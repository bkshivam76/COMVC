@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid()

        .ID("GLookUp_AssetList_AsetTrans_datagrid").CustomDataGrid()

        .Columns(columns =>
        {
            columns.Add().DataField("REF_ITEM").Caption("Asset Name").SortOrder(SortOrder.Asc);
            columns.Add().DataField("REF_DESC").Caption("Description");
            columns.Add().DataField("REF_AMT").Caption("Value");
            columns.Add().DataField("REF_QTY").Caption("Quantity");
            columns.Add().DataField("REF_CREATION_DATE").Caption("Voucher Date").DataType(GridColumnDataType.Date).Format("dd/MM/yyyy");

            columns.Add().DataField("REC_EDIT_ON").Caption("REC_EDIT_ON").Visible(false);
            columns.Add().DataField("REF_ITEM_ID").Caption("REF_ITEM_ID").Visible(false);
            columns.Add().DataField("REF_MISC_ID").Caption("REF_MISC_ID").Visible(false);
            columns.Add().DataField("REF_LED_ID").Caption("REF_LED_ID").Visible(false);
            columns.Add().DataField("REF_TRANS_TYPE").Caption("REF_TRANS_TYPE").Visible(false);
            columns.Add().DataField("SALE_QTY").Caption("Sale Quantity").Visible(false);

            columns.Add().DataField("REF_NAME").Caption("REF_NAME").Visible(false);
            columns.Add().DataField("ITEM_CON_LED_ID").Caption("ITEM_CON_LED_ID").Visible(false);
            columns.Add().DataField("AI_TYPE").Caption("AI_TYPE").Visible(false);
        })

        .Selection(s => s.Mode(SelectionMode.Single))
)