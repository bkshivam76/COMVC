
@{
}

@Html.DevExpress().ComboBox(
                  settings =>
                  {
                      settings.Name = "AssetList";
                      settings.CallbackRouteValues = new { Controller = "AssetTransferVoucher", Action = "AssetTransfer_LookUp_GetAssetList_LIVESTOCK" };
                      settings.Properties.DropDownStyle = DropDownStyle.DropDown;
                      settings.Properties.ValueField = "REF_ITEM_ID";
                      settings.Properties.TextFormatString = "{0}";
                      settings.Width = Unit.Percentage(100);
                      settings.Properties.NullDisplayText = "Select Asset";
                      settings.SelectedIndex = -1;
                      settings.Properties.Columns.Add("REF_ITEM", "Asset Name");
                      settings.Properties.Columns.Add("REF_DESC", "Description");
                      settings.Properties.Columns.Add("REF_QTY", "Quantity");
                      settings.Properties.Columns.Add("REC_EDIT_ON", "Voucher Date");

                      settings.Properties.ValidationSettings.ErrorTextPosition = ErrorTextPosition.Bottom;
                      settings.Properties.ClientSideEvents.SelectedIndexChanged = "ChangeAsset_ListAssetTransferVoucher";
                      settings.Properties.ClientSideEvents.ValueChanged = "ChangeAsset_ListAssetTransferVoucher";
                      //settings.Properties.ClientSideEvents.Init = "AssetsTransferAssetListRaiseSelectedIndexChanged";                      
                      settings.Properties.ClientSideEvents.BeginCallback = @"function(s, e) {       
                      e.customArgs['CROSS_M_ID'] = $('#CROSS_M_ID').val();
                      e.customArgs['iFR_CEN_ID'] = $('#iFR_CEN_ID').val();  
                      e.customArgs['USE_CROSS_REF'] = $('#USE_CROSS_REF').val();  
                      e.customArgs['Cmb_Asset_Type_SelectedIndex'] = $('#Cmb_Asset_Type_SelectedIndex').val();  
                      e.customArgs['IsReadOnly'] = '" + (Model.IsReadOnly != null ? (Convert.ToBoolean(Model.IsReadOnly) ? "true" : "false") : "false") + "' }";

                  }).BindList(@ViewData["AssetList"]).Bind(Model.selectData).GetHtml()


