
@using DevExtreme.AspNet.Data;
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("FrCen_List_AsetTrans_datagrid")
    .Columns(columns =>
    {
        columns.Add().DataField("FR_CEN_NAME").Caption("Name");
        columns.Add().DataField("FR_UID").Caption("U.ID. No.");
        columns.Add().DataField("FR_PAD_NO").Caption("No.");
        columns.Add().DataField("FR_INCHARGE").Caption("Incharge");
        columns.Add().DataField("FR_ZONE").Caption("Zone");
        columns.Add().DataField("FR_TEL_NO").Visible(false);
    })

    .Selection(s => s.Mode(SelectionMode.Single))

)
