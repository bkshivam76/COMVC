
@using DevExtreme.AspNet.Data;
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("TOCen_List_AsetTrans_datagrid")
    .Columns(columns =>
    {
        columns.Add().DataField("TO_CEN_NAME").Caption("Name");
        columns.Add().DataField("TO_UID").Caption("U.ID. No.");
        columns.Add().DataField("TO_PAD_NO").Caption("No.");
        columns.Add().DataField("TO_INCHARGE").Caption("Incharge");
        columns.Add().DataField("TO_ZONE").Caption("Zone");
        columns.Add().DataField("TO_TEL_NO").Visible(false);
    })

    .Selection(s => s.Mode(SelectionMode.Single))
)
