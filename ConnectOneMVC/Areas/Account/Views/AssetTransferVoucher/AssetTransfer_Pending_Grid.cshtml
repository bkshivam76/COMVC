@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    string ExportGridHeaderLeft = (string)ViewBag.ExportGridHeaderLeft;
    string ExportGridHeaderRight = (string)ViewBag.ExportGridHeaderRight;
    string ExportGridFooter = (string)ViewBag.ExportGridFooter;
}

@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "AssetTransfer_Pending_ListGrid";
        settings.CallbackRouteValues = new
        {
            Controller = "AssetTransferVoucher",
            Action = "AssetTransfer_Pending_Grid",
            SessionGUID = SessionGUID

        };

        settings.ClientSideEvents.BeginCallback = "AsetTrans_PendingBeginCallback";
        settings.CustomDataActionRouteValues = new { Controller = "AssetTransferVoucher", Action = "AssetTransferCustomDataAction" };
        settings.ClientSideEvents.FocusedRowChanged = "AssetTrasferOnGridFocusedRowChanged";
        settings.ClientSideEvents.EndCallback = "AsetTrans_PendingEndCallback";
        settings.ClientSideEvents.ContextMenuItemClick = "AsetTrans_PendingContextMenuClick";
        settings.ClientSideEvents.RowDblClick = "AsetTrans_PendingRowDblClick";

        settings.Styles.Row.Wrap = DefaultBoolean.False;
        settings.SettingsBehavior.AllowEllipsisInText = true;

        settings.FillContextMenuItems = (sender, e) =>
        {
            if (e.MenuType == GridViewContextMenuType.Rows)
            {
                var Accept = e.CreateItem("Accept Transfer", "Accept");
                Accept.Image.IconID = "actions_apply_16x16gray";
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Accept);

                var PrintView = e.CreateItem("List Preview", "ListPreview");
                PrintView.Image.IconID = "actions_hideproduct_16x16devav";
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), PrintView);
                var Close = e.CreateItem("Close", "Close");
                Close.Image.IconID = "actions_close_16x16devav";
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Close);
            }
        };

        settings.Settings.GroupFormat = "{1}";
        settings.KeyFieldName = "ID";

        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "ITEM_ID",
            Caption = "ITEM ID",
            Visible = false
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Description",
            Caption = "Description",
            GroupIndex = 0
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Centre Name",
            Caption = "Centre Name",
            Width = 200
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Incharge",
            Caption = "Incharge",
            Width = 100

        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Contact No.",
            Caption = "Contact No",
            Width = 100

        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Centre UID",
            Caption = "Centre UID",
            Width = 100

        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "No.",
            Caption = "No.",
            Width = 100

        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "CEN_ID",
            Caption = "CEN ID",
            Visible = false

        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Date",
            Caption = "Date",
            PropertiesEdit = { DisplayFormatString = "dd-MM-yyyy" },
            Width = 100
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Asset Type",
            Caption = "Asset Type",
            Width = 200
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Asset",
            Caption = "Asset",
            Width = 200

        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "ASSET_ITEM_ID",
            Caption = "ASSET ITEM ID",
            Visible = false

        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Qty / Weight",
            Caption = "Qty/Weight",
            Width = 100

        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Amount",
            Caption = "Amount",
            Width = 100

        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "ASSET_REF_ID",
            Caption = "ASSET REF ID",
            Visible = false

        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Purpose",
            Caption = "Purpose",
            Width = 200


        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "PUR_ID",
            Caption = "PUR ID",
            Visible = false

        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "ID",
            Caption = "ID",
            Visible = false
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "M_ID",
            Caption = "M_ID",
            Visible = false
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "REC_EDIT_ON",
            Caption = "REC EDIT ON",
            Visible = false
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Narration",
            Caption = "Narration",
            Width = 100
        });


        settings.Settings.ShowHeaderFilterBlankItems = false;
        settings.SettingsContextMenu.Enabled = true;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsContextMenu.EnableGroupFooterMenu = DefaultBoolean.False;
        settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.Refresh = false;

        settings.Settings.VerticalScrollBarMode = ScrollBarMode.Visible;
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Visible;
        settings.Settings.ShowHeaderFilterButton = true;

        settings.KeyboardSupport = true;
        //settings.AccessKey = "G";
        settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
        //settings.Width = 800;


        settings.Settings.ShowGroupFooter = GridViewGroupFooterMode.Hidden;

        settings.SettingsBehavior.AutoExpandAllGroups = true;
        settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
        settings.Settings.UseFixedTableLayout = true;
        settings.SettingsBehavior.ColumnMoveMode = GridColumnMoveMode.AmongSiblings;
        settings.SettingsBehavior.AllowSort = true;
        settings.SettingsBehavior.EnableCustomizationWindow = true;

        settings.Settings.ShowFilterRow = true;
        settings.Settings.AutoFilterCondition = AutoFilterCondition.Contains;

        settings.SettingsSearchPanel.ShowApplyButton = true;
        settings.SettingsSearchPanel.ShowClearButton = true;
        settings.SettingsBehavior.AllowFocusedRow = true;

        // show filter control
        settings.Settings.ShowFilterBar = GridViewStatusBarMode.Visible;
        settings.SettingsFilterControl.ViewMode = true ? FilterControlViewMode.VisualAndText : FilterControlViewMode.Visual;
        settings.SettingsFilterControl.AllowHierarchicalColumns = true;// AllowHierarchicalColumns;
        settings.SettingsFilterControl.ShowAllDataSourceColumns = true;//FilterBuilderDemoHelper.Options.ShowAllDataSourceColumns;
        settings.SettingsFilterControl.MaxHierarchyDepth = 1;

        settings.Settings.ShowGroupedColumns = false;
        settings.Settings.ShowFooter = false;

        settings.Styles.GroupRow.Font.Bold = true;
        settings.SettingsBehavior.AllowFixedGroups = true;


        settings.SettingsExport.EnableClientSideExportAPI = true;
        settings.SettingsExport.ExcelExportMode = DevExpress.Export.ExportType.DataAware;
        settings.SettingsExport.PageHeader.Center = "Pending Asset Transfer Entries";
        settings.SettingsExport.PageHeader.Left = ExportGridHeaderLeft;
        settings.SettingsExport.PageHeader.Right = ExportGridHeaderRight;
        settings.SettingsExport.PageFooter.Right = ExportGridFooter;//Redmine bug 132871 fixed
        settings.SettingsExport.PageFooter.Font.Size = 7;
        settings.SettingsExport.PaperKind = System.Drawing.Printing.PaperKind.A4Rotated;
        settings.SettingsExport.TopMargin = 10;
        settings.SettingsExport.LeftMargin = 10;
        settings.SettingsExport.RightMargin = 10;
        settings.SettingsExport.BottomMargin = 10;
        //pager settings
        settings.SettingsPager.Mode = GridViewPagerMode.ShowPager;
        settings.SettingsPager.PageSizeItemSettings.Visible = true;
        settings.SettingsPager.PageSize = 25;
        MyExtensions.GridViewHelper.CustomGridView(settings);
    }).Bind(Model).GetHtml()