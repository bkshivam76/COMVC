<script>
        $(document).ready(async function ()
        {
            ShowLoader_Ready();
            InitAllDropdownDatagrid_AsetTrans();
            TransformTextForDB("Frm_AssetTransferVoucher_Window");
            $("#TextEdit1Text_AsetTrans").find('input').css("color", "#696969");
            $("#TextEdit1_Div_AsetTrans").hide();
            if (Tag_AsetTrans != "_View")
            {
                dontaskpopupcloseconfirmation = false;
            }
            sessionclearpath = "/Account/AssetTransferVoucher/SessionClear";
            await Promise.all([LookUp_GetItemList_AsetTrans(true), LookUp_GetPurposeList_AsetTrans(true), LookUp_GetOwnList_AsetTrans(true), LookUp_GetLocList_AsetTrans(true)]);
            if (Tag_AsetTrans == "_New" || Tag_AsetTrans == "_New_From_Selection")
            {
                if ("@Model.Txt_SaleAmt_AsetTrans".length == 0)
                {
                    $("#Txt_SaleAmt_AsetTrans").dxNumberBox("option", "value", null);
                }
                if ("@Model.pending_list" == "True")
                {
                    ShowLoader();
                    OpenPopup("popup_frm_Asset_Transfer_Pending_Window","Pending Asset Transfer Entries", "/Account/AssetTransferVoucher/Frm_Asset_Transfer_Pending", "auto", 1000, false, null);
                    HideLoader();
                }
                else
                {
                    After_AssetTransfer_loaded();
                }
            }
            else if (Tag_AsetTrans == "_Edit" || Tag_AsetTrans == "_Delete" || Tag_AsetTrans == "_View")
            {
                await GLookUp_ItemList_DataGrid_AsetTrans.selectRows("@Model.GLookUp_ItemList_AsetTrans", false);
                ItemList_ATV_ReadOnly = false;
                Control_SetReadOnly("GLookUp_ItemList_AsetTrans", "dxDropDownBox", (ItemList_ATV_Enable == true && ItemList_ATV_ReadOnly == false) ? false : true);
                await GLookUp_ToCen_List_DataGrid_AsetTrans.selectRows("@Model.GLookUp_ToCen_List_AsetTrans", false);
                ToCen_ATV_ReadOnly = false;
                Control_SetReadOnly("GLookUp_ToCen_List_AsetTrans", "dxDropDownBox", (ToCen_ATV_Enable == true && ToCen_ATV_ReadOnly == false) ? false : true);
                await GLookUp_FrCen_List_DataGrid_AsetTrans.selectRows("@Model.GLookUp_FrCen_List_AsetTrans", false);
                FrCen_ATV_ReadOnly = false;
                Control_SetReadOnly("GLookUp_FrCen_List_AsetTrans", "dxDropDownBox", (FrCen_ATV_Enable == true && FrCen_ATV_ReadOnly == false) ? false : true);
                $("#Cmb_Asset_Type_AsetTrans").dxSelectBox("instance").option("value", TransformText("@Model.Cmb_Asset_Type_AsetTrans"));
                await GLookUp_AssetList_DataGrid_AsetTrans.selectRows("@Model.GLookUp_AssetList_AsetTrans", false);
                AssetList_ATV_ReadOnly = false;
                Control_SetReadOnly("GLookUp_AssetList_AsetTrans", "dxDropDownBox", (AssetList_ATV_Enable == true && AssetList_ATV_ReadOnly == false) ? false : true);
                $("#Txt_Qty_AsetTrans").dxNumberBox("instance").option("value", parseFloat("@Model.Txt_Qty_AsetTrans"));
                $("#Txt_SaleAmt_AsetTrans").dxNumberBox("instance").option("value", parseFloat("@Model.Txt_SaleAmt_AsetTrans"));
                await GLookUp_PurList_DataGrid_AsetTrans.selectRows("@Model.GLookUp_PurList_AsetTrans", false);
                PurList_ATV_ReadOnly = false;
                Control_SetReadOnly("GLookUp_PurList_AsetTrans", "dxDropDownBox", (PurList_ATV_Enable == true && PurList_ATV_ReadOnly == false) ? false : true);
                After_AssetTransfer_loaded();
            }

            //FCRA Related
            //await $("#ListSpecialVoucherRef_Astr").dxList("getDataSource").load();            
            if (parseInt("@Model.splVchrRefsCount_Astr") > 0) {
                //await $("#ListSpecialVoucherRef_Astr").dxList("getDataSource").load();
                OnSplVchrRefsListSelectionChanged_Astr();
            }
            if (parseInt("@Model.splVchrRefsCount_Astr") == 0)
            {
                $("#Astr_SpecialVoucherRefDiv").remove();
                $("#Astr_NarrationDiv").removeClass("col-sm-12 col-md-8 col-lg-8").addClass("col-sm-12 col-md-12");
            }

        });
    async function After_AssetTransfer_loaded()
    {
        if (Tag_AsetTrans == "_New_From_Selection" && (Check_USE_CROSS_REF() == false)) //By Item-wise Selection
        {
            await GLookUp_ItemList_DataGrid_AsetTrans.selectRows($("#iSpecific_ItemID").val(), false);
            ItemList_ATV_ReadOnly = false;
            Control_SetReadOnly("GLookUp_ItemList_AsetTrans", "dxDropDownBox", (ItemList_ATV_Enable == true && ItemList_ATV_ReadOnly == false) ? false : true);
            $("#Txt_V_Date_AsetTrans").dxDateBox("instance").focus();
        }
        else
        {
            $("#GLookUp_ItemList_AsetTrans").dxDropDownBox("instance").focus();
        }
        if ("@UserType".toUpperCase() != "SUPERUSER" && "@UserType".toUpperCase() != "AUDITOR")
        {
            $("#Txt_SaleAmt_AsetTrans").dxNumberBox("instance").option("visible", false);
            $("#lblAsetValue").hide();
            GLookUp_AssetList_DataGrid_AsetTrans.columnOption("REF_AMT","visible", false);
        }
        FormInitialSettings("Frm_AssetTransferVoucher_Window", Tag_AsetTrans);
        //setTimeout(function ()
        //{
        //    Set_Form_View_Delete_Mode(null, "Frm_AssetTransferVoucher_Window", Tag_AsetTrans);
        //    Focus_FirstEditable_Field("Frm_AssetTransferVoucher_Window", Tag_AsetTrans);
        //    HideLoader_Ready();
        //}, Timeout500);
    }
    function AjaxSuccessAssetTransfer(data)
    {
            HideLoader();
            if (data.jsonParam.result == false)
            {
                if (data.jsonParam.closeform)
                {
                    dontaskpopupcloseconfirmation = true;
                    $("#Dynamic_Content_popup").dxPopup("hide");
                }
                if (data.jsonParam.refreshgrid)
                {
                     RefreshGridView("@ViewBag.GridToRefresh");
                }
                var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                alertclick.done(function (alertResult)
                {
                    if (alertResult)
                    {
                        if (data.jsonParam.focusid)
                        {
                            var id = "#" + data.jsonParam.focusid;
                            setTimeout(function ()
                            {
                                $(id).find('input').focus();
                            }, Timeout500);
                        }
                    }
                });
            }
            else if (data.jsonParam.result == true)
            {
                var VouDate = $("#Txt_V_Date_AsetTrans").dxDateBox("instance").option("value");
                var _ActiveTab_ID = $(".TabPanalMenu-tabs .active").attr("id");
                var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                alertclick.done(function (result)
                {
                    if (result)
                    {
                        if ("@ViewBag.GridToRefresh" != "CashBookListGrid")
                        {
                            RefreshGridView("@ViewBag.GridToRefresh");
                        }
                        if (/*typeof CashBookListGrid !== 'undefined'*/ _ActiveTab_ID =="contact_Frm_Voucher_Info_CB")
                        {
                            AfterVoucherClose_CB(VouDate, Tag_AsetTrans, IsUndefinedOrNull(data.CashbookGridPK) ? "" : data.CashbookGridPK);
                        }
                        else if (_ActiveTab_ID == "contact_Frm_Voucher_Info") {
                            AfterVoucherClose_VoucherEntry();
                        }
                        dontaskpopupcloseconfirmation = true;
                        $("#Dynamic_Content_popup").dxPopup("hide");
                    }
                });
            }
        }
</script> @*Document.ready() SetDefault() AjaxSuccess()*@

