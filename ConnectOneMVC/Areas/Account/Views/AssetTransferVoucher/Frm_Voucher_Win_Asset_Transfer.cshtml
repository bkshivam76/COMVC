<script>
    function BUT_SAVE_Click_AsetTrans(e)
    {
        if (ValidateForm(e))
        {
            var form = $("#Frm_AssetTransferVoucher_Window");
            if (Tag_AsetTrans == "_Delete")
            {
                DeleteAfterConfirmation("@Model.Me_Text", "", form);
            }
            else
            {
                debugger
                var AssetType = $("#Cmb_Asset_Type_AsetTrans").dxSelectBox("option", "value");
                var AssetDesc = $("#Txt_Desc_AsetTrans").dxTextBox("option", "value");
                var SelectedParty = $("#Look_OwnList_AsetTrans").dxDropDownBox("option", "text");
                if (AssetType != null) {
                    if (AssetType == "ADVANCES" || AssetType == "OTHER DEPOSITS" || AssetType == "OTHER LIABILITIES") {
                        if (AssetDesc.split(',')[0] !=SelectedParty) {
                            var confirm = DevExpress.ui.dialog.confirm("Party name used in sending Centre ( " + AssetDesc.split(',')[0] + " ) is different from Party Selected by you. <br>Sure You Want To Continue?", "Confirm");
                            confirm.done(function (dialogresult) {
                                if (dialogresult) { form.submit(); }
                            });
                        }
                    }
                }
                else {
                    form.submit();
                }
