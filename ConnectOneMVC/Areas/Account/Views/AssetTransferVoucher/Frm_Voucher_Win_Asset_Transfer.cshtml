<div class="AssetTransferVoucher_ClearReferences">
    @using DevExtreme.AspNet.Mvc;    

    @model ConnectOneMVC.Areas.Account.Models.AssetTransferVoucher
    @{
        Html.EnableClientValidation();
        Html.EnableUnobtrusiveJavaScript();
        bool IsVisible = Model != null && (Model.Tag.ToString().Trim() == "_View" || Model.Tag.ToString().Trim() == "_Delete") ? true : false;
        var Open_Institute_Name = ViewData["Open_Institute_Name"];
        var UserType = (string)ViewBag.OpenUserType;
    }
    <style>
        #ListSpecialVoucherRef_Astr .dx-list-item-content {
            padding: 4.5px;
        }
    </style>
    <div id="Frm_Voucher_Win_Asset_Transfer_popup">
        @using (Ajax.BeginForm("Frm_AssetTransferVoucher_Window", "AssetTransferVoucher",
            new AjaxOptions
            {
                HttpMethod = "POST",
                UpdateTargetId = "Frm_Voucher_Win_Asset_Transfer_popup",
                InsertionMode = InsertionMode.InsertAfter,
                OnBegin = "AjaxBeginFormPost",
                OnSuccess = "AjaxSuccessAssetTransfer"
            },
            new
            {
                id = "Frm_AssetTransferVoucher_Window",
                @class = "edit_form form-horizontal"
            }))
        {
            @Html.HiddenFor(x => x.xID1_AsetTrans)
            @Html.HiddenFor(x => x.ActionMethod)
            @Html.HiddenFor(x => x.CROSS_REF_ID)
            @Html.HiddenFor(x => x.iAsset_Type)
            @Html.HiddenFor(x => x.HQ_IDs)
            @Html.HiddenFor(x => x.iCon_Led_ID)
            @Html.HiddenFor(x => x.Info_LastEditedOn)
            @Html.HiddenFor(x => x.Info_MaxEditedOn)
            @Html.HiddenFor(x => x.iRef_ItemID)
            @Html.HiddenFor(x => x.iSpecific_ItemID)
            @Html.HiddenFor(x => x.LastEditedOn)
            @Html.HiddenFor(x => x.Tag)
            @Html.HiddenFor(x => x.xMID)
            @Html.HiddenFor(x => x.aItem_ID)
            @Html.HiddenFor(x => x.aLed_ID)
            @Html.HiddenFor(x => x.iVoucher_Type)
            @Html.HiddenFor(x => x.iLed_ID)
            @Html.HiddenFor(x => x.iTrans_Type)
            @Html.HiddenFor(x => x.iParty_Req)
            @Html.HiddenFor(x => x.iProfile)
            @Html.HiddenFor(x => x.iMinValue)
            @Html.HiddenFor(x => x.iMaxValue)
            @Html.HiddenFor(x => x.USE_CROSS_REF)
            @Html.HiddenFor(x => x.OwnershipRequire)
            @Html.HiddenFor(x => x.Property_Name)
            @Html.HiddenFor(x => x.iTO_CEN_ID)
            @Html.HiddenFor(x => x.AssetList_REF_CREATION_DATE)
            @Html.HiddenFor(x => x.AssetList_REC_EDIT_ON)
            @Html.HiddenFor(x => x.AssetList_REF_AMT)
            @Html.HiddenFor(x => x.LocList_REC_EDIT_ON)
            @Html.HiddenFor(x => x.iFR_CEN_ID)
            @Html.HiddenFor(x => x.CROSS_M_ID)
            @Html.HiddenFor(x => x.FR_REC_EDIT_ON)
            @Html.HiddenFor(x => x.TitleX)
            @Html.HiddenFor(x => x.Me_Text)
            @Html.HiddenFor(x => x.pending_list)
            @Html.HiddenFor(x => x.TextEdit1Tag_AsetTrans)
            @Html.HiddenFor(x => x.Txt_SaleAmtTag_AsetTrans)
            @Html.HiddenFor(x => x.xID2)
            //FCRA Related
            @Html.HiddenFor(x => x.Astr_SplVchrReferenceSelected)
            @Html.HiddenFor(x => x.splVchrRefsCount_Astr)

            using (Html.DevExtreme().ValidationGroup())
            {
                <div class="container-fluid">
                    <div class="full-width-header-bg2">
                        <div class="row">
                            <div class="col-sm-8">
                                <h3 class="popuphead"><i class="far fa-edit"></i> Asset Transfer</h3>
                            </div>
                            <div class="col-sm-4 prm">
                                <h5 class="mand-txt-align">
                                    <i class="fas fa-info-circle"></i> Red Fields are mandatory
                                </h5>
                            </div>
                            @Html.ValidationSummary(true, "", new { @class = "text-red" })
                        </div>
                    </div><!--[Header]-->
                    <div class="row">
                        <div class="col-sm-8">
                            <div class="form-field">
                                <div class="row">
                                    <div class="col-sm-3 pll">
                                        @Html.Label("Item Name:", htmlAttributes: new { @class = "control-label" })
                                    </div>
                                    <div class="col-sm-9 prm">
                                        @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_ItemList_AsetTrans").Name("GLookUp_ItemList_AsetTrans") .ValueExpr("ITEMID") .DisplayExpr("ITEMNAME")
                                                .DataSource(d => d.Mvc().Controller("AssetTransferVoucher").LoadAction("AssetTransfer_LookUp_GetItemList").Key("ITEMID").LoadParams(new { USE_CROSS_REF = new JS("function (){return Check_USE_CROSS_REF();}"), DDRefresh = new JS("function (){ return ItemListDDRefresh_AsetTrans;}") }).LoadMode(DataSourceLoadMode.Raw).CacheRawData(true))
                                                .Placeholder("Select Item...").OnValueChanged("GLookUp_ItemList_EditValueChanged_AsetTrans").ReadOnly(true).FocusStateEnabled(false).ContentTemplate(@<text> @Html.Partial("AssetTransfer_LookUp_GetItemList") </text>) )

                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-field">
                                <div class="row">
                                    <div class="col-sm-6 pll">
                                        @Html.Label("Voucher Date:", htmlAttributes: new { @class = "control-label text-red" })
                                    </div>
                                    <div class="col-sm-6 prm">
                                        @(Html.DevExtreme().DateBox().CustomDateBox().ID("Txt_V_Date_AsetTrans").Name("Txt_V_Date_AsetTrans").Value(Model.Txt_V_Date_AsetTrans))

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div><!--[row 1]-->
                    <div class="row">
                        <div class="col-sm-8">
                            <div class="form-field">
                                <div class="row">
                                    <div class="col-sm-3 pll">
                                        @Html.Label("Head:", htmlAttributes: new { @class = "control-label" })
                                    </div>
                                    <div class="col-sm-9 prm">
                                        @(Html.DevExtreme().TextBox().CustomTextBox().ID("BE_Item_Head_AsetTrans").Name("BE_Item_Head_AsetTrans").ReadOnly(true).FocusStateEnabled(false))
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-field">
                                <div class="row">
                                    <div class="col-sm-6 pll">
                                        @Html.Label("Voucher No:", htmlAttributes: new { @class = "control-label" })
                                    </div>
                                    <div class="col-sm-6 prm">
                                        @(Html.DevExtreme().TextBox().CustomTextBox().ID("Txt_V_NO_AsetTrans").Name("Txt_V_NO_AsetTrans").ReadOnly(true).FocusStateEnabled(false))
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div><!--[row 2]-->
                    <div class="row">
                        <div class="col-sm-12">
                            <div class="form-field">
                                <fieldset class="default-fieldset">
                                    <legend class="custom-legend mlm"> Transfer From:</legend>
                                    <div class="row">
                                        <div class="col-sm-2 pll">
                                            @Html.Label("From Centre:", htmlAttributes: new { @class = "control-label text-red" })
                                        </div>
                                        <div class="col-sm-6 prm">
                                            @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_FrCen_List_AsetTrans").Name("GLookUp_FrCen_List_AsetTrans").ValueExpr("FR_ID") .DisplayExpr("FR_CEN_NAME")
                                                      .DataSource(d => d.Mvc().Controller("AssetTransferVoucher").LoadAction("AssetTransfer_LookUp_GetFromCenterList").Key("FR_ID").LoadParams(new { iTrans_Type = new JS("function (){ return $('#iTrans_Type').val();}"), DDRefresh = new JS("function (){return FrCen_ListDDRefresh_AsetTrans; }") }).LoadMode(DataSourceLoadMode.Raw).CacheRawData(true))
                                                      .Placeholder("Select Centre (Transfer From)...").OnValueChanged("GLookUp_FrCen_List_EditValueChanged_AsetTrans").ReadOnly(true).ContentTemplate(@<text> @Html.Partial("AssetTransfer_LookUp_GetFromCenterList") </text>).FocusStateEnabled(false) )

                                        </div>
                                        <div class="col-sm-2 prm">
                                            <label class="control-label" for="BE_Fr_UID_AsetTrans">Centre U.ID. No.:</label>
                                        </div>
                                        <div class="col-sm-2 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("BE_Fr_UID_AsetTrans").Name("BE_Fr_UID_AsetTrans").Value(Model.BE_Fr_UID_AsetTrans).ReadOnly(true).FocusStateEnabled(false) )
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-sm-2 pll">
                                            @Html.Label("Institute:", htmlAttributes: new { @class = "control-label" })
                                        </div>
                                        <div class="col-sm-6 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_Fr_Institute_AsetTrans") .Name("BE_Fr_Institute_AsetTrans") .Value(Model.BE_Fr_Institute_AsetTrans) .ReadOnly(true).FocusStateEnabled(false) )

                                        </div>
                                        <div class="col-sm-2 prm">
                                            <label class="control-label" for="BE_Fr_Pad_No_AsetTrans">PAD No.:</label>
                                        </div>
                                        <div class="col-sm-2 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_Fr_Pad_No_AsetTrans") .Name("BE_Fr_Pad_No_AsetTrans") .Value(Model.BE_Fr_Pad_No_AsetTrans) .ReadOnly(true).FocusStateEnabled(false) )

                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-sm-2 pll">
                                            @Html.Label("Incharge:", htmlAttributes: new { @class = "control-label" })
                                        </div>
                                        <div class="col-sm-2 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_Fr_Incharge_AsetTrans") .Name("BE_Fr_Incharge_AsetTrans") .Value(Model.BE_Fr_Incharge_AsetTrans) .ReadOnly(true).FocusStateEnabled(false))

                                        </div>
                                        <div class="col-sm-1 prm">
                                            <label class="control-label" for="BE_Fr_Tel_No_AsetTrans">Tel.No.:</label>
                                        </div>
                                        <div class="col-sm-3 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_Fr_Tel_No_AsetTrans") .Name("BE_Fr_Tel_No_AsetTrans") .Value(Model.BE_Fr_Tel_No_AsetTrans) .ReadOnly(true).FocusStateEnabled(false) )

                                        </div>
                                        <div class="col-sm-2 prm">
                                            @Html.Label("Zone:", htmlAttributes: new { @class = "control-label" })
                                        </div>
                                        <div class="col-sm-2 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_Fr_Zone_AsetTrans") .Name("BE_Fr_Zone_AsetTrans") .Value(Model.BE_Fr_Zone_AsetTrans) .ReadOnly(true).FocusStateEnabled(false) )

                                        </div>
                                    </div>
                                </fieldset>
                            </div>
                        </div>
                    </div><!--[From]-->
                    <div class="row">
                        <div class="col-sm-12">
                            <div class="form-field">
                                <fieldset class="default-fieldset">
                                    <legend class="custom-legend mlm"> Transfer To:</legend>
                                    <div class="row">
                                        <div class="col-sm-2 pll">
                                            @Html.Label("To Centre:", htmlAttributes: new { @class = "control-label text-red" })
                                        </div>
                                        <div class="col-sm-6 prm">
                                            @(Html.DevExtreme().DropDownBox().CustomDropDown() .ID("GLookUp_ToCen_List_AsetTrans") .Name("GLookUp_ToCen_List_AsetTrans") .ValueExpr("TO_ID") .DisplayExpr("TO_CEN_NAME")
                                                      .DataSource(d => d.Mvc().Controller("AssetTransferVoucher").LoadAction("AssetTransfer_LookUp_GetToCenterList").Key("TO_ID").LoadParams(new { iTrans_Type = new JS("function (){return $('#iTrans_Type').val();}"), DDRefresh = new JS("function() {return ToCen_ListDDRefresh_AsetTrans;}") }).LoadMode(DataSourceLoadMode.Raw).CacheRawData(true))
                                                      .Placeholder("Select Centre (Transfer To)...") .OnValueChanged("GLookUp_ToCen_List_EditValueChanged_AsetTrans") .ReadOnly(true) .ContentTemplate(@<text> @Html.Partial("AssetTransfer_LookUp_GetToCenterList") </text>).FocusStateEnabled(false) )

                                        </div>
                                        <div class="col-sm-2 prm">
                                            <label class="control-label" for="BE_To_UID_AsetTrans">Centre U.ID. No.:</label>
                                        </div>
                                        <div class="col-sm-2 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_To_UID_AsetTrans") .Name("BE_To_UID_AsetTrans") .Value(Model.BE_To_UID_AsetTrans) .ReadOnly(true).FocusStateEnabled(false) )
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-sm-2 pll">
                                            @Html.Label("Institute:", htmlAttributes: new { @class = "control-label" })
                                        </div>
                                        <div class="col-sm-6 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_To_Institute_AsetTrans") .Name("BE_To_Institute_AsetTrans") .Value(Model.BE_To_Institute_AsetTrans) .ReadOnly(true).FocusStateEnabled(false) )

                                        </div>
                                        <div class="col-sm-2 prm">
                                            <label class="control-label" for="BE_To_Pad_No_AsetTrans">PAD No.:</label>
                                        </div>
                                        <div class="col-sm-2 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_To_Pad_No_AsetTrans") .Name("BE_To_Pad_No_AsetTrans") .Value(Model.BE_To_Pad_No_AsetTrans) .ReadOnly(true).FocusStateEnabled(false) )

                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-sm-2 pll">
                                            @Html.Label("Incharge:", htmlAttributes: new { @class = "control-label" })
                                        </div>
                                        <div class="col-sm-2 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_To_Incharge_AsetTrans") .Name("BE_To_Incharge_AsetTrans") .Value(Model.BE_To_Incharge_AsetTrans) .ReadOnly(true).FocusStateEnabled(false) )

                                        </div>
                                        <div class="col-sm-1">
                                            <label class="control-label" for="BE_To_Tel_No">Tel.No.:</label>
                                        </div>
                                        <div class="col-sm-3 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_To_Tel_No_AsetTrans") .Name("BE_To_Tel_No_AsetTrans") .Value(Model.BE_To_Tel_No_AsetTrans) .ReadOnly(true).FocusStateEnabled(false) )

                                        </div>
                                        <div class="col-sm-2 prm">
                                            @Html.Label("Zone:", htmlAttributes: new { @class = "control-label" })
                                        </div>
                                        <div class="col-sm-2 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_To_Zone_AsetTrans") .Name("BE_To_Zone_AsetTrans") .Value(Model.BE_To_Zone_AsetTrans) .ReadOnly(true).FocusStateEnabled(false) )

                                        </div>
                                    </div>
                                </fieldset>
                            </div>
                        </div>
                    </div><!--[TO]-->
                    <div class="row">
                        <div class="col-sm-12">
                            <div class="form-field">
                                <fieldset class="default-fieldset">
                                    <legend class="custom-legend mlm"> Asset Detail:</legend>
                                    <div class="row">
                                        <div class="col-sm-2 pll">
                                            @Html.Label("Asset Type:", htmlAttributes: new { @class = "control-label text-red" })
                                        </div>
                                        <div class="col-sm-6 prm">
                                            @(Html.DevExtreme().SelectBox().CustomSelectBox() .ID("Cmb_Asset_Type_AsetTrans") .Name("Cmb_Asset_Type_AsetTrans") .DataSource(new[] { "GOLD", "SILVER", "VEHICLES", "LIVESTOCK", "MOVABLE ASSETS", "LAND & BUILDING", "FD", "ADVANCES", "OTHER DEPOSITS","OTHER LIABILITIES" }).OnValueChanged("Cmb_Asset_Type_SelectedIndexChanged_AsetTrans").Placeholder("Select Type...").ShowClearButton(false) )

                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-sm-2 pll">
                                            @Html.Label("Asset Name:", htmlAttributes: new { @class = "control-label text-red" })
                                        </div>
                                        <div class="col-sm-6 prm">
                                            @(Html.DevExtreme().DropDownBox().CustomDropDown() .ID("GLookUp_AssetList_AsetTrans") .Name("GLookUp_AssetList_AsetTrans") .ValueExpr("REF_ID") .DisplayExpr("REF_ITEM").ShowClearButton(false)
                                                    .DataSource(d => d.Mvc().Controller("AssetTransferVoucher").LoadAction("GLookUp_Get_AssetList_AsetTrans").Key("REF_ID").LoadMode(DataSourceLoadMode.Raw).CacheRawData(true))
                                                    .ReadOnly(true).OnValueChanged("GLookUp_AssetList_EditValueChanged_AsetTrans").ContentTemplate(@<text> @Html.Partial("AssetTransfer_LookUp_GetAssetList") </text>).FocusStateEnabled(false).Placeholder("Select Asset"))

                                        </div>
                                        <div class="col-sm-2 prm">
                                            @Html.Label("Asset Value:", htmlAttributes: new { @class = "control-label", @id = "lblAsetValue" })
                                        </div>
                                        <div class="col-sm-2 prm">
                                            @(Html.DevExtreme().NumberBox().CustomNumberBox() .ID("Txt_SaleAmt_AsetTrans") .Name("Txt_SaleAmt_AsetTrans") .ReadOnly(true) .OnValueChanged("Txt_Amount_EditValueChanged_AsetTrans").FocusStateEnabled(false).Format("#0.##") )

                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-sm-2 pll">
                                            @Html.Label("Description:", htmlAttributes: new { @class = "control-label" })
                                        </div>
                                        <div class="col-sm-6 prm">
                                            @(Html.DevExtreme().TextBoxFor(x => x.Txt_Desc_AsetTrans).CustomTextBox() .ID("Txt_Desc_AsetTrans") .Name("Txt_Desc_AsetTrans") .ReadOnly(true).FocusStateEnabled(false) )
                                        </div>
                                        <div class="col-sm-2 prm">
                                            @Html.Label("Asset Weight:", htmlAttributes: new { @class = "control-label", @id = "lbl_CurQty_AsetTrans" })
                                        </div>
                                        <div class="col-sm-2 prm">
                                            @(Html.DevExtreme().NumberBox().CustomNumberBox() .ID("Txt_CurQty_AsetTrans") .Name("Txt_CurQty_AsetTrans") .ReadOnly(true).FocusStateEnabled(false).Format("#.###"))
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-sm-2 pll">
                                            @Html.Label("Owner Name:", htmlAttributes: new { @class = "control-label", @id = "lbl_owner_AsetTrans" })
                                        </div>
                                        <div class="col-sm-6 prm" id="Look_OwnList_Div_AsetTrans">
                                            @(Html.DevExtreme().DropDownBox().CustomDropDown() .ID("Look_OwnList_AsetTrans") .Name("Look_OwnList_AsetTrans") .ValueExpr("ID") .DisplayExpr("Name")
                                                      .DataSource(d => d.Mvc().Controller("AssetTransferVoucher").LoadAction("AssetTransfer_LookUp_GetOwnerList").Key("ID").LoadParams(new { DDRefresh = new JS("function() {return OwnerListDDRefresh_AsetTrans;}") }).LoadMode(DataSourceLoadMode.Raw).CacheRawData(true))
                                                   .OnValueChanged("Look_OwnList_EditValueChanged_AsetTrans") .ReadOnly(true).FocusStateEnabled(false).ContentTemplate(@<text> @Html.Partial("AssetTransfer_LookUp_GetOwnerList") </text>).Placeholder("Select Owner...") )

                                        </div>
                                        <div class="col-sm-6 prm" id="TextEdit1_Div_AsetTrans">
                                            @(Html.DevExtreme().TextBoxFor(x=>x.TextEdit1Text_AsetTrans).CustomTextBox() .ID("TextEdit1Text_AsetTrans") .Name("TextEdit1Text_AsetTrans") .ReadOnly(true).FocusStateEnabled(false).MaxLength(100) )
                                        </div>
                                        <div class="col-sm-2 prm">
                                            @Html.Label("Transfer Weight:", htmlAttributes: new { @class = "control-label", @id = "lbl_TrfQty_AsetTrans" })
                                        </div>
                                        <div class="col-sm-2 prm">
                                            @(Html.DevExtreme().NumberBox().CustomNumberBox() .ID("Txt_Qty_AsetTrans") .Name("Txt_Qty_AsetTrans") .OnValueChanged("Txt_Qty_EditValueChanged_AsetTrans").Format("#.###") )

                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-sm-2 pll">
                                            @Html.Label("Location:", htmlAttributes: new { @class = "control-label", @id = "lbl_location_AsetTrans" })
                                        </div>
                                        <div class="col-sm-6 prm">
                                            @(Html.DevExtreme().DropDownBox().CustomDropDown()  .ID("Look_LocList_AsetTrans") .Name("Look_LocList_AsetTrans") .ValueExpr("AL_ID") .DisplayExpr("LocationName")
                                                      .DataSource(d => d.Mvc().Controller("AssetTransferVoucher").LoadAction("AssetTransfer_LookUp_GetLocList").Key("AL_ID").LoadParams(new {DDRefresh = new JS("function() {return OwnerListDDRefresh_AsetTrans;}") }).LoadMode(DataSourceLoadMode.Raw).CacheRawData(true))
                                                      .OnValueChanged("Look_LocList_EditValueChanged_AsetTrans") .ReadOnly(true).FocusStateEnabled(false).ContentTemplate(@<text> @Html.Partial("AssetTransfer_LookUp_GetLocList") </text>).Placeholder("Select Location...") )

                                        </div>
                                        <div class="col-sm-2 prm">
                                            @Html.Label("Use of Property:", htmlAttributes: new { @class = "control-label", @id = "lbl_Use_AsetTrans" })
                                        </div>
                                        <div class="col-sm-2 prm">
                                            @(Html.DevExtreme().SelectBox().CustomSelectBox() .ID("Cmd_PUse_AsetTrans") .Name("Cmd_PUse_AsetTrans") .DataSource(new[] { "MAIN CENTRE", "CLASS", "MUSEUM", "STORE", "GARDEN", "GARAGE", "DEPARTMENT", "RESIDENCE", "NOT IN USE" }) .Value(Model.Cmd_PUse_AsetTrans) .ReadOnly(true).FocusStateEnabled(false).Placeholder("Select Use Of Property...").ShowClearButton(false) )

                                        </div>
                                    </div>
                                </fieldset>
                            </div>
                        </div>
                    </div><!--[Detail]-->


                    <div class="row">
                        <div id="Astr_NarrationDiv" class="col-sm-12 col-md-8 col-lg-8">
                            <div class="row">
                                <div class="col-sm-12">
                                    <div class="form-field">
                                        <div class="row">
                                            <div class="col-sm-2 col-md-2 col-lg-2 pll">
                                                <label class="control-label text-red" for="GLookUp_PurList_AsetTrans">Purpose:</label>
                                            </div>
                                            <div class="col-sm-10 col-md-10 col-lg-10 prm">
                                                @(Html.DevExtreme().DropDownBox().CustomDropDown() .ID("GLookUp_PurList_AsetTrans") .Name("GLookUp_PurList_AsetTrans") 
                                                .ValueExpr("PUR_ID") .DisplayExpr("PUR_NAME") .OnValueChanged("GLookUp_PurList_EditValueChanged_AsetTrans")
                                                .DataSource(d => d.Mvc().Controller("AssetTransferVoucher").LoadAction("AssetTransfer_LookUp_GetPurList").Key("PUR_ID")
                                                .LoadParams(new { DDRefresh = new JS("function() {return PurListDDRefresh_AsetTrans;}") })
                                                .LoadMode(DataSourceLoadMode.Raw).CacheRawData(true)).ReadOnly(true).FocusStateEnabled(false)
                                                .ContentTemplate(@<text> @Html.Partial("AssetTransfer_LookUp_GetPurList") </text>).Placeholder("Select Purpose...")  )

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div><!--[Purpose]-->
                            <div class="row">
                                <div class="col-sm-12 col-md-12 col-lg-12">
                                    <div class="form-field">
                                        <fieldset class="default-fieldset">
                                            <div class="row">
                                                <div class="col-sm-2 pll">
                                                    <label class="control-label" for="Txt_Narration_AsetTrans">Narration:</label>
                                                </div>
                                                <div class="col-sm-10 prm">
                                                    @(Html.DevExtreme().TextBox().CustomTextBox(true) .ID("Txt_Narration_AsetTrans") .Name("Txt_Narration_AsetTrans") .Value(Model.Txt_Narration_AsetTrans).MaxLength(250).Placeholder("Type Any Narration...") )
                                                </div>
                                            </div>
                                            <div class="row">
                                                <div class="col-sm-2 pll">
                                                    <label class="control-label" for="Name">Remarks:</label>
                                                </div>
                                                <div class="col-sm-10 prm">
