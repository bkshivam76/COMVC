
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid()
    .ID("LookUp_Cen_List_AssetsTransfer_GLookUp_Centre_List_datagrid")
    .CustomDataGrid()
    .Columns(columns =>
    {
        columns.Add().DataField("TO_CEN_NAME").Caption("CENTRE").Width(100);
        columns.Add().DataField("TO_PAD_NO").Caption("PAD No.");
        columns.Add().DataField("TO_UID").Caption("UID");
        columns.Add().DataField("TO_ZONE").Caption("Zone");
        columns.Add().DataField("TO_CEN_ID").Caption("CEN ID");
        columns.Add().DataField("TO_INCHARGE").Caption("Incharge").Width(0);
        columns.Add().DataField("TO_ID").Caption("TO_ID ID").Width(0).Visible(false);
        
        columns.Add().DataField("TO_TEL_NO").Caption("TO_TEL_NO").Width(0);
    })
    .Selection(s => s.Mode(SelectionMode.Single))
)