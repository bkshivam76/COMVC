    <script>
        function OnSplVchrRefsListSelectionChanged_B2B(e) {           
            var listBox = $("#ListSpecialVoucherRef_B2B").dxList("instance");
            if (listBox) {
                var selecteditemkey = listBox.option("selectedItemKeys")
                if (selecteditemkey != null && selecteditemkey.length > 0) {
                    $("#B2B_SplVchrReferenceSelected").val(selecteditemkey.join(","));
                }
                else {
                    $("#B2B_SplVchrReferenceSelected").val("");
                }
            }
            else
            {
                $("#B2B_SplVchrReferenceSelected").val("");
            }
        }// List selection

    </script>
