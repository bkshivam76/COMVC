<div class="B2B_ClearReferences">


    @using DevExtreme.AspNet.Mvc;
    @model ConnectOneMVC.Areas.Account.Models.Voucher_BankToBank
    <script src="~/Content/fontawesome/js/fontawesome_v5_all.js"></script>
    @{
        bool IsReadOnly = Model != null && (Model.ActionMethod.ToString().Trim() == "_View" || Model.ActionMethod.ToString().Trim() == "_Delete") ? true : false;
        string submitBtnText = Model != null && Model.ActionMethod.ToString().Trim() == "_Delete" ? "Delete" : "Save";

        Html.EnableClientValidation();
        Html.EnableUnobtrusiveJavaScript();
    }

    <style>
        .legendClass {
            margin-bottom: 0 !important;
            border-bottom: 1px solid #e5e5e5 !important;
            font-weight: 600;
        }

        .margB3 {
            margin-bottom: 3px !important;
        }

        .margB10 {
            margin-bottom: 10px !important;
        }

        #Txt_Amount_B2B .dx-placeholder {
            text-align: center;
            width: 100%;
        }
        #ListSpecialVoucherRef_B2B .dx-list-item-content {
            padding: 4.5px;
        }
        .fullLineLblWidth{
            width: 14.5%;
        }
    </style>
    <div id="B2B_ParentDiv">

        @using (Ajax.BeginForm("Frm_Voucher_Win_B2B", "BankToBankTransferVoucher",
                                               new AjaxOptions
                                               {
                                                   HttpMethod = "POST",
                                                   UpdateTargetId = "Frm_Voucher_BankToBank_popup",
                                                   InsertionMode = InsertionMode.InsertAfter,
                                                   OnBegin = "AjaxBeginFormPost",
                                                   OnSuccess = "AjaxSuccessVoucherBankToBank"
                                               },
                                               new
                                               {
                                                   id = "B2BvalidationForm",
                                                   @class = "edit_form form-horizontal"
                                               }))
        {
            @Html.HiddenFor(x => x.ActionMethod)
            @Html.HiddenFor(x => x.TempActionMethod)
            @Html.HiddenFor(x => x.REC_EDIT_ON_Bank1_B2B)
            @Html.HiddenFor(x => x.REC_EDIT_ON_Bank2_B2B)
            @Html.HiddenFor(x => x.iTrans_Type_B2B)
            @Html.HiddenFor(x => x.iLed_ID_B2B)
            @Html.HiddenFor(x => x.iVoucher_Type_B2B)
            @Html.HiddenFor(x => x.xID_B2B)
            @Html.HiddenFor(x => x.LastEditedOn_B2B)
            @Html.HiddenFor(x => x.BE_Bank1_Acc_No_Tag_B2B)
            @Html.HiddenFor(x => x.B2B_SplVchrReferenceSelected)
            @Html.HiddenFor(x => x.splVchrRefsCount_B2B)


            using (Html.DevExtreme().ValidationGroup("Bank2Bank"))
            {
                <div class="full-width-header-bg2">
                    <div class="row">
                        <div class="col-sm-8">
                            <h3 class="popuphead"><i class="far fa-edit"></i> Bank To Bank Transfer</h3>
                        </div>
                        <div class="col-sm-4 prm">
                            <h5 class="mand-txt-align">
                                <i class="fas fa-info-circle"></i> Red Fields are mandatory
                            </h5>
                        </div>
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                    </div>
                </div><!--[Header]-->
                <div class="row">
                    <div class="">
                        <div class="col-sm-7 col-md-7 col-lg-7">
                            <div class="form-field">
                                <div class="container-fluid">
                                    <div class="row">
                                        <div class="col-sm-6 col-md-3 col-lg-3 pll">
                                            @Html.Label("Item Name:", htmlAttributes: new { @class = "control-label text-red", @id = "lbl_itemName_B2B" })
                                        </div>
                                        <div class="col-sm-6 col-md-9 col-lg-9 prm">
                                        @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_ItemList_B2B").Name("GLookUp_ItemList_B2B").ValueExpr("ITEMID")
                                            .DisplayExpr("ITEMNAME").Placeholder("Select Item...").DataSource(Model.B2B_Item_Data, "ITEMID").Value(Model.GLookUp_ItemList_B2B)
                                            .ReadOnly(true).OnValueChanged("GLookUp_ItemList_EditValueChanged_B2B").ContentTemplate(@<text> @Html.Partial("BankToBank_LookUp_GetItemList") </text>).FocusStateEnabled(false)
                                        )
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div><!--[Item Name]-->
                        <div class="col-sm-5 col-md-5 col-lg-5">
                            <div class="form-field">
                                <div class="container-fluid">
                                    <div class="row">
                                        <div class="col-sm-6 col-md-4 col-lg-4 pll">
                                            @Html.Label("Voucher Date:", htmlAttributes: new { @class = "control-label text-red ", @id = "lbl_vdate_b2b" })
                                        </div>
                                        <div class="col-sm-6 col-md-8 col-lg-8 prm">
                                            @(Html.DevExtreme().DateBox().CustomDateBox().ID("Txt_V_Date_B2B").Name("Txt_V_Date_B2B").Value(Model.Txt_V_Date_B2B).Placeholder("dd-MM-yyyy").ReadOnly(IsReadOnly) )
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div><!--[V Date]-->
                    </div>
                </div><!--[row 1]-->
                <div class="row">
                    <div class="">
                        <div class="col-sm-7 col-md-7 col-lg-7">
                            <div class="form-field">
                                <div class="container-fluid">
                                    <div class="row">
                                        <div class="col-sm-6 col-md-3 col-lg-3 pll">
                                            @Html.Label("Head:", htmlAttributes: new { @class = "control-label disabletxt", @id = "lbl_head_b2b" })
                                        </div>
                                        <div class="col-sm-6 col-md-9 col-lg-9 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("BE_Item_Head_B2B").Name("BE_Item_Head_B2B").Placeholder("Head").Value(Model.BE_Item_Head_B2B).Disabled(true).ValidationError(true).MaxLength(50) )
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div><!--[Head]-->
                        <div class="col-sm-5 col-md-5 col-lg-5">
                            <div class="form-field">
                                <div class="container-fluid">
                                    <div class="row">
                                        <div class="col-sm-6 col-md-4 col-lg-4 pll">
                                            @Html.Label("Voucher No", htmlAttributes: new { @class = "control-label", @id = "lbl_vNo_b2b" })
                                        </div>
                                        <div class="col-sm-6 col-md-8 col-lg-8 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("Txt_V_NO_B2B").Name("Txt_V_NO_B2B").Value(Model.Txt_V_NO_B2B).ReadOnly(true).ValidationError(true).MaxLength(50).FocusStateEnabled(false) )
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div><!--[V NO]-->
                    </div>
                </div><!--[row 2]-->
                <div class="row">
                    <div class="col-sm-12">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <div class="col-sm-3 col-md-2 col-lg-2 pll fullLineLblWidth">
                                        @Html.Label("Mode:", htmlAttributes: new { @class = "control-label text-red ", @id = "lbl_cmode_b2b" })
                                    </div>
                                    <div class="col-sm-9 col-md-10 col-lg-10 prm">
                                        @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("Cmd_Mode_B2B").Name("Cmd_Mode_B2B").DataSource(new[] { "CHEQUE", "DD", "CBS", "RTGS", "NEFT" }).ReadOnly(IsReadOnly).Value("CHEQUE").OnValueChanged("Cmd_Mode_SelectedIndexChanged_B2B").ShowClearButton(false))
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Cmd mode]-->
                <div class="row">
                    <div class="col-sm-7 col-md-7 ">
                        <div class="form-field">
                            <div class="container-fluid">
                                <fieldset class="default-fieldset" id="LayoutControlItem1_B2B">
                                    <legend class="custom-legend mlm" id="lbl_Reg_No_B2B">Bank Detail (Transfer From):</legend>
                                    <div class="row">
                                        <div class="col-sm-3 col-md-3 col-lg-3 pll">
                                            @Html.Label("From Bank:", htmlAttributes: new { @class = "control-label text-red", @id = "LabelControl2_B2B" })

                                        </div>
                                        <div class="col-sm-9 col-md-9 col-lg-9 prm ">
                                            @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_BankList1_B2B").Name("GLookUp_BankList1_B2B").ValueExpr("BA_ID")
                                                .DisplayExpr("BANK_NAME").Placeholder("Select Bank...").DataSource(Model.Bank1_Data_B2B, "BA_ID").Value(Model.GLookUp_BankList1_B2B)
                                                .ReadOnly(true).OnValueChanged("GLookUp_BankList1_EditValueChanged_B2B").ContentTemplate(@<text> @Html.Partial("LookUp_GetBankList") </text>)
                                            )
                                        </div>
                                    </div><!--[From Bank]-->
                                    <div class="row">
                                        <div class="col-sm-3 col-md-3 col-lg-3 pll">
                                            <label class="control-label" id="LabelControl5_B2B" for="Name">Branch :</label>
                                        </div>
                                        <div class="col-sm-9 col-md-9 col-lg-9 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Bank1_Branch_B2B").Value(Model.BE_Bank1_Branch_B2B).ID("BE_Bank1_Branch_B2B").Disabled(true) )
                                        </div>
                                    </div><!--[Branch]-->
                                    <div class="row">
                                        <div class="col-sm-3 col-md-3 col-lg-3 pll">
                                            <label class="control-label" id="LabelControl6_B2B" for="Name">A/c. No.:</label>
                                        </div>
                                        <div class="col-sm-9 col-md-9 col-lg-9 prm ">
                                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("BE_Bank1_Acc_No_B2B").Name("BE_Bank1_Acc_No_B2B").Value(Model.BE_Bank1_Acc_No_B2B).Disabled(true) )
                                        </div>
                                    </div><!--[Account no]-->
                                </fieldset>
                            </div>
                        </div>
                    </div><!--[Bank 1]-->
                    <div class="col-sm-5 col-md-5">
                        <div class="form-field">
                            <div class="container-fluid">
                                <fieldset class="default-fieldset" id="LayoutControlItem3_B2B">
                                    <legend class="custom-legend mlm" id="lbl_Ref_Title_B2B"> Cheque Detail</legend>
                                    <div class="row">
                                        <div class="col-sm-3 col-md-4 col-lg-4 pll">
                                            <label id="lbl_Ref_No_B2B" class="control-label text-red" for="Name">Cheque No:</label>
                                        </div>
                                        <div class="col-sm-9 col-md-8 col-lg-8 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox(true,true).ID("Txt_Ref_No_B2B").Name("Txt_Ref_No_B2B").Value(Model.Txt_Ref_No_B2B).ReadOnly(IsReadOnly).Placeholder("Type Cheque No. ...").MaxLength(25) )
                                        </div>
                                    </div><!--[Cheque No]-->
                                    <div class="row">
                                        <div class="col-sm-3 col-md-4 col-lg-4 pll">
                                            <label id="lbl_Ref_Date_B2B" class="control-label text-red" for="Name">Cheque Date:</label>
                                        </div>
                                        <div class="col-sm-9 col-md-8 col-lg-8 prm">
                                            @(Html.DevExtreme().DateBox().CustomDateBox().ID("Txt_Ref_Date_B2B").Name("Txt_Ref_Date_B2B").Value(Model.Txt_Ref_Date_B2B).ReadOnly(IsReadOnly).Min("01/01/1900") )
                                        </div>
                                    </div><!--[Cheque Date]-->
                                    <div class="row">
                                        <div class="col-sm-3 col-md-4 col-lg-4 pll">
                                            <label id="lbl_Ref_CDate_B2B" class="control-label" for="Name">Clearing Date:</label>
                                        </div>
                                        <div class="col-sm-9 col-md-8 col-lg-8 prm ">
                                            @(Html.DevExtreme().DateBox().CustomDateBox().ID("Txt_Ref_CDate_B2B").Name("Txt_Ref_CDate_B2B").Value(Model.Txt_Ref_CDate_B2B).ReadOnly(IsReadOnly).Min("01/01/1900") )
                                        </div>
                                    </div><!--[Clearing Date]-->
                                </fieldset>
                            </div>
                        </div>
                    </div>
                </div><!--[Bank 1 Details]-->
                <div class="row">
                    <div class="col-sm-12 col-md-12 col-lg-12">
                        <div class="form-field">
                            <div class="container-fluid">
                                <fieldset class="default-fieldset" id="LayoutControlItem4_B2B">
                                    <legend class="custom-legend mlm" id="LabelControl12_B2B"> Bank Detail (Transfer To):</legend>
                                    <div class="row">
                                        <div class="col-sm-2 col-md-2 col-lg-2 pll fullLineLblWidth">
                                            @Html.Label("To Bank:", htmlAttributes: new { @class = "control-label text-red", @id = "LabelControl11_B2B" })

                                        </div>
                                        <div class="col-sm-10 col-md-10 col-lg-10 prm">
                                            @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_BankList2_B2B").Name("GLookUp_BankList2_B2B").ValueExpr("BA_ID")
                                                .DisplayExpr("BANK_NAME").Placeholder("Select Bank...").DataSource(Model.Bank2_Data_B2B, "BA_ID").Value(Model.GLookUp_BankList2_B2B)
                                                .ReadOnly(true).OnValueChanged("GLookUp_BankList2_EditValueChanged_B2B").ContentTemplate(@<text> @Html.Partial("LookUp_GetBankList2") </text>)            
                                            )
                                        </div>
                                    </div><!--[Bank 2]-->
                                    <div class="row">
                                        <div class="col-sm-3 col-md-2 col-lg-2 pll fullLineLblWidth">
                                            <label class="control-label" id="LabelControl10_B2B" for="Name">Branch:</label>
                                        </div>
                                        <div class="col-sm-9 col-md-10 col-lg-10 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Bank2_Branch_B2B").ID("BE_Bank2_Branch_B2B").Value(Model.BE_Bank2_Branch_B2B).Disabled(true) )
                                        </div>
                                    </div><!--[Branch]-->
                                    <div class="row">
                                        <div class="col-sm-3 col-md-2 col-lg-2 pll fullLineLblWidth">
                                            <label class="control-label" id="LabelControl9_B2B" for="Name">A/c. No.:</label>
                                        </div>
                                        <div class="col-sm-9 col-md-10 col-lg-10 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("BE_Bank2_Acc_No_B2B").Name("BE_Bank2_Acc_No_B2B").Value(Model.BE_Bank2_Acc_No_B2B).Disabled(true) )
                                        </div>
                                    </div><!--[Acc no]-->
                                </fieldset>
                            </div>
                        </div>
                    </div>
                </div><!--[Bank 2 Details]-->

                <div class="row">                                            
                    <div id="B2B_NarrationDiv" class="col-sm-12 col-md-7 col-lg-7">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <div class="col-sm-3 col-md-3 col-lg-3 pll">
                                        <label class="control-label" id="LabelControl17_B2B" for="Name">Narration:</label>
                                    </div>
                                    <div class="col-sm-9 col-md-9 col-lg-9 prm">
                                        @(Html.DevExtreme().TextBox().CustomTextBox(true).ID("Txt_Narration_B2B").Name("Txt_Narration_B2B").Value(Model.Txt_Narration_B2B).Placeholder("Type any Other Details / Remarks...").MaxLength(250).ReadOnly(IsReadOnly) )
                                    </div>
                                </div><!--[Narration]-->
                                <div class="row">
                                    <div class="col-sm-3 col-md-3 col-lg-3 pll">
                                        <label class="control-label" id="LabelConreol16_B2B">Remarks:</label>
                                    </div>
                                    <div class="col-sm-9 col-md-9 col-lg-9 prm">
                                        @(Html.DevExtreme().TextBox().CustomTextBox(true).ID("Txt_Remarks_B2B").Name("Txt_Remarks_B2B").Value(Model.Txt_Remarks_B2B).Placeholder("Type any Other Details / Remarks...").MaxLength(250).ReadOnly(IsReadOnly) )
                                    </div>
                                </div><!--[Remarks]-->
                                <div class="row">
                                    <div class="col-sm-3 col-md-3 col-lg-3 pll">
                                        <label class="control-label" id="LabelControl15_B2B">Reference:</label>
                                    </div>
                                    <div class="col-sm-9 col-md-9 col-lg-9 prm" id="B2B_reference_div">
                                        @(Html.DevExtreme().TextBox().CustomTextBox(true).ID("Txt_Reference_B2B").Name("Txt_Reference_B2B").Value(Model.Txt_Reference_B2B).Placeholder("Type any Reference Details ...").MaxLength(250).ReadOnly(IsReadOnly) )
                                    </div>
                                </div><!--[Reference]-->
                                <div class="row">
                                    <div class="col-sm-3 col-md-3 col-lg-3 pll">
                                        <label class="control-label text-red" id="lbl_B2B_reference" for="Name">Purpose:</label>
                                    </div>
                                    <div class="col-sm-9 col-md-9 col-lg-9 prm">
                                        @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("PurposeID_B2B").Name("PurposeID_B2B").ValueExpr("PUR_ID")
                                            .DisplayExpr("PUR_NAME").Placeholder("Select Purpose...").DataSource(Model.PurposeList_B2B, "PUR_ID").Value(Model.PurposeID_B2B)
                                            .Placeholder("Select Purpose...").Disabled(false))
                                        @Html.ValidationMessageFor(model => model.PurposeID_B2B, "", new { @class = "text-red" })
                                    </div>
                                </div><!--[Purpose]-->
                            </div>
                        </div>
                    </div><!--[Narration/Remarks/Reference]-->                    
                    <div class="col-sm-12 col-md-5 col-lg-5 fcraAmtDiv_B2B">
                        <div class="row">
                            <div class="col-sm-12 col-md-6 col-lg-6" id="B2B_SpecialVoucherRefDiv">                                
                                <div class="form-field ">
                                    <div class="dx-texteditor-container">
                                        @(Html.DevExtreme().List().CustomList().ID("ListSpecialVoucherRef_B2B")
                                        .DataSource(Model.SpecialReferenceList_Data_B2B, "Task_Name")
                                        .SearchEnabled(false)
                                        .SelectionMode(DevExtreme.AspNet.Mvc.ListSelectionMode.Multiple)
                                        .KeyExpr("Task_Name")
                                        .DisplayExpr("Task_Name")
                                        .OnSelectionChanged("OnSplVchrRefsListSelectionChanged_B2B")
                                        .Height(88).ShowScrollbar(ShowScrollbarMode.Always).UseNativeScrolling(false)
                                        .ShowSelectionControls(true)
                                        .SelectedItemKeys(Model.SpecialReference_Get_SelectedValue_B2B))
                                    </div>
                                </div>                                    
                            </div>
                            <div class="col-sm-12 col-md-6 col-lg-6" id="fcraAmtDiv_B2B">
                                <div class="form-field">
                                    <div class="container-fluid mb_height66" style="min-height: 88px !important;">
                                        <div class="row">
                                            <div class="col-sm-3 col-md-12 col-lg-12" style="text-align:center" id="B2B_Transfer_Div">
                                                <label class="control-label text-red" id="lbl_amt_B2B">Transfer:</label>
                                            </div>
                                            <div class="col-sm-9 col-md-12 col-lg-12 ">
                                                @(Html.DevExtreme().NumberBox().CustomNumberBox()
                                                    .ID("Txt_Amount_B2B").Name("Txt_Amount_B2B")
                                                    .Value(Model.Txt_Amount_B2B).Placeholder("Type Amount...")
                                                    .ReadOnly(IsReadOnly).Format("#0.00")
                                                    .InputAttr(new { @style = "text-align:center" })
                                                ) @*redmine Bug #132664 fixed *@
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                </div><!--[Amount]-->
                                </div>
                            </div>

                    
                </div><!--[Narration, FCRA and Amount columns]-->

                <div class="row">
                    <div class="col-sm-12 col-md-12 col-lg-12">
                        <div class="row">
                            <div class="col-sm-5 col-md-5 col-lg-5">
                                @Html.Partial("Drop_Request", String.Format("Send Your Request to Madhuban for ( {0} ~ Bank to Bank Transfer )...", Model.TempActionMethod.Substring(1)))
                            </div>
                            <div class="col-sm-7 col-md-7 col-lg-7">
                                <div class="styleActionBtn">
                                    @if (Model.ActionMethod.ToString() != "_View")
                                    {
                                        @(Html.DevExtreme().Button().CustomSaveButton(Model.ActionMethod.ToString()).ID("EditVouB2B").Text(submitBtnText).UseSubmitBehavior(false).OnClick("B2BFormSubmit") )
                                    }
                                    @(Html.DevExtreme().Button().CustomCloseButton().ID("CancelVouB2B").Text(Model.TempActionMethod == "_View" ? "Close" : "Cancel").OnClick(@<text> function () { $("#Dynamic_Content_popup").dxPopup("hide"); } </text>) )
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Buttons]-->
            }
        }
    </div>

    <script>
        function Cmd_Mode_SelectedIndexChanged_B2B(e) {
            if (e.value != null) {//redmine Bug #133513 fixed
                var text = e.value.toUpperCase();
                if (text == "CHEQUE") {
                    $("#lbl_Ref_Title_B2B").text("Cheque Detail:");
                    $("#lbl_Ref_No_B2B").text("Cheque No.:");
                    $("#Txt_Ref_No_B2B").dxTextBox("instance").option("placeholder", "Type Cheque No...");
                    $("#lbl_Ref_Date_B2B").text("Cheque Date:");
                    $("#lbl_Ref_CDate_B2B").text("Clearing Date:");
                }
                if (text == "DD") {
                    $("#lbl_Ref_Title_B2B").text("D.D. Detail:");
                    $("#lbl_Ref_No_B2B").text("D.D. No.:");
                    $("#Txt_Ref_No_B2B").dxTextBox("instance").option("placeholder", "Type D.D. No...");
                    $("#lbl_Ref_Date_B2B").text("D.D. Date:");
                    $("#lbl_Ref_CDate_B2B").text("Clearing Date:");
                }
                if (text == "CBS" || text == "RTGS" || text == "NEFT") {
                    $("#lbl_Ref_Title_B2B").text(e.value + " Reference Detail:");
                    $("#lbl_Ref_No_B2B").text("Ref. No.:");
                    $("#Txt_Ref_No_B2B").dxTextBox("instance").option("placeholder", "Type Ref. No...");
                    $("#lbl_Ref_Date_B2B").text("Date:");
                    $("#lbl_Ref_CDate_B2B").text("Clearing Date:");
                }
            }
            RefNoValidation();
        }
    </script>
    @* Cmd mode value change *@
<script>
        async function GLookUp_ItemList_EditValueChanged_B2B(e, FirstCall = false) {
            var itemID;
            if (e) {
                itemID = e.value;
                if ((e.value == null||e.value.length==0) && e.previousValue != null) {
                    Item_B2B_DG.clearSelection();
                    return;
                }
            }
            else {
                itemID = $("#GLookUp_ItemList_B2B").dxDropDownBox("option", "value");
            }
            await Item_B2B_DG.selectRows(itemID);
            if (Item_B2B_DG.getSelectedRowsData().length > 0) {
                var item = Item_B2B_DG.getSelectedRowsData()[0];
                $("#BE_Item_Head_B2B").dxTextBox("instance").option("value", item["LED_NAME"]);
                $("#iVoucher_Type_B2B").val(item["ITEM_VOUCHER_TYPE"]);
                $("#iLed_ID_B2B").val(item["ITEM_LED_ID"]);
                $("#iTrans_Type_B2B").val(item["ITEM_TRANS_TYPE"]);
            }
        }
        async function GLookUp_BankList1_EditValueChanged_B2B(e,FirstCall=false)
        {
            var bankID;
            if (e)
            {
                bankID = e.value;
                if ((e.value == null || e.value.length==0) && e.previousValue != null)
                {
                    Bank1_B2B_DG.clearSelection();
                    $("#BE_Bank1_Branch_B2B").dxTextBox("instance").reset();
                    $("#BE_Bank1_Acc_No_B2B").dxTextBox("instance").reset();
                    return;
                }
            }
            else {
