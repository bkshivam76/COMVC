    @* Document.ready *@
    <script>
    $("#B2B_ParentDiv").keydown(function (e)
    {

        if (e.originalEvent.repeat == true)
        {
            return false;
        }
        if (e.key == "F2")
        {
            e.preventDefault();
            $("#Txt_V_Date_B2B").dxDateBox("instance").focus();
        }
        else if (e.key == "S" && e.shiftKey) //save
        {
            e.preventDefault();
            if ("@Model.ActionMethod" == "_New" || "@Model.ActionMethod" == "_New_From_Selection" || "@Model.ActionMethod" == "_Edit")
            {
                $("#EditVouB2B").trigger("click");
            }
        }
        else if (e.key == "D" && e.shiftKey) //Delete
        {
            e.preventDefault();
            if ("@Model.ActionMethod" == "_Delete")
            {
                $("#EditVouB2B").trigger("click");
            }
        }
    });
    </script>
