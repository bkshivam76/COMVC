
@Html.DevExpress().FloatingActionButton(
settings =>
{
    settings.Name = "CBAuditNested_FAB";
    settings.ContainerElementID = "CBAuditNestedGrid_Div";
    settings.HorizontalPosition = FloatingActionButtonHorizontalPosition.Right;
    settings.VerticalPosition = FloatingActionButtonVerticalPosition.Bottom;

    FABActionGroup actionItemGroup1 = new FABActionGroup() { ContextName = "actionItemContext1" };
    actionItemGroup1.Items.Add(new FABActionItem("Prev", "~/Content/FloatingActionButton/Images/Prev.png", "Prev"));
    actionItemGroup1.Items.Add(new FABActionItem("Next", "~/Content/FloatingActionButton/Images/Next.png", "Next"));
    actionItemGroup1.Items.Add(new FABActionItem("Edit", "~/Content/FloatingActionButton/Images/Edit.png", "Edit"));
    actionItemGroup1.Items.Add(new FABActionItem("Reject", "~/Content/FloatingActionButton/Images/rejectrednew.png", "Reject"));
    settings.Items.Add(actionItemGroup1);

    settings.ClientSideEvents.ActionItemClick = "On_CBAuditNested_ActionItemClick";
    settings.ControlStyle.CssClass = "DevexpressComponents";

}).GetHtml()