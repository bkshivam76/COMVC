@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
        .ID("CB_Item_List_DG")
        .Columns(columns =>
        {
            columns.Add().DataField("ItemName").Caption("Item");
            columns.Add().DataField("ItemID").Caption("ItemID").Visible(false);
            columns.Add().DataField("Ledger").Caption("Head");
            columns.Add().DataField("LedgerID").Caption("LED_ID").Visible(false);

        })

        .Selection(s => s.Mode(SelectionMode.Single))
        .SelectedRowKeys(new JS(@"component.option(""value"")"))

)