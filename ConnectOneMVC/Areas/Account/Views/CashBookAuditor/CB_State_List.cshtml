@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
        .ID("CB_State_List_DG")
        .Columns(columns =>
        {
            columns.Add().DataField("R_ST_NAME").Caption("State");
            columns.Add().DataField("R_ST_CODE").Caption("Code").Visible(false);
            columns.Add().DataField("R_ST_REC_ID").Caption("ID").Visible(false);
        })

        .Selection(s => s.Mode(SelectionMode.Multiple))
        .SelectedRowKeys(new JS(@"component.option(""value"")"))

)