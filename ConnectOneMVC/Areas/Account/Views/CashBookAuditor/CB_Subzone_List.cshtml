@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
        .ID("CB_Subzone_List_DG")
        .Columns(columns =>
        {
            columns.Add().DataField("Name").Caption("Name");
            columns.Add().DataField("ShortName").Caption("Short Name");
            columns.Add().DataField("Zone").Caption("Zone");
        })

        .Selection(s => s.Mode(SelectionMode.Multiple))
        .SelectedRowKeys(new JS(@"component.option(""value"")"))

)