@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
        .ID("CB_UID_List_DG")
        .Columns(columns =>
        {
        columns.Add().DataField("UID").Caption("UID");
        columns.Add().DataField("Center").Caption("Center");
        columns.Add().DataField("Zone").Caption("Zone");
        columns.Add().DataField("SubZone").Caption("SubZone");
        columns.Add().DataField("AccType").Caption("AccType");
        columns.Add().DataField("CEN_ID").Caption("Center ID");
        columns.Add().DataField("State").Caption("State");
})

        .Selection(s => s.Mode(SelectionMode.Single))
        .SelectedRowKeys(new JS(@"component.option(""value"")"))

)