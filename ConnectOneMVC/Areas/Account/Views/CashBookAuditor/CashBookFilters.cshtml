        async function RefreshItemList() {
            var $DataGrid = $("#CB_Item_List_DG");
            var ddRefresh = false;
            if ($DataGrid.length) {
                $.ajax({
                    type: 'POST',
                    url: "/Account/CashBookAuditor/RefreshItemList",
                    cache: false,
                    async: false,
                    data: { Head: CB_Head },
                    success: function (data) {
