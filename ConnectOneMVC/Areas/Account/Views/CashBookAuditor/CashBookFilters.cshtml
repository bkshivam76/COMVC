        {
            using (Html.DevExtreme().ValidationGroup())
            {
                <div class="row">
                    <div class="form-field">
                        <div class="container-fluid">

                            <div class="row">
                                <div class="col-sm-12 col-md-12 col-lg-12">
                                    @(Html.DevExtreme().TabPanel().ID("CBFilterPanel").Items(items =>
                                                    {
                                                        items.Add().Title("Default Filters").Template(@<text> @DefaultFilterView() </text>);
                                                items.Add().Title("Unit Filters").Template(@<text> @UnitFilterView() </text>);
                                        items.Add().Title("Entry Filters").Template(@<text> @EntryFilterView() </text>);

                            }).DeferRendering(false))
                                    @helper DefaultFilterView()
                                    {
                                        @Html.Partial("DefaultFilters", Model);
                                    }
                                    @helper UnitFilterView()
                                    {
                                        @Html.Partial("UnitFilters", Model);
                                    }
                                    @helper EntryFilterView()
                                    {
                                        @Html.Partial("EntryFilters", Model);
                                    }
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-12 col-md-12 col-lg-12 styleActionBtn">
                        @(Html.DevExtreme().Button().ID("CashBookApplyFilter2").Text("Show").Icon("fas fa-eye").UseSubmitBehavior(true))@*//.OnClick("CB_FilterShowClick")*@
                    </div>

