            {
                $("#CB_Head_List_DG").dxDataGrid("instance").selectRows(((JSON.parse(JSON.stringify(@Html.Raw(Json.Encode(Model.CB_Head)))))[0]).split(','), true);
            }
            if ((@Html.Raw(Json.Encode(Model.CB_Item))) != null&& (@Html.Raw(Json.Encode(Model.CB_Item)))[0].length > 0)
            {
                WaitForHeadDDValueChangetoGetOver();
                function WaitForHeadDDValueChangetoGetOver()
                {
                    ShowLoader();
