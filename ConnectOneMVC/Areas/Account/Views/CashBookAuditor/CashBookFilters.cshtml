            $("#CB_Zone_List_DG").dxDataGrid("instance").clearSelection();
            $("#CB_Subzone_List_DG").dxDataGrid("instance").clearSelection();
            $("#CB_UID_List_DG").dxDataGrid("instance").clearSelection();
            RefreshSubzoneList();
            RefreshUIDList();
        }
        if (e.value != null && e.value.length > 0)
        {
            CB_Zone = e.value;
        }
        else
        {
            CB_Zone = "";
        }
        if (ZoneFirstValueChange == true && ((@Html.Raw(Json.Encode(Model.CB_Zone))) != null && (@Html.Raw(Json.Encode(Model.CB_Zone)))[0].length > 0)) {
            ZoneFirstValueChange = false;
            ZonevalueChange = false;
