    <script>
        async function RefreshZoneList() {
            var $DataGrid = $("#CB_Zone_List_DG");
            if ($DataGrid.length) {
                $.ajax({
                    type: 'GET',
                    url: "/Account/CashBookAuditor/RefreshZoneList",
                    cache: false,
                    //async: false,
                    success: function (data) {
                        $DataGrid.dxDataGrid("instance").refresh();
                    }
                });
            }
        }
        async function RefreshSubzoneList() {
            var DDrefresh = false;
            var $DataGrid = $("#CB_Subzone_List_DG");
            if ($DataGrid.length) {
                $.ajax({
                    type: 'POST',
                    url: "/Account/CashBookAuditor/RefreshSubzoneList",
                    cache: false,
                    data: { Zone: CB_Zone },
                    success: function (data) {
                        $DataGrid.dxDataGrid("instance").refresh();

                    }
                });
            }
        }
        async function RefreshStateList() {
