    <script>

        var CB_Grid_PageIndex_auditor;
        var CB_Grid_PageCount_auditor;
        function Grid_Display_CBAudit(FreshData = false) {
            HideLoader();
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Account/CashBookAuditor/Grid_Display",
                //async: false,
                data:
                {
                    FreshData: FreshData
                },
                cache: false,
                success: function (data) {
                    CB_FreshData = false;
                    if (data.jsonParam.result == false) {
                        HideLoader();
                        DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                        if (data.jsonParam.closeform == true) {
                            btnCloseActiveTab();
                        }

                    }
                    else {
                        HideLoader();
                        ShowLoader();
                        CashBookAuditorRefresh();

                    }
                }
            });

        }
        function CashBookAuditorRefresh() {

            if (typeof window !== 'undefined') {
                if (typeof window.CashBookAuditListGrid !== 'undefined') {
                    if (typeof window.CashBookAuditListGrid.Refresh !== 'undefined') {
                        if (typeof CashBookAuditListGrid.Refresh == 'function') {
                            GridViewDoCallback(CashBookAuditListGrid, function () { window.CashBookAuditListGrid.PerformCallback(); });
                        }
                        else {
                            alert("refresh is not a function");
                        }
                    }
                    else {
                        ShowLoader();
                        setTimeout(function () {
                            CashBookAuditorRefresh();
                            HideLoader();
                        }, Timeout500);
                    }
                }
                else {
                    alert('grid undefined')
                }
            }
            else {
                alert('window undefined')
            }
        }

    </script>
    @* Grid Display and Summary Button *@
    <script>
    var Req_Attach_Count_auditor;
    var Res_Attach_Count_auditor;
    var Com_Attach_Count_auditor;
    var CB_SelectedRowIndex = -1;
    var NextRowTempID_auditor;
    var CBGrid_PageSize_auditor;
    var CB_SearchPanelExp_auditor = "";
    var CB_ClientLayout = null;
    var CB_Prev_Selectedindex;
    var CB_Prev_RecID;
    var CB_Refreshdone = false;
    var CB_TotalRowCount;
    var CB_TotalEntriesCount;
    var CB_RefreshAfterAction = false;
    var CB_Cen_ID_auditor;
        var CB_Vouching_Category_auditor;
        var CBAudit_TempID_Prev = null;
    function CBAuditor_Grid_init(s, e)
    {
        CBAuditor_grid_AdjustSize(s, e);
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt)
        {
            CBAuditor_grid_AdjustSize(s, e);
        });

        $(".CB_customPreviewRow").hide();
    }
    function CBAuditor_Grid_begincallback(s, e)
    {
        ShowLoader();
        e.customArgs["command"] = e.command;
        e.customArgs["_ActiveFilterString"] = CBaudit_ActiveFilterString;
        e.customArgs["ShowHorizontalBar"] = CBaudit_ShowHorizontalBar;
        e.customArgs["AllowCellMerge"] = CBaudit_AllowCellMerge;
        e.customArgs["ViewMode"] = CBauditGrid_ViewMode;
        e.customArgs["FreshData"] = CB_FreshData;
        CBAudit_TempID_Prev = CBAudit_TempID;
    }
    function CBAuditor_Grid_endcallback(s, e)
    {
        HideLoader();
        CBAuditor_grid_AdjustSize(s, e);
        CB_ClientLayout = s.cpClientLayout;
        CB_TotalRowCount = s.cpTotalRowCount;
        CB_TotalEntriesCount = s.cpTotalEntries;
        $("#CashBookAuditListGrid").toggleClass('compact', CBauditGrid_ViewMode == "Compact");
        $("#CashBookAuditListGrid").toggleClass('default', CBauditGrid_ViewMode == "Default");
        if ($("#ButCB_Audit_Narration").dxButton("instance").option("visible") == true)
        {
            if ($("#ButCB_Audit_Narration").dxButton("instance").option("text") == "Hide Narration")
            {
                $(".CB_customPreviewRow").show();
            }
            else
            {
                $(".CB_customPreviewRow").hide();
            }
        }
        CBaudit_ActiveFilterString = s.cpFilterExpression;
        CB_SearchPanelExp_auditor = s.cpSearchPanelExpression;
        CBGrid_PageSize_auditor = s.cpPageSize;
        CB_Grid_PageCount_auditor = s.GetPageCount();
        CB_Grid_PageIndex_auditor = s.GetPageIndex();
        SendCustomArgs_FilterControl(s, e);
        if (e.command == "REFRESH")
        {
            HideLoader();
            CB_Prev_Selectedindex = CB_SelectedRowIndex;
            CB_Prev_RecID = iREC_ID_auditor;
            CB_Refreshdone = true;          
            if (CB_TotalRowCount > 0)
            {
                if (CB_SelectedRowIndex > -1)
                {
                    s.UnselectRowOnPage(CB_SelectedRowIndex);
                }
                else
                {
                    CB_Refreshdone = false;
                    CB_RefreshAfterAction = false;
                }
            }
            else
            {
                CB_Refreshdone = false;
                CB_RefreshAfterAction = false;

                if (CB_DataScope.toUpperCase() == "EXCLUSIVE") {
                    var confirm = DevExpress.ui.dialog.confirm("No Entries Are Allocated To You<br>Do You Want New Allocations To Be Done?", "Confirm");
                    confirm.done(function (dialogresult) {
                        if (dialogresult) {
                            ClearRightPane();
                            CB_SelectedRowIndex = -1;
                            CB_FreshData = true;
                            HideLoader();
                            ShowLoader();
                            Grid_Display_CBAudit(CB_FreshData);
                        }
                        else
                        {
                            if (Rightpane.IsCollapsed() == false) {
                                CollapsePane(Rightpane, Middlepane);
                            }
                            if (Leftpane.IsCollapsed() == false) {
                                CollapsePane(Leftpane, Middlepane);
                            }
                        }
                    });
                }
                else
                {
                    if (Rightpane.IsCollapsed() == false) {
                        CollapsePane(Rightpane, Middlepane);
                    }
                    if (Leftpane.IsCollapsed() == false) {
                        CollapsePane(Leftpane, Middlepane);
                    }
                }
            }
        }
        else if (e.command == "GOTOPAGE")
        {
            s.SelectRowOnPage(CBNextRowToBeSelected, true);
        }
        else if (e.command == "CUSTOMCALLBACK")
        {
            CB_FreshData = false;
            if (CB_ShowClick == true)
            {
                CB_ShowClick = false;
                if (CB_TotalRowCount == 0)
                {
                    if (CB_DataScope.toUpperCase() == "EXCLUSIVE")
                    {
                        var confirm = DevExpress.ui.dialog.confirm("No Entries Are Allocated To You<br>Do You Want New Allocations To Be Done?", "Confirm");
                        confirm.done(function (dialogresult) {
                            if (dialogresult) {
                                ClearRightPane();
                                CB_SelectedRowIndex = -1;
                                CB_FreshData = true;
                                HideLoader();
                                ShowLoader();
                                Grid_Display_CBAudit(CB_FreshData);
                            }
                            else
                            {
                                if (Rightpane.IsCollapsed() == false)
                                {
                                    CollapsePane(Rightpane, Middlepane);
                                }
                                if (Leftpane.IsCollapsed() == false)
                                {
                                    CollapsePane(Leftpane, Middlepane);
                                }
                            }
                        });
                    }
                    else {
                        if (Rightpane.IsCollapsed() == false) {
                            CollapsePane(Rightpane, Middlepane);
                        }
                        if (Leftpane.IsCollapsed() == false) {
                            CollapsePane(Leftpane, Middlepane);
                        }
                    }
                }

            }
            if (CB_TotalRowCount > 0) {
                if (CB_SelectedRowIndex == -1) {
                    s.SelectRowOnPage(0, true);
                }
                else {
                    s.SelectRowOnPage(CB_SelectedRowIndex, true);
                }
            }
            else
            {
                if (Rightpane.IsCollapsed() == false) {
                    CollapsePane(Rightpane, Middlepane);
                }
                if (Leftpane.IsCollapsed() == false) {
                    CollapsePane(Leftpane, Middlepane);
                }
            }

        }
        else if (e.command == "FUNCTION")
        {
            if (CB_SelectedRowIndex > -1) {
                // $("#CashBookAuditListGrid_DXADRow" + CB_SelectedRowIndex).css("background-color", "#0072C6");
                $("#CashBookAuditListGrid_DXDataRow" + CB_SelectedRowIndex).css("color", "#0000FF");
            }
        }
        else if (e.command == "PAGERONCLICK")
        {
            s.SelectRowOnPage(s.GetTopVisibleIndex(), true);
        }

    }
    function CBAuditor_grid_AdjustSize(s, e) {
        var height = (document.documentElement.clientHeight * 90) / 100;
        s.SetHeight(height);
    }
    function CBAuditor_OnRowClick(s, e)
    {
        s.SelectRowOnPage(e.visibleIndex, true);
    }
    function CBAuditor_OnSelectionChanged(s, e)
    {
        if (s.GetSelectedRowCount() > 0)
        {
            ShowLoader();
            CB_row_SerialNo = s.GetSelectedKeysOnPage()[0];
            console.log(s.GetSelectedKeysOnPage());
            CashBookAuditListGrid.GetValuesOnCustomCallback({ key: CB_row_SerialNo }, CashBookAuditorVoucherOnGetRowValues);
            CB_SelectedRowIndex = e.visibleIndex;
            // $("#CashBookAuditListGrid_DXADRow" + e.visibleIndex).css("background-color", "#0072C6");
            $("#CashBookAuditListGrid_DXDataRow" + e.visibleIndex).css("color", "#0000FF");
        }
        else
        {
            CB_SelectedRowIndex = -1;
            CB_row_SerialNo = 0;
            CBAudit_FAB.SetVisible(false);
            //Rightpane.Collapse(Middlepane);
            //Leftpane.Collapse(Middlepane);
            if (CB_Refreshdone == true)
            {
                CB_RefreshAfterAction = false;
                CB_Refreshdone = false;
                if (CB_Prev_Selectedindex > -1)
                {
                    if (CB_Prev_Selectedindex > CB_TotalRowCount - 1)
                    {
                        s.SelectRowOnPage(CB_TotalRowCount - 1, true);
                    }
                    else
                    {
                        s.SelectRowOnPage(CB_Prev_Selectedindex, true);
                    }
                }
                CBAudit_TempID_Prev = null;
            }
        }
    }

    function CashBookAuditorVoucherOnGetRowValues(CashBookVoucherData)
    {
        if (CashBookVoucherData != null && CashBookVoucherData.length > 0)
        {
            var CashBookVouchervalues = CashBookVoucherData.split("![");
            CBAudit_TempID = CashBookVouchervalues[0];
            iREC_ID_auditor = CashBookVouchervalues[1];
            iREC_EDIT_ON_auditor = CashBookVouchervalues[2];
            iTR_ITEM_ID_auditor = CashBookVouchervalues[3];
            iTR_AB_ID_1_auditor = CashBookVouchervalues[4];
            iTR_M_ID_auditor = CashBookVouchervalues[5];
            ACTION_STATUS_auditor = CashBookVouchervalues[6];
