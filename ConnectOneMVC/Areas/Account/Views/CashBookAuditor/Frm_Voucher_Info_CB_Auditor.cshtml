    function CreationDetail(ID, Action_Status, Add_Date, Add_By, Action_Date, Action_By, Edit_Date, Edit_By) {
        var Status = "";
        var StatusStr = "";
        var Pic_Status = "";
        var Lbl_Create = "";
        var Lbl_Modify = "";
        var Lbl_ActionOn = "";
        var Lbl_ActionBy = "";
        if (ID && ID.length > 0) {
            if (ID.toUpperCase() == "OPENING BALANCE") {
                $('#Lbl_Create_CB').text("");
                $('#Lbl_ActionOn_CB').text("");
                $('#Lbl_ActionBy_CB').text("");
                $('#Lbl_Modify_CB').text("");
                $("#LockICON_CB").hide();
                return;
            }
            $("#LockICON_CB").show();
            Status = Action_Status;
            if (Status && Status.toUpperCase() == "LOCKED") {
                Pic_Status = "fa fa-lock";
            }
            else {
                Pic_Status = "fa fa-unlock";
            }
            if (Status == "Locked") {
                StatusStr = "Locked";
            }
            else {
                StatusStr = "UnLocked";
            }
            Lbl_ActionOn = StatusStr + " On: " + Action_Date;
            Lbl_ActionBy = StatusStr + " By: " + Action_By.toUpperCase();
            Lbl_Create = "Add On: " + Add_Date + ", By: " + Add_By.toUpperCase();
            Lbl_Modify = "Edit On: " + Edit_Date + ", By: " + Edit_By.toUpperCase();
            $('#Lbl_Create_CB').text(Lbl_Create);
            $('#Lbl_ActionOn_CB').text(Lbl_ActionOn);
            $('#Lbl_ActionBy_CB').text(Lbl_ActionBy);
            $('#Lbl_Modify_CB').text(Lbl_Modify);
            if (Pic_Status == "fa fa-lock") {
                $('#LockICON_CB').addClass(Pic_Status).removeClass("fa-unlock");
            }
            else if (Pic_Status == "fa fa-unlock") {
                $('#LockICON_CB').addClass(Pic_Status).removeClass("fa-lock");
            }
            else {
                $('#LockICON_CB').removeClass("fa").removeClass("fa-lock").removeClass("fa-unlock");
            }
        }
        else {
            $('#Lbl_Create_CB').text("");
            $('#Lbl_ActionOn_CB').text("");
            $('#Lbl_ActionBy_CB').text("");
            $('#Lbl_Modify_CB').text("");
            $("#footericon").hide();
        }
    }
