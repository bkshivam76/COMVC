        function On_CBAudit_ActionItemClick(s, e) {
            var img = document.getElementById('RightPane_Img');
            CBAudit_FAB.ExpandActionGroupItems();
            if (e.actionName == "Skip") {
                CBNextRowToBeSelected = CB_SelectedRowIndex + 1;
                var NextPageIndex = FindPageindex();
                if (NextPageIndex != CashBookAuditListGrid.GetPageIndex()) {
                    CashBookAuditListGrid.GotoPage(NextPageIndex);
                }
                else {
                    CashBookAuditListGrid.SelectRowOnPage(CBNextRowToBeSelected, true);
                }
            }
            else if (e.actionName == "Prev") {
                CBNextRowToBeSelected = CB_SelectedRowIndex - 1;
                var NextPageIndex = FindPageindex();
                if (NextPageIndex != CashBookAuditListGrid.GetPageIndex()) {
                    CashBookAuditListGrid.GotoPage(NextPageIndex);
                }
                else {
                    CashBookAuditListGrid.SelectRowOnPage(CBNextRowToBeSelected, true);
                }
            }
            else if (e.actionName == "Accept") {
                OnAcceptwithoutRemarks();
            }
            else if (e.actionName == "Reject") {
                OnAcceptRejectVoucher("Reject");
            }
            else if (e.actionName == "AcceptWithRemarks") {
                OnAcceptRejectVoucher("Accept");
            }
            else if (e.actionName == "Undecided") {
                OnCB_SkipVoucher();
            }
            else if (e.actionName == "Rotate") {
                ImageRotate(img);
            }
            else if (e.actionName == "ZoomOut") {
                ImageZoomOut(img);
            }
            else if (e.actionName == "ZoomIn") {
                ImageZoomIn(img);
            }
            else if (e.actionName == "Fit") {
                ImageFit(img);
            }
            else if (e.actionName == "Back") {
                ImageBack("CBAudit_FAB", "actionItemContext");
            }
            else if (e.actionName == "DocAction") {
                CBAudit_FAB.SetActionContext("docActionContext", true);
            }
            else if (e.actionName == "PrevDoc") {
                DocumentGridPrevNextClick("Prev");
            }
            else if (e.actionName == "SkipDoc") { DocumentGridPrevNextClick("Next"); }
            else if (e.actionName == "RejectDoc") { DocumentGridRejectBtnClick(); }
            else if (e.actionName == "AcceptDoc") { DocumentGridAcceptBtnClick(); }
            else if (e.actionName == "EditDoc") { DocumentGridEditBtnClick(); }

        }
        function FindPageindex() {
            var calculatePageNumber = (CBNextRowToBeSelected + 1) / CBGrid_PageSize_auditor;
            var pageIndex = (Math.ceil(calculatePageNumber)) - 1;
            return pageIndex;
        }
        function OnAcceptRejectVoucher(_actionMethod)
        {
            if (CB_Attachment_ID_auditor.length = 0)//check case where there are remarks
            {
                DevExpress.ui.dialog.alert("Please Select a Attachment!!");
                return;
            }
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Account/CashBookAuditor/Frm_CB_Remarks",
                data:
                {
                    ActionMethod: _actionMethod,
                    RefRecId: (CB_MasterRowMID_auditor == null || CB_MasterRowMID_auditor == "") ? CB_MasterRowRecID_auditor : CB_MasterRowMID_auditor,
                    MainGridName: "CashBookAuditListGrid",
                    TempID: CBAudit_TempID,
                    EntryCenID: CB_Cen_ID_auditor,
                    VouchingCategory: CB_Vouching_Category_auditor
                },
                cache: false,
                success: function (data) {
                    HideLoader();
                    OpenPopup("VoucherAuditRemarksPopup", "Remarks", null, "auto", 250, true, data);
                }
            });
        }
        function OnCB_SkipVoucher() {
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Account/CashBookAuditor/UndecidedVoucher",
                data:
                {
                    TempID: CBAudit_TempID
                },
                cache: false,
                success: function (data) {
                    HideLoader();
                    var alert;
                    if (data.result == true) {
                        CB_RefreshAfterAction = true;
                        //alert = DevExpress.ui.dialog.alert(data.message, "Success");
                        CashBookAuditListGrid.Refresh();
                        DevExpress.ui.notify({ message: data.message, width: 300, shading: true, position: 'center' }, "success", 1500);
                        // HideAlert(alert);
                    }
                    else {
                        alert = DevExpress.ui.dialog.alert(data.message, "Error");
                    }
                }
            });
        }
        function OnAcceptwithoutRemarks() {
