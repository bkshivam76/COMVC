    <script>

    var CB_FreshData = false;
    var CB_ShowClick = false;
    var CB_DataScope = "EXCLUSIVE";
    function CB_DirectShowClick(e)
    {
        CB_FreshData = false;
        CB_ShowClick = true;
        ShowLoader();
        Grid_Display_CBAudit(CB_FreshData);
    }
    function CB_FilterShowClick(e) { }
    function OnCBfilterDocument(e)
    {
        ShowLoader();
        $.ajax({
            url: '@Url.Action("CashBookFilters", "CashBookAuditor")',
            type: "GET",
            success: function (data)
            {
                OpenPopup("CashbookFiltersPopup", "Filters", null, "auto","50%", true, data);
            }
        });
    }
    function CBFilterSuccess(data)
    {
        HideLoader();
        HidePopup("CashbookFiltersPopup");
        CB_FreshData = false;
        CB_ShowClick = true;
        if (CB_SelectedRowIndex > -1)
        {
            GridViewDoCallback(CashBookAuditListGrid, function () { CashBookAuditListGrid.UnselectRows(CB_SelectedRowIndex); });
        }
        Grid_Display_CBAudit(CB_FreshData);
        Vouching_GenerateFilterText();
    }
    function CB_MoreClick(e)
    {
        if (CB_TotalEntriesCount >= 50)
        {
            DevExpress.ui.dialog.alert("50 Entries Have Been Alloted To You<br>More Than 50 Entries Cannot Be Alloted", "Information");
            return;
        }
        CB_FreshData = true;
        HideLoader();
        ShowLoader();
        Grid_Display_CBAudit(CB_FreshData);
    }
    </script>
    <script>
    var CBauditGrid_ViewMode ="Compact";
    function CashbookAuditor_ViewSwitch_ValueChange(e)
    {
        CBauditGrid_ViewMode = e.component.option("text");
        if (CBauditGrid_ViewMode == "Default")
        {
            $("#CashBookAudit_MasterToggleScrollBar").dxButton("instance").option("visible", true);
            e.component.option("text", "Compact");
            e.component.option("icon", "collapse");
            $("#ButCB_Audit_Narration").dxButton("instance").option("visible", true);
            $(".CB_customPreviewRow").hide();
        }
        else
        {
            CBaudit_ShowHorizontalBar = 0;
            $("#CashBookAudit_MasterToggleScrollBar").dxButton("instance").option("visible", false);
            e.component.option("text", "Default");
            e.component.option("icon", "expand");
        }
        ShowLoader();
        $.ajax({
            url: '@Url.Action("Frm_Voucher_Info_CB_Grid_Auditor", "CashBookAuditor")',
            type: "GET",
            async:false,
            data:
            {
                ShowHorizontalBar: CBaudit_ShowHorizontalBar,
                ViewMode:CBauditGrid_ViewMode
            },
            success: function (res)
            {
                $("#CashBookAuditreloadPartialView").html(res);
                HideLoader();
            }
        });
        $("#CashBookAuditListGrid").toggleClass('compact', CBauditGrid_ViewMode == "Compact");
        $("#CashBookAuditListGrid").toggleClass('default', CBauditGrid_ViewMode == "Default");
        if (CBauditGrid_ViewMode == "Compact")
        {
            $("#ButCB_Audit_Narration").dxButton("instance").option("visible", false);
            $(".CB_customPreviewRow").show();
        }
    }

    </script>
