                    var PrintViewitem = e.CreateItem("List Preview", "ListPreview");
                    PrintViewitem.Image.IconID = "actions_export_16x16devav";
                    e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), PrintViewitem);

                    var Close = e.CreateItem("Close", "Close");
                    Close.Image.IconID = "actions_close_16x16devav";
                    e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Close);

