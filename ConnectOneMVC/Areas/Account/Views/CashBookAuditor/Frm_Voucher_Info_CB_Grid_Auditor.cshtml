
@{
    string ViewMode = ViewBag.ViewMode==null?"Compact":(string)ViewBag.ViewMode;
    var SessionGUID = Request.QueryString["SessionGUID"];
    int CB_ShowHorizontalBar = ViewBag.CB_ShowHorizontalBar == null ? 0 : (int)ViewBag.CB_ShowHorizontalBar;
    bool AllowCellMerge = ViewBag.ShowNarration == null ? true : (bool)ViewBag.ShowNarration;

    bool iRef_no_visible = ViewData["iRef_no_Visible"] == null ? true : (bool)ViewData["iRef_no_Visible"];

    bool ShowRECBank = ViewData["iTR_REC_BANK_Visible"] == null ? true : (bool)ViewData["iTR_REC_BANK_Visible"];
    bool ShowPAYBank = ViewData["iTR_PAY_BANK_Visible"] == null ? true : (bool)ViewData["iTR_PAY_BANK_Visible"];

    bool RECJOURNAL_REMOVE = ViewData["iTR_REC_JOURNAL_Remove"] == null ? true : (bool)ViewData["iTR_REC_JOURNAL_Remove"];
    bool RECTOTAL_REMOVE = ViewData["iTR_REC_TOTAL_Remove"] == null ? true : (bool)ViewData["iTR_REC_TOTAL_Remove"];

    bool PAYJOURNAL_REMOVE = ViewData["iTR_PAY_JOURNAL_Remove"] == null ? true : (bool)ViewData["iTR_PAY_JOURNAL_Remove"];
    bool PAYTOTAL_REMOVE = ViewData["iTR_PAY_TOTAL_Remove"] == null ? true : (bool)ViewData["iTR_PAY_TOTAL_Remove"];
    int TotalRowCount = ViewData["GridTotalRowCount"] == null ? 0 : (int)ViewData["GridTotalRowCount"];
    int TotalEntryCount=ViewData["GridTotalEntryCount"]== null ? 0 : (int)ViewData["GridTotalEntryCount"];
}

@Html.DevExpress().GridView(
        settings =>
        {
            settings.Name = "CashBookAuditListGrid";
            settings.CallbackRouteValues = new
            {
                Controller = "CashBookAuditor",
                Action = "Frm_Voucher_Info_CB_Grid_Auditor",
                SessionGUID = SessionGUID

            };
            settings.CustomDataActionRouteValues = new
            {
                Controller = "CashBookAuditor",
                Action = "CB_GetGridData"

            };
            settings.EnableTheming = true;
            settings.Theme = "Aqua";

            settings.ClientVisible = true;
            settings.Settings.ShowGroupPanel = false;
            settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.Control;
            settings.SettingsResizing.Visualization = ResizingMode.Postponed;
            settings.SettingsBehavior.AllowCellMerge = ViewMode=="Compact"?false:AllowCellMerge;
            settings.SettingsBehavior.AllowEllipsisInText = false;
            settings.ControlStyle.Wrap = DefaultBoolean.True;
            settings.Width = Unit.Percentage(100);

            settings.CommandColumn.Visible = false;
            settings.CommandColumn.MaxWidth = 30;
            settings.CommandColumn.ShowSelectCheckbox = true;
            //settings.Styles.SelectedRow.BackColor = System.Drawing.Color.FromArgb(0, 114, 198);
            settings.Styles.SelectedRow.ForeColor = System.Drawing.Color.FromArgb(0,0,255);


            settings.SettingsLoadingPanel.Text = "<b>Remember Baba while CashBook loads...</b>";
            settings.Styles.LoadingPanel.Wrap = DefaultBoolean.True;

            //pager settings
            settings.SettingsPager.Mode = GridViewPagerMode.ShowPager;
            settings.SettingsPager.PageSizeItemSettings.Visible = true;
            settings.SettingsPager.PageSize =70;



            settings.Settings.ShowPreview = true;
            settings.Styles.PreviewRow.CssClass = "CB_customPreviewRow";
            settings.SetPreviewRowTemplateContent(c =>
            {
                var Narration = DataBinder.Eval(c.DataItem, "iTR_NARRATION") == null ? "" : DataBinder.Eval(c.DataItem, "iTR_NARRATION").ToString();
                //var Status = DataBinder.Eval(c.DataItem, "VOUCHING_STATUS") == null ? "" : DataBinder.Eval(c.DataItem, "VOUCHING_STATUS").ToString();
                //var Remarks = DataBinder.Eval(c.DataItem, "Vouching_Remarks") == null ? "" : DataBinder.Eval(c.DataItem, "Vouching_Remarks").ToString();
                if (Narration.Length > 0)
                {
                    ViewContext.Writer.Write("<div><span style='color:Green'> <i>Narration: " + Narration + "</i></span></div>");
                }
                //if (Remarks.Length > 0)
                //{
                //    if (Status.ToUpper() == "REJECTED")
                //    {
                //        ViewContext.Writer.Write("<div><span style='color:#FF0000'> <i>Rejection Remarks: " + Remarks + "</i></span></div>");
                //    }
                //    else if (Status.ToUpper() == "ACCEPTED")
                //    {
                //        ViewContext.Writer.Write("<div><span style='color:#008000'> <i>Acceptance Remarks: " + Remarks + "</i></span></div>");
                //    }
                //}
            });

            settings.PreRender = (s, e) =>
            {
                MVCxGridView grid = (MVCxGridView)s;

                if (ViewData["Layout"] != null)
                {
                    grid.LoadClientLayout(ViewData["Layout"].ToString());
                }
            };
            settings.HtmlRowPrepared = (s, e) =>
            {
                MVCxGridView grid = (MVCxGridView)s;

                if (e.RowType == GridViewRowType.Data)
                {
                    if (e.GetValue("iTR_REF_NO") != null && ((int)e.GetValue("iTR_REF_NO")) % 2 == 0)
                    {
                        e.Row.BackColor = System.Drawing.Color.Linen;
                    }
                    else
                    {
                        e.Row.BackColor = System.Drawing.Color.AliceBlue;
                    }
                    if (e.GetValue("iCross_Ref_ID") == null && (e.GetValue("iTR_CODE") != null && ((int)e.GetValue("iTR_CODE") == 8 || (int)e.GetValue("iTR_CODE") == 15)))
                    {
                        e.Row.BackColor = System.Drawing.Color.Pink;
                    }
                }
                if (e.RowType == GridViewRowType.Preview)
                {
                    e.Row.BackColor = System.Drawing.Color.LightGray;
                }
            };
            settings.HtmlRowCreated = (s, e) =>
            {
                MVCxGridView grid = (MVCxGridView)s;
                if (e.RowType == GridViewRowType.Preview)
                {
                    var Narration = e.GetValue("iTR_NARRATION") == null ? "" : e.GetValue("iTR_NARRATION").ToString();
                    //var Status = e.GetValue("VOUCHING_STATUS") == null ? "" : e.GetValue("VOUCHING_STATUS").ToString();
                    //var Remarks = e.GetValue("Vouching_Remarks") == null ? "" : e.GetValue("Vouching_Remarks").ToString();
                    if (Narration.Length == 0) // && Remarks.Length==0
                    {
                        e.Row.Visible = false;
                    }
                }
            };
            settings.CustomCellMerge = (s, e) =>
            {
                MVCxGridView grid = (MVCxGridView)s;
                if (grid.VisibleRowCount > 0)
                {
                    if (ViewMode == "Default")
                    {
                        if (e.Column.FieldName != "iTR_DATE" && e.Column.FieldName != "iTR_VNO" && e.Column.FieldName != "iTR_REF_NO" && e.Column.FieldName != "iTR_PARTY_1"&& e.Column.FieldName!= "CB_auditIcon")
                        {
                            e.Merge = false;
                            e.Handled = true;
                            return;
                        }
                        double? _Ref_No1 = grid.GetRowValues(e.RowVisibleIndex1, "iTR_REF_NO") == null ? (double?)null : Convert.ToDouble(grid.GetRowValues(e.RowVisibleIndex1, "iTR_REF_NO"));
                        double? _Ref_No2 = grid.GetRowValues(e.RowVisibleIndex2, "iTR_REF_NO") == null ? (double?)null : Convert.ToDouble(grid.GetRowValues(e.RowVisibleIndex2, "iTR_REF_NO"));
                        if (e.Column.FieldName == "CB_auditIcon")
                        {
                            if (_Ref_No1 == _Ref_No2)
                            {
                                e.Merge = true;
                                e.Handled = true;
                            }
                            else
                            {
                                e.Merge = false;
                                e.Handled = true;
                            }
                        }
                        if (e.Column.FieldName == "iTR_DATE")
                        {
                            DateTime? _Date1 = (DateTime?)grid.GetRowValues(e.RowVisibleIndex1, "iTR_DATE");
                            DateTime? _Date2 = (DateTime?)grid.GetRowValues(e.RowVisibleIndex2, "iTR_DATE");
                            if (_Date1 == _Date2 && _Ref_No1 == _Ref_No2)
                            {
                                e.Merge = true;
                                e.Handled = true;
                            }
                            else
                            {
                                e.Merge = false;
                                e.Handled = true;
                            }
                        }
                        if (e.Column.FieldName == "iTR_VNO")
                        {
                            string _Vno1 = "";
                            if (!(Convert.IsDBNull(grid.GetRowValues(e.RowVisibleIndex1, "iTR_VNO"))))
                            {
                                _Vno1 = (string)grid.GetRowValues(e.RowVisibleIndex1, "iTR_VNO");
                            }
                            string _Vno2 = "";
                            if (!(Convert.IsDBNull(grid.GetRowValues(e.RowVisibleIndex2, "iTR_VNO"))))
                            {
                                _Vno2 = (string)grid.GetRowValues(e.RowVisibleIndex2, "iTR_VNO");
                            }

                            if (_Vno1 == _Vno2 && _Ref_No1 == _Ref_No2)
                            {
                                e.Merge = true;
                                e.Handled = true;
                            }
                            else
                            {
                                e.Merge = false;
                                e.Handled = true;
                            }
                        }
                        if (e.Column.FieldName == "iTR_PARTY_1")
                        {
                            string _Party1 = "";
                            if (!(Convert.IsDBNull(grid.GetRowValues(e.RowVisibleIndex1, "iTR_PARTY_1"))))
                            {
                                _Party1 = (string)grid.GetRowValues(e.RowVisibleIndex1, "iTR_PARTY_1");
                            }
                            string _Party2 = "";
                            if (!(Convert.IsDBNull(grid.GetRowValues(e.RowVisibleIndex2, "iTR_PARTY_1"))))
                            {
                                _Party2 = (string)grid.GetRowValues(e.RowVisibleIndex2, "iTR_PARTY_1");
                            }

                            if (_Party1 == _Party2 && _Ref_No1 == _Ref_No2)
                            {
                                e.Merge = true;
                                e.Handled = true;
                            }
                            else
                            {
                                e.Merge = false;
                                e.Handled = true;
                            }
                        }
                        if (e.Column.FieldName == "iTR_REF_NO")
                        {
                            if (_Ref_No1 == _Ref_No2)
                            {
                                e.Merge = true;
                                e.Handled = true;
                            }
                            else
                            {
                                e.Merge = false;
                                e.Handled = true;
                            }
