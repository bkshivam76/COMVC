                            grid.Columns["Payments"].Columns["iTR_PAY_BANK"].Visible = true;
                        }
                    }

                    if (grid.Columns["Payments"].Columns.IndexOf(grid.Columns["iTR_PAY_JOURNAL"]) > -1)
                    {
                        if (PAYJOURNAL_REMOVE == true)
                        {
                            grid.Columns["Payments"].Columns["iTR_PAY_JOURNAL"].Visible = false;
                        }
                        else
                        {
                            grid.Columns["Payments"].Columns["iTR_PAY_JOURNAL"].Visible = true;
                        }
                    }
                    if (grid.Columns["Payments"].Columns.IndexOf(grid.Columns["iTR_PAY_TOTAL"]) > -1)
                    {
                        if (PAYTOTAL_REMOVE == true)
                        {
                            grid.Columns["Payments"].Columns["iTR_PAY_TOTAL"].Visible = false;
                        }
                        else
                        {
                            grid.Columns["Payments"].Columns["iTR_PAY_TOTAL"].Visible = true;
                        }
                    }
                }
