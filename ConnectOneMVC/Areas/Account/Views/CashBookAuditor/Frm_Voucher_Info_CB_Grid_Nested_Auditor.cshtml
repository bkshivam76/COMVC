            var Rejection_Reason = e.GetValue("Rejection_Reason");
            var description = e.GetValue("Description");
            var No_Attachment_Reason = e.GetValue("Reason");
            var VouchingRemarks = e.GetValue("Vouching_Remarks") == null ? "" : e.GetValue("Vouching_Remarks").ToString();
            var VouchingHistory = e.GetValue("Vouching_History") == null ? "" : e.GetValue("Vouching_History").ToString();
            if ((Rejection_Reason == null || Rejection_Reason.ToString().Length == 0) && (description == null || description.ToString().Length == 0) && (No_Attachment_Reason == null || No_Attachment_Reason.ToString().Length == 0) && (VouchingRemarks == null || VouchingRemarks.ToString().Length == 0)&& VouchingHistory.Length==0)
            {
                e.Row.Visible = false;
            }
        }
    };
    settings.Init = (s, e) =>
    {
        MVCxGridView grid = (MVCxGridView)s;
    };
