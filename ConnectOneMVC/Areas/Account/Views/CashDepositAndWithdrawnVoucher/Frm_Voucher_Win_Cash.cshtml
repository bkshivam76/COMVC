<div class=CDW_ClearReferences>
    @using DevExtreme.AspNet.Mvc;
    @model ConnectOneMVC.Areas.Account.Models.Voucher_Win_Cash
    @{
        string submitBtnText = Model != null && Model.ActionMethod.ToString().Trim() == "_Delete" ? "Delete" : "Save";
        Html.EnableClientValidation();
        Html.EnableUnobtrusiveJavaScript();

        var IsMobile = Request.Browser.IsMobileDevice;

    }
    <style>
        #Txt_Amount_CDW .dx-placeholder {
            text-align: center;
            width: 100%;
        }

        #Txt_Amount_CDW {
            text-align: center !important;
        }

        #ListSpecialVoucherRef_CDW .dx-list-item-content {
            padding: 4.5px;
        }

        .td_width1 {
            width: 15%;
            text-align: right;
        }

        .td_width2 {
            width: 10%;
            text-align: center;
        }

        .td_width3 {
            width: 25%;
            text-align: right;
        }

        .td_width4 {
            width: 10%;
            text-align: center;
        }

        .td_width5 {
            width: 40%;
            text-align: right;
        }

        form.edit_form .left-secff .form-field {
            padding-top: 7px;
            padding-bottom: 4.7px;
        }

        .col-sm-6.left-secff fieldset .row {
            margin-bottom: 2.8px;
        }
    </style>
    <div id="Frm_Voucher_Win_Cash_popup" class="">

        @using (Ajax.BeginForm("Frm_Voucher_Win_Cash", "CashDepositAndWithdrawnVoucher",
            new AjaxOptions
            {
                HttpMethod = "POST",
                UpdateTargetId = "Frm_Voucher_Win_Cash_popup",
                InsertionMode = InsertionMode.InsertAfter,
                OnBegin = "AjaxBeginFormPost",
                OnSuccess = "AjaxSuccessVoucherWinCash"
            },
            new
            {
                id = "CDW_validationForm",
                @class = "edit_form form-horizontal"
            }))
        {
            @Html.HiddenFor(x => x.ActionMethod)
            @Html.HiddenFor(x => x.TempActionMethod)
            @Html.HiddenFor(x => x.REC_EDIT_ON_Bank_CDW)
            @Html.HiddenFor(x => x.iTrans_Type)
            @Html.HiddenFor(x => x.LED_ID)
            @Html.HiddenFor(x => x.VOUCHER_TYPE)
            @Html.HiddenFor(x => x.iMode)
            @Html.HiddenFor(x => x.RecID)
            @Html.HiddenFor(x => x.LastEditedOn)
            @Html.HiddenFor(x => x.BE_Bank_Acc_No_Tag_CDW)
            @Html.HiddenFor(x => x.cdw_SplVchrReferenceSelected)
            @Html.HiddenFor(x => x.splVchrRefsCount)
            using (Html.DevExtreme().ValidationGroup("CDW_Voucher"))
            {

                <div class="full-width-header-bg2">
                    <div class="row">
                        <div class="col-sm-8">
                            <h3 class="popuphead"><i class="far fa-edit"></i> Cash Deposit / Withdrawn</h3>
                        </div>
                        <div class="col-sm-4 prm">
                            <h5 class="mand-txt-align">
                                <i class="fas fa-info-circle"></i> Red Fields are mandatory
                            </h5>
                        </div>
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                    </div>
                </div>
                <div class="row">
                    <div class="">
                        <div class="col-sm-6">
                            <div class="form-field">
                                <div class="container-fluid">
                                    <div class="row">
                                        <div class="col-sm-6 col-md-3 col-lg-3 pll">
                                            @Html.Label("Item Name:", htmlAttributes: new { @class = "control-label text-red", @id = "lbl_itemName" })
                                        </div>
                                        <div class="col-sm-6 col-md-9 col-lg-9 prm pll2">
                                            @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_ItemList_CDW").Name("GLookUp_ItemList_CDW").ValueExpr("ITEMID").DisplayExpr("ITEMNAME").ReadOnly(true).Placeholder("Select Item...").Value(Model.GLookUp_ItemList_CDW)
                                              .DataSource(Model.ItemListData,"ITEMID").OnValueChanged("GLookUp_ItemList_EditValueChanged_CDW").ContentTemplate(@<text> @Html.Partial("VoucherWin_Cash_LookUp_GetItemList") </text>).ShowClearButton(false) )
                                            @Html.ValidationMessageFor(model => model.GLookUp_ItemList_CDW, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div><!--[item]-->
                        <div class="col-sm-6">
                            <div class="form-field">
                                <div class="container-fluid">
                                    <div class="row">
                                        <div class="col-sm-6 col-md-4 col-lg-4 pll">
                                            @Html.Label("Voucher Date:", htmlAttributes: new { @class = "contrcol-sm-6ol-label text-red", @id = "lbl_voucherdate" })
                                        </div>
                                        <div class="col-sm-6 col-md-8 col-lg-8 prm">
                                            @(Html.DevExtreme().DateBoxFor(x => x.Txt_V_Date_CDW).CustomDateBox().ID("Txt_V_Date_CDW").Name("Txt_V_Date_CDW") )
                                            @Html.ValidationMessageFor(model => model.Txt_V_Date_CDW, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div><!--[vdate]-->
                    </div>
                </div><!--[row 1]-->
                <div class="row">
                    <div class="">
                        <div class="col-sm-6">
                            <div class="form-field">
                                <div class="container-fluid">
                                    <div class="row">
                                        <div class="col-sm-6 col-md-3 col-lg-3 pll">
                                            @Html.Label("Head:", htmlAttributes: new { @class = "control-label", @id = "lbl_cdw_head" })
                                        </div>
                                        <div class="col-sm-6 col-md-9 col-lg-9 prm pll2">
                                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("BE_Item_Head_CDW").Name("BE_Item_Head_CDW").Placeholder("").Disabled(true).MaxLength(50) )
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div><!--[head]-->
                        <div class="col-sm-6">
                            <div class="form-field">
                                <div class="container-fluid">
                                    <div class="row">
                                        <div class="col-sm-6 col-md-4 col-lg-4 pll">
                                            @Html.Label("Voucher No:", htmlAttributes: new { @class = "control-label", @id = "lbl_cdw_vno" })
                                        </div>
                                        <div class="col-sm-6 col-md-8 col-lg-8 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("Txt_V_NO_CDW").Name("Txt_V_NO_CDW").Placeholder("").Value(Model.Txt_V_NO_CDW).ReadOnly(true).MaxLength(50).FocusStateEnabled(false) )
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div><!--[v no]-->
                    </div>
                </div><!--[row 2]-->

                <div class="col-sm-6 left-secff">

                    <div class="form-field">
                        <div class="container-fluid">
                            <fieldset class="default-fieldset" id="LayoutControlItem1_CDW">
                                <legend class="custom-legend mlm"><label id="lbl_Reg_No"> Bank Detail:</label></legend>
                                <div class="row">
                                    <div class="col-sm-6 col-md-3 col-lg-3 pll">
                                        <label class="control-label text-red" id="lbl_cdw_bank" for="Name">Bank Name:</label>
                                    </div>
                                    <div class="col-sm-6 col-md-9 col-lg-9 prm pll2">
                                        @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_BankList_CDW").Name("GLookUp_BankList_CDW").ValueExpr("BA_ID").DisplayExpr("BANK_NAME").ReadOnly(true)
                                              .DataSource(Model.BankListData,"BA_ID").Placeholder("Select Bank...").Value(Model.GLookUp_BankList_CDW)
                                              .OnValueChanged("GLookUp_BankList_EditValueChanged_CDW").ContentTemplate(@<text> @Html.Partial("LookUp_GetBankList") </text>) )


                                        @Html.ValidationMessageFor(model => model.GLookUp_BankList_CDW, "", new { @class = "text-danger" })
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-sm-6 col-md-3 col-lg-3 pll">
                                        <label class="control-label" id="lbl_cdw_branch" for="Name">Branch:</label>
                                    </div>
                                    <div class="col-sm-6 col-md-9 col-lg-9 prm pll2">
                                        @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Bank_Branch_CDW").Placeholder("").ID("BE_Bank_Branch_CDW").Disabled(true) )
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-6 col-md-3 col-lg-3 pll">
                                        <label class="control-label col-sm-4" id="lbl_cdw_acc" for="Name">A/c.No.:</label>
                                    </div>
                                    <div class="col-sm-6 col-md-9 col-lg-9 prm pll2">
                                        @(Html.DevExtreme().TextBox().CustomTextBox().ID("BE_Bank_Acc_No_CDW").Name("BE_Bank_Acc_No_CDW").Placeholder("").Disabled(true) )
                                    </div>
                                </div>
                            </fieldset>
                        </div>
                    </div>

                    <div class="form-field">
                        <div class="container-fluid">
                            <fieldset class="default-fieldset" id="LayoutControlItem3_CDW">
                                <legend class="custom-legend mlm"><label id="lbl_Ref_Title_CDW" class="disabletxt"> Cheque Detail:</label></legend>


                                <div class="row">
                                    <div class="col-sm-6 col-md-3 col-lg-3 pll">
                                        <label id="lbl_Ref_No_CDW" class="control-label disabletxt" for="Name">Cheque No.:</label>
                                    </div>
                                    <div class="col-sm-6 col-md-9 col-lg-9 prm pll2">
                                        @(Html.DevExtreme().TextBox().CustomTextBox(true,true).ID("Txt_Ref_No_CDW").Name("Txt_Ref_No_CDW").Placeholder("").MaxLength(25).ReadOnly(true).FocusStateEnabled(false) )
                                        @Html.ValidationMessageFor(model => model.Txt_Ref_No_CDW, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-6 col-md-3 col-lg-3 pll">
                                        <label id="lbl_Ref_Date_CDW" class="control-label disabletxt" for="Name">Cheque Date:</label>
                                    </div>
                                    <div class="col-sm-6 col-md-9 col-lg-9 prm pll2">
                                        @(Html.DevExtreme().DateBox().CustomDateBox().ID("Txt_Ref_Date_CDW").Name("Txt_Ref_Date_CDW").Placeholder("").ReadOnly(true).FocusStateEnabled(false) )
                                        @Html.ValidationMessageFor(model => model.Txt_Ref_Date_CDW, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-6 col-md-3 col-lg-3 pll">
                                        <label id="lbl_Ref_CDate_CDW" class="control-label disabletxt" for="Name">Clearing Date:</label>
                                    </div>
                                    <div class="col-sm-6 col-md-9 col-lg-9 prm pll2">
                                        @(Html.DevExtreme().DateBox().CustomDateBox().ID("Txt_Ref_CDate_CDW").Name("Txt_Ref_CDate_CDW").Placeholder("").ReadOnly(true).FocusStateEnabled(false))
                                    </div>
                                </div>
                            </fieldset>
                        </div>
                    </div>

                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-3 col-md-3 col-lg-3 pll">
                                    <label class="control-label text-red" id="lbl_cdw_reference" for="Name">Purpose:</label>
                                </div>
                                <div class="col-sm-9 col-md-9 col-lg-9 prm">
                                    @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("PurposeID_CDW").Name("PurposeID_CDW").DataSource(Model.PurposeListData,"PUR_ID").DisplayExpr("PUR_NAME").ValueExpr("PUR_ID").Value(Model.PurposeID_CDW).Placeholder("Select Purpose...").Disabled(false))
                                    @Html.ValidationMessageFor(model => model.PurposeID_CDW, "", new { @class = "text-red" })
                                </div>
                            </div>
                        </div>
                    </div>


                    <div class="" id="CDW_NarrationDiv">
                        <div class="form-field">
                            <div class="container-fluid">

                                <fieldset class="default-fieldset" id="LayoutControlItem3_CDW">
                                    <legend class="custom-legend mlm"><label id="lbl_Ref_Title_CDW"> Other Details:</label></legend>

                                    <div class="row">
                                        <div class="col-sm-3 col-md-3 col-lg-3 pll">
                                            <label class="control-label" id="lbl_cdw_remarks" for="Name">Remarks:</label>
                                        </div>
                                        <div class="col-sm-9 col-md-9 col-lg-9 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox(true).ID("Txt_Remarks_CDW").Name("Txt_Remarks_CDW").Value(Model.Txt_Remarks_CDW).Placeholder("Type any Other Detail / Remarks...").MaxLength(250).ReadOnly(Model.TempActionMethod == "_View" || Model.TempActionMethod == "_Delete") )
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-sm-3 col-md-3 col-lg-3 pll">
                                            <label class="control-label" id="lbl_cdw_reference" for="Name">Reference:</label>
                                        </div>
                                        <div class="col-sm-9 col-md-9 col-lg-9 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox(true).ID("Txt_Reference_CDW").Name("Txt_Reference_CDW").Value(Model.Txt_Reference_CDW).Placeholder("Type any Reference Details...").MaxLength(250).ReadOnly(Model.TempActionMethod == "_View" || Model.TempActionMethod == "_Delete") )
                                        </div>
                                    </div>
                                </fieldset>
                            </div>
                        </div>
                    </div>


                    <!--[Bank detail, cheque detail and narration]-->
                </div>

                <div class="col-sm-6">
                    <div id="cdw_denomination_div">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <div>
                                        <label id="lbl_currency_cdw" class="pll">Currency Denominations Details:</label>
                                    </div>
                                </div>
                                <div class="row" style="padding:2px 0">
                                    <table border="0" cellpadding="0" cellspacing="0" class="tb_widthmain">
                                        <tr>
                                            <td class="td_width1">2000</td>
                                            <td class="td_width2">x</td>
                                            <td class="td_width3 dx-texteditorDiv">
                                                @(Html.DevExtreme().NumberBox().CustomNumberBox(IsMobile).ID("Txt_2000_CDW").Name("Txt_2000_CDW").ReadOnly(true).FocusStateEnabled(false).ElementAttr(new { @class = "CurrDenom_CDW" }).Min(0).Max(1000000).Format("#0").OnInput("CurrDenom_CDW_OnInput").OnValueChanged("CurrDenom_CDW_ValueChange").Value(Model.Txt_2000_CDW))
                                            </td>
                                            <td class="td_width4">=</td>
                                            <td class="td_width5 dx-texteditorDiv2">
                                                @(Html.DevExtreme().NumberBox().CustomNumberBox(IsMobile).ID("BE_2000_CDW").Name("BE_2000_CDW").InputAttr(new { @style = "text-align:right",@class= "input-read-only" }).Format("#,##0.00").ReadOnly(true).FocusStateEnabled(false).OnValueChanged("CurrDenom_Amont_CDW_ValueChange") )
                                            </td>
                                        </tr>

                                        <tr>
                                            <td class="td_width1">500</td>
                                            <td class="td_width2">x</td>
                                            <td class="td_width3 dx-texteditorDiv">
                                                @(Html.DevExtreme().NumberBox().CustomNumberBox(IsMobile).ID("Txt_500_CDW").Name("Txt_500_CDW").ReadOnly(true).FocusStateEnabled(false).ElementAttr(new { @class = "CurrDenom_CDW" }).Min(0).Max(1000000).Format("#0").OnInput("CurrDenom_CDW_OnInput").OnValueChanged("CurrDenom_CDW_ValueChange").Value(Model.Txt_500_CDW))
                                            </td>
                                            <td class="td_width4">=</td>
                                            <td class="td_width5 dx-texteditorDiv2">
                                                @(Html.DevExtreme().NumberBox().CustomNumberBox(IsMobile).ID("BE_500_CDW").Name("BE_500_CDW").InputAttr(new { @style = "text-align:right", @class = "input-read-only" }).Format("#,##0.00").ReadOnly(true).FocusStateEnabled(false).OnValueChanged("CurrDenom_Amont_CDW_ValueChange") )
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="td_width1">200</td>
                                            <td class="td_width2">x</td>
                                            <td class="td_width3 dx-texteditorDiv">
                                                @(Html.DevExtreme().NumberBox().CustomNumberBox(IsMobile).ID("Txt_200_CDW").Name("Txt_200_CDW").ReadOnly(true).FocusStateEnabled(false).ElementAttr(new { @class = "CurrDenom_CDW" }).Min(0).Max(1000000).Format("#0").OnInput("CurrDenom_CDW_OnInput").OnValueChanged("CurrDenom_CDW_ValueChange").Value(Model.Txt_200_CDW))
                                            </td>
                                            <td class="td_width4">=</td>
                                            <td class="td_width5 dx-texteditorDiv2">
                                                @(Html.DevExtreme().NumberBox().CustomNumberBox(IsMobile).ID("BE_200_CDW").Name("BE_200_CDW").InputAttr(new { @style = "text-align:right", @class = "input-read-only" }).Format("#,##0.00").ReadOnly(true).FocusStateEnabled(false).OnValueChanged("CurrDenom_Amont_CDW_ValueChange") )
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="td_width1">100</td>
                                            <td class="td_width2">x</td>
                                            <td class="td_width3 dx-texteditorDiv">
                                                @(Html.DevExtreme().NumberBox().CustomNumberBox(IsMobile).ID("Txt_100_CDW").Name("Txt_100_CDW").ReadOnly(true).FocusStateEnabled(false).ElementAttr(new { @class = "CurrDenom_CDW" }).Min(0).Max(1000000).Format("#0").OnInput("CurrDenom_CDW_OnInput").OnValueChanged("CurrDenom_CDW_ValueChange").Value(Model.Txt_100_CDW))
                                            </td>
                                            <td class="td_width4">=</td>
                                            <td class="td_width5 dx-texteditorDiv2">
                                                @(Html.DevExtreme().NumberBox().CustomNumberBox(IsMobile).ID("BE_100_CDW").Name("BE_100_CDW").InputAttr(new { @style = "text-align:right", @class = "input-read-only" }).Format("#,##0.00").ReadOnly(true).FocusStateEnabled(false).OnValueChanged("CurrDenom_Amont_CDW_ValueChange") )
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="td_width1" style="">50</td>
                                            <td class="td_width2" style="">x</td>
                                            <td class="td_width3 dx-texteditorDiv" style="">
                                                @(Html.DevExtreme().NumberBox().CustomNumberBox(IsMobile).ID("Txt_50_CDW").Name("Txt_50_CDW").ReadOnly(true).FocusStateEnabled(false).ElementAttr(new { @class = "CurrDenom_CDW" }).Min(0).Max(1000000).Format("#0").OnInput("CurrDenom_CDW_OnInput").OnValueChanged("CurrDenom_CDW_ValueChange").Value(Model.Txt_50_CDW))
                                            </td>
                                            <td class="td_width4" style="">=</td>
                                            <td class="td_width5 dx-texteditorDiv2">
                                                @(Html.DevExtreme().NumberBox().CustomNumberBox(IsMobile).ID("BE_50_CDW").Name("BE_50_CDW").InputAttr(new { @style = "text-align:right", @class = "input-read-only" }).Format("#,##0.00").ReadOnly(true).FocusStateEnabled(false).OnValueChanged("CurrDenom_Amont_CDW_ValueChange") )
