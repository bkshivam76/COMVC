                    $("#Txt_Ref_CDate_CDW").dxDateBox("instance").option("readOnly", true);
                    $("#Txt_Ref_No_CDW").dxTextBox("instance").option("focusStateEnabled", false);
                    $("#Txt_Ref_Date_CDW").dxDateBox("instance").option("focusStateEnabled", false);
                    $("#Txt_Ref_CDate_CDW").dxDateBox("instance").option("focusStateEnabled", false);
                    $("#lbl_Ref_Title_CDW").addClass("disabletxt").removeClass("text-red");
                    $("#lbl_Ref_No_CDW").addClass("disabletxt").removeClass("text-red");
                    $("#lbl_Ref_Date_CDW").addClass("disabletxt").removeClass("text-red");
                    $("#lbl_Ref_CDate_CDW").addClass("disabletxt").removeClass("text-red");
                    $("#Txt_Ref_No_CDW").dxTextBox("instance").option("placeholder", "");
                    $("#Txt_Ref_Date_CDW").dxDateBox("instance").option("placeholder", "");
                    $("#Txt_Ref_CDate_CDW").dxDateBox("instance").option("placeholder", "");
                    if (FirstCall == false) {
                        $(".CurrDenom_CDW").dxNumberBox("option", "value", 0)
