                    $("#Txt_Narration_CDW").dxTextBox('instance').option("focusStateEnabled", false);

                    $("#Txt_Amount_CDW").dxNumberBox('instance').option("readOnly", true);
                    $("#Txt_Amount_CDW").dxNumberBox('instance').option("focusStateEnabled", false);
                }
                else {
                    $('#iMode').val("CHEQUE");
                    $("#lbl_amt_CDW").text("Cash Withdrawn");
                    $("#Txt_Ref_No_CDW").dxTextBox("instance").reset();
                    $("#Txt_Ref_Date_CDW").dxDateBox("instance").reset();
                    $("#Txt_Ref_CDate_CDW").dxDateBox("instance").reset();
                    $("#Txt_Ref_No_CDW").dxTextBox("instance").option("readOnly", false);
