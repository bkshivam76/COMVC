    <script class="CDW_Scripts">
        async function GLookUp_BankList_EditValueChanged_CDW(e, FirstCall = false) {
            var dropDownBox = $("#GLookUp_BankList_CDW").dxDropDownBox("instance");
            dropDownBox.close();
            var BankID;
            if (e) {
                BankID = e.value;
                if ((e.value == null || e.value.length == 0) && e.previousValue != null) {
                    Bank_CDW_DG.clearSelection();
                    $("#BE_Bank_Branch_CDW").dxTextBox("instance").reset();
                    $("#BE_Bank_Acc_No_CDW").dxTextBox("instance").reset();
                    return;
                }
            }
            else {
                BankID = $("#GLookUp_BankList_CDW").dxDropDownBox("option", "value");
            }
            await Bank_CDW_DG.selectRows(BankID);
            if (Bank_CDW_DG.getSelectedRowsData().length > 0) {
                var item = Bank_CDW_DG.getSelectedRowsData()[0];
                $("#REC_EDIT_ON_Bank_CDW").val(JS_Json_Date_To_ddMMyyyy(item["REC_EDIT_ON"]));
                $("#BE_Bank_Branch_CDW").dxTextBox("instance").option('value', item["BANK_BRANCH"]);
                $("#BE_Bank_Acc_No_CDW").dxTextBox("instance").option('value', item["BANK_ACC_NO"]);
                $("#BE_Bank_Acc_No_Tag_CDW").val(item["BI_SHORT_NAME"]);
            }
        }
        async function GLookUp_ItemList_EditValueChanged_CDW(e, FirstCall = false) {
            
            var ItemID;
            if (e) {
                ItemID = e.value;
                if ((e.value == null || e.value.length == 0) && e.previousValue != null) {
                    Item_CDW_DG.clearSelection();
                    return;
                }
            }
            else {
                ItemID = $("#GLookUp_ItemList_CDW").dxDropDownBox("option", "value");
            }
            await Item_CDW_DG.selectRows(ItemID);
            
            if (Item_CDW_DG.getSelectedRowsData().length > 0) {
