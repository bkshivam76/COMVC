    <script class="CDW_Scripts">
    function CDW_SaveBtnClick(e)
    {
        CDW_saveClick == true

        var TotalAmount = $("#Txt_Amount_CDW").dxNumberBox("instance").option("value");

        if (TotalAmount == null || TotalAmount <= 0) {
            var alertclick = DevExpress.ui.dialog.alert("Amount cannot be Zero/Negative...!", "Incomplete Information..");
            alertclick.done(function (alertResult) {
                if (alertResult) {                       
                    var id = "#Txt_Amount_CDW";
                    setTimeout(function () {
                        $(id).find('input').focus();
                    }, Timeout100);                        
                }
            });
            return;
        }

        if (ValidateForm(e))
        {
            var form = $("#CDW_validationForm");
            if (e.component.option("text") == "Delete")
            {
                DeleteAfterConfirmation("Confirm", "", form);
            }
            else
            {
                form.submit();
            }
        }
    }
    function AjaxSuccessVoucherWinCash(data)
    {
        HideLoader();
        CDW_saveClick = false;
        var _ActiveTab_ID = $(".TabPanalMenu-tabs .active").attr("id");
        if (data.jsonParam.result == false)
        {
            if (data.jsonParam.refreshgrid === true)
            {
                RefreshGridView("@ViewBag.GridToRefresh");
            }
            var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
            alertclick.done(function (alertResult)
            {
                if (alertResult)
                {
                    if (data.jsonParam.focusid)
                    {
                        var id = "#" + data.jsonParam.focusid;
                        setTimeout(function ()
                        {
                            $(id).find('input').focus();
                        }, Timeout100);
                    }
                }
            });
            if (data.jsonParam.closeform)
            {
                dontaskpopupcloseconfirmation = true;
                $("#Dynamic_Content_popup").dxPopup("hide");
            }
        }
        else if (data.jsonParam.result == true)
        {
            var saveAlertClick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
            saveAlertClick.done(function (result)
            {
                if (result)
                {
                    if ("@ViewBag.GridToRefresh" != "CashBookListGrid")
                    {
                        RefreshGridView("@ViewBag.GridToRefresh");
                    }
                    //if (_ActiveTab_ID == "contact_Frm_Voucher_Info_CB")
                    //{
                    if (/*typeof CashBookListGrid !== 'undefined'*/ _ActiveTab_ID == "contact_Frm_Voucher_Info_CB") {
                        AfterVoucherClose_CB($("#Txt_V_Date_CDW").dxDateBox("instance").option("value"), "@Model.TempActionMethod", IsUndefinedOrNull(data.CashbookGridPK) ? "" : data.CashbookGridPK);
                    }
                    else if (_ActiveTab_ID == "contact_Frm_Voucher_Info")
                    {
                        AfterVoucherClose_VoucherEntry();
                    }
                    dontaskpopupcloseconfirmation = true;
                    $("#Dynamic_Content_popup").dxPopup("hide");
                }
            });
        }
