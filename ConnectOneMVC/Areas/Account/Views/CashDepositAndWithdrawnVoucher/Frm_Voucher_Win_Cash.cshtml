        function SetNarration_CDW() {
            var Narration_Text = "Denominations = ";
            $("#Txt_Narration_CDW").dxTextBox('instance').option("value", Narration_Text);
            var val_2000 = $("#Txt_2000_CDW").dxNumberBox('instance').option('value');
            //var val_1000 = $("#Txt_1000_CDW").dxNumberBox('instance').option('value');
            var val_500 = $("#Txt_500_CDW").dxNumberBox('instance').option('value');
            var val_200 = $("#Txt_200_CDW").dxNumberBox('instance').option('value');
            var val_100 = $("#Txt_100_CDW").dxNumberBox('instance').option('value');
            var val_50 = $("#Txt_50_CDW").dxNumberBox('instance').option('value');
            var val_20 = $("#Txt_20_CDW").dxNumberBox('instance').option('value');
            var val_10 = $("#Txt_10_CDW").dxNumberBox('instance').option('value');
            var val_5 = $("#Txt_5_CDW").dxNumberBox('instance').option('value');
            var val_2 = $("#Txt_2_CDW").dxNumberBox('instance').option('value');
            var val_1 = $("#Txt_1_CDW").dxNumberBox('instance').option('value');
            if (val_2000 > 0) {
                Narration_Text += "2000x" + val_2000 + ",";
            }
            //if (val_1000 > 0) {
            //    Narration_Text += "1000x" + val_1000 + ","
            //}
            if (val_500 > 0) {
                Narration_Text += "500x" + val_500 + ","
            }
            if (val_200 > 0) {
                Narration_Text += "200x" + val_200 + ","
            }
            if (val_100 > 0) {
                Narration_Text += "100x" + val_100 + ","
            }
            if (val_50 > 0) {
                Narration_Text += "50x" + val_50 + ","
            }
            if (val_20 > 0) {
                Narration_Text += "20x" + val_20 + ","
            }
            if (val_10 > 0) {
                Narration_Text += "10x" + val_10 + ","
            }
            if (val_5 > 0) {
                Narration_Text += "5x" + val_5 + ","
            }
            if (val_2 > 0) {
                Narration_Text += "2x" + val_2 + ","
            }
            if (val_1 > 0) {
                Narration_Text += "1x" + val_1 + ","
            }
            if (Narration_Text.endsWith(",")) {
                Narration_Text = Narration_Text.substring(0, Narration_Text.length - 1);
            }
            $("#Txt_Narration_CDW").dxTextBox('instance').option("value", Narration_Text);
        }
