    <script class="CDW_Scripts">
        var CDW_saveClick = true;
        $(document).ready(async function ()
        {
            ShowLoader_Ready();
            TransformTextForDB("CDW_validationForm");
            sessionclearpath = "/Account/CashDepositAndWithdrawnVoucher/SessionClear";
            InitDropdown_CDW();
            await Promise.all([LookUp_GetItemList_CDW(true),LookUp_GetBankList_CDW(true)])
            if (Tag_CDW != "_View")
            {
                dontaskpopupcloseconfirmation = false;
            }
            if (Tag_CDW == "_View" || Tag_CDW == "_Delete") {
                dontaskpopupcloseconfirmation = true;
            }
            if (Tag_CDW == "_New_From_Selection")
            {
                await GLookUp_ItemList_EditValueChanged_CDW(null, true);
              /*  Control_SetReadOnly("GLookUp_ItemList_CDW", "dxDropDownBox", true, "#696969");*/
            }
            else if (Tag_CDW == "_Edit" || Tag_CDW == "_View" ||Tag_CDW == "_Delete")
            {
                await Data_Binding_CDW();
            }
            if (parseInt("@Model.splVchrRefsCount") > 0)
            {
                OnSplVchrRefsListSelectionChanged_CDW();
            }
            if (parseInt("@Model.splVchrRefsCount") == 0)
            {
                $("#cdw_SpecialVoucherRefDiv").remove();
                $("#fcraAmtDiv_cdw").removeClass("col-sm-12 col-md-6").addClass("col-sm-12 col-md-12");
            }
            Set_Form_View_Delete_Mode(null, "CDW_validationForm", Tag_CDW);
            Focus_FirstEditable_Field("CDW_validationForm");
            HideLoader_Ready();
        });
        async function Data_Binding_CDW()
        {
            await GLookUp_ItemList_EditValueChanged_CDW(null, true);
            Control_SetReadOnly("GLookUp_ItemList_CDW", "dxDropDownBox", false);
            await GLookUp_BankList_EditValueChanged_CDW(null,true);
            Control_SetReadOnly("GLookUp_BankList_CDW", "dxDropDownBox", false);
            if ("@Model.Txt_Ref_No_CDW".length > 0) { $("#Txt_Ref_No_CDW").dxTextBox("instance").option("value", "@Model.Txt_Ref_No_CDW"); }
            if ("@Model.Txt_Ref_Date_CDW".length > 0) { $("#Txt_Ref_Date_CDW").dxDateBox("instance").option("value", moment("@Model.Txt_Ref_Date_CDW","DD/MM/YYYY")); }
            if ("@Model.Txt_Ref_CDate_CDW".length > 0) { $("#Txt_Ref_CDate_CDW").dxDateBox("instance").option("value", moment("@Model.Txt_Ref_CDate_CDW", "DD/MM/YYYY")); }
            if ($("#VOUCHER_TYPE").val().toUpperCase() == "CASH DEPOSITED")
            {
                CurrDenom_CDW_ValueChange();
            }
        }
    </script>
