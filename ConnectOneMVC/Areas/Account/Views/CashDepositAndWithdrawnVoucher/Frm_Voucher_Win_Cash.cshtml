                    $("#lbl_currency_cdw").removeClass("text-red").addClass("disabletxt");

                    $("#Txt_Narration_CDW").dxTextBox('instance').option("readOnly", false);
                    $("#Txt_Narration_CDW").dxTextBox('instance').option("focusStateEnabled", true);

                    $("#Txt_Amount_CDW").dxNumberBox('instance').option("readOnly", false);
                    $("#Txt_Amount_CDW").dxNumberBox('instance').option("focusStateEnabled", true);

                }
            }
        }
