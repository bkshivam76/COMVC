                                            <td class="td_width2">x</td>
                                            <td width="80" style="width:80px; text-align:right;" class="dx-texteditorDiv">
                                                @(Html.DevExtreme().NumberBox().CustomNumberBox(IsMobile).ID("Txt_5_CDW").Name("Txt_5_CDW").ReadOnly(true).FocusStateEnabled(false).ElementAttr(new { @class = "CurrDenom_CDW" }).Min(0).Max(1000000).Format("#0").OnInput("CurrDenom_CDW_OnInput").OnValueChanged("CurrDenom_CDW_ValueChange").Value(Model.Txt_5_CDW))
                                            </td>
                                            <td width="50" style="width:40px; text-align:center;">=</td>
                                            <td class="td_width5 dx-texteditorDiv2">
                                                @(Html.DevExtreme().NumberBox().CustomNumberBox(IsMobile).ID("BE_5_CDW").Name("BE_5_CDW").InputAttr(new { @style = "text-align:right", @class = "input-read-only" }).Format("#,##0.00").ReadOnly(true).FocusStateEnabled(false).OnValueChanged("CurrDenom_Amont_CDW_ValueChange") )
                                            </td>
                                        </tr>
                                        <tr>
                                            <td width="50" style="width:50px; text-align:right;">2</td>
                                            <td class="td_width2">x</td>
                                            <td width="80" style="width:80px; text-align:right;" class="dx-texteditorDiv">
                                                @(Html.DevExtreme().NumberBox().CustomNumberBox(IsMobile).ID("Txt_2_CDW").Name("Txt_2_CDW").ReadOnly(true).FocusStateEnabled(false).ElementAttr(new { @class = "CurrDenom_CDW" }).Min(0).Max(1000000).Format("#0").OnInput("CurrDenom_CDW_OnInput").OnValueChanged("CurrDenom_CDW_ValueChange").Value(Model.Txt_2_CDW))

