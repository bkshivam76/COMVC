



@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("Frm_Voucher_Win_Cash_GLookUp_BankList_datagrid")

    .Columns(columns =>
    {
        columns.Add().DataField("BANK_NAME").Caption("Name").Width(180); ;
        columns.Add().DataField("BANK_BRANCH").Caption("Branch");
        columns.Add().DataField("BANK_ACC_NO").Caption("Account No.");       
        columns.Add().DataField("REC_EDIT_ON").Caption("REC_EDIT_ON").Visible(false);
        columns.Add().DataField("BA_ID").Caption("ID").Visible(false);
     
    })

    .Selection(s => s.Mode(SelectionMode.Single))
    .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}")
)

