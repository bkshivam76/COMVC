@{     var SessionGUID = Request.QueryString["SessionGUID"];}

@Html.DevExpress().GridView(settings =>
{
    settings.Name = "Doc_Library_Grid" ;

    settings.CallbackRouteValues = new { Controller = "DocumentsLibrary", Action = "Frm_Doc_Library_Grid", SessionGUID= SessionGUID };

    settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.Control;
    settings.CustomDataActionRouteValues = new { Controller = "DocumentsLibrary", Action = "DocLibCustomDataAction" };


    settings.CustomJSProperties = (sender, e) =>
    {
        e.Properties["cpFilterExpression"] = (sender as MVCxGridView).FilterExpression;
        e.Properties["cpPostedGrid_RowCount"] = (sender as MVCxGridView).VisibleRowCount;
    };
    settings.AfterPerformCallback = (s, e) =>
    {
        ASPxGridView gridd = (ASPxGridView)s;

    };



    settings.FillContextMenuItems = (sender, e) =>
    {
        if (e.MenuType == GridViewContextMenuType.Rows)
        {

            var Close = e.CreateItem("Close", "Close");
            Close.Image.IconID = "actions_close_16x16devav";
            e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Close);

        }
    };

    settings.KeyFieldName = "ID";

    //settings.Columns.Add("Title").Caption = "Title";
    settings.Columns.Add(c =>
    {

        c.FieldName = "Title";
        c.Caption = "Title";
        c.SetDataItemTemplateContent(container =>
        {
            Html.DevExpress().HyperLink(hyperlink =>
            {
                var visibleIndex = container.VisibleIndex;
                var keyValue = container.KeyValue;
                var fileName = DataBinder.Eval(container.DataItem, "FileName");
                var title = DataBinder.Eval(container.DataItem, "Title");
                hyperlink.Name = "hl" + keyValue.ToString();
                hyperlink.Properties.Text = title.ToString();
                hyperlink.Properties.Target = "_blank";
                hyperlink.NavigateUrl = "http://accountserver.bkinfo.in/connectone/update/common/" + fileName;

            }).Render();
        });

    });
    settings.Columns.Add(c =>
    {

        c.FieldName = "Category";
        c.Caption = "Category";

        //  SortOrder = DevExpress.Web.ASPxGridView.head      ColumnSortOrder.Ascending,
        c.GroupIndex = 0;

    });

    settings.Columns.Add("FileName").Visible = false;
    settings.Columns.Add("FileLocationPath").Visible = false;



    settings.Settings.ShowHeaderFilterBlankItems = false;
    settings.SettingsContextMenu.Enabled = true;

    settings.SettingsBehavior.EnableCustomizationWindow = true;
    //settings.SettingsContextMenu.EnableGroupFooterMenu = DefaultBoolean.True;
    settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
    settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
    settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;
    settings.SettingsBehavior.AllowFixedGroups = true;
    settings.SettingsBehavior.AllowCellMerge = false;

    settings.Settings.VerticalScrollBarMode = ScrollBarMode.Visible;
    settings.Settings.ShowHeaderFilterButton = true;

    settings.KeyboardSupport = true;
    //settings.AccessKey = "G";
    settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
    settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.HideDataCells;

    settings.Settings.ShowGroupFooter = GridViewGroupFooterMode.VisibleAlways;
    settings.Styles.GroupRow.Font.Bold = true;

    settings.SettingsBehavior.AutoExpandAllGroups = true;
    settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
    settings.Settings.UseFixedTableLayout = true;
    settings.SettingsBehavior.ColumnMoveMode = GridColumnMoveMode.AmongSiblings;
    settings.SettingsBehavior.AllowSort = true;
    settings.SettingsBehavior.EnableCustomizationWindow = true;

    settings.Settings.ShowFilterRow = false;
    settings.Settings.AutoFilterCondition = AutoFilterCondition.Contains;

    settings.SettingsSearchPanel.ShowApplyButton = true;
    settings.SettingsPager.Mode = GridViewPagerMode.ShowAllRecords;
    settings.SettingsSearchPanel.ShowClearButton = true;
    settings.SettingsBehavior.AllowSort = true;
    settings.SettingsBehavior.AllowFocusedRow = true;

    // show filter control
    settings.Settings.ShowFilterBar = GridViewStatusBarMode.Visible;
    settings.SettingsFilterControl.ViewMode = true ? FilterControlViewMode.VisualAndText : FilterControlViewMode.Visual;
    settings.SettingsFilterControl.AllowHierarchicalColumns = true;// AllowHierarchicalColumns;
    settings.SettingsFilterControl.ShowAllDataSourceColumns = true;//FilterBuilderDemoHelper.Options.ShowAllDataSourceColumns;
    settings.SettingsFilterControl.MaxHierarchyDepth = 1;
    settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
    //settings.Settings.ShowGroupedColumns = ShowGroupedColumns;
    settings.Settings.ShowFooter = false;


    settings.ClientSideEvents.EndCallback = "Doc_Lib_endcallback";
    //settings.ClientSideEvents.BeginCallback = "Doc_Lib_begincallback";
    //settings.ClientSideEvents.RowDblClick = "Doc_Lib_dblclickEdit";
    //settings.ClientSideEvents.FocusedRowChanged = "Doc_Lib_FocusedRowChanged";
    settings.ClientSideEvents.ContextMenuItemClick = "Doc_Lib_ContextMenuClick";
    MyExtensions.GridViewHelper.CustomGridView(settings);
}).Bind(Model).GetHtml()

