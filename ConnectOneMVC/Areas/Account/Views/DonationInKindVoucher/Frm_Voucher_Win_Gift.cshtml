                                    <div class="col-sm-2 pll"><label class="control-label" for="BE_PAN_No_DNK">PAN No.:</label></div>
                                    <div class="col-sm-3 prm">
                                        @(Html.DevExtreme().TextBox().CustomTextBox().ID("BE_PAN_No_DNK").Name("BE_PAN_No_DNK").Value(Model.BE_PAN_No_DNK).ReadOnly(true).FocusStateEnabled(false))
                                    </div>
                                </div><!--[city/pan]-->
                                <div class="row">
