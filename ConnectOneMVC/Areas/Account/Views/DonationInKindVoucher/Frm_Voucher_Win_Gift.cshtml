                                                            @class = "edit_form form-horizontal"
                                                        }))

        {
            @Html.HiddenFor(x => x.ActionMethod)
            @Html.HiddenFor(x => x.BE_ADD1_DNK)
            @Html.HiddenFor(x => x.BE_ADD2_DNK)
            @Html.HiddenFor(x => x.BE_ADD3_DNK)
            @Html.HiddenFor(x => x.BE_ADD4_DNK)
            @Html.HiddenFor(x => x.BE_STATE_DNK)
            @Html.HiddenFor(x => x.BE_DISTRICT_DNK)
            @Html.HiddenFor(x => x.BE_COUNTRY_DNK)
            @Html.HiddenFor(x => x.BE_PINCODE_DNK)
