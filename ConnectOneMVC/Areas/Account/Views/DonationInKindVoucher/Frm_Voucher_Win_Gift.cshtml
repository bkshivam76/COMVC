                    </div><!--[Header]-->
                    <div class="row">
                        <div class="col-sm-9">
                            <div class="form-field">
                                <div class="row">
                                    <div class="col-sm-3 plm"><label class="control-label underline" for="user">Donor Detail:</label></div>
                                    <div class="col-sm-9 prm btn-align"> 
                                        @(Html.DevExtreme().Button().ID("But_DonAdd_DNK").Text("Add Donor").OnClick(@<text> function() { Add_Donar_DNK(); }</text>).Disabled(Isvisible).FocusStateEnabled(false))
                                        @(Html.DevExtreme().Button().ID("But_DonManage_DNK").Text("Manage Donor").OnClick(@<text> function() { Manage_Donar_DNK(); } </text>).Disabled(Isvisible).FocusStateEnabled(false))
                                    </div>
                                </div><!--[Donor btn]-->
                                <div class="row">
                                    <div class="col-sm-2 plm">
                                        <label class="control-label text-red" for="Name">Name:</label>
                                    </div>
                                    <div class="col-sm-10 prm" data-toggle="tooltip" data-placement="bottom" title="Select Party...">

                                        @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_PartyList1_DNK").Name("GLookUp_PartyList1_DNK").ValueExpr("C_ID").DisplayExpr("C_NAME").Placeholder("Select Party...").ReadOnly(true).FocusStateEnabled(false).ShowClearButton(false)
                                                .DataSource(d => d.Mvc().Controller("DonationInKindVoucher").LoadAction("LookUp_GetPartyList_DNK").Key("C_ID").LoadParams(new { DDRefresh = new JS("function (){ return PartyList1_DDRefresh_DNK;}") }).LoadMode(DataSourceLoadMode.Raw).CacheRawData(true))
