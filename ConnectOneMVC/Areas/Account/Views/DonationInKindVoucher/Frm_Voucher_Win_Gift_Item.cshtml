    function GLookUp_PurList_EditValueChanged_Itm_Dtel(e) {
        e.component.close();
        if ((e.value == null || e.value.length == 0) && e.previousValue != null) {
            DG_PurList_Itm_Dtel.clearSelection();
            return;
        }
    }
    async function LookUp_GetItemList_Itm_Dtel(FirstCall = false) {
        if (FirstCall == false) {
            ItemList_DDRefresh_Itm_Dtel = true;
            await DG_ItemList_Itm_Dtel.refresh();
            ItemList_DDRefresh_Itm_Dtel = false;
        }
        var TotalCount = DG_ItemList_Itm_Dtel.totalCount();
        if (TotalCount < 0) //dd has not been loaded so total count will return -1 in this case
        {
            var ds = $("#GLookUp_ItemList_DNK_Itm").dxDropDownBox("getDataSource");
            var store = ds.store();
            TotalCount = await store.totalCount();
        }
        if (TotalCount == 1) {
            $("#GLookUp_ItemList_DNK_Itm").find('input').css('color', '#000080');//Setting Navy blue colour
            if (Tag_Itm_Dtel == "_New" || Tag_Itm_Dtel == "_New_From_Selection") {
                DG_ItemList_Itm_Dtel.selectRowsByIndexes(0);
                ItemList_Itm_Enable = false;
                Control_SetReadOnly("GLookUp_ItemList_DNK_Itm", "dxDropDownBox", (ItemList_Itm_Enable == true && ItemList_Itm_ReadOnly == false) ? false : true);
            }
        }
        else {
            if (Tag_Itm_Dtel == "_New" || Tag_Itm_Dtel == "_New_From_Selection") {
                ItemList_Itm_ReadOnly = false;
                Control_SetReadOnly("GLookUp_ItemList_DNK_Itm", "dxDropDownBox", (ItemList_Itm_Enable == true && ItemList_Itm_ReadOnly == false) ? false : true);
            }
        }
    }
