    @(Html.DevExtreme().Popup().CustomPopup().ID("Win_Gift_Item_Content_popup").CloseOnOutsideClick(false).ShowTitle(true).Title("PopUpDidnotOpen") )
    <script>
    var ItemList_DDRefresh_Itm_Dtel;
    var PurList_DDRefresh_Itm_Dtel;
    var DG_ItemList_Itm_Dtel;
    var DG_PurList_Itm_Dtel;
    var Tag_Itm_Dtel = "@Model.ActionMethod_DNK_Itm";
    var PurList_Itm_Enable = true;
    var PurList_Itm_ReadOnly = true;
    var ItemList_Itm_Enable = true;
    var ItemList_Itm_ReadOnly = true;
    var Txt_Qty_Itm_Enable = true;
    var Txt_Qty_Itm_ReadOnly = false;
    var Cmd_UOM_Itm_Enable = true;
    var Cmd_UOM_Itm_ReadOnly = false;
    var Txt_Rate_Itm_Enable = true;
    var Txt_Rate_Itm_ReadOnly = false;

    </script> @*Global Variables*@
    <script>
    $(document).ready(async function ()
    {
        ShowLoader_Ready();
        AssignIDtoLabel("Frm_Voucher_Win_Gift_Item_Window","DIK_Item")
        TransformTextForDB("Frm_Voucher_Win_Gift_Item_Window");
        InitAllDropDownDataGrid_Itm_Dtel();
        await Promise.all([LookUp_GetItemList_Itm_Dtel(true), LookUp_GetPurposeList_Itm_Dtel(true)]);
        //$("#Txt_Amount_DNK_Itm").find('input').css('color', "#696969");
        if (Tag_Itm_Dtel == "_Edit" || Tag_Itm_Dtel == "_Delete" || Tag_Itm_Dtel == "_View")
        {
            await DG_ItemList_Itm_Dtel.selectRows($("#iSpecific_ItemID_DNK_Itm").val(),false);
            ItemList_Itm_ReadOnly = true;
            Control_SetReadOnly("GLookUp_ItemList_DNK_Itm", "dxDropDownBox", (ItemList_Itm_Enable == true && ItemList_Itm_ReadOnly == false) ? false : true);

            await DG_PurList_Itm_Dtel.selectRows($("#iPur_ID_DNK_Itm").val(),false);
            PurList_Itm_ReadOnly = false;
            Control_SetReadOnly("GLookUp_PurList_DNK_Itm", "dxDropDownBox", (PurList_Itm_Enable == true && PurList_Itm_ReadOnly == false) ? false : true);
            @*$("#Txt_Qty_DNK_Itm").dxNumberBox("instance").option("value", parseFloat("@Model.Txt_Qty_DNK_Itm"));*@
        }
        if (Tag_Itm_Dtel == "_View")
        {
            switch ($("#iProfile_DNK_Itm").val())
            {
                case "GOLD":
                case "SILVER":
                case "OTHER ASSETS":
                case "LIVESTOCK":
                case "VEHICLES":
                case "LAND & BUILDING":
                    $("#BUT_SAVE_COM_Itm_Dtel").dxButton("instance").option("text", "View");
                    break;
                default:
                    if ($("#iVoucher_Type_DNK_Itm").val().toUpperCase() == "LAND & BUILDING" && $("#iProfile_DNK_Itm").val().toUpperCase()!="LAND & BUILDING")
                    {
                        $("#BUT_SAVE_COM_Itm_Dtel").dxButton("instance").option("text", "View");
                    }
                    else
                    {
                        $("#BUT_SAVE_COM_Itm_Dtel").dxButton("instance").option("visible", false);
                    }
                    break;
            }
        }
        if ("@Model.iSpecific_Allow_DNK_Itm" == "True")  //By Item-wise Selection
        {
            await DG_ItemList_Itm_Dtel.selectRows($("#iSpecific_ItemID_DNK_Itm").val(), false);
            ItemList_Itm_ReadOnly = false;
            Control_SetReadOnly("GLookUp_ItemList_DNK_Itm", "dxDropDownBox", (ItemList_Itm_Enable == true && ItemList_Itm_ReadOnly == false) ? false : true);
            $("#iSpecific_Allow_DNK_Itm").val(false);
        }
        FormInitialSettings("Frm_Voucher_Win_Gift_Item_Window",Tag_Itm_Dtel);
    });
    function DIK_Item_But_save_click(e)
    {
        if (ValidateForm(e))
        {
            $("#Frm_Voucher_Win_Gift_Item_Window").submit();
        }
    }
    function Item_DetailAjaxSuccess_DNK_Itm(data)
    {
        HideLoader();
        if (data.jsonParam.result == false)
        {
            var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
            alertclick.done(function (alertResult)
            {
                if (alertResult)
                {
                    if (data.jsonParam.focusid)
                    {
                        var id = "#" + data.jsonParam.focusid;
                        setTimeout(function ()
                        {
                            $(id).find('input').focus();
                        }, Timeout100);
                    }
                }
            });
        }
        else if (data.jsonParam.result == true)
        {
            if (data.jsonParam.popup_form_path == "" || data.jsonParam.popup_form_path == null)
            {
                Fill_Item_Grid_DonationInKindVoucher();
            }
            else
            {
                ShowLoader();
                if (data.jsonParam.popup_form_name == "Frm_Reference_Type")
                {
                    OpenPopup("Win_Gift_Item_Content_popup", data.jsonParam.popup_title, data.jsonParam.popup_form_path + "?" + data.jsonParam.popup_querystring, "auto", 340, false, null);
                }
                else
                {
                    OpenPopup("Win_Gift_Item_Content_popup", data.jsonParam.popup_title, data.jsonParam.popup_form_path + "?" + data.jsonParam.popup_querystring, "auto", 1000, false, null);
                }
            }
        }
    }
    $(function ()
    {
        $("#Win_Gift_Item_Content_popup").dxPopup({
            onHiding: function (e)
            {
                var title = $("#Win_Gift_Item_Content_popup").dxPopup("instance").option("title");
                $.ajax({
                    type: 'GET',
                    url: "/Account/ProfilePaymentVoucher/ProfilePaymentClearSession",
                    cache: false,
                    success: function ()
                    {
                        if (title.includes("Land & Building") || title.includes("Property"))
                        {
                            $("#Win_Gift_Item_Popup").dxPopup("hide");
                        }
                    }
                });

                //if ($("#Frm_Asset_Window_ParentDiv").length > 0) { $("#Frm_Asset_Window_ParentDiv").remove(); }
                //if ($("#Frm_GoldSilver_Window_ParentDiv").length > 0) { $("#Frm_GoldSilver_Window_ParentDiv").remove(); }
                //if ($("#Payment_PropertySelect_ParentDiv").length > 0) { $("#Payment_PropertySelect_ParentDiv").remove(); }
                //if ($("#Frm_Live_Stock_Window_ParentDiv").length > 0) { $("#Frm_Live_Stock_Window_ParentDiv").remove(); }
                //if ($("#Frm_Vehicle_Window_ParentDiv").length > 0) { $("#Frm_Vehicle_Window_ParentDiv").remove(); }
                //if ($("#Frm_Property_Window_ParentDiv").length > 0) { $("#Frm_Property_Window_ParentDiv").remove(); }
                //if ($("#WIPReferenceType_ParentDiv").length > 0) { $("#WIPReferenceType_ParentDiv").remove(); }
            }
        });
    });
    </script> @*Document.ready, SetDefault() & AjaxSuccess Functions*@
    <script>
    function InitAllDropDownDataGrid_Itm_Dtel() {
        var $DG_ItemList_Itm_Dtel = $("#ItemList_DG_Itm_Dtel");
        if ($DG_ItemList_Itm_Dtel.length) {
            DG_ItemList_Itm_Dtel = $DG_ItemList_Itm_Dtel.dxDataGrid("instance");
        }

        var $DG_PurList_Itm_Dtel = $("#PurList_DG_Itm_Dtel");
        if ($DG_PurList_Itm_Dtel.length) {
            DG_PurList_Itm_Dtel = $DG_PurList_Itm_Dtel.dxDataGrid("instance");
        }
    }
    async function LookUp_GetPurposeList_Itm_Dtel(FirstCall = false) {
        if (FirstCall == false) {
            PurList_DDRefresh_Itm_Dtel = true;
            await DG_PurList_Itm_Dtel.refresh();
            PurList_DDRefresh_Itm_Dtel = false;
        }
        if (Tag_Itm_Dtel == "_New" || Tag_Itm_Dtel == "_New_From_Selection") {
            PurList_Itm_ReadOnly = false;
