    function Txt_Qty_Rate_EditValueChanged_Itm_Dtel(e) {
        var Txt_Qty = $("#Txt_Qty_DNK_Itm").dxNumberBox("instance").option("value");
        var Txt_Rate;
        if (@YearID <= 2223) {
            Txt_Rate = 1;
        }
        else {
            Txt_Rate = $("#Txt_Rate_DNK_Itm").dxNumberBox("instance").option("value");
        }
        if (Txt_Qty != null && Txt_Rate != null) {
            $("#Txt_Amount_DNK_Itm").dxNumberBox("instance").option("value", Txt_Qty == null ? 0 : parseFloat(Txt_Qty * Txt_Rate).toFixed(2));
        }
    }
