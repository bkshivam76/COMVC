
@using DevExtreme.AspNet.Data;
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("ItemList_DG_Itm_Dtel")
    .Columns(columns =>
    {
        columns.Add().DataField("ITEM_NAME").Caption("Name").Visible(true);
        columns.Add().DataField("LED_NAME").Caption("Head").Visible(true); 
        columns.Add().DataField("LED_TYPE").Caption("Head").Visible(false);
        columns.Add().DataField("ITEM_TRANS_TYPE").Visible(false);
        columns.Add().DataField("ITEM_LED_ID").Visible(false);
        columns.Add().DataField("ITEM_VOUCHER_TYPE").Visible(false);
        columns.Add().DataField("ITEM_PARTY_REQ").Visible(false);
        columns.Add().DataField("ITEM_PROFILE").Visible(false);
        columns.Add().DataField("ITEM_CON_LED_ID").Visible(false);
        columns.Add().DataField("ITEM_CON_MIN_VALUE").Visible(false);
        columns.Add().DataField("ITEM_CON_MAX_VALUE").Visible(false);
        columns.Add().DataField("CON_LED_TYPE").Visible(false);
        columns.Add().DataField("ITEM_ID").Visible(false);
    })  
    .Selection(s => s.Mode(SelectionMode.Single))
)
