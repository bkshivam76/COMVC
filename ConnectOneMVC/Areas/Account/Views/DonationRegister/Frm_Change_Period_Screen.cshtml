<div class="DonationRegister_ChangePeriod_ClearReferences">
    @using DevExtreme.AspNet.Mvc;

    @model ConnectOneMVC.Areas.Account.Models.DonationRegisterPeriod

    @{
        /**/

        Html.EnableClientValidation();
        Html.EnableUnobtrusiveJavaScript();
        Html.AntiForgeryToken();
    }
    <div>
        @using (Ajax.BeginForm("Frm_Change_Period_Screen", "DonationRegister",
               new AjaxOptions
               {
                   HttpMethod = "POST",
                   UpdateTargetId = "Frm_Change_Period_Screen",
                   InsertionMode = InsertionMode.InsertAfter,
                   OnBegin = "AjaxBeginFormPost",
                   OnSuccess = "Frm_Change_Period_Screen_Success"
               },
                new
                {
                    id = "id_Frm_Change_Period_Screen_DonReg",
                    @class = "edit_form"
                }))
        {
            using (Html.DevExtreme().ValidationGroup())
            {
                <div class="row">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-3 col-md-3 col-lg-3 pll"><label class="control-label  text-red" for="Name">From:</label></div>
                                <div class="col-sm-9 col-md-9 col-lg-9 prm">
                                    @(Html.DevExtreme().DateBox().CustomDateBox().ID("DonReg_Fromdate").Name("DonReg_Fromdate").Max((DateTime)ViewBag.MaxDate).Value(Convert.ToDateTime(Model.DonReg_Fromdate)))

                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-3 col-md-3 col-lg-3 pll"><label class="control-label  text-red" for="Name">To:</label></div>
                                <div class="col-sm-9 col-md-9 col-lg-9 prm">

                                    @(Html.DevExtreme().DateBox().CustomDateBox().ID("DonReg_Todate").Name("DonReg_Todate").Max((DateTime)ViewBag.MaxDate).Value(Convert.ToDateTime(Model.DonReg_Todate)))
                                </div>

                            </div>
                        </div>
                    </div>
                </div><!--[row]-->
                <div class="row">
                    <div class="form-field ">
                        <div class="styleActionBtn">
                            @(Html.DevExtreme().Button().CustomSaveButton().ID("DonRegChangePeriod").Text("Ok").UseSubmitBehavior(true) )
                            @(Html.DevExtreme().Button().CustomCloseButton().ID("DonRegChangePeriodCancel").Text("Cancel").OnClick(@<text> function () { $("#Dynamic_Content_popup").dxPopup("hide"); } </text>) )
                        </div>
                    </div>
                </div><!--[button]-->
            }
        }
    </div>
    <script>
        $(document).ready(function () {
            setTimeout(function () {
                $("#DonReg_Fromdate").dxDateBox("instance").focus();
            }, Timeout100);
        });
        function Frm_Change_Period_Screen_Success(data) {
            HideLoader();
            if (data.result == false) {
                DevExpress.ui.dialog.alert(data.message, 'Error!!');
            }
            else {
                $("#BE_View_Period_DonReg").text(data.Period);
                $("#Dynamic_Content_popup").dxPopup("hide");
            }
        }


    </script>
</div>