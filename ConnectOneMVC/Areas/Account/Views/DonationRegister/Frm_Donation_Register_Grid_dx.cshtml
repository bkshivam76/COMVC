@using DevExtreme.AspNet.Mvc;
@{

    int ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;
    var SessionGUID = Request.QueryString["SessionGUID"];
    SessionGUID = SessionGUID == "null" ? null : SessionGUID;
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;

}

@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar)
                 .ID("DonRegisterListGrid_dx")
                 .DataSource(d => d.Mvc().Controller("DonationRegister")
                 .LoadAction("Donation_Register_Grid_Load")
                 .OnBeforeSend("DonRegisterListGrid_dx_OnBeforeSend")

                 .LoadMode(DataSourceLoadMode.Raw).Key("ID"))
                 .Columns(columns =>
                 {
                     columns.Add().DataField("iIcon").Name("iIcon").Caption("").CellTemplate(new JS("DonRegisterListGrid_dx_iIconTemplate")).Width(30)
                     .HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource")).RenderAsync(true);

                     columns.Add().DataField("DonRegisterListGrid_dx_Compact_Column").Name("DonRegisterListGrid_dx_Compact_Column").Caption("")
                     .Visible(false).CellTemplate(new JS("DonRegisterListGrid_dx_Compact_Column_Template"))
                     .CalculateCellValue("DonRegisterListGrid_dx_Compact_Column_CellValue").Width("100%")
                     .RenderAsync(true).ShowInColumnChooser(false);

                     columns.Add().DataField("DonationDate").Caption("Date").MinWidth(140)
                      .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                     columns.Add().DataField("Donor_Name").Caption("Donor Name").MinWidth(175);
                     columns.Add().DataField("PAN").Caption("PAN").MinWidth(100);
                     columns.Add().DataField("Address").Caption("Address").MinWidth(350);
                     columns.Add().DataField("City").Caption("City").MinWidth(100);
                     columns.Add().DataField("District").Caption("District").MinWidth(100);
                     columns.Add().DataField("State").Caption("State").MinWidth(100);
                     columns.Add().DataField("Country").Caption("Country").MinWidth(100);
                     columns.Add().DataField("Purpose").Caption("Purpose").MinWidth(125);
                     columns.Add().DataField("Amount").Caption("Amount").MinWidth(100)
                     .DataType(GridColumnDataType.Number)
                     .Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     //.Format("#0.00;");
                     columns.Add().DataField("Mode").Caption("Mode").MinWidth(100);
                     columns.Add().DataField("Cheque_DD_Ref_No").Caption("Cheque/DD/Ref No.").MinWidth(130);
                     columns.Add().DataField("Cheque_DD_Ref_Date").Caption("Cheque/DD/Ref Date").MinWidth(140)
                    .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                     columns.Add().DataField("Cheque_DD_Ref_Bank").Caption("Cheque/DD/Ref Bank").MinWidth(150)
                     .DataType(GridColumnDataType.String);
                     columns.Add().DataField("DepBank").Caption("Dep. Bank").MinWidth(150);
                     columns.Add().DataField("Form_Received").Caption("Form Received").MinWidth(100);
                     columns.Add().DataField("Form_Received_Date").Caption("Form Received Date").MinWidth(140)
                      .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                     columns.Add().DataField("Status_Remarks").Caption("Status Remarks").MinWidth(200)
                      .DataType(GridColumnDataType.String);
                     columns.Add().DataField("Receipt_No").Caption("Receipt_No").MinWidth(100)
                     .DataType(GridColumnDataType.String);
                     columns.Add().DataField("Kind_of_Donation").Caption("Kind of Donation").MinWidth(130);
                     columns.Add().DataField("Amt_in_Foreign_Curr").Caption("Amt (in Foreign Curr.)").MinWidth(130)
                     .DataType(GridColumnDataType.Number).Format("#0.00;");
                     columns.Add().DataField("Currency").Caption("Currency").MinWidth(100)
                      .DataType(GridColumnDataType.String);
                     columns.Add().DataField("Curr_Rate").Caption("Curr. Rate").MinWidth(100)
                     .DataType(GridColumnDataType.Number).Format("#0.00;");

                     columns.Add().DataField("DS_STATUS_MISC_ID").Visible(false);
                     columns.Add().DataField("TR_AB_ID_1").Visible(false);
                     columns.Add().DataField("Action_Status").Visible(false);
                     columns.Add().DataField("Action_By").Caption("Action By").Visible(false);
                     columns.Add().DataField("Action_Date").Caption("Action Date").Visible(false);
                     columns.Add().DataField("Add_By").Caption("Add By").Visible(false);
                     columns.Add().DataField("Add_Date").Caption("Add Date").Visible(false);
                     columns.Add().DataField("Edit_By").Caption("Edited By").Visible(false);
                     columns.Add().DataField("Edit_Date").Caption("Edited Date").Visible(false);
                     columns.Add().DataField("Offered_for_Audit").Caption("Offered for Audit").Visible(false);
                     columns.Add().DataField("Attachment_IDs").Visible(false);
                     columns.Add().DataField("VA_Status").Visible(false);
                     columns.Add().DataField("ID").Visible(false);
                     columns.Add().DataField("Attached_Form").Visible(false);
                     columns.Add().DataField("Attached_PAN").Visible(false);
                     columns.Add().DataField("Attached_Aadhar").Visible(false);
                     columns.Add().DataField("AADHAR").Caption("Aadhar").Visible(false);

                     columns.Add().DataField("REJECTED_COUNT").Caption("iREJECTED_COUNT").Visible(false);
                     columns.Add().DataField("RESPONDED_COUNT").Caption("iRESPONDED_COUNT").Visible(false);
                     columns.Add().DataField("COMPLETE_ATTACH_COUNT").Caption("iCOMPLETE_ATTACH_COUNT").Visible(false);
                     columns.Add().DataField("REQ_ATTACH_COUNT").Caption("iREQ_ATTACH_COUNT").Visible(false);
                     columns.Add().DataField("OTHER_ATTACH_CNT").Visible(false);
                     columns.Add().DataField("ALL_ATTACH_CNT").Visible(false);
                     columns.Add().DataField("Status").GroupIndex(0);
                     columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);//Bug #137209 Fix


                 })           
.Selection(s => s.Mode(SelectionMode.Multiple)
.ShowCheckBoxesMode(GridSelectionShowCheckBoxesMode.Always)
.AllowSelectAll(true))

 //.Summary(s =>
 //{
 //    s.TotalItems(item => item.Add().Column("SummaryColumn").DisplayFormat(""));
 //    s.GroupItems(Gitem => Gitem.Add().Column("SummaryColumn")
 //    .ShowInGroupFooter(true).DisplayFormat(""));

 //})
 .MasterDetail(md =>
 {
     md.AutoExpandAll(false);
     md.Enabled(!VouchingMode);
     md.Template(new JS("DonRegisterListGrid_dx_DetailTemplate"));
 })
.OnInitialized("DonRegisterListGrid_dx_OnInitialized")
.OnCellPrepared("DonRegisterListGrid_dx_OnCellPrepared")
.OnRowPrepared("DonRegisterListGrid_dx_OnRowPrepared")
.OnContentReady("DonRegisterListGrid_dx_OnContentReady")
.OnCellDblClick("DonRegisterListGrid_dx_OnCellDblClick")
.OnSelectionChanged("DonRegisterListGrid_dx_OnSelectionChanged")
////.OnFocusedRowChanged("DonRegisterListGrid_dx_OnFocusedRowChanged")
.OnRowExpanding("DonRegisterListGrid_dx_OnRowExpanding")
.OnRowCollapsing("DonRegisterListGrid_dx_OnRowCollapsing")
.OnContextMenuPreparing("DonRegisterListGrid_dx_OnContextMenuPreparing")
.OnRowClick("DonRegisterListGrid_InfoGrid_dx_OnRowClick")
)