    <script>
        function PeriodSelectionChange_DonReg()
        {
            var SelectBox = $("#PeriodSelection_DonReg").dxSelectBox("instance").option("value");
            $("#btnChangePeriod_DonReg").dxButton("instance").option("disabled", true);
            if (SelectBox == "Specific Period")
            {
                $("#btnChangePeriod_DonReg").dxButton("instance").option("disabled", false);
                ChangePeriodClick_DonReg();
            }
            else
            {
                ShowLoader();
                $.ajax({
                    type: 'GET',
                    url: "/Account/DonationRegister/Period_ChangeEvent",
                    data: { Chaval: $("#PeriodSelection_DonReg").dxSelectBox("instance").option("value") },
                    cache: false,
                    success: function (data)
                    {
                        $("#BE_View_Period_DonReg").text(data.Period);
                        HideLoader();
                    }
                });
            }
        }
        function ChangePeriodClick_DonReg()
        {
            ShowLoader();
            OpenDynamicPopup("Change Period", "@Url.Action("Frm_Change_Period_Screen", "DonationRegister", new { @area = "Account" })", "auto", "30%", false, null);
        }
        function DonationRegisterShowClick(e)
        {
            DonRegisterListGrid.SetFocusedRowIndex(-1);
            if (DonReg_IsVouchingMode == true)
            {
                ClearLeftPane();
                ClearRightPane();
            }
            DonRegisterListGrid.Refresh();
        }
    </script>
    <script>

        function DonReg_VouchingSwitch_ValueChange(e) {
            ShowLoader();
            DonReg_IsVouchingMode = e.value;
            //DonRegisterListGrid.SetFocusedRowIndex(-1);
            if (DonReg_SetVouchingModeOn == true) {
                DonReg_SetVouchingModeOn = false;
            }
            else {
                DonationRegister_FAB.SetVisible(false);
            }
            if (DonReg_IsVouchingMode == true) {
                OpenRightPane();
                ClearLeftPane();
                OpenLeftPane();
            }
            else {
                CloseRightPane();
                ClearLeftPane();
                CloseLeftPane();
            }
            DonRegisterListGrid_CollapseAllDetailRows();
        }
        function DonReg_ViewSwitch_ValueChange(e) {
            ShowLoader();
            DonReg_ViewMode = e.value == false ? "Default" : "Compact";
            if (DonReg_SetVouchingModeOn == true) {
                $("#DonRegVouchingModeSwitch").dxSwitch("instance").option("value", true);
            }
            else {
                if (DonReg_IsVouchingMode == false) {
                    DonationRegister_FAB.SetVisible(false);
                }
                DonRegisterListGrid.CollapseAllDetailRows();
            }
            HideLoader();
        }
        function DonRegisterListGrid_CollapseAllDetailRows() {
            ShowLoader();
            if (typeof window !== 'undefined') {
                if (typeof window.DonRegisterListGrid !== 'undefined') {
                    if (typeof window.DonRegisterListGrid.CollapseAllDetailRows !== 'undefined') {
                        if (typeof DonRegisterListGrid.CollapseAllDetailRows == 'function') {
                            HideLoader();
                            DonRegisterListGrid.SetFocusedRowIndex(-1);
                            DonRegisterListGrid.CollapseAllDetailRows();
                        }
                        else {
                            alert("CollapseAllDetailRows is not a function");
                        }
                    }
                    else {
                        setTimeout(function () {
                            DonRegisterListGrid_CollapseAllDetailRows();
                        }, Timeout100);
                    }
                }
                else {
                    alert('grid undefined')
                }
            }
            else {
                alert('window undefined')
            }
        }
    </script>
