    function OnGridDonRegisterListGrid_EndCallback(s, e)
    {
        ASPxClientControl.AdjustControls(document.getElementById("DonationRegister_ParentDiv"));
        DonReg_ColumnToBeShownIndex = s.cpColumnToBeShownIndex;
        DonReg_ColumnToBeHidddenIndex = s.cpColumnToBeHidddenIndex;
        if (DonReg_IsVouchingMode == true) {
            $(".DonRegisterListGrid_PreviewRow").hide();
        }
        else { $(".DonRegisterListGrid_PreviewRow").show(); }
        GetSessionStorage("DonRegisterListGrid");
        if (flag == 1) {
            HideLoader();
            flag = 2;
            DRAttachmentFocusRowIndexBeforeRefresh = s.GetFocusedRowIndex();
            ASPxClientControl.GetControlCollection().GetByName(DonationRegisterInfo_NestedGrid_AccessID).Refresh();

        }

        //DonRegister_AdjustSize();
        DonRegister_layout = s.cpClientLayout;
        SendCustomArgs_FilterControl(s, e);
        if (command == "REFRESH")
        {
            s.SetFocusedRowIndex(-1);
            s.SetFocusedRowIndex(DonationRegister_FocusedRowBeforeRefresh);
            if (DonRegisterListGrid.GetSelectedRowCount() > 0)
            {
                DonRegisterListGrid.UnselectRows();
            }
        }

    }

        function OnGridDonRegisterNestedListGrid_EndCallback(s, e) {


            if (e.command == "REFRESH") {

                if (flag == 2) {
                    s.SetFocusedRowIndex(-1);
                    s.SetFocusedRowIndex(DRAttachmentFocusRowIndexBeforeRefresh);
                }
            }
        }
    function DonRegister_AdjustSize() {
        var height = (document.documentElement.clientHeight * 90) / 100;
        try { DonRegisterListGrid.SetHeight(height); } catch (err) { }
    }
    function DonRegister_changeMode() {
        if (DonReg_ShowHorizontalBar == 0) {
            DonReg_ShowHorizontalBar = 1;
            $("#DonRegisterToggleScrollBar").find("span").text("Default Data");
            $("#DonRegisterToggleScrollBar").width(110);
        }
        else {
            DonReg_ShowHorizontalBar = 0;
            $("#DonRegisterToggleScrollBar").find("span").text("Full Data");
            $("#DonRegisterToggleScrollBar").width(90);
        }
        $.ajax({
            url: '@Url.Action("Frm_Donation_Register_Grid", "DonationRegister")',
            type: "GET",
            data: { ShowHorizontalBar: DonReg_ShowHorizontalBar, Layout: DonRegister_layout, VouchingMode: DonReg_IsVouchingMode, ViewMode: DonReg_ViewMode, ColumnToBeHidddenIndex: DonReg_ColumnToBeHidddenIndex, ColumnToBeShownIndex: DonReg_ColumnToBeShownIndex   },
            success: function (res)
            {
                $("#DonRegisterreloadPartialView").html(res);
                if (DonReg_IsVouchingMode == true) {
                    $(".DonRegisterListGrid_PreviewRow").hide();
                    ClearLeftPane();
                    ClearRightPane();
                }
                else { $(".DonRegisterListGrid_PreviewRow").show(); }
                GetSessionStorage("DonRegisterListGrid");
                DonRegisterListGrid.SetFocusedRowIndex(-1);
            }
        });
    }


