        function Reject_Receipt() {            

            var proceedForRejection = true;

            const SelectedStatusesArray = SelectedStatuses.split(",");
            if (SelectedStatusesArray.length > 0) {
                for (let i = 0; i < SelectedStatusesArray.length; i++) {
                    if (SelectedStatusesArray[i] == "Receipt Request Rejected") {
                        proceedForRejection = false;
                        break;
                    }
                }
            }
            else {
                DevExpress.ui.dialog.alert("Please select atleast one row.", "!! Alert !!")
                return;
            }

            if (proceedForRejection == false) {
                DevExpress.ui.dialog.alert("The receipt in 'Rejected' status cannot be rejected again. Please unselect the receipts which are already rejected", "!! Alert !!")
                return;
            }

            var confirmClick = DevExpress.ui.dialog.confirm("Are you Sure Selected Donation Acknowledgement should be Rejected ?", "!! Confirm !!");
            confirmClick.done(function (confirmresult) {
                if (confirmresult) {
                    ShowLoader();

                    $.ajax({
                        type: 'GET',
                        url: "/Account/DonationRegister/Donation_Register_AddRejectionReason",
                        cache: false,
                        data:
                        {
                            DonationID: SelectedIDs,
                            RejectionRemarks: "",//RejectionRemarks : show previous filled ones here
                            ABID: SelectedAB_IDs,
                        },
                        success: function (data) {
                            OpenPopup("Reject_Reason_popup", "Reason for Rejection", null, "auto",550, true, data);
                        }
                    });
                }
            })
        }
