                s.GetRowValues(s.GetFocusedRowIndex(), 'ID;Edit_Date;Add_Date;Add_By;Edit_By;Action_Status;Action_Date;Action_By;Kind_of_Donation;Attachment_IDs;Status', DonRegisterOnGetRowValues);
            }
            else { DonRegisterID = null;}
        }

    function DonRegisterOnGetRowValues(values) {
        DonRegisterID = values[0];
        DonRegister_EditDate = values[1];
        DonRegister_AddDate = values[2];
        DonRegister_AddBy = values[3];
        DonRegister_EditBy = values[4];
        DonRegister_ActionStatus = values[5];
        DonRegister_ActionDate = values[6];
        DonRegister_ActionBy = values[7];
        DonRegister_Kind_of_Donation = values[8];
        DonRegister_Attachments = values[9];
        DonRegister_Status = values[10];
        DonRegister_UpdateFooterDetail(DonRegisterID, DonRegister_ActionStatus, DonRegister_AddDate, DonRegister_AddBy,
        DonRegister_ActionDate, DonRegister_ActionBy, DonRegister_EditDate, DonRegister_EditBy);
        if (DonReg_IsVouchingMode == true)
        {
            OpenLeftPane();
            LoadDocumentAndAdditionalInfoInLeftPane("Account", "DonationRegister", "LeftPaneContent", DonRegisterID, DonReg_IsVouchingMode);
        }
    }

    function DonRegister_UpdateFooterDetail(DonRegisterID, DonRegister_Action_Status, DonRegister_Add_Date, DonRegister_Add_By, DonRegister_Action_Date, DonRegister_Action_By, DonRegister_Edit_Date, DonRegister_Edit_By) {
        DonRegister_Action_Date = DonRegister_Action_Date != "" && DonRegister_Action_Date != null ? DonRegister_Action_Date : DonRegister_Action_Date;
        DonRegister_Edit_Date = DonRegister_Edit_Date != "" && DonRegister_Edit_Date != null ? DonRegister_Edit_Date : DonRegister_Edit_Date;
        DonRegister_Add_Date = DonRegister_Add_Date != "" && DonRegister_Add_Date != null ? DonRegister_Add_Date : DonRegister_Add_Date;
        $.ajax({
            type: 'GET',
            url: "/Account/DonationRegister/CreationDetail",
            data: {
                Xrow: DonRegisterID, Action_Status: DonRegister_Action_Status, Add_Date: DonRegister_Add_Date,
                Add_By: DonRegister_Add_By, Action_Date: DonRegister_Action_Date, Action_By: DonRegister_Action_By, Edit_Date: DonRegister_Edit_Date, Edit_By: DonRegister_Edit_By
            },
            cache: false,
            success: function (DonRegisterLbl_result) {
                $('#DonRegister_Lbl_ActionOn').text(DonRegisterLbl_result.Lbl_StatusOn);
                $('#DonRegister_Lbl_ActionBy').text(DonRegisterLbl_result.Lbl_StatusBy);
                $('#DonRegisterLbl_Status').text(DonRegisterLbl_result.Lbl_Status);
                $('#DonRegisterLbl_Create').text(DonRegisterLbl_result.Lbl_Create);
                $('#DonRegisterLbl_Modify').text(DonRegisterLbl_result.Lbl_Modify);
                if (DonRegisterLbl_result.Lbl_Status_Color != "") {
                    $('#DonRegisterLbl_Status').css('color', DonRegisterLbl_result.Lbl_Status_Color);
                }
                if (DonRegisterLbl_result.Pic_Status != "") {
                    $('#DonRegister_LockICON').css('class', DonRegisterLbl_result.Pic_Status);
                }

            }
        });
    }

