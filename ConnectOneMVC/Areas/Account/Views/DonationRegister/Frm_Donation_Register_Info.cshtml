    function OnDonationRegisterListGridNestedFocusedRowChange(s, e)
    {
        if (DonationRegisterInfo_IsDetailRowExpanded || DonReg_IsVouchingMode == true)
        {
            DonationRegisterInfo_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
            if (DonationRegisterInfo_NestedRecord_FocusedRowIndex < 0)
            {
                DonationRegister_FAB.SetActionContext("AddAttachmentContext", false);
                DonationRegisterInfo_MasterRowMID = null;
                DonationRegisterInfo_MasterRowRecID = null;

            }
            else
            {
                ShowLoader();
                DonationRegisterInfo_NestedGrid_AccessID = s.uniqueID;
              //  s.GetRowValues(s.GetFocusedRowIndex(), 'Doc_Status;Params_Mandatory;LABEL_FROM_DATE;LABEL_TO_DATE;LABEL_DESCRIPTION;Document_Category;Document_ID;ATTACH_ID;TxnID;TxnMID;MAP_ID;Reason;ATTACH_FILE_NAME;Attachment_Action_Status;UniqueID', OnDonationRegisterInfo_GetGridRowValues);
                DonationRegister_NestedRowUniqueID = s.GetRowKey(s.GetFocusedRowIndex());
                flag = 1;
                s.GetValuesOnCustomCallback({ key: DonationRegister_NestedRowUniqueID }, OnDonationRegisterInfo_GetGridRowValues);

            }
        }
    }
    function OnDonationRegisterInfo_GetGridRowValues(data)
    {
        flag = 0;
        HideLoader();//Redmine Bug #131651 fixed
        var values = data.split('![');
        if (values[14] != null)
        {
            DonationRegister_FAB.SetVisible(true);
            DonationRegisterInfo_Nested_Doc_Status = values[0];
            if (DonReg_IsVouchingMode == true) {
                DonationRegister_FAB.SetActionContext("AuditActionContext", true);
            }
            else {
                if (DonationRegisterInfo_Nested_Doc_Status == "") {
                    DonationRegister_FAB.SetActionContext("AutoItemContext", true);
                }
                else if (DonationRegisterInfo_Nested_Doc_Status == "NO") {
                    DonationRegister_FAB.SetActionContext("EditItemContext", true);
                }
                else if (DonationRegisterInfo_Nested_Doc_Status == "YES") {
                    DonationRegister_FAB.SetActionContext("actionItemContext", true);
                }
            }
            DonationRegisterInfo_ParamMandatory = values[1];
            DonationRegisterInfo_FromDateLabel = values[2];
            DonationRegisterInfo_ToDateLabel = values[3];
            DonationRegisterInfo_DescriptionLabel = values[4];
            DonationRegisterInfo_Doc_Category = values[5];
            DonationRegisterInfo_Doc_ID = values[6];
            DonationRegisterInfo_AtachmentID = values[7];
            IndexAttachmentID = DonationRegisterInfo_AtachmentID;
            DonationRegisterInfo_MasterRowRecID = values[8];
            DonationRegisterInfo_MasterRowMID = values[9];
            DonationRegisterInfo_NestedRowMapID = values[10];
            DonationRegisterInfo_reason = values[11];
            DonationRegisterInfo_FileName = values[12];
            DonationRegisterInfo_Attachment_RecStatus = values[13];
            if (DonReg_IsVouchingMode == true) {
                if (DonationRegisterInfo_FileName != null && DonationRegisterInfo_FileName.length > 0) {
                    ViewDocument(DonationRegisterInfo_AtachmentID, DonationRegisterInfo_FileName, "DonationRegister_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else {
                    CloseRightPane();
                    document.getElementById('RightPane_div_Iframe').style.display = "none";
                    document.getElementById('RightPane_div_Img').style.display = "none";
                }
            }

        }
        DonationRegisterInfo_NestedRowReasonID = values[15];
        IndexAttachmentReasonID = DonationRegisterInfo_NestedRowReasonID;
    }
    function DonationRegisterGrid_Nested_BeginCallBack(s, e)
    {
        e.customArgs["VouchingMode"] = DonReg_IsVouchingMode;
        e.customArgs["ShowHorizontalBar"] = DonReg_ShowHorizontalBar;
        e.customArgs["command"] = e.command;
    }

    </script>
