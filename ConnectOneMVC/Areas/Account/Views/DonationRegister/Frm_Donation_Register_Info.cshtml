    function GetSelectedFieldValuesCallback(values) {
        SelectedRows.BeginUpdate();
        try {
            SelectedRows.ClearItems();
            for (var i = 0; i < values.length; i++) {
                SelectedRows.AddItem(values[i]);
            }
        } finally {
            SelectedRows.EndUpdate();
        }
        $("#count").html(gvRowSelection.GetSelectedRowCount());

    }

    function DonRegister_ContextMenuFunction(s, e) {
        if (e.item.name == 'Close') {
            closeDonationRegister();
        }
        else if (e.item.name == 'Add_Attachment') {
            if (DonRegisterID.length > 0) {
                Open_Attachment_Window(DonRegisterID, DonRegister_Kind_of_Donation = "Regular" ? "Donation_Regular" : "Donation_Foreign", "DonRegisterListGrid");
            }
            else {
                DevExpress.ui.dialog.alert('Please select a donation entry to which document has to be attached!!', 'Alert ');
            }
        }
        else if (e.item.name == 'Attach_Don_Form') {
            if (DonRegisterID.length > 0) {
                Open_Attachment_Window(DonRegisterID, DonRegister_Kind_of_Donation = "Regular" ? "Donation_Regular" : "Donation_Foreign", "DonRegisterListGrid", "DONATION", "3a4c7065-29eb-47aa-b31b-a07f91f5bc6b");
            }
            else {
                DevExpress.ui.dialog.alert('Please select a donation entry to which Donation Form has to be attached!!', 'Alert ');
            }
        }
        else if (e.item.name == 'Attach_PAN') {
            if (DonRegisterID.length > 0) {
