    function showHideNextPrev() {
        var Attachments = All_Attachments_DonReg.split(",");
        var CurrAttachmentSlot = 0;

        for (let i = 0; i < Attachments.length; i++) {
            if (Attachments[i] == Curr_Attachment_DonReg) {
                CurrAttachmentSlot = i;
            }
        }

            if (CurrAttachmentSlot == 0){ $("#linkPrevAttachment").hide(); }
            else { $("#linkPrevAttachment").show(); }

            if (CurrAttachmentSlot == Attachments.length-1) { $("#linkNextAttachment").hide(); }
            else { $("#linkNextAttachment").show(); }
    }
    function OnNextAttachmentClick() {
        var Attachments = All_Attachments_DonReg.split(",");
        for (let i = 0; i < Attachments.length-1; i++) {
            if (Attachments[i] == Curr_Attachment_DonReg) {
                Curr_Attachment_DonReg = Attachments[i + 1];
                document.getElementById('DonRegAttachmentFrm').src = "http://192.168.61.142:1008/Attachments/" + Curr_Attachment_DonReg + "#toolbar=0&navpanes=0";
            }
        }
        showHideNextPrev();
    }
    function OnPrevAttachmentClick() {
        var Attachments = All_Attachments_DonReg.split(",");
        for (let i = 0; i < Attachments.length - 1; i++) {
            if (Attachments[i + 1] == Curr_Attachment_DonReg) {
                Curr_Attachment_DonReg = Attachments[i];
                document.getElementById('DonRegAttachmentFrm').src = "http://192.168.61.142:1008/Attachments/" + Curr_Attachment_DonReg + "#toolbar=0&navpanes=0";
            }
        }
        showHideNextPrev();
    }
