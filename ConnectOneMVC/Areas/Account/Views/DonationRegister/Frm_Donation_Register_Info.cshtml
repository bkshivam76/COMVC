                    });
                   
                }
            });
        }
    function On_DonationRegister_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@DonationReg_HelpAttachmentAddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (DonationRegisterInfo_ParamMandatory == 1)
            {
                AddAttachment(DonationRegisterInfo_MasterRowRecID, "Accounts_DonationRegister", DonationRegisterInfo_Doc_ID, DonationRegisterInfo_Doc_Category, DonationRegisterInfo_ParamMandatory, DonationRegisterInfo_FromDateLabel, DonationRegisterInfo_ToDateLabel, DonationRegisterInfo_DescriptionLabel, "DonationRegisterAttachment", null, "DonRegisterListGrid", DonationRegisterInfo_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(DonationRegisterInfo_MasterRowRecID, "Accounts_DonationRegister", DonationRegisterInfo_Doc_ID, "DonationRegisterAttachment", "DonRegisterListGrid", DonationRegisterInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (DonationRegisterInfo_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(DonationRegisterInfo_MasterRowRecID, "Accounts_DonationRegister", DonationRegisterInfo_AtachmentID, DonationRegisterInfo_ParamMandatory, DonationRegisterInfo_FromDateLabel, DonationRegisterInfo_ToDateLabel, DonationRegisterInfo_DescriptionLabel, "DonationRegisterAttachment", null, "DonRegisterListGrid", DonationRegisterInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(DonationRegisterInfo_MasterRowRecID, "Accounts_DonationRegister", DonationRegisterInfo_AtachmentID, DonationRegisterInfo_ParamMandatory, DonationRegisterInfo_FromDateLabel, DonationRegisterInfo_ToDateLabel, DonationRegisterInfo_DescriptionLabel, null, "DonRegisterListGrid", DonationRegisterInfo_NestedGrid_AccessID, DonationRegisterInfo_Attachment_RecStatus);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@Help_Attachment_ViewRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            ViewDocument(DonationRegisterInfo_AtachmentID, DonationRegisterInfo_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName === "Add_Reason")
        {
            if (DonationRegisterInfo_Doc_Category.toLowerCase() == "others") {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else {
                AttachmentAddReason(DonationRegisterInfo_MasterRowRecID, DonationRegisterInfo_NestedRowMapID, "Accounts_DonationRegister", "DonRegisterListGrid", DonationRegisterInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName == "Link_Attach") {
            LinkAttachment(DonationRegisterInfo_MasterRowRecID, "Accounts_DonationRegister", "Donation Register", "DonRegisterListGrid", DonationRegisterInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(DonationRegisterInfo_MasterRowRecID, DonationRegisterInfo_NestedRowMapID, "Accounts_DonationRegister", "DonRegisterListGrid", DonationRegisterInfo_NestedGrid_AccessID, DonationRegisterInfo_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(DonationRegisterInfo_MasterRowRecID, DonationRegisterInfo_NestedRowMapID, "DonRegisterListGrid", DonationRegisterInfo_NestedGrid_AccessID);
        }
        else if (e.actionName == "AuditAction")
        {
            DonationRegister_FAB.SetActionContext("AuditActionContext", true);
        }
        else if (e.actionName == "BackAudit")
        {
            if (DonationRegisterInfo_Nested_Doc_Status == "") {
                DonationRegister_FAB.SetActionContext("AutoItemContext", true);
            }
            if (DonationRegisterInfo_Nested_Doc_Status == "NO") {
                DonationRegister_FAB.SetActionContext("EditItemContext", true);
            }
            if (DonationRegisterInfo_Nested_Doc_Status == "YES") {
                DonationRegister_FAB.SetActionContext("actionItemContext", true);
            }
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
        else if (e.actionName == "Accept") {

            OnDonReg_AcceptwithoutRemarks();
        }
        else if (e.actionName == "Reject") {

            OnDonReg_AcceptRejectVoucher("Reject");
        }
        else if (e.actionName == "AcceptWithRemarks") {

            OnDonReg_AcceptRejectVoucher("Accept");
        }
            else if (e.actionName == "AcceptDoc") {

                OnDonReg_AcceptDoc();
            }
            else if (e.actionName == "RejectDoc") {

                OnDonReg_RejectDoc();
            }
        }
