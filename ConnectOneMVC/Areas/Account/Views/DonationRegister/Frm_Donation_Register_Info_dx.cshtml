    function On_DonationRegister_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@DonationReg_HelpAttachmentAddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (DonationRegisterInfo_ParamMandatory == 1)
            {
                AddAttachment(DonationRegisterInfo_MasterRowRecID, "Accounts_DonationRegister", DonationRegisterInfo_Doc_ID, DonationRegisterInfo_Doc_Category, DonationRegisterInfo_ParamMandatory, DonationRegisterInfo_FromDateLabel, DonationRegisterInfo_ToDateLabel, DonationRegisterInfo_DescriptionLabel, "DonationRegisterAttachment", null, "DonRegisterListGrid_dx", DonationRegisterInfo_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(DonationRegisterInfo_MasterRowRecID, "Accounts_DonationRegister", DonationRegisterInfo_Doc_ID, "DonationRegisterAttachment", "DonRegisterListGrid_dx", DonationRegisterInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (DonationRegisterInfo_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
