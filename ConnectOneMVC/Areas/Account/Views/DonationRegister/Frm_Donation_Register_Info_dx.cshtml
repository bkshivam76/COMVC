            function Generate_Receipt() {
                debugger;
                if (SelectedStatuses == "") {
                    DevExpress.ui.dialog.alert('Please select donation to be Generated!!', 'Alert ');
                    return;
                }
                var All_Status = SelectedStatuses.split(",");
                for (let i = 0; i < All_Status.length; i++) {
                    if (All_Status[i] == "Receipt Generated" || All_Status[i] == "Receipt Printed" || All_Status[i] == "Receipt Despatched") {
                        DevExpress.ui.dialog.alert('Donation Entry in "' + All_Status[i] + '" status can not be generated!!', 'Alert ');
                        return;
                    }
                }
                // alert(Selected_Donation_Dates);
                var result = DevExpress.ui.dialog.confirm("Sure you want to <color=red> Generate Receipt </color> for Selected Entries...?", "Confirmation...");
                result.done(function (dialogResult) {
                    if (dialogResult) {
                        $.ajax({
