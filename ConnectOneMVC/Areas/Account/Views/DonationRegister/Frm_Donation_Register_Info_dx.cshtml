    function GetSelectedFieldValuesCallback_DonationRegister(values) {
        SelectedAlreadyOfferedRows = ""; SelectedNotOfferedRows = ""; SelectedIDs = ""; SelectedStatuses = ""; SelectedAttached_Form = ""; SelectedStatusIDs = ""; SelectedAB_IDs = ""; Selected_PANs = ""; Selected_AADHARs = ""; Selected_Donation_Kinds = "";Selected_Donation_Dates=""
        for (var i = 0; i < values.length; i++) {
            var CurrValue = values[i].toString();
            var Values_Arr = CurrValue.split(",");
            var ID = Values_Arr[0];
            var Offered = Values_Arr[1];
            var Status = Values_Arr[2];
            var Attached_Form = Values_Arr[3];
            StatusID = Values_Arr[4];
            var ABID = Values_Arr[5];
            var Attached_PAN = Values_Arr[6];
            var Attached_Aadhar = Values_Arr[7];
            var PAN = Values_Arr[8];
            var Aadhar = Values_Arr[9];
            RecEditOn = Values_Arr[10];
            var Aadhar = Values_Arr[9];
            var DonationKind = Values_Arr[11];
            var VoucherDate = Values_Arr[12];
            var FormReceivedDate = Values_Arr[13];
            if (Offered == "NO") {
                if (SelectedNotOfferedRows.length > 0) { SelectedNotOfferedRows = SelectedNotOfferedRows + "," }
                SelectedNotOfferedRows = SelectedNotOfferedRows + ID;
            }
            else {
                if (SelectedAlreadyOfferedRows.length > 0) { SelectedAlreadyOfferedRows = SelectedAlreadyOfferedRows + "," }
                SelectedAlreadyOfferedRows = SelectedAlreadyOfferedRows + ID;
            }
            if (SelectedIDs.length > 0) { SelectedIDs = SelectedIDs + "," }
            SelectedIDs = SelectedIDs + ID;
            if (SelectedStatuses.length > 0) { SelectedStatuses = SelectedStatuses + "," }
            SelectedStatuses = SelectedStatuses + Status;
            if (SelectedAttached_Form.length > 0) { SelectedAttached_Form = SelectedAttached_Form + "," }
            SelectedAttached_Form = SelectedAttached_Form + Attached_Form;
            if (SelectedStatusIDs.length > 0) { SelectedStatusIDs = SelectedStatusIDs + "," }
            SelectedStatusIDs = SelectedStatusIDs + StatusID;
            if (SelectedAB_IDs.length > 0) { SelectedAB_IDs = SelectedAB_IDs + "," }
            SelectedAB_IDs = SelectedAB_IDs + ABID;
            if (SelectedAttached_PANs.length > 0) { SelectedAttached_PANs = SelectedAttached_PANs + "," }
            SelectedAttached_PANs = SelectedAttached_PANs + Attached_PAN;
            if (SelectedAttached_AADHARs.length > 0) { SelectedAttached_AADHARs = SelectedAttached_AADHARs + "," }
            SelectedAttached_AADHARs = SelectedAttached_AADHARs + Attached_Aadhar;
            if (Selected_PANs.length > 0) { Selected_PANs = Selected_PANs + "," }
            Selected_PANs = Selected_PANs + PAN;
            if (Selected_Donation_Kinds.length > 0) { Selected_Donation_Kinds = Selected_Donation_Kinds + "," }
            Selected_Donation_Kinds = Selected_Donation_Kinds + DonationKind;
            if (Selected_Donation_Dates.length > 0) { Selected_Donation_Dates = Selected_Donation_Dates + "," }
            Selected_Donation_Dates = Selected_Donation_Dates + JS_Json_Date_To_ddMMyyyy(VoucherDate, _format = "DD/MM/YYYY HH:mm:ss.SSS");
            if (Selected_Form_Received_Dates.length > 0) { Selected_Form_Received_Dates = Selected_Form_Received_Dates + "," }
            Selected_Form_Received_Dates = Selected_Form_Received_Dates + JS_Json_Date_To_ddMMyyyy(FormReceivedDate, _format = "DD/MM/YYYY HH:mm:ss.SSS");
            if (Selected_AADHARs.length > 0) { Selected_AADHARs = Selected_AADHARs + "," }
            Selected_AADHARs = Selected_AADHARs + Aadhar;
           // alert((moment(VoucherDate, "DD/MM/YYYY HH:mm:ss").format("DD/MM/YYYY HH:mm:ss")));
           // alert(JS_Json_Date_To_ddMMyyyy(VoucherDate, _format = "DD/MM/YYYY HH:mm:ss.SSS"))

        }
    }


