            function DonRegisterchangeMode_dx() {
                DonRegisterListGrid_dx.beginUpdate();
                if (DonReg_ShowHorizontalBar == 0) {
                    DonReg_ShowHorizontalBar = 1;
                    $("#DonRegisterToggleScrollBar_dx").find("span").text("Default Data");
                    $("#DonRegisterToggleScrollBar_dx").width(110);
                    DonRegisterListGrid_dx.option("columnHidingEnabled", false);
