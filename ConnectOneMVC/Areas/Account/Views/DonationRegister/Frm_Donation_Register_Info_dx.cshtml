                    DonRegisterListGrid_dx.option("columnHidingEnabled", true)
                    DonRegisterListGrid_dx.option("columnResizingMode", "nextColumn")
                }
                DonRegisterListGrid_dx.endUpdate();
            }
            function DonRegister_ViewSwitch_ValueChange_dx(e) {
                DonReg_ViewMode = e.value == false ? "Default" : "Compact";
                if (DonReg_SetVouchingModeOn == true) {
                    $("#DonRegVouchingModeSwitch").dxSwitch("instance").option("value", true);
                }
                DonRegisterListGrid_dx.beginUpdate();
                var columns = DonRegisterListGrid_dx.option("columns");
                if (DonReg_ViewMode == "Compact") {
                    VisibleColumns_DonRegisterListGrid_dx = [];
                    for (var i = 0; i < columns.length; i++) {
                        var name = columns[i].dataField;
                        var ColumnVisible = DonRegisterListGrid_dx.columnOption(name, "visible");
                        if (name == "DonRegisterListGrid_dx_Compact_Column") {
                            DonRegisterListGrid_dx.columnOption(name, "visible", true);
                        }
                        else if (ColumnVisible == true && name != "iIcon") {
                            VisibleColumns_DonRegisterListGrid_dx.push(name);
                            DonRegisterListGrid_dx.columnOption(name, "visible", false);
                        }
                    }
                }
                else {
                    DonRegisterListGrid_dx.columnOption("DonRegisterListGrid_dx_Compact_Column", "visible", false);
                    for (var i = 0; i < VisibleColumns_DonRegisterListGrid_dx.length; i++) {
                        DonRegisterListGrid_dx.columnOption(VisibleColumns_DonRegisterListGrid_dx[i], "visible", true);
                    }
                }
                DonRegisterListGrid_dx.repaint();
                DonRegisterListGrid_dx.endUpdate();
            }
            function DonRegisterListGrid_dx_Compact_Column_CellValue(rowData) {
                var data = [];

                if (!(rowData.Mode === "CASH")) {
                    data = [
                        rowData.DonationDate, rowData.Donor_Name, rowData.PAN,
                        rowData.Address, rowData.City, rowData.State, rowData.District,
                        rowData.Country, rowData.Purpose, rowData.Amount, rowData.Mode,
                        rowData.Cheque_DD_Ref_No, rowData.Cheque_DD_Ref_Date,
                        rowData.Cheque_DD_Ref_Bank, rowData.DepBank

                    ]
                }
                else {
                    data = [
                        rowData.DonationDate, rowData.Donor_Name, rowData.PAN,
                        rowData.Address, rowData.City, rowData.State, rowData.District,
                        rowData.Country, rowData.Purpose, rowData.Amount, rowData.Mode
                    ]

                }
                return data.join(" ")


