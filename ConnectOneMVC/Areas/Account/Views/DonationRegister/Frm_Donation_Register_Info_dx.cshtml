            data: {
                Xrow: DonRegisterID, Action_Status: DonRegister_Action_Status, Add_Date: DonRegister_Add_Date,
                Add_By: DonRegister_Add_By, Action_Date: DonRegister_Action_Date, Action_By: DonRegister_Action_By, Edit_Date: DonRegister_Edit_Date, Edit_By: DonRegister_Edit_By
            },
            cache: false,
            success: function (DonRegisterLbl_result) {
                $('#DonRegister_Lbl_ActionOn').text(DonRegisterLbl_result.Lbl_StatusOn);
                $('#DonRegister_Lbl_ActionBy').text(DonRegisterLbl_result.Lbl_StatusBy);
                $('#DonRegisterLbl_Status').text(DonRegisterLbl_result.Lbl_Status);
                $('#DonRegisterLbl_Create').text(DonRegisterLbl_result.Lbl_Create);
                $('#DonRegisterLbl_Modify').text(DonRegisterLbl_result.Lbl_Modify);
                if (DonRegisterLbl_result.Lbl_Status_Color != "") {
                    $('#DonRegisterLbl_Status').css('color', DonRegisterLbl_result.Lbl_Status_Color);
                }
                if (DonRegisterLbl_result.Pic_Status != "") {
                    $('#DonRegister_LockICON').css('class', DonRegisterLbl_result.Pic_Status);
                }

            }
        });
    }


    function GetSelectedFieldValuesCallback(values) {
        SelectedRows.BeginUpdate();
        try {
            SelectedRows.ClearItems();
            for (var i = 0; i < values.length; i++) {
                SelectedRows.AddItem(values[i]);
            }
        } finally {
            SelectedRows.EndUpdate();
        }
        $("#count").html(gvRowSelection.GetSelectedRowCount());

    }

