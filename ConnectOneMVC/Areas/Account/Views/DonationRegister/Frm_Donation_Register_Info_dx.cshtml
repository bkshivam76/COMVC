<script>
        function DonLogsListGrid_dx_OnInitialized(e) {
            DxGrid_AdjustSize(e.component, $("#DonationLogs_ParentDiv_dx .report_button_div"))
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                DxGrid_AdjustSize(e.component, $("#DonationLogs_ParentDiv_dx .report_button_div"), "", evt)
            });


        }
        function DonLogs_onRowPrepared(e) {     //This is to color the rows.
            var DonationLogsInstance = $("#DonRegister_Gateway_Logs_dx").dxDataGrid("instance");
            if (e.rowType == "data") {
                var GridName = e.element[0].id;
                $(e.rowElement).addClass(GridName + "_DataRow_" + e.key)
                if (e.data.RESULT == 'CAPTURED') {
                    $(e.rowElement).css("background-color", "lightgreen");

                } else {
                    $(e.rowElement).css("background-color", "lightcoral");
                }
            }
        }

        function DonLogs_dx_GroupCell_Template(container, templateData) { //This is to name the group name.

            var Bank_Name, AccNo, recid;
            var RowData = DxGrid_GetGroupRowData(templateData.data)
            if (RowData != null) {
                Bank_Name = RowData.BI_BANK_NAME;
                AccNo = RowData.CEN_ACC_NO;
                recid = RowData.REC_ID;
            }
            if (templateData.groupContinuesMessage && recid == null) {
                $(container).html(templateData.groupContinuesMessage);
                return
            }

            $(container).html("Online Donation Logs for "+Bank_Name + "  A/C No. " + AccNo);


        }

        function DonLogschangeMode_dx() {
            var DonationLogsInstance = $("#DonRegister_Gateway_Logs_dx").dxDataGrid("instance");
            DonationLogsInstance.beginUpdate();
            if (DonLogs_ShowHorizontalBar == 0) {
                DonLogs_ShowHorizontalBar = 1;
                $("#DonLogsToggleScrollBar_dx").find("span").text("Default Data");
                $("#DonLogsToggleScrollBar_dx").width(110);
                DonationLogsInstance.option("columnHidingEnabled", false);
                DonationLogsInstance.option("allowColumnResizing", true)
                DonationLogsInstance.option("columnResizingMode", "widget")
            }
            else {
                DonLogs_ShowHorizontalBar = 0;
                $("#DonLogsToggleScrollBar_dx").find("span").text("Full Data");
                $("#DonLogsToggleScrollBar_dx").width(90);
                DonationLogsInstance.option("columnHidingEnabled", true)
                DonationLogsInstance.option("allowColumnResizing", false)
                DonationLogsInstance.option("columnResizingMode", "nextColumn")
            }
            DonationLogsInstance.endUpdate();
        }

        function OnDonLogsListPreviewClick() {
                if ("@DonationReg_ExportRight" == "False") {
                    DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
                    return;
                }
                OpenPopup("DonLogs_report_modal", "Export Option", "@Url.Action("Frm_Export_Options_Logs_dx", "DonationRegister", new { @area = "Account" })", "auto", 125, false, null);
        }
    function DonLogsListGrid_dx_OnContextMenuPreparing(e)
        {
            if (!e.items) e.items = [];
            if (e.target == "header") {
                DxGrid_HeaderContextMenu(e)
            }
            else if ((e.target == "content" && e.row && e.row.rowType == "groupFooter") || e.target == "footer") {
                DxGrid_FooterContextMenu(e);
            }
            else if (e.target == "content" && e.row && e.row.rowType == "data")
            {
                var key = e.component.getKeyByRowIndex(e.row.rowIndex);
                e.component.selectRows(key);
                var expanded = e.component.isRowExpanded(key);
                e.items = [
                    {
                        text: "List Preview",
                        icon: "fa-solid fa-file-export text-warning",
                        visible: "@DonationReg_ExportRight" == "True",
                        beginGroup: true,
                        onItemClick: function () {
                            OnDonLogsListPreviewClick();
                        }
                    },
                    {
                        text: "Refresh",
                        beginGroup: true,//redmine Bug #137374 fix
                        icon: "fa-solid fa-arrow-rotate-right text-success",
                        onItemClick: function () {
                            var dataGridInstance = $("#DonRegister_Gateway_Logs_dx").dxDataGrid("instance");
                            dataGridInstance.refresh();
                        }
                    },
                    {
                        text: "Close",
                        icon: "fa-solid fa-rectangle-xmark text-danger",
                        beginGroup: true,
                        onItemClick: function () {
                            closeDonationRegister();
                        }
                    }
                ]
        }
            else if (e.target == "content" && e.row == void 0) {
                e.items = [
                    {
                        text: "Refresh",
                        beginGroup: true,//redmine Bug #137374 fix
                        icon: "fa-solid fa-arrow-rotate-right text-success",
                        onItemClick: function () {
                            var dataGridInstance = $("#DonRegister_Gateway_Logs_dx").dxDataGrid("instance");
                            dataGridInstance.refresh();
                        }
                    },
                    {
                        text: "Close",
                        icon: "fa-solid fa-rectangle-xmark text-danger",
                        beginGroup: true,
                        onItemClick: function () {
                            closeDonationRegister();
                        }
                    }
                ]
            }
    }
    function DonLogsListGrid_dx_OnContentReady(e) {
        DxGrid_RowSelectionTobeCheckedAfterAnyAction(e)
        DxGrid_OnContentReady(e, DonLogs_ShowHorizontalBar);
    }
</script>
</div>


