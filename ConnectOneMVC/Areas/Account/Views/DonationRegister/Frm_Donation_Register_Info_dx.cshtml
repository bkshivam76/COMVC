        function DonationRegister_dx_Detail_SelectedRowData(selectedData = null) {                
                if (selectedData == null) {
                    selectedData = $("#" + DonationRegisterInfo_NestedGrid_AccessID).dxDataGrid("getSeletedRowsData");
                }
                var values = selectedData[0];
                DonationRegister_NestedRowUniqueID = values["UniqueID"];
                if (values["UniqueID"] != null) {
                    DonationRegister_FAB.SetVisible(true);
                    DonationRegisterInfo_Nested_Doc_Status = values["Doc_Status"];

                    if (DonReg_IsVouchingMode == true) {
                        DonationRegister_FAB.SetActionContext("AuditActionContext", true);
                    }
                    else {
                        if (DonationRegisterInfo_Nested_Doc_Status == "") {
                            DonationRegister_FAB.SetActionContext("AutoItemContext", true);
                        }
                        else if (DonationRegisterInfo_Nested_Doc_Status == "NO") {
                            DonationRegister_FAB.SetActionContext("EditItemContext", true);
                        }
                        else if (DonationRegisterInfo_Nested_Doc_Status == "YES") {
                            DonationRegister_FAB.SetActionContext("actionItemContext", true);
                        }
                    }
                    DonationRegisterInfo_ParamMandatory = values["Params_Mandatory"];
                    DonationRegisterInfo_FromDateLabel = values["LABEL_FROM_DATE"];
                    DonationRegisterInfo_ToDateLabel = values["LABEL_TO_DATE"];
                    DonationRegisterInfo_DescriptionLabel = values["LABEL_DESCRIPTION"];
                    DonationRegisterInfo_Doc_Category = values["Document_Category"];
                    DonationRegisterInfo_Doc_ID = values["Document_ID"];
                    DonationRegisterInfo_AtachmentID = values["ATTACH_ID"];
                    IndexAttachmentID = DonationRegisterInfo_AtachmentID;
                    DonationRegisterInfo_MasterRowRecID = values["TxnID"];
                    DonationRegisterInfo_MasterRowMID = values["TxnMID"];
                    DonationRegisterInfo_NestedRowMapID = values["MAP_ID"];
                    DonationRegisterInfo_reason = values["Reason"];
                    DonationRegisterInfo_FileName = values["ATTACH_FILE_NAME"];
                    DonationRegisterInfo_Attachment_RecStatus = values["Attachment_Action_Status"];
                    if (DonReg_IsVouchingMode == true) {
                        if (DonationRegisterInfo_FileName != null && DonationRegisterInfo_FileName.length > 0) {
                            ViewDocument(DonationRegisterInfo_AtachmentID, DonationRegisterInfo_FileName, "DonationRegister_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                        }
                        else {
                            CloseRightPane();
                            ClearRightPane();
                        }
                    }
                }
                DonationRegisterInfo_NestedRowReasonID = values["ReasonID"];
                IndexAttachmentReasonID = DonationRegisterInfo_NestedRowReasonID;
            }

