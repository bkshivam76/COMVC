        function DonRegisterListGrid_dx_SelectedRowData(selectedData = null) {
            SelectedAlreadyOfferedRows = ""; SelectedNotOfferedRows = ""; SelectedIDs = ""; SelectedStatuses = ""; SelectedAttached_Form = ""; SelectedStatusIDs = ""; SelectedAB_IDs = ""; Selected_PANs = ""; Selected_AADHARs = ""; Selected_Donation_Kinds = ""; Selected_Donation_Dates = ""
            if (selectedData == null) {

                selectedData = DonRegisterListGrid_dx.getSelectedRowsData();
            }
            if (selectedData != null && selectedData.length > 0) {

                for (var i = 0; i < selectedData.length; i++) {

                    var Values_Arr = selectedData[i];
                    var ID = Values_Arr["ID"];
                    DonRegisterID = Values_Arr["ID"];
                    var Offered = Values_Arr["Offered_for_Audit"];
                    var Status = Values_Arr["Status"];
                    DonRegister_Status = Values_Arr["Status"];
                    var Attached_Form = Values_Arr["Attached_Form"];
                    StatusID = Values_Arr["DS_STATUS_MISC_ID"];
                    var ABID = Values_Arr["TR_AB_ID_1"];
                    var Attached_PAN = Values_Arr["Attached_PAN"];
                    var Attached_Aadhar = Values_Arr["Attached_Aadhar"];
                    var PAN = Values_Arr["PAN"];
                    var Aadhar = Values_Arr["AADHAR"];
                    RecEditOn = Values_Arr["Edit_Date"];
                    DonRegister_EditDate = Values_Arr["Edit_Date"];
                    var DonationKind = Values_Arr["Kind_of_Donation"];
                    DonRegister_Kind_of_Donation = Values_Arr["Kind_of_Donation"];
                    var VoucherDate = Values_Arr["DonationDate"];
                    var FormReceivedDate = Values_Arr["Form_Received_Date"];
                    DonRegister_AddDate = Values_Arr["Add_Date"];
                    DonRegister_AddBy = Values_Arr["Add_By"];
                    DonRegister_EditBy = Values_Arr["Edit_By"];
                    DonRegister_ActionStatus = Values_Arr["Action_Status"];
                    DonRegister_ActionDate = Values_Arr["Action_Date"];
                    DonRegister_ActionBy = Values_Arr["Action_By"];
                    DonRegister_Attachments = Values_Arr["Attachment_IDs"];

                    if (Offered == "NO") {
                        if (SelectedNotOfferedRows.length > 0) { SelectedNotOfferedRows = SelectedNotOfferedRows + "," }
                        SelectedNotOfferedRows = SelectedNotOfferedRows + ID;
                    }
                    else {
                        if (SelectedAlreadyOfferedRows.length > 0) { SelectedAlreadyOfferedRows = SelectedAlreadyOfferedRows + "," }
                        SelectedAlreadyOfferedRows = SelectedAlreadyOfferedRows + ID;
                    }
                    if (SelectedIDs.length > 0) { SelectedIDs = SelectedIDs + "," }
                    SelectedIDs = SelectedIDs + ID;
                    if (SelectedStatuses.length > 0) { SelectedStatuses = SelectedStatuses + "," }
                    SelectedStatuses = SelectedStatuses + Status;
                    if (SelectedAttached_Form.length > 0) { SelectedAttached_Form = SelectedAttached_Form + "," }
                    SelectedAttached_Form = SelectedAttached_Form + Attached_Form;
                    if (SelectedStatusIDs.length > 0) { SelectedStatusIDs = SelectedStatusIDs + "," }
                    SelectedStatusIDs = SelectedStatusIDs + StatusID;
                    if (SelectedAB_IDs.length > 0) { SelectedAB_IDs = SelectedAB_IDs + "," }
                    SelectedAB_IDs = SelectedAB_IDs + ABID;
                    if (SelectedAttached_PANs.length > 0) { SelectedAttached_PANs = SelectedAttached_PANs + "," }
                    SelectedAttached_PANs = SelectedAttached_PANs + Attached_PAN;
                    if (SelectedAttached_AADHARs.length > 0) { SelectedAttached_AADHARs = SelectedAttached_AADHARs + "," }
                    SelectedAttached_AADHARs = SelectedAttached_AADHARs + Attached_Aadhar;
                    if (Selected_PANs.length > 0) { Selected_PANs = Selected_PANs + "," }
                    Selected_PANs = Selected_PANs + PAN;
                    if (Selected_Donation_Kinds.length > 0) { Selected_Donation_Kinds = Selected_Donation_Kinds + "," }
                    Selected_Donation_Kinds = Selected_Donation_Kinds + DonationKind;
                    if (Selected_Donation_Dates.length > 0) { Selected_Donation_Dates = Selected_Donation_Dates + "," }
                    Selected_Donation_Dates = Selected_Donation_Dates + JS_Json_Date_To_ddMMyyyy(VoucherDate, _format = "DD/MM/YYYY HH:mm:ss.SSS");
                    if (Selected_Form_Received_Dates.length > 0) { Selected_Form_Received_Dates = Selected_Form_Received_Dates + "," }
                    Selected_Form_Received_Dates = Selected_Form_Received_Dates + JS_Json_Date_To_ddMMyyyy(FormReceivedDate, _format = "DD/MM/YYYY HH:mm:ss.SSS");
                    if (Selected_AADHARs.length > 0) { Selected_AADHARs = Selected_AADHARs + "," }
                    Selected_AADHARs = Selected_AADHARs + Aadhar;
                    // alert((moment(VoucherDate, "DD/MM/YYYY HH:mm:ss").format("DD/MM/YYYY HH:mm:ss")));
                    // alert(JS_Json_Date_To_ddMMyyyy(VoucherDate, _format = "DD/MM/YYYY HH:mm:ss.SSS"))

                }
                DonRegister_UpdateFooterDetail_dx(DonRegisterID, DonRegister_ActionStatus, DonRegister_AddDate, DonRegister_AddBy,
                    DonRegister_ActionDate, DonRegister_ActionBy, DonRegister_EditDate, DonRegister_EditBy);
                if (DonReg_IsVouchingMode) {
                    OpenLeftPane();
                    LeftPaneContent_DonRegister_dx("DonRegisterListGrid_dx", DonRegisterID, DonReg_IsVouchingMode)
                }
            }
            else
                DonRegisterID = null;


        }
        function DonRegister_UpdateFooterDetail_dx(DonRegisterID, DonRegister_Action_Status, DonRegister_Add_Date, DonRegister_Add_By, DonRegister_Action_Date, DonRegister_Action_By, DonRegister_Edit_Date, DonRegister_Edit_By) {
            DonRegister_Action_Date = DonRegister_Action_Date != "" && DonRegister_Action_Date != null ? DonRegister_Action_Date : DonRegister_Action_Date;
            DonRegister_Edit_Date = DonRegister_Edit_Date != "" && DonRegister_Edit_Date != null ? DonRegister_Edit_Date : DonRegister_Edit_Date;
            DonRegister_Add_Date = DonRegister_Add_Date != "" && DonRegister_Add_Date != null ? DonRegister_Add_Date : DonRegister_Add_Date;
            $.ajax({
                type: 'GET',
                url: "/Account/DonationRegister/CreationDetail",
                data: {
                    Xrow: DonRegisterID, Action_Status: DonRegister_Action_Status, Add_Date: DonRegister_Add_Date,
                    Add_By: DonRegister_Add_By, Action_Date: DonRegister_Action_Date, Action_By: DonRegister_Action_By, Edit_Date: DonRegister_Edit_Date, Edit_By: DonRegister_Edit_By
                },
                cache: false,
                success: function (DonRegisterLbl_result) {
                    $('#DonRegister_Lbl_ActionOn').text(DonRegisterLbl_result.Lbl_StatusOn);
                    $('#DonRegister_Lbl_ActionBy').text(DonRegisterLbl_result.Lbl_StatusBy);
                    $('#DonRegisterLbl_Status').text(DonRegisterLbl_result.Lbl_Status);
                    $('#DonRegisterLbl_Create').text(DonRegisterLbl_result.Lbl_Create);
                    $('#DonRegisterLbl_Modify').text(DonRegisterLbl_result.Lbl_Modify);
                    if (DonRegisterLbl_result.Lbl_Status_Color != "") {
                        $('#DonRegisterLbl_Status').css('color', DonRegisterLbl_result.Lbl_Status_Color);
                    }
                    if (DonRegisterLbl_result.Pic_Status != "") {
                        $('#DonRegister_LockICON').css('class', DonRegisterLbl_result.Pic_Status);
                    }

                }
            });
        }

