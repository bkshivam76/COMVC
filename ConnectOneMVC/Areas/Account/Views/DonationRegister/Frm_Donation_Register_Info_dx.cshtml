            function Download_80GReceipt(e) {
                if (SelectedIDs == "") {
                    DevExpress.ui.dialog.alert('Please select donation for which 80G Receipt is to be Downloaded!!', 'Alert ');
                    return;
                }
                $.ajax({
                    type: 'GET',
                    url: "/Account/DonationRegister/Download80GReceipt",
                    data:
                    {
                        IDs: SelectedIDs
                    },
                    cache: false,
                    success: function (data) {
                        if (data.jsonParam.result == true) {
                            var links = data.jsonParam.flag.split('|');
                            links.forEach(function (item) {
                                var aftertrim = item.trim();
                                if (aftertrim.length > 0) {
                                    $(aftertrim)[0].click();
                                }
                            })
                        }
                        DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                    }
                });
            }
