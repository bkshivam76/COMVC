@{    var SessionGUID = Request.QueryString["SessionGUID"];}
@Html.DevExpress().GridView(settings =>
{
    int ShowHorizontalBar = ViewBag.ShowHorizontalBar == null ? 0 : (int)ViewBag.ShowHorizontalBar;
    settings.Name = "PrintGrid_" + ViewData["DonationID"];
    settings.SettingsDetail.MasterGridName = "DonRegisterListGrid";
    settings.CallbackRouteValues = new { Controller = "DonationRegister", Action = "Frm_Donation_Register_Prints_Grid", DonationID = ViewData["DonationID"], SessionGUID= SessionGUID };
    settings.Width = Unit.Percentage(100);
    settings.Settings.ShowHeaderFilterButton = true;
    settings.SettingsContextMenu.Enabled = true;
    settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
    settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
    settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;//Redmine Bug #131651 fixed

    settings.KeyFieldName = "pKey";
    settings.Columns.Add("DR_TR_ID").Visible = false;
    settings.Columns.Add("Print");
    settings.Columns.Add("Print_Date").PropertiesEdit.DisplayFormatString = "d";
    settings.Columns.Add("Location");
    if (ShowHorizontalBar == 1)
    {
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Visible;
        settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.Off;
        settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.Control;
        settings.SettingsResizing.Visualization = ResizingMode.Postponed;
    }
    else
    {
        settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.HideDataCells;
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Hidden;
        settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.Disabled;
        //settings.SettingsAdaptivity.HideDataCellsAtWindowInnerWidth = 500;
    }
    settings.ClientSideEvents.BeginCallback = "Donreg_PrintGrid_BeginCallBack";
    MyExtensions.GridViewHelper.CustomGridView(settings);
}).Bind(Model).GetHtml()

