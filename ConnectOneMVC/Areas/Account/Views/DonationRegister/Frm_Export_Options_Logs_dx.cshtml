<div class="DonationLogs_ExportOptions_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    <div>
        @(Html.DevExtreme().Button()
                .ID("DonationLogs_ExportGridDatapdf")
                .Text("Export to PDF")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                .OnClick("ExportPDF")
                .Visible(false)
                .Width(120)
    )

        @(Html.DevExtreme().Button()
                .ID("DonationLogs_ExportGridDataxls")
                .Text("Export to XLS")
                //.Icon("fa-file-excel-o")
                .OnClick("ExportXLS")
                .Visible(false)
                .Width(120)
    )
        @(Html.DevExtreme().Button()
                .ID("DonationLogs_ExportGridDataxls_dx")
                .Text("Export to XLSX")
                //.Icon("fa-file-excel-o")
                .OnClick("ExportXLS_dx")
                .Visible(true)
                .Width(120)
    )
        @(Html.DevExtreme().Button()
                .ID("DonationLogs_ExportGridDataxlsx")
                .Text("Export to XLSX")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                .OnClick("ExportXLSX")
                .Visible(false)
                .Width(120)
    )

        @(Html.DevExtreme().Button()
                .ID("DonationLogs_ExportGridDatadocx")
                .Text("Export to DOCX")
                //.Icon("export_exporttodocx_16x16office2013")
                .OnClick("ExportDOCX")
                .Visible(false)
                .Width(120)
    )

        @(Html.DevExtreme().Button()
                .ID("DonationLogs_ExportGridDatartf")
                .Text("Export to RTF")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                .OnClick("ExportRTF")
                .Visible(false)
                .Width(120)
    )

        @(Html.DevExtreme().Button()
                .ID("DonationLogs_ExportGridDatacsv")
                .Text("Export to CSV")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                .OnClick("ExportCSV")
                .Visible(false)
                .Width(120)
    )
    </div>
    <script>
        var DonationLogsInstance = $("#DonRegister_Gateway_Logs_dx").dxDataGrid("instance");
        function ExportPDF() {
            
            DonationLogsInstance.ExportTo(ASPxClientGridViewExportFormat.Pdf);
            $("#DonLogs_report_modal").dxPopup("hide");
        }
        function ExportXLS() {
            DonationLogsInstance.ExportTo(ASPxClientGridViewExportFormat.Xls);
            $("#DonLogs_report_modal").dxPopup("hide");
        }
        function ExportXLSX() {
            DonationLogsInstance.ExportTo(ASPxClientGridViewExportFormat.Xlsx);
            $("#DonLogs_report_modal").dxPopup("hide");
        }
        function ExportCSV() {
            DonationLogsInstance.ExportTo(ASPxClientGridViewExportFormat.Csv);
            $("#DonLogs_report_modal").dxPopup("hide");
        }
        function ExportDOCX() {
            DonationLogsInstance.ExportTo(ASPxClientGridViewExportFormat.Docx);
            $("#DonLogs_report_modal").dxPopup("hide");
        }
        function ExportRTF() {
            DonationLogsInstance.ExportTo(ASPxClientGridViewExportFormat.Rtf);
            $("#DonLogs_report_modal").dxPopup("hide");
        }
        function ExportXLS_dx() {
            const workbook = new ExcelJS.Workbook();
            const worksheet = workbook.addWorksheet('Sheet');

            DevExpress.excelExporter.exportDataGrid({
                worksheet: worksheet,
                component: $("#DonRegister_Gateway_Logs_dx").dxDataGrid("instance"),
                autoFilterEnabled: true,
            }).then(function (exportRange) {
                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: 'application/octet-stream' }), 'DonationLogsInstance_dx.xlsx');
                });
            });
            $("#DonLogs_report_modal").dxPopup("hide");
        }

    </script>
</div>