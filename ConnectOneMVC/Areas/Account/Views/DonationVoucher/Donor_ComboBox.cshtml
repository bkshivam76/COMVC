@Html.DevExpress().ComboBox(settings => {
    settings.Name = "Donation_Donor_List";
    settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
    settings.SelectedIndex = -1;
    settings.ControlStyle.CssClass = "dx-texteditor-input";

    settings.Properties.DropDownWidth = 550;
    settings.Properties.DropDownStyle = DropDownStyle.DropDown;
    settings.CallbackRouteValues = new { Controller = "DonationVoucher", Action = "Donor_ComboBox" };
    settings.Properties.CallbackPageSize = 50;
    settings.Properties.IncrementalFilteringMode = IncrementalFilteringMode.Contains;

    settings.Properties.TextFormatString = "{0}";
    settings.Properties.ValueField = "C_ID";
    settings.Properties.ValueType = typeof(string);
    settings.Properties.TextField = "C_NAME";
    

    settings.Properties.NullTextDisplayMode = NullTextDisplayMode.UnfocusedAndFocused;
    settings.Properties.NullDisplayText = "Select Donor";
    settings.Properties.NullText = "Select Donor";

    settings.Properties.Columns.Add("C_NAME","Name",300);
    settings.Properties.Columns.Add("C_PAN_NO", "PANNo", 120);
    settings.Properties.Columns.Add("CI_NAME", "City", 100);
    settings.Properties.Columns.Add("CO_NAME", "Country", 80);
    settings.Properties.Columns.Add("REC_EDIT_ON", "REC_EDIT_ON",0);
    settings.Properties.Columns.Add("C_R_ADD1", "Address1", 0);
    settings.Properties.Columns.Add("C_R_ADD2", "Address2", 0);
    settings.Properties.Columns.Add("C_R_ADD3", "Address3", 0);
    settings.Properties.Columns.Add("C_R_ADD4", "C_R_ADD4", 0);
    settings.Properties.Columns.Add("C_R_PINCODE", "Pincode", 0);
    settings.Properties.Columns.Add("ST_NAME", "State", 0);
    settings.Properties.Columns.Add("DI_NAME", "District", 0);
    settings.Properties.Columns.Add("C_ID", "C_ID", 0);

    settings.ClientEnabled = true;
    settings.Properties.ClientSideEvents.SelectedIndexChanged = "DonorComboBoxValueChange";
    settings.Properties.ClientSideEvents.Init = "DonorComboBoxInit";
    settings.Properties.ClientSideEvents.KeyDown = "DonorComboBoxkeydown";
    settings.Properties.ClientSideEvents.DropDown = "Donation_Donor_dropdown_open";
    settings.Properties.ClientSideEvents.CloseUp = "Donation_Donor_dropdown_close";

}).BindList(Model).GetHtml()
