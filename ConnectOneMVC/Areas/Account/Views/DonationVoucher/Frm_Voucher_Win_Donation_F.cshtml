            if (TotalCount < 0) //dd has not been loaded so total count will return -1 in this case
            {
                var ds = $("#GLookUp_BankList_Donation_F").dxDropDownBox("getDataSource");
                var store = ds.store();
                TotalCount = await store.totalCount();
            }
            Cnt_BankAccount_F = TotalCount;
            if (TotalCount == 1) {
                $("#GLookUp_BankList_Donation_F").find('input').css('color', '#696969');//Setting DimGray colour
                $("#BE_Bank_Acc_No_Donation_F").find('input').css('color', '#696969');//Setting DimGray colour
                if (Tag_Don_F == "_New" || Tag_Don_F == "_New_From_Selection")
                {
                    await GLookUp_BankList_DG_D_F.selectRowsByIndexes(0);
                    BankList_F_Enable = false;
                    Control_SetReadOnly("GLookUp_BankList_Donation_F", "dxDropDownBox", (BankList_F_Enable == true && BankList_F_ReadOnly == false) ? false : true);
                }
            }
            else {
                if (Tag_Don_F == "_New" || Tag_Don_F == "_New_From_Selection") {
                    BankList_F_ReadOnly = false;
                    Control_SetReadOnly("GLookUp_BankList_Donation_F", "dxDropDownBox", (BankList_F_Enable == true && BankList_F_ReadOnly == false) ? false : true);
                }
            }
        }
        async function LookUp_GetPurposeList_F(FirstCall = false) {
            if (FirstCall == false) {
                PurList_DDRefresh_D_F = true;
                await GLookUp_PurList_DG_D_F.refresh();
