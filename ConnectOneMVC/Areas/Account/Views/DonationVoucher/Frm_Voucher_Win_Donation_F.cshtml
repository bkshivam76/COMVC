        async function LookUp_GetItemList_F(FirstCall = false) {
            if (FirstCall == false) {
                ItemList_DDRefresh_D_F = true;
                await GLookUp_ItemList_DG_D_F.refresh();
                ItemList_DDRefresh_D_F = false;
            }
            var TotalCount = GLookUp_ItemList_DG_D_F.totalCount();
            if (TotalCount < 0) //dd has not been loaded so total count will return -1 in this case
            {
                var ds = $("#GLookUp_ItemList_Donation_F").dxDropDownBox("getDataSource");
                var store = ds.store();
                TotalCount = await store.totalCount();
            }
            if (TotalCount == 1) {
                $("#GLookUp_ItemList_Donation_F").find('input').css('color', '#000080');//Setting Navy blue colour
                if (Tag_Don_F == "_New" || Tag_Don_F == "_New_From_Selection") {
                    await GLookUp_ItemList_DG_D_F.selectRowsByIndexes(0);
                    ItemList_F_Enable = false;
                    Control_SetReadOnly("GLookUp_ItemList_Donation_F", "dxDropDownBox", (ItemList_F_Enable == true && ItemList_F_ReadOnly == false) ? false : true);
                }
            }
            else {
                if (Tag_Don_F == "_New" || Tag_Don_F == "_New_From_Selection") {
                    ItemList_F_ReadOnly = false;
                    Control_SetReadOnly("GLookUp_ItemList_Donation_F", "dxDropDownBox", (ItemList_F_Enable == true && ItemList_F_ReadOnly == false) ? false : true);
                }
            }
        }
        async function LookUp_GetPartyList_F(FirstCall = false)
        {
            $("#GLookUp_PartyList_Donation_F").dxDropDownBox("reset");
