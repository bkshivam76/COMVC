<div class="DonationForeign_ClearReferences">
    @model ConnectOneMVC.Areas.Account.Models.ForeignDonationV
    @using DevExtreme.AspNet.Mvc;

    @{
        Html.EnableClientValidation();
        Html.EnableUnobtrusiveJavaScript();
        Html.AntiForgeryToken();
        bool Isvisible = (Model.ActionMethod == "_Delete" || Model.ActionMethod == "_View") ? true : false;

        bool DonationVou_AddFacilityAddress = (bool)ViewData["DonationVou_AddFacilityAddress"];
        bool DonationVou_ListFacilityAddress = (bool)ViewData["DonationVou_ListFacilityAddress"];

    }

    <style>


        #But_DonAdd_F .dx-icon {
            width: 45px;
            height: 35px;
            line-height: normal;
            left: 45px;
            top: -10px;
            bottom: 0;
        }

        #But_DonAdd_F .dx-button-content {
            height: inherit;
            padding-top: 45px;
            padding-bottom: 5px
        }

        #But_DonManage_F .dx-icon {
            width: 45px;
            height: 35px;
            line-height: normal;
            left: 45px;
            top: -10px;
            bottom: 0;
        }

        #But_DonManage_F .dx-button-content {
            height: inherit;
            padding-top: 45px;
            padding-bottom: 5px
        }
        /*FCRA Related Style*/
        #ListSpecialVoucherRef_DnF .dx-list-item-content {
            padding: 4.5px;
        }
        .ListOneRow .dx-scrollable {
            overflow-y: hidden
        }
    </style>
    <div id="Frm_Voucher_Donation_F_popup" class="col-md-12" style="padding-right:0; padding-left:0;">

        @using (Ajax.BeginForm("Frm_Voucher_Win_Donation_Window_F", "DonationVoucher",

        new AjaxOptions
        {
            HttpMethod = "POST",
            UpdateTargetId = "Frm_Voucher_Donation_F_popup",
            InsertionMode = InsertionMode.InsertAfter,
            OnBegin = "AjaxBeginFormPost",
            OnSuccess = "AjaxSuccessDonationVoucher_F"
        },
        new
        {
            id = "donation_F_validationForm",
            @class = "edit_form form-horizontal"
        }))

        {
            @Html.HiddenFor(x => x.ActionMethod)
            @Html.HiddenFor(x => x.iVoucher_Type_F)
            @Html.HiddenFor(x => x.iLed_ID_F)
            @Html.HiddenFor(x => x.iTrans_Type_F)
            @Html.HiddenFor(x => x.TitleX_F)
            @Html.HiddenFor(x => x.Text_F)
            @Html.HiddenFor(x => x.PartyList_REC_EDIT_ON_F)
            @Html.HiddenFor(x => x.BankList_REC_EDIT_ON_F)
            @Html.HiddenFor(x => x.iSpecific_ItemID_F)
            @Html.HiddenFor(x => x.xID_F)
            @Html.HiddenFor(x => x.Info_LastEditedOn_F)
            @Html.HiddenFor(x => x.LastEditedOn_F)
            @Html.HiddenFor(x => x.DnF_SplVchrReferenceSelected)
            @Html.HiddenFor(x => x.splVchrRefsCount_DnF)

            using (Html.DevExtreme().ValidationGroup("ForeignDonationValidationGroup"))
            {
                <div class="container-fluid">
                    <div class="full-width-header-bg">
                        <div class="row">
                            <div class="col-sm-8 pll">
                                <h3 class="popuphead">
                                    <i class="far fa-edit"></i> Foreign Donation
                                </h3>
                            </div>
                            <div class="col-sm-4 prl">
                                <h5 class="mand-txt-align">
                                    <i class="fas fa-info-circle"></i> Red Fields are mandatory
                                </h5>
                            </div>
                            @Html.ValidationSummary(true, "", new { @class = "text-red" })
                        </div>
                    </div><!--[Header]-->
                    <div class="row">
                        <div class="col-sm-7">
                            <div class="form-field">
                                <div class="row">
                                    <div class="col-sm-4 pll">
                                        @Html.Label("Item Name:", htmlAttributes: new { id = "itemtypelabel_df", @class = "control-label text-red" })
                                    </div>
                                    <div class="col-sm-8 prm">
                                        @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_ItemList_Donation_F").Name("GLookUp_ItemList_Donation_F").ValueExpr("ITEM_ID").DisplayExpr("ITEM_NAME")
                                          .DataSource(d => d.Mvc().Controller("DonationVoucher").LoadAction("LookUp_GetItemList_ForeignDonation_F").Key("ITEM_ID").LoadParams(new { DDRefresh = new JS("function (){ return ItemList_DDRefresh_D_F;}") }).LoadMode(DataSourceLoadMode.Raw).CacheRawData(true))
                                          .Placeholder("Select Item...").ReadOnly(true).FocusStateEnabled(false).ShowClearButton(false)
                                          .OnValueChanged("GLookUp_ItemList_EditValueChanged_F").ContentTemplate(@<text> @Html.Partial("LookUp_GetItemList_ForeignDonation_F") </text>))
                                    </div>
                                </div>
                            </div>
                        </div><!--[Item Name]-->
                        <div class="col-sm-5">
                            <div class="form-field">
                                <div class="row">
                                    <div class="col-sm-4 pll">
                                        @Html.Label("Voucher Date:", htmlAttributes: new { id = "voucherdatelabel_df", @class = "control-label text-red" })
                                    </div>
                                    <div class="col-sm-8 prm">
                                        @(Html.DevExtreme().DateBox().CustomDateBox().ID("Txt_V_Date_Donation_F").Name("Txt_V_Date_Donation_F").Value(Model.Txt_V_Date_Donation_F))
                                        @Html.ValidationMessageFor(model => model.Txt_V_Date_Donation_F, "", new { @class = "text-red" })

                                    </div>
                                </div>
                            </div>
                        </div><!--[Voucher Date]-->
                    </div><!--[Row 1]-->
                    <div class="row">
                        <div class="col-sm-7">
                            <div class="form-field">
                                <div class="row">
                                    <div class="col-sm-4 pll">
                                        @Html.Label("Head:", htmlAttributes: new { @class = "control-label disabletxt" })
                                    </div>
                                    <div class="col-sm-8 prm ">

                                        @(Html.DevExtreme().TextBox().CustomTextBox().ID("BE_Item_Head_Donation_F").Name("BE_Item_Head_Donation_F").ReadOnly(true).FocusStateEnabled(false))
                                    </div>
                                </div>
                            </div>
                        </div><!--[Head]-->
                        <div class="col-sm-5">
                            <div class="form-field">
                                <div class="row">
                                    <div class="col-sm-4 pll">
                                        @Html.Label("Voucher No:", htmlAttributes: new { @class = "control-label disabletxt" })
                                    </div>
                                    <div class="col-sm-8 prm">

                                        @(Html.DevExtreme().TextBox().CustomTextBox().ID("Txt_V_NO_Donation_F").Name("Txt_V_NO_Donation_F").Value(Model.Txt_V_NO_Donation_F).ReadOnly(true).FocusStateEnabled(false))
                                    </div>
                                </div>
                            </div><!--[Voucher No]-->
                            @if (Request.Browser.IsMobileDevice)
                            {
                                <div class="form-field">
                                    <div class="row">
                                        <div class="col-sm-4 pll">
                                            @Html.Label("Receipt No:", htmlAttributes: new { @class = "control-label  disabletxt" })
                                        </div>
                                        <div class="col-sm-8 prm">

                                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("BE_Receipt_No_Donation_F").Name("BE_Receipt_No_Donation_F").Value(Model.BE_Receipt_No_Donation_F).ReadOnly(true).FocusStateEnabled(false))

                                        </div>


                                    </div>
                                </div>
                            }
                        </div>
                    </div><!--[Row 2]-->
                    <div class="row">
                        <div class="col-sm-7">
                            <div class="form-field">
                                <fieldset class="default-fieldset">
                                    <legend class="custom-legend mlm" id="donordetaillabel_F">Donor Detail:</legend>
                                    <div class="row">
                                        <div class="col-sm-4 pll">
                                            @Html.Label("Donor Name:", htmlAttributes: new { id = "voucherdonorlabel_F", @class = "control-label text-red" })
                                        </div>
                                        <div class="col-sm-8 prm" data-toggle="tooltip" data-placement="bottom" title="Select Donor Name">
                                            @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_PartyList_Donation_F").Name("GLookUp_PartyList_Donation_F").ValueExpr("C_ID").DisplayExpr("C_NAME").Placeholder("Select Donor...").ReadOnly(true).FocusStateEnabled(false)
                                  .DataSource(d => d.Mvc().Controller("DonationVoucher").LoadAction("LookUp_GetPartyList_ForeignDonation_F").Key("C_ID").LoadParams(new { DDRefresh = new JS("function (){ return PartyList_DDRefresh_D_F;}") }).LoadMode(DataSourceLoadMode.Raw).CacheRawData(true))
                                  .OnValueChanged("GLookUp_PartyList_EditValueChanged_F").ContentTemplate(@<text> @Html.Partial("LookUp_GetPartyList_ForeignDonation_F")</text>) )

                                            @Html.ValidationMessageFor(model => model.GLookUp_PartyList_Donation_F, "", new { @class = "text-red" })

                                        </div>
                                    </div><!--[Donor Name]-->
                                    <div class="row">
                                        <div class="col-sm-4 pll">
                                            @Html.Label("Address:", htmlAttributes: new { id = "donoraddress_F", @class = "control-label text-red" })
                                            <div class="row ptl ptm">
                                                <div class="col-md-12 donr pb4">
                                                    @(Html.DevExtreme().Button().ID("But_DonAdd_F").Text("Add Donor").Height(111).Width(130).OnClick(@<text> function() { Add_Donar_F(); }</text>).Icon(Url.Content("../../../../Icons/add user.png")).Disabled(Isvisible).FocusStateEnabled(false))
                                                </div>
                                                <div class="col-md-12 prm rgt-box-btn">
                                                    @(Html.DevExtreme().Button().ID("But_DonManage_F").Text("Manage Donor").Height(111).Width(130).OnClick(@<text> function() { Manage_Donar_F() } </text>).Icon(Url.Content("../../../../Icons/manage user.png")).Disabled(Isvisible).FocusStateEnabled(false))
                                                </div>
                                            </div>
                                        </div>  <!--[Address Label/Add Donor/Manage Donor]-->
                                        <div class="col-sm-8 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Add1_Donation_F").ID("BE_Add1_Donation_F").ReadOnly(true).FocusStateEnabled(false))
                                            @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Add2_Donation_F").ID("BE_Add2_Donation_F").ReadOnly(true).FocusStateEnabled(false))
                                            @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Add3_Donation_F").ID("BE_Add3_Donation_F").ReadOnly(true).FocusStateEnabled(false))
                                            @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Add4_Donation_F").ID("BE_Add4_Donation_F").ReadOnly(true).FocusStateEnabled(false))
                                            <div class="row ptl pbs">
                                                <div class="col-sm-4 brd-div">
                                                    <label id="donorcity_F" class="control-label add-txt-blue bot-marg" for="BE_City_Donation_F">City:</label>
                                                </div>
                                                <div class="col-sm-8 ">
                                                    @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_City_Donation_F").ID("BE_City_Donation_F").ReadOnly(true).FocusStateEnabled(false).Height("21px"))
                                                </div>
                                            </div><!--[City]-->
                                            <div class="row pbs">
                                                <div class="col-sm-4 brd-div">
                                                    <label id="donorpincode_F" class="control-label add-txt-blue bot-marg" for="BE_Pincode_Donation_F">PinCode:</label>
                                                </div>
                                                <div class="col-sm-8">
                                                    @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Pincode_Donation_F").ID("BE_Pincode_Donation_F").ReadOnly(true).FocusStateEnabled(false).Height("21px"))
                                                </div>
                                            </div><!--[PinCode]-->
                                            <div class="row pbs">
                                                <div class="col-sm-4 brd-div">
                                                    <label id="donordistrict_F" class="control-label add-txt-blue bot-marg" for="BE_District_Donation_F">District:</label>
                                                </div>
                                                <div class="col-sm-8">
                                                    @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_District_Donation_F").ID("BE_District_Donation_F").ReadOnly(true).FocusStateEnabled(false).Height("22px"))
                                                </div>
                                            </div><!--[District]-->
                                            <div class="row pbs">
                                                <div class="col-sm-4 brd-div">
                                                    <label id="donorstate_F" class="control-label add-txt-blue bot-marg" for="BE_State_Donation_F">State:</label>
                                                </div>
                                                <div class="col-sm-8">
                                                    @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_State_Donation_F").ID("BE_State_Donation_F").ReadOnly(true).FocusStateEnabled(false).Height("22px"))

                                                </div>
                                            </div><!--[State]-->
                                            <div class="row pbs">
                                                <div class="col-sm-4 brd-div ">
                                                    <label id="donorcountry_F" class="control-label text-red bot-marg" for="BE_Country_Donation_F">Country:</label>
                                                </div>
                                                <div class="col-sm-8">
                                                    @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Country_Donation_F").ID("BE_Country_Donation_F").ReadOnly(true).FocusStateEnabled(false).Height("22px"))

                                                </div>
                                            </div><!--[Country]-->
                                            <div class="row ptm ptl pbtm3">
                                                <div class="col-sm-4 brd-div">
                                                    <label id="donortaxationno_F" class="control-label  bot-marg" for="BE_TAXATION_No_Donation_F">Taxation No.:</label>
                                                </div>
                                                <div class="col-sm-8">
                                                    @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_TAXATION_No_Donation_F").ID("BE_TAXATION_No_Donation_F").ReadOnly(true).FocusStateEnabled(false).Height("22px"))
                                                </div>
                                            </div><!--[PAN No/Taxation No.]-->
                                            <div class="row pbs">
                                                <div class="col-sm-4 brd-div">
                                                    <label id="donorPassport_F" class="control-label  bot-marg" for="BE_Passport_No_Donation_F">Passport:</label>
                                                </div>
                                                <div class="col-sm-8">
                                                    @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Passport_No_Donation_F").ID("BE_Passport_No_Donation_F").ReadOnly(true).FocusStateEnabled(false).Height("22px"))
                                                </div>
                                            </div><!--[Passport]-->
                                            <div class="row pbs">
                                                <div class="col-sm-4 brd-div">
                                                    <label id="donorCategory_F" class="control-label text-red bot-marg" for="GLookUp_CatList_Donation_F">Category:</label>
                                                </div>
                                                <div class="col-sm-8">
                                                    @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_CatList_Donation_F").Name("GLookUp_CatList_Donation_F").ValueExpr("CAT_ID").DisplayExpr("CAT_NAME").ReadOnly(true).FocusStateEnabled(false)
                                                    .DataSource(d => d.Mvc().Controller("DonationVoucher").LoadAction("LookUp_GetCatList_ForeignDonation_F").Key("CAT_ID").LoadParams(new { DDRefresh = new JS("function (){ return CatList_DDRefresh_D_F;}") }).LoadMode(DataSourceLoadMode.Raw).CacheRawData(true))
                                                    .Placeholder("Select Category...").OnValueChanged("GLookUp_catList_EditValueChanged_F").ContentTemplate(@<text> @Html.Partial("LookUp_GetCatList_ForeignDonation_F")</text>))
                                                </div>
                                            </div><!--[Category]-->
                                        </div>
                                    </div>
                                </fieldset>
                            </div><!--[Donor Detail Block]-->
                        </div><!--[Row 3-Left]-->
                        <div class="col-sm-5">
                            @if (Request.Browser.IsMobileDevice == false)
                            {
                                <div class="form-field">
                                    <div class="row">
                                        <div class="col-sm-4 pll">
                                            @Html.Label("Receipt No:", htmlAttributes: new { @class = "control-label  disabletxt" })
                                        </div>
                                        <div class="col-sm-8 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("BE_Receipt_No_Donation_F").Name("BE_Receipt_No_Donation_F").Value(Model.BE_Receipt_No_Donation_F).ReadOnly(true).FocusStateEnabled(false))
                                        </div>
                                    </div>
                                </div><!--[Receipt No]-->
                            }
                            <div class="form-field">
                                <div class="row">
                                    <div class="col-sm-4 pll">
                                        @Html.Label("Currency Name:", htmlAttributes: new { @class = "control-label text-red", @id = "lbl_currency_f" })
                                    </div>
                                    <div class="col-sm-8 prm">
                                        @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_CurList_Donation_F").Name("GLookUp_CurList_Donation_F").ValueExpr("CUR_ID").DisplayExpr("CUR_NAME").ReadOnly(true).FocusStateEnabled(false)
                                        .DataSource(d => d.Mvc().Controller("DonationVoucher").LoadAction("LookUp_GetCurList_ForeignDonation_F").Key("CUR_ID").LoadParams(new { DDRefresh = new JS("function (){ return CurList_DDRefresh_D_F;}") }).LoadMode(DataSourceLoadMode.Raw).CacheRawData(true))
                                        .Placeholder("Select Currency...").OnValueChanged("GLookUp_CurList_EditValueChanged_F").ContentTemplate(@<text> @Html.Partial("LookUp_GetCurList_ForeignDonation_F")</text>))
                                    </div>
                                </div>
                            </div><!--[Currency Name]-->
                            <div class="form-field">
                                <div class="row">
                                    <div class="col-sm-4 pll">
                                        @Html.Label("Amt Recd In:", htmlAttributes: new { id = "lbl_AmtRecd_F", @class = "control-label text-red" })
                                    </div>
                                    <div class="col-sm-8 prm" data-toggle="tooltip" data-placement="bottom" title="Select Payment Mode">

                                        @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("Cmd_Mode_Donation_F").Name("Cmd_Mode_Donation_F").DataSource(new[] { "CASH", "CHEQUE", "DD", "CBS", "RTGS", "NEFT", "REMITTANCE" }).ShowClearButton(false).OnValueChanged("Cmd_Mode_SelectedIndexChanged_F"))

                                    </div>
                                </div>
                            </div><!--[Mode]-->
                            <div class="form-field" style="padding-bottom:14px;padding-top:14px">
                                <fieldset class="default-fieldset" id="Ref_Item_Donation_F">
                                    <legend class="custom-legend mlm disabletxt" id="lbl_Ref_Title_F"> Reference Detail:</legend>
                                    <div class="row">
                                        <div class="col-sm-4 pll">
                                            <label id="lbl_Ref_Bank_F" class="control-label " for="GLookUp_RefBankList_Donation_F">Remitting Bank:</label>
                                        </div>
                                        <div class="col-sm-8 Bank prm" data-toggle="tooltip" data-placement="bottom" title="Select Remitting Bank Name">

                                            @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_RefBankList_Donation_F").Name("GLookUp_RefBankList_Donation_F").ValueExpr("BI_ID").DisplayExpr("BI_BANK_NAME")
                                            .DataSource(d => d.Mvc().Controller("DonationVoucher").LoadAction("LookUp_GetRefBankList_ForeignDonation_F").Key("BI_ID").LoadParams(new { DDRefresh = new JS("function (){ return RefBankList_DDRefresh_D_F;}") }).LoadMode(DataSourceLoadMode.Raw).CacheRawData(true))
                                            .Placeholder("Select Bank...").OnValueChanged("GLookUp_RefBankList_EditValueChanged_F").ContentTemplate(@<text> @Html.Partial("LookUp_GetRefBankList_ForeignDonation_F") </text>).ReadOnly(true).FocusStateEnabled(false))


                                        </div>
                                    </div><!--[Bank Name]-->
                                    <div class="row">
                                        <div class="col-sm-4 pll">
                                            <label id="lbl_Ref_Branch_F" class="control-label  mrg-top-sm" for="Txt_Ref_Branch_Donation_F">Branch Name:</label>
                                        </div>
                                        <div class="col-sm-8 prm">

                                            @(Html.DevExtreme().TextBox().CustomTextBox(true,true).Name("Txt_Ref_Branch_Donation_F").ID("Txt_Ref_Branch_Donation_F").Value(Model.Txt_Ref_Branch_Donation_F).Placeholder("Type Branch Name...").OnValueChanged("Txt_Ref_Branch_Donation_F_ValueChange").MaxLength(25))


                                        </div>
                                    </div><!--[Branch Name]-->
                                    <div class="row">
                                        <div class="col-sm-4 pll">
                                            <label id="lbl_Ref_No_F" class="control-label mrg-top-sm" for="Txt_Ref_No_Donation_F">Ref.No.:</label>
                                        </div>
                                        <div class="col-sm-8 prm">

                                            @(Html.DevExtreme().TextBox().CustomTextBox(true,true).Name("Txt_Ref_No_Donation_F").ID("Txt_Ref_No_Donation_F").Value(Model.Txt_Ref_No_Donation_F).OnValueChanged("Txt_Ref_No_Donation_F_ValueChange").MaxLength(25))


                                        </div>
                                    </div><!--[Ref.No]-->
                                    <div class="row">
                                        <div class="col-sm-4 pll">
                                            <label id="lbl_Ref_Date_F" class="control-label  mrg-top-sm" for="Name">Date:</label>
                                        </div>
                                        <div class="col-sm-8 prm">

                                            @(Html.DevExtreme().DateBox().CustomDateBox().ID("Txt_Ref_Date_Donation_F").Name("Txt_Ref_Date_Donation_F").Min(new DateTime(1900,1,1))
                                                                                                                                      .Value(Model.Txt_Ref_Date_Donation_F))

                                        </div>
                                    </div><!--[Date]-->
                                    <div class="row">
                                        <div class="col-sm-4 pll">
                                            <label id="lbl_Ref_Cdate_F" class="control-label  mrg-top-sm" for="Name">Clearing Date:</label>
                                        </div>
                                        <div class="col-sm-8 prm">
                                            @(Html.DevExtreme().DateBox().CustomDateBox().ID("Txt_Ref_CDate_Donation_F").Name("Txt_Ref_CDate_Donation_F").Min(new DateTime(1900,01,01)))
                                        </div>
                                    </div><!--[Clearing Date]-->
                                </fieldset>
                            </div><!--[Txt_Reference_Donation Detail Block]-->
                            <div class="form-field" style="padding-bottom:14px;padding-top:15px">
                                <fieldset class="default-fieldset" id="Correspondent_Bank_Item_Donation_F">
                                    <legend class="custom-legend mlm disabletxt" id="lbl_Corres_Title_F">Correspondent Bank Detail:</legend>
                                    <div class="row">
                                        <div class="col-sm-4 pll">
                                            <label id="lbl_Corres_Bank_F" class="control-label  mrg-top-sm " for="Txt_Co_Bank_Donation_F">Bank Name:</label>
                                        </div>
                                        <div class="col-sm-8 prm" data-toggle="tooltip" data-placement="bottom" title="Select Correspondent Bank Name">
                                            @(Html.DevExtreme().TextBox().CustomTextBox(true,true).Name("Txt_Co_Bank_Donation_F").ID("Txt_Co_Bank_Donation_F").MaxLength(25).Placeholder("Type Bank Name...").Value(Model.Txt_Co_Bank_Donation_F).OnValueChanged("Txt_Co_Bank_Donation_F_ValueChange"))
                                        </div>
                                    </div><!--[Bank Name]-->
                                    <div class="row">
                                        <div class="col-sm-4 pll">
                                            <label id="lbl_Corres_Branch_F" class="control-label mrg-top-sm" for="Txt_Co_Branch_Donation_F">Branch Name:</label>
                                        </div>
                                        <div class="col-sm-8 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox(true,true).Name("Txt_Co_Branch_Donation_F").ID("Txt_Co_Branch_Donation_F").MaxLength(25).Placeholder("Type Branch Name...").Value(Model.Txt_Co_Branch_Donation_F).OnValueChanged("Txt_Co_Branch_Donation_F_ValueChange"))
                                        </div>
                                    </div><!--[Branch No]-->
                                </fieldset>
                            </div><!--[Correspondent Bank Detail Block]-->

                        </div><!--[Row 3-Right]-->
                    </div><!--[Row 3]-->
                    <div class="row">
                        <div class="col-sm-7">
                            <div class="form-field">
                                <fieldset class="default-fieldset" id="Deposit_Bank_Item_Donation">
                                    <legend class="custom-legend mlm" id="lbl_Bank_Title_DF">Deposited Bank Detail:</legend>
                                    <div class="row">
                                        <div class="col-sm-3 pll">
                                            <label id="lbl_DepositedBank_Name" class="control-label text-red mrg-top-sm " for="GLookUp_BankList_Donation_F">Name:</label>
                                        </div>
                                        <div class="col-sm-9 prm " data-toggle="tooltip" data-placement="bottom" title="Select Bank Name">

                                            @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_BankList_Donation_F").Name("GLookUp_BankList_Donation_F").ValueExpr("BA_ID").DisplayExpr("BANK_NAME")
