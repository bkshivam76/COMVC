                            <div class="col-sm-6 ">
                                <div class="row">
                                    <div class="form-field">
                                        <div class="container-fluid">
                                            <div class="col-sm-8 pll">
                                                <label id="lbl_Slip_Txn_No" class="control-label" for="Name">Slip Txn No.:</label>
                                            </div>
                                            <div class="col-sm-4 prm plm">

                                                @(Html.DevExtreme().NumberBox().CustomNumberBox().Name("Txt_Slip_Count_Donation").ID("Txt_Slip_Count_Donation").Value(Model.Txt_Slip_Count_Donation).ReadOnly(true).FocusStateEnabled(false).Disabled(Isvisible))

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div><!--[Slip Txn No]-->
                            <div class="col-sm-6 ">
                                <div class="row">
                                    <div class="form-field">
                                        <div class="container-fluid">
                                            <div class="col-sm-6 pll">
