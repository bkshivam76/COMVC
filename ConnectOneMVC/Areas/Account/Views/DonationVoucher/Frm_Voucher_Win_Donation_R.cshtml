<div class="DonationRegular_ClearReferences">
    @using DevExtreme.AspNet.Mvc;

    @model ConnectOneMVC.Areas.Account.Models.DonationVoucher
    @{
        Html.EnableClientValidation();
        Html.EnableUnobtrusiveJavaScript();
        Html.AntiForgeryToken();
        bool Isvisible = (Model.TempActionMethod == "_Delete" || Model.TempActionMethod == "_View") ? true : false;

        bool DonationVou_AddFacilityAddress = (bool)ViewData["DonationVou_AddFacilityAddress"];
        bool DonationVou_ListFacilityAddress = (bool)ViewData["DonationVou_ListFacilityAddress"];
    }
    <style>
        #DonAdd .dx-button-text, #DonManage .dx-button-text {
            color: black;
        }

        #DonorComboView {
            border: 1px solid #89b9eb;
        }

        div#DonAdd, #DonManage {
            border: 1px solid #95c3ef;
            margin-bottom: 9px;
            max-width: 125px;
        }

            #DonAdd .dx-icon, #DonManage .dx-icon {
                width: 40px;
                height: 40px;
                line-height: normal;
                left: 45px;
                top: -17px;
                bottom: 0;
            }

            #DonAdd .dx-button-content, #DonManage .dx-button-content {
                height: inherit;
                padding-top: 45px;
                padding-left: 0
            }

        /*FCRA Related Style*/
        #ListSpecialVoucherRef_DnR .dx-list-item-content {
            padding: 4.5px;
        }

        .ListOneRow .dx-scrollable {
            overflow-y: hidden
        }
    </style>

    <div id="Frm_Voucher_Donation_popup" class="col-md-12" style="padding-right:0; padding-left:0;">

        @using (Ajax.BeginForm("Frm_Voucher_Win_Donation_R", "DonationVoucher",

                                new AjaxOptions
                                {
                                    HttpMethod = "POST",
                                    UpdateTargetId = "Frm_Voucher_Donation_popup",
                                    InsertionMode = InsertionMode.InsertAfter,
                                    OnBegin = "AjaxBeginFormPost",
                                    OnSuccess = "AjaxSuccessDonationVoucher"
                                },
                                new
                                {
                                    id = "donationvalidationForm",
                                    @class = "edit_form"
                                }
                                ))

        {
            @Html.HiddenFor(x => x.ActionMethod)
            @Html.HiddenFor(x => x.TempActionMethod)
            @Html.HiddenFor(x => x.Donor_RecEditOn)
            @Html.HiddenFor(x => x.DepositBank_RecEditOn)
            @Html.HiddenFor(x => x.iTrans_Type)
            @Html.HiddenFor(x => x.iLed_ID)
            @Html.HiddenFor(x => x.xID)
            @Html.HiddenFor(x => x.LastEditedOn)
            @Html.HiddenFor(x => x.Info_LastEditedOn)
            @Html.HiddenFor(x => x.iVoucher_Type)
            @Html.HiddenFor(x => x.iSpecific_ItemID)
            @Html.HiddenFor(x => x.TitleX)
            @Html.HiddenFor(x => x.Text)
            @Html.HiddenFor(x => x.SelectedBankID)
            @Html.HiddenFor(x => x.SelectedDepositSlipNo)
            @Html.HiddenFor(x => x.SelectedRefBankID)
            @Html.HiddenFor(x => x.DnR_SplVchrReferenceSelected)
            @Html.HiddenFor(x => x.splVchrRefsCount_DnR)

            @(Html.DevExtreme().Popup().CustomPopup().ID("Donar_Mng_or_Add").ElementAttr("class", "popup")//.Width(1260).Height(521)
                                                                                    .ShowTitle(true).Title("Information").Visible(false).DragEnabled(true).ContentTemplate(@<text>
                                                                                        <div id="Donar_Mng_or_Add_result"> </div> </text>))

            using (Html.DevExtreme().ValidationGroup("donationvoucher"))
            {

                <div class="full-width-header-bg">
                    <div class="row">
                        <div class="col-sm-8 pll">
                            <h3 class="popuphead">
                                <i class="far fa-money-bill-alt money-icon"></i> Donation
                            </h3>
                        </div>
                        <div class="col-sm-4 prl">
                            <h5 class="mand-txt-align">
                                <i class="fas fa-info-circle"></i> Red Fields are mandatory
                            </h5>
                        </div>
                        @Html.ValidationSummary(true, "", new { @class = "text-red" })
                    </div>
                </div><!--[Header]-->
                <div class="row">
                    <div class="col-sm-7">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="col-sm-4 pll">
                                    @Html.Label("Item Name:", htmlAttributes: new { id = "itemtypelabel", @class = "control-label" })
                                </div>
                                <div class="col-sm-8 prm">
                                    @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_ItemList_Donation").Name("GLookUp_ItemList_Donation").ValueExpr("ITEM_ID").DisplayExpr("ITEM_NAME")  .Placeholder("Select Item...").ReadOnly(true).FocusStateEnabled(false).Disabled(Isvisible)
                                          .OnValueChanged("GLookUp_ItemList_EditValueChanged").ContentTemplate(@<text> @Html.Partial("LookUp_GetItemList_DonationVoucher") </text>).DataSource(Model.ItemData, "ITEM_ID").Value(Model.GLookUp_ItemList_Donation))

                                </div>
                            </div>
                        </div>
                    </div><!--[Item Name]-->
                    <div class="col-sm-5">
                        <div class="form-field">
                            <div class="container-fluid">

                                <div class="col-sm-4 pll">
                                    @Html.Label("Voucher Date:", htmlAttributes: new { id = "voucherdatelabel", @class = "control-label text-red" })
                                </div>
                                <div class="col-sm-8 prm">
                                    @(Html.DevExtreme().DateBox().CustomDateBox().ID("Txt_V_Date_Donation").Name("Txt_V_Date_Donation").Placeholder("dd-MM-yyyy").Disabled(Isvisible)
                                                                                                              .Value(Model.Txt_V_Date_Donation))
                                    @Html.ValidationMessageFor(model => model.Txt_V_Date_Donation, "", new { @class = "text-red" })


                                </div>
                            </div>
                        </div>
                    </div><!--[Voucher Date]-->
                </div><!--[Row 1]-->
                <div class="row">
                    <div class="col-sm-7">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="col-sm-4 pll">
                                    @Html.Label("Head:", htmlAttributes: new { @class = "control-label disabletxt" })
                                </div>
                                <div class="col-sm-8 prm ">

                                    @(Html.DevExtreme().TextBox().CustomTextBox().ID("BE_Item_Head_Donation").Name("BE_Item_Head_Donation").ReadOnly(true).FocusStateEnabled(false).MaxLength(50).Disabled(Isvisible))
                                </div>


                            </div>
                        </div>
                    </div><!--[Head]-->
                    <div class="col-sm-5">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="col-sm-4 pll">
                                    @Html.Label("Voucher No:", htmlAttributes: new { @class = "control-label disabletxt" })
                                </div>
                                <div class="col-sm-8 prm">

                                    @(Html.DevExtreme().TextBox().CustomTextBox().ID("Txt_V_NO_Donation").Name("Txt_V_NO_Donation").Value(Model.Txt_V_NO_Donation).ReadOnly(true).FocusStateEnabled(false).MaxLength(50).Disabled(Isvisible))
                                </div>


                            </div>
                        </div>
                        @if (Request.Browser.IsMobileDevice)
                        {
                            <div class="form-field">
                                <div class="container-fluid">
                                    <div class="col-sm-4 pll">
                                        @Html.Label("Receipt No:", htmlAttributes: new { @class = "control-label  disabletxt" })
                                    </div>
                                    <div class="col-sm-8 prm">

                                        @(Html.DevExtreme().TextBox().CustomTextBox().ID("BE_Receipt_No_Donation").Name("BE_Receipt_No_Donation").Value(Model.BE_Receipt_No_Donation).ShowClearButton(true).ReadOnly(true).FocusStateEnabled(false).ValidationError(true).MaxLength(50).Disabled(Isvisible))

                                    </div>


                                </div>
                            </div>
                        }
                    </div><!--[Voucher No]-->
                </div><!--[Row 2]-->
                <div class="row">
                    <div class="col-sm-7 ">
                        <div class="form-field">
                            <div class="container-fluid" style="padding:2px 0px 0px 0px">
                                <fieldset class="default-fieldset">
                                    <legend id="donordetaillabel" class="custom-legend mlm">Donor Detail:</legend>
                                    @*<div class="btn-align marginAll2">
                                            @(Html.DevExtreme().Button().ID("DonAdd").Text("Add Donor Ctrl+A").Type(DevExtreme.AspNet.Mvc.ButtonType.Default).OnClick(@<text> function() { Add_a_Donar(); }</text>).Disabled(Isvisible))
                                            @(Html.DevExtreme().Button().ID("DonManage").Text("Manage Donor Ctrl+M").Type(DevExtreme.AspNet.Mvc.ButtonType.Default).OnClick(@<text> function() { Manage_Donar() } </text>).Disabled(Isvisible))
                                        </div>*@
                                    <div class="row">
                                        <div class="col-sm-4 pll">
                                            @Html.Label("Donor Name:", htmlAttributes: new { id = "voucherdonorlabel", @class = "control-label text-red" })
                                        </div>
                                        <div class="col-sm-8 prm" data-toggle="tooltip" data-placement="bottom" title="Select Donor Name">
                                            @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_PartyList_Donation").Name("GLookUp_PartyList_Donation").DataSource(Model.PartyData, "C_ID").ValueExpr("C_ID").DisplayExpr("C_NAME").Placeholder("Select Donor...").Disabled(Isvisible)
                                                  .Value(Model.GLookUp_PartyList_Donation).ReadOnly(true).FocusStateEnabled(false).OnValueChanged("GLookUp_PartyList_EditValueChanged").ContentTemplate(@<text> @Html.Partial("LookUp_GetPartyList_DonationVoucher")</text>))
                                            @Html.ValidationMessageFor(model => model.GLookUp_PartyList_Donation, "", new { @class = "text-red" })
                                        </div>

                                    </div><!--[Donor Name]-->
                                    <div class="row">
                                        <div class="col-sm-4 pll">
                                            @Html.Label("Address:", htmlAttributes: new { id = "donoraddress", @class = "control-label text-red" })
                                            <div class="row ptl ptm">
                                                <div class="col-md-12 donr pb4">
                                                    @(Html.DevExtreme().Button().ID("DonAdd").Text("Add Donor").Type(DevExtreme.AspNet.Mvc.ButtonType.Default).Height(111).Width(130).Icon(Url.Content("../../../../Icons/add user.png")).OnClick(@<text> function() { Add_a_Donar(); }</text>).Disabled(Isvisible).FocusStateEnabled(false))
                                                    @*</div>
                                                        <div class="col-md-12 prm rgt-box-btn">*@
                                                    @(Html.DevExtreme().Button().ID("DonManage").Text("Manage Donor").Type(DevExtreme.AspNet.Mvc.ButtonType.Default).Height(111).Width(130).Icon(Url.Content("../../../../Icons/manage user.png")).OnClick(@<text> function() { Manage_Donar() } </text>).Disabled(Isvisible).FocusStateEnabled(false))
                                                </div>
                                            </div>
                                        </div>  <!--[Address Label/Add Donor/Manage Donor]-->
                                        <div class="col-sm-8 prm">

                                            @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Add1_Donation").ID("BE_Add1_Donation").ReadOnly(true).FocusStateEnabled(false).Disabled(Isvisible))
                                            @Html.ValidationMessageFor(model => model.BE_Add1_Donation, "", new { @class = "text-red" })
                                            @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Add2_Donation").ID("BE_Add2_Donation").ReadOnly(true).FocusStateEnabled(false).Disabled(Isvisible))
                                            @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Add3_Donation").ID("BE_Add3_Donation").ReadOnly(true).FocusStateEnabled(false).Disabled(Isvisible))
                                            @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Add4_Donation").ID("BE_Add4_Donation").ReadOnly(true).FocusStateEnabled(false).Disabled(Isvisible))

                                            <div class="row ptl pbs">
                                                <div class="col-sm-4 brd-div">
                                                    <label id="donorcity" class="control-label add-txt-blue text-red bot-marg" for="Name">City:</label>
                                                </div>
                                                <div class="col-sm-8 ">

                                                    @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_City_Donation").ID("BE_City_Donation").ReadOnly(true).FocusStateEnabled(false).Height("21px").Disabled(Isvisible))

                                                    @Html.ValidationMessageFor(model => model.BE_City_Donation, "", new { @class = "text-red" })
                                                </div>
                                            </div><!--[City]-->
                                            <div class="row pbs">
                                                <div class="col-sm-4 brd-div">
                                                    <label id="donorpincode" class="control-label add-txt-blue bot-marg" for="Name">Pin Code:</label>
                                                </div>
                                                <div class="col-sm-8">

                                                    @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Pincode_Donation").ID("BE_Pincode_Donation").ReadOnly(true).FocusStateEnabled(false).Height("21px").Disabled(Isvisible))

                                                </div>
                                            </div><!--[PinCode]-->
                                            <div class="row pbs">
                                                <div class="col-sm-4 brd-div">
                                                    <label id="donordistrict" class="control-label add-txt-blue text-red bot-marg" for="Name">District:</label>
                                                </div>
                                                <div class="col-sm-8">

                                                    @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_District_Donation").ID("BE_District_Donation").ReadOnly(true).FocusStateEnabled(false).Height("22px").Disabled(Isvisible))

                                                </div>
                                            </div><!--[District]-->
                                            <div class="row pbs">
                                                <div class="col-sm-4 brd-div">
                                                    <label id="donorstate" class="control-label add-txt-blue text-red bot-marg" for="Name">State:</label>
                                                </div>
                                                <div class="col-sm-8">

                                                    @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_State_Donation").ID("BE_State_Donation").ReadOnly(true).FocusStateEnabled(false).Height("22px").Disabled(Isvisible))


                                                </div>
                                            </div><!--[State]-->
                                            <div class="row pbs">
                                                <div class="col-sm-4 brd-div ">
                                                    <label id="donorcountry" class="control-label text-red bot-marg" for="Name">Country:</label>
                                                </div>
                                                <div class="col-sm-8">
                                                    @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Country_Donation").ID("BE_Country_Donation").ReadOnly(true).FocusStateEnabled(false).Height("22px").Disabled(Isvisible))
                                                </div>
                                            </div><!--[Country]-->
                                            <div class="row ptm ptl pbtm3">
                                                <div class="col-sm-4 brd-div">
                                                    <label id="donorAadhar" class="control-label add-txt-blue bot-marg" for="Name">Aadhar No.:</label>
                                                </div>
                                                <div class="col-sm-8">

                                                    @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_AADHAAR_No_Donation").ID("BE_AADHAAR_No_Donation").ReadOnly(true).FocusStateEnabled(false).Height("22px").Disabled(Isvisible))

                                                </div>
                                            </div><!--[Aadhar No]-->
                                            <div class="row pbs">
                                                <div class="col-sm-4 brd-div">
                                                    <label id="donorpan" class="control-label add-txt-blue bot-marg" for="Name">PAN No.:</label>
                                                </div>
                                                <div class="col-sm-8">

                                                    @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_PAN_No_Donation").ID("BE_PAN_No_Donation").ReadOnly(true).FocusStateEnabled(false).Height("22px").Disabled(Isvisible))

                                                </div>
                                            </div><!--[PAN No]-->
                                            <div class="row pbs">
                                                <div class="col-sm-4 brd-div">
                                                    <label id="BE_ID_No_Label_Donation" class="control-label add-txt-blue bot-marg">Passport No.:</label>
                                                    @*@Html.Label("ID No.:", htmlAttributes: new { @class = "control-label add-txt-blue bot-marg", @ID = "BE_ID_No_Label_Donation" })*@
                                                </div>
                                                <div class="col-sm-8">

                                                    @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_ID_No_Donation").ID("BE_ID_No_Donation").ReadOnly(true).FocusStateEnabled(false).Height("22px").Disabled(Isvisible))

                                                </div>
                                            </div><!--[Other ID]-->
                                        </div>
                                    </div>
                                </fieldset>
                            </div>
                        </div><!--[Donor Detail Block]-->
                    </div><!--[Row 3-Left]-->

                    <div class="col-sm-5">
                        @if (Request.Browser.IsMobileDevice == false)
                        {
                            <div class="row">
                                <div class="form-field" style="padding: 8px 4px 8px 4px">
                                    <div class="container-fluid">
                                        <div class="col-sm-4 pll">
                                            @Html.Label("Receipt No:", htmlAttributes: new { @class = "control-label  disabletxt" })
                                        </div>
                                        <div class="col-sm-8 prm">

                                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("BE_Receipt_No_Donation").Name("BE_Receipt_No_Donation").Value(Model.BE_Receipt_No_Donation).ShowClearButton(true).ReadOnly(true).FocusStateEnabled(false).ValidationError(true).MaxLength(50).Disabled(Isvisible))

                                        </div>
                                    </div>
                                </div>
                            </div><!--[Receipt No]-->}
                        <div class="row">
                            <div class="form-field" style="padding: 8px 4px 8px 4px">
                                <div class="container-fluid">
                                    <div class="col-sm-4 pll">
                                        @Html.Label("Mode:", htmlAttributes: new { id = "donationvouchermode", @class = "control-label text-red" })
                                    </div>
                                    <div class="col-sm-8 prm" data-toggle="tooltip" data-placement="bottom" title="Select Payment Mode">

                                        @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("Cmd_Mode_Donation").Name("Cmd_Mode_Donation").DataSource(new[] { "CASH", "CHEQUE", "DD", "CBS", "RTGS", "NEFT", "MO", "CASH TO BANK" }).ShowClearButton(false)
                                              .Value(Model.Cmd_Mode_Donation).OnValueChanged("Cmd_Mode_SelectedIndexChanged").Disabled(Isvisible))
                                        @Html.ValidationMessageFor(model => model.Cmd_Mode_Donation, "", new { @class = "text-red" })

                                    </div>
                                </div>
                            </div>
                        </div><!--[Mode]-->
                        <div class="form-field" style="padding: 6px 4px 8px 4px">
                            <div class="container-fluid">
                                <fieldset class="default-fieldset" id="Ref_Item_Donation">
                                    <legend class="custom-legend mlm"><span id="lbl_Ref_Title" class="disabletxt"> Reference Detail:</span></legend>
                                    <div class="row">
                                        <div class="col-sm-4 pll">
                                            <label id="lbl_Ref_Bank" class="control-label " for="Name">Bank Name:</label>
                                        </div>
                                        <div class="col-sm-8 Bank prm" data-toggle="tooltip" data-placement="bottom" title="Select Bank Name">

                                            @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_RefBankList_Donation").Name("GLookUp_RefBankList_Donation").DataSource(Model.RefBankData, "BI_ID").ValueExpr("BI_ID").DisplayExpr("BI_BANK_NAME").Value(Model.GLookUp_RefBankList_Donation)
                                                  .Placeholder("Select Bank...").OnValueChanged("GLookUp_RefBankList_EditValueChanged").ContentTemplate(@<text> @Html.Partial("LookUp_GetRefBankList_DonationVoucher") </text>).ReadOnly(true).FocusStateEnabled(false).Disabled(Isvisible))
                                            @Html.ValidationMessageFor(model => model.GLookUp_RefBankList_Donation, "", new { @class = "text-red" })

                                        </div>
                                    </div><!--[Bank Name]-->
                                    <div class="row">
                                        <div class="col-sm-4 pll">
                                            <label id="lbl_Ref_Branch" class="control-label  mrg-top-sm" for="Name">Branch Name:</label>
                                        </div>
                                        <div class="col-sm-8 prm">

                                            @(Html.DevExtreme().TextBox().CustomTextBox(true,true).Name("Txt_Ref_Branch_Donation").ID("Txt_Ref_Branch_Donation").Value(Model.Txt_Ref_Branch_Donation).Disabled(Isvisible))
                                            @Html.ValidationMessageFor(model => model.Txt_Ref_Branch_Donation, "", new { @class = "text-red" })

                                        </div>
                                    </div><!--[Branch Name]-->
                                    <div class="row">
                                        <div class="col-sm-4 pll">
                                            <label id="lbl_Ref_No" class="control-label mrg-top-sm" for="Name">Ref.No.:</label>
                                        </div>
                                        <div class="col-sm-8 prm">

                                            @(Html.DevExtreme().TextBox().CustomTextBox(true,true).Name("Txt_Ref_No_Donation").ID("Txt_Ref_No_Donation").Value(Model.Txt_Ref_No_Donation).Disabled(Isvisible))
                                            @Html.ValidationMessageFor(model => model.Txt_Ref_No_Donation, "", new { @class = "text-red" })

                                        </div>
                                    </div><!--[Ref.No]-->
                                    <div class="row">
                                        <div class="col-sm-4 pll">
                                            <label id="lbl_Ref_Date" class="control-label  mrg-top-sm" for="Name">Date:</label>
                                        </div>
                                        <div class="col-sm-8 prm">

                                            @(Html.DevExtreme().DateBox().CustomDateBox().ID("Txt_Ref_Date_Donation").Name("Txt_Ref_Date_Donation").OnValueChanged("refdatechange").Min("01/01/1936")
                                                                                                                                      .Value(Model.Txt_Ref_Date_Donation).Disabled(Isvisible))

                                        </div>
                                    </div><!--[Date]-->
                                    <div class="row">
                                        <div class="col-sm-4 pll">
                                            <label id="lbl_Ref_Cdate" class="control-label  mrg-top-sm" for="Name">Clearing Date:</label>
                                        </div>
                                        <div class="col-sm-8 prm">

                                            @(Html.DevExtreme().DateBoxFor(x => x.Txt_Ref_CDate_Donation).CustomDateBox().OnValueChanged("refdatechange").ID("Txt_Ref_CDate_Donation").Name("Txt_Ref_CDate_Donation").Min("01/01/1936").Disabled(Isvisible))

                                        </div>
                                    </div><!--[Clearing Date]-->
                                </fieldset>
                            </div>
                        </div><!--[Txt_Reference_Donation Detail Block]-->
                        <div class="form-field" style="padding: 6px 4px 8px 4px">
                            <div class="container-fluid">
                                <fieldset class="default-fieldset" id="Deposit_Bank_Item_Donation">
                                    <legend class="custom-legend mlm"><span id="lbl_Bank_Title" class="disabletxt">Deposited Bank Detail:</span></legend>
                                    <div class="row">
                                        <div class="col-sm-4 pll">
                                            <label id="lbl_Bank_Name" class="control-label  mrg-top-sm " for="Name">Bank Name:</label>
                                        </div>
                                        <div class="col-sm-8 prm" data-toggle="tooltip" data-placement="bottom" title="Select Bank Name">

                                            @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_BankList_Donation").Name("GLookUp_BankList_Donation").DataSource(Model.BankData, "BA_ID").ValueExpr("BA_ID").DisplayExpr("BANK_NAME").Disabled(Isvisible)
                                                  .Value(Model.GLookUp_BankList_Donation).Placeholder("Select Bank...").OnValueChanged("GLookUp_BankList_EditValueChanged").ContentTemplate(@<text> @Html.Partial("LookUp_GetBankList_DonationVoucher") </text>).ReadOnly(true).FocusStateEnabled(false))
                                            @Html.ValidationMessageFor(model => model.GLookUp_BankList_Donation, "", new { @class = "text-red" })

                                        </div>
                                    </div><!--[Bank Name]-->
                                    <div class="row">
                                        <div class="col-sm-4 pll">
                                            <label id="lbl_Acc_No" class="control-label mrg-top-sm" for="Name">A/c.No.:</label>
                                        </div>
                                        <div class="col-sm-8 prm">

                                            @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Bank_Acc_No_Donation").ID("BE_Bank_Acc_No_Donation").ReadOnly(true).FocusStateEnabled(false).Disabled(Isvisible))

                                        </div>
                                    </div><!--[A/c No]-->
                                </fieldset>
                            </div>
                        </div><!--[Deposited Bank Detail Block]-->
