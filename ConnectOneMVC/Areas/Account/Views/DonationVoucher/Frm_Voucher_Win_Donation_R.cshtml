<script>
    async function DonationVoucherSaveClick(e)
    {
        e.component.repaint();
        ShowLoader("Saving", false);
        var shouldProceed = true;
        if (ValidateForm(e))
        {
            var item = $("#GLookUp_ItemList_Donation").dxDropDownBox("instance").option("value");
            var panNo = $("#BE_PAN_No_Donation").dxTextBox("instance").option("value");
            if (item == "46f72cc7-14b7-4758-affc-e1952bfb469a" && panNo.substr(3, 1) != "C" && panNo != null && panNo.length > 0)
            {
                await CreateCustomConfirmDialog("@Model.TitleX", '<div><size=13><b>Usually CSR dononations are from Company...!<br>(सामान्यतः CSR सहयोग कम्पनियों से मिलता है!)<br><br>Is this actually a CSR Donation?<br>(क्या यह सहयोग CSR सहयोग ही है?)</div>', false).show().done(function (dialogResult)
                {
                    shouldProceed = dialogResult;
                });
            }
            if (shouldProceed == true)
            {
                if ($("#Txt_Slip_No_Donation").dxNumberBox("instance").option("value") > 0)
                {
                    var slipCountCheck = await slipCountCheck_Donation();
                    if (slipCountCheck.result == false)
                    {
                        await CreateCustomConfirmDialog("@Model.TitleX", slipCountCheck.message, false).show().done(function (dialogResult)
                        {
                            shouldProceed = dialogResult;
                        });
                    }
                }
                if (shouldProceed == true)
                {
                    $("#donationvalidationForm").submit();
                }
            }
        }
        HideLoader();    
    }
    function slipCountCheck_Donation()
    {
        return $.ajax({
            type: "GET",
            url: "/Account/DonationVoucher/slipCountCheck",
            data:
            {
                SlipCount: $("#Txt_Slip_Count_Donation").dxNumberBox("instance").option("value"),
                SlipNo: $("#Txt_Slip_No_Donation").dxNumberBox("instance").option("value"),
                BankId: BankID_Donation,
                xID: $("#xID").val()
            },
            cache: false,
        });
    }
    function DonationVoucherDeleteClick(e)
        {
            if (ValidateForm(e))
            {
                DeleteAfterConfirmation("@Model.TitleX", "", $("#donationvalidationForm"));
            }
        }
