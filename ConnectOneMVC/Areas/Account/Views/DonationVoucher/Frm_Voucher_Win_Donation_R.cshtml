    <script>
        async function GLookUp_ItemList_EditValueChanged(e) {
            var item;
            if (e) {
                item = e.value;
                if ((e.value == null || e.value.length == 0) && e.previousValue != null) {
                    Item_DG_Donation.clearSelection();
                    return;
                }
            }
            else {
                item = $("#GLookUp_ItemList_Donation").dxDropDownBox("option", "value");
            }
            await Item_DG_Donation.selectRows(item);
            if (Item_DG_Donation.getSelectedRowsData().length > 0) {
                var item = Item_DG_Donation.getSelectedRowsData()[0];
                $("#BE_Item_Head_Donation").dxTextBox("instance").option("value", item["LED_NAME"]);
                $("#iVoucher_Type").val(item["ITEM_VOUCHER_TYPE"]);
                $("#iLed_ID").val(item["ITEM_LED_ID"]);
                $("#iTrans_Type").val(item["ITEM_TRANS_TYPE"]);
            }
        }
        async function GLookUp_PartyList_EditValueChanged(e) {
            var party;
            if (e) {
                party = e.value;
