        function refdatechange(e) {
            var mode = ($("#Cmd_Mode_Donation").dxSelectBox("instance").option('value')).toLowerCase();
            clearingdatecheck(mode);
        }
        function clearingdatecheck(cmode) {
            var refcdate = $("#Txt_Ref_CDate_Donation").dxDateBox("instance").option('value');
            if (refcdate) {
                $("#Txt_Ref_CDate_Donation").dxDateBox({})
                    .dxValidator({
                        validationRules: [{
                            type: 'compare',
                            comparisonTarget: function () {
                                var date = $("#Txt_Ref_Date_Donation").dxDateBox("instance");
                                if (date) {
                                    return date.option("value");
                                }
                            },
                            comparisonType: ">=",
                            message: "clearing date cannot be less than " + cmode + " date",
                            ignoreEmptyValue: true,
                        }],
                        validationGroup: "donationvoucher"
                    });
            }
            else {
                $("#Txt_Ref_CDate_Donation").dxDateBox({})
                    .dxValidator({});
            }
        }
        function RefNoValidation(cmdMode) {
            $("#Txt_Ref_No_Donation").dxTextBox({})
                .dxValidator({
                    validationRules: [{
                        type: 'custom',
                        validationCallback: function (options) {
                            var result = true;
                            if (cmdMode == "CHEQUE" || cmdMode == "DD") {
                                if (options.value == "" || options.value == null) {
                                    result = false;
                                }
                            }
                            return result;
                        },
                        reevaluate: true,
                        message: cmdMode + " No. Cannot Be Blank"
                    },
                    {
                        type: 'custom',
                        validationCallback: function (options) {
                            var result = true;
                            if (cmdMode == "CHEQUE" || cmdMode == "DD") {
                                var regex = /^[0-9]{6,8}$/;
                                if (regex.test(options.value) == false) {
                                    result = false;
                                }
                            }
                            return result;
                        },
                        reevaluate: true,
                        message: 'Invalid ' + cmdMode + ' No.Format(Min 6 Digits Max 8 Digits)'
                    }],
                    validationGroup: "donationvoucher"
                });
        }
    </script>
