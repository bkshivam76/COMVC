                    $("#BE_District_Donation").dxTextBox("instance").reset();
                    $("#BE_Country_Donation").dxTextBox("instance").reset();
                    $("#BE_Pincode_Donation").dxTextBox("instance").reset();
                    $("#BE_PAN_No_Donation").dxTextBox("instance").reset();
                    $("#BE_AADHAAR_No_Donation").dxTextBox("instance").reset();
                    $("#BE_ID_No_Donation").dxTextBox("instance").reset();
                    $("#BE_ID_No_Label_Donation").text("Passport No.:");
                    return;
                }
            }
            else {
                party = $("#GLookUp_PartyList_Donation").dxDropDownBox("option", "value");
            }
            await Party_DG_Donation.selectRows(party);
