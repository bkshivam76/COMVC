
@using DevExtreme.AspNet.Data;
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("BankList_Donation_F_DataGrid")
    .Columns(columns =>
    {
        columns.Add().DataField("BANK_NAME").Caption("Name").Visible(true);
        columns.Add().DataField("BANK_BRANCH").Caption("Branch").Visible(true);
        columns.Add().DataField("BANK_ACC_NO").Caption("Account No.").Visible(true);
        columns.Add().DataField("BI_SHORT_NAME").Visible(false);
        columns.Add().DataField("BA_ID").Visible(false);
        columns.Add().DataField("REC_EDIT_ON").Visible(false);
    })
    .SelectedRowKeys(new JS(@"component.option(""value"")"))
    .Selection(s => s.Mode(SelectionMode.Single))
)
