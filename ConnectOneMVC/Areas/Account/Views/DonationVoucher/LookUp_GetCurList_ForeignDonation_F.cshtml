
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("CurList_Donation_F_DataGrid")

    .Columns(columns =>
    {
        columns.Add().DataField("CUR_NAME").Caption("Name").Visible(true);
        columns.Add().DataField("CUR_CODE").Caption("Code").Visible(true);
        columns.Add().DataField("CUR_SYMBOL").Caption("Symbol").Visible(true);
        columns.Add().DataField("CUR_ID").Visible(false);       
    })
         .Selection(s => s.Mode(SelectionMode.Single))
)
