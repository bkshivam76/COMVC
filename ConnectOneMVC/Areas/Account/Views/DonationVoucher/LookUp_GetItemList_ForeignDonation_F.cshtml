
@using DevExtreme.AspNet.Data;
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("ItemList_Donation_F_DataGrid")
    .Columns(columns =>
    {
        columns.Add().DataField("ITEM_NAME").Caption("ITEM NAME").Visible(true);
        columns.Add().DataField("LED_NAME").Visible(false);
        columns.Add().DataField("ITEM_TRANS_TYPE").Visible(false);
        columns.Add().DataField("ITEM_LED_ID").Visible(false);
