

@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("DonationVoucher_GLookUp_DonorList_datagrid")
    .Columns(columns =>
    {
        columns.Add().DataField("C_NAME").Caption("Name");
        columns.Add().DataField("C_PAN_NO").Caption("PANNo.");
        columns.Add().DataField("CI_NAME").Caption("City");
        columns.Add().DataField("MOB").Caption("Mobile");
        columns.Add().DataField("CO_NAME").Caption("Country").Visible(false);
        columns.Add().DataField("C_UID_NO").Caption("UID No").Visible(false);
        columns.Add().DataField("REC_EDIT_ON").Caption("REC_EDIT_ON").Visible(false).Format("dd/MM/yyyy");
        columns.Add().DataField("C_R_ADD1").Caption("Address1").Visible(false);
        columns.Add().DataField("C_R_ADD2").Caption("Address2").Visible(false);
        columns.Add().DataField("C_R_ADD3").Caption("Address3").Visible(false);
        columns.Add().DataField("C_R_ADD4").Caption("C_R_ADD4").Visible(false);
        columns.Add().DataField("C_R_PINCODE").Caption("Pincode").Visible(false);
        columns.Add().DataField("ST_NAME").Caption("State").Visible(false);
        columns.Add().DataField("DI_NAME").Caption("District").Visible(false);



    })
         .Selection(s => s.Mode(SelectionMode.Single))
            .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}")
)
