
@using DevExtreme.AspNet.Data;
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("PartyList_Donation_F_DataGrid")
    .Columns(columns =>
    {
        columns.Add().DataField("C_NAME").Caption("Name").Visible(true);
        columns.Add().DataField("C_PAN_NO").Caption("PAN No.").Visible(true);
        columns.Add().DataField("C_TAX_ID_NO").Caption("Taxation No.").Visible(true);
        columns.Add().DataField("CI_NAME").Caption("City").Visible(true);
        columns.Add().DataField("CO_NAME").Caption("Country").Visible(true);
        columns.Add().DataField("C_PASSPORT_NO").Caption("Passport No.").Visible(true);
        columns.Add().DataField("C_R_ADD1").Visible(false);
        columns.Add().DataField("C_R_ADD2").Visible(false);
        columns.Add().DataField("C_R_ADD3").Visible(false);
        columns.Add().DataField("C_R_ADD4").Visible(false);
        columns.Add().DataField("C_R_PINCODE").Visible(false);
        columns.Add().DataField("C_UID_NO").Visible(false);
        columns.Add().DataField("ST_NAME").Caption("State").Visible(false);
        columns.Add().DataField("DI_NAME").Visible(false);
        columns.Add().DataField("C_ID").Visible(false);
        columns.Add().DataField("REC_EDIT_ON").Visible(false);
    })
    .SelectedRowKeys(new JS(@"component.option(""value"")"))
    .Selection(s => s.Mode(SelectionMode.Single))
)
