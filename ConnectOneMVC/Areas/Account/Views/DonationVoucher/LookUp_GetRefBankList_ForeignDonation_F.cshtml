
@using DevExtreme.AspNet.Data;
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("RefBankList_Donation_F_DataGrid")
    .Columns(columns =>
    {
        columns.Add().DataField("BI_BANK_NAME").Caption("Name").Visible(true);
        columns.Add().DataField("BI_SHORT_NAME").Caption("Short").Visible(true);
        columns.Add().DataField("BI_ID").Visible(false);
    })
    .SelectedRowKeys(new JS(@"component.option(""value"")"))
    .Selection(s => s.Mode(SelectionMode.Single))
)
