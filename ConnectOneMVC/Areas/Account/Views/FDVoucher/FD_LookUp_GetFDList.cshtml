@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("FDVoucher_LookUp_GetFDList_DG")
    .Columns(columns =>
    {
        columns.Add().DataField("FD_NO").Caption("FD No");
        columns.Add().DataField("FD_AMOUNT").Caption("Amt");
        columns.Add().DataField("BANK_NAME").Caption("Bank");
        columns.Add().DataField("MATURITY_AMOUNT").Caption("Maturity");
        columns.Add().DataField("MATURITY_DATE").Caption("Mat Date").DataType(GridColumnDataType.Date).Format("dd/MM/yyyy"); 
        columns.Add().DataField("FD_AS_DATE").Caption("As Date").DataType(GridColumnDataType.Date).Format("dd/MM/yyyy"); 
        columns.Add().DataField("ROI").Caption("Rate");
        columns.Add().DataField("FD_DATE").Caption("FD DATE").Visible(false);
        columns.Add().DataField("FD_STATUS").Caption("Status");
        columns.Add().DataField("FD_ID").Caption("FD_ID").Visible(false);
        columns.Add().DataField("BANK_CUST_NO").Caption("BANK_CUST_NO").Visible(false);
        columns.Add().DataField("BA_ID").Caption("BA_ID").Visible(false);
        columns.Add().DataField("BANK_BRANCH").Caption("BANK_BRANCH").Visible(false);
        columns.Add().DataField("REC_EDIT_ON").Caption("REC_EDIT_ON").Visible(false);
    })

    .Selection(s => s.Mode(SelectionMode.Single))
    .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}")
    )