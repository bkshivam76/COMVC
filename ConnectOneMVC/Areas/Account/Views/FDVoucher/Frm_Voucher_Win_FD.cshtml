<script>

    async function FDVoucherSave(e)
    {
        FD_PopupCloseConfirmation = false;
        var GetDialogResult = true;//Redmine bug 132869 fixed
        if ($("#FD_GLookUp_BankList").dxDropDownBox("instance").option("readOnly") || $("#FD_GLookUp_BankList").dxDropDownBox("instance").option("disabled") || $("#PanelControl3").prop("disabled"))
        {
            $("#GLookUp_BankListEnabled").val(false);
        }
        else
        {
            $("#GLookUp_BankListEnabled").val(true);
        }
        var form = $("#id_Frm_Voucher_Win_FD");
        if ("@Model.ActionMethod" == "_New" || "@Model.ActionMethod" == "_New_From_Selection")
        {
            $("#xMID").val(createGuid());
        }
        if (ValidateForm(e))
        {
            if (e.component.option("text") == "Delete")
            {
                DeleteAfterConfirmation("Confirm", "", form);
            }
            else
            {
                if ("@Model.FDiAction" == "Renew_FD")
                {
                    if ("@Model.ActionMethod" == "_New" || "@Model.ActionMethod" == "_New_From_Selection" || "@Model.ActionMethod" == "_Edit")
                    {
                        if ($("#FD_TXT_RENEWAL_MATURITY_AMOUNT").dxNumberBox("instance").option("value") < $("#FD_Txt_Amount").dxNumberBox("instance").option("value"))
                        {
                            var Maturity_Date = new Date($("#FD_MaturityDate").val());
                            var Renewal_Date = $("#FD_TXT_NRC_DATE").dxDateBox("instance").option("value");
                            if (Maturity_Date <= Renewal_Date)
                            {
                                var renew_result = DevExpress.ui.dialog.confirm('Renewal amount is less than F.D. Amount...!<br>Are you sure you want to Save...?', "Confirm");
                                await renew_result.done(function (dialogResult)
                                {
                                    if (!dialogResult)
                                    {
                                        GetDialogResult = false;//Redmine bug 132869 fixed
                                        $("#FD_TXT_RENEWAL_MATURITY_AMOUNT").dxNumberBox("instance").focus();
                                        return;
                                    }
                                });
                            }
                        }
                        if (GetDialogResult == true)
                        {
                            if ($("#FD_MaturityAmt").val() < $("#FD_TXT_REC_AMOUNT").dxNumberBox("instance").option("value"))
                            {
                                var Maturity_Date = new Date($("#FD_MaturityDate").val());
                                var Renewal_Date = $("#FD_TXT_NRC_DATE").dxDateBox("instance").option("value");
                                if (Maturity_Date < Renewal_Date)
                                {
                                    var renew_result = DevExpress.ui.dialog.confirm('Received amount should not be greater than Maturity Amount...!<br>Are you sure you want to Save...?', "Confirm");
                                    await renew_result.done(function (dialogResult)
                                    {
                                        if (!dialogResult)
                                        {
                                            GetDialogResult = false;//Redmine bug 132869 fixed
                                            $("#FD_TXT_RENEWAL_MATURITY_AMOUNT").dxNumberBox("instance").focus();
                                            return;
                                        }
                                    });
                                }
                            }
                        }
                    }
                }
                else if ("@Model.FDiAction" == "Close_FD")//Redmine bug 132800 fixed
                {
                    if ("@Model.ActionMethod" == "_New" || "@Model.ActionMethod" == "_New_From_Selection" || "@Model.ActionMethod" == "_Edit")
                    {
                        if ($("#FD_Txt_Amount").dxNumberBox("instance").option("value") > $("#FD_TXT_REC_AMOUNT").dxNumberBox("instance").option("value"))
                        {

                            var Maturity_Date = new Date($("#FD_MaturityDate").val());
                            var Renewal_Date = $("#FD_TXT_NRC_DATE").dxDateBox("instance").option("value");

                            if (Renewal_Date >= Maturity_Date)//Redmine bug 132800 fixed
                            {
                                var renew_result = DevExpress.ui.dialog.confirm('Received Amount cannot be less than F.D. Amount on Maturity...!<br>Are you sure you want to Save...?', "Confirm");
                                await renew_result.done(function (dialogResult)
                                {
                                    if (dialogResult == false)
                                    {
                                        GetDialogResult = false;
                                        $("#FD_TXT_REC_AMOUNT").dxNumberBox("instance").focus();
                                        return;
                                    }
                                });
                            }
                        }

                    }
                }
                if (GetDialogResult == true)//Redmine bug 132869 fixed
                {
                    ShowLoader();
                    form.submit();
                }
            }
        }
    }
    var FDVoucher_GridToRefresh = "@ViewBag.GridToRefresh";
    function AjaxSuccessVoucherWinFD(data)
    {
        HideLoader();
        if (data.jsonParam == void 0)
        {
            var PopupTitle = "@Model.ActionMethod".startsWith("_New") ? "New" : "@Model.ActionMethod".substring(1);
            OpenPopup("Frm_Voucher_FD_popup", PopupTitle + " ~ Fixed Deposit (F.D.)", null, "auto", 700, true, data);
        }
        else if (data.jsonParam.result == false)
        {
            if (data.jsonParam.closeform)
            {
                dontaskpopupcloseconfirmation = true;
                $("#Dynamic_Content_popup").dxPopup("hide");
            }
            var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
            alertclick.done(function (alertResult)
            {
                if (alertResult)
                {
                    if (data.jsonParam.refreshgrid == true)
                    {
                        RefreshGridView(FDVoucher_GridToRefresh);
                    }
                    if (data.jsonParam.focusid)
                    {
                        var id = "#" + data.jsonParam.focusid;
                        setTimeout(function ()
                        {
                            $(id).find('input').focus();
                        }, Timeout100);
                    }
                }
            });
        }
        else if (data.jsonParam.result == true)
        {     
            var _ActiveTab_ID = $(".TabPanalMenu-tabs .active").attr("id");
            var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
            alertclick.done(function (result)
            {
                if (result)
                {
                    if (FDVoucher_GridToRefresh != "CashBookListGrid")
                    {
                        RefreshGridView(FDVoucher_GridToRefresh);
                    }
                    if (/*typeof CashBookListGrid !== 'undefined'*/ _ActiveTab_ID == "contact_Frm_Voucher_Info_CB")
                    {
                        AfterVoucherClose_CB($("#FD_Txt_V_Date").dxDateBox("instance").option("value"), "@Model.ActionMethod", IsUndefinedOrNull(data.CashbookGridPK) ? "" : data.CashbookGridPK);
                    }
                    else if (_ActiveTab_ID == "contact_Frm_Voucher_Info")
                    {
                        AfterVoucherClose_VoucherEntry();
                    }
                    dontaskpopupcloseconfirmation = true;
                    $("#Dynamic_Content_popup").dxPopup("hide");
                }
            });
        }
    }
    function Frm_Voucher_FD_popup_Hiding(e)
    {
        FDwindow_DepBank_DataGrid = null;
        ClearAllReferences("FDWindow_ClearReferences");
        e.component.content()[0].innerHTML = "";
    }
</script>@*Save Functions*@
<script>
    function refdatechange(e)
    {
        clearingdatecheck(FD_CMD_Mode==null?"":FD_CMD_Mode.toLowerCase());
    }
    function clearingdatecheck(cmode)
    {
        var refcdate = $("#FD_Txt_Ref_CDate").dxDateBox("instance").option('value');
        if (refcdate) {
            $("#FD_Txt_Ref_CDate").dxDateBox({})
                .dxValidator({
                    validationRules: [{
                        type: 'compare',
                        comparisonTarget: function () {
                            var date = $("#FD_Txt_Ref_Date").dxDateBox("instance");
                            if (date) {
                                return date.option("value");
                            }
                        },
                        comparisonType: ">=",@* Redmine Bug #133701 fixed *@
                        message: "clearing date cannot be less than " + cmode + " date",
                        ignoreEmptyValue: true,
                        reevaluate:true,
                    }],
                    validationGroup: "FD_Voucher"
                });
        }
        else {
            $("#FD_Txt_Ref_CDate").dxDateBox({})
                .dxValidator({});
        }
    }
    function FD_cmdmode_validations(FD_Cmd_Mode) {
        $("#FD_Txt_Ref_No").dxTextBox({})
            .dxValidator({
                validationRules: [{
                    type: 'custom',
                    validationCallback: function (options) {
                        var result = true;
                        if (FD_Cmd_Mode == "CHEQUE" || FD_Cmd_Mode == "DD") {
                            var reg = /^[0-9]{6,8}$/;
                            if (!(reg.test(options.value))) {
                                result = false
                            }
                        }
                        return result;
                    },
                    reevaluate: true,
                    message: 'Invalid Format(Need To Be Of Min 6 Digits And Max 8 Digits)'
                }],
                validationGroup: "FD_Voucher"
            });
    }
    $(function () {
        $("#PurposeID_FD").dxSelectBox({})
            .dxValidator({
                validationRules: [{
                    type: 'custom',
                    validationCallback: function (options) {
                        var result = true;
                        if ("@Model.ActionMethod" == "_New" ||"@Model.ActionMethod" == "_New_From_Selection"||"@Model.ActionMethod" == "_Edit") {

                            if (options.value == "" || options.value ==null) {
                                result = false;
                            }
                        }
                        return result;
                    },
                    message: " Purpose Cannot Be Blank..!!"
                }],
                validationGroup: "FD_Voucher"
            });//redmine Bug #133286 fix
        $("#FD_Txt_V_Date").dxDateBox({})
            .dxValidator({
                validationRules: [{
                    type: 'custom',
                    validationCallback: function (options) {
                        var result = true;
                        return result;
                    }
                }],
                validationGroup: "FD_Voucher"
            }); @* Redmine Bug #133256 Fix *@
    });
    function BTN_FD_DET_Click()
    {
        if ("@FDVoucher_ViewRight" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        var FDID=null;
        if (($("#GLookUp_FD_List").dxDropDownBox("instance").option("value") != null && ($("#GLookUp_FD_List").dxDropDownBox("instance").option("value")).length != 0))
        {
            FDID = $("#GLookUp_FD_List").dxDropDownBox("instance").option("value");
        }
        else
        {
            if ("@Model.ActionMethod" == "_View" || "@Model.ActionMethod" == "_Delete")
            {
                FDID = "@Model.GLookUp_FD_List";
            }
        }
        if (FDID == null || FDID.length==0)
        {
            var alert = DevExpress.ui.dialog.alert("FD Not Selected...", "Error..");//Redmine Bug #134206 fix
            alert.done(function (result)
            {
                if (result)
                {
                    $("#GLookUp_FD_List").dxDropDownBox("instance").focus();
                }
            });
            return;
        }
        ShowLoader();
        $.ajax({
            type: 'POST',
            url: "/Account/FDVoucher/Frm_FD_Window",
            data:
            {
                xFdID: FDID,
                TempActionMethod: "_View",
                Popup_id:"Frm_Voucher_FD_popup"
            },
            cache: false,
            success:
                function (data)
                {
                      OpenPopup("Frm_Voucher_FD_popup", ("@Model.ActionMethod".substring(1)) + " ~ Fixed Deposit (F.D.)", null, "auto", 700, true, data);
                }
        });
    }
</script>@* Misc *@
</div>
