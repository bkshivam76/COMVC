    }
    function GetItemCountInSameMaster()
    {
        $.ajax({
            type: 'POST',
            url: "/Account/FDVoucher/GetItemCountInSameMaster",
            async: false,
            data:
            {
                xMID: $("#xMID").val()
            },
            cache: false,
            success:
                function (data)
                {
                    if (data.result == false)
                    {
                        DevExpress.ui.dialog.confirm(data.message, "Error..");
                        return null;
                    }
                    else
                    {
                        if (data.itemid.length > 0)
                        {
                            return data.itemid;
                        }
                        else
                        {
                            return null;
                        }
                    }
                }
        });
    }
</script>@*document.ready*@
<script>
    var FD_Item_DataGrid;
    var FD_DepBank_DataGrid;
    var FD_FDList_DataGrid; 
    var FD_PopupCloseConfirmation = true;
    var FD_ItemDD_Refresh = false;
    var FD_FDListDD_Refresh = false;
    var FD_DepBankDD_Refresh = false;
    var FD_Bank_Enabled = true;
    var FD_Bank_ReadOnly = true;
    var FD_CMD_Mode = "BANK ACCOUNT"; @* Redmine Bug #133701 fixed *@
    function InitAllDropdowns_FD()
    {
        var $FD_Item_DataGrid = $("#FDVoucher_LookUp_GetItemList_DG");
        if ($FD_Item_DataGrid.length)
        {
            FD_Item_DataGrid = $FD_Item_DataGrid.dxDataGrid("instance");
        }
        var $FD_DepBank_DataGrid = $("#FDVoucher_LookUp_GetBankList_DG");
        if ($FD_DepBank_DataGrid.length)
        {
            FD_DepBank_DataGrid = $FD_DepBank_DataGrid.dxDataGrid("instance");
        }
        var $FD_FDList_DataGrid = $("#FDVoucher_LookUp_GetFDList_DG");
        if ($FD_FDList_DataGrid.length)
        {
            FD_FDList_DataGrid = $FD_FDList_DataGrid.dxDataGrid("instance");
        }
    }
    async function LookUp_GetItemList_FD(FirstCall = false)
    {
        //skipping refresh as it never gets refresh
        var DsItems = GetDataSourceItems("FD_GLookUp_ItemList", "dxDropDownBox");
        if (DsItems.length== 1)
        {
            $("#FD_GLookUp_ItemList").find('input').css('color', '#000080');
            if ("@Model.ActionMethod" == "_New" || "@Model.ActionMethod" == "_New_From_Selection")
            {
                await FD_Item_DataGrid.selectRows(DsItems[0].ITEMID);
                Control_SetReadOnly("FD_GLookUp_ItemList", "dxDropDownBox", true);
            }
        }
        else
        {
            if ("@Model.ActionMethod" == "_New" || "@Model.ActionMethod" == "_New_From_Selection")
            {
                Control_SetReadOnly("FD_GLookUp_ItemList", "dxDropDownBox", false);
            }
        }
    }
    async function LookUp_GetBankList_FD(FirstCall = false)
    {
        if (FirstCall === false)
        {
            var BankData = await Get_Bank_Data_FD();
            $("#FD_GLookUp_BankList").dxDropDownBox("option", "dataSource", new DevExpress.data.ArrayStore({
                key: "BA_ID",
                data: BankData
            }))
            FD_DepBank_DataGrid.option("dataSource", $("#GLookUp_RStateList_AB").dxDropDownBox("option", "dataSource"))
        }
        var DsItems = GetDataSourceItems("FD_GLookUp_BankList", "dxDropDownBox");
        var TotalCount = DsItems.length;
        $("#Cnt_BankAccount").val(TotalCount);
        if (TotalCount == 1)
        {
            $("#FD_GLookUp_BankList").find("input").css("color", "#696969");
            if ("@Model.ActionMethod" == "_New" || "@Model.ActionMethod" == "_New_From_Selection")
            {
                await FD_DepBank_DataGrid.selectRows(DsItems[0].BA_ID);
                FD_Bank_Enabled = false
                Control_SetReadOnly("FD_GLookUp_BankList", "dxDropDownBox", !(FD_Bank_Enabled == true && FD_Bank_ReadOnly==false), "#696969");
            }
        }
        else
        {
            if ("@Model.ActionMethod" == "_New" || "@Model.ActionMethod" == "_New_From_Selection")
            {
                FD_Bank_ReadOnly = false;
                Control_SetReadOnly("FD_GLookUp_BankList", "dxDropDownBox", !(FD_Bank_Enabled == true && FD_Bank_ReadOnly == false));
            }
        }
        if ("@Model.ActionMethod" == "_New" || "@Model.ActionMethod" == "_New_From_Selection")
        {
            FD_Bank_ReadOnly = false;
            Control_SetReadOnly("FD_GLookUp_BankList", "dxDropDownBox", !(FD_Bank_Enabled == true && FD_Bank_ReadOnly == false));
        }
    }
    async function Get_Bank_Data_FD()
    {
        return $.ajax({
            type: 'GET',
            url: "/Account/FDVoucher/GetBankDataOnRefresh",
            cache: false
        });
    }
</script>@*DD refresh function and init*@
<script>    
    async function GLookUp_ItemList_EditValueChanged_FD(e,FirstCall=false)
    {
        var item;
        if (e) {
            item = e.value;
            if ((e.value == null || e.value.length == 0) && e.previousValue != null) {
                FD_Item_DataGrid.clearSelection();               
                return;
            }
        }
        else
        {
            item = $("#FD_GLookUp_ItemList").dxDropDownBox("option", "value");
        }
        await FD_Item_DataGrid.selectRows(item);
        if (FD_Item_DataGrid.getSelectedRowsData().length > 0)
        {
            var item = FD_Item_DataGrid.getSelectedRowsData()[0];
            $("#FD_BE_Item_Head").dxTextBox("instance").option("value", item["LED_NAME"]);
            $("#iVoucher_Type").val(item["ITEM_VOUCHER_TYPE"]);
            $("#iLed_ID").val(item["ITEM_LED_ID"]);
            $("#iTrans_Type").val(item["ITEM_TRANS_TYPE"]);            
        }     
    }
    async function GLookUp_BankList_EditValueChanged_FD(e,FirstCall=false)
    {
        var bank;
        if (e) {
            bank = e.value;
            if ((e.value == null || e.value.length == 0) && e.previousValue != null) {
                FD_DepBank_DataGrid.clearSelection();
                $("#FD_Txt_Branch").dxTextBox("instance").option("value", "");
                $("#FD_Txt_AccountNo").dxTextBox("instance").option("value", "");
                return;
            }
        }
        else
        {
            bank = $("#FD_GLookUp_BankList").dxDropDownBox("option", "value");
        }
        await FD_DepBank_DataGrid.selectRows(bank);
        if (FD_DepBank_DataGrid.getSelectedRowsData().length > 0)
        {
            var item = FD_DepBank_DataGrid.getSelectedRowsData()[0];
            $("#FD_Txt_Branch").dxTextBox("instance").option("value", item["BANK_BRANCH"]);
            $("#FD_Txt_AccountNo").dxTextBox("instance").option("value", item["BANK_ACC_NO"]);
            $("#GlookUp_BankList_REC_EDIT_ON").val(JS_Date_toIsoString(item["REC_EDIT_ON"]));
        }
    }
    async function GLookUp_FD_List_EditValueChanged(e,FirstCall=false)
    {
        var fd;
        if (e) {
            fd = e.value;
            if ((e.value == null || e.value.length == 0) && e.previousValue != null) {
                $("#FD_TXT_Fd_Bank").dxTextBox("instance").option("value", null);
                $("#FD_Txt_Amount").dxNumberBox("instance").option("value", null);
                FD_FDList_DataGrid.clearSelection();
                return;
            }
        }
        else
        {
            fd = $("#GLookUp_FD_List").dxDropDownBox("option", "value");
        }
        await FD_FDList_DataGrid.selectRows(fd);
        if (FD_FDList_DataGrid.getSelectedRowsData().length > 0)
        {
            var item = FD_FDList_DataGrid.getSelectedRowsData()[0];
            $("#FD_TXT_Fd_Bank").dxTextBox("instance").option("value", item["BANK_NAME"]);
            $("#FD_Txt_Amount").dxNumberBox("instance").option("value", parseFloat(item["FD_AMOUNT"]));     
            $("#FD_MaturityDate").val(JS_Date_toIsoString(item["MATURITY_DATE"]));
            $("#FD_MaturityAmt").val(item["MATURITY_AMOUNT"]);
            $("#FD_AsDate").val(JS_Date_toIsoString(item["FD_AS_DATE"]));
            $("#FdListBank_ID").val(item["BA_ID"]);
            $("#FD_Date").val(JS_Date_toIsoString(item["FD_DATE"]));
            $("#FD_List_REC_EDIT_ON").val(JS_Date_toIsoString(item["REC_EDIT_ON"]));
            $("#FD_RenewFromFDNo").val(item["FD_NO"]);
            if ("@Model.iAction" == "Close_FD")
            {
                $("#FD_TXT_RENEWAL_MATURITY_AMOUNT").dxNumberBox("instance").option("value", parseFloat(item["MATURITY_AMOUNT"]));
            }
            $.ajax({
                type: 'POST',
                url: "/Account/FDVoucher/GetTDS",
                async: false,
                data:
                {
                    FD_ID: item["FD_ID"],
                    xMID: $("#xMID").val()
                },
                cache: false,
                success:
                    function (data)
                    {
                        $("#FD_TXT_TDS_PREV").dxNumberBox("instance").option("value",(data.tds-data.tdsReversal));
                    }
            });
            if (($("#FD_TXT_REC_AMOUNT").dxNumberBox("instance").option("value")) != null && $("#FD_TXT_REC_AMOUNT").dxNumberBox("instance").option("value")!=0)
            {
                var rec_amount = parseFloat($("#FD_TXT_REC_AMOUNT").dxNumberBox("instance").option("value"));
                var Txt_Amount = parseFloat($("#FD_Txt_Amount").dxNumberBox("instance").option("value"));
                $("#FD_TXT_INTEREST").dxNumberBox("instance").option("value", (rec_amount - Txt_Amount));
            }
            TXT_NRC_DATE_EditValueChanged(null, FirstCall);
        }
    }
    function TXT_REC_AMOUNT_EditValueChanged(e,FirstCall=false)
    {
        var GLookUp_FD_ListView = $("#GLookUp_FD_List").dxDropDownBox("instance").option("value");
        var TXT_REC_AMOUNT = parseFloat($("#FD_TXT_REC_AMOUNT").dxNumberBox("instance").option("value"));
        var Amount = parseFloat($("#FD_Txt_Amount").dxNumberBox("instance").option("value"));
        var Txt_Amount = parseFloat(Amount.toFixed(2));
        var Cmb_Rec_Mode = $("#FD_Cmb_Rec_Mode").dxSelectBox("instance").option("value");
        Cmb_Rec_Mode = Cmb_Rec_Mode == null ? "" : Cmb_Rec_Mode;
        var TXT_RENEWAL_MATURITY_AMOUNT = parseFloat($("#FD_TXT_RENEWAL_MATURITY_AMOUNT").dxNumberBox("instance").option("value"));
        if (GLookUp_FD_ListView != null && GLookUp_FD_ListView.length > 0 )
        {
            TXT_REC_AMOUNT = parseFloat((TXT_REC_AMOUNT.toFixed(2)).toString());
            $("#FD_TXT_INTEREST").dxNumberBox("instance").option("value", (TXT_REC_AMOUNT - Txt_Amount));           
        }
        if ("@Model.iAction" != "Renew_FD")
        {
            return;
        }
        if (Cmb_Rec_Mode.toUpperCase() != "CASH")
        {
            Fieldset_SetDisable("PanelControl3", true);
            $("#lbl_Ref_Bank").removeClass("text-red").addClass("disabletxt");
            $("#lbl_Ref_No").removeClass("text-red").addClass("disabletxt");
            $("#lbl_Ref_Date").removeClass("text-red").addClass("disabletxt");
        }     
        TXT_REC_AMOUNT = isNaN(TXT_REC_AMOUNT) ? 0 : TXT_REC_AMOUNT;
        TXT_RENEWAL_MATURITY_AMOUNT = isNaN(TXT_RENEWAL_MATURITY_AMOUNT) ? 0 : TXT_RENEWAL_MATURITY_AMOUNT;
        if (TXT_REC_AMOUNT-TXT_RENEWAL_MATURITY_AMOUNT !=0) {
            if (Cmb_Rec_Mode.toUpperCase() != "CASH") {
                FD_Bank_ReadOnly = false;            
                FD_Bank_Enabled = true;
                Control_SetReadOnly("FD_GLookUp_BankList", "dxDropDownBox", !(FD_Bank_Enabled == true && FD_Bank_ReadOnly==false));
                Fieldset_SetDisable("PanelControl3", false);
                $("#lbl_Ref_Bank").addClass("text-red").removeClass("disabletxt");
                if (Cmb_Rec_Mode.toUpperCase() != "BANK ACCOUNT") {
                    $("#lbl_Ref_No").addClass("text-red").removeClass("disabletxt");
                    $("#lbl_Ref_Date").addClass("text-red").removeClass("disabletxt");
                }
                else {
                    $("#lbl_Ref_No").removeClass("text-red").removeClass("disabletxt");
                    $("#lbl_Ref_Date").removeClass("text-red").addClass("disabletxt");
                }
            }
            $("#lblReceiptMode").addClass("text-red").removeClass("disabletxt");
            Control_SetReadOnly("FD_Cmb_Rec_Mode", "dxSelectBox", false);
            if (TXT_RENEWAL_MATURITY_AMOUNT - TXT_REC_AMOUNT >0) {
                $("#lblReceiptMode").text("Pay Mode:");
                $("#lbl_Ref_Title").text("Saving Bank Details:");
            }
            else {
                $("#lblReceiptMode").text("Receipt Mode:");
                if (Cmb_Rec_Mode.toUpperCase() == "CHEQUE") {
                    $("#lbl_Ref_Title").text("Saving Bank Details:");
                }
                else if (Cmb_Rec_Mode.toUpperCase() == "DD") {
                    $("#lbl_Ref_Title").text("Saving Bank Details:");
                }
                else if (Cmb_Rec_Mode.toUpperCase() == "BANK ACCOUNT") {
                    $("#lbl_Ref_Title").text("Saving Bank Details:");
                }
            }
        }
        else
        {
            $("#lblReceiptMode").removeClass("text-red").addClass("disabletxt");
            Control_SetReadOnly("FD_Cmb_Rec_Mode", "dxSelectBox", true, "#696969");
            if (e)
            {
                if ($("#FD_Cmb_Rec_Mode").dxSelectBox("option", "value") == null)
                {
                    $("#FD_Cmb_Rec_Mode").dxSelectBox("option", "value", "BANK ACCOUNT");
                }
            }
        }
    }
