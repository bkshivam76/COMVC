</div>
@(Html.DevExtreme().Popup().CustomPopup().ID("Frm_Voucher_FD_popup").OnShowing("PopupOnShowing").OnHiding("Frm_Voucher_FD_popup_Hiding").CloseOnOutsideClick(false).ShowTitle(true).Title("New ~ Item Detail").ContentTemplate(@<text> <div id="result_Voucher_FD_popup"> </div> </text>))

<script>
    $(document).ready(async function ()
    {
        ShowLoader_Ready();
        if ("@FDVoucher_ViewRight" == "False")
        {
            $("#ViewFD").hide();
        }
        if ("@Model.TitleX" == "FD related Income / Expenses") {
            if ("@Model.Tag".startsWith("_New")) {
                $("#Dynamic_Content_popup").dxPopup("instance").option("title", "New" + " ~ " + "@Model.TitleX");
            }
            else {
                $("#Dynamic_Content_popup").dxPopup("instance").option("title", "@Model.ActionMethod".substring(1) + " ~ " + "@Model.TitleX");//redmine Bug #132913 fixed
            }
        }
        if ("@Model.ActionMethod" != "_View")
        {
            dontaskpopupcloseconfirmation = false;
        }
        InitAllDropdowns_FD();
        ClosingScreenParentDivClass = "FDVoucher_ClearReferences";
        TransformTextForDB("id_Frm_Voucher_Win_FD");
        sessionclearpath = "/Account/FDVoucher/SessionClear";
        Fieldset_SetDisable("PanelControl3", true);
        await LookUp_GetItemList_FD(true);
        switch ("@Model.iAction")
        {
            case "New_FD":
                await GLookUp_ItemList_EditValueChanged_FD(null, true);
                Fieldset_SetDisable("C_R_Panel", true);
                $("#lblFDAct").addClass("disabletxt").removeClass("text-red");
                $("#lblReceiptMode").addClass("disabletxt").removeClass("text-red");
                $("#lblReceivedAmount").addClass("disabletxt").removeClass("text-red");
                $("#lblInterest").addClass("disabletxt").removeClass("text-red");
                $("#lblTDS").addClass("disabletxt").removeClass("text-red");
                $("#lblTDS_Prev").addClass("disabletxt").removeClass("text-red");
                $("#lbl_FD_Txt_NRC_Date").text("FD Start Date:");
                $("#Lay_Select_Fd").hide();
                $("#Lay_View_Fd").hide();
                $("#Lay_FD_Bank").hide();
                $("#Lay_Payment_Mode").show();
                $("#Lay_Renewal_Amount").hide();
                Control_SetReadOnly("FD_Txt_Amount", "dxNumberBox", false);
                Fieldset_SetDisable("PanelControl3", false);
                Control_SetReadOnly("FD_Cmd_Mode", "dxSelectBox", false);
                $("#Lay_Renewal").hide();
                break;
            case "Renew_FD":
                Fieldset_SetDisable("C_R_Panel", false);
                $("#lblFDAct").removeClass("disabletxt").removeClass("text-red");
                $("#lblReceiptMode").removeClass("disabletxt").addClass("text-red");
                $("#lblReceivedAmount").removeClass("disabletxt").addClass("text-red");
                $("#lblInterest").removeClass("disabletxt").addClass("text-red");
                $("#lblTDS").removeClass("disabletxt").removeClass("text-red");
                $("#lblTDS_Prev").removeClass("disabletxt").removeClass("text-red");
                $("#lbl_FD_Txt_NRC_Date").text("Renewal Date:");
                $("#Lay_Select_Fd").show();
                $("#Lay_View_Fd").show();
                $("#Lay_FD_Bank").show();
                $("#Lay_Payment_Mode").hide();
                $("#Lay_Renewal_Amount").show();
                $("#lbl_TXT_RENEWAL_MATURITY_AMOUNT").text("Renewal Amt:");
                Control_SetReadOnly("FD_Txt_Amount", "dxNumberBox", true, "#696969");
                $("#FD_TXT_RENEWAL_MATURITY_AMOUNT").dxNumberBox("instance").option("placeholder", "Renewal Amount...");
                Control_SetReadOnly("FD_TXT_RENEWAL_MATURITY_AMOUNT", "dxNumberBox", false);
                await GLookUp_ItemList_EditValueChanged_FD(null, true);
                break;
            case "Close_FD":
                $("#lblRenewalTitle").text("FD Closure Detail:");
                Fieldset_SetDisable("C_R_Panel", false);
                $("#lblFDAct").removeClass("disabletxt").removeClass("text-red");
                $("#lblReceiptMode").removeClass("disabletxt").addClass("text-red");
                $("#lblReceivedAmount").removeClass("disabletxt").addClass("text-red");
                $("#lblInterest").removeClass("disabletxt").addClass("text-red");
                $("#lblTDS").removeClass("disabletxt").removeClass("text-red");
                $("#lblTDS_Prev").removeClass("disabletxt").removeClass("text-red");
                $("#lbl_FD_Txt_NRC_Date").text("FD Close Date:");
                $("#Lay_Select_Fd").show();
                $("#Lay_View_Fd").show();
                $("#Lay_FD_Bank").show();
                $("#Lay_Payment_Mode").hide();
                $("#Lay_Renewal_Amount").show();
                $("#lbl_TXT_RENEWAL_MATURITY_AMOUNT").text("Maturity Amt:");
                $("#FD_TXT_RENEWAL_MATURITY_AMOUNT").dxNumberBox("instance").option("placeholder", "Maturity Amount...");
