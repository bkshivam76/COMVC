                $("#Lay_Renewal").hide();
                break;
        }
        Control_SetReadOnly("FD_GLookUp_ItemList", "dxDropDownBox", true, "#696969");
        await LookUp_GetBankList_FD(true);
        if ("@Model.ActionMethod" == "_Edit" || "@Model.ActionMethod" == "_View" || "@Model.ActionMethod" == "_Delete")
        {
            Txt_V_Date_EditValueChanged_FD(null, true)           
            Cmd_Mode_SelectedIndexChanged(null, true)            
            if ("@Model.iAction" == "New_FD")
            {
                if ("@Model.FD_GLookUp_BankList".length > 0)
                {
                    await GLookUp_BankList_EditValueChanged_FD(null,true)
                }
                FD_Bank_ReadOnly = false;
                Control_SetReadOnly("FD_GLookUp_BankList", "dxDropDownBox", !(FD_Bank_Enabled == true && FD_Bank_ReadOnly == false));
                TXT_NRC_DATE_EditValueChanged(null,true)
                await GLookUp_ItemList_EditValueChanged_FD(null, true);
            }
            else if ("@Model.iAction" == "Renew_FD")
            {
                await GLookUp_FD_List_EditValueChanged(null,true);
                Control_SetReadOnly("GLookUp_FD_List", "dxDropDownBox", true, "#696969");
                if ("@Model.FD_Cmb_Rec_Mode".length > 0)
                {
                    //Redmine Bug#133709 fixed
                    Cmd_Mode_SelectedIndexChanged(null, true,true)
                }
                if ("@Model.FD_GLookUp_BankList".length > 0)
                {
                    await GLookUp_BankList_EditValueChanged_FD(null, true)
                    FD_Bank_ReadOnly = false;
                    Control_SetReadOnly("FD_GLookUp_BankList", "dxDropDownBox", !(FD_Bank_Enabled == true && FD_Bank_ReadOnly == false));
                }
                await GLookUp_ItemList_EditValueChanged_FD(null, true);
                TXT_NRC_DATE_EditValueChanged(null,true);
                TXT_REC_AMOUNT_EditValueChanged(null,true);
            }
            else if ("@Model.iAction" == "Close_FD")
            {
                await GLookUp_FD_List_EditValueChanged(null, true);
                Control_SetReadOnly("GLookUp_FD_List", "dxDropDownBox", true, "#696969");
                Cmd_Mode_SelectedIndexChanged(null, true, true)
                await GLookUp_ItemList_EditValueChanged_FD(null, true);
                TXT_REC_AMOUNT_EditValueChanged(null, true);
                TXT_NRC_DATE_EditValueChanged(null,true);
                if ("@Model.FD_GLookUp_BankList".length > 0)
                {
                    await GLookUp_BankList_EditValueChanged_FD(null, true)
                }
                FD_Bank_ReadOnly = false;
                Control_SetReadOnly("FD_GLookUp_BankList", "dxDropDownBox", !(FD_Bank_Enabled == true && FD_Bank_ReadOnly == false));
            }
            else if ("@Model.iAction".length == 0)
            {
                await GLookUp_FD_List_EditValueChanged();
                Control_SetReadOnly("GLookUp_FD_List", "dxDropDownBox", true, "#696969");
                if ("@Model.FD_Cmb_Rec_Mode".length > 0)
                {
                    Cmd_Mode_SelectedIndexChanged(null, true, true)
                }
                await GLookUp_ItemList_EditValueChanged_FD(null, true);
                TXT_REC_AMOUNT_EditValueChanged(null, true);
                if ("@Model.FD_GLookUp_BankList".length > 0)
                {
                    await GLookUp_BankList_EditValueChanged_FD(null, true)
                    FD_Bank_ReadOnly = false;
                    Control_SetReadOnly("FD_GLookUp_BankList", "dxDropDownBox", !(FD_Bank_Enabled == true && FD_Bank_ReadOnly == false));
                }
            }
        }
        else if ("@Model.ActionMethod" == "_New_From_Selection")
        {
            await GLookUp_ItemList_EditValueChanged_FD(null, true);
        }
        //FCRA Related
        if (parseInt("@Model.splVchrRefsCount_FD") == 0)
        {
            $("#FD_SpecialVoucherRefDiv").remove();
            $("#FD_NarrationDiv").removeClass("col-sm-12 col-md-8 col-lg-8").addClass("col-sm-12 col-md-12");
        }
        if (parseInt("@Model.splVchrRefsCount_FD") > 0)
        {
            OnSplVchrRefsListSelectionChanged_FD();
        }
        AdjustForm_FD();
        FormInitialSettings("id_Frm_Voucher_Win_FD", "@Model.Tag",false);
    });
