<div class="FDVoucher_ClearReferences">
@using DevExtreme.AspNet.Mvc;
@model ConnectOneMVC.Areas.Account.Models.Model_Frm_Voucher_Win_FD
@{ 
    bool FDVoucher_ViewRight = (bool)ViewData["FDVoucher_ViewRight"];   
}
<style>
    #FD_Txt_Ref_No {
        text-transform:uppercase;
    }
    /*FCRA Related*/
    #ListSpecialVoucherRef_FD .dx-list-item-content {
        padding: 4.5px;
    }
    </style>
<div id="Frm_Voucher_Win_FD_popup">
    @using (Ajax.BeginForm("Frm_Voucher_Win_FD", "FDVoucher",
        new AjaxOptions
        {
            HttpMethod = "POST",
            UpdateTargetId = "Frm_Voucher_Item_popup",
            InsertionMode = InsertionMode.InsertAfter,
            OnBegin = "AjaxBeginFormPost",
            OnSuccess = "AjaxSuccessVoucherWinFD",

        },
        new
        {
            id = "id_Frm_Voucher_Win_FD",
            @class = "edit_form"
        }))
    {
        @Html.HiddenFor(x => x.xID)
        @Html.HiddenFor(x => x.xMID)
        @Html.HiddenFor(x => x.CreatedFDID)
        @Html.HiddenFor(x => x.iVoucher_Type)
        @Html.HiddenFor(x => x.iTrans_Type)
        @Html.HiddenFor(x => x.iLed_ID)
        @Html.HiddenFor(x => x.iSpecific_ItemID)
        @Html.HiddenFor(x => x.Cnt_BankAccount)
        @Html.HiddenFor(x => x.iAction)
        @Html.HiddenFor(x => x.FDiAction)
        @Html.HiddenFor(x => x.LastEditedOn)
        @Html.HiddenFor(x => x.Info_LastEditedOn)
        @Html.HiddenFor(x => x.TitleX)
        @Html.HiddenFor(x => x.Tag)
        @Html.HiddenFor(x => x.ActionMethod)
        @Html.HiddenFor(x => x.GlookUp_BankList_REC_EDIT_ON)
        @Html.HiddenFor(x => x.FD_List_REC_EDIT_ON)
        @Html.HiddenFor(x => x.FD_MaturityDate)
        @Html.HiddenFor(x => x.FD_MaturityAmt)
        @Html.HiddenFor(x => x.xID_FDWindow)
        @Html.HiddenFor(x => x.GLookUp_BankListEnabled)
        @Html.HiddenFor(x => x.Look_BankList)
        @Html.HiddenFor(x => x.Look_BankList_RecEditOn)
        @Html.HiddenFor(x => x.FD_AsDate)
        @Html.HiddenFor(x => x.FdListBank_ID)
        @Html.HiddenFor(x => x.FD_Date)
        @Html.HiddenFor(x => x.FD_ItemID)
        @Html.HiddenFor(x => x.FD_SplVchrReferenceSelected)
        @Html.HiddenFor(x => x.splVchrRefsCount_FD)
        @Html.HiddenFor(x => x.FD_RenewFromFDNo)
        @Html.HiddenFor(x => x.In_UP_FD)
        @Html.HiddenFor(x => x.In_UP_FDHty)
        @Html.HiddenFor(x => x.In_UP_RenFDHis)

        using (Html.DevExtreme().ValidationGroup("FD_Voucher"))
        {
            <div class="full-width-header-bg">
                <div class="row">
                    <div class="col-sm-6">
                        <h3 class="popuphead"><i class="far fa-edit"></i>@Model.TitleX</h3>
                    </div>
                    <div class="col-sm-6">
                        <h5 class="mand-txt-align"><i class="fas fa-info-circle"></i> Red Fields are mandatory</h5>
                    </div>
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                </div>
            </div><!--[Header]-->
            <div class="row">
                <div class="col-sm-6">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-4 pll">
                                    @Html.Label("Item Name:", htmlAttributes: new { @class = "control-label text-red", @id = "lbl_FD_GLookUp_ItemList" })
                                </div>
                                <div class="col-sm-8 prm">
                                    @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("FD_GLookUp_ItemList").Name("FD_GLookUp_ItemList").ValueExpr("ITEMID").DisplayExpr("ITEMNAME").DataSource(Model.ItemData, "ITEMID")
                                          .Placeholder("Select Item..").OnValueChanged("GLookUp_ItemList_EditValueChanged_FD").ReadOnly(true).Value(Model.FD_GLookUp_ItemList).ContentTemplate(@<text>@Html.Partial("FD_LookUp_GetItemList")</text>))
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-4 pll">
                                    @Html.Label("Voucher Date:", htmlAttributes: new { @class = "control-label text-red", @id = "lbl_FD_Txt_V_Date" })
                                </div>
                                <div class="col-sm-8 prl">
                                    @(Html.DevExtreme().DateBox().CustomDateBox().ID("FD_Txt_V_Date").Name("FD_Txt_V_Date").OnValueChanged("Txt_V_Date_EditValueChanged_FD").Value(Model.FD_Txt_V_Date) )
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div><!--[Item/Voucher Date]-->
            <div class="row">
                <div class="col-sm-6">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-4 pll">
                                    @Html.Label("Head", htmlAttributes: new { @class = "control-label", @id = "lbl_FD_BE_Item_Head" })
                                </div>
                                <div class="col-sm-8 prm">
                                    @(Html.DevExtreme().TextBox().CustomTextBox().ID("FD_BE_Item_Head").Name("FD_BE_Item_Head").Placeholder("Head").Value(Model.FD_BE_Item_Head).ReadOnly(true) )
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-4 pll">
                                    @Html.Label("Voucher No", htmlAttributes: new { @class = "control-label", @id = "lbl_FD_Txt_V_NO" })
                                </div>
                                <div class="col-sm-8 prl">
                                    @(Html.DevExtreme().TextBox().CustomTextBox().ID("FD_Txt_V_NO").Name("FD_Txt_V_NO").Value(Model.FD_Txt_V_NO).ReadOnly(true).FocusStateEnabled(false))
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div><!--[Head/Voucher No]-->
            <div class="row">
                <div class="col-sm-6" id="Lay_Select_Fd">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-4 pll">
                                    @Html.Label("FD No:", htmlAttributes: new { @class = "control-label text-red", @id = "lbl_GLookUp_FD_List" })
                                </div>
                                <div class="col-md-6 col-sm-5 prm">
                                    @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_FD_List").Name("GLookUp_FD_List").ValueExpr("FD_ID").DisplayExpr("FD_NO").Value(Model.GLookUp_FD_List)
                                          .DataSource(Model.FDData,"FD_ID").Placeholder("Select F.D. No...").OnValueChanged("GLookUp_FD_List_EditValueChanged").ContentTemplate(@<text>@Html.Partial("FD_LookUp_GetFDList")</text>))
                                </div>

                                <div class="col-md-2 col-sm-3 prm" id="Lay_View_Fd">

                                    @(Html.DevExtreme().Button().ID("ViewFD").Text("View").OnClick("BTN_FD_DET_Click"))

                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[FD No.]-->
                <div class="col-sm-6" id="div_fd_amount">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-4 pll" id="div_fd_amount_lbl">
                                    @Html.Label("FD Amount:", htmlAttributes: new { @class = "control-label text-red", @id = "lbl_FD_Txt_Amount" })
                                </div>
                                <div class="col-sm-8 prl" id="div_fd_amount_nb">
                                    @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("FD_Txt_Amount").Name("FD_Txt_Amount").Placeholder("Type FD Amount...").Format("#.##").Value(Model.FD_Txt_Amount))

                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[FD Amount]-->
            </div> <!--[FD No./FD Amount]-->
            <div class="row" id="div_renewdate_Fdbank">
                <div class="col-sm-6" id="Lay_NRC_Date">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-4 pll" id="div_fd_renewdate_lbl">
                                    @Html.Label("Renew Date:", htmlAttributes: new { @class = "control-label text-red", @id = "lbl_FD_Txt_NRC_Date" })
                                </div>
                                <div class="col-sm-8 prm" id="div_fd_renewdate">
                                    @(Html.DevExtreme().DateBox().CustomDateBox().ID("FD_TXT_NRC_DATE").Name("FD_TXT_NRC_DATE").Placeholder("Date..").OnValueChanged("TXT_NRC_DATE_EditValueChanged").Value(Model.FD_TXT_NRC_DATE).ElementAttr("OnClick", "TXT_NRC_DATE_Click()") )
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Renew Date]-->
                <div class="col-sm-6" id="Lay_FD_Bank">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-4 pll" id="div_fd_bank_lbl">
                                    @Html.Label("FD Bank:", htmlAttributes: new { @class = "control-label text-red", @id = "lbl_FD_TXT_Fd_Bank" })
                                </div>
                                <div class="col-sm-8 prl" id="div_fd_bank">
                                    @(Html.DevExtreme().TextBox().CustomTextBox(true,true).ID("FD_TXT_Fd_Bank").Name("FD_TXT_Fd_Bank").Placeholder("Bank's Name").ReadOnly(true).Value(Model.FD_TXT_Fd_Bank) )

                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[FD Bank]-->
            </div><!--[RenewDate/FD Bank]-->
            <div class="row" id="div_fd_paymode_renewamt">
                <div class="col-sm-6" id="Lay_Payment_Mode">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-4 pll" id="div_fd_paymode_lbl">
                                    <label class="control-label text-red" for="Name" id="lbl_FD_Cmd_Mode">Paymt Mode :</label>
                                </div>
                                <div class="col-sm-8 prm" id="div_fd_paymode">
                                    @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("FD_Cmd_Mode").Name("FD_Cmd_Mode").Placeholder("Select Payment Mode..").ShowClearButton(false).Value(Model.FD_Cmd_Mode)
                                                                               .DataSource(new[] { "CHEQUE", "DD", "BANK ACCOUNT", "CASH" }).OnValueChanged("Cmd_Mode_SelectedIndexChanged") )
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[payment mode]-->
                <div class="col-sm-6" id="Lay_Renewal_Amount">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-4 pll" id="div_fd_renewamt_lbl">
                                    <label class="control-label text-red" for="Name" id="lbl_TXT_RENEWAL_MATURITY_AMOUNT">Renewal Amt</label>
                                </div>
                                <div class="col-sm-8 prl" id="div_fd_renewamt">
                                    @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("FD_TXT_RENEWAL_MATURITY_AMOUNT").Name("FD_TXT_RENEWAL_MATURITY_AMOUNT").Placeholder("Amount...").OnValueChanged("TXT_REC_AMOUNT_EditValueChanged").Format("#0.00").Value(Model.FD_TXT_RENEWAL_MATURITY_AMOUNT) )@* Redmine Bug #133690 fixed  *@

                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Renewal Amount]-->
            </div> <!--[Paymentmode/Renewal Amount]-->
            <div class="row">
                <div class="col-sm-6" id="Lay_Renewal">
                    <div class="form-field">
                        <div class="container-fluid">
                            <fieldset class="default-fieldset" id="C_R_Panel">
                                <legend class="custom-legend mlm"><label id="lblRenewalTitle" class="disabletxt"> FD Renewal Detail:</label></legend>
                                <div class="row">
                                    <div class="col-sm-4 pll">
                                        <label id="lblFDAct" class="control-label" for="Name">FD Action:</label>
                                    </div>
                                    <div class="col-sm-8 prl">
                                        @(Html.DevExtreme().TextBox().CustomTextBox(true,true).Name("FD_TXT_FD_ACT").MaxLength(25).ID("FD_TXT_FD_ACT").ReadOnly(true).Placeholder("").Value(Model.FD_TXT_FD_ACT) )
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-4 pll">
                                        <label class="control-label text-red" for="Name" id="lblReceivedAmount">Amount Recd:</label>
                                    </div>
                                    <div class="col-sm-8 prl">
                                        @(Html.DevExtreme().NumberBox().CustomNumberBox().Name("FD_TXT_REC_AMOUNT").ID("FD_TXT_REC_AMOUNT").Placeholder("Total Amt with interest...").Format("#0.00").OnValueChanged("TXT_REC_AMOUNT_EditValueChanged").Value(Model.FD_TXT_REC_AMOUNT)) @*Redmine Bug #132902 fixed*@
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-4 pll">
                                        <label class="control-label text-red" for="Name" id="lblInterest">Interest:</label>
                                    </div>
                                    <div class="col-sm-8 prl">
                                        @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("FD_TXT_INTEREST").Name("FD_TXT_INTEREST").ReadOnly(true).Placeholder("Interest Not Accounted yet...").Format("#0.00").Value(Model.FD_TXT_INTEREST) )
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-4 pll">
                                        <label id="lblReceiptMode" class="control-label disabletxt" for="Name">Receipt Mode:</label>
                                    </div>
                                    <div class="col-sm-8 prl">
                                        @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("FD_Cmb_Rec_Mode").Name("FD_Cmb_Rec_Mode").Placeholder("Select Receipt Mode...").DataSource(new[] { "CHEQUE", "DD", "BANK ACCOUNT", "CASH" }).Value(string.IsNullOrWhiteSpace(Model.FD_Cmb_Rec_Mode)?"BANK ACCOUNT": Model.FD_Cmb_Rec_Mode).OnValueChanged("Cmd_Mode_SelectedIndexChanged").ReadOnly(true).ShowClearButton(false) )
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-4 pll">
                                        <label id="lblTDS" class="control-label" for="Name">TDS Deduction:</label>
                                    </div>
                                    <div class="col-sm-8 prl">
                                        @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("FD_TXT_TDS").Name("FD_TXT_TDS").Placeholder("UnAccounted TDS Yet...").Format("#0.00").Value(Model.FD_TXT_TDS) )
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-4 pll">
                                        <label id="lblTDS_Prev" class="control-label" for="Name">TDS (Previous):</label>
                                    </div>
                                    <div class="col-sm-8 prl">
                                        @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("FD_TXT_TDS_PREV").Name("FD_TXT_TDS_PREV").Placeholder("TDS Already Accounted...").ReadOnly(true).Format("#0.00").Value(Model.FD_TXT_TDS_PREV) )
                                    </div>
                                </div>
                            </fieldset>
                        </div>
                    </div>
                </div><!--[Renewal Detail]-->
                <div class="col-sm-6" id="FD_BankDetailDiv">
                    <div class="form-field">
                        <div class="container-fluid">
                            <fieldset class="default-fieldset" id="PanelControl3">
                                <legend class="custom-legend mlm"><label id="lbl_Ref_Title" class="disabletxt"> Bank Payment detail for FD:</label></legend>
                                <div class="row">
                                    <div class="col-sm-4 pll" id="div_fd_bank_name_lbl">
                                        <label id="lbl_Ref_Bank" class="control-label disabletxt" for="Name">Bank Name:</label>
                                    </div>
                                    <div class="col-sm-8 prl" id="div_fd_bank_name">
                                        @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("FD_GLookUp_BankList").Name("FD_GLookUp_BankList").ValueExpr("BA_ID").DisplayExpr("BANK_NAME").Value(Model.FD_GLookUp_BankList)
                                              .DataSource(Model.BankData,"BA_ID").Placeholder("Select Bank...").OnValueChanged("GLookUp_BankList_EditValueChanged_FD").ContentTemplate(@<text>@Html.Partial("FD_LookUp_GetBankList")</text>).ReadOnly(true))
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-4 pll" id="div_fd_bank_branch_lbl">
                                        <label class="control-label disabletxt" for="Name" id="lbl_Branch">Branch:</label>
                                    </div>
                                    <div class="col-sm-8 prl" id="div_fd_bank_branch">
                                        @(Html.DevExtreme().TextBox().CustomTextBox(true,true).Name("FD_Txt_Branch").MaxLength(25).ID("FD_Txt_Branch").ReadOnly(true).Value(Model.FD_Txt_Branch) )
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-4 pll" id="div_fd_bank_account_lbl">
                                        <label class="control-label disabletxt" for="Name" id="lbl_Account_No">Account No :</label>
                                    </div>
                                    <div class="col-sm-8 prl" id="div_fd_bank_account">
                                        @(Html.DevExtreme().TextBox().CustomTextBox(true,true).ID("FD_Txt_AccountNo").Name("FD_Txt_AccountNo").ReadOnly(true).MaxLength(25).Value(Model.FD_Txt_AccountNo) )
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-4 pll" id="div_fd_bank_refno_lbl">
                                        <label id="lbl_Ref_No" class="control-label disabletxt" for="Name">Ref No:</label>
                                    </div>
                                    <div class="col-sm-8 prl" id="div_fd_bank_refno">
                                        @(Html.DevExtreme().TextBox().CustomTextBox(true,true).ID("FD_Txt_Ref_No").Name("FD_Txt_Ref_No").MaxLength(25).Placeholder("Type No...").Value(Model.FD_Txt_Ref_No) )
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-4 pll" id="div_fd_bank_date_lbl">
                                        <label id="lbl_Ref_Date" class="control-label disabletxt" for="Name">Date:</label>
                                    </div>
                                    <div class="col-sm-8 prl" id="div_fd_bank_date">
                                        @(Html.DevExtreme().DateBox().CustomDateBox().ID("FD_Txt_Ref_Date").Name("FD_Txt_Ref_Date").Placeholder("dd-MM-yyyy").OnValueChanged("refdatechange").Min("01/01/1936").Value(Model.FD_Txt_Ref_Date) )
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-4 pll" id="div_fd_bank_cdate_lbl">
                                        <label id="lbl_Ref_Cdate" class="control-label disabletxt" for="Name">Clearing :</label>
                                    </div>
                                    <div class="col-sm-8 prl" id="div_fd_bank_cdate">
                                        @(Html.DevExtreme().DateBox().CustomDateBox().ID("FD_Txt_Ref_CDate").Name("FD_Txt_Ref_CDate").Placeholder("dd-MM-yyyy").OnValueChanged("refdatechange").Min("01/01/1936").Value(Model.FD_Txt_Ref_CDate))
                                    </div>
                                </div>
                            </fieldset>
                        </div>
                    </div>
                </div><!--[Bank Payment Detail]-->
            </div><!--[Rnewal/Bank Payment Detail]-->

            <div class="row">
                <div id="FD_NarrationDiv" class="col-sm-12 col-md-8 col-lg-8">
                    <div class="row">
                        <div class="col-sm-12">
                            <div class="form-field">
                                <div class="container-fluid">
                                    <div class="row">
                                        <div class="col-sm-2 pll">
                                            <label class="control-label" for="Name" id="lbl_FD_Txt_Narration">Narration :</label>
                                        </div>
                                        <div class="col-sm-10 prl">
                                            @(Html.DevExtreme().TextBox().CustomTextBox(true).ID("FD_Txt_Narration").Name("FD_Txt_Narration").Value(Model.FD_Txt_Narration).Placeholder("Type any Narration...").MaxLength(250) )
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div><!--[Narration]-->
                    <div class="row">
                        <div class="col-sm-12">
                            <div class="form-field">
                                <div class="container-fluid">
                                    <div class="row">
                                        <div class="col-sm-2 pll">
                                            <label class="control-label" for="Name" id="lbl_FD_Txt_Remarks">Remarks :</label>
                                        </div>
                                        <div class="col-sm-10 prl">
                                            @(Html.DevExtreme().TextBox().CustomTextBox(true).ID("FD_Txt_Remarks").Name("FD_Txt_Remarks").Value(Model.FD_Txt_Remarks).Placeholder("Type any Other Detail/Remarks...").MaxLength(250) )
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div><!--[Remarks]-->
                    <div class="row">
                        <div class="col-sm-12">
                            <div class="form-field">
                                <div class="container-fluid">
                                    <div class="row">
                                        <div class="col-sm-2 pll">
                                            <label class="control-label" for="Name" id="lbl_FD_Txt_Reference">Reference :</label>
                                        </div>
                                        <div class="col-sm-10 prl">
                                            @(Html.DevExtreme().TextBox().CustomTextBox(true).ID("FD_Txt_Reference").Name("FD_Txt_Reference").Value(Model.FD_Txt_Reference).Placeholder("Type any Reference Details...").MaxLength(250) )
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div><!--[Reference]-->

                    <div class="row">
                        <div class="col-sm-12">
                            <div class="form-field">
                                <div class="container-fluid">
                                    <div class="row">
                                        <div class="col-sm-2 pll">
                                            <label class="control-label text-red" id="lbl_cdw_purpose" for="Name">Purpose:</label>
                                        </div>
                                        <div class="col-sm-10 prl">
                                            @(Html.DevExtreme().SelectBox().CustomSelectBox()
                                                .ID("PurposeID_FD").Name("PurposeID_FD")
                                                .DataSource(d => d.Mvc().Controller("FDVoucher")
                                                .LoadAction("LookUp_GetPurposeList").Key("PUR_ID").LoadMode(DataSourceLoadMode.Raw))
                                                .DisplayExpr("PUR_NAME").ValueExpr("PUR_ID")
                                                .Value(Model.PurposeID_FD).Placeholder("Select Purpose...")
                                             )
                                            @Html.ValidationMessageFor(model => model.PurposeID_FD, "", new { @class = "text-red" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div><!--[Purpose]-->
                </div>
                <div class="col-sm-12 col-md-4 col-lg-4" id="FD_SpecialVoucherRefDiv">
                    <div class="form-field ">
                        <div class="dx-texteditor-container">
                            @(Html.DevExtreme().List().CustomList().ID("ListSpecialVoucherRef_FD")
                                .DataSource(Model.SpecialReferenceList_Data_FD, "Task_Name")
                                .SearchEnabled(false)
                                .SelectionMode(DevExtreme.AspNet.Mvc.ListSelectionMode.Multiple)
                                .KeyExpr("Task_Name")
                                .DisplayExpr("Task_Name")
                                .OnSelectionChanged("OnSplVchrRefsListSelectionChanged_FD")
                                .Height(123).ShowScrollbar(ShowScrollbarMode.Always).UseNativeScrolling(false)
                                .ShowSelectionControls(true)
                                .SelectedItemKeys(Model.SpecialReference_Get_SelectedValue_FD))
                        </div>
                    </div>
                </div>
            </div>

            

            <div class="row">
                <div class="col-sm-12 col-md-12 col-lg-12">
                    <div class="row">
