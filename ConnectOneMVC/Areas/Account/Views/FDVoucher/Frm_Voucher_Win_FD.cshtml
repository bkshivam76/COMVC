                            @Html.Partial("Drop_Request", String.Format("Send Your Request to Madhuban for ( {0} ~ {1})...", Model.ActionMethod.Substring(1), Model.TitleX))
                        </div>
                        <div class="col-sm-6 col-md-6 col-lg-6">
