@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
}
@(Html.DevExtreme().DataGrid().CustomDataGridListing()
                 .ID("FDVoucherListGrid")
                 .DataSource(s => s.Array().Key("ITEMID").Data(Model))
                 .Columns(columns =>
                 {
                     columns.Add().DataField("Sr").Caption("Sr").Visible(false).SortOrder(SortOrder.Asc);
                     columns.Add().DataField("FDActivity").Caption("FD Activity").SortOrder(SortOrder.Desc);
                     columns.Add().DataField("ITEMID").Caption("Item ID").Visible(false);
                 })                            
         .OnInitialized("FDVoucherListGrid_Init")
         .OnSelectionChanged("FDVoucherListGrid_SelectionChanged")
         .OnContentReady("FDVoucherListGrid_ContentReady")
         .OnKeyDown("FDVoucherListGrid_KeyDown")
         .Paging(s=>s.Enabled(false))
         .Pager(s => s.Visible(false))
         .FilterRow(s=>s.Visible(false))
         .FilterPanel(s=>s.Visible(false))
         .HeaderFilter(s=>s.Visible(false))      
)
