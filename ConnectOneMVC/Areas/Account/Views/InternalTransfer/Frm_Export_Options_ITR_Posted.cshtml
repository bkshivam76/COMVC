<div class="ITR_ExportPosted_ClearReferences">
    @using DevExtreme.AspNet.Mvc
    <div>
        @(Html.DevExtreme().Button()
                                .ID("SI_ExportGridDatapdf")
                                .Text("Export to PDF")
                                .OnClick("ExportPDF")
                                .Visible(true)
                                .Width(120)
    )<br />

        @(Html.DevExtreme().Button()
                                .ID("SI_ExportGridDataxls")
                                .Text("Export to XLS")
                                .OnClick("ExportXLS")
                                .Visible(true)
                                .Width(120)
    )<br />
        @(Html.DevExtreme().Button()
                                .ID("SI_ExportGridDataxlsx")
                                .Text("Export to XLSX")
                                .OnClick("ExportXLSX")
                                .Visible(true)
                                .Width(120)
    )<br />

        @(Html.DevExtreme().Button()
                                .ID("SI_ExportGridDatadocx")
                                .Text("Export to DOCX")
                                .OnClick("ExportDOCX")
                                .Visible(true)
                                .Width(120)
    )<br />

        @(Html.DevExtreme().Button()
                                .ID("SI_ExportGridDatartf")
                                .Text("Export to RTF")
                                .OnClick("ExportRTF")
                                .Visible(true)
                                .Width(120)
    )<br />

        @(Html.DevExtreme().Button()
                                .ID("SI_ExportGridDatacsv")
                                .Text("Export to CSV")
                                .OnClick("ExportCSV")
                                .Visible(true)
                                .Width(120)
    )
    </div>
    <script>
        function ExportPDF() {
            ITR_PostedGrid.ExportTo(ASPxClientGridViewExportFormat.Pdf);
            $("#ITR_report_modal").dxPopup("hide");
        }
        function ExportXLS() {
            ITR_PostedGrid.ExportTo(ASPxClientGridViewExportFormat.Xls);
            $("#ITR_report_modal").dxPopup("hide");
        }
        function ExportXLSX() {
            ITR_PostedGrid.ExportTo(ASPxClientGridViewExportFormat.Xlsx);
            $("#ITR_report_modal").dxPopup("hide");
        }
        function ExportCSV() {
            ITR_PostedGrid.ExportTo(ASPxClientGridViewExportFormat.Csv);
            $("#ITR_report_modal").dxPopup("hide");
        }
        function ExportDOCX() {
            ITR_PostedGrid.ExportTo(ASPxClientGridViewExportFormat.Docx);
            $("#ITR_report_modal").dxPopup("hide");
        }
        function ExportRTF() {
            ITR_PostedGrid.ExportTo(ASPxClientGridViewExportFormat.Rtf);
            $("#ITR_report_modal").dxPopup("hide");
        }
    </script>

   
 </div>

