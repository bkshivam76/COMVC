@{
    string ExportGridHeaderLeft = (string) ViewBag.ExportGridHeaderLeft;
    string ExportGridHeaderRight = (string)ViewBag.ExportGridHeaderRight;
    string ExportGridFooter = (string)ViewBag.ExportGridFooter;//Redmine bug 132871 fixed
    var SessionGUID = Request.QueryString["SessionGUID"];
}
@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "PendingInternalTransferListGrid";
        settings.CallbackRouteValues = new
        {
            Controller = "InternalTransfer",
            Action = "Frm_I_Transfer_Pending_Grid",
            SessionGUID = SessionGUID
        };
        settings.ClientSideEvents.BeginCallback = "PendingBeginCallBack";//Redmine bug 132871 fixed
        settings.ClientSideEvents.EndCallback = "PendingEndCallBack";//Redmine Bug #132901 fixed

        settings.CustomDataActionRouteValues = new { Controller = "InternalTransfer", Action = "pInternalTransferCustomDataAction" };

        settings.ClientSideEvents.FocusedRowChanged = "OnGridFocusedRowChanged";


        settings.FillContextMenuItems = (sender, e) =>
        {
            if (e.MenuType == GridViewContextMenuType.Rows)
            {
                var Accept = e.CreateItem("Accept Transfer", "Accept");
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Accept);
                var PrintView = e.CreateItem("List Preview", "ListPreview");
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), PrintView);
                var Close = e.CreateItem("Close", "Close");
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Close);
            }
        };
        settings.Styles.Row.Wrap = DefaultBoolean.False;
        settings.SettingsBehavior.AllowEllipsisInText = true;
        settings.ClientSideEvents.ContextMenuItemClick = "ContextMenuFunction";

        settings.KeyFieldName = "ID";

        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Centre_Name",
            Caption = "Centre Name"    ,
            Width=200
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Centre_UID",
            Caption = "Centre ID",
            Width =95
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "No",
            Caption = "No.",
            Width = 60
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Zone",
            Caption = "Zone",
            Width = 60
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Sub_Zone",
            Caption = "Sub Zone",
            Width = 90
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Date",
            Caption = "Date",
            PropertiesEdit = { DisplayFormatString = "dd-MM-yyyy" },
            Width=80

        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Mode",
            Caption = "Mode",
            Width =70
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Amount",
            Caption = "Amount",
            Width = 80
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Bank_Name",
            Caption = "Bank Name",
            Width = 150
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Branch_Name",
            Caption = "Branch Name",
            Width = 130
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Bank_Ac_No",
            Caption = "Bank A/c. No.",
            Width = 120
        });
        settings.Columns.Add("Incharge").Caption = "Incharge";
        settings.Columns.Add("Contact_No").Caption = "Contact No.";
        settings.Columns.Add("Purpose").Caption = "Purpose";
        settings.Columns.Add("Ref_No").Caption = "Ref No.";
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Ref_Date",
            Caption = "Ref.Date",
            PropertiesEdit = { DisplayFormatString = "dd-MM-yyyy" },
            Width = 85

        });
        settings.Columns.Add("Narration").Caption = "Narration";

        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Description",
            Caption = "Description",
            GroupIndex = 0,
            Visible = false
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
