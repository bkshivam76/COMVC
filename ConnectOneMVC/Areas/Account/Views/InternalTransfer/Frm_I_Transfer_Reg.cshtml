                    DevExpress.ui.dialog.alert(data.message, 'Error!');
                }
                else if (data.result == true)
                {
                    multiuser_confirm = true;
                }
                else if (data.result == "MultiUser_Confirm")
                {
                    var confirm = DevExpress.ui.dialog.confirm(data.message, 'Confirm!');
                    confirm.done(function (dialogResult)
                    {
                        if (dialogResult)
                        {
                            multiuser_confirm = true;
                        }
                        else
                        {
                            multiuser_confirm = false;
                        }
                    });
                }
            }
        });
        if (multiuser_confirm)
        {
            $.ajax({
                type: 'GET',
                url: "/Account/InternalTransfer/Checks_Edit_DeleteClick_ITR",
                async:false,
                cache: false,
                data: { Posted_Id: ITR_Posted_ID },
                success: function (data)
                {
                    if (data.result == false)
                    {
                        DevExpress.ui.dialog.alert(data.message, 'Inform !');
                        if (data.refreshGrid)
                        {
                            ITR_PostedGrid.Refresh();
                        }
                    }
                    else if (data.result == true)
                    {
                        Delete_Check_Passed = true;
                    }
                }
            });
        }
        if (Delete_Check_Passed)
        {
            ShowLoader();
            OpenDynamicPopup("Delete ~ Internal Transfer", "@Url.Action("Frm_Voucher_Win_I_Transfer", "InternalTransfer", new { @area = "Account" })?Tag=_Delete&RegisterGridRowID=" + ITR_Posted_ID + "&_Delete_From_Register=" + true, "auto", 1000, false, null);
        }
    }// delete clicked
    function OnITRListPreviewClick()
    {
        ShowLoader();
        OpenPopup("ITR_report_modal", "Export Option", "@Url.Action("Frm_Export_Options", "InternalTransfer", new { @area = "Account" })?SelectedIndex=" + $("#ITR_Gridpanel").dxTabPanel("instance").option("selectedIndex"), "auto", "20%", false, null);// redmine bug #132961 fixed
    }
    function OnITRAddAttachment(ID)
