<div class="InternalTransferRegister_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    @model ConnectOneMVC.Areas.Account.Models.InternalTransferRegister
    @{
        Layout = null;
        Html.EnableClientValidation();
        Html.EnableUnobtrusiveJavaScript();
        Html.AntiForgeryToken();
        string UserType = (string)ViewBag.UserType;
        bool Help_Attachment_AddRight = (bool)ViewData["Help_Attachment_AddRight"];//attachment
        bool Help_Attachment_EditRight = (bool)ViewData["Help_Attachment_EditRight"];//attachment
        bool Help_Attachment_ViewRight = (bool)ViewData["Help_Attachment_ViewRight"];//attachment
        bool Help_Attachment_DeleteRight = (bool)ViewData["Help_Attachment_DeleteRight"];//attachment
        bool IntrnlTranfrReg_Auto_Vouching_Mode = (bool)ViewData["IntrnlTranfrReg_Auto_Vouching_Mode"];
        bool IsVolumeCentre = (bool)ViewBag.IsVolumeCentre;
    }
    <link href="/content/fontawesome/css/fontawesome-all.css" rel="stylesheet">
    <style>
        .filter_btn i {
            background: #86c13e;
        }

        .find_btn i {
            background: #81b4df;
        }

        .addEditDiv {
            padding: 2px 0;
        }

            .addEditDiv p {
                margin: 0;
            }

        .rightDiv {
            display: flex;
            justify-content: flex-end;
        }
    </style>
    @Html.HiddenFor(x => x.xID)
    <div class="ITR_Reg_ParentDiv clearfix">
        <div id="ITR_Reg_content" class="col-md-12 report_header_div_main">
            <div class="col-md-4 padd report_header_div">
                <label class="report_header_label">Internal Transfers Register</label>
            </div>
            <div class="report_button_div">
                @(Html.DevExtreme().Switch().ID("IntrnlTranfrRegVouchingModeSwitch").SwitchedOnText("Vouching On").SwitchedOffText("Vouching Off").OnValueChanged("IntrnlTranfrReg_VouchingSwitch_ValueChange").Width(100).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
                @(Html.DevExtreme().Switch().ID("IntrnlTranfrRegViewModeSwitch").SwitchedOnText("Compact").SwitchedOffText("Default").OnValueChanged("IntrnlTranfrReg_ViewSwitch_ValueChange").Width(70).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
                @(Html.DevExtreme().Button().ID("ITR_Edit").Text("Edit").Icon("edit").OnClick(@<text> function () { DataNavigation_ITR("EDIT"); } </text>) )
                @(Html.DevExtreme().Button().ID("ITR_Delete").Text("Delete").Icon("trash").OnClick(@<text> function () { DataNavigation_ITR("DELETE"); } </text>) )
                @(Html.DevExtreme().Button().ID("ITR_View").Text("View").Icon("doc").OnClick(@<text> function () { DataNavigation_ITR("VIEW"); } </text>) )
                @(Html.DevExtreme().Button().ID("ITR_Accept").Text("Accept Transfer").Icon("fas fa-check-circle btn-icons checkgreen icon-rgt-space5").OnClick(@<text> function () {DataNavigation_ITR("ACCEPT"); } </text>) )
                @(Html.DevExtreme().Button().ID("ITR_listPreview").Text("List Preview").Icon("print").OnClick(@<text> function () { OnITRListPreviewClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("ITR_Close").Text("Close").Icon("close").OnClick(@<text> function (){$(".TabPanalMenu-tabs .active span").click()} </text>) )

            </div>
        </div>
    </div>@*Header*@
    <div>
        @(Html.DevExtreme().TabPanel().ID("ITR_Gridpanel").Items(items =>
                                                                                {
                                                                                    items.Add().Title("Currently Posted Entries").Template(@<text> @CurrentlyPostedView() </text>);
                                                                                            items.Add().Title("Pending Entries To Be Accepted By Us").Template(@<text> @PendingEntriesView() </text>);
                                                                                                }).DeferRendering(false).OnSelectionChanged("ITR_Gridpanel_selectionChanged"))
        @helper CurrentlyPostedView()
        {
            @Html.Partial("ITR_CurrentlyPosted", Model);
        }
        @helper PendingEntriesView()
        {
            @Html.Partial("ITR_PendingEntries", Model);
        }
    </div>@*Grid Tabs*@
    @Html.Partial("AttachmentFAB", "ITR_PostedPrf_FAB,ITR_Reg_ParentDiv,Type1,ITR_Posted," + UserType)@*fab buttons*@

    @(Html.DevExtreme().Popup().CustomPopup().ID("ITR_report_modal").OnShowing("PopupOnShowing").Title("Pending Internal Transfer").FullScreen(false).MaxWidth(125).Height("auto").ShowCloseButton(true).ContentTemplate(@<text> <div id='ITR_report_modal_result'> </div> </text>) )
    @(Html.DevExtreme().Popup().CustomPopup().ID("ITR_manage_Attachment").OnShowing("PopupOnShowing").DragEnabled(true).Height(250).Width(850).ShowCloseButton(true).ContentTemplate(@<text> <div id="ITR_manage_Attachment_result"> </div> </text>))

