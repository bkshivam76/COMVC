    <script>
        

        function On_ITR_Posted_FABActionItemClick(s, e) {
            var img = document.getElementById('RightPane_Img');
            s.ExpandActionGroupItems();
            if (e.actionName === "add_attach") {
                if (Help_Attachment_AddRight == "False") {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                if (ITR_Posted_ParamMandatory == 1) {
                    AddAttachment(ITR_Posted_RecID_ForAttachment, "Accounts_CashBook", ITR_Posted_Doc_ID, ITR_Posted_Doc_Category, ITR_Posted_ParamMandatory, ITR_Posted_FromDateLabel, ITR_Posted_ToDateLabel, ITR_Posted_DescriptionLabel, "ITR_PostedProfileAttachment", null, "ITR_PostedGrid", ITR_Posted_NestedGrid_AccessID);
                }
                else {
                    Attachment_DirectBrowse(ITR_Posted_RecID_ForAttachment, "Accounts_CashBook", ITR_Posted_Doc_ID, "ITR_PostedProfileAttachment", "ITR_PostedGrid", ITR_Posted_NestedGrid_AccessID);
                }
            }
            else if (e.actionName === "edit_attach") {
                if (Help_Attachment_EditRight == "False") {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                if (ITR_Posted_Attachment_RecStatus.toUpperCase() == "LOCKED") {
                    DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                    return;
                }
                EditAttachment(ITR_Posted_RecID_ForAttachment, "Accounts_CashBook", ITR_Posted_AtachmentID, ITR_Posted_ParamMandatory, ITR_Posted_FromDateLabel, ITR_Posted_ToDateLabel, ITR_Posted_DescriptionLabel, "ITR_PostedProfileAttachment", null, "ITR_PostedGrid", ITR_Posted_NestedGrid_AccessID);
            }
            else if (e.actionName === "delete_attach") {
                if (Help_Attachment_DeleteRight == "False") {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                DeleteAttachment(ITR_Posted_RecID_ForAttachment, "Accounts_CashBook", ITR_Posted_AtachmentID, ITR_Posted_ParamMandatory, ITR_Posted_FromDateLabel, ITR_Posted_ToDateLabel, ITR_Posted_DescriptionLabel, null, "ITR_PostedGrid", ITR_Posted_NestedGrid_AccessID, ITR_Posted_Attachment_RecStatus);
            }
            else if (e.actionName === "view_attach") {
                if (Help_Attachment_ViewRight == "False") {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                ViewDocument(ITR_Posted_AtachmentID, ITR_Posted_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
            }
            else if (e.actionName == "Link_Attach") {
                LinkAttachment(ITR_Posted_RecID_ForAttachment, "Accounts_CashBook", "Internal Transfers Register", "ITR_PostedGrid", ITR_Posted_NestedGrid_AccessID);
            }
            else if (e.actionName === "Add_Reason") {
                if (ITR_Posted_Doc_Category.toLowerCase() == "others") {
                    DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
                }
                else {
                    AttachmentAddReason(ITR_Posted_RecID_ForAttachment, ITR_Posted_NestedRowMapID, "Accounts_CashBook", "ITR_PostedGrid", ITR_Posted_NestedGrid_AccessID);
                }
            }
            else if (e.actionName === "Edit_Reason") {
                AttachmentEditReason(ITR_Posted_RecID_ForAttachment, ITR_Posted_NestedRowMapID, "Accounts_CashBook", "ITR_PostedGrid", ITR_Posted_NestedGrid_AccessID, ITR_Posted_reason);
            }
            else if (e.actionName === "Delete_Reason") {
                AttachmentDeleteReason(ITR_Posted_RecID_ForAttachment, ITR_Posted_NestedRowMapID, "ITR_PostedGrid", ITR_Posted_NestedGrid_AccessID);
            }
            else if (e.actionName === "Rotate") {
                ImageRotate(img);
            }
            else if (e.actionName === "ZoomOut") {
                ImageZoomOut(img);
            }
            else if (e.actionName === "ZoomIn") {
                ImageZoomIn(img);
            }
            else if (e.actionName == "Fit") {
                ImageFit(img);
            }
            else if (e.actionName == "Back") {
                ImageBack(s.uniqueID, "actionItemContext");
            }
            else if (e.actionName == "AuditAction") {
                ITR_PostedPrf_FAB.SetActionContext("AuditActionContext", true);
            }
            else if (e.actionName == "BackAudit") {
                if (ITR_Posted_Nested_Doc_Status == "") {
                    ITR_PostedPrf_FAB.SetActionContext("AutoItemContext", true);
                }
                if (ITR_Posted_Nested_Doc_Status == "NO") {
                    ITR_PostedPrf_FAB.SetActionContext("EditItemContext", true);
                }
                if (ITR_Posted_Nested_Doc_Status == "YES") {
                    ITR_PostedPrf_FAB.SetActionContext("actionItemContext", true);
                }
            }
            else if (e.actionName == "Accept") {
                ITR_Posted_AcceptwithoutRemarks();
            }
            else if (e.actionName == "Reject") {
                ITR_Posted_AcceptRejectVoucher("Reject");
            }
            else if (e.actionName == "AcceptWithRemarks") {
                ITR_Posted_AcceptRejectVoucher("Accept");
            }
        }
        function ITR_Posted_AcceptwithoutRemarks() {
            var Recid;
            if (ITR_Posted_IsDetailRowExpanded == true || IntrnlTranfrReg_IsVouchingMode == true) {
                if (ITR_Posted_MasterRowRecID == null || ITR_Posted_MasterRowRecID == "") {
                    Recid = ITR_Posted_MasterRowMID;
                }
                else {
                    Recid = ITR_Posted_MasterRowRecID;
                }
            }
            else {
                Recid = ITR_Posted_ID;
            }
            Entry_AcceptwithoutRemarks(Recid, "Accounts_CashBook", "ITR_PostedGrid", ITR_Posted_AtachmentID, ITR_Posted_NestedRowReasonID, ITR_Posted_NestedRowKeyValue);
        }
        function ITR_Posted_AcceptRejectVoucher(_actionMethod) {
            var Recid;

            if (ITR_Posted_IsDetailRowExpanded == true || IntrnlTranfrReg_IsVouchingMode == true) {
                if (ITR_Posted_MasterRowRecID == null || ITR_Posted_MasterRowRecID == "") {
                    Recid = ITR_Posted_MasterRowMID;
                }
                else {
                    Recid = ITR_Posted_MasterRowRecID;
                }
            }
            else {
                Recid = ITR_Posted_ID;
            }
            Entry_AcceptReject(_actionMethod, Recid, "Accounts_CashBook", "ITR_PostedGrid", ITR_Posted_AtachmentID, ITR_Posted_NestedRowReasonID, ITR_Posted_NestedRowKeyValue);
        }
        function OnITR_PostedGridNestedFocusedRowChange(s, e) {
            if (ITR_Posted_IsDetailRowExpanded == true || IntrnlTranfrReg_IsVouchingMode == true) {
                ITR_Posted_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
                if (ITR_Posted_NestedRecord_FocusedRowIndex >= 0) {
                    var key = s.GetRowKey(s.GetFocusedRowIndex());
                    s.GetValuesOnCustomCallback({ key: key }, OnITR_Posted_GetGridRowValues)
                    ITR_Posted_NestedGrid_AccessID = s.uniqueID;
                    //s.GetRowValues(ITR_Posted_NestedRecord_FocusedRowIndex, 'Doc_Status;Params_Mandatory;LABEL_FROM_DATE;LABEL_TO_DATE;LABEL_DESCRIPTION;Document_Category;Document_ID;ATTACH_ID;TxnID;TxnMID;MAP_ID;Reason;ATTACH_FILE_NAME;Attachment_Action_Status;UniqueID', OnITR_Posted_GetGridRowValues);
                }
                else {
                    ITR_PostedPrf_FAB.SetActionContext("AddAttachmentContext", false);
                }
            }
        }
        function OnITR_Posted_GetGridRowValues(values) {
            var values = values.split("![");
            if (values[14] != null) {
                ITR_PostedPrf_FAB.SetVisible(true);
                ITR_Posted_Nested_Doc_Status = values[0];
                if (IntrnlTranfrReg_IsVouchingMode == true) {
                    ITR_PostedPrf_FAB.SetActionContext("AuditActionContext", true);
                }
                else {
                    if (ITR_Posted_Nested_Doc_Status == "") {
                        ITR_PostedPrf_FAB.SetActionContext("AutoItemContext", true);
                    }
                    else if (ITR_Posted_Nested_Doc_Status == "NO") {
                        ITR_PostedPrf_FAB.SetActionContext("EditItemContext", true);
                    }
                    else if (ITR_Posted_Nested_Doc_Status == "YES") {
                        ITR_PostedPrf_FAB.SetActionContext("actionItemContext", true);
                    }
                }
                ITR_Posted_ParamMandatory = values[1];
                ITR_Posted_FromDateLabel = values[2];
                ITR_Posted_ToDateLabel = values[3];
                ITR_Posted_DescriptionLabel = values[4];
                ITR_Posted_Doc_Category = values[5];
                ITR_Posted_Doc_ID = values[6];
                ITR_Posted_AtachmentID = values[7];
                IndexAttachmentID = ITR_Posted_AtachmentID;
                ITR_Posted_MasterRowRecID = values[8];
                ITR_Posted_MasterRowMID = values[9];
                ITR_Posted_NestedRowMapID = values[10];
                ITR_Posted_reason = values[11];
                ITR_Posted_FileName = values[12];
                ITR_Posted_Attachment_RecStatus = values[13];
                ITR_Posted_NestedRowKeyValue = values[14];

                if (ITR_Posted_MasterRowMID != null || ITR_Posted_MasterRowMID != "") {
                    ITR_Posted_RecID_ForAttachment = ITR_Posted_MasterRowMID;
                }
                else if (ITR_Posted_MasterRowRecID != null || ITR_Posted_MasterRowRecID != "") {
                    ITR_Posted_RecID_ForAttachment = ITR_Posted_MasterRowRecID;
                }
                if (IntrnlTranfrReg_IsVouchingMode == true) {
                    if (ITR_Posted_FileName != null && ITR_Posted_FileName.length > 0) {
                        ViewDocument(ITR_Posted_AtachmentID, ITR_Posted_FileName, "ITR_PostedPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                    }
                    else {
                        CloseRightPane();
                        ClearRightPane();
                    }
                }
            }
            ITR_Posted_NestedRowReasonID = values[15];
            IndexAttachmentReasonID = ITR_Posted_NestedRowReasonID;
            HideLoader();
        }

        function ITR_PostedGrid_Nested_BeginCallBack(s, e) {
            //e.customArgs["ShowHorizontalBar"] = Cash_ShowHorizontalBar;
            e.customArgs["VouchingMode"] = IntrnlTranfrReg_IsVouchingMode;
            e.customArgs["command"] = e.command;
        }
        function ITR_Posted_DetailRowExpanding(s, e) {
            ITR_Posted_IsDetailRowExpanded = true;
            s.SetFocusedRowIndex(e.visibleIndex);
            var pane = Mainspliter.GetPaneByName('RightPane');
            if (IntrnlTranfrReg_IsVouchingMode == true) {
                pane.Expand();
            }
            else {
                pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
        function ITR_Posted_DetailRowCollapsing(s, e) {
            ITR_Posted_IsDetailRowExpanded = false;
            s.SetFocusedRowIndex(e.visibleIndex)
            if (IntrnlTranfrReg_IsVouchingMode == true) {
                if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false) {
                    CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
                }
            }
            else {
                ITR_PostedPrf_FAB.SetVisible(false);
            }
        }
    </script>
    @*attachment and nested grid*@
    <script>
        function DataNavigation_ITR(Action)
        {
            if (ITR_Posted_ID == null && Action!="ACCEPT") { DevExpress.ui.dialog.alert("Posted Internal Transfer Entry Not Selected...!", 'Error'); return; }
            switch (Action)
            {
                case "EDIT":
                    Vouchers_Edit_AllEntryData("", "", "", "", "Internal Transfer Register", "", "", "", "", "", "", "ITR_PostedGrid", ITR_Posted_ID, false);
                    break;
                case "DELETE":
                    Vouchers_Delete_AllEntryData("", "", "", "", "Internal Transfer Register", "", "", "", "", "", "", "ITR_PostedGrid", ITR_Posted_ID, false, false);
                    break;
                case "VIEW":
                    Vouchers_View_AllEntryData("", "", "", "Internal Transfer Register", "", "", "ITR_PostedGrid", ITR_Posted_ID);
                    break;
                case "EDIT-COMMON":
                    Edit_Common(ITR_Posted_ID, ITR_Posted_MID, "ITR_PostedGrid","8");
                    break;
                case "ACCEPT":
                    OnITR_AcceptTransferClick();
                    break;
            }        
        }
        function DataNavigation_Volume_ITR(Action)
        {
            if ("@IsVolumeCentre" == "True")
            {
                switch (Action)
                {
                    case "NEW":
                        OnITRNewClick();
                        break;
                    case "EDIT":
                        OnITREditClick();
                        break;
                    case "DELETE":
                        OnITRDeleteClick();
                        break;
                    case "UNMATCH":
                        OnITRUnmatchTransferClick();
                        break;
                }
            }
        }
        </script>
</div>