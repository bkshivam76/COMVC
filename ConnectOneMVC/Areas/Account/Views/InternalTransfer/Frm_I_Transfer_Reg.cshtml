    <script>

    function ITR_Gridpanel_selectionChanged(e)
    {
        ITR_PendingGrid.SetFocusedRowIndex(-1);
        ITR_PostedGrid.SetFocusedRowIndex(-1);
    }

    function OnIntTransCellClick(event, cell,col, row)
    {
        if (UserType_IntTransPrf == "AUDITOR" || UserType_IntTransPrf == "SUPERUSER")
        {
            if (event.button == 0)
            {
                if (cell.style.backgroundColor.length > 0)
                {
                    cell.style.backgroundColor = "";
                }
                else
                {
                    cell.style.backgroundColor = 'skyblue';
                }
            }
        }
    }


    $(document).ready(function ()
    {
        if (IntrnlTranfrReg_SetVouchingModeOn == true)
        {
            $("#IntrnlTranfrRegViewModeSwitch").dxSwitch("instance").option("value", true);
        }
    });
    function IntrnlTranfrReg_VouchingSwitch_ValueChange(e)
    {
        IntrnlTranfrReg_IsVouchingMode = e.value;
        ITR_PostedGrid.SetFocusedRowIndex(-1);
        ITR_PostedPrf_FAB.SetVisible(false);
        if (IntrnlTranfrReg_IsVouchingMode == true) {
            OpenRightPane();
            ClearLeftPane();
            OpenLeftPane();
        }
        else {
            ITR_PostedPrf_FAB.SetActionContext("AddAttachmentContext", false);
            CloseRightPane();
            ClearLeftPane();
            CloseLeftPane();
        }
        ITR_PostedGrid_CollapseAllDetailRows();
    }
    function ITR_PostedGrid_CollapseAllDetailRows()
    {
        if (typeof window !== 'undefined')
        {
            if (typeof window.ITR_PostedGrid !== 'undefined')
            {
                if (typeof window.ITR_PostedGrid.CollapseAllDetailRows !== 'undefined')
                {
                    if (typeof ITR_PostedGrid.CollapseAllDetailRows == 'function')
                    {
                        ITR_PostedGrid.SetFocusedRowIndex(-1);
                        ITR_PostedGrid.CollapseAllDetailRows();
                    }
                    else
                    {
                        alert("CollapseAllDetailRows is not a function");
                    }
                }
                else
                {
                    ShowLoader();
                    setTimeout(function ()
                    {
                        ITR_PostedGrid_CollapseAllDetailRows();
                        HideLoader();
                    }, Timeout100);
                }
            }
            else
            {
                alert('grid undefined')
            }
        }
        else
        {
            alert('window undefined')
        }
    }
    function IntrnlTranfrReg_ViewSwitch_ValueChange(e)
    {
        IntrnlTranfrReg_ViewMode = e.value == false ? "Default" : "Compact";
        if (IntrnlTranfrReg_SetVouchingModeOn == true)
        {
            $("#IntrnlTranfrRegVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }
        else
        {
            ITR_PostedGrid.CollapseAllDetailRows();
        }
    }
    function OnITRNewClick()
    {
        ShowLoader();
        OpenDynamicPopup("New ~ Internal Transfer", "@Url.Action("Frm_Voucher_Win_I_Transfer", "InternalTransfer", new { @area = "Account" })?Tag=_New" + "&_New_From_Register" + true, "auto", 1000, false, null);
    }
    function OnITR_AcceptTransferClick()
    {
        if ($("#ITR_Gridpanel").dxTabPanel("instance").option("selectedIndex") == 1 )
        {
            if (ITR_Pending_ID != null)
            {
                ShowLoader();
                OpenDynamicPopup("Match ~ Internal Transfer", "@Url.Action("Frm_Voucher_Win_I_Transfer", "InternalTransfer", new { @area = "Account" })?RegisterGridRowID=" + ITR_Pending_ID + "&_Accepted_From_Register=" + true +"&Tag=_New", "auto", 1000, false, null);
            }
            else
            {
                DevExpress.ui.dialog.alert("Select A Row..!!", 'Inform!');
            }
        }
        else
        {
            DevExpress.ui.dialog.alert("Internal Transfer Entry Not Selected...!", 'Inform!');
        }
    }//accept transfer
    function OnITRUnmatchTransferClick()
    {
        if (ITR_Posted_ID == null) { DevExpress.ui.dialog.alert("Posted Internal Transfer Entry Not Selected...!", 'Error'); return; }
        $.ajax({
            type: 'GET',
            url: "/Account/InternalTransfer/UnmatchTransferClick",
            cache: false,
            data: { Posted_Id: ITR_Posted_ID, Pending_Id: ITR_Pending_ID },
            success: function (data)
            {
                if (data.message.length > 0)
                {
                    DevExpress.ui.dialog.alert(data.message, 'Inform!');
                }
                if (data.refreshGrid == true)
                {
                    ITR_PostedGrid.Refresh();
                }
            }
        });
    }//unmatch transfer
    function OnITREditClick()
    {
        if (ITR_Posted_ID == null) { DevExpress.ui.dialog.alert("Please Select Posted Transfer Entry To Be Edited...!", 'Error'); return; }
        var multiuser_confirm = false;
        var Edit_Check_Passed = false;
        $.ajax({
            type: 'GET',
            url: "/Account/InternalTransfer/MultiUser_ITR_Confirm",
            async:false,
            cache: false,
            data: { Posted_Id: ITR_Posted_ID },
            success: function (data)
            {
                if (data.result == false)
                {
                    DevExpress.ui.dialog.alert(data.message, 'Error!');
                }
                else if (data.result == true)
                {
                    multiuser_confirm = true;
                }
                else if (data.result == "MultiUser_Confirm")
                {
                    var confirm = DevExpress.ui.dialog.confirm(data.message, 'Confirm!');
                    confirm.done(function (dialogResult)
                    {
                        if (dialogResult)
                        {
                            multiuser_confirm = true;
                        }
                        else
                        {
                            multiuser_confirm = false;
                        }
                    });
                }
            }
        });
        if (multiuser_confirm)
        {
            $.ajax({
                type: 'GET',
                url: "/Account/InternalTransfer/Checks_Edit_DeleteClick_ITR",
                async:false,
                cache: false,
                data: { Posted_Id: ITR_Posted_ID },
                success: function (data)
                {
                    if (data.result == false)
                    {
                        DevExpress.ui.dialog.alert(data.message, 'Inform !');
                        if (data.refreshGrid)
                        {
                            ITR_PostedGrid.Refresh();
                        }
                    }
                    else if (data.result == true)
                    {
                        Edit_Check_Passed = true;
                    }
                }
            });
        }
        if (Edit_Check_Passed)
        {
            ShowLoader();
            OpenDynamicPopup("Edit ~ Internal Transfer", "@Url.Action("Frm_Voucher_Win_I_Transfer", "InternalTransfer", new { @area = "Account" })?Tag=_Edit&RegisterGridRowID=" + ITR_Posted_ID + "&_Edit_From_Register=" + true, "auto", 1000, false, null);
        }
    }// edit click
    function OnITRDeleteClick ()
    {
        if (ITR_Posted_ID == null) { DevExpress.ui.dialog.alert("Posted Internal Transfer Entry Not Selected...!", 'Error'); return; }
        var multiuser_confirm = false;
        var Delete_Check_Passed = false;
        $.ajax({
            type: 'GET',
            url: "/Account/InternalTransfer/MultiUser_ITR_Confirm",
            async:false,
            cache: false,
            data: { Posted_Id: ITR_Posted_ID },
            success: function (data)
            {
                if (data.result == false)
