@{
    bool isvolumeCentre = ViewBag.IsVolumeCentre == null ? false : ViewBag.IsVolumeCentre;
    bool isunmatchTransfer = ViewBag.IsunmatchTransfer == null ? false : ViewBag.IsunmatchTransfer;
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;
}

@Html.DevExpress().GridView(
    settings =>
