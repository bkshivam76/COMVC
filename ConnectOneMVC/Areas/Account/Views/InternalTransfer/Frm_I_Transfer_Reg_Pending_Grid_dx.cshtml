@using DevExtreme.AspNet.Mvc;
@{

}
@(Html.DevExtreme().DataGrid().CustomDataGridListing(1)
      .ID("ITR_PendingGrid")
      .DataSource(d => d.Mvc().Controller("InternalTransfer").LoadAction("Pending_Grid_Data_dx").LoadMode(DataSourceLoadMode.Raw).Key("ID"))
      .Columns(columns =>
      {
          columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);
          columns.Add().DataField("iIcon").Name("iIcon").Caption("").Visible(true).CellTemplate(new JS("ITR_PendingGrid_dx_iIconTemplate")).Width(50).HeaderCellTemplate(new JS("ITR_PendingGrid_dx_HeaderiIconTemplate")).AllowHeaderFiltering(false).AllowSorting(false).Width(30);
          columns.Add().DataField("Status").Caption("Status").Visible(true);
          columns.Add().DataField("Centre_Name").Caption("Centre Name").Visible(true);
          columns.Add().DataField("Center_UID").Caption("Center UID").Visible(true);
          columns.Add().DataField("No").Caption("No.").Visible(true);
          columns.Add().DataField("Zone").Caption("Zone").Visible(true);
          columns.Add().DataField("Sub_Zone").Caption("Sub Zone").Visible(true);
          columns.Add().DataField("Description").Caption("Description").Visible(false).GroupIndex(0);
          columns.Add().DataField("xDate").Caption("Date").Visible(true).DataType(GridColumnDataType.Date).Format("dd-MM-yyyy").Width(80);
          columns.Add().DataField("Mode").Caption("Mode").Visible(true);
          columns.Add().DataField("Amount").Caption("Amount").Visible(true).DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
          columns.Add().DataField("Bank_Name").Caption("Bank Name").Visible(true);
          columns.Add().DataField("Branch_Name").Caption("Branch Name").Visible(true);
          columns.Add().DataField("Bank_AC_No").Caption("Bank A/C. No.").Visible(true);
          columns.Add().DataField("Incharge").Caption("Incharge").Visible(true);
          columns.Add().DataField("ContactNo").Caption("Contact No.").Visible(true);
          columns.Add().DataField("Purpose").Caption("Purpose").Visible(true);
          columns.Add().DataField("RefNo").Caption("Ref. No.").Visible(true);
          columns.Add().DataField("RefDate").Caption("Ref. Date").Visible(true).DataType(GridColumnDataType.Date).Format("dd-MM-yyyy").Width(80);
          columns.Add().DataField("Ref_Bank_AccNo").Caption("Ref_Bank_AccNo").Visible(true);
          columns.Add().DataField("Narration").Caption("Narration").Visible(true);
          columns.Add().DataField("AddBy").Caption("Add By").Visible(false);
          columns.Add().DataField("AddDate").Caption("Add Date").Visible(false).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss");
          columns.Add().DataField("EditBy").Caption("Edit By").Visible(false);
          columns.Add().DataField("EditDate").Caption("Edit Date").Visible(false).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss");
          columns.Add().DataField("ActionStatus").Caption("Action Status").Visible(false);
          columns.Add().DataField("ActionBy").Caption("Action By").Visible(false);
          columns.Add().DataField("ActionDate").Caption("Action Date").Visible(false).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss");
          columns.Add().DataField("ITEM_ID").Caption("ITEM_ID").Visible(false);
          columns.Add().DataField("CEN_ID").Caption("CEN_ID").Visible(false);
          columns.Add().DataField("BI_ID").Caption("BI_ID").Visible(false);
          columns.Add().DataField("PUR_ID").Caption("PUR_ID").Visible(false);
          columns.Add().DataField("ID").Caption("ID").Visible(false);
          columns.Add().DataField("MID").Caption("MID").Visible(false);
          columns.Add().DataField("REF_BI_ID").Caption("REF_BI_ID").Visible(false);
          columns.Add().DataField("Ref_Branch").Caption("Ref_Branch").Visible(false);
          columns.Add().DataField("Ref_Others").Caption("Ref_Others").Visible(false);
      })
      .Summary(s =>
      {
          s.TotalItems(item => item.Add().Name("Amount_Amount_sum").SummaryType(SummaryType.Sum).Column("Amount").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}")));        
          s.RecalculateWhileEditing(true);
      })
      .OnInitialized("ITR_PendingGrid_dx_OnInitialized")
      .OnContentReady("ITR_PendingGrid_dx_OnContentReady")
      .OnSelectionChanged("ITR_PendingGrid_dx_OnSelectionChanged")
      .OnContextMenuPreparing("ITR_PendingGrid_dx_OnContextMenuPreparing")
      .OnCellDblClick("ITR_PendingGrid_dx_OnCellDblClick")
)