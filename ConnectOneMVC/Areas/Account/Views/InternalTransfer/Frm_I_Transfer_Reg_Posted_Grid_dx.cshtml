@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;
}

@(Html.DevExtreme().DataGrid().CustomDataGridListing(1)
.ID("ITR_PostedGrid")
.DataSource(d => d.Mvc().Controller("InternalTransfer").LoadAction("Posted_Grid_Data_dx").LoadMode(DataSourceLoadMode.Raw).Key("ID"))
.Columns(columns =>
{
    columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);
    columns.Add().DataField("iIcon").Name("iIcon").Caption("").CellTemplate(new JS("ITR_PostedGrid_dx_iIconTemplate")).Width(30)
    .HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource"));
    columns.Add().DataField("ITR_PostedGrid_Compact_Column").Name("ITR_PostedGrid_Compact_Column").Caption("")
    .Visible(false).CellTemplate(new JS("ITR_PostedGrid_dx_Compact_Column")).CalculateCellValue("ITR_PostedGrid_dx_Compact_Column_CellValue").Width("100%").ShowInColumnChooser(false);
    columns.Add().DataField("Status").Caption("Status").Visible(true);
    columns.Add().DataField("Centre_Name").Caption("Centre Name").Visible(true);
    columns.Add().DataField("Center_UID").Caption("Center UID").Visible(true);
    columns.Add().DataField("No").Caption("No.").Visible(true);
    columns.Add().DataField("Zone").Caption("Zone").Visible(true);
    columns.Add().DataField("Sub_Zone").Caption("Sub Zone").Visible(true);
    columns.Add().DataField("Description").Caption("Description").Visible(false).GroupIndex(0);
    columns.Add().DataField("xDate").Caption("Date").Visible(true).Width(80).DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
    columns.Add().DataField("Mode").Caption("Mode").Visible(true);
    columns.Add().DataField("Amount").Caption("Amount").Visible(true).DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
    columns.Add().DataField("Bank_Name").Caption("Bank Name").Visible(true);
    columns.Add().DataField("Branch_Name").Caption("Branch Name").Visible(true);
    columns.Add().DataField("Bank_AC_No").Caption("Bank A/C. No.").Visible(true);
    columns.Add().DataField("Bank_2").Caption("Bank_2").Visible(true);
    columns.Add().DataField("RefNo").Caption("Ref. No.").Visible(true);
    columns.Add().DataField("RefDate").Caption("Ref. Date").Visible(true).Width(80).DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
    columns.Add().DataField("Purpose").Caption("Purpose").Visible(true);
    columns.Add().DataField("AddBy").Caption("Add By").Visible(false);
    columns.Add().DataField("AddDate").Caption("Add Date").Visible(false).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss"); ;
    columns.Add().DataField("EditBy").Caption("Edit By").Visible(false);
    columns.Add().DataField("EditDate").Caption("Edit Date").Visible(false).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss"); ;
    columns.Add().DataField("ActionStatus").Caption("Action Status").Visible(false);
    columns.Add().DataField("ActionBy").Caption("Action By").Visible(false);
    columns.Add().DataField("ActionDate").Caption("Action Date").Visible(false).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss"); ;
    columns.Add().DataField("ID").Caption("ID").Visible(false);
    columns.Add().DataField("MID").Caption("MID").Visible(false);
    columns.Add().DataField("iRESPONDED_COUNT").Caption("iRESPONDED_COUNT").Visible(false);
    columns.Add().DataField("iCOMPLETE_ATTACH_COUNT").Caption("iCOMPLETE_ATTACH_COUNT").Visible(false);
    columns.Add().DataField("iREQ_ATTACH_COUNT").Caption("iREQ_ATTACH_COUNT").Visible(false);
    columns.Add().DataField("iOTHER_ATTACH_CNT").Caption("iOTHER_ATTACH_CNT").Visible(false);
    columns.Add().DataField("iALL_ATTACH_CNT").Caption("iALL_ATTACH_CNT").Visible(false);
    columns.Add().DataField("TR_ITEM_ID").Caption("TR_ITEM_ID").Visible(false);
    columns.Add().DataField("TR_SR_NO").Caption("TR_SR_NO").Visible(false);
    columns.Add().DataField("TR_TYPE").Caption("TR_TYPE").Visible(false);
})
    .Summary(s =>
    {
        s.TotalItems(item => item.Add().Name("Amount_Amount_sum").SummaryType(SummaryType.Sum).Column("Amount").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}")));
        s.RecalculateWhileEditing(true);
    })
.MasterDetail(md =>
{
    md.AutoExpandAll(false);
    md.Enabled(!VouchingMode);
    md.Template(new JS("ITR_PostedGrid_dx_DetailTemplate"));

})
.OnInitialized("ITR_PostedGrid_dx_OnInitialized")
.OnCellPrepared("ITR_PostedGrid_dx_OnCellPrepared")
.OnRowPrepared("ITR_PostedGrid_dx_OnRowPrepared")
.OnContentReady("ITR_PostedGrid_dx_OnContentReady")
.OnCellDblClick("ITR_PostedGrid_dx_OnCellDblClick")
.OnSelectionChanged("ITR_PostedGrid_dx_OnSelectionChanged")
.OnRowExpanding("ITR_PostedGrid_dx_OnRowExpanding")
.OnRowCollapsing("ITR_PostedGrid_dx_OnRowCollapsing")
.OnContextMenuPreparing("ITR_PostedGrid_dx_OnContextMenuPreparing")

)