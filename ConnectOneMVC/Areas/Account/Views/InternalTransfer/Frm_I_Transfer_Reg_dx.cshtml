    @* ITR_Global_Variables*@

<script>
    $(document).ready(function () {
        if (IntrnlTranfrReg_SetVouchingModeOn == true) {
            $("#IntrnlTranfrRegViewModeSwitch").dxSwitch("instance").option("value", true);
        }
        $(".ITR_PostedGrid_PreviewRow").hide();
        GetSessionStorage("ITR_PostedGrid");
        $(".ITR_PendingGrid_PreviewRow").hide();
        GetSessionStorage("ITR_PendingGrid");
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            DxGrid_AdjustSize([ITR_PostedGrid, ITR_PendingGrid], $("#ITR_Reg_ParentDiv_dx .report_button_div"), "", evt)
        });
    });
    function IntrnlTranfrReg_VouchingSwitch_ValueChange_dx(e)
    {
        IntrnlTranfrReg_IsVouchingMode = e.value;
        if (IntrnlTranfrReg_SetVouchingModeOn == true) {
            IntrnlTranfrReg_SetVouchingModeOn = false;
        }
        else {
            ITR_PostedPrf_FAB.SetVisible(false);
        }
        if (IntrnlTranfrReg_IsVouchingMode == true) {
            OpenRightPane();
            ClearLeftPane();
            OpenLeftPane();
            $("#ITR_Reg_content_label").addClass("col-md-12").removeClass("col-md-4")
        }
        else {
            CloseRightPane();
            ClearLeftPane();
            CloseLeftPane();
            $("#ITR_Reg_content_label").addClass("col-md-4").removeClass("col-md-12")
        }
        ITR_PostedGrid.clearSelection();
        ITR_PostedGrid.option("masterDetail.enabled", !IntrnlTranfrReg_IsVouchingMode)
        ITR_PostedGrid.repaint();      
    }
    async function IntrnlTranfrReg_ViewSwitch_ValueChange_dx(e) {
        IntrnlTranfrReg_ViewMode = e.value == false ? "Default" : "Compact";
        if (IntrnlTranfrReg_SetVouchingModeOn == true) {
            $("#IntrnlTranfrRegVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }
        ITR_PostedPrf_FAB.SetActionContext("AddAttachmentContext", false);
        if (Expanded_Row_Key_ITR_PostedGrid != null && Expanded_Row_Key_ITR_PostedGrid.length > 0) {
            await ITR_PostedGrid.collapseRow(Expanded_Row_Key_ITR_PostedGrid)
        }
        ITR_PostedGrid.beginUpdate();
        var columns = ITR_PostedGrid.option("columns");
        if (IntrnlTranfrReg_ViewMode == "Compact") {
            VisibleColumns_ITR_PostedGrid = [];
            for (var i = 0; i < columns.length; i++) {
                var name = columns[i].dataField;
                var ColumnVisible = ITR_PostedGrid.columnOption(name, "visible");
                if (name == "ITR_PostedGrid_Compact_Column") {
                    ITR_PostedGrid.columnOption(name, "visible", true);
                }
                else if (ColumnVisible == true && name != "iIcon") {
                    VisibleColumns_ITR_PostedGrid.push(name);
                    ITR_PostedGrid.columnOption(name, "visible", false);
                }
            }
        }
        else {
            ITR_PostedGrid.columnOption("ITR_PostedGrid_Compact_Column", "visible", false);
            for (var i = 0; i < VisibleColumns_ITR_PostedGrid.length; i++) {
                ITR_PostedGrid.columnOption(VisibleColumns_ITR_PostedGrid[i], "visible", true);
            }
        }
        ITR_PostedGrid.repaint();
        ITR_PostedGrid.endUpdate();
    }
    function DataNavigation_ITR(Action)
    {
        if (ITR_Tab_Selected == "Pending" && Action!="ACCEPT") { DevExpress.ui.dialog.alert("Posted Internal Transfer Entry Not Selected...!", 'Error'); return; }
        if (ITR_Tab_Selected == "Posted" && ITR_Posted_ID == null) { DevExpress.ui.dialog.alert("Posted Internal Transfer Entry Not Selected...!", 'Error'); return; }
        switch (Action)
        {
            case "EDIT":
                Vouchers_Edit_AllEntryData(ITR_Posted_ID, ITR_Posted_MID, ITR_Posted_EditDate, ITR_Posted_AddDate, "Internal Transfer Register", ITR_Posted_Date,
                    ITR_Posted_ActionStatus, "8", ITR_Posted_ITEM_ID, ITR_Posted_Srno, ITR_Posted_Type, "ITR_PostedGrid", ITR_Posted_ID, false);
                break;
            case "DELETE":
                Vouchers_Delete_AllEntryData(ITR_Posted_ID, ITR_Posted_MID, ITR_Posted_EditDate, ITR_Posted_AddDate, "Internal Transfer Register", ITR_Posted_Date,
                    ITR_Posted_ActionStatus, "8", ITR_Posted_ITEM_ID, ITR_Posted_Srno, ITR_Posted_Type,"ITR_PostedGrid", ITR_Posted_ID, false, false);
                break;
            case "VIEW":
                Vouchers_View_AllEntryData(ITR_Posted_ID, ITR_Posted_MID, ITR_Posted_EditDate, "Internal Transfer Register", ITR_Posted_Date, "8", "ITR_PostedGrid", ITR_Posted_ID);
                break;
            case "EDIT-COMMON":
                Edit_Common(ITR_Posted_ID, ITR_Posted_MID, "ITR_PostedGrid","8");
                break;
            case "ACCEPT":
                OnITR_AcceptTransferClick();
                break;
        }
    }
    function DataNavigation_Volume_ITR(Action)
    {
        if ("@IsVolumeCentre" == "True")
        {
            switch (Action)
            {
                case "NEW":
                    OnITRNewClick();
                    break;
                case "EDIT":
                    DataNavigation_ITR("EDIT")
                    break;
                case "DELETE":
                    DataNavigation_ITR("DELETE")
                    break;
                case "UNMATCH":
                    OnITRUnmatchTransferClick();
                    break;
            }
        }
    }
    function OnITRNewClick()
    {
        ShowLoader();
        OpenDynamicPopup("New ~ Internal Transfer", "@Url.Action("Frm_Voucher_Win_I_Transfer", "InternalTransfer", new { @area = "Account" })?Tag=_New" + "&_New_From_Register" + true, "auto", 1000, false, null);
    }
    function OnITR_AcceptTransferClick()
    {
        if (ITR_Tab_Selected == "Pending" )
        {
            if (ITR_Pending_ID != null)
            {
                ShowLoader();
                $.ajax({
                    type: 'GET',
                    url: "/Account/InternalTransfer/Frm_Voucher_Win_I_Transfer",
                    cache: false,
                    data: {
                        RegisterGridRowID: ITR_Pending_ID,
                        _Accepted_From_Register: true,
                        Tag: "_New",
                        _Date: ITR_Pending_xDate,
                        _a_Item_ID: ITR_Pending_ITEM_ID,
                        _Mode: ITR_Pending_Mode,
                        _CEN_ID: ITR_Pending_CEN_ID,
                        _BI_ID: ITR_Pending_BI_ID,
                        _BI_BRANCH: ITR_Pending_Branch_Name,
                        _BI_ACC_NO: ITR_Pending_Bank_AC_No,
                        _REF_BI_ID: ITR_Pending_REF_BI_ID,
                        _REF_BRANCH: ITR_Pending_Ref_Branch,
                        _REF_OTHERS: ITR_Pending_Ref_Others,
                        _BI_REF_NO: ITR_Pending_RefNo,
                        _BI_REF_DT: ITR_Pending_RefDate,
                        _Amount: ITR_Pending_Amount,
                        _a_PUR_ID: ITR_Pending_PUR_ID,
                        CROSS_REF_ID: ITR_Pending_ID,
                        CROSS_M_ID: ITR_Pending_MID,
                        FR_REC_EDIT_ON: JS_Date_toIsoString(DateStringToJsDate(ITR_Pending_EditDate,"DD-MM-YYYY HH:mm:ss")),
                        _REF_BANK_ACC_NO: ITR_Pending_Ref_Bank_AccNo,
                    },
                    success: function (data)
                    {
                       OpenDynamicPopup("Match ~ Internal Transfer", null, "auto", 1000, true, data);
                    }
                });
            }
            else
            {
                DevExpress.ui.dialog.alert("Select A Row..!!", 'Inform!');
            }
        }
        else
        {
            DevExpress.ui.dialog.alert("Internal Transfer Entry Not Selected...!", 'Inform!');
        }
    }//accept transfer
    function OnITRUnmatchTransferClick()
    {
        if (ITR_Tab_Selected == "Pending" || ITR_Posted_ID == null)
        {
            DevExpress.ui.dialog.alert("Posted Internal Transfer Entry Not Selected...!", 'Error'); return;
        }     
        $.ajax({
            type: 'GET',
            url: "/Account/InternalTransfer/UnmatchTransferClick",
            cache: false,
            data:
            {
                Posted_Id: ITR_Posted_ID,
                Tr_Date: ITR_Posted_Date,
                EditDate: ITR_Posted_EditDate,
                MID: ITR_Posted_MID
            },
            success: function (data)
            {
                if (data.message.length > 0)
                {
                    DevExpress.ui.dialog.alert(data.message, 'Inform!');
                }
                if (data.refreshGrid == true)
                {
                    RefreshGridView("ITR_PostedGrid")
                }
            }
        });
    }//unmatch transfer
    function OnITREditClick()
    {
        if (ITR_Posted_ID == null) { DevExpress.ui.dialog.alert("Please Select Posted Transfer Entry To Be Edited...!", 'Error'); return; }
        var multiuser_confirm = false;
        var Edit_Check_Passed = false;
        $.ajax({
            type: 'GET',
            url: "/Account/InternalTransfer/MultiUser_ITR_Confirm",
            async:false,
            cache: false,
            data: { Posted_Id: ITR_Posted_ID },
            success: function (data)
            {
                if (data.result == false)
                {
                    DevExpress.ui.dialog.alert(data.message, 'Error!');
                }
                else if (data.result == true)
                {
                    multiuser_confirm = true;
                }
                else if (data.result == "MultiUser_Confirm")
                {
                    var confirm = DevExpress.ui.dialog.confirm(data.message, 'Confirm!');
                    confirm.done(function (dialogResult)
                    {
                        if (dialogResult)
                        {
                            multiuser_confirm = true;
                        }
                        else
                        {
                            multiuser_confirm = false;
                        }
                    });
                }
            }
        });
        if (multiuser_confirm)
        {
            $.ajax({
                type: 'GET',
                url: "/Account/InternalTransfer/Checks_Edit_DeleteClick_ITR",
                async:false,
                cache: false,
                data: { Posted_Id: ITR_Posted_ID },
                success: function (data)
                {
                    if (data.result == false)
                    {
                        DevExpress.ui.dialog.alert(data.message, 'Inform !');
                        if (data.refreshGrid)
                        {
                            ITR_PostedGrid.refresh();
                        }
                    }
                    else if (data.result == true)
                    {
                        Edit_Check_Passed = true;
                    }
                }
            });
        }
        if (Edit_Check_Passed)
        {
            ShowLoader();
            OpenDynamicPopup("Edit ~ Internal Transfer", "@Url.Action("Frm_Voucher_Win_I_Transfer", "InternalTransfer", new { @area = "Account" })?Tag=_Edit&RegisterGridRowID=" + ITR_Posted_ID + "&_Edit_From_Register=" + true, "auto", 1000, false, null);
        }
    }// edit click
