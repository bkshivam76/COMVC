    <script>
        function ITR_PendingGrid_dx_OnInitialized(e)
        {
            ITR_PendingGrid = e.component;
            DxGrid_AdjustSize(e.component, $("#ITR_Reg_ParentDiv_dx .report_button_div"))                  
        }
        async function ITR_PendingGrid_dx_OnContentReady(e) {
            await DxGrid_RowSelectionTobeCheckedAfterAnyAction(e, null)
            DxGrid_OnContentReady(e);            
        }
        function ITR_PendingGrid_dx_OnSelectionChanged(e) {
            var selectedRowKeys = e.selectedRowKeys;
            if (selectedRowKeys != null && selectedRowKeys.length > 0) {
                ITR_PendingGridOnGetRowValues_dx(e.selectedRowsData);
            }
            else {
                ITR_Pending_ID = null;
                ITR_Pending_updateFooterDetail(ITR_Pending_ID, ITR_Pending_ActionStatus, ITR_Pending_AddDate, ITR_Pending_AddBy, ITR_Pending_ActionDate, ITR_Pending_ActionBy, ITR_Pending_EditDate, ITR_Pending_EditBy);
            }
        }
        function ITR_PendingGridOnGetRowValues_dx(data) {
            var value = data[0];
            ITR_Pending_ActionBy = value["ActionBy"];
            ITR_Pending_ActionDate = (JS_Json_Date_To_ddMMyyyy((value["ActionDate"] ?? ""), "DD-MM-YYYY HH:mm:ss") ?? "");
            ITR_Pending_ActionStatus = value["ActionStatus"];
            ITR_Pending_AddBy = value["AddBy"];
            ITR_Pending_AddDate = (JS_Json_Date_To_ddMMyyyy((value["AddDate"] ?? ""), "DD-MM-YYYY HH:mm:ss") ?? "");
            ITR_Pending_EditBy = value["EditBy"];
            ITR_Pending_EditDate = (JS_Json_Date_To_ddMMyyyy((value["EditDate"] ?? ""), "DD-MM-YYYY HH:mm:ss") ?? "");
            ITR_Pending_ID = value["ID"];
            ITR_Pending_xDate = (JS_Json_Date_To_ddMMyyyy((value["xDate"] ?? ""), "DD-MM-YYYY") ?? "");
            ITR_Pending_ITEM_ID = value["ITEM_ID"];
            ITR_Pending_Mode = value["Mode"];
            ITR_Pending_CEN_ID = value["CEN_ID"];
            ITR_Pending_BI_ID = value["BI_ID"];
            ITR_Pending_Branch_Name = value["Branch_Name"];
            ITR_Pending_Bank_AC_No = value["Bank_AC_No"];
            ITR_Pending_REF_BI_ID = value["REF_BI_ID"];
            ITR_Pending_Ref_Branch = value["Ref_Branch"];
            ITR_Pending_Ref_Others = value["Ref_Others"];
            ITR_Pending_RefNo = value["RefNo"];
            ITR_Pending_RefDate = (JS_Json_Date_To_ddMMyyyy((value["RefDate"] ?? ""), "DD-MM-YYYY") ?? "");
            ITR_Pending_Amount = value["Amount"];
            ITR_Pending_PUR_ID = value["PUR_ID"];
            ITR_Pending_MID = value["MID"];
            ITR_Pending_Ref_Bank_AccNo = value["Ref_Bank_AccNo"];
            ITR_Pending_updateFooterDetail(ITR_Pending_ID, ITR_Pending_ActionStatus, ITR_Pending_AddDate, ITR_Pending_AddBy, ITR_Pending_ActionDate, ITR_Pending_ActionBy, ITR_Pending_EditDate, ITR_Pending_EditBy);
        }
        function ITR_Pending_updateFooterDetail(ID, ITR_ActionStatus, ITR_AddDate, ITR_AddBy, ITR_ActionDate, ITR_ActionBy, ITR_EditDate, ITR_EditBy) {
            var Status = "";
            var Lbl_Status = "";
            var Lbl_StatusBy = "";
            var Pic_Status = "";
            var Lbl_Create = "";
            var Lbl_Modify = "";
            var Lbl_Status_Color = "";
            var Lbl_ActionOn = "";
            var Lbl_ActionBy = "";
            var StatusStr = "";
            if (ID != null) {
                Status = ITR_ActionStatus;
                StatusStr = Status == "Locked" ? "Locked" : Status == null ? null : "UnLocked";

                if (Status && Status.toUpperCase() == "LOCKED") {
                    Lbl_Status = "Completed";
                    Lbl_Status_Color = "blue";
                    Pic_Status = "fa fa-lock";
                }
                else {
                    Pic_Status = "fa fa-unlock";
                    Lbl_Status = Status;
                    if (Status && Status.toUpperCase() == "COMPLETED") {
                        Lbl_Status_Color = "green";
                    }
                    else {
                        Lbl_Status_Color = "red";
                    }
                }

                if (ITR_AddDate) {
                    Lbl_Create = "Add On: " + ITR_AddDate + ", By: " + ITR_AddBy;
                }
                if (ITR_EditDate) {
                    Lbl_Modify = "Edit On: " + ITR_EditDate + ", By: " + ITR_EditBy;
                }
                if (ITR_ActionDate) {
                    Lbl_ActionOn = StatusStr + " On: " + ITR_ActionDate;
                }
                if (ITR_ActionBy) {
                    Lbl_ActionBy = StatusStr + " By: " + ITR_ActionBy;
                }
            }

            $('#ITR_Pending_Lbl_Status').text(Lbl_Status);
            $('#ITR_Pending_Lbl_Create').text(Lbl_Create);
            $('#ITR_Pending_Lbl_ActionOn').text(Lbl_ActionOn);
            $('#ITR_Pending_Lbl_ActionBy').text(Lbl_ActionBy);
            $('#ITR_Pending_Lbl_Modify').text(Lbl_Modify);
            if (Lbl_Status_Color != "") {
                $('#ITR_Pending_Lbl_Status').css('color', Lbl_Status_Color);
            }
            if (Pic_Status == "fa fa-lock") {
                $('#ITR_Pending_LockICON').addClass(Pic_Status).removeClass("fa-unlock");
            }
            else if (Pic_Status == "fa fa-unlock") {
                $('#ITR_Pending_LockICON').addClass(Pic_Status).removeClass("fa-lock");
            }
            else {
                $('#ITR_Pending_LockICON').removeClass("fa").removeClass("fa-unlock").removeClass("fa-lock");
            }
        }
        function ITR_PendingGrid_dx_OnContextMenuPreparing(e)
        {            
            if (!e.items) e.items = [];
            if (e.target == "header") {
                DxGrid_HeaderContextMenu(e)
            }
            else if ((e.target == "content" && e.row && e.row.rowType == "groupFooter") || e.target == "footer") {
                DxGrid_FooterContextMenu(e)
            }
            else if (e.target == "content" && e.row && (e.row.rowType == "data" || e.row.rowType == "detailAdaptive")) {
                var key = e.component.getKeyByRowIndex(e.row.rowIndex);
                e.component.selectRows(key);
                var expanded = e.component.isRowExpanded(key);
                e.items = [

                    {
                        text: "Accept Transfer",
                        icon: "../../../../Icons/Accept-icon.png",
                        beginGroup: true,
                        onItemClick: function () {
                            DataNavigation_ITR("ACCEPT");
                        }
                    },
                    {
                        text: "Edit Common Info",
                        icon: "fa-solid fa-file-pen",
                        onItemClick: function () {
                            DataNavigation_ITR("EDIT-COMMON");
                        }
                    },
                    {
                        text: "Export",
                        icon: "fa-solid fa-plus text-success",
                        onItemClick: function () {
                            OnITRListPreviewClick();
                        }
                    },
                    {
                        text: "Close",
                        icon: "fa-solid fa-rectangle-xmark text-danger",
                        onItemClick: function () {
                            $(".TabPanalMenu-tabs .active span").click();
                        }
                    },
                    {
                        text: "Refresh",
                        beginGroup: true,
                        icon: "fa-solid fa-arrow-rotate-right text-success",
                        onItemClick: function () {
                            RefreshGridView("ITR_PendingGrid")
                            /* ITR_PendingGrid.refresh()*/
                        }
                    }

                ]
            }
            else if (e.target == "content" && e.row==void 0)
            {
                e.items = [{
                    text: "Close",
                    icon: "fa-solid fa-rectangle-xmark text-danger",
                    onItemClick: function () {
                        $(".TabPanalMenu-tabs .active span").click();
                    }
                },
                {
                    text: "Refresh",
                    beginGroup: true,
                    icon: "fa-solid fa-arrow-rotate-right text-success",
                    onItemClick: function () {
                        RefreshGridView("ITR_PendingGrid")                       
                    }
                }

                ]
            }
        }
        function ITR_PendingGrid_dx_OnCellDblClick(e) {
            if (IntrnlTranfrReg_IsVouchingMode == false) {
                if (e.rowType == "data") {
                    DataNavigation_ITR("EDIT");
                }
            }
        }

        function ITR_PendingGrid_dx_iIconTemplate(container, templateData) {
            if (templateData.rowType == "data") {
                var UniqueID = templateData.component.element()[0].id
                var key = templateData.data.ID
                var VisibleIndex = templateData.rowIndex
                var htmlString = "";
                htmlString += DxGrid_AuditIconAfterClick(UniqueID, key, VisibleIndex)
                $(container).html(htmlString)
            }
        }
        function ITR_PendingGrid_dx_HeaderiIconTemplate(container, templateData) {
            htmlString = '<img src="../../../../Content/FloatingActionButton/Images/pin.png" alt="pin.png" style="width:80%;"/>';
            $(container).html(htmlString)
        }
    </script>
