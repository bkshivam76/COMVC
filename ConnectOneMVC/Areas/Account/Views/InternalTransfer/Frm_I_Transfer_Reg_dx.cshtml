    function OnITRListPreviewClick()
    {
        ShowLoader();
        OpenPopup("report_export_modal", "Export Option", "/Account/InternalTransfer/Frm_Export_Options_dx?SelectedTab=" + ITR_Tab_Selected, "auto", 125, false, false);
    }
    function OnITRAddAttachment(ID)
    {
        if (ID == null)
        {
            DevExpress.ui.dialog.alert("Select A Row..!!", 'Inform!');
            return;
        }
        $("#ID_Frm_Help_Document_Attach").remove();
        ShowLoader();
        OpenDynamicPopup("Internal Transfer Register", "@Url.Action("Frm_Attachment_Window", "Attachment", new { @area = "Help" })?AM=New&Refrecid=" + ID + "&RefScreen=" + "Internal_Transfer", "auto", 900, false, null);
    }
    function OnITRManageAttachment(ID)
    {
        if (ID == null) {
            DevExpress.ui.dialog.alert("Select A Row..!!", 'Inform!');
            return;
        }
        ShowLoader();
        OpenPopup("ITR_manage_Attachment", "Internal Transfer Register", "@Url.Action("Frm_Attachment_Info", "Attachment", new { @area = "Help" })?RefRecID=" + ID + "&PopUpId=ITR_manage_Attachment", "auto", 1150, false, null);
    }
    function ITR_Gridpanel_selectionChanged(e)
    {
        var selectedindex = e.component.option("selectedIndex");
        if (selectedindex == 0)
        {
            ITR_Tab_Selected = "Posted";
            ITR_PendingGrid.hideColumnChooser();
            if (UserType_IntTransPrf == "SUPERUSER" || UserType_IntTransPrf == "AUDITOR")
            {
                $("#IntrnlTranfrRegViewModeSwitch").dxSwitch("option", "visible", true)
            }
        }
        else
        {
            ITR_Tab_Selected = "Pending";
            ITR_PostedGrid.hideColumnChooser();
            $("#IntrnlTranfrRegViewModeSwitch").dxSwitch("option", "visible", false)
        }
    }
    $(".TabPanalMenu-tabs .active span").on("click", function ()
    {
        $.ajax({
            type: 'GET',
            url: "/Account/InternalTransfer/SessionClear_REG",
