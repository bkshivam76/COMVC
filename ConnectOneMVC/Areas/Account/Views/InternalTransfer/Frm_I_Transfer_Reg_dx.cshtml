        function ITR_PostedGrid_dx_Compact_Column_CellValue(rowData) {
            var data = [];
            data = [
                rowData.Status, rowData.Centre_Name, rowData.Center_UID, rowData.No,
                rowData.Zone, rowData.Sub_Zone, rowData.Description, rowData.xDate,
                rowData.Mode, rowData.Amount, rowData.Bank_Name, rowData.Branch_Name,
                rowData.Bank_AC_No, rowData.Bank_2, rowData.RefNo, , rowData.RefDate, rowData.Purpose
            ]
            return data.join(" ")
        }

        //detail grid for posted
        function ITR_PostedGrid_dx_DetailTemplate(container, templateData) {
            var GridName = templateData.component.element()[0].id
            var RecID = templateData.data.ID;
            var MID = templateData.data.MID;
            ITR_PostedGrid_dx_Detail(container, GridName, RecID, MID, IntrnlTranfrReg_IsVouchingMode, 1);
        }
        function ITR_PostedGrid_dx_Detail(container, GridName, RecID, MID, vouchingMode, AllColumns) {
            var url = "/Account/InternalTransfer/Itr_Posted_DetailGrid_Data?VouchingMode=" + vouchingMode + "&RecID=" + RecID + "&MID=" + MID
            var instance = DxGrid_AttachmentGrid_Create(container, GridName, RecID, vouchingMode, AllColumns, url)
            instance.option("onSelectionChanged", ITR_PostedGrid_dx_Detail_onSelectionChanged);
        }
        function ITR_PostedGrid_dx_Detail_onSelectionChanged(e) {
            if (ITR_Posted_IsDetailRowExpanded || IntrnlTranfrReg_IsVouchingMode) {
                if (e.selectedRowsData != null && e.selectedRowsData.length > 0) {
                    ITR_Posted_NestedGrid_AccessID = e.element[0].id;
                    ITR_PostedGrid_dx_Detail_SelectedRowData(e.selectedRowsData)
                }
                else {
                    ITR_PostedPrf_FAB.SetActionContext("AddAttachmentContext", false);
                }
            }
        }
        function ITR_PostedGrid_dx_Detail_SelectedRowData(selectedData = null) {
            if (selectedData == null) {
                selectedData = $("#" + ITR_Posted_NestedGrid_AccessID).dxDataGrid("getSeletedRowsData");
            }
            var values = selectedData[0];
            ITR_Posted_NestedRowKeyValue = values["UniqueID"];
            if (values["UniqueID"] != null) {
                ITR_PostedPrf_FAB.SetVisible(true);
                ITR_Posted_Nested_Doc_Status = values["Doc_Status"];

                if (IntrnlTranfrReg_IsVouchingMode == true) {

                    ITR_PostedPrf_FAB.SetActionContext("AuditActionContext", true);
                }
                else {
                    if (ITR_Posted_Nested_Doc_Status == "") {
                        ITR_PostedPrf_FAB.SetActionContext("AutoItemContext", true);
                    }
                    else if (ITR_Posted_Nested_Doc_Status == "NO") {
                        ITR_PostedPrf_FAB.SetActionContext("EditItemContext", true);
                    }
                    else if (ITR_Posted_Nested_Doc_Status == "YES") {
                        ITR_PostedPrf_FAB.SetActionContext("actionItemContext", true);
                    }
                }
                ITR_Posted_ParamMandatory = values["Params_Mandatory"];
                ITR_Posted_FromDateLabel = values["LABEL_FROM_DATE"];
                ITR_Posted_ToDateLabel = values["LABEL_TO_DATE"];
                ITR_Posted_DescriptionLabel = values["LABEL_DESCRIPTION"];
                ITR_Posted_Doc_Category = values["Document_Category"];
                ITR_Posted_Doc_ID = values["Document_ID"];
                ITR_Posted_AtachmentID = values["ATTACH_ID"];
                IndexAttachmentID = ITR_Posted_AtachmentID;
                ITR_Posted_MasterRowRecID = values["TxnID"];
                ITR_Posted_MasterRowMID = values["TxnMID"];
                ITR_Posted_NestedRowMapID = values["MAP_ID"];
                ITR_Posted_reason = values["Reason"];
                ITR_Posted_FileName = values["ATTACH_FILE_NAME"];
                ITR_Posted_Attachment_RecStatus = values["Attachment_Action_Status"];


                if (ITR_Posted_MasterRowMID != null && ITR_Posted_MasterRowMID != "") {
                    ITR_Posted_RecID_ForAttachment = ITR_Posted_MasterRowMID;
                }
                else if (ITR_Posted_MasterRowRecID != null && ITR_Posted_MasterRowRecID != "") {
                    ITR_Posted_RecID_ForAttachment = ITR_Posted_MasterRowRecID;
                }
                if (IntrnlTranfrReg_IsVouchingMode == true) {
                    if (ITR_Posted_FileName != null && ITR_Posted_FileName.length > 0) {
                        ViewDocument(ITR_Posted_AtachmentID, ITR_Posted_FileName, "ITR_PostedPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                    }
                    else {
                        CloseRightPane();
                        ClearRightPane();
                    }
                }
            }
            ITR_Posted_NestedRowReasonID = values["ReasonID"];
            IndexAttachmentReasonID = ITR_Posted_NestedRowReasonID;
        }

        function LeftPaneContent_ITR_Posted_dx(GridName, RecID, MID, vouchingMode, AllColumns = 0) {
            $("#LeftPane_Div_Content").html(null);
            $("#LeftPane_Div_Content").append("<div class='col-xs-12'><label>Documents Attached:</label><div class='AttachmentGrid'><form></form></div></div><div class='col-xs-12'><label>Additional Info:</label><div class='AdditionalInfoGrid'><form></form></div></div>")
            ITR_PostedGrid_dx_Detail($("#LeftPane_Div_Content .AttachmentGrid>form"), GridName, RecID, MID, vouchingMode, AllColumns)
            setTimeout(function () {
                AdditionalInfoGrid_ITR_PostedGrid_dx($("#LeftPane_Div_Content .AdditionalInfoGrid>form"), GridName, RecID, MID, vouchingMode, AllColumns)
            })
        }
        function AdditionalInfoGrid_ITR_PostedGrid_dx(container, GridName, RecID, MID, vouchingMode, AllColumns) {
            var url = "/Account/InternalTransfer/Itr_Posted_AdditionalGridData_dx?VouchingMode=" + vouchingMode + "&RecID=" + RecID + "&MID=" + MID
            DxGrid_CreateAdditionalInfoGrid(container, GridName, RecID, vouchingMode, AllColumns, url)
        }
    </script>
