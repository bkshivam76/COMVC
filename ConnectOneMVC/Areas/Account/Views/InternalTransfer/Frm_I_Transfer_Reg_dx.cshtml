    <script>
        function On_ITR_Posted_FABActionItemClick(s, e) {
            var img = document.getElementById('RightPane_Img');
            s.ExpandActionGroupItems();
            if (e.actionName === "add_attach") {
                if (Help_Attachment_AddRight == "False") {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                if (ITR_Posted_ParamMandatory == 1) {
                    AddAttachment(ITR_Posted_RecID_ForAttachment, "Accounts_CashBook", ITR_Posted_Doc_ID, ITR_Posted_Doc_Category, ITR_Posted_ParamMandatory, ITR_Posted_FromDateLabel, ITR_Posted_ToDateLabel, ITR_Posted_DescriptionLabel, "ITR_PostedProfileAttachment", null, "ITR_PostedGrid", ITR_Posted_NestedGrid_AccessID);
                }
                else {
                    Attachment_DirectBrowse(ITR_Posted_RecID_ForAttachment, "Accounts_CashBook", ITR_Posted_Doc_ID, "ITR_PostedProfileAttachment", "ITR_PostedGrid", ITR_Posted_NestedGrid_AccessID);
                }
            }
            else if (e.actionName === "edit_attach") {
                if (Help_Attachment_EditRight == "False") {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                if (ITR_Posted_Attachment_RecStatus.toUpperCase() == "LOCKED") {
                    DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                    return;
                }
                EditAttachment(ITR_Posted_RecID_ForAttachment, "Accounts_CashBook", ITR_Posted_AtachmentID, ITR_Posted_ParamMandatory, ITR_Posted_FromDateLabel, ITR_Posted_ToDateLabel, ITR_Posted_DescriptionLabel, "ITR_PostedProfileAttachment", null, "ITR_PostedGrid", ITR_Posted_NestedGrid_AccessID);
            }
            else if (e.actionName === "delete_attach") {
                if (Help_Attachment_DeleteRight == "False") {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                DeleteAttachment(ITR_Posted_RecID_ForAttachment, "Accounts_CashBook", ITR_Posted_AtachmentID, ITR_Posted_ParamMandatory, ITR_Posted_FromDateLabel, ITR_Posted_ToDateLabel, ITR_Posted_DescriptionLabel, null, "ITR_PostedGrid", ITR_Posted_NestedGrid_AccessID, ITR_Posted_Attachment_RecStatus);
            }
            else if (e.actionName === "view_attach") {
                if (Help_Attachment_ViewRight == "False") {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                ViewDocument(ITR_Posted_AtachmentID, ITR_Posted_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
            }
            else if (e.actionName == "Link_Attach") {
                LinkAttachment(ITR_Posted_RecID_ForAttachment, "Accounts_CashBook", "Internal Transfers Register", "ITR_PostedGrid", ITR_Posted_NestedGrid_AccessID);
            }
            else if (e.actionName === "Add_Reason") {
                if (ITR_Posted_Doc_Category.toLowerCase() == "others") {
                    DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
                }
                else {
                    AttachmentAddReason(ITR_Posted_RecID_ForAttachment, ITR_Posted_NestedRowMapID, "Accounts_CashBook", "ITR_PostedGrid", ITR_Posted_NestedGrid_AccessID);
                }
            }
            else if (e.actionName === "Edit_Reason") {
                AttachmentEditReason(ITR_Posted_RecID_ForAttachment, ITR_Posted_NestedRowMapID, "Accounts_CashBook", "ITR_PostedGrid", ITR_Posted_NestedGrid_AccessID, ITR_Posted_reason);
            }
            else if (e.actionName === "Delete_Reason") {
                AttachmentDeleteReason(ITR_Posted_RecID_ForAttachment, ITR_Posted_NestedRowMapID, "ITR_PostedGrid", ITR_Posted_NestedGrid_AccessID);
            }
            else if (e.actionName === "Rotate") {
                ImageRotate(img);
            }
            else if (e.actionName === "ZoomOut") {
                ImageZoomOut(img);
            }
            else if (e.actionName === "ZoomIn") {
                ImageZoomIn(img);
            }
            else if (e.actionName == "Fit") {
                ImageFit(img);
            }
            else if (e.actionName == "Back") {
                ImageBack(s.uniqueID, "actionItemContext");
            }
            else if (e.actionName == "AuditAction") {
                ITR_PostedPrf_FAB.SetActionContext("AuditActionContext", true);
            }
            else if (e.actionName == "BackAudit") {
                if (ITR_Posted_Nested_Doc_Status == "") {
                    ITR_PostedPrf_FAB.SetActionContext("AutoItemContext", true);
                }
                if (ITR_Posted_Nested_Doc_Status == "NO") {
                    ITR_PostedPrf_FAB.SetActionContext("EditItemContext", true);
                }
                if (ITR_Posted_Nested_Doc_Status == "YES") {
                    ITR_PostedPrf_FAB.SetActionContext("actionItemContext", true);
                }
            }
            else if (e.actionName == "Accept") {
                ITR_Posted_AcceptwithoutRemarks();
            }
            else if (e.actionName == "Reject") {
                ITR_Posted_AcceptRejectVoucher("Reject");
            }
            else if (e.actionName == "AcceptWithRemarks") {
                ITR_Posted_AcceptRejectVoucher("Accept");
            }
        }
        function ITR_Posted_AcceptwithoutRemarks() {          
            var Recid;
            if (ITR_Posted_IsDetailRowExpanded == true || IntrnlTranfrReg_IsVouchingMode == true) {
                if (ITR_Posted_MasterRowRecID == null || ITR_Posted_MasterRowRecID == "") {
                    Recid = ITR_Posted_MasterRowMID;
                }
                else {
                    Recid = ITR_Posted_MasterRowRecID;
                }
            }
            else {
                Recid = ITR_Posted_ID;
            }
            Entry_AcceptwithoutRemarks(Recid, "Accounts_CashBook", "ITR_PostedGrid", ITR_Posted_AtachmentID, ITR_Posted_NestedRowReasonID, ITR_Posted_NestedRowKeyValue);
        }
        function ITR_Posted_AcceptRejectVoucher(_actionMethod) {
            var Recid;

            if (ITR_Posted_IsDetailRowExpanded == true || IntrnlTranfrReg_IsVouchingMode == true) {
                if (ITR_Posted_MasterRowRecID == null || ITR_Posted_MasterRowRecID == "") {
                    Recid = ITR_Posted_MasterRowMID;
                }
                else {
                    Recid = ITR_Posted_MasterRowRecID;
                }
            }
            else {
                Recid = ITR_Posted_ID;
            }
            Entry_AcceptReject(_actionMethod, Recid, "Accounts_CashBook", "ITR_PostedGrid", ITR_Posted_AtachmentID, ITR_Posted_NestedRowReasonID, ITR_Posted_NestedRowKeyValue);
        }
    </script>
    <script>   
        function ITR_PostedGrid_dx_OnInitialized(e)
        {
            ITR_PostedGrid = e.component;
            DxGrid_AdjustSize(e.component, $("#ITR_Reg_ParentDiv_dx .report_button_div"))                  
        }
        function ITR_PostedGrid_dx_OnCellPrepared(e) {
            if (e.rowType == "data") {
                if (IntrnlTranfrReg_IsVouchingMode == true) {
                    if (e.column.dataField === "iIcon") {
                        $(e.cellElement).attr("onmouseover", "OnGridRowMouseHoverIn(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.data.ID + "')");
                        $(e.cellElement).attr("onmouseout", "OnGridRowMouseHoverOut(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.data.ID + "')");
                    }
                }
                $(e.cellElement).attr("id", e.element[0].id + "_Cell_" + e.data.ID + "|" + e.column.dataField);
            }
        }
        function ITR_PostedGrid_dx_OnRowPrepared(e) {
            if (e.rowType == "data") {
                var GridName = e.element[0].id;
                $(e.rowElement).addClass(GridName + "_DataRow_" + e.data.ID);
                DxGrid_CreatePreviewRow(e, IntrnlTranfrReg_IsVouchingMode, "Master")
            }
            else if (e.rowType == "detailAdaptive") {
                DxGrid_MovePreviewRowAfterAdaptiveRow(e)
            }
        }
        async function ITR_PostedGrid_dx_OnContentReady(e)
        {    
            await DxGrid_RowSelectionTobeCheckedAfterAnyAction(e, Expanded_Row_Key_ITR_PostedGrid, ITR_Posted_XID)
            ITR_Posted_XID = null;        
            DxGrid_OnContentReady(e);
        }
        function ITR_PostedGrid_dx_OnCellDblClick(e) {
            if (e.rowType == "data") {
                if (IntrnlTranfrReg_IsVouchingMode == true && IntrnlTranfrReg_ViewMode == "Default") {
                    OnGridCellClick(e.event, e.cellElement[0], e.columnIndex, e.rowIndex, e.element[0].id, e.key, e.column.dataField)
                }
                else if (IntrnlTranfrReg_IsVouchingMode == false) {
                    if (e.rowType == "data") {
                        DataNavigation_ITR("EDIT");
                    }
                }
            }
        }
        function ITR_PostedGrid_dx_OnSelectionChanged(e) {          
            var selectedRowKeys = e.selectedRowKeys;
            if (selectedRowKeys != null && selectedRowKeys.length > 0) {
                if (IntrnlTranfrReg_IsVouchingMode) {
                    ITR_PostedPrf_FAB.SetVisible(true);
                    ITR_PostedPrf_FAB.SetActionContext("AddAttachmentContext", false);
                }
                ITR_PostedGridOnGetRowValues_dx(e.selectedRowsData);
            }
            else {
                ITR_Posted_ID = null;
                ITR_Posted_updateFooterDetail(ITR_Posted_ID, ITR_Posted_ActionStatus, ITR_Posted_AddDate, ITR_Posted_AddBy, ITR_Posted_ActionDate, ITR_Posted_ActionBy, ITR_Posted_EditDate, ITR_Posted_EditBy);
            }
        }
        function ITR_PostedGridOnGetRowValues_dx(data) {
            var value = data[0];
            ITR_Posted_ActionBy = value["ActionBy"];
            ITR_Posted_ActionDate = (JS_Json_Date_To_ddMMyyyy((value["ActionDate"] ?? ""), "DD-MM-YYYY HH:mm:ss") ?? "");
            ITR_Posted_ActionStatus = value["ActionStatus"];
            ITR_Posted_AddBy = value["AddBy"];
            ITR_Posted_AddDate = (JS_Json_Date_To_ddMMyyyy((value["AddDate"] ?? ""), "DD-MM-YYYY HH:mm:ss") ?? "");
            ITR_Posted_EditBy = value["EditBy"];
            ITR_Posted_EditDate = (JS_Json_Date_To_ddMMyyyy((value["EditDate"] ?? ""), "DD-MM-YYYY HH:mm:ss") ?? "");
            ITR_Posted_ID = value["ID"];
            ITR_Posted_MID = value["MID"];
            ITR_Posted_Date = (JS_Json_Date_To_ddMMyyyy((value["xDate"] ?? ""), "DD-MM-YYYY") ?? "");
            ITR_Posted_ITEM_ID = value["TR_ITEM_ID"];
            ITR_Posted_Srno = value["TR_SR_NO"];
            ITR_Posted_Type = value["TR_TYPE"];
            ITR_Posted_updateFooterDetail(ITR_Posted_ID, ITR_Posted_ActionStatus, ITR_Posted_AddDate, ITR_Posted_AddBy, ITR_Posted_ActionDate, ITR_Posted_ActionBy, ITR_Posted_EditDate, ITR_Posted_EditBy);

            if (IntrnlTranfrReg_IsVouchingMode) {
                OpenLeftPane();
                LeftPaneContent_ITR_Posted_dx("ITR_PostedGrid", ITR_Posted_ID, ITR_Posted_MID, IntrnlTranfrReg_IsVouchingMode)
            }
        }
        function ITR_Posted_updateFooterDetail(ITR_Posted_ID, ITR_ActionStatus, ITR_AddDate, ITR_AddBy, ITR_ActionDate, ITR_ActionBy, ITR_EditDate, ITR_EditBy) {
            var Status = "";
            var Lbl_Status = "";
            var Lbl_StatusBy = "";
            var Pic_Status = "";
            var Lbl_Create = "";
            var Lbl_Modify = "";
            var Lbl_Status_Color = "";
            var Lbl_ActionOn = "";
            var Lbl_ActionBy = "";
            var StatusStr = "";
            if (ITR_Posted_ID) {
                Status = ITR_ActionStatus;
                StatusStr = Status == "Locked" ? "Locked" : Status == null ? null : "UnLocked";

                if (Status && Status.toUpperCase() == "LOCKED") {
                    Lbl_Status = "Completed";
                    Lbl_Status_Color = "blue";
                    Pic_Status = "fa fa-lock";
                }
                else {
                    Pic_Status = "fa fa-unlock";
                    Lbl_Status = Status;
                    if (Status && Status.toUpperCase() == "COMPLETED") {
                        Lbl_Status_Color = "green";
                    }
                    else {
                        Lbl_Status_Color = "red";
                    }
                }

                if (ITR_AddDate) {
                    Lbl_Create = "Add On: " + ITR_AddDate + ", By: " + ITR_AddBy;
                }
                if (ITR_EditDate) {
                    Lbl_Modify = "Edit On: " + ITR_EditDate + ", By: " + ITR_EditBy;
                }
                if (ITR_ActionDate) {
                    Lbl_ActionOn = StatusStr + " On: " + ITR_ActionDate;
                }
                if (ITR_ActionBy) {
                    Lbl_ActionBy = StatusStr + " By: " + ITR_ActionBy;
                }
            }
            $('#ITR_Posted_Lbl_Status').text(Lbl_Status);
            $('#ITR_Posted_Lbl_Create').text(Lbl_Create);
            $('#ITR_Posted_Lbl_ActionOn').text(Lbl_ActionOn);
            $('#ITR_Posted_Lbl_ActionBy').text(Lbl_ActionBy);
            $('#ITR_Posted_Lbl_Modify').text(Lbl_Modify);
            if (Lbl_Status_Color != "") {
                $('#ITR_Posted_Lbl_Status').css('color', Lbl_Status_Color);
            }
            if (Pic_Status == "fa fa-lock") {
                $('#ITR_Posted_LockICON').addClass(Pic_Status).removeClass("fa-unlock");
            }
            else if (Pic_Status == "fa fa-unlock") {
                $('#ITR_Posted_LockICON').addClass(Pic_Status).removeClass("fa-lock");
            }
            else {
                $('#ITR_Posted_LockICON').removeClass("fa").removeClass("fa-lock").removeClass("fa-unlock");
            }
        }
        function ITR_PostedGrid_dx_OnContextMenuPreparing(e) {         
            if (!e.items) e.items = [];
            if (e.target == "header") {
                DxGrid_HeaderContextMenu(e)
            }
            else if ((e.target == "content" && e.row && e.row.rowType == "groupFooter") || e.target == "footer") {
                if (IntrnlTranfrReg_ViewMode == "Compact")
                    DxGrid_FooterContextMenu(e, true);
                else
                    DxGrid_FooterContextMenu(e);
            }
            else if (e.target == "content" && e.row && (e.row.rowType == "data" || e.row.rowType == "detailAdaptive")) {
                var key = e.component.getKeyByRowIndex(e.row.rowIndex);
                e.component.selectRows(key);
                var expanded = e.component.isRowExpanded(key);
                e.items = [{
                    text: "Expand Detail",
                    icon: "fa-solid fa-arrow-down-wide-short " + (expanded ? "text-muted" : "text-info"),
                    disabled: expanded,
                    visible: !IntrnlTranfrReg_IsVouchingMode,
                    onItemClick: function () {
                        if (expanded) {
                        }
                        else {
                            e.component.expandRow(key);
                        }
                    }
                },
                {
                    text: "Collapse Detail",
                    icon: "fa-solid fa-arrow-up-wide-short " + (!expanded ? "text-muted" : "text-info"),
                    disabled: !expanded,
                    visible: !IntrnlTranfrReg_IsVouchingMode,
                    onItemClick: function () {
                        if (expanded) {
                            e.component.collapseRow(key);
                        }
                        else {
                        }
                    }
                },
                {
                    text: "Accept Transfer",
                    icon: "../../../../Icons/Accept-icon.png",
                    beginGroup: true,
                    onItemClick: function () {
                        DataNavigation_ITR("ACCEPT");
                    }
                },
                {
                    text: "Edit Common Info",
                    icon: "fa-solid fa-file-pen",
                    onItemClick: function () {
                        DataNavigation_ITR("EDIT-COMMON");
                    }
                },
                {
                    text: "Export",
                    icon: "fa-solid fa-plus text-success",
                    onItemClick: function () {
                        OnITRListPreviewClick();
                    }
                },
                {
                    text: "Close",
                    icon: "fa-solid fa-rectangle-xmark text-danger",
                    onItemClick: function () {
                        $(".TabPanalMenu-tabs .active span").click();
                    }
                },
                {
                    text: "Refresh",
                    beginGroup: true,
                    icon: "fa-solid fa-arrow-rotate-right text-success",
                    onItemClick: function () {
                        RefreshGridView("ITR_PostedGrid")
                    }
                }

                ]
            }
            else if (e.target == "content" && e.row == void 0) {
                e.items = [{
                    text: "Close",
                    icon: "fa-solid fa-rectangle-xmark text-danger",
                    onItemClick: function () {
                        $(".TabPanalMenu-tabs .active span").click();
                    }
                },
                {
                    text: "Refresh",
                    beginGroup: true,
                    icon: "fa-solid fa-arrow-rotate-right text-success",
                    onItemClick: function () {
                        RefreshGridView("ITR_PostedGrid")
                    }
                }

                ]
            }
        }
        function ITR_PostedGrid_dx_OnRowExpanding(e) {
            if (Array.isArray(e.key) == false) //not group row
            {
                e.component.collapseRow(Expanded_Row_Key_ITR_PostedGrid)
                e.component.selectRows(e.key);
                Expanded_Row_Key_ITR_PostedGrid = e.key;
                ITR_Posted_IsDetailRowExpanded = true;
                var DetailGridID = e.element[0].id + e.key;
                var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
                if (instance != void 0) {
                    instance.state(null) // grid maintains its state after collapsing so resetting the state when expands again as per old grid
                }
                //e.component.collapseAll(-1);
            }
            else {
                e.component.option("CustomProp.groupRowExpanded", true);
            }
        }
        function ITR_PostedGrid_dx_OnRowCollapsing(e) {
            if (Array.isArray(e.key) == false) //not group row
            {
                var DetailGridID = e.element[0].id + e.key;
                sessionStorage.removeItem(DetailGridID + "_DetailGridState") //removing grid state from session storage on collapse
                ITR_Posted_IsDetailRowExpanded = false;
                e.component.selectRows(e.key);
                if (IntrnlTranfrReg_IsVouchingMode == false) {
                    ITR_PostedPrf_FAB.SetVisible(false);
                }
                var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
                if (instance != void 0) {
                    instance.clearSelection();
                }
            }
            else {
                e.component.option("CustomProp.groupRowCollapsed", true);
            }
        }

