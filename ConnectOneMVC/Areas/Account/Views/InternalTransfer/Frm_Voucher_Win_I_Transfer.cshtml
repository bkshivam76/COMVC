                                            @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("ITV_GLookUp_ItemList").Name("ITV_GLookUp_ItemList").ValueExpr("ITEM_ID").DisplayExpr("ITEM_NAME").DataSource(d => d.Mvc().Controller("InternalTransfer").LoadAction("LookUp_GetItemList_InternalTransfer").Key("ITEM_ID").LoadParams(new { DDRefresh = new JS("function (){ return ItemDDRefresh_ITV;}") }))
                                                                                         .OnValueChanged("GLookUp_ItemList_EditValueChanged_ITV").ContentTemplate(@<text> @Html.Partial("LookUp_GetItemList_InternalTransfer") </text>).ReadOnly(true).FocusStateEnabled(false).OnFocusOut("GLookUp_ItemList_Leave_ITV"))
                                            @Html.ValidationMessageFor(model => model.ITV_GLookUp_ItemList, "", new { @class = "text-red" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div> <!--[Item Name]-->
                    <div class="col-sm-4">
                        <div class="form-field">
