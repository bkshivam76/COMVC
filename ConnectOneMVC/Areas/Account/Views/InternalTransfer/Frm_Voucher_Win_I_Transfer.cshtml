                                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("ITV_BE_Fr_Zone").Name("ITV_BE_Fr_Zone").ReadOnly(true).FocusStateEnabled(false))
                                        </div>
                                    </div>
                                </fieldset>
                            </div>
                        </div>
                    </div>
                </div><!--[Transfer from]-->
