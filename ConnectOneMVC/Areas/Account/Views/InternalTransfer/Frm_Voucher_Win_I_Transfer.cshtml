    <script>
        function hide_trfbank_datagrid_columns() {
            var $grid = $("#Frm_Voucher_Win_ItemInternalTransfer_GLookUp_TrfBankList_Centre_datagrid");
            if (ITV_Cmd_Mode.toUpperCase() == "CHEQUE" || ITV_Cmd_Mode.toUpperCase() == "CBS" || ITV_Cmd_Mode.toUpperCase() == "RTGS" || ITV_Cmd_Mode.toUpperCase() == "NEFT" || (ITV_Cmd_Mode.toUpperCase() == "CASH TO BANK" && ITR_iTrans_Type == "DEBIT")) {
                $grid.dxDataGrid('columnOption', 'TRF_BA_ACCOUNT_NO', 'visible', true);
                $grid.dxDataGrid('columnOption', 'TRF_BB_BRANCH_NAME', 'visible', true);
