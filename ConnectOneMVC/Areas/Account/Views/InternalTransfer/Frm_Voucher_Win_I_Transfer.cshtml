                            $("#ITV_GLookUp_TrfBankList").find('input').css('color', '#008000');
                            $("#ITV_Txt_Trf_Branch").find('input').css('color', '#008000');
                            $("#ITV_Txt_Trf_ANo").find('input').css('color', '#008000');
                        }
                    }
                    $("#ITV_Txt_Ref_No").dxTextBox("instance").option("value", TransformText("@Model._BI_REF_NO"));
                    $("#ITV_Txt_Ref_No").dxTextBox("instance").option("readOnly", true);
                    $("#ITV_Txt_Ref_No").find('input').css('color', '#008000');
                    if ("@Model.ITV_iTrans_Type".toUpperCase() == "DEBIT" && "@Model.ITV_Cmd_Mode".toUpperCase() == "DD")
                    {
                        $("#ITV_Txt_DD_Fr_Chq_No").dxTextBox("instance").option("visible", true);
