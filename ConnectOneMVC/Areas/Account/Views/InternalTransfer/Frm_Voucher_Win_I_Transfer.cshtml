                        $("#ITV_Txt_DD_Fr_Chq_No").dxTextBox("instance").option("readOnly", false);
                    }
                    if ("@Model._BI_REF_DT".length > 0)
                    {
                        if ("@Model._BI_REF_DT".length > 0)
                        {
                            $("#ITV_Txt_Ref_Date").dxDateBox("instance").option("value", moment("@Model._BI_REF_DT", "DD/MM/YYYY"));
                        }
                        $("#ITV_Txt_Ref_Date").dxDateBox("instance").option("readOnly", true);
                        $("#ITV_Txt_Ref_Date").find('input').css('color', '#008000');
                    }
                }
                $("#ITV_Txt_Amount").dxNumberBox("instance").option("value", parseFloat("@Model.ITV_Txt_Amount"));
                $("#ITV_Txt_Bank_Chg").dxNumberBox("instance").option("value", parseFloat("@Model.ITV_Txt_Bank_Chg"));
