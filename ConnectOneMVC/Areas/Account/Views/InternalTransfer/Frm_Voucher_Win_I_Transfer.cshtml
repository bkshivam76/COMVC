                                    </div>
                                </div>
                            </div>
                        </div>
                    </div><!--[V date]-->
                </div><!--[row 1]-->
                <div class="row">
                    <div class="col-sm-5">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <div class="col-sm-5 pll">
                                        @Html.Label("Head:", htmlAttributes: new { @class = "control-label disabletxt", @id = "lbl_itemhead" })
                                    </div>
                                    <div class="col-sm-7 prm">
                                        @(Html.DevExtreme().TextBox().CustomTextBox().ID("ITV_BE_Item_Head").Name("ITV_BE_Item_Head").Value(Model.ITV_BE_Item_Head).ReadOnly(true).MaxLength(50) )

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div><!--[head]-->
