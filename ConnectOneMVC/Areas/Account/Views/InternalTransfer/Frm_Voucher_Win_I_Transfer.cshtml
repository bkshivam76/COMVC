                $("#ITV_Txt_Trf_ANo").dxTextBox("instance").option("value", Accno);
                $("#ITV_Txt_Trf_Branch").dxTextBox("instance").option("value", Branch);
            }
            TrfBank_DataGrid_ITV.option("focusedRowIndex", -1);
            TrfBank_DataGrid_ITV.option("focusedRowEnabled", false);
            TrfBank_DataGrid_ITV.clearFilter();
            return;
        }
        if (TrfBank_DataGrid_ITV.getSelectedRowsData().length > 0)
        {
            var item = TrfBank_DataGrid_ITV.getSelectedRowsData()[0];
            $("#REC_EDIT_ON_Trf_Bank").val(item["REC_EDIT_ON"]);
            if (ITV_Cmd_Mode == "CHEQUE" || ITV_Cmd_Mode == "CBS" || ITV_Cmd_Mode == "RTGS" || ITV_Cmd_Mode == "NEFT" || ITV_Cmd_Mode == "CASH TO BANK")
            {
                $("#ITV_Txt_Trf_ANo").dxTextBox("instance").option("value", item["TRF_BA_ACCOUNT_NO"]);
                $("#ITV_Txt_Trf_Branch").dxTextBox("instance").option("value", item["TRF_BB_BRANCH_NAME"]);
            }
        }
    }
