                    $("#ITV_GLookUp_PurList").dxSelectBox("instance").option("value", "@Model.ITV_GLookUp_PurList");
                    $("#ITV_GLookUp_PurList").dxSelectBox("instance").option("readOnly", true);
                    $("#ITV_GLookUp_PurList").find('input').css('color', '#008000');
                }
            }
            else if ("@Model._Pending_List" == "True")
            {
                ShowLoader();
                OpenPopup("Frm_I_Transfer_Pending", "Pending Internal Transfer Entries", "/Account/InternalTransfer/Frm_I_Transfer_Pending", "auto", 1000, false, null);
                HideLoader();
            }
        }
        if ("@Model.Tag" == "_New_From_Selection" && $("#USE_CROSS_REF").val() == "False")
        {
            await Item_DataGrid_ITV.selectRows("@Model.ITV_iSpecific_ItemID", false);
            Control_SetReadOnly("ITV_GLookUp_ItemList", "dxDropDownBox", false);
            setTimeout(function()
            {
                $("#ITV_Txt_V_Date").dxDateBox("instance").focus();
            })
        }

        //FCRA Related
        if (parseInt("@Model.splVchrRefsCount_ITV") == 0)
            {
                $("#ITV_SpecialVoucherRefDiv").remove();
                //$("#ITV_NarrationDiv").removeClass("col-sm-12 col-md-8 col-lg-8").addClass("col-sm-12 col-md-12");
            }
        //await $("#ListSpecialVoucherRef_ITV").dxList("getDataSource").load();
        if (parseInt("@Model.splVchrRefsCount_ITV") > 0) {
                //await $("#ListSpecialVoucherRef_ITV").dxList("getDataSource").load();
                OnSplVchrRefsListSelectionChanged_ITV();
            }


        await Load_from_Last_voucher();
        if ("@Model._Pending_List" != "True")
        {
            ITV_Form_Load();
        }
    });

    async function Load_from_Last_voucher()
    {
        if ("@Model.Selected_Mode".length > 0)
        {
            if ("@Model.Selected_Item_ID".length > 0)
            {
                await Item_DataGrid_ITV.selectRows("@Model.Selected_Item_ID", false);
                await GLookUp_ItemList_Leave_ITV();
            }
            $("#ITV_Cmd_Mode").dxSelectBox("instance").option("value", "@Model.Selected_Mode");
            if ("@Model.Selected_Mode" != "CASH")
            {
                $("#ITV_Txt_V_Date").dxDateBox("instance").option("readOnly", false);
                await Bank_DataGrid_ITV.selectRows("@Model.Selected_Bank_ID", false);
                Control_SetReadOnly("#ITV_GLookUp_BankList", "dxDropDownBox", false);
            }
        }
        if ("@Model.Selected_Amount".length > 0)
        {
            $("#ITV_Txt_Amount").dxNumberBox("instance").option("value", parseFloat("@Model.Selected_Amount"));
            if ("@Model.Selected_Ref_Date".length > 0)
            {
                $("#ITV_Txt_Ref_Date").dxDateBox("instance").option("value", moment("@Model.Selected_Ref_Date", "DD/MM/YYYY"));
            }
            if ("@Model.Selected_RefC_Date".length > 0)
            {
                $("#ITV_Txt_Ref_CDate").dxDateBox("instance").option("value", moment("@Model.Selected_RefC_Date", "DD/MM/YYYY"));
            }
            $("#ITV_Txt_Ref_No").dxTextBox("instance").option("value", TransformText("@Model.Selected_RefNo"));
            if ("@Model.Selected_Drawee_Bank_ID".length > 0)
            {
                await TrfBank_DataGrid_ITV.selectRows("@Model.Selected_Drawee_Bank_ID", false);
            }
            $("#ITV_Txt_Trf_Branch").dxTextBox("instance").option("value", TransformText("@Model.Selected_Drawee_Branch"));
        }
    }
    function ITV_Form_Load()
    {
        if ("@Model.Tag" == "_New_From_Selection")
        {
            setTimeout(function ()
            {
                $("#ITV_Txt_V_Date").dxDateBox("instance").focus();
            })
        }
        else
        {
            if ("@Model.Selected_Item_ID".length == 0)
            {
                setTimeout(function ()
                {
                    //$("#ITV_GLookUp_ItemList").dxDropDownBox("instance").focus();
                });
                if ("@Model.Tag" == "_Edit")
                {
                    $("#ShowChangeItemEffects").val(false);
                }
            }
            else
            {
                $("#ShowChangeItemEffects").val(false);
                if ($("#ITV_iTrans_Type").val() == "DEBIT")
                {
                    setTimeout(function ()
                    {
                        $("#ITV_GLookUp_ToCen_List").dxDropDownBox("instance").focus();
                    });
                }
                else
                {
                    setTimeout(function ()
                    {
                        $("#ITV_GLookUp_FrCen_List").dxDropDownBox("instance").focus();
                    });
                }
                $("#ShowChangeItemEffects").val(true);
            }
        }
        FormInitialSettings("FormID_Frm_Voucher_Win_I_Transfer", "@Model.Tag");
    }
    function TDS_HidePopUp(e)
    {
        $.ajax({
            type: 'GET',
            url: "/Account/InternalTransfer/ITR_TDS_SessionClear",
            cache: false
        });
    }
    function Pending_HidePopUp(e)
    {
        $.ajax({
            type: 'GET',
            url: "/Account/InternalTransfer/IT_Pending_SessionClear",
            cache: false
        });
        if ($("#ITV_Cmd_Mode").dxSelectBox("instance").option("value") == null)
        {
            $("#ITV_Cmd_Mode").dxSelectBox("instance").option("value", "CASH");
        }
        ITV_Form_Load();
    } //itv_pending_popup hide

