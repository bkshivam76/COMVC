                                        <div class="col-sm-2 prm">
                                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("ITV_BE_Fr_Incharge").Name("ITV_BE_Fr_Incharge").ReadOnly(true).FocusStateEnabled(false) )
