                $grid.dxDataGrid('columnOption', 'TRF_STATUS', 'visible', true);
            }
            else if (ITV_Cmd_Mode.toUpperCase() == "DD") {
                $grid.dxDataGrid('columnOption', 'TRF_BB_BRANCH_NAME', 'visible', false);
                $grid.dxDataGrid('columnOption', 'TRF_BA_ACCOUNT_NO', 'visible', false);
                $grid.dxDataGrid('columnOption', 'TRF_IFSC_CODE', 'visible', false);
                $grid.dxDataGrid('columnOption', 'TRF_STATUS', 'visible', false);
            }
            $grid.dxDataGrid("instance").repaint();
        }
        function TRF_Bank_GridIFSC_Visible() {
            $("#ITV_GLookUp_TrfBankList").dxDropDownBox({

                valueExpr: "TRF_BI_ID",
                placeholder: "Select Bank...",
                displayExpr: function (item) {
                    item.TRF_BI_BANK_NAME;
                },
                showClearButton: true,
                dataSource: new DevExpress.data.CustomStore({
                    loadMode: "raw",
                    key: "TRF_BI_ID",
                    load: function () {
                        return $.getJSON("/InternalTransfer/LookUp_GetTrfBankList_InternalTransfer", { "ITV_Cmd_Mode": ITV_Cmd_Mode, "iTrans_Type": iTrans_Type, "iTO_CEN_ID": iTO_CEN_ID, "iFR_CEN_ID": iFR_CEN_ID });
                    }
                }),
                contentTemplate: function (e) {
                    var value = e.component.option("value"),
                        $dataGrid = $("<div>").dxDataGrid({
                            dataSource: e.component.option("dataSource"),
                            columns: ["TRF_BI_BANK_NAME", "TRF_BI_SHORT_NAME", "TRF_STATUS", "TRF_IFSC_CODE", "TRF_BB_BRANCH_NAME", "TRF_BA_ACCOUNT_NO"],
                            hoverStateEnabled: true,
                            paging: { enabled: true, pageSize: 10 },
                            filterRow: { visible: true },
                            scrolling: { mode: "infinite" },
                            height: 265,
                            selection: { mode: "single" },
                            selectedRowKeys: [value],
                            onSelectionChanged: function (selectedItems) {
                                var keys = selectedItems.selectedRowKeys,
                                    hasSelection = keys.length;

                                e.component.option("value", hasSelection ? keys[0] : null);
                            }
                        });

                    dataGrid = $dataGrid.dxDataGrid("instance");

                    e.component.on("valueChanged", function (args) {
                        dataGrid.selectRows(args.value, false);
                    });

                    return $dataGrid;
                }
            });
        }
        function ITR_cmdmode_validations(ITV_Cmd_Mode) {
            $("#ITV_Txt_Ref_No").dxTextBox({})
                .dxValidator({
                    validationRules: [{
                        type: 'custom',
                        validationCallback: function (options) {
                            var result = true;
                            if (ITV_Cmd_Mode != "CASH") {
                                if (options.value == "" || options.value == null) {
                                    result = false;
                                }
                            }
                            return result;
                        },
                        reevaluate: true,
                        message: "Cannot Be Blank..!!"
                    },
                    {
                        type: 'custom',
                        validationCallback: function (options) {
                            var result = true;
                            if (ITV_Cmd_Mode == "CHEQUE" || ITV_Cmd_Mode == "DD") {
                                var reg = /^[0-9]{6,8}$/;
                                if (!(reg.test(options.value))) {
                                    result = false
                                }
                            }
                            return result;
                        },
                        reevaluate: true,
                        message: "Invalid Format(Min 6 Digits Max 8 Digits)"
                    },
                    {
                        type: 'custom',
                        validationCallback: function (options) {
                            var result = true;
                            if (ITV_Cmd_Mode == "CASH TO DD") {
                                var reg = /^[0-9]{6}$/;
                                if (!(reg.test(options.value))) {
                                    result = false
                                }
                            }
                            return result;
                        },
                        reevaluate: true,
                        message: 'Invalid Format(6 digits Required)'
                    }//Redmine Bug #133202 fixed//Redmine Bug #133182 fixed
                    ],
                    validationGroup: "ITR_Validation"
                });

            $("#ITV_GLookUp_TrfBankList").dxDropDownBox({})
                .dxValidator({
                    validationRules: [{
                        type: 'custom',
                        validationCallback: function (options) {
                            var result = true;
                            if (ITR_iTrans_Type.toUpperCase() == "DEBIT") //redmine Bug #133219 fixed
                            {
                                if (ITV_Cmd_Mode != "CASH" && ITV_Cmd_Mode != "CHEQUE") {
                                    if (options.value == "" || options.value == null) {
                                        result = false;
                                    }
                                }
                            }
                            else {
                                if (ITV_Cmd_Mode == "DD") {
                                    if (options.value == "" || options.value == null) {
                                        result = false;
                                    }
                                }
                            }
                            return result;
                        },
                        reevaluate: true,
                        message: "Cannot Be Blank!!"
                    }
                    ],
                    validationGroup: "ITR_Validation"
                });

            $("#ITV_Txt_Trf_ANo").dxTextBox({})
                .dxValidator({
                    validationRules: [{
                        type: 'custom',
                        validationCallback: function (options) {
                            var result = true;
                            if (ITR_iTrans_Type.toUpperCase() == "DEBIT" && ITV_Cmd_Mode != "CASH" && ITV_Cmd_Mode != "CHEQUE" && ITV_Cmd_Mode != "CASH TO DD" && ITV_Cmd_Mode != "DD" && $("#ITV_Txt_Trf_ANo").dxTextBox("option", "readOnly") == false)//Redmine Bug #133168 fixed//Redmine Bug #133171 fixed
                            {
                                if (options.value == "" || options.value == null) {
                                    result = false;
                                }
                            }
                            return result;
                        },
                        reevaluate: true,
                        message: "Cannot Be Blank!!"
                    }
                    ],
                    validationGroup: "ITR_Validation"
                });
        }
