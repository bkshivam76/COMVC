                                                                                                                                                                                                                                                                                                                                                                                                          .OnValueChanged("GLookUp_BankList_EditValueChanged_ITV").ReadOnly(true).ContentTemplate(@<text> @Html.Partial("LookUp_GetBankList_InternalTransfer") </text>) )
