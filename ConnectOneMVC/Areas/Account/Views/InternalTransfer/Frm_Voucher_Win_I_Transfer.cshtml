                                    </div>
                                    <div class="col-sm-9 prm plm">
                                        @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("ITV_Cmd_Mode").Name("ITV_Cmd_Mode").DataSource(new[] { "CASH", "CASH TO DD", "CHEQUE", "DD", "CBS", "RTGS", "NEFT", "CASH TO BANK" }).Value("CASH").ShowClearButton(false).OnValueChanged("Cmd_ModeChange"))@*Redmine Bug #133166 fixed*@
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div><!--[mode]-->
                    <div class="col-sm-4">
