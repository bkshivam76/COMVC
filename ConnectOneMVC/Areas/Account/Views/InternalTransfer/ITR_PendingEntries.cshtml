                            <i id="ITR_Pending_LockICON" style="color:red;font-size:35px;"></i>
                        </div>

                        <div class="footer-locktext">
                            <div id="ITR_Pending_Lbl_ActionOn" class="left_footertext_top"></div>
                            <div id="ITR_Pending_Lbl_ActionBy" class="left_footertext_bottom">
                            </div>
                        </div>
                    </div>

                    <div class="col-sm-6 col-md-6 col-lg-6">
