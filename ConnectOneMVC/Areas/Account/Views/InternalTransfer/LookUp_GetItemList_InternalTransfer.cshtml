
@using ConnectOneMVC.Controllers;
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                    .ID("Frm_Voucher_Win_ItemInternalTransfer_GLookUp_ItemList_datagrid")
                    .Columns(columns =>
                    {
                        columns.Add().DataField("ITEM_NAME").Caption("Name");
                        columns.Add().DataField("LED_NAME").Caption("Head");
                        columns.Add().DataField("ITEM_ID").Caption("ITEM_ID").Visible(false);
                        columns.Add().DataField("ITEM_TRANS_TYPE").Caption("ITEM_TRANS_TYPE").Visible(false);
                        columns.Add().DataField("ITEM_LED_ID").Caption("ITEM_LED_ID").Visible(false);
                        columns.Add().DataField("ITEM_VOUCHER_TYPE").Caption("ITEM_VOUCHER_TYPE").Visible(false);

                    })
                    .Selection(s => s.Mode(SelectionMode.Single))
             )

