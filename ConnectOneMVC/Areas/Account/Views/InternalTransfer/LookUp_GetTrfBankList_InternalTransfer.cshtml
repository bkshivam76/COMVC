@using ConnectOneMVC.Controllers;

@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()

            .ID("Frm_Voucher_Win_ItemInternalTransfer_GLookUp_TrfBankList_Centre_datagrid")
            .Columns(columns =>
            {

                columns.Add().DataField("TRF_BI_BANK_NAME").Caption("Name");
                columns.Add().DataField("TRF_BI_SHORT_NAME").Caption("Short");
                columns.Add().DataField("TRF_BA_ACCOUNT_NO").Caption("Account No.").Visible(false);
                columns.Add().DataField("TRF_IFSC_CODE").Caption("IFSC CODE").Visible(false);
                columns.Add().DataField("TRF_BB_BRANCH_NAME").Caption("Branch").Visible(false);
                columns.Add().DataField("TRF_STATUS").Caption("Status").Visible(false);
                columns.Add().DataField("BA_FERA_ACC").Caption("BA_FERA_ACC").Visible(false);
                columns.Add().DataField("TRF_BI_ID").Caption("TRF_BI_ID").Visible(false);
                columns.Add().DataField("BA_REC_ID").Caption("BA_REC_ID").Visible(false);
                columns.Add().DataField("REC_EDIT_ON").Caption("REC_EDIT_ON").Visible(false);               
            })         
            .Selection(s => s.Mode(SelectionMode.Single))
              .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;component.option('value', keys[0]);}")//redmine Bug #133183 fix
            )


