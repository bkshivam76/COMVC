
@using DevExpress.XtraReports.UI;
@using DevExtreme.AspNet.Mvc;

@Html.DevExpress().DocumentViewer(
            settings =>
            {
                settings.Name = "ReportViewer";
                settings.Report = (XtraReport)Session["pInternalTransferReport"];
                settings.CallbackRouteValues = new { Controller = "InternalTransfer", Action = "ReportViewerPartial", isFromReportViewer = true };
                settings.ExportRouteValues = new { Controller = "InternalTransfer", Action = "ReportViewerExportTo" };
            }).GetHtml()