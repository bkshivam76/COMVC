    <script>
        //FCRA Related
        function OnSplVchrRefsListSelectionChanged_Jv(e) {
            var listBox = $("#ListSpecialVoucherRef_Jv").dxList("instance");
            var selecteditemkey = listBox.option("selectedItemKeys")
            if (selecteditemkey != null && selecteditemkey.length > 0) {
                $("#Jv_SplVchrReferenceSelected").val(selecteditemkey.join(","));
