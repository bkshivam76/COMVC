                            <div class="col-sm-9 prm">
                                @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Txt_Qty_JV_Itm").Name("Txt_Qty_JV_Itm")
                                            .OnValueChanged("Txt_Qty_Rate_EditValueChanged_Itm").Value(Model.Txt_Qty_JV_Itm)
