                return;
            }
            if ($("#iPartyID_JV_Itm").val().length > 0) {
                await JV_PartyList_Itm.selectRows($("#iPartyID_JV_Itm").val(), false);
                //$("#GLookUp_PartyList_JV_Itm").dxDropDownBox("instance").option('value', $("#iPartyID_JV_Itm").val());
            }
            else {
                JV_PartyList_Itm.clearSelection();
            }
        }
