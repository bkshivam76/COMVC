    <script>
        function Item_DetailAjaxSuccess_JV_Itm(data) {
            //debugger;
            HideLoader();
            if (data.jsonParam.result == false) {
                var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                alertclick.done(function (alertResult) {
                    if (alertResult) {
                        if (data.jsonParam.focusid) {
                            var id = "#" + data.jsonParam.focusid;
                            setTimeout(function () {
                                $(id).find('input').focus();
                            }, 250);
                        }
                    }
                });
            }
            else if (data.jsonParam.result == true) {
                if (data.jsonParam.popup_form_path == "" || data.jsonParam.popup_form_path == null) {
                    Fill_Item_Grid_JournalVoucher();
                }
                else {
                    ShowLoader();
                    if (data.jsonParam.popup_form_name == "Frm_Voucher_Win_Journal_Reference") {
                        OpenPopup("JV_Item_Content_popup", data.jsonParam.popup_title, data.jsonParam.popup_form_path + "?" + data.jsonParam.popup_querystring, "auto", 800, false, null);
                    }
                    else {
                        OpenPopup("JV_Item_Content_popup", data.jsonParam.popup_title, data.jsonParam.popup_form_path + "?" + data.jsonParam.popup_querystring, "auto", 1000, false, null);
                    }
                }
            }
        }
        $(function () {
            $("#JV_Item_Content_popup").dxPopup({
                onHiding: function (e) {
                    $.ajax({
                        type: 'GET',
                        url: "/Account/ProfilePaymentVoucher/ProfilePaymentClearSession",
                        cache: false,
                    });
                }
            });
        });
    </script>
