        function GLookUp_ItemList_EditValueChanged_Itm(e) {
            //debugger;
            e.component.close();
            if ((e.value == null || e.value.length == 0) && e.previousValue != null) {
                JV_ItemList_Itm.clearSelection();
                $("#BE_Item_Head_JV_Itm").dxTextBox("instance").reset();
                $("#Txt_ItemNature_JV_Itm").dxTextBox("instance").reset();
                return;
            }
            if (JV_ItemList_Itm.getSelectedRowsData().length > 0) {
                //debugger;
                var item = JV_ItemList_Itm.getSelectedRowsData()[0];
                $("#GLookUp_ItemName_JV_Itm").val(item["ITEM_NAME"]);
                $("#BE_Item_Head_JV_Itm").dxTextBox("instance").option("value", item["LED_NAME"]);
                $("#Txt_ItemNature_JV_Itm").dxTextBox("instance").option("value", item["ITEM_VOUCHER_TYPE"])
                $("#iLed_ID_JV_Itm").val(item["ITEM_LED_ID"]);
                $("#iProfile_JV_Itm").val(item["ITEM_PROFILE"]);
                $("#iCond_Ledger_ID_JV_Itm").val(item["ITEM_CON_LED_ID"]);
                $("#iMinValue_JV_Itm").val(item["ITEM_CON_MIN_VALUE"]);
                $("#iMaxValue_JV_Itm").val(item["ITEM_CON_MAX_VALUE"]);
                $("#iLed_Type_JV_Itm").val(item["LED_TYPE"]);
                $("#iCon_Led_Type_JV_Itm").val(item["CON_LED_TYPE"]);

                SetRefType();
                $("#iTDScode_JV_Itm").val(item["ITEM_TDS_CODE"]);
                $("#iParty_Req_JV_Itm").val("NO");

                if ($("#iProfile_JV_Itm").val().toUpperCase() == "ADVANCES" || $("#iProfile_JV_Itm").val().toUpperCase() == "OTHER DEPOSITS" ||
                    $("#iProfile_JV_Itm").val().toUpperCase() == "OTHER LIABILITIES" || $("#iLed_ID_JV_Itm").val() == "00182"
                    || item["LED_NAME"].toUpperCase().includes("TDS")) {
                    if (!item["LED_NAME"].toUpperCase().includes("TDS")) {
                        $("#iParty_Req_JV_Itm").val("YES")
                    }
                    ChangePartyView(true);
                }
                else {
                    ChangePartyView(false);
                }
                if ($("#iParty_Req_JV_Itm").val().trim().toUpperCase() == "YES") {
                    document.getElementById('LblPary_Jv_Itm').style.color = "#ad1f1f";
                    document.getElementById('LblPary_Jv_Itm').style.fontWeight = 500;
                }
                else {
                    document.getElementById('LblPary_Jv_Itm').style.color = "Black";
                }
                $("#Cross_RefID_JV_Itm").val("");
                $("#Txt_Qty_JV_Itm").dxNumberBox("instance").option("value", "");
            }

        }
        function SetRefType() {
            //debugger;
            if ($("#iProfile_JV_Itm").val() == null) { return; }
            if ($("#iProfile_JV_Itm").val().toUpperCase() != "NOT APPLICABLE")
            {
                if ($("#iProfile_JV_Itm").val().toUpperCase() == "OTHER LIABILITIES")
                {
                    if ($("#RdAction_JV_Itm").dxRadioGroup("option","value") == 1) {//credit
                        Control_SetReadOnly("Cmb_RefType_JV_Itm","dxSelectBox",false);
                    }
                    else {
                        Control_SetReadOnly("Cmb_RefType_JV_Itm","dxSelectBox",true);
                    }
                }
                else
                {
                    if ($("#RdAction_JV_Itm").dxRadioGroup("option","value") == 0) {//debit
                        Control_SetReadOnly("Cmb_RefType_JV_Itm","dxSelectBox",false);
                    }
                    else {
                        Control_SetReadOnly("Cmb_RefType_JV_Itm","dxSelectBox",true);
                    }
                }
            }
            else {
                Control_SetReadOnly("Cmb_RefType_JV_Itm","dxSelectBox",true);
                $("#Cmb_RefType_JV_Itm").dxSelectBox("instance").option('value', 'Existing')
            }
            if (Tag_Itm_Jv == "_Edit") {
                Control_SetReadOnly("Cmb_RefType_JV_Itm","dxSelectBox",true);
            }
        }
        function ChangePartyView(Enabled) {
            if (Enabled) {
                //JV_PartyList_Itm.clearSelection;
                ("#Party_RecEditOn_JV_Itm").val = null;
                $("#GLookUp_PartyList_JV_Itm").dxDropDownBox({ disabled: false });
                PartyBind();
            }
            else {
                //JV_PartyList_Itm.clearSelection;
                ("#Party_RecEditOn_JV_Itm").val = null;
                $("#GLookUp_PartyList_JV_Itm").dxDropDownBox({ disabled: true });
                $("#iPartyID_JV_Itm").val = "";
                PartyBind();
            }
        }
        async function PartyBind() {
           Control_SetReadOnly("GLookUp_PartyList_JV_Itm", "dxDropDownBox", false);
