    <script>
        var ItemList_DDRefresh_Itm;
        var Jv_Party_DDrefresh_Itm;
        var PurList_DDRefresh_JvItm;
        var Tag_Itm_Jv = "@Model.ActionMethod_JV_Itm";
        var ItemList_JvItm_Enable = true;
        var ItemList_JvItm_ReadOnly = true;
        var PurList_JvItm_Enable = true;
        var PurList_JvItm_ReadOnly = true;
        var PartyList_JvItm_Enable = true;
        var PartyList_JvItm_ReadOnly = true;
        var JV_ItemList_Itm;
        var JV_PartyList_Itm;
        var JV_PurList_Itm;
        var $JV_PurList_Itm;
        var $JV_ItemList_Itm;
        $(document).ready(async function ()
        {
            //debugger;
            ShowLoader_Ready();
            if (Tag_Itm_Jv == "_New") {
                document.getElementById("TitleX").innerHTML = "New ~ Item Detail";
                $("#RdAction_JV_Itm").dxRadioGroup("instance").option("value", @Model.RdAction_JV_Itm);
                Control_SetReadOnly("Cmb_RefType_JV_Itm", "dxSelectBox", true);
            }
            else {
                document.getElementById("TitleX").innerHTML = "Edit ~ Item Detail";
            }
            //debugger;
            
            TransformTextForDB("Frm_Voucher_Win_Journal_New_Item_Detail");
            InitAllDropDownDataGrid_Itm();
            await Promise.all([LookUp_GetItemList_JV_Itm(true), LookUp_GetPurposeList_JV_Itm(true), LookUp_GetPartyList_JV_Itm(true)]);
            await PartyBind();

            if (Tag_Itm_Jv == "_Edit" || Tag_Itm_Jv == "_Delete" || Tag_Itm_Jv == "_View")
            {

                var CrossRefID = $("#Cross_RefID_JV_Itm").val();
                await Data_Binding();
                $("#Txt_Qty_JV_Itm").dxNumberBox("instance").option("value", parseFloat(@Model.Txt_Qty_JV_Itm)); //Added to ensure that the change in Item , on load, does not wipes out the Qty
                $("#Cross_RefID_JV_Itm").val(CrossRefID);
                Control_SetReadOnly("GLookUp_ItemList_JV_Itm", "dxDropDownBox", true)
            }

            setTimeout(function () {
                Set_Form_View_Delete_Mode(null, "Frm_Voucher_Win_Journal_New_Item_Detail", Tag_Itm_Jv);
                Focus_FirstEditable_Field("Frm_Voucher_Win_Journal_New_Item_Detail", Tag_Itm_Jv);
                HideLoader_Ready();
            }, 500);
        });

        function BUT_SAVE_COM_Itm_onClick(e) {
            if (ValidateForm(e))
            {
                $('#Frm_Voucher_Win_Journal_New_Item_Detail').submit();                   
                
            }
        }
        async function Data_Binding()
        {
           await JV_ItemList_Itm.selectRows($("#iSpecific_ItemID_JV_Itm").val(), false);
            ItemList_JvItm_ReadOnly = false;
            Control_SetReadOnly("GLookUp_ItemList_JV_Itm", "dxDropDownBox", ItemList_JvItm_ReadOnly);

