        async function LookUp_GetItemList_JV_Itm(FirstCall = false)
        {
            if (FirstCall == false) {
                ItemList_DDRefresh_Itm = true;
                JV_ItemList_Itm.refresh();
                ItemList_DDRefresh_Itm = false;
            }
            var TotalCount = JV_ItemList_Itm.totalCount();
            if (TotalCount < 0) {
                var ds = $("#GLookUp_ItemList_JV_Itm").dxDropDownBox("getDataSource");
                var store = ds.store();
                TotalCount = await store.totalCount();
            }
            if (TotalCount == 1) {
                $("#GLookUp_ItemList_JV_Itm").find('input').css('color', '#000080');//Setting Navy blue colour
                if (Tag_Itm_Jv == "_New" || Tag_Itm_Jv == "_New_From_Selection") {
                    DG_ItemList_Itm_Dtel.selectRowsByIndexes(0);
                    ItemList_JvItm_Enable = false;
                    Control_SetReadOnly("GLookUp_ItemList_JV_Itm", "dxDropDownBox", (ItemList_JvItm_Enable == true && ItemList_JvItm_ReadOnly == false) ? false : true);
                }
            }
            else {
                if (Tag_Itm_Jv == "_New" || Tag_Itm_Jv == "_New_From_Selection") {
                    ItemList_JvItm_ReadOnly = false;
                    Control_SetReadOnly("GLookUp_ItemList_JV_Itm", "dxDropDownBox", (ItemList_JvItm_Enable == true && ItemList_JvItm_ReadOnly == false) ? false : true);
                }
            }
        }
