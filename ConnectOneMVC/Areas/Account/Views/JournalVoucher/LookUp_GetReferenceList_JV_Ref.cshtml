@using DevExtreme.AspNet.Data;
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("ReferenceList_JV_Ref")
    .Columns(columns =>
        {
            columns.Add().DataField("Type").Visible(true);
            columns.Add().DataField("Category").Visible(true);
            columns.Add().DataField("Use").Caption("Head").Visible(true);
            columns.Add().DataField("Item").Visible(true);
            columns.Add().DataField("OWNER").Visible(true);
            columns.Add().DataField("Org_Value").Visible(true).Format("#0.00").DataType(GridColumnDataType.Number);
            columns.Add().DataField("Curr_Value").Visible(true).Format("#0.00").DataType(GridColumnDataType.Number);
            columns.Add().DataField("REC_ID").Visible(true);
            columns.Add().DataField("REC_EDIT_ON").Visible(true);
            columns.Add().DataField("REF_CREATION_DATE").Visible(true);

            columns.Add().DataField("Make").Visible(true);
            columns.Add().DataField("Model").Visible(true);
            columns.Add().DataField("Org_Qty").Visible(true).Format("#0.00").DataType(GridColumnDataType.Number);
            columns.Add().DataField("Curr_Qty").Visible(true).Format("#0.00").DataType(GridColumnDataType.Number);

            //Opening extra columns
            columns.Add().DataField("Head").Visible(true);
            columns.Add().DataField("Head_Type").Visible(true);

            //WIP extra columns
            columns.Add().DataField("Ledger").Visible(true);
            columns.Add().DataField("Reference").Visible(true);
            columns.Add().DataField("Next_Year_Closing_Value").Visible(true).Format("#0.00").DataType(GridColumnDataType.Number);

            //Other Liabilities
            columns.Add().DataField("Party").Visible(true);
            columns.Add().DataField("Date").Visible(true).Format("MMM dd, yyyy").DataType(GridColumnDataType.Date);
            columns.Add().DataField("Due").Visible(true);
            columns.Add().DataField("Reason").Visible(true);
            columns.Add().DataField("Detail").Visible(true);

            //Vehicle extra columns
            columns.Add().DataField("Vehicle").Visible(true);
            columns.Add().DataField("Reg_No").Visible(true);

            //Other deposits
            columns.Add().DataField("Period").Visible(true);

            //Live stock extra columns
            columns.Add().DataField("Name").Visible(true);
            columns.Add().DataField("BIRTH_YEAR").Visible(true);

            //Gold, Silver
            columns.Add().DataField("Org_Weight").Visible(true).Format("#0.000").DataType(GridColumnDataType.Number);
            columns.Add().DataField("Curr_Weight").Visible(true).Format("#0.000").DataType(GridColumnDataType.Number);
            columns.Add().DataField("DESC").Visible(true);
            columns.Add().DataField("DETAILS").Visible(true);
        }
        
    )
    .Selection(s => s.Mode(SelectionMode.Single))
    )
