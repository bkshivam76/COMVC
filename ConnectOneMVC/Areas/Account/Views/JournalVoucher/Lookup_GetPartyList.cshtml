
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("Jv_New_Item_LookUp_GetPartyList")

    .Columns(columns =>
    {
        columns.Add().DataField("ID").Caption("ID").Visible(false);
        columns.Add().DataField("Name").Caption("Name");
        columns.Add().DataField("PAN").Caption("PAN").Visible(true);
        columns.Add().DataField("C_UID_NO").Caption("C_UID_NO").Visible(false);
        columns.Add().DataField("C_OTHER_ID").Caption("C_OTHER_ID").Visible(false);
        columns.Add().DataField("C_OTHER_ID_LABEL").Caption("C_OTHER_ID_LABEL").Visible(false);
        columns.Add().DataField("REC_EDIT_ON").Caption("REC_EDIT_ON").Visible(false);
        columns.Add().DataField("C_CATEGORY").Caption("C_CATEGORY").Visible(false);
    })

    .Selection(s => s.Mode(SelectionMode.Single))

)
