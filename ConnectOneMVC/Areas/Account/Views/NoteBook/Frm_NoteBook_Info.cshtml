        function NoteBook_Grid_init(s, e) {
            NB_AdjustSize(s, e);
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                NB_AdjustSize(s, e);

            });
            s.SetFocusedRowIndex(-1);
        }
        function NB_AdjustSize(s, e) {
            var height = (document.documentElement.clientHeight * 90) / 100;
            s.SetHeight(height);
        }
        function NoteBook_Grid_beginCallBack(s, e) {
            ShowLoader_GridView();
            e.customArgs["command"] = e.command;
            e.customArgs["TotalDays"] = TotalDays_NB;
            e.customArgs["Band_Caption"] = Band2Caption;
            e.customArgs["setDisable"] = NB_SetDisable;
            e.customArgs["ChangedValue"] = JSON.stringify(NoteBook_ChangedValues);
        }
        function NoteBook_Grid_endcallback(s, e) {
            NoteBook_ChangedValues = new Array();
            $("#BE_Cash_Bank_NB").text(s.cpCashBankText);
            if ($('#NoteBookListGrid_DXFilterRow').is(":visible")) {
                NBFilterVisible = false;
            }
            else {
                NBFilterVisible = true;
            }
            if ($('#NoteBookListGrid_DXSearchPanel').is(":visible")) {
                NBFindVisible = false;
            }
            else {
                NBFindVisible = true;
            }
            if (e.command == "UPDATEEDIT") {
                Saving_Notebook();
            }
            HideLoader_GridView();
        }
        function NoteBook_Grid_Focused_Row_changed(s, e) {
            var FocusRowIndex = s.GetFocusedRowIndex();
            if (FocusRowIndex >= 0) {
                REC_ID_NB = s.GetRowKey(FocusRowIndex);
            }
            else {
                REC_ID_NB = null;
                $("#lbl_SelectedItem_NB").html("<font color=blue>Item</font>");
                $("#lbl_EntryDatemonth_NB").html("<font color=blue> Entry Date/Month </font>");
            }
        }
        function NoteBook_OnFocusedCellChanging(s, e) {
            FocusedCell_RowVisibleIndex_NB = e.cellInfo.rowVisibleIndex;
            FocusedCell_ColumnVisibleIndex_NB = e.cellInfo.column.index;
            ITEM_NAME_NB = s.batchEditApi.GetCellValue(FocusedCell_RowVisibleIndex_NB, "ITEM_NAME");
            ShowEntryDateMonth_NB(e.cellInfo.column.fieldName, e.cellInfo.column.name);
            var TotalorgValue = s.batchEditApi.GetCellTextContainer(FocusedCell_RowVisibleIndex_NB, "AMT_TOTAL").innerText;
            AMT_TOTAL_NB = TotalorgValue.trim().length == 0 ? 0 : parseInt(TotalorgValue);
            ShowSelectedItem_NB(ITEM_NAME_NB, AMT_TOTAL_NB);
        }
        function NoteBook_OnBatchEditStartEditing(s, e)
        {            
        }
        function NoteBook_OnBatchEditEndEditing(s, e)
        {
            var CellnewValue = e.rowValues[e.focusedColumn.index].value;
            var CellorgValue = s.batchEditApi.GetCellValue(e.visibleIndex, e.focusedColumn.fieldName);
            var ValueLimit = 10000;
            if (parseInt(open_FY) > 2425)
            {
                ValueLimit = 1000;
            }
            if (CellnewValue > ValueLimit || CellnewValue < 0)
            {
                var Alert = DevExpress.ui.dialog.alert("Amount Cannot Be Negative And Greater Than " + ValueLimit+" ...!", "Note-Book Entry");
                Alert.done(function ()
                {
                    e.rowValues[e.focusedColumn.index].value = CellorgValue;
                    s.batchEditApi.SetCellValue(e.visibleIndex, e.focusedColumn.fieldName, CellorgValue, null, true);
                    NoteBookListGrid.batchEditApi.StartEdit(e.visibleIndex, e.focusedColumn.index);    
                });
            }
            else
            {
                CalculateSummaryAndTotal(s, e);
            }
        }
        function CalculateSummaryAndTotal(s, e)
        {
            var CelloriginalValue = s.batchEditApi.GetCellValue(e.visibleIndex, e.focusedColumn.fieldName);
            CelloriginalValue = CelloriginalValue == null ? 0 : CelloriginalValue;
            var CellnewValue = e.rowValues[e.focusedColumn.index].value;
            CellnewValue = CellnewValue == null ? 0 : parseInt(CellnewValue);
            var diff = CellnewValue - CelloriginalValue;
            if (diff != 0) {
                FillChangedValue_NB(e.key, e.focusedColumn.fieldName, e.rowValues[e.focusedColumn.index].value);
            }
            var CellsummaryLabel = ASPxClientControl.GetControlCollection().GetByName(e.focusedColumn.fieldName + "labelSummary");
            CellsummaryLabel.SetValue(parseInt(CellsummaryLabel.GetValue()) + diff);
            var TotalorgValue = e.rowValues[(s.GetColumnByField("AMT_TOTAL").index)].value;
            TotalorgValue = TotalorgValue == null ? 0 : parseInt(TotalorgValue);
            s.batchEditApi.SetCellValue(e.visibleIndex, "AMT_TOTAL", TotalorgValue + diff, null, true);
            if (FocusedCell_RowVisibleIndex_NB == e.visibleIndex)
            {
                AMT_TOTAL_NB = TotalorgValue + diff;
                ShowSelectedItem_NB(ITEM_NAME_NB, AMT_TOTAL_NB);
            }
            AMT_TOTALlabelSummary.SetValue(parseInt(AMT_TOTALlabelSummary.GetValue()) + diff);
        }
        function ShowEntryDateMonth_NB(columnFieldName, columnName) {
            var cmb_view_text = ($("#Cmb_View_NB").dxSelectBox("instance").option("text")).toProperCase();
            if (columnFieldName.startsWith("AMT_DT_")) {
                $("#lbl_EntryDatemonth_NB").html("<font color=blue> Entry Date: </font>" + "<font color=red>" + GetDayNumberWithSuffix(columnName) + " " + cmb_view_text.replace("-", ",") + "</font>");
            }
            else {
                $("#lbl_EntryDatemonth_NB").html("<font color=blue> Entry Month: </font>" + "<font color=red>" + cmb_view_text + "</font>");
            }
        }
        function ShowSelectedItem_NB(itemName, Total) {
            $("#lbl_SelectedItem_NB").html("<font color=blue>" + itemName + "</font>" + "<font color=red> Total Amt: " + Total.toFixed(2) + "</font>");
        }
        function NB_editor_init(s, e) {
           // var errorTextElement = $(".dxeOutOfRWarn_Aqua > label");
           // $(errorTextElement).text("Amount Cannot Be Negative And Greater Than 10,000...!");
            var editorInput = s.GetInputElement();
            editorInput.type = "number";
        }
        function FillChangedValue_NB(Key, FieldName, Val) {
            var index = NoteBook_ChangedValues.findIndex(x => x.Key == Key && x.Field == FieldName);
            if (index > -1) {
                NoteBook_ChangedValues[index].Value = Val;
            }
            else {
                NoteBook_ChangedValues.push({ Key: Key, Field: FieldName, Value: Val })
            }            
        }
        function NoteBookEntry_ValueChanged(s, fieldName, keyValue) {
            if (s.GetValue() == null || s.GetValue() >= 0) {
                var Amount = s.GetValue() == null ? 0 : s.GetValue();
                $.ajax({
                    type: "Get",
                    url: "/Account/NoteBook/UpdateCellData",
                    data: { key: keyValue, field: fieldName, value: Amount },
                    success: function (data) {
                        ASPxClientControl.GetControlCollection().GetByName("txt" + keyValue + "AMT_TOTAL").SetValue(data.Grand_Total);
                        ASPxClientControl.GetControlCollection().GetByName(fieldName + "labelSummary").SetText(data.Summary.split('|')[1]);
                        ASPxClientControl.GetControlCollection().GetByName("AMT_TOTAL" + "labelSummary").SetText(data.Summary.split('|')[0]);
                    }
                });
            }
            else {
                var Alert = DevExpress.ui.dialog.alert("Amount Cannot Be Negative...!", "Note-Book Entry");
                Alert.done(function () {
                    s.SetValue(null);
                    s.Focus();
                })
            }
        }
        function NB_EditorKeyDown(s, e) {
            //if (e.htmlEvent.repeat == false)
            //{
            //    if (e.htmlEvent.ctrlKey == true)
            //    {
            //        if (e.htmlEvent.keyCode == 39)//right arrow
            //        {
            //            if (NoteBookListGrid.GetEditor(FocusedCell_ColumnVisibleIndex_NB + 1)) {
            //                NoteBookListGrid.batchEditApi.StartEdit(FocusedCell_RowVisibleIndex_NB, FocusedCell_ColumnVisibleIndex_NB + 1);
            //            }
            //        }
            //        else if (e.htmlEvent.keyCode == 37) //left arrow
            //        {
            //            NoteBookListGrid.batchEditApi.StartEdit(FocusedCell_RowVisibleIndex_NB, FocusedCell_ColumnVisibleIndex_NB == 5 ? FocusedCell_ColumnVisibleIndex_NB - 2 : FocusedCell_ColumnVisibleIndex_NB - 1);
            //        }
            //        else if (e.htmlEvent.keyCode == 38) //up arrow
            //        {
            //            if (FocusedCell_RowVisibleIndex_NB != 0) {
            //                NoteBookListGrid.batchEditApi.StartEdit(FocusedCell_RowVisibleIndex_NB - 1, FocusedCell_ColumnVisibleIndex_NB);
            //            }
            //        }
            //        else if (e.htmlEvent.keyCode == 40) //down arrow
            //        {
            //            if (NoteBookListGrid.IsDataRow(FocusedCell_RowVisibleIndex_NB + 1)) {
            //                NoteBookListGrid.batchEditApi.StartEdit(FocusedCell_RowVisibleIndex_NB + 1, FocusedCell_ColumnVisibleIndex_NB);
            //            }
            //        }
            //    }
            //}
        }  
        function NBTrackBarPositionChanged() {
            var NBcurrentZoom = 1.0;
            var NBtrackBarCurrentValue = trackBarNB.GetValue()
            if (NBtrackBarCurrentValue != 0) {
                NBcurrentZoom += NBtrackBarCurrentValue / 100;
            }
            $('#NBreloadPartialView').animate({ 'zoom': NBcurrentZoom }, 'slow');
        }
        function NB_FindClick(e) {
            if (NBFindVisible) {
                NoteBookListGrid.contextMenuHelper.ContextMenuShowSearchPanel(1);
            }
            else {
                NoteBookListGrid.contextMenuHelper.ContextMenuShowSearchPanel(0);
            }
            NBFindVisible = !NBFindVisible;
        }
        function NB_FilterClick(e) {
            if (NBFilterVisible) {
                NoteBookListGrid.contextMenuHelper.ContextMenuShowFilterRow(1);
            }
            else {
                NoteBookListGrid.contextMenuHelper.ContextMenuShowFilterRow(0);
            }
            NBFilterVisible = !NBFilterVisible;
        }
    </script>
    @* Grid Relaated *@
    <script>
        function Cmb_View_SelectedIndexChanged_NB(e) {
            if (e.value == null) {
                $("#Cmb_View_NB").dxSelectBox("option", "value", e.previousValue);
                return;
            }
            NB_PeriodChange = true;
            if (Check_UnSave_Data) {
                Data_Change().then(function (data) {
                    if (data == "True") {
                        var confirm = DevExpress.ui.dialog.confirm('Do you want to Save Notebook Entry...?', "Confirm");
                        confirm.done(function (dialogResult) {
                            if (dialogResult) {
                                SaveClick_NB();
                            }
                            else {
                                NB_ChangePeriod();
                            }
                        });
                    }
                    else {
                        NB_ChangePeriod();
                    }
                })
            }
            else {
                NB_ChangePeriod();
            }
        }
        function NB_ChangePeriod() {
            $.ajax({
                type: 'POST',
                url: "/Account/NoteBook/Cmb_View_SelectedIndexChanged",
                cache: false,
                data:
                {
                    Index: $("#Cmb_View_NB").dxSelectBox("instance").option("value")
                },
                success: function (data) {
                    TotalDays_NB = data.TotalDays;
                    Band2Caption = data.GridBand2_Caption;
                    $("#BE_View_Period_NB").dxTextBox("instance").option("value", data.Periodtext);
                    xFR_Date = data.fr_date;
                    NoteBookRefresh();
                    $("#TotalDays").val(TotalDays_NB);
                    $("#Band_Caption").val(Band2Caption);
                    $("#PeriodText").val(data.Periodtext);
                }
            });
            NB_PeriodChange = false;
        }
        function NoteBookRefresh() {
            if (typeof window !== 'undefined') {
                if (typeof window.NoteBookListGrid !== 'undefined') {
                    if (typeof window.NoteBookListGrid.Refresh !== 'undefined') {
                        if (typeof NoteBookListGrid.Refresh == 'function') {
                            NoteBookListGrid.SetFocusedRowIndex(-1);
                            NoteBookListGrid.Refresh();
                        }
                        else {
                            alert("Refresh is not a function");
                        }
                    }
                    else {
                        setTimeout(function () {
                            NoteBookRefresh();

                        }, Timeout100);
                    }
                }
                else {
                    alert('grid undefined')
                }
            }
            else {
                alert('window undefined')
            }
        }
    </script>
    @* Period Change*@
    <script>
    var Check_UnSave_Data = false;
    var Flag_Data_Change = false;
    var TotalDays_NB = 0;
    var Band2Caption = null;
    $(document).ready(function ()
    {
        ShowLoader_Ready();
        if ("@Accnt_Notebook_ExportRight" == "False")
        {
            $("#BUT_PRINT_NB").hide();
        }

        if ("@Model.ActionMethod" == "_View")
        {
            NB_SetDisable = true;
            $("#Set_Disable").val(true)
        }
        else
        {
            $("#Set_Disable").val(false)
        }
        Check_UnSave_Data = false;
        if ("@Model.ActionMethod" == "_Edit" || "@Model.ActionMethod" == "_View")
        {
            $("#Cmb_View_NB").dxSelectBox("instance").option("readOnly", true);
        }
        TotalDays_NB = parseInt("@Model.TotalDays");
        Band2Caption = "@Model.GridBand2_Caption";
        xFR_Date = "@Model.fr_date";
        $("#TotalDays").val(TotalDays_NB);
        $("#Band_Caption").val(Band2Caption);
        $("#PeriodText").val("@Model.Periodtext");
        @*$("#Cmb_View_NB").dxSelectBox("instance").option("value", parseInt("@Model.Cmb_View_SelectedIndex"));*@
        if ("@Model.ActionMethod" == "_View")
        {
            $("#BUT_SAVE_NB").dxButton("instance").option("disabled", true);
        }
        Check_UnSave_Data = true;
        setTimeout(function () { HideLoader_Ready(); }, Timeout500);
    });
    </script>
    @* document.ready *@
    <script>
        function BE_Cash_Bank_ButtonClick_NB() {
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Account/NoteBook/Frm_View_Summary",
                cache: false,
                success: function (result) {
                    OpenPopup("popup_frm_Frm_View_Summary_NB", "Summary...", null, "auto", 775, true, result);
                }
            });
        }
        function NB_Summary_close(e) {
            $.ajax({
                type: 'GET',
                url: "/Account/NoteBook/Frm_View_SummaryGrid_Close",
                cache: false
            });
            ClearAllReferences("NoteBookSummary_ClearReferences");
            e.component.content()[0].innerHTML = "";
        }
        async function Data_Change() {
            NoteBookListGrid.batchEditApi.EndEdit();
            var changes = NoteBookListGrid.batchEditApi.HasChanges();
            if (changes == true) {
                return "True";
            }
            else {
                return $.ajax({
                    type: 'GET',
                    url: "/Account/NoteBook/Data_Change",
                    cache: false
                });
            }
        }
    </script>
    @* Summary and data change*@
    <script>
    function SaveClick_NB()
    {
        NoteBookListGrid.batchEditApi.EndEdit();
        ShowLoader("Saving", false);
        if (NoteBookListGrid.batchEditApi.HasChanges())
        {
            NoteBookListGrid.UpdateEdit();//raise callback
        }
        else
        {
            Saving_Notebook();
        }
    }
    function Saving_Notebook()
    {
        $.ajax({
            type: 'Get',
            url: "/Account/NoteBook/Saveclick",
            success: function (data)
            {
                HideLoader();
                var alert = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                alert.done(function (dialogResult)
                {
                    if (dialogResult)
                    {
                        if (data.jsonParam.result == true && NB_PeriodChange == true)// change if called from change period selection changed
                        {
                            NB_ChangePeriod();
                        }
                        else if (data.jsonParam.result == true && Close_Btn_Click == true) //close if called from close button click
                        {
                            close_NB();
                        }
                        else if (data.jsonParam.result == true && NB_Export_Click == true) //export if called from export btn click
                        {
                            NB_Export_Click = false;
                            Export_NoteBook();
                        }
                        else if (data.jsonParam.result == true && Close_Btn_Click == false)
                        {
                            NoteBookListGrid.SetFocusedRowIndex(-1);
                            NoteBookListGrid.Refresh();
                        }
                    }
                });
            }
        });
    }
    function NB_CloseClick(e)
    {
        ShowLoader();
        Close_Btn_Click = true;
        Data_Change().then(function (data)
        {
            if (data=="True")
            {
                HideLoader();
                var confirm = DevExpress.ui.dialog.confirm('Do you want to Save Notebook Entry...?', "Confirm");
                confirm.done(function (dialogResult)
                {
                    if (dialogResult)
                    {
                        SaveClick_NB();
                    }
                    else
                    {
                        close_NB();
                    }
                });
            }
            else
            {
                HideLoader();
                close_NB();
            }
        });
    }
    function close_NB()
    {
        ShowLoader();
        if ("@Open_From_CB" == "False" && $(".TabPanalMenu-tabs .active").attr("id") =="contact_Frm_NoteBook_Info") {
            btnCloseActiveTab();
        }
        else
        {
            $("#Notebook_Popup_ID").dxPopup("hide");
            if (typeof CashBookListGrid !== 'undefined'&&"@Model.xEntryDate".length>0) {
                AfterVoucherClose_CB(moment("@Model.xEntryDate", "DD/MM/YYYY"), "@Model.ActionMethod");
            }
            if ("@ViewBag.GridToRefresh" != "CashBookListGrid")
            {
                RefreshGridView("@ViewBag.GridToRefresh");
            }
