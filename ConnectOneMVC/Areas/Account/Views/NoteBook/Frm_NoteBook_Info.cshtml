    <style>
        .filter_btn i {
            background: #86c13e;
        }

        .find_btn i {
            background: #81b4df;
        }

        .GridViewShowFilterOnHover:hover .dxgv__hfb {
            display: inline-table !important;
        }

        .GridViewShowFilterOnHover .dxgv__hfb[alt="Filter applied"] {
            display: inline-table !important;
