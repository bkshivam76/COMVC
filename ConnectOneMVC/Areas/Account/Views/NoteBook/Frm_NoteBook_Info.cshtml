            font-weight: 500 !important;
        }

        .NoteBookAltRowClass {
            background: linear-gradient(to top, #FFF6E3 0%, #FFFEFB 100%);
        }

        .NoteBookRowClass:not(.NoteBookAltRowClass) {
            background: linear-gradient(to top, #DFF5FF 0%, #FEFEFF 100%);
        }

