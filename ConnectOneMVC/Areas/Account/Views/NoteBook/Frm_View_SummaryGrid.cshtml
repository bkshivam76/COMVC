@using DevExtreme.AspNet.Mvc;
@{ var SessionGUID = Request.QueryString["SessionGUID"];}
@(Html.DevExtreme().DataGrid().CustomDataGridListing()
                 .ID("SummaryListGrid_NB")
                 .DataSource(s => s.Array().Key("Sr").Data(Model))
                 .Columns(columns =>
                 {
                     columns.Add().DataField("Title").Caption("Title").Visible(false).SortOrder(SortOrder.Desc).GroupIndex(0);
                     columns.Add().DataField("Description").Caption("Description").Width(220);
                     columns.Add().DataField("O_BALANCE").Caption("Opening Balance").Width(160).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("R_BALANCE").Caption("Total Receipt").Width(160).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("P_BALANCE").Caption("Total Payment").Width(160).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("C_BALANCE").Caption("Closing Balance").Width(160).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("Sr").Caption("Sr").Visible(false).SortOrder(SortOrder.Asc);
                 })               
         .Paging(s=>s.Enabled(false))
         .Pager(s => s.Visible(false))
         .FilterRow(s=>s.Visible(false))
         .FilterPanel(s=>s.Visible(false))
         .HeaderFilter(s=>s.Visible(false))
         .Summary(s=>
         {
             s.TotalItems(t =>
             {
                 t.Add().SummaryType(SummaryType.Custom).Name("Description_Description_custom").Column("Description").DisplayFormat("Grand Total : {0}");
                 t.Add().SummaryType(SummaryType.Sum).Name("O_BALANCE_O_BALANCE_sum").Column("O_BALANCE").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
                 t.Add().SummaryType(SummaryType.Sum).Name("R_BALANCE_R_BALANCE_sum").Column("R_BALANCE").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
                 t.Add().SummaryType(SummaryType.Sum).Name("P_BALANCE_P_BALANCE_sum").Column("P_BALANCE").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
                 t.Add().SummaryType(SummaryType.Sum).Name("C_BALANCE_C_BALANCE_sum").Column("C_BALANCE").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
             });
             s.GroupItems(t =>
             {
                 t.Add().SummaryType(SummaryType.Custom).Name("Description_Description_custom").Column("Description").DisplayFormat("Total : {0}").ShowInGroupFooter(true);
                 t.Add().SummaryType(SummaryType.Sum).Name("O_BALANCE_O_BALANCE_sum").Column("O_BALANCE").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}")).ShowInGroupFooter(true);
                 t.Add().SummaryType(SummaryType.Sum).Name("R_BALANCE_R_BALANCE_sum").Column("R_BALANCE").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}")).ShowInGroupFooter(true);
                 t.Add().SummaryType(SummaryType.Sum).Name("P_BALANCE_P_BALANCE_sum").Column("P_BALANCE").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}")).ShowInGroupFooter(true);
                 t.Add().SummaryType(SummaryType.Sum).Name("C_BALANCE_C_BALANCE_sum").Column("C_BALANCE").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}")).ShowInGroupFooter(true);
             });
         })
         .OnContextMenuPreparing("SummaryListGrid_NB_dx_ContextMenuPreparing")

)
