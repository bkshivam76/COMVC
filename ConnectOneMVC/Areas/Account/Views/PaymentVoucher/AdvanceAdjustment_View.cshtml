@using DevExtreme.AspNet.Mvc;
@model ConnectOneMVC.Areas.Account.Models.Param_paymentVoucherDetailsViewModel
@{
    bool IsVisible = (Model != null && Model.TempActionMethod == "_Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.TempActionMethod == "_View" || Model.TempActionMethod == "_Delete") ? true : false;
}
<div id="Frm_Voucher_Win_Gen_Pay_Grid_3_PartialView">
    <div class="row">
        <div class="col-md-12">
            @Html.Action("Frm_Voucher_Win_Gen_Pay_Grid_3", "PaymentVoucher")
            <div class="btnsDiv marginAll2">
                @(Html.DevExtreme().Button().ID("AdvanceAdjustmentEdit").Text("Edit").Icon("edit").OnClick(@<text> function () { OnFrm_Voucher_Win_Gen_Pay_Grid_3_EditClick(); } </text>).Disabled(IsDisabled))
                @(Html.DevExtreme().Button().ID("AdvanceAdjustmentDelete").Text("Delete").Icon("trash").OnClick(@<text> function () { OnFrm_Voucher_Win_Gen_Pay_Grid_3_DeleteClick(); } </text>).Disabled(IsDisabled))
                @(Html.DevExtreme().Button().ID("AdvanceAdjustmentView").Text("View").Icon("doc").OnClick(@<text> function () { OnFrm_Voucher_Win_Gen_Pay_Grid_3_ViewClick(); } </text>).Disabled(IsVisible))
            </div>
        </div>
        </div>
</div>

<script>
 
    function Frm_Voucher_Win_Gen_Pay_Grid_3_beginCallback(s, e)
    {
        e.customArgs['command'] = e.command;
        e.customArgs['xParty_ID'] = $('#GLookUp_PartyList1_Tag').dxDropDownBox('instance').option('value');
    }
    function Frm_Voucher_Win_Gen_Pay_Grid_3_Init(s, e)
    {
        //ASPxClientUtils.AttachEventToElement(
        //    s.GetMainElement(),
        //    "keydown",
        //    function (evt) {
        //        switch (evt.keyCode) {

        //            case 13: //enter key
        //                evt.preventDefault();
        //                OnFrm_Voucher_Win_Gen_Pay_Grid_3_EditClick();
        //                break;
        //            case 32: //space bar
        //                evt.preventDefault();
        //                OnFrm_Voucher_Win_Gen_Pay_Grid_3_ViewClick();
        //                break;
        //            case 46://delete key
        //                evt.preventDefault();
        //                OnFrm_Voucher_Win_Gen_Pay_Grid_3_DeleteClick();
        //                break;
        //        }
        //    });
    }
    var Grid_3_RowNumber;
    var Payment_Grid3_PageData;
    function Frm_Voucher_Win_Gen_Pay_Grid_3_DblClick(s, e)
    {
        OnFrm_Voucher_Win_Gen_Pay_Grid_3_EditClick();
    }
    function OnAdvanceAdjustmentGridFocusedRowChanged(s, e)
    {
        s.Focus();
        //s.GetRowValues(s.GetFocusedRowIndex(), 'Sr;', OnAdvanceAdjustmentGetRowValues);
    }
    function OnAdvanceAdjustmentGetRowValues(values)
    {
        Grid_3_RowNumber = values[0];
    }

    function OnFrm_Voucher_Win_Gen_Pay_Grid_3_EditClick()
    {
        if ("@IsDisabled" == "False")
        {
            if ($('#GLookUp_PartyList1_Tag').dxDropDownBox('instance').option('value') == "" || $('#GLookUp_PartyList1_Tag').dxDropDownBox('instance').option('value') == null)
            {
                DevExpress.ui.dialog.alert('Party Not Selected...!', "Error");
            }
            else if (Frm_Voucher_Win_Gen_Pay_Grid_3.GetFocusedRowIndex() >= 0)
            {
                Payment_Grid3_PageData = Frm_Voucher_Win_Gen_Pay_Grid_3.cpPagedata;
                Grid_3_RowNumber = Payment_Grid3_PageData[Frm_Voucher_Win_Gen_Pay_Grid_3.GetFocusedRowIndex() - Frm_Voucher_Win_Gen_Pay_Grid_3.GetTopVisibleIndex()];
                var url = "@Url.Action("Frm_Voucher_Win_Gen_Pay_Adv", "PaymentVoucher", new { @area = "Account" })?ActionMethod=Edit&iPartyID=" + $("#GLookUp_PartyList1_Tag").dxDropDownBox("instance").option("value") + "&SrID=" + Grid_3_RowNumber;
                ShowLoader();
                OpenPopup("Frm_Voucher_Item_popup", "Edit ~ Advance Adjustment", url, "auto", 700, false, null);
            }
            else
            {
                DevExpress.ui.dialog.alert('Select A Row...!', "Error");
            }
        }
    }

    function OnFrm_Voucher_Win_Gen_Pay_Grid_3_DeleteClick()
    {
        if ("@IsDisabled" == "False")
        {
            if ($('#GLookUp_PartyList1_Tag').dxDropDownBox('instance').option('value') == "" || $('#GLookUp_PartyList1_Tag').dxDropDownBox('instance').option('value') == null)
            {
                DevExpress.ui.dialog.alert('Party Not Selected...!', "Error");
            }
            else if (Frm_Voucher_Win_Gen_Pay_Grid_3.GetFocusedRowIndex() >= 0)
            {
                Payment_Grid3_PageData = Frm_Voucher_Win_Gen_Pay_Grid_3.cpPagedata;
                Grid_3_RowNumber = Payment_Grid3_PageData[Frm_Voucher_Win_Gen_Pay_Grid_3.GetFocusedRowIndex() - Frm_Voucher_Win_Gen_Pay_Grid_3.GetTopVisibleIndex()];
                $.ajax({
                    type: 'GET',
                    url: "/Account/PaymentVoucher/FillGrid3",
                    data: {
                        TempActionMethod: "_Delete",
                        Sr: Grid_3_RowNumber,
                        Payment_Credit_Amt: $("#Txt_CreditAmt").dxNumberBox("instance").option("value")
                    },
                    cache: false,
                    async: false,
                    success: function (data)
                    {
                        if (data.result == "true" || data.result == true)
                        {
                            $("#Txt_DiffAmt").dxNumberBox("instance").option("value", data.Txt_DiffAmt);
                            $("#Txt_CashAmt").dxNumberBox("instance").option("value", data.Txt_CashAmt);
                            $("#Txt_AdvAmt").dxNumberBox("instance").option("value", data.Txt_AdvAmt);
                            Frm_Voucher_Win_Gen_Pay_Grid_3.SetFocusedRowIndex(-1);
                            Frm_Voucher_Win_Gen_Pay_Grid_3.PerformCallback();
                        }
                    }
                });
            }
            else
            {
                DevExpress.ui.dialog.alert('Select A Row...!', "Error");
            }
        }
    }

    function OnFrm_Voucher_Win_Gen_Pay_Grid_3_ViewClick()
    {
        if ("@IsVisible" == "False")
        {
            if ($('#GLookUp_PartyList1_Tag').dxDropDownBox('instance').option('value') == "" || $('#GLookUp_PartyList1_Tag').dxDropDownBox('instance').option('value') == null)
            {
                DevExpress.ui.dialog.alert('Party Not Selected...!', "Error");
            }
            else if (Frm_Voucher_Win_Gen_Pay_Grid_3.GetFocusedRowIndex() >= 0)
            {
                Payment_Grid3_PageData = Frm_Voucher_Win_Gen_Pay_Grid_3.cpPagedata;
                Grid_3_RowNumber = Payment_Grid3_PageData[Frm_Voucher_Win_Gen_Pay_Grid_3.GetFocusedRowIndex() - Frm_Voucher_Win_Gen_Pay_Grid_3.GetTopVisibleIndex()];
                var url = "@Url.Action("Frm_Voucher_Win_Gen_Pay_Adv", "PaymentVoucher", new { @area = "Account" })?ActionMethod=View&iPartyID=" + $("#GLookUp_PartyList1_Tag").dxDropDownBox("instance").option("value") + "&SrID=" + Grid_3_RowNumber;
                ShowLoader();
                OpenPopup("Frm_Voucher_Item_popup", "View ~ Advance Adjustment", url, "auto", 700, false, null);
            }
            else
            {
                DevExpress.ui.dialog.alert('Select A Row...!', "Error");
            }
        }
    }
    function Frm_Voucher_Win_Gen_Pay_Grid_3_ContextMenuFunction(s, e)
    {
        if (e.item.name == 'Edit') {
            OnFrm_Voucher_Win_Gen_Pay_Grid_3_EditClick();
        }
        else if (e.item.name == 'Delete') {
            OnFrm_Voucher_Win_Gen_Pay_Grid_3_DeleteClick();
        }
        else if (e.item.name == 'View') {
            OnFrm_Voucher_Win_Gen_Pay_Grid_3_ViewClick();
        }
        else if (e.item.name == 'Refresh') {
            Frm_Voucher_Win_Gen_Pay_Grid_3.Refresh();
        }
    }
    </script>



