@using DevExtreme.AspNet.Mvc;
@model ConnectOneMVC.Areas.Account.Models.Param_paymentVoucherDetailsViewModel
@{
    bool IsVisible = (Model != null && Model.TempActionMethod == "_Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.TempActionMethod == "_View" || Model.TempActionMethod == "_Delete") ? true : false;
}
<div id="Frm_Voucher_Win_Gen_Pay_Grid_1_PartialView">
    <div class="row">
        <div class="col-md-12">
            @Html.Action("Frm_Voucher_Win_Gen_Pay_Grid_2", "PaymentVoucher")
            <div class="btnsDiv marginAll2">
                @(Html.DevExtreme().Button().ID("BankPaymentNew").Text("New").Icon("add").OnClick(@<text> function () { OnFrm_Voucher_Win_Gen_Pay_Grid_2_NewClick(); } </text>).Disabled(IsDisabled))
                @(Html.DevExtreme().Button().ID("BankPaymentEdit").Text("Edit").Icon("edit").OnClick(@<text> function () { OnFrm_Voucher_Win_Gen_Pay_Grid_2_EditClick(); } </text>).Disabled(IsDisabled).Visible(true) ) 
                @(Html.DevExtreme().Button().ID("BankPaymentDelete").Text("Delete").Icon("trash").OnClick(@<text> function () { OnFrm_Voucher_Win_Gen_Pay_Grid_2_DeleteClick(); } </text>).Disabled(IsDisabled))
                @(Html.DevExtreme().Button().ID("BankPaymentView").Text("View").Icon("doc").OnClick(@<text> function () { OnFrm_Voucher_Win_Gen_Pay_Grid_2_ViewClick(); } </text>).Disabled(IsVisible))
            </div>
        </div>
    </div>

</div>
<script>
    var BankPayment_Sr;
    var Payment_BankGrid_Data;
