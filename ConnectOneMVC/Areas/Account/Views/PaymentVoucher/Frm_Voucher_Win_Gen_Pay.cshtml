    <script>    
        var paymentvoucher_saveClick = true;
        function Payment_Voucher_Save(e)
        {
            ShowLoader();
            setTimeout(async function ()
            {
                if (Payment_vDatevalueChangeInprogress == false)
                {
                    HideLoader();
                    if (Payment_v_date_checkPassed == true)
                    {
                        dontaskpopupcloseconfirmation = true;
                        paymentvoucher_saveClick = true;
                        if (ValidateForm(e))
                        {
                            var form = $("#ID_Frm_Voucher_Win_Gen_Pay");
                            if (e.component.option("text") == "Delete")
                            {
                                DeleteAfterConfirmation("Confirm", "", form);
                            }
                            else
                            {
                                var ShouldProgress = true;
                                if ($("#Txt_CashAmt").dxNumberBox("instance").option("value") > 10000)
                                {
                                    ShouldProgress = await DevExpress.ui.dialog.confirm('<div><size=13><b>Cash Payment more than <font color=red>Rs. 10,000</font> is not allowed...!</b></size> <br/><br/>Do you still want to Save...?</div>', "Confirm");
                                    //result.done(function (dialogResult)
                                    //{
                                    //    if (dialogResult)
                                    //    {
                                    //        form.submit();
                                    //    }
                                    //    else
                                    //    {
                                    //        $("#Txt_CashAmt").dxNumberBox("instance").focus();
                                    //    }
                                    //});
                                }
                                if (ShouldProgress == true)
                                {
                                    var subtotal = $("#Txt_SubTotal").dxNumberBox("instance").option("value");
                                    if (subtotal >= 50000)
                                    {
                                        var Pan = $("#BE_PAN_No").dxTextBox("instance").option("value");
                                        var Aadhar = $("#BE_AADHAR_No").dxTextBox("instance").option("value");
                                        if ((Pan == null || Pan.length == 0) && (Aadhar == null || Aadhar.length == 0) )
                                        {
                                            if (PartyCategory_payment.toLowerCase() != "govt entity" && PartyCategory_payment.toLowerCase() != "multiple party")                                     
                                            {
                                                DevExpress.ui.dialog.alert("PAN/Aadhar is mandatory for Amounts of 50 Thousand and Above...!", "Incomplete Information").done(function () {
                                                    $("#GLookUp_PartyList1_Tag").dxDropDownBox("instance").focus();
                                                });
                                                return;
                                            }
                                        }
                                    }
                                    form.submit();
                                }
                                else
                                {
                                    $("#Txt_CashAmt").dxNumberBox("instance").focus();                                  
                                }
                            }
                        }
                    }
                }
                else
                {
                    setTimeout(function ()
                    {
                        Payment_Voucher_Save(e)
                    }, 100)
                }
            })
        }
