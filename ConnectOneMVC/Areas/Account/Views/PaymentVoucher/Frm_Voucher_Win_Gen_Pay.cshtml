    @* Document.ready *@
    <script>
    var Party_DG_Pay; 
        var ActionMethod_Payment = "@Model.TempActionMethod";
        var dataSource_Party_Payment = null;
    function InitDropdown_Payment()
    {
        //await $("#GLookUp_PartyList1_Tag").dxDropDownBox("getDataSource").load();
        var $Party_DG_Pay = $("#Frm_Gen_Pay_GLookUp_PartyList1_datagrid");
        if ($Party_DG_Pay.length)
        {
            Party_DG_Pay = $Party_DG_Pay.dxDataGrid("instance");
        }
    }
    async function LookUp_GetPartyList_Payment(FirstCall=false,PartyID="")
    {
        if (ActionMethod_Payment == "_New" ||ActionMethod_Payment == "_New_From_Selection")
        {
            Control_SetReadOnly("GLookUp_PartyList1_Tag", "dxDropDownBox", false);
        }
        if (FirstCall == false)
        {
            ShowLoader();         
            $.ajax({
                type: 'GET',
                url: "/Account/PaymentVoucher/RefreshPartyList",
                cache: false,
                success: function (data)
                {
                    dataSource_Party_Payment = new DevExpress.data.DataSource({ // need to dispose it in in clearreference
                        store:
                        {
                            type: "array",
                            key: "C_ID",
                            data: data
                        }
                    });
                    $("#GLookUp_PartyList1_Tag").dxDropDownBox("instance").option("dataSource", dataSource_Party_Payment);
                    Party_DG_Pay.option("dataSource", dataSource_Party_Payment);
                    dataSource_Party_Payment.load().done((r) =>
                    {
                        $("#GLookUp_PartyList1_Tag").dxDropDownBox("reset");
                        if (PartyID.length > 0)
                        {
                            if (data.some(data => data.C_ID === PartyID)) {
                                $("#GLookUp_PartyList1_Tag").dxDropDownBox("instance").option("value", PartyID);
                            }
                        }
                        $("#GLookUp_PartyList1_Tag").dxDropDownBox("focus");
                        HideLoader();
                    })                  
                }
            });
        }     
    }
    </script>
    @* DD init *@
<script>
    var PartyCategory_payment = "";
    async function GLookUp_PartyList1_EditValueChanged_Payment(e,FirstCall=false)
    {
        if (e)
        {
            if (ActionMethod_Payment == "_Edit")
            {
                if (e.value != "@Model.GLookUp_PartyList1_Tag" && (e.value!=e.previousValue) && e.previousValue!=null && e.previousValue.length>0)
                {                 
                    var Message = await CreatedItemReferenceChecks_AllGridRow(true);
                    if (Message != null && Message.length > 0)
                    {
                        DevExpress.ui.dialog.alert('Party Change Is Not Allowed..!<br><br>' + Message, 'Information...').done(function () { e.component.focus(); });
                        if (e.value == null || e.value.length == 0)
                        {
                            Party_DG_Pay.clearSelection();
                        }
                        Party_DG_Pay.selectRows("@Model.GLookUp_PartyList1_Tag", false);                     
                        return;
                    }                 
                }
            }
        }
        var party;
        if (e) {
            party = e.value;
            if ((e.value == null || e.value.length == 0) && e.previousValue != null) {
                Party_DG_Pay.clearSelection();
                $("#BE_City").dxTextBox("instance").reset();
                $("#BE_PAN_No").dxTextBox("instance").reset();
                $("#BE_AADHAR_No").dxTextBox("instance").reset();
                $("#Txt_AdvAmt").dxNumberBox("instance").option("value", 0.00);
                $("#Txt_LB_Amt").dxNumberBox("instance").option("value", 0.00);
                PartyCategory_payment = "";
                Party_Outstanding_Advances("");
                Party_Outstanding_Liabilities("");
                return;
            }
        }
        else
        {
            party = $("#GLookUp_PartyList1_Tag").dxDropDownBox("option", "value");
        }
        await Party_DG_Pay.selectRows(party);
        if (Party_DG_Pay.getSelectedRowsData().length > 0)
        {
            var item = Party_DG_Pay.getSelectedRowsData()[0];
            $("#GLookUp_PartyList1_Txt_Gen_Pay").val(item["C_NAME"]);
            $("#BE_City").dxTextBox("instance").option("value", item["C_CITY"]);
            $("#BE_PAN_No").dxTextBox("instance").option("value", item["C_PAN_NO"]);
            $("#BE_AADHAR_No").dxTextBox("instance").option("value", item["C_AADHAR_NO"]);
            $("#GLookUp_PartyList1_REC_EDIT_ON_Gen_Pay").val(JS_Json_Date_To_ddMMyyyy(item["REC_EDIT_ON"]));
            PartyCategory_payment = item["C_CATEGORY"] == null ? "" : item["C_CATEGORY"].toLowerCase();
            if (FirstCall == false)
            {
                $("#Txt_AdvAmt").dxNumberBox("instance").option("value", 0.00);
                $("#Txt_LB_Amt").dxNumberBox("instance").option("value", 0.00);
                Party_Outstanding_Advances(party);
                Party_Outstanding_Liabilities(party);
            }
        }
    }//party dropdown change
    var Payment_v_date_checkPassed = true;
    var Payment_vDatevalueChangeInprogress = false;
    function Txt_V_Date_EditValueChanging(e)
    {
        Payment_vDatevalueChangeInprogress = true;
        Payment_v_date_check = false;  
        if (ActionMethod_Payment == "_Edit")
        {           
            if (e.value != null)
            {
                if (e.previousValue != e.value)
                {
                    if ($("#IsProfileCreationVoucher_Gen_Pay").val() == "True") {
                        ShowLoader_Ready("Checking Voucher Date", false);
                        $.ajax({
                            type: 'GET',
                            url: "/Account/PaymentVoucher/Txt_V_Date_EditValueChanging",
                            data:
                            {
                                xMID: "@Model.xMID",
                                NewValue: (moment(e.value).format("DD/MM/YYYY HH:mm:ss"))//redmine bug #133144 fix
                            },
                            cache: false,
                            success: function (data)
                            {
                               HideLoader_Ready();
                                if (data.result == false)
                                {
                                    var dateAlert = DevExpress.ui.dialog.alert(data.message, "Error");
                                    e.component.option("value", e.previousValue);
                                    dateAlert.done(function () { e.component.focus(); });
                                    Payment_vDatevalueChangeInprogress = false;
                                    Payment_v_date_check = false;
                                }
                                else
                                {
                                    Payment_vDatevalueChangeInprogress = false;
                                    Payment_v_date_check = true;
                                }
                            }
                        });
                    }
                    else
                    {
                        Payment_vDatevalueChangeInprogress = false;
                        Payment_v_date_check = true;
                    }
                }
                else
                {
                    Payment_vDatevalueChangeInprogress = false;
                    Payment_v_date_check = true;
                }
            }
            else
            {
                Payment_vDatevalueChangeInprogress = false;
                Payment_v_date_check = true;
            }
        }
        else
        {
            Payment_vDatevalueChangeInprogress = false;
            Payment_v_date_check = true;
        }    
    }// Txt_V_Date value change
    function Amount_EditValueChanged(e)
    {
        var subtotal = $("#Txt_SubTotal").dxNumberBox("instance").option("value");
        var cashAmt = $("#Txt_CashAmt").dxNumberBox("instance").option("value");
        var BankAmt = $("#Txt_BankAmt").dxNumberBox("instance").option("value");
        var AdvAmt = $("#Txt_AdvAmt").dxNumberBox("instance").option("value");
        var CreditAmt = $("#Txt_CreditAmt").dxNumberBox("instance").option("value");
        var DiffAmt = subtotal - cashAmt - BankAmt - AdvAmt - CreditAmt;
        $("#Txt_DiffAmt").dxNumberBox("instance").option("value", parseFloat(DiffAmt.toFixed(2))); /*RedminBug#134897*/

        Calculation_Check();
        if (CreditAmt > 0)
        {
            Control_SetReadOnly("Txt_DueDate", "dxDateBox", false);
            $("#Txt_DueDate").dxDateBox("instance").option("value", null);
            $("#Txt_DueDate").dxDateBox("instance").option("placeholder", "Enter Due Date..");
        }
        else
        {
            Control_SetReadOnly("Txt_DueDate", "dxDateBox", true);
            $("#Txt_DueDate").dxDateBox("instance").option("value", null);
            $("#Txt_DueDate").dxDateBox("instance").option("placeholder", "");
        }
    }
</script>
