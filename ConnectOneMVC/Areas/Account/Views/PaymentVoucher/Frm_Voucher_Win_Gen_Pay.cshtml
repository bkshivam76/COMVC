<div class="PaymentVoucher_ClearReferences">
    @using DevExtreme.AspNet.Mvc;

    @model ConnectOneMVC.Areas.Account.Models.Param_paymentVoucherDetailsViewModel
    <link href="/content/fontawesome/css/fontawesome-all.css" rel="stylesheet">
    @{var isvisible = Model.TempActionMethod == "_View" || Model.TempActionMethod == "_Delete" ? true : false; }
    <style>
        .customPreviewRow {
            background: none;
        }

        .form-horizontal .control-label {
            text-align: right;
        }

        .partyDetailBtns > div {
            margin: 0 2px 2px 0;
        }
        /*FCRA Related*/
        #ListSpecialVoucherRef_Pmt .dx-list-item-content {
            padding: 4.5px;
        }
        .ListOneRow .dx-scrollable {
            overflow-y: hidden
        }
        @@media only screen and (max-width:768px) {
            .partyDetailBtns > div { padding: 4px; width: 49%; }
        }

    </style>
    <div class="form-horizontal" id="Payment_ParentDiv">
        @using (Ajax.BeginForm("Frm_Voucher_Win_Gen_Pay_BUT_SAVE_Click", "PaymentVoucher",
        new AjaxOptions
        {
            HttpMethod = "POST",
            UpdateTargetId = "",
            OnBegin = "AjaxBeginFormPost",
            OnSuccess = Model.PostSucessFunction
        },
        new
        {
            id = "ID_Frm_Voucher_Win_Gen_Pay",
            @class = "edit_form"
        }))
        {
            using (Html.DevExtreme().ValidationGroup("CashWinGenPay"))
            {
                @Html.HiddenFor(x => x.Tag, new { id = "Tag_Gen_Pay" })
                @Html.HiddenFor(x => x.ConfirmFlag, new { id = "ConfirmFlag_Gen_Pay" })
                @Html.HiddenFor(x => x.GLookUp_PartyList1_Txt, new { id = "GLookUp_PartyList1_Txt_Gen_Pay" })
                @Html.HiddenFor(x => x.TitleX, new { id = "TitleX_Gen_Pay" })
                @Html.HiddenFor(x => x.Text, new { id = "Text_Gen_Pay" })
                @Html.HiddenFor(x => x.GLookUp_PartyList1_REC_EDIT_ON, new { id = "GLookUp_PartyList1_REC_EDIT_ON_Gen_Pay" })
                @Html.HiddenFor(x => x.xID, new { id = "xID_Gen_Pay" })
                @Html.HiddenFor(x => x.xMID, new { id = "xMID_Gen_Pay" })
                @Html.HiddenFor(x => x.iParty_Req, new { id = "iParty_Req_Gen_Pay" })
                @Html.HiddenFor(x => x.LastEditedOn, new { id = "LastEditedOn_Gen_Pay" })
                @Html.HiddenFor(x => x.iSpecific_ItemID, new { id = "iSpecific_ItemID_Gen_Pay" })
                @Html.HiddenFor(x => x.iVoucher_Type, new { id = "iVoucher_Type_Gen_Pay" })
                @Html.HiddenFor(x => x.iTrans_Type, new { id = "iTrans_Type_Gen_Pay" })
                @Html.HiddenFor(x => x.iLed_ID, new { id = "iLed_ID_Gen_Pay" })
                @Html.HiddenFor(x => x.LB_DOCS_ARRAY, new { id = "LB_DOCS_ARRAY_Gen_Pay" })
                @Html.HiddenFor(x => x.LB_EXTENDED_PROPERTY_TABLE, new { id = "LB_EXTENDED_PROPERTY_TABLE_Gen_Pay" })
                @Html.HiddenFor(x => x.Sel_Bank_ID, new { id = "Sel_Bank_ID_Gen_Pay" })
                @Html.HiddenFor(x => x.IsProfileCreationVoucher, new { id = "IsProfileCreationVoucher_Gen_Pay" })
                @Html.HiddenFor(x => x.Info_LastEditedOn, new { id = "Info_LastEditedOn_Gen_Pay" })
                @Html.HiddenFor(x => x.TempActionMethod)
                @Html.HiddenFor(x => x.PopupName)//redmine Bug #133106 fixed
                @Html.HiddenFor(x => x.PostSucessFunction)//redmine Bug #133107 fixed
                @Html.HiddenFor(x => x.Pmt_SplVchrReferenceSelected)
                @Html.HiddenFor(x => x.splVchrRefsCount_Pmt)

                <div class="full-width-header-bg2">
                    <div class="row">

                        <div class="col-xs-6 pll">
                            <h3 class="popuphead"><i class="far fa-edit"></i>Payment</h3>
                        </div>
                        <div class="col-xs-6 prm">
                            <h5 class="mand-txt-align"><i class="fas fa-info-circle"></i> Red Fields are mandatory</h5>
                        </div>
                    </div>
                </div><!--[Header]-->
                <div class="row">
                    <div class="col-sm-12 col-md-6 col-lg-6">
                        <div class="form-field">
                            <div class="container-fluid">
                                <fieldset class="default-fieldset">
                                    <div class="row">
                                        <div class="col-sm-4">
                                            <legend class="custom-legend mlm"> Party Detail:</legend>
                                        </div>
                                        <div class="col-sm-8 text-right partyDetailBtns">
                                            @(Html.DevExtreme().Button().ID("VWGP_AddParty").Text("Add Party").Type(DevExtreme.AspNet.Mvc.ButtonType.Normal).OnClick("Payment_AddParty_Click").Disabled(isvisible) )
                                            @(Html.DevExtreme().Button().Text("Manage Party").Type(DevExtreme.AspNet.Mvc.ButtonType.Normal).OnClick("Payment_ManageParty_Click").Disabled(isvisible) )
                                        </div>
                                    </div><!--[Add Party/Manage Party]-->
                                    <div class="row">
                                        <div class="col-sm-2 pll">
                                            <label class="control-label" for="GLookUp_PartyList1_Tag">Name:</label>
                                        </div>
                                        <div class="col-sm-10 prm">
                                            @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_PartyList1_Tag").Name("GLookUp_PartyList1_Tag").ValueExpr("C_ID").DisplayExpr("C_NAME").OnValueChanged("GLookUp_PartyList1_EditValueChanged_Payment").ReadOnly(true)
                                              .DataSource(Model.PartyListData,"C_ID").Value(Model.GLookUp_PartyList1_Tag).Placeholder("Select Party...").ContentTemplate(@<text> @Html.Partial("frm_Gen_Pay_LookUp_GetPartyList") </text>))
                                        </div>
                                    </div><!--[Name]-->
                                    <div class="row">
                                        <div class="col-sm-4">
                                            <div class="row">
                                                <div class="col-sm-4 pll">
                                                    <label class="control-label" for="BE_City">City:</label>
                                                </div>
                                                <div class="col-sm-8 prm">
                                                    @(Html.DevExtreme().TextBoxFor(x => x.BE_City).CustomTextBox().ID("BE_City").Name("BE_City").Value(Model.BE_City).ReadOnly(true).FocusStateEnabled(false) )
                                                </div>
                                            </div>
                                        </div><!--[City]-->
                                        <div class="col-sm-4">
                                            <div class="row">
                                                <div class="col-sm-4 pll">
                                                    <label class="control-label" for="BE_PAN_No">PAN:</label>
                                                </div>
                                                <div class="col-sm-8 prm">
                                                    @(Html.DevExtreme().TextBoxFor(x => x.BE_PAN_No).CustomTextBox().ID("BE_PAN_No").Name("BE_PAN_No").Value(Model.BE_PAN_No).ReadOnly(true).FocusStateEnabled(false) )
                                                </div>
                                            </div>
                                        </div><!--[Pan No.]-->
                                        <div class="col-sm-4">
                                            <div class="row">
                                                <div class="col-sm-4 pll">
                                                    <label class="control-label" for="BE_PAN_No">Aadhar:</label>
                                                </div>
                                                <div class="col-sm-8 prm">
                                                    @(Html.DevExtreme().TextBoxFor(x => x.BE_AADHAR_No).CustomTextBox().ID("BE_AADHAR_No").Name("BE_AADHAR_No").Value(Model.BE_AADHAR_No).ReadOnly(true).FocusStateEnabled(false) )
                                                </div>
                                            </div>
                                        </div><!--[Pan No.]-->
                                    </div>
                                </fieldset>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-md-3 col-lg-3">
                        <div class="form-field">
                            <div class="container-fluid">
                                <fieldset class="default-fieldset">
                                    <legend class="custom-legend mlm"> Invoice / Bill Detail:</legend>
                                    <div class="row" style="padding-top: 2px;padding-bottom:2px">
                                        <div class="col-sm-3 pll">
                                            <label class="control-label" for="Txt_Inv_Date">Date:</label>
                                        </div>
                                        <div class="col-sm-9 prm">
                                            @(Html.DevExtreme().DateBox().CustomDateBox().ID("Txt_Inv_Date").Name("Txt_Inv_Date").Value(Model.Txt_Inv_Date).Placeholder("DD/MM/YYYY").Min(new DateTime(1990, 01, 01)).ReadOnly(isvisible))

                                        </div>
                                    </div><!--[Bill Date]-->
                                    <div class="row">
                                        <div class="col-sm-3 pll">
                                            <label class="control-label" for="FormData_Txt_Inv_No">No:</label>
                                        </div>
                                        <div class="col-sm-9 prm">
                                            @(Html.DevExtreme().TextBoxFor(x => x.Txt_Inv_No).CustomTextBox(true,true).ID("Txt_Inv_No").Name("Txt_Inv_No").Value(Model.Txt_Inv_No).Placeholder("Invoice / Bill No...").ReadOnly(isvisible).MaxLength(25) )

                                        </div>
                                    </div><!--[Bill No.]-->
                                </fieldset>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-md-3 col-lg-3">
                        <div class="form-field">
                            <div class="container-fluid">
                                <fieldset class="default-fieldset">
                                    <legend class="custom-legend mlm"> Voucher Detail:</legend>
                                    <div class="row" style="padding-top: 2px;padding-bottom:2px">
                                        <div class="col-sm-3 pll">
                                            <label class="control-label col-sm-4 text-red" for="Txt_V_Date">Date:</label>
                                        </div>
                                        <div class="col-sm-9 prm">
                                            @(Html.DevExtreme().DateBox().CustomDateBox().OnValueChanged("Txt_V_Date_EditValueChanging").ID("Txt_V_Date").Name("Txt_V_Date").Value(Model.Txt_V_Date).Placeholder("DD/MM/YYYY").ReadOnly(isvisible))

                                        </div>
                                    </div><!--[Voucher Date]-->
                                    <div class="row">
                                        <div class="col-sm-3 pll">
                                            <label class="control-label" for="Txt_V_NO">No:</label>
                                        </div>
                                        <div class="col-sm-9 prm">
                                            @(Html.DevExtreme().TextBoxFor(x => x.Txt_V_NO).CustomTextBox(true,true).ID("Txt_V_NO").Name("Txt_V_NO").Value(Model.Txt_V_NO).Placeholder("").ReadOnly(true).FocusStateEnabled(false) )
                                        </div>
                                    </div><!--[Voucher No.]-->
                                </fieldset>
                            </div>
                        </div>
                    </div>
                </div><!--[Block 1]-->
                <div class="row">
                    <div class="col-sm-12 col-md-12 col-lg-12">
                        <div id="Frm_Voucher_Win_Gen_Pay_Grid_1_PartialView">
                            @Html.Partial("ItemGrid_View", Model)
                        </div>
                    </div>
                </div><!--[Item Grid]-->
                <div class="row ">
                    <div class="col-sm-12 col-md-8 col-lg-8">
                        <div class="form-field">
                            <div class="container-fluid">
                                @(Html.DevExtreme().TabPanel().ID("ProductionVoucherpanel").Items(items =>
                                                                                                                                                                                                                                                                       {
                                                                                                                                                                                                                                                                           items.Add().Title("Bank Payment").Template(@<text> @BankPaymentView() </text>);
                                                                                                                                                                                                                                                                items.Add().Title("Advance Adjustment").Template(@<text> @AdvanceAdjustmentView() </text>);
                                                                                                                                                                                                                                                        items.Add().Title("Payable Adjustment").Template(@<text> @PayableAdjustmentView() </text>);
                                                                                                                                                                                                                                            }).DeferRendering(false))
                                @helper BankPaymentView()
                                {
                                    @Html.Partial("BankPayment_View", Model);
                                }
                                @helper AdvanceAdjustmentView()
                                {
                                    @Html.Partial("AdvanceAdjustment_View", Model);
                                }
                                @helper PayableAdjustmentView()
                                {
                                    @Html.Partial("PayableAdjustment_View", Model);
                                }
                            </div>
                        </div>
                    </div><!--[Tabs]-->
                    <div class="col-sm-12 col-md-4 col-lg-4 form-horizontal">
                        <div class="row">
                            <div class="bot-shadow ">
                                <div class="container-fluid">
                                    <fieldset class="default-fieldset">
                                        <legend class="custom-legend mlm"> Payment / Adjusted Details:</legend><br>
                                        <div class="col-md-6 col-sm-3 pll" style="text-align:right;">
                                            <label class="control-label" for="Txt_CashAmt">Cash Amount:</label>
                                        </div>
                                        <div class="col-md-6 col-sm-9 prm">
                                            @(Html.DevExtreme().NumberBox().CustomNumberBox()
                                            .ID("Txt_CashAmt").Name("Txt_CashAmt")
                                            .Value((double)Model.Txt_CashAmt)
                                            .OnValueChanged("Amount_EditValueChanged")
                                            .Format("#0.00").ReadOnly(isvisible)
                                         )

                                        </div><!--[Cash Amount]-->
                                        <div class="col-md-6 col-sm-3 pll" style="text-align:right;">
                                            <label class="control-label" for="Txt_CreditAmt">Credit Amount:</label>
                                        </div>
                                        <div class="col-md-6 col-sm-9 prm">
                                            @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Txt_CreditAmt").Name("Txt_CreditAmt").Value((double)Model.Txt_CreditAmt).OnValueChanged("Amount_EditValueChanged").Format("#0.00").ReadOnly(isvisible))
                                        </div><!--[Credit Amount]-->
                                        <div class="col-md-6 col-sm-3 pll" style="text-align:right;">
                                            <label class="control-label  bluedisabletxt" for="Txt_BankAmt">Bank Amount:</label>
                                        </div>
                                        <div class="col-md-6 col-sm-9 prm">
                                            @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Txt_BankAmt").Name("Txt_BankAmt").Value((double)Model.Txt_BankAmt).OnValueChanged("Amount_EditValueChanged").Format("#0.00").ReadOnly(true).FocusStateEnabled(false))

                                        </div><!--[Bank Amount]-->
                                        <div class="col-md-6 col-sm-3 pll" style="text-align:right;">
                                            <label class="control-label  bluedisabletxt" for="Txt_AdvAmt">Advance Adjustment:</label>
                                        </div>
                                        <div class="col-md-6 col-sm-9 prm">
                                            @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Txt_AdvAmt").Name("Txt_AdvAmt").Value((double)Model.Txt_AdvAmt).OnValueChanged("Amount_EditValueChanged").Format("#0.00").ReadOnly(true).FocusStateEnabled(false))

                                        </div><!--[Advance Adjustment]-->
                                        <div class="col-md-6 col-sm-3 pll" style="text-align:right;">
                                            <label class="control-label  bluedisabletxt" for="Txt_LB_Amt">Payable Adjustment:</label>
                                        </div>
                                        <div class="col-md-6 col-sm-9 prm">
                                            @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Txt_LB_Amt").Name("Txt_LB_Amt").Value((double)Model.Txt_LB_Amt).Format("#0.00").ReadOnly(true).FocusStateEnabled(false))

                                        </div><!--[Payable Adjustment]-->
                                        <div class="col-md-6 col-sm-3 pll" style="text-align:right;">
                                            <label class="control-label  bluedisabletxt" for="Txt_TDS_Amt">TDS amonut:</label>
                                        </div>
                                        <div class="col-md-6 col-sm-9 prm">
                                            @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Txt_TDS_Amt").Name("Txt_TDS_Amt").Value((double)Model.Txt_TDS_Amt).Format("#0.00").ReadOnly(true).FocusStateEnabled(false))


                                        </div><!--[TDS Amount]-->
                                    </fieldset>
                                </div>
                            </div>
                        </div>
                    </div><!--[Payment/Adjust detail]-->
                </div><!--[Tabs/Payment/Adjust detail]-->
                <div class="row">
                    <div class="col-sm-6 col-md-8 col-lg-8">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <div class="col-md-3 pll">
                                        <label class="control-label" id="Payment_Txt_Narration">Narration:</label>
                                    </div>
                                    <div class="col-md-9 prm">
                                        @(Html.DevExtreme().TextBoxFor(x => x.Txt_Narration).CustomTextBox(true).ID("Txt_Narration").Value(Model.Txt_Narration).Placeholder("Type Any Narration...").ReadOnly(isvisible).MaxLength(2000) )
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div><!--[Narration]-->
                    <div class="col-sm-6 col-md-4 col-lg-4">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="col-md-6 col-sm-3 pll" style="text-align:right;">
                                    <label class="control-label  bluedisabletxt" id="Payment_Txt_DueDate">Credit Due Date:</label>
                                </div>
                                <div class="col-md-6 col-sm-9 prm">
                                    @(Html.DevExtreme().DateBox().CustomDateBox().ID("Txt_DueDate").Name("Txt_DueDate").Value(Model.Txt_DueDate).ReadOnly(true))
                                </div>
                            </div>
                        </div>
                    </div><!--[Due Date]-->
                </div><!--[Narration/Due Date]-->
                <div class="row">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="col-sm-2 col-md-2 col-lg-2 pll">
                                <label class="control-label" id="Payment_Txt_Reference">Reference:</label>
                            </div>
                            <div class="col-sm-10 col-md-10 col-lg-10 prm">
                                @(Html.DevExtreme().TextBoxFor(x => x.Txt_Reference).CustomTextBox(true).ID("Txt_Reference").Value(Model.Txt_Reference).Placeholder("Type Any Reference Details...").ReadOnly(isvisible))
                            </div>
                        </div>
                    </div>
                </div><!--[Reference]-->

                <div class="row">
                    <div class="col-sm-12 col-md-12 col-lg-12 ListOneRow" id="Pmt_SpecialVoucherRefDiv">
                        <div class="form-field ">
                            <div class="dx-texteditor-container">
                                @(Html.DevExtreme().List().CustomList().ID("ListSpecialVoucherRef_Pmt")
                                .DataSource(Model.SpecialReferenceList_Data_Pmt, "Task_Name")
                                .SearchEnabled(false)
                                .SelectionMode(DevExtreme.AspNet.Mvc.ListSelectionMode.Multiple)
                                .KeyExpr("Task_Name")
                                .DisplayExpr("Task_Name")
                                .OnSelectionChanged("OnSplVchrRefsListSelectionChanged_Pmt")
                                .Height(42).Width(300).ShowScrollbar(ShowScrollbarMode.Always).UseNativeScrolling(false)
                                .ShowSelectionControls(true)
                                .SelectedItemKeys(Model.SpecialReference_Get_SelectedValue_Pmt))
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row" style="margin-top:3px">
                    <div class="col-sm-12 col-md-12 col-lg-12">
                        <div class="row">
                            <div class="col-sm-6 col-md-6 col-lg-6">
                                @Html.Partial("Drop_Request", String.Format("Send Your Request to Madhuban for ( {0} ~ Payment )...", Model.TempActionMethod.Substring(1)))
                            </div>
                            <div class="col-sm-6 col-md-6 col-lg-6">
                                <div class="styleActionBtn">
                                    @(Html.DevExtreme().Button().CustomSaveButton(Model.TempActionMethod).ID("frm_win_gen_Save").Text(Model.TempActionMethod == "_Delete" ? "Delete" : "Save").UseSubmitBehavior(false).OnClick("Payment_Voucher_Save").Visible(Model.TempActionMethod == "_View" ? false : true) )
                                    @(Html.DevExtreme().Button().CustomCloseButton().ID("frm_win_gen_Cancel").Text(Model.TempActionMethod == "_View" ? "Close" : "Cancel").OnClick(@<text> function () { Close_PaymentVoucher(); } </text>) )
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Buttons]-->
            }
        }
    </div>
