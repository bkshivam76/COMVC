@{
    bool FilterVisible = ViewBag.FilterVisible == null ? false : ViewBag.FilterVisible;
    bool SearchVisible = ViewBag.SearchVisible == null ? false : ViewBag.SearchVisible;
    bool ShowGroupedColumns = ViewBag.ShowGroupedColumns == null ? false : ViewBag.ShowGroupedColumns;
}

@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "Frm_Voucher_Win_Gen_Pay_Grid_2";
        settings.CallbackRouteValues = new
        {
            Controller = "PaymentVoucher",
            Action = "Frm_Voucher_Win_Gen_Pay_Grid_2",
            FilterVisible = FilterVisible,
            SearchVisible = SearchVisible,
            ShowGroupedColumns = ShowGroupedColumns
        };
        settings.Settings.VerticalScrollBarMode = ScrollBarMode.Visible;
        settings.Settings.VerticalScrollableHeight = 100;
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Visible;


        settings.KeyboardSupport = true;
        //settings.AccessKey = "G";
        settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
        settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.HideDataCells;



        settings.SettingsBehavior.AutoExpandAllGroups = true;
        settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
        settings.Settings.UseFixedTableLayout = true;
        settings.SettingsBehavior.ColumnMoveMode = GridColumnMoveMode.AmongSiblings;
        settings.SettingsBehavior.AllowSort = true;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.NextColumn;
        settings.SettingsResizing.Visualization = ResizingMode.Live;
        settings.SettingsBehavior.AllowEllipsisInText = true;

        settings.CustomJSProperties = (sender, e) =>
        {
            var grid = (sender as MVCxGridView);
            int startIndex = (grid.PageIndex == -1 || grid.SettingsPager.Mode == GridViewPagerMode.ShowAllRecords ? 0 : grid.PageIndex) * grid.SettingsPager.PageSize;
            int endIndex = grid.PageIndex == -1 || grid.SettingsPager.Mode == GridViewPagerMode.ShowAllRecords ? grid.VisibleRowCount : Math.Min(grid.VisibleRowCount, startIndex + grid.SettingsPager.PageSize);
            object[] Rowdata = new object[endIndex - startIndex];
            for (int n = startIndex; n < endIndex; n++)
            {
                Rowdata[n - startIndex] = grid.GetRowValues(n, new string[] { "Sr" });
            }
            e.Properties["cpPagedata"] = Rowdata;
        };


        settings.SettingsBehavior.AllowFocusedRow = true;
        settings.ClientSideEvents.FocusedRowChanged = "OnBankPaymentGridFocusedRowChanged";
        settings.ClientSideEvents.Init = "Frm_Voucher_Win_Gen_Pay_Grid_2_Init";
        settings.ClientSideEvents.RowDblClick = "Frm_Voucher_Win_Gen_Pay_Grid_2_DblClick";
        settings.SettingsContextMenu.Enabled = true;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;
        settings.FillContextMenuItems = (sender, e) =>
        {
            if (e.MenuType == GridViewContextMenuType.Rows)
            {
                var Additem = e.CreateItem("New", "New");
                Additem.Image.IconID = "actions_new_16x16gray";
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Additem);
                var Edititem = e.CreateItem("Edit", "Edit");
                Edititem.Image.IconID = "actions_edit_16x16devav";
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Edititem);
                var Deleteitem = e.CreateItem("Delete", "Delete");
                Deleteitem.Image.IconID = "actions_delete_16x16devav";
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Deleteitem);
                var Viewitem = e.CreateItem("View", "View");
                Viewitem.Image.IconID = "actions_show_16x16gray";
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Viewitem);
            }
        };
        settings.ClientSideEvents.ContextMenuItemClick = "Frm_Voucher_Win_Gen_Pay_Grid_2_ContextMenuFunction";
        // DXCOMMENT: Specify the grid's key field name and define grid columns in accordance with data model fields
        settings.KeyFieldName = "Sr";

        settings.Columns.Add("Sr").Caption = "Sr.";
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Amount";
                column.Caption = "Amount";
                column.PropertiesEdit.DisplayFormatString = "#0.00";
            }
        });
        settings.Columns.Add("Mode").Caption = "Mode";
        settings.Columns.Add("Ref_No").Caption = "No.";
        settings.Columns.Add("Ref_Date", MVCxGridViewColumnType.DateEdit).Caption = "Date";
        settings.Columns.Add("Ref_CDate", MVCxGridViewColumnType.DateEdit).Caption = "Clearing Date";
        settings.Columns.Add("BANK_NAME").Caption = "Bank Name";
        settings.Columns.Add("Branch").Caption = "Branch";
        settings.Columns.Add("Acc_No").Caption = "A/c. No.";
        settings.Columns.Add(new MVCxGridViewColumn() { FieldName = "ID", Caption = "ID", Visible = false });
        settings.Columns.Add(new MVCxGridViewColumn() { FieldName = "MT_BANK_ID", Caption = "MT_BANK_ID", Visible = false });
        settings.Columns.Add("MT_BANK_Name").Caption = "Money Transfer Bank";
        settings.Columns.Add("Ref_Acc_No").Caption = "Ref. A/c. No.";
        settings.Columns.Add(new MVCxGridViewColumn() { FieldName = "Edit_Time", Caption = "Edit_Time", Visible = false });




        settings.SettingsFilterControl.ViewMode = true ? FilterControlViewMode.VisualAndText : FilterControlViewMode.Visual;
        settings.SettingsFilterControl.AllowHierarchicalColumns = true;// AllowHierarchicalColumns;
        settings.SettingsFilterControl.ShowAllDataSourceColumns = true;//FilterBuilderDemoHelper.Options.ShowAllDataSourceColumns;
        settings.SettingsFilterControl.MaxHierarchyDepth = 1;

        settings.Settings.ShowGroupedColumns = ShowGroupedColumns;
        //settings.Settings.ShowGroupButtons = false;
        //settings.Settings.ShowFooter = true;
        MyExtensions.GridViewHelper.CustomGridView(settings);
    }).Bind(Model).GetHtml()

