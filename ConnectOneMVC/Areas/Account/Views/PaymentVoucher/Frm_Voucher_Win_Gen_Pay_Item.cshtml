    <script>
    var Paymentitem_ActionMethod = "@Model.TempActionMethod";  
    function PaymentItem_AddParty_Click(e)
    {
        if (Paymentitem_ActionMethod == "_New" || Paymentitem_ActionMethod== "_Edit" || Paymentitem_ActionMethod == "_New_From_Selection")
        {
            AddParty("Payment_Add_Party", "LookUp_GetPartyList_PaymentItem", "PaymentItem_AddParty_Click", "PaymentAddParty");
        }
    }
    </script>
    <script>
    $(document).ready(async function ()
    {
        ShowLoader_Ready();
        InitAllDD_PaymentItem();
        TransformTextForDB("ID_Frm_Voucher_Win_Gen_Pay_Item_Window");
        await Promise.all([LookUp_GetItemList(true),LookUp_GetPartyList_PaymentItem("", true)]);
        if ("@Model.ActionMethod" == "_New" || "@Model.ActionMethod" == "_New_From_Selection")
        {
            $("#GLookUp_PurList").dxSelectBox("instance").option("readOnly", false);
        }
        await PartyBind();
        if ("@Model.TempActionMethod" == "_View" || "@Model.TempActionMethod" == "_Delete" || "@Model.TempActionMethod" == "_Edit")
        {
            await Data_Binding();
            Control_SetReadOnly("GLookUp_ItemList", "dxDropDownBox", true);
            Control_SetReadOnly("GLookUp_PartyList", "dxDropDownBox", true);
        }
        if ("@Model.TempActionMethod" == "_View")
        {
            switch ($("#iProfile").val().toUpperCase())
            {
                case "GOLD":
                case "SILVER":
                case "OTHER ASSETS":
                case "LIVESTOCK":
                case "VEHICLES":
                case "LAND & BUILDING":
                case "TELEPHONE BILL":
                    $("#Payment_Item_ViewMode_Btn").dxButton("instance").option("visible", true);
                    break;
                default:
                    if ($("#iVoucher_Type").val().toUpperCase().trim() == "LAND & BUILDING" && $("#iProfile").val().toUpperCase() != "LAND & BUILDING") {
                        $("#Payment_Item_ViewMode_Btn").dxButton("instance").option("visible", true);
                    }
                    else {
                        $("#Payment_Item_ViewMode_Btn").dxButton("instance").option("visible", false);
                    }
                    break;
            }
        }
        if ("@Model.ActionMethod" == "_New" && "@Model.GLookUp_PurList".length > 0)
        {
            Control_SetReadOnly("GLookUp_PurList", "dxSelectBox", true);
            //$("#GLookUp_PurList").dxSelectBox("instance").option("readOnly", true);
        }
        if ("@Model.iSpecific_Allow" == "True")
        {
            @*await Item_DG_Pay.selectRows("@Model.iSpecific_ItemID", false);*@
            await GLookUp_ItemList_EditValueChanged();
            Control_SetReadOnly("GLookUp_ItemList", "dxDropDownBox", false);
            $("#iSpecific_Allow").val(false);
        }
        if ("@Model.AllowAmountEdit" == "False")
        {
            $("#Txt_Amt").dxNumberBox({ inputAttr: { title: "Amount has been disabled , as there are references posted against created item" } });
            $("#Txt_Amt").dxNumberBox("instance").option("readOnly", true);
            $("#Txt_Qty").dxNumberBox({ inputAttr: { title: "Quantity has been disabled , as there are references posted against created item" } });
            $("#Txt_Qty").dxNumberBox("instance").option("readOnly", true);
        }
        $("#Payment_Credit_Amt").val($("#Txt_CreditAmt").dxNumberBox("instance").option("value"));
        Set_Form_View_Delete_Mode(null, "ID_Frm_Voucher_Win_Gen_Pay_Item_Window", "@Model.TempActionMethod");
        Focus_FirstEditable_Field("ID_Frm_Voucher_Win_Gen_Pay_Item_Window");
        HideLoader_Ready();      
    });// document.ready fn
    async function Data_Binding ()
    {
        await GLookUp_ItemList_EditValueChanged();
        Control_SetReadOnly("GLookUp_ItemList", "dxDropDownBox", false);
        $("#GLookUp_PurList").dxSelectBox("instance").option("readOnly", false);
    }

    @*document.body.addEventListener("keydown", PaymentItem_doucumentKeyDown, false);
    function PaymentItem_doucumentKeyDown(evt)
    {
        if (evt.ctrlKey && evt.keyCode == 79)//ctrl+o save
        {
            evt.preventDefault();
            if ("@Model.TempActionMethod" == "_New"||"@Model.TempActionMethod" == "_Edit"||"@Model.TempActionMethod" == "_New_From_Selection")
            {
                $("#ItemEdit").trigger("dxclick");
            }
        }
        else if (evt.ctrlKey && evt.keyCode == 65)//ctrl+a add party
        {
            evt.preventDefault();
            Payment_AddParty_Click();
        }
        else if (evt.ctrlKey && evt.keyCode == 76)//ctrl+l show party ledger
        {
            evt.preventDefault();
            Payment_ShowPartyLedger_Click();
        }
        else if (evt.ctrlKey && evt.keyCode == 68)//ctrl+d delete
        {
            evt.preventDefault();
            if ("@Model.TempActionMethod" == "_Delete")
            {
                $("#ItemDelete").trigger("dxclick");
            }
        }

    }*@ //shortcuts

    </script>
    @* Document.ready *@
    <script>
        var Payment_Party_Pan = "";
        var Payment_Item_Party_Name = "";
        function GetTDSRate() {
            $("#TXT_TDS").dxNumberBox("instance").option("readOnly", false);
            $("#TXT_TDS").dxNumberBox("instance").option("focusStateEnabled", true);
            $("#tdsdeducted").removeClass("disabletxt");
            $("#TXT_TDS").dxNumberBox("instance").option("placeholder", "TDS Deducted");

            if ((!($("#GLookUp_ItemList").dxDropDownBox("instance").option("value"))) || (!($("#GLookUp_PartyList").dxDropDownBox("instance").option("value")))) {
                $("#BE_TDS_Rate").dxTextBox("instance").option("value", "NA");
                $("#TXT_TDS").dxNumberBox("instance").option("readOnly", true);
                $("#TXT_TDS").dxNumberBox("instance").option("focusStateEnabled", false);
                $("#tdsdeducted").addClass("disabletxt");
                $("#TXT_TDS").dxNumberBox("instance").option("placeholder", "");
                return;
            }
            if ($("#iTDS_CODE").val().toUpperCase() == "NONE") {
                $("#BE_TDS_Rate").dxTextBox("instance").option("value", "NA");
                $("#TXT_TDS").dxNumberBox("instance").option("readOnly", true);
                $("#TXT_TDS").dxNumberBox("instance").option("focusStateEnabled", false);
                $("#tdsdeducted").addClass("disabletxt");
                $("#TXT_TDS").dxNumberBox("instance").option("placeholder", "");
                return;
            }
            $.ajax({
                type: 'GET',
                url: "/Account/PaymentVoucher/GetTDSRate",
                data: { PAN: Payment_Party_Pan, TDS_Code: $("#iTDS_CODE").val() },
                cache: false,
                success: function (data) {
                    if (data.result == false) {
                        DevExpress.ui.dialog.alert(data.message, 'Error..');
                    }
                    else {
                        if (data.taxRate) {
                            $("#BE_TDS_Rate").dxTextBox("instance").option("value", data.taxRate);
                        }
                        else {
                            $("#BE_TDS_Rate").dxTextBox("instance").option("value", "NA");
                        }
                    }
                }
            });
        }
        async function PartyBind()
        {
            Control_SetReadOnly("GLookUp_PartyList", "dxDropDownBox", false);
            if ($("#iPartyID").val() == null || $("#iPartyID").val().length <= 0)
            {
                return;
            }
            if ($("#iPartyID").val().length > 0)
            {
                await ChangeLookUp_GetPartyList_Gen_Pay_Item();
                Control_SetReadOnly("GLookUp_PartyList", "dxDropDownBox", true, "#696969");
            }
        }
        function Payment_ShowPartyLedger_Click() {
            var GLookUp_PartyList_Tag = $("#GLookUp_PartyList").dxDropDownBox("instance").option("value");
            if (GLookUp_PartyList_Tag != null && GLookUp_PartyList_Tag != "") {
                $("#Payment_Add_Party").dxPopup("instance").option("title", "Current Year Transactions for " + Payment_Item_Party_Name);
                $("#Payment_Add_Party").dxPopup("show");
                $("#Payment_Add_Party").dxPopup("instance").option("width", "70%");
                $("#Payment_Add_Party").dxPopup("instance").option("height", "70%");
                $("#result_PaymentAddParty").html('');
                ShowLoader();
                $.ajax({
                    type: 'Get',
                    url: "/Reports/PartyLedger/Frm_Party_Report",
                    data: { _Opening: 0, partyid: GLookUp_PartyList_Tag, PopUpId: "Payment_Add_Party" },
                    cache: false,
                    success: function (resultsuccess) {
                        $("#result_PaymentAddParty").html(resultsuccess);
                        HideLoader();
                    }
                });
            }
        }
        function Payment_item_Save(e) {
            if (ValidateForm(e)) {
                var form = $("#ID_Frm_Voucher_Win_Gen_Pay_Item_Window");
                if (($("#iVoucher_Type").val()).trim().toUpperCase() == "PAYMENT - INSTITUTE") {
                    var Confirmclick = DevExpress.ui.dialog.confirm('<div><size=13><b>Transfer to other Institute not allowed <font color=red>without Head-Quarter Permission</font>...!</b></size></br></br>Do you want to Continue...?</div>', "Message...");
                    Confirmclick.done(function (alertResult) {
                        if (alertResult) {
                            form.submit();
                        }
                        else {
                            $("#GLookUp_ItemList").dxDropDownBox("instance").focus();
                        }
                    });
                }
                else {
                    form.submit();
                }
            }
        }
    </script>
    @* Other Functions *@
    <script>
    async function GLookUp_ItemList_EditValueChanged(e)
    {
        var item;
        if (e)
        {
            item = e.value;
            if ((e.value == null || e.value.length == 0) && e.previousValue != null)
            {
                Item_DG_Pay.clearSelection();
                return;
            }
        }
        else
        {
            item = $("#GLookUp_ItemList").dxDropDownBox("option", "value");
        }
        await Item_DG_Pay.selectRows(item);
        if (Item_DG_Pay.getSelectedRowsData().length > 0)
        {
            var item = Item_DG_Pay.getSelectedRowsData()[0];
            $("#BE_Item_Head").dxTextBox("instance").option("value", item["LED_NAME"]);
            $("#BE_TDS_Section").dxTextBox("instance").option("value", item["ITEM_TDS_CODE"]);
            $("#iVoucher_Type").val(item["ITEM_VOUCHER_TYPE"]);
            $("#iLed_ID").val(item["ITEM_LED_ID"]);
            $("#iLed_Type").val(item["LED_TYPE"]);
            $("#iCon_Led_Type").val(item["CON_LED_TYPE"]);
            $("#iTrans_Type").val(item["ITEM_TRANS_TYPE"]);
            $("#iParty_Req").val(item["ITEM_PARTY_REQ"]);
            $("#Item_Name").val(item["ITEM_NAME"]);
            if (item["ITEM_PARTY_REQ"].toUpperCase().trim() == "YES")
            {
                $("#itemdetail_partylabel").addClass("text-red");
            }
            else
            {
                $("#itemdetail_partylabel").removeClass("text-red");
            }
            $("#iProfile").val(item["ITEM_PROFILE"]);
            $("#iCond_Ledger_ID").val(item["ITEM_CON_LED_ID"]);
            $("#iMinValue").val(item["ITEM_CON_MIN_VALUE"]);
            $("#iMaxValue").val(item["ITEM_CON_MAX_VALUE"]);
            $("#iTDS_CODE").val(item["ITEM_TDS_CODE"]);
            GetTDSRate();
            if ($("#iProfile").val() == "VEHICLES" || $("#iProfile").val() == "LIVESTOCK" || $("#iProfile").val() == "LAND & BUILDING")
            {
                $("#Txt_Qty").dxNumberBox("instance").option("readOnly", true);
                $("#Cmb_Unit").dxSelectBox("instance").option("readOnly", true);
                $("#Txt_Rate").dxNumberBox("instance").option("readOnly", true);
                $("#Txt_Qty").dxNumberBox("instance").option("value", 1);
                $("#Cmb_Unit").dxSelectBox("instance").option("value", "NO");
                $("#Txt_Rate").dxNumberBox("instance").option("placeholder", "");
                $("#payment_item_qty").addClass("disabletxt");
                $("#payment_item_unit").addClass("disabletxt");
                $("#payment_item_rate").addClass("disabletxt");
            }
            else if ($("#iProfile").val() == "ADVANCES" || $("#iProfile").val() == "OTHER DEPOSITS" || $("#iProfile").val() == "OTHER LIABILITIES" || $("#iProfile").val() == "TELEPHONE BILL")
            {
                $("#Txt_Qty").dxNumberBox("instance").option("readOnly", true);
                $("#Cmb_Unit").dxSelectBox("instance").option("readOnly", true);
                $("#Txt_Rate").dxNumberBox("instance").option("readOnly", true);
                $("#Txt_Qty").dxNumberBox("instance").reset();
                $("#Txt_Qty").dxNumberBox("instance").option("placeholder", "");
                $("#Txt_Rate").dxNumberBox("instance").option("placeholder", "");
                $("#Cmb_Unit").dxSelectBox("instance").option("value", "NO");
                $("#payment_item_qty").addClass("disabletxt");
                $("#payment_item_unit").addClass("disabletxt");
                $("#payment_item_rate").addClass("disabletxt");
            }
            else if ($("#iProfile").val() == "GOLD" || $("#iProfile").val() == "SILVER" || $("#iProfile").val() == "OTHER ASSETS")
            {

                $("#Txt_Qty").dxNumberBox("instance").option("readOnly", false);
                $("#Cmb_Unit").dxSelectBox("instance").option("readOnly", false);
                $("#Txt_Rate").dxNumberBox("instance").option("readOnly", false);
                $("#Cmb_Unit").dxSelectBox("instance").option("value", "NO");
                $("#Cmb_Unit").dxSelectBox("instance").option("placeholder", "Select Unit");
                $("#Txt_Rate").dxNumberBox("instance").option("placeholder", "Enter Rate");
                $("#Txt_Qty").dxNumberBox("instance").option("placeholder", "Enter Quantity");
                $("#payment_item_qty").removeClass("disabletxt");
                $("#payment_item_unit").removeClass("disabletxt");
                $("#payment_item_rate").removeClass("disabletxt");
            }
            else
            {
                $("#Txt_Qty").dxNumberBox("instance").option("readOnly", false)
                $("#Cmb_Unit").dxSelectBox("instance").option("readOnly", false)
                $("#Txt_Rate").dxNumberBox("instance").option("readOnly", false)
                $("#Txt_Qty").dxNumberBox("instance").reset();
                $("#Cmb_Unit").dxSelectBox("instance").option("placeholder", "Select Unit");
                $("#Txt_Rate").dxNumberBox("instance").option("placeholder", "Enter Rate");
                $("#Txt_Qty").dxNumberBox("instance").option("placeholder", "Enter Quantity");
                $("#payment_item_qty").removeClass("disabletxt");
                $("#payment_item_unit").removeClass("disabletxt");
                $("#payment_item_rate").removeClass("disabletxt");
            }

            if ("@Model.TempActionMethod" != "_View" && "@Model.TempActionMethod" != "_Delete")
            {
                if ($("#GLookUp_PartyList").dxDropDownBox("instance").option("value") != "" && $("#GLookUp_PartyList").dxDropDownBox("instance").option("value") != null)
                {
                    if ($("#iTDS_CODE").val().toUpperCase() != "NONE" && Payment_Party_Pan.length < 10)
                    {
                        if ("@Model.TempActionMethod" == "_Edit")
                        {
                            if ($("#GLookUp_PartyList").dxDropDownBox("instance").option("readOnly") == false && $("#GLookUp_PartyList").dxDropDownBox("instance").option("disabled") == false)
                            {
                                DevExpress.ui.dialog.alert('PAN No. not specified in Party Details...!<br>TDS Rates will be shown as higher for parties without PAN information.<br>Please enter PAN information in AddressBook under "General" Tab. ', 'Incomplete Information...').done(function (result) { $("#GLookUp_ItemList").dxDropDownBox("focus") });
                            }
                        }
                        else
                        {
                            DevExpress.ui.dialog.alert('PAN No. not specified in Party Details...!<br>TDS Rates will be shown as higher for parties without PAN information.<br>Please enter PAN information in AddressBook under "General" Tab. ', 'Incomplete Information...').done(function (result) { $("#GLookUp_ItemList").dxDropDownBox("focus") });
                        }
                    }
                }
            }
        }
    }
    async function ChangeLookUp_GetPartyList_Gen_Pay_Item(e)
    {
        var party;
        if (e)
        {
            party = e.value;
            if ((e.value == null || e.value.length == 0) && e.previousValue != null)
            {
                Party_DG_itemPay.clearSelection();
                GetTDSRate();
                return;
            }
        }
        else
        {
            party = $("#GLookUp_PartyList").dxDropDownBox("option", "value");
        }
        await Party_DG_itemPay.selectRows(party);
        if (Party_DG_itemPay.getSelectedRowsData().length > 0)
        {
            var item = Party_DG_itemPay.getSelectedRowsData()[0];
            Payment_Party_Pan = item["PAN"] == null ? "" : item["PAN"];         
            Payment_Item_Party_Name = item["Name"];
            if ("@Model.TempActionMethod" != "_View" && "@Model.TempActionMethod" != "_Delete")
            {
                if (Item_DG_Pay.getSelectedRowsData().length > 0 && $("#iTDS_CODE").val().toUpperCase() != "NONE" && Payment_Party_Pan.length < 10)
                {
                    if ("@Model.TempActionMethod" == "_Edit")
                    {
                        if (e.component.option("readOnly") == false && e.component.option("disabled") == false)
                        {
                            DevExpress.ui.dialog.alert('PAN No. not specified in Party Details...!<br>TDS Rates will be shown as higher for parties without PAN information.<br>Please enter PAN information in AddressBook under "General" Tab. ', 'Incomplete Information...').done(function (result) { $("#GLookUp_PartyList").dxDropDownBox("focus")});
                        }
                    }
                    else
                    {
                        DevExpress.ui.dialog.alert('PAN No. not specified in Party Details...!<br>TDS Rates will be shown as higher for parties without PAN information.<br>Please enter PAN information in AddressBook under "General" Tab. ', 'Incomplete Information...').done(function (result) { $("#GLookUp_PartyList").dxDropDownBox("focus") });
                    }
                }
            }
        }
        GetTDSRate();
    }

    function Txt_Qty_EditValueChanged(e)
    {
        if ($("#Calc_Allow").val()=="True")
        {
            if ("@Model.TempActionMethod" == "_New")
            {
                $("#Txt_Amt").dxNumberBox("instance").option("value", parseFloat(($("#Txt_Rate").dxNumberBox("instance").option("value") * e.value).toFixed(2)));
            }
        }
    }//qty
    function Txt_Rate_EditValueChanged(e)
    {
        if ($("#Calc_Allow").val()=="True")
        {
            if ("@Model.TempActionMethod" == "_New")
            {
                $("#Txt_Amt").dxNumberBox("instance").option("value", parseFloat(($("#Txt_Qty").dxNumberBox("instance").option("value") * e.value).toFixed(2)));
            }
        }
    } //rate
    </script>
