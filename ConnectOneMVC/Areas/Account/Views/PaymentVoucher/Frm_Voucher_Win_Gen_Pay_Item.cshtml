    <script>
        var Item_DG_Pay;
        var Party_DG_itemPay;
        var dataSource_Party_Payment_Item = null;
        function InitAllDD_PaymentItem()
        {
            //await Promise.all([$("#GLookUp_ItemList").dxDropDownBox("getDataSource").load(),
                //$("#GLookUp_PartyList").dxDropDownBox("getDataSource").load()]);
            var $Item_DG_Pay = $("#Frm_Gen_Pay_Item_GLookUp_ItemList_datagrid");
            if ($Item_DG_Pay.length)
            {
                Item_DG_Pay = $Item_DG_Pay.dxDataGrid("instance");
            }
            var $Party_DG_Pay = $("#Frm_Gen_Pay_Item_GLookUp_PartyList1_datagrid");
            if ($Party_DG_Pay.length)
            {
                Party_DG_itemPay = $Party_DG_Pay.dxDataGrid("instance");
            }
        }
        async function LookUp_GetItemList(FirstCall = false)
        {
            var DGItem = GetDataSourceItems("GLookUp_ItemList", "dxDropDownBox");
            var TotalCount = DGItem.length;          
            if (TotalCount == 1)
            {
                $("#GLookUp_ItemList").find('input').css('color', '#000080');
                if (Paymentitem_ActionMethod == "_New" || Paymentitem_ActionMethod == "_New_From_Selection")
                {
                    if (FirstCall === true)
                    {
                        await GLookUp_ItemList_EditValueChanged();
                    }
                    Control_SetReadOnly("GLookUp_ItemList", "dxDropDownBox", true);
                }
            }
            else
            {
                if (Paymentitem_ActionMethod == "_New" || Paymentitem_ActionMethod == "_New_From_Selection")
                {
                    Control_SetReadOnly("GLookUp_ItemList", "dxDropDownBox", false);
                }
            }
        }
        async function LookUp_GetPartyList_PaymentItem(partyid = "", FirstCall = false)
        {
            if (FirstCall === false)
            {
                ShowLoader();
                $.ajax({
                    type: 'GET',
                    url: "/Account/PaymentVoucher/RefreshPartyList_Item",
                    cache: false,
                    success: function (data) {
                        dataSource_Party_Payment_Item = new DevExpress.data.DataSource({ // need to dispose it in in clearreference
                            store:
                            {
                                type: "array",
                                key: "ID",
                                data: data
                            }
                        });
                        $("#GLookUp_PartyList").dxDropDownBox("instance").option("dataSource", dataSource_Party_Payment_Item);
                        Party_DG_itemPay.option("dataSource", dataSource_Party_Payment_Item);
                        dataSource_Party_Payment_Item.load().done((r) => {
                            $("#GLookUp_PartyList").dxDropDownBox("reset");
                            if (partyid.length > 0) {
                                $("#GLookUp_PartyList").dxDropDownBox("option", "value", partyid)
                                Control_SetReadOnly("GLookUp_PartyList", "dxDropDownBox", false);
                            }
                            $("#GLookUp_PartyList").dxDropDownBox("focus")
                            HideLoader();
                        })
                    }
                });
            }
            else
            {
                if (Paymentitem_ActionMethod == "_New" || Paymentitem_ActionMethod == "_New_From_Selection")
                {
                    Control_SetReadOnly("GLookUp_PartyList", "dxDropDownBox", false);
                }
            }
        }
    </script>
