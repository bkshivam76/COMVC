    function ShowRemark_valueChange(e)
    {
        if (e.value)
        {
           $(".customPreviewRow").show();
        }
        else
        {
           $(".customPreviewRow").hide();
        }
    }
    function Frm_Voucher_Win_Gen_Pay_Grid_1_EndCallBack(s, e)
    {
        if ($("#CheckEdit2").dxCheckBox("instance").option("value"))
        {
            $(".customPreviewRow").show();
        }
        else
        {
            $(".customPreviewRow").hide();
        }
        Grid1_Item_TotalCount = s.cpGrid1_VisibleRowCount;
    }
    function Frm_Voucher_Win_Gen_Pay_Grid_1_OnGridFocusedRowChanged(s, e)
    {
        s.Focus();
       // Payment_Grid_1_RowNumber = s.GetRowKey(s.GetFocusedRowIndex());
        //s.GetRowValues(s.GetFocusedRowIndex(), 'Sr;Item_ID', Frm_Voucher_Win_Gen_Pay_Grid_1_OnGetRowValues);
    }
    function Frm_Voucher_Win_Gen_Pay_Grid_1_OnGetRowValues(values)
    {
        Payment_Grid_1_RowNumber = (values[0]);
        Payment_Selected_ItemID = values[1];
    }

    function OnFrm_Voucher_Item_popup_NewClick()
    {
        if ("@IsDisabled" == "False")
        {
            Payment_vDate_item = ($("#Txt_V_Date").dxDateBox("instance").option("value") == null || $("#Txt_V_Date").dxDateBox("instance").option("value") == "") ? null : FormatDateToddMMyyyy($("#Txt_V_Date").dxDateBox("instance").option("value"));
            Payment_partyID_item = $("#GLookUp_PartyList1_Tag").dxDropDownBox("instance").option("value") == null ? "" : $("#GLookUp_PartyList1_Tag").dxDropDownBox("instance").option("value");
            if (ActionMethod_Payment == "_New_From_Selection")
            {
                ActionMethod_Payment = "_New";
                $("#TempActionMethod").val("_New");
                Payment_ispecificallow_item = true;
            }
            else
            {
                Payment_ispecificallow_item = false;
            }
            ShowLoader();
            Actionmethod_pay_item = "New";
            @*var Url = "@Url.Action("Frm_Voucher_Win_Gen_Pay_Item", "PaymentVoucher", new { @area = "Account" })?ActionMethod=New" + "&iSpecific_Allow=" + Payment_ispecificallow_item + "&iSpecific_ItemID=" + $("#iSpecific_ItemID_Gen_Pay").val() + "&Vdt=" + Payment_vDate_item +"&iPartyID=" + Payment_partyID_item;*@
            $.ajax({
                type: 'GET',
                url: "/Account/PaymentVoucher/Frm_Voucher_Win_Gen_Pay_Item",
                data:
                {
                    ActionMethod:"New",
                    iSpecific_Allow:Payment_ispecificallow_item,
                    iSpecific_ItemID: $("#iSpecific_ItemID_Gen_Pay").val(),
                    Vdt:Payment_vDate_item,
                    iPartyID:Payment_partyID_item
                },
                cache: false,
                success: function (data)
                {
                    OpenPopup("Frm_Voucher_Item_popup", "New ~ Item Detail", null, "auto",850, true,data);
                }
            });
        }
    }
    function OnFrm_Voucher_Win_Gen_Pay_EditClick()
    {
        if ("@IsDisabled" == "False")
        {
            Payment_partyID_item = $("#GLookUp_PartyList1_Tag").dxDropDownBox("instance").option("value") == null ? "" : $("#GLookUp_PartyList1_Tag").dxDropDownBox("instance").option("value");
            if (Frm_Voucher_Win_Gen_Pay_Grid_1.GetFocusedRowIndex()>-1)
            {
                Payment_ItemGrid_Data = Frm_Voucher_Win_Gen_Pay_Grid_1.cpPagedata;
                Payment_Grid_1_RowNumber = Payment_ItemGrid_Data[Frm_Voucher_Win_Gen_Pay_Grid_1.GetFocusedRowIndex() - Frm_Voucher_Win_Gen_Pay_Grid_1.GetTopVisibleIndex()][0];
                Payment_Selected_ItemID = Payment_ItemGrid_Data[Frm_Voucher_Win_Gen_Pay_Grid_1.GetFocusedRowIndex() - Frm_Voucher_Win_Gen_Pay_Grid_1.GetTopVisibleIndex()][1];
                Actionmethod_pay_item = "Edit";
                @*var Url = "@Url.Action("Frm_Voucher_Win_Gen_Pay_Item", "PaymentVoucher", new { @area = "Account" })?ActionMethod=Edit&iPartyID=" + Payment_partyID_item + "&GridRowNo=" + Payment_Grid_1_RowNumber;*@
                ShowLoader();
                $.ajax({
                    type: 'GET',
                    url: "/Account/PaymentVoucher/Frm_Voucher_Win_Gen_Pay_Item",
                    data:
                    {
                        ActionMethod: "Edit",
                        iPartyID: Payment_partyID_item,
                        GridRowNo: Payment_Grid_1_RowNumber
                    },
                    cache: false,
                    success: function (data)
                    {
                        OpenPopup("Frm_Voucher_Item_popup", "Edit ~ Item Detail", null, "auto",850, true, data);
                    }
                });
            }
            else
            {
                DevExpress.ui.dialog.alert('Please Select One Row', "Information!!");
            }
        }
    }
    function OnFrm_Voucher_Win_Gen_Pay_DeleteClick()
    {
        if ("@IsDisabled" == "False")
        {
            if (Frm_Voucher_Win_Gen_Pay_Grid_1.GetFocusedRowIndex() > -1)
            {
                Payment_ItemGrid_Data = Frm_Voucher_Win_Gen_Pay_Grid_1.cpPagedata;
                Payment_Grid_1_RowNumber = Payment_ItemGrid_Data[Frm_Voucher_Win_Gen_Pay_Grid_1.GetFocusedRowIndex() - Frm_Voucher_Win_Gen_Pay_Grid_1.GetTopVisibleIndex()][0];
                Payment_Selected_ItemID = Payment_ItemGrid_Data[Frm_Voucher_Win_Gen_Pay_Grid_1.GetFocusedRowIndex() - Frm_Voucher_Win_Gen_Pay_Grid_1.GetTopVisibleIndex()][1];
                Actionmethod_pay_item = "Delete";
                ShowLoader();
                $.ajax({
                    type: 'GET',
                    url: "/Account/PaymentVoucher/Frm_Voucher_Win_Gen_Pay_Item",
                    data:
                    {
                        ActionMethod: "Delete",
                        GridRowNo: Payment_Grid_1_RowNumber
                    },
                    cache: false,
                    success: function (data)
                    {
                        HideLoader();
                        if (data.result == false)
                        {
                            DevExpress.ui.dialog.alert(data.message, "Error..");
                        }
                        else if (data.result == true)
                        {
                            ShowLoader();
                            $.ajax({
                                type: 'POST',
                                url: "/Account/PaymentVoucher/FillGrid1",
                                data:
                                {
                                    TempActionMethod: "_Delete",
                                    GLookUp_PartyList: $("#GLookUp_PartyList1_Tag").dxDropDownBox("option", "value") == null ? null : $("#GLookUp_PartyList1_Tag").dxDropDownBox("option", "value"),
                                    Payment_Credit_Amt: $("#Txt_CreditAmt").dxNumberBox("instance").option("value") //Redmine Bug #134863 fix
                                },
                                cache: false,
                                success: function (data)
                                {
                                    if (data.result == "true" || data.result == true)
                                    {
                                        $("#Txt_DiffAmt").dxNumberBox("instance").option("value", data.Txt_DiffAmt);
                                        $("#iParty_Req_Gen_Pay").val(data.iParty_Req);
                                        $("#Txt_SubTotal").dxNumberBox("instance").option("value", data.Txt_SubTotal);
                                        $("#Txt_TDS_Amt").dxNumberBox("instance").option("value", data.Txt_TDS_Amt);
                                        $("#Txt_BankAmt").dxNumberBox("instance").option("value", data.Txt_BankAmt);
                                        $("#Txt_CreditAmt").dxNumberBox("instance").option("value", data.Txt_CreditAmt);
                                        $("#Txt_CashAmt").dxNumberBox("instance").option("value", data.Txt_CashAmt);
                                        $("#Txt_AdvAmt").dxNumberBox("instance").option("value", data.Txt_AdvAmt);
                                        $("#Txt_LB_Amt").dxNumberBox("instance").option("value", data.Txt_LB_Amt);
                                        Frm_Voucher_Win_Gen_Pay_Grid_1.SetFocusedRowIndex(-1);
                                        RefreshGridView("Frm_Voucher_Win_Gen_Pay_Grid_1");
                                        PerformCallbackGridView("Frm_Voucher_Win_Gen_Pay_Grid_3");
                                        PerformCallbackGridView("Frm_Voucher_Win_Gen_Pay_Grid_4");
                                    }
                                    HideLoader();
                                }
                            });
                        }
                    }
                });
            }
            else
            {
                DevExpress.ui.dialog.alert('Please Select One Row', "Information!!");
            }
        }
    }
    function OnFrm_Voucher_Win_Gen_Pay_ViewClick()
    {
        if ("@IsVisible" == "False")
        {
            Payment_partyID_item = $("#GLookUp_PartyList1_Tag").dxDropDownBox("instance").option("value") == null ? "" : $("#GLookUp_PartyList1_Tag").dxDropDownBox("instance").option("value");
            if (Frm_Voucher_Win_Gen_Pay_Grid_1.GetFocusedRowIndex() > -1)
            {
                Payment_ItemGrid_Data = Frm_Voucher_Win_Gen_Pay_Grid_1.cpPagedata;
                Payment_Grid_1_RowNumber = Payment_ItemGrid_Data[Frm_Voucher_Win_Gen_Pay_Grid_1.GetFocusedRowIndex() - Frm_Voucher_Win_Gen_Pay_Grid_1.GetTopVisibleIndex()][0];
                Payment_Selected_ItemID = Payment_ItemGrid_Data[Frm_Voucher_Win_Gen_Pay_Grid_1.GetFocusedRowIndex() - Frm_Voucher_Win_Gen_Pay_Grid_1.GetTopVisibleIndex()][1];
                Actionmethod_pay_item = "View";
                @*var Url = "@Url.Action("Frm_Voucher_Win_Gen_Pay_Item", "PaymentVoucher", new { @area = "Account" })?ActionMethod=View&iPartyID=" + Payment_partyID_item + "&GridRowNo=" + Payment_Grid_1_RowNumber;*@
                ShowLoader();
                $.ajax({
                    type: 'GET',
                    url: "/Account/PaymentVoucher/Frm_Voucher_Win_Gen_Pay_Item",
                    data:
                    {
                        ActionMethod: "View",
                        iPartyID: Payment_partyID_item,
                        GridRowNo: Payment_Grid_1_RowNumber
                    },
                    cache: false,
                    success: function (data)
                    {
                        OpenPopup("Frm_Voucher_Item_popup", "View ~ Item Detail", null, "auto", 850, true, data);
                    }
                });
            }
            else
            {
                DevExpress.ui.dialog.alert('Please Select One Row', "Information!!");
            }
        }
    }
    function Frm_Voucher_Win_Gen_Pay_Grid_1_ContextMenuFunction(s, e)
    {
        if (e.item.name == 'New')
        {
            OnFrm_Voucher_Item_popup_NewClick();
        }
        else if (e.item.name == 'Edit') {
            OnFrm_Voucher_Win_Gen_Pay_EditClick();
        }
        else if (e.item.name == 'Delete') {
            OnFrm_Voucher_Win_Gen_Pay_DeleteClick();
        }
        else if (e.item.name == 'View') {
            OnFrm_Voucher_Win_Gen_Pay_ViewClick();
        }
        else if (e.item.name == 'Refresh') {
            Frm_Voucher_Win_Gen_Pay_Grid_1.Refresh();
        }
    }
    function Frm_Voucher_Win_Gen_Pay_Item_Content_OnSuccess(data)
    {
        HideLoader();    
        if (data.jsonParam.result == false)
        {
            var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
            alertclick.done(function (alertResult)
            {
                if (alertResult)
                {
                    if (data.jsonParam.focusid)
                    {
                        var id = "#" + data.jsonParam.focusid;
                        setTimeout(function ()
                        {
                            $(id).find('input').focus();
                        }, Timeout100);
                    }
                }
            });
        }
        else
        {
            if (data.jsonParam.popup_form_path == "" || data.jsonParam.popup_form_path == null)
            {
                Fillgrid1_PaymentVoucher();
            }
            else
            {
                var width = 1000;
                if (data.jsonParam.popup_form_name == "Frm_Reference_Type")
                {
                    width = 340;                    
                }
                else if (data.jsonParam.popup_form_name == "Frm_Asset_Window")
                {
                    width = 870;                    
                }
                else if (data.jsonParam.popup_form_name == "Frm_GoldSilver_Window")
                {
                    width = 700;
                }
                else if (data.jsonParam.popup_form_name == "Frm_Telephone_Select")
                {
                    width = 855;
                }
                else if (data.jsonParam.popup_form_name == "Frm_Live_Stock_Window")
                {
                    width = 870;
                }
                else if (data.jsonParam.popup_form_name == "Frm_Vehicles_Window")
                {
                    width = 870;
                }
                OpenPopup("Frm_Voucher_Item_Content_popup", data.jsonParam.popup_title, data.jsonParam.popup_form_path + "?" + data.jsonParam.popup_querystring, "auto", width, false, null);
            }
        }
    }    
    function Fillgrid1_PaymentVoucher()
    {
        ShowLoader_Ready();
        $.ajax({
            type: 'POST',
            url: "/Account/PaymentVoucher/FillGrid1",
            data: $("#ID_Frm_Voucher_Win_Gen_Pay_Item_Window").serialize(),
            cache: false,
            success: async function (data)
            {
                if (data.result == "true" || data.result == true)
                {
                    $("#Txt_DiffAmt").dxNumberBox("instance").option("value", data.Txt_DiffAmt);
                    $("#iParty_Req_Gen_Pay").val(data.iParty_Req);
                    $("#Txt_SubTotal").dxNumberBox("instance").option("value", data.Txt_SubTotal);
                    $("#Txt_TDS_Amt").dxNumberBox("instance").option("value", data.Txt_TDS_Amt);
                    $("#Txt_BankAmt").dxNumberBox("instance").option("value", data.Txt_BankAmt);
                    $("#Txt_CreditAmt").dxNumberBox("instance").option("value", data.Txt_CreditAmt);
                    $("#Txt_CashAmt").dxNumberBox("instance").option("value", data.Txt_CashAmt);
                    $("#Txt_AdvAmt").dxNumberBox("instance").option("value", data.Txt_AdvAmt);
                    $("#Txt_LB_Amt").dxNumberBox("instance").option("value", data.Txt_LB_Amt);
                    //Frm_Voucher_Win_Gen_Pay_Grid_1.SetFocusedRowIndex(-1);
                    RefreshGridView("Frm_Voucher_Win_Gen_Pay_Grid_1");
                    PerformCallbackGridView("Frm_Voucher_Win_Gen_Pay_Grid_3");
                    PerformCallbackGridView("Frm_Voucher_Win_Gen_Pay_Grid_4");
                    Focus_FirstEditable_Field("ID_Frm_Voucher_Win_Gen_Pay", "@Model.TempActionMethod");
                    if (data.volume_result == "BankGrid")
                    {
                        OnFrm_Voucher_Win_Gen_Pay_Grid_2_NewClick(data.volume_amount);
                    }
                    else if (data.volume_result == "LBGrid") {
                        OnFrm_Voucher_Win_Gen_Pay_Grid_4_EditClick(data.volume_amount, data.volume_sr);
                    }
                }          
                ShowLoader();
                var partyIdItem = $("#GLookUp_PartyList").dxDropDownBox("instance").option("value");
                if (partyIdItem != null && partyIdItem.length > 0)
                {
                    if (Actionmethod_pay_item == "New")
                    {
                        var PartyData = GetDataSourceItems("GLookUp_PartyList1_Tag", "dxDropDownBox");                      
                        if (PartyData.some(data => data.C_ID === partyIdItem))
                        {
                            $("#GLookUp_PartyList1_Tag").dxDropDownBox("instance").option("value", partyIdItem);
                        }
                        else
                        {
                            await LookUp_GetPartyList_Payment(false, partyIdItem);
                        }
                    }
                    else
                    {
                        $("#GLookUp_PartyList1_Tag").dxDropDownBox("instance").option("value", partyIdItem);
                    }
                }           
                HideLoader();
                if ($("#Frm_Voucher_Item_Content_popup").length > 0 && $("#Frm_Voucher_Item_Content_popup").dxPopup("instance").option("title") != "PopUpDidnotOpen")
                {
                    $("#Frm_Voucher_Item_Content_popup").dxPopup("hide");
                }
                $("#Frm_Voucher_Item_popup").dxPopup("hide");
                HideLoader_Ready();
            }
        });
    } // Redmine Bug #134769 fixed
</script>
<script>
    function Calculation_Check(e)
    {
        var value = $("#Txt_DiffAmt").dxNumberBox("instance").option("value");
        if ("@Model.TempActionMethod" != "_Delete") {
            if (value != 0) {
                $("#frm_win_gen_Save").dxButton("instance").option("disabled", true);
            }
            else {
                $("#frm_win_gen_Save").dxButton("instance").option("disabled", false);
            }
        }
        $("#Txt_DiffAmt").toggleClass('negative', value != 0); 
        $("#Txt_DiffAmt").toggleClass('positive', value == 0); 
    }

</script>


