@using DevExtreme.AspNet.Mvc;
@model ConnectOneMVC.Areas.Account.Models.Param_paymentVoucherDetailsViewModel
@{
    bool IsVisible = (Model != null && Model.TempActionMethod == "_Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.TempActionMethod == "_View" || Model.TempActionMethod == "_Delete") ? true : false;
}
<style>
    .negative .dx-texteditor-input {
        background: lightsalmon;
    }

    .positive .dx-texteditor-input {
        background: aliceblue;
    }
    </style>
<div id="Frm_Voucher_Win_Gen_Pay_Grid_1_PartialView">
    <div class="row">
        <div class="col-md-12">
            @Html.Action("Frm_Voucher_Win_Gen_Pay_Grid_1", "PaymentVoucher")
        </div>
    </div>
</div>
<div class="row">
    <div class="form-field">
        <div class="container-fluid">
            <div class="col-sm-12 col-md-5 col-lg-5 btnsDiv">
                @(Html.DevExtreme().Button().ID("Frm_Voucher_Win_Gen_Pay_ModelNew").Text("New").Icon("add").OnClick(@<text> function () { OnFrm_Voucher_Item_popup_NewClick(); } </text>).Disabled(IsDisabled) )
                @(Html.DevExtreme().Button().ID("Frm_Voucher_Win_Gen_Pay_ModelEdit").Text("Edit").Icon("edit").OnClick(@<text> function () { OnFrm_Voucher_Win_Gen_Pay_EditClick(); } </text>).Disabled(IsDisabled)  )
                @(Html.DevExtreme().Button().ID("Frm_Voucher_Win_Gen_Pay_ModelDelete").Text("Delete").Icon("trash").OnClick(@<text> function () { OnFrm_Voucher_Win_Gen_Pay_DeleteClick(); } </text>).Disabled(IsDisabled)  )
                @(Html.DevExtreme().Button().ID("Frm_Voucher_Win_Gen_Pay_ModelView").Text("View").Icon("doc").OnClick(@<text> function () { OnFrm_Voucher_Win_Gen_Pay_ViewClick(); } </text>).Disabled(IsVisible) )
            </div><!--[Item Grid Buttons]-->
            <div class="col-sm-12 col-md-7 col-lg-7">
                <div class="row">
                    <div class="col-sm-3 col-md-3 col-lg-3">
                        
                                @(Html.DevExtreme().CheckBoxFor(x => x.CheckEdit2).ID("CheckEdit2").Value(false).OnValueChanged("ShowRemark_valueChange").Text("Show Remarks") )
                           
                        </div>
                   
                    <div class="col-sm-4 col-md-4 col-lg-4 prm ">
                        <div class="row">
                            <div class="col-sm-12 col-md-3 col-lg-3">
                                <label class="control-label pll blu-txt" for="FormData_Txt_DiffAmt" style="font-size:11px;padding-right:1px">Diff.:</label>
                            </div>
                            <div class="col-sm-12 col-md-9 col-lg-9 text-right" id="payment_txtdiff_div">
                                @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Txt_DiffAmt").Name("Txt_DiffAmt").Value((double)Model.Txt_DiffAmt).ReadOnly(true).OnValueChanged("Calculation_Check").Format("#0.00").InputAttr(new { @style = "text-align:right;" }).FocusStateEnabled(false) )
                            </div>
                        </div>
                    </div><!--[Diff]-->
                    <div class="col-sm-5 col-md-5 col-lg-5">
                        <div class="row">
                            <div class="col-sm-12 col-md-6 col-lg-6">
                                <label class="control-label pll blu-txt" for="FormData_Txt_SubTotal" style="font-size:11px;">Total Amount:</label>
                            </div>
                            <div class="col-sm-12 col-md-6 col-lg-6 text-right">
                                @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Txt_SubTotal").Name("Txt_SubTotal").Value((double)Model.Txt_SubTotal).ReadOnly(true).Format("#0.00").InputAttr(new { @style = "text-align:right;" }).FocusStateEnabled(false) )
                            </div>
                        </div>
                    </div><!--[Total]-->
                </div>
            </div>
        </div>
    </div>
</div>

