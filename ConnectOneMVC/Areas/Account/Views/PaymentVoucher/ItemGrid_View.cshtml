    var Payment_vDate_item = null;
    var Payment_partyID_item = null;
    var Grid1_Item_TotalCount;
    var Actionmethod_pay_item;
    var Payment_ItemGrid_Data;
    function Frm_Voucher_Win_Gen_Pay_Grid_1_DblClick(s, e)
    {
        OnFrm_Voucher_Win_Gen_Pay_EditClick();
    }
