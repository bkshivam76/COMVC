@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("Frm_Gen_Pay_GLookUp_PartyList1_datagrid")   
    .Columns(columns =>
    {
        columns.Add().DataField("C_ID").Visible(false);
        columns.Add().DataField("C_NAME").Caption("Name");
        columns.Add().DataField("C_CITY").Caption("City");
        columns.Add().DataField("C_PAN_NO").Caption("PAN No").Visible(false);
        columns.Add().DataField("C_AADHAR_NO").Caption("AADHAR No").Visible(false);
        columns.Add().DataField("C_CATEGORY").Caption("CATEGORY").Visible(false);
    })  
    .Selection(s => s.Mode(SelectionMode.Single))
      .OnSelectionChanged("function(selectedItems){var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}")

)
