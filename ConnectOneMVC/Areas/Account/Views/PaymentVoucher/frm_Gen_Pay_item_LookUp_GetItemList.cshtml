@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("Frm_Gen_Pay_Item_GLookUp_ItemList_datagrid")    
    .Columns(columns =>
    {
        columns.Add().DataField("ITEM_NAME").Caption("Name");
        columns.Add().DataField("LED_NAME").Caption("Head").AllowSearch(false);
        columns.Add().DataField("ITEM_PARTY_REQ").Caption("Party").AllowSearch(false);
        columns.Add().DataField("CON_LED_TYPE").Visible(false);
        columns.Add().DataField("ITEM_CON_LED_ID").Visible(false);
        columns.Add().DataField("ITEM_CON_MAX_VALUE").Visible(false);
        columns.Add().DataField("ITEM_CON_MIN_VALUE").Visible(false);
        columns.Add().DataField("ITEM_LED_ID").Visible(false);
        columns.Add().DataField("ITEM_PROFILE").Visible(false);
        columns.Add().DataField("ITEM_TDS_CODE").Visible(false);
        columns.Add().DataField("ITEM_TRANS_TYPE").Visible(false);
        columns.Add().DataField("ITEM_VOUCHER_TYPE").Visible(false);
        columns.Add().DataField("LED_TYPE").Visible(false);
        columns.Add().DataField("TDS_RATE").Visible(false);
    })
    .Selection(s => s.Mode(SelectionMode.Single))
     .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}")
)


