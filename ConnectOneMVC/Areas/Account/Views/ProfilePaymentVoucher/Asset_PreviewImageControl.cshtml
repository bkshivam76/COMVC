@{ 
    var Payment_Asset_Image = ViewBag.Payment_Asset_Image == null ? null : (byte[])ViewBag.Payment_Asset_Image;
}
@Html.DevExpress().BinaryImage(
    settings =>
    {
        settings.Name = "Asset_binaryImage_show";
        settings.ClientEnabled = true;
        settings.ClientVisible = true;
        settings.Properties.ClientInstanceName = "Asset_binaryImage_show";
        settings.Properties.EnableClientSideAPI = true;
        settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
        settings.Height = 145;//System.Web.UI.WebControls.Unit.Percentage(40);       
        settings.ContentBytes = Payment_Asset_Image;
        settings.Properties.ImageSizeMode = ImageSizeMode.FitProportional;
        settings.ControlStyle.CssClass = "DevexpressComponents";

    }).GetHtml()