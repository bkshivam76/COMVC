
@Html.DevExpress().UploadControl(
    settings =>
    {
        settings.Name = "Asset_FileUpload";
        settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
        settings.Height = System.Web.UI.WebControls.Unit.Percentage(100);
        settings.ClientEnabled = true;
        settings.ClientVisible = true;
        settings.ClientSideEvents.FileUploadComplete = "Payment_asset_FileUploaded";
        settings.NullText = "Select Asset Image File...";
        settings.ValidationSettings.MaxFileSize = 4194304;
        settings.ValidationSettings.AllowedFileExtensions = new string[] { ".jpg", ".jpeg", ".png" };
        settings.UploadMode = UploadControlUploadMode.Standard;
        settings.AutoStartUpload = true;
        settings.ControlStyle.CssClass = "DevexpressComponents";
    }).GetHtml()