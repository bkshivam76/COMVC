<script>
    var LocList_Asset_DG;
    var dataSource_AssetLocation_PrfPay=null;
    function Init_DD_Asset_Window()
    {
        var $LocList_Asset_DG = $("#Frm_Window_GLookUp_LocList_datagrid");
        if ($LocList_Asset_DG.length)
        {
            LocList_Asset_DG = $LocList_Asset_DG.dxDataGrid("instance");
        }
    }
    async function LookUp_GetLocList_Asset(FirstCall = false)
    {
        if (FirstCall === false)
        {
            ShowLoader();
            var DDvalue = $("#LocList").dxDropDownBox("instance").option("value");
            $.ajax({
                type: 'GET',
                url: "/Account/ProfilePaymentVoucher/RefreshLocationList",
                cache: false,
                success: function (data)
                {
                    dataSource_AssetLocation_PrfPay = new DevExpress.data.DataSource({ // need to dispose it in in clearreference
                        store:
                        {
                            type: "array",
                            key: "AL_ID",
                            data: data
                        }
                    });
                    $("#LocList").dxDropDownBox("instance").option("dataSource", dataSource_AssetLocation_PrfPay);
                    LocList_Asset_DG.option("dataSource", dataSource_AssetLocation_PrfPay);
                    dataSource_AssetLocation_PrfPay.load().done((r) =>
                    {
                        $("#LocList").dxDropDownBox("reset");
                        if (data.some(data => data.AL_ID === DDvalue))
                        {
                            $("#LocList").dxDropDownBox("instance").option("value", DDvalue);
                        }
                        $("#LocList").dxDropDownBox("focus");
                        AssetLocation_Settings_PrfPay(FirstCall);
                        HideLoader();
                    })
                }
            });
        }
        else
        {
            AssetLocation_Settings_PrfPay(FirstCall);
        }
    }     
    async function AssetLocation_Settings_PrfPay(FirstCall)
    {
        var DGItem = GetDataSourceItems("LocList", "dxDropDownBox");
        var TotalCount = DGItem.length;   
        if (TotalCount == 1)
        {
            if (FirstCall === true)
            {
                await Frm_Asset_Window_LocList_OnValueChanged();
            }
            else
            {
                $("#LocList").dxDropDownBox("instance").option("value", DGItem[0].AL_ID);
            }          
            Control_SetReadOnly("LocList", "dxDropDownBox", true, "#696969");
        }
        else
        {
            Control_SetReadOnly("LocList", "dxDropDownBox", false);
        }
        if (TotalCount > 1)
        {
            $("#payment_OtherAsset_Location").addClass("text-red");
        }
        else
        {
            $("#payment_OtherAsset_Location").removeClass("text-red");
        }
    }
    async function Frm_Asset_Window_LocList_OnValueChanged(e)
    {
        var LocID;
        if (e)
        {
            LocID = e.value;
            if ((e.value == null || e.value.length == 0) && e.previousValue != null) {
                LocList_Asset_DG.clearSelection();
                return;
            }
        }
        else
        {
            LocID = $("#LocList").dxDropDownBox("instance").option("value");
        }
        await LocList_Asset_DG.selectRows(LocID);
    }
    function OnFrm_Asset_Window_popup_NewLocationClick()
    {
        if ("@ProfileCore__AddRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        $.ajax({
            type: 'GET',
            url: "/Account/ProfilePaymentVoucher/AddLocations_Check",
            data: { ActionMethod: "New"},
            cache: false,
            success: function (data)
            {
                if (data.result == true)
                {
                    ShowLoader();
                    OpenPopup("PaymentAddLocation", "New ~ Location", "@Url.Action("Frm_Location_Window", "ProfilePaymentVoucher", new { @area = "Account" })?ActionMethod=New&PopupID=PaymentAddLocation&DropdownRefreshFunction=LookUp_GetLocList_Asset", "auto", 400, false, null);
                }
                else
                {
                    DevExpress.ui.dialog.alert(data.message, "Error").done(function (result) { $("#LocList").dxDropDownBox("focus") });
                }
            }
        });
    }
</script>
