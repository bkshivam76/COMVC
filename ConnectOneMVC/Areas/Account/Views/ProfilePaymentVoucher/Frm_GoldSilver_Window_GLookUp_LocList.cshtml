@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("Frm_Window_GLookUp_LocList_datagrid")
    .DataSource(new JS(@"component.option(""dataSource"")"))
    .Columns(columns =>
    {
        columns.Add().DataField("Location_Name").Caption("Name");
        columns.Add().DataField("AL_ID").Visible(false);
        columns.Add().DataField("Matched_Type");
        columns.Add().DataField("Matched_Name");
        columns.Add().DataField("Matched_Instt");
        columns.Add().DataField("Final_Amount").Format("#0.00").DataType(GridColumnDataType.Number);
    })     
   
    .Selection(s => s.Mode(SelectionMode.Single))
   .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}")
)