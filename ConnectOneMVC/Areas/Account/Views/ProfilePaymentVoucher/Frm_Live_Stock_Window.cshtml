    function Frm_Live_Stock_Window_AjaxSuccessForm(data)
    {
        HideLoader();
        if (data.jsonParam.result == false)
        {
            var alertclick = DevExpress.ui.dialog.alert( data.jsonParam.message, data.jsonParam.title);
            alertclick.done(function (alertResult)
            {
                if (alertResult)
                {
                    if (data.jsonParam.focusid)
                    {
                        var id = "#" + data.jsonParam.focusid;
                        setTimeout(function ()
                        {
                            $(id).find('input').focus();
                        }, Timeout100);
                    }
                }
            });
        }
        else if (data.jsonParam.result)
        {
            if ("@From_DNK"=="True") //calling from DNK
            {
                $("#LS_NAME_DNK_Itm").val($("#Txt_Name").dxTextBox('instance').option("value"));
                $("#LS_BIRTH_YEAR_DNK_Itm").val($("#Cmd_Year").dxSelectBox('instance').option("value"));
                $("#LS_INSURANCE_DNK_Itm").val($("#Rad_Insurance").dxRadioGroup('instance').option("value"));
                $("#LS_INSURANCE_ID_DNK_Itm").val($("#Look_InsList").dxSelectBox('instance').option("value"));
                $("#LS_INS_POLICY_NO_DNK_Itm").val($("#Txt_PolicyNo").dxTextBox('instance').option("value"));
                $("#LS_INS_AMT_DNK_Itm").val($("#Txt_InsAmt").dxNumberBox('instance').option("value"));
                if (isValidDate(data.Ins_Date))
                {
                    $("#LS_INS_DATE_DNK_Itm").val(data.Ins_Date);
                }
                $("#Txt_Rate_DNK_Itm").dxNumberBox("instance").option("value", $("#Txt_Amount_DNK_Itm").dxNumberBox("instance").option("value"));
                $("#Txt_Remarks_DNK_Itm").dxTextBox('instance').option("value", $("#Txt_Others").dxTextBox('instance').option("value"));
                $("#X_LOC_ID_DNK_Itm").val($("#Look_LocList").dxDropDownBox('instance').option("value"));
                Fill_Item_Grid_DonationInKindVoucher();
            }
            else if ("@From_JV"=="True") //calling from JV
            {
                $("#LS_NAME_JV_Itm").val($("#Txt_Name").dxTextBox('instance').option("value"));
                $("#LS_BIRTH_YEAR_JV_Itm").val($("#Cmd_Year").dxSelectBox('instance').option("value"));
                $("#LS_INSURANCE_JV_Itm").val($("#Rad_Insurance").dxRadioGroup('instance').option("value"));
                $("#LS_INSURANCE_ID_JV_Itm").val($("#Look_InsList").dxSelectBox('instance').option("value"));
                $("#LS_INS_POLICY_NO_JV_Itm").val($("#Txt_PolicyNo").dxTextBox('instance').option("value"));
                $("#LS_INS_AMT_JV_Itm").val($("#Txt_InsAmt").dxNumberBox('instance').option("value"));
                if (isValidDate(data.Ins_Date))
                {
                    $("#LS_INS_DATE_JV_Itm").val(data.Ins_Date);
                }

                $("#Txt_Remarks_JV_Itm").dxTextBox('instance').option("value", $("#Txt_Others").dxTextBox('instance').option("value"));
                $("#X_LOC_ID_JV_Itm").val($("#Look_LocList").dxDropDownBox('instance').option("value"));
                Fill_Item_Grid_JournalVoucher();
            }
            else      //Calling from Payments screen
            {
                $("#LS_NAME").val($("#Txt_Name").dxTextBox('instance').option("value"));
                $("#LS_BIRTH_YEAR").val($("#Cmd_Year").dxSelectBox('instance').option("value"));
                $("#LS_INSURANCE").val($("#Rad_Insurance").dxRadioGroup('instance').option("value"));
                $("#LS_INSURANCE_ID").val($("#Look_InsList").dxSelectBox('instance').option("value"));
                $("#LS_INS_POLICY_NO").val($("#Txt_PolicyNo").dxTextBox('instance').option("value"));
                $("#LS_INS_AMT").val($("#Txt_InsAmt").dxNumberBox('instance').option("value"));
                if (data.Ins_Date.length > 0)
                {
                    $("#LS_INS_DATE").val(data.Ins_Date);
                }
                $("#Txt_Rate").dxNumberBox("instance").option("value", $("#Txt_Amt").dxNumberBox("instance").option("value"));
                $("#Txt_Remarks").dxTextBox('instance').option("value", $("#Txt_Others").dxTextBox('instance').option("value"));
                $("#X_LOC_ID").val($("#Look_LocList").dxDropDownBox('instance').option("value"));
                Fillgrid1_PaymentVoucher();
            }
        }
    }
</script>
    @* Document.ready and save success *@
    <script>
        var LocList_LS_DG;
        var dataSource_LSLocation_PrfPay = null;
        async function LookUp_GetLocList_LS(FirstCall = false)
        {
            var $LocList_LS_DG = $("#Frm_Window_GLookUp_LocList_datagrid");
            if ($LocList_LS_DG.length) {
                LocList_LS_DG = $LocList_LS_DG.dxDataGrid("instance");
                if (FirstCall === false) {
                    ShowLoader();
                    var DDvalue = $("#Look_LocList").dxDropDownBox("instance").option("value");
                    $.ajax({
                        type: 'GET',
                        url: "/Account/ProfilePaymentVoucher/RefreshLocationList",
                        cache: false,
                        success: function (data) {
                            dataSource_LSLocation_PrfPay = new DevExpress.data.DataSource({ // need to dispose it in in clearreference
                                store:
                                {
                                    type: "array",
                                    key: "AL_ID",
                                    data: data
                                }
                            });
                            $("#Look_LocList").dxDropDownBox("instance").option("dataSource", dataSource_LSLocation_PrfPay);
                            LocList_LS_DG.option("dataSource", dataSource_LSLocation_PrfPay);
                            dataSource_LSLocation_PrfPay.load().done((r) => {
                                $("#Look_LocList").dxDropDownBox("reset");
                                if (data.some(data => data.AL_ID === DDvalue)) {
                                    $("#Look_LocList").dxDropDownBox("instance").option("value", DDvalue);
                                }
                                $("#Look_LocList").dxDropDownBox("focus");
                                LSLocation_Settings_PrfPay(FirstCall);
                                HideLoader();
                            })
                        }
                    });
                }
                else {
                    LSLocation_Settings_PrfPay(FirstCall);
                }
            }
        }
        async function LSLocation_Settings_PrfPay(FirstCall)
        {
            var DGItem = GetDataSourceItems("Look_LocList", "dxDropDownBox");
            var TotalCount = DGItem.length;
            if (TotalCount == 1)
            {
                if (FirstCall === true)
                {
                    await OnChangeFrm_Live_Stock_Window_Look_LocList();
                }
                else
                {
                    $("#Look_LocList").dxDropDownBox("instance").option("value", DGItem[0].AL_ID);
                }
                Control_SetReadOnly("Look_LocList", "dxDropDownBox", true, "#696969");
            }
            else
            {
                Control_SetReadOnly("Look_LocList", "dxDropDownBox", false);
            }
            if (TotalCount > 1)
            {
                $("#livestocklocationLabel").addClass("text-red");
            }
            else
            {
                $("#livestocklocationLabel").removeClass("text-red");
            }
        }       
        async function OnChangeFrm_Live_Stock_Window_Look_LocList(e)
        {
            var LocID;
            if (e)
            {
                LocID = e.value;
                if ((e.value == null || e.value.length == 0) && e.previousValue != null)
                {
                    LocList_LS_DG.clearSelection();
                    return;
                }
            }
            else {
                LocID = $("#Look_LocList").dxDropDownBox("instance").option("value");
            }
            await LocList_LS_DG.selectRows(LocID);
        }
        function LivestockAddLocationClick(e)
        {
            if ("@ProfileCore_AddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
                return;
            }
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Account/ProfilePaymentVoucher/AddLocations_Check",
                data: { ActionMethod: "New" },
                cache: false,
                success: function (data)
                {
                    HideLoader();
                    if (data.result)
                    {
                        ShowLoader();
                        $.ajax({
                            type: 'GET',
                            url: "/Account/ProfilePaymentVoucher/Frm_Location_Window",
                            data: {
                                ActionMethod: "New",
                                PopupID: "PaymentAddLocation",
                                DropdownRefreshFunction: "LookUp_GetLocList_LS"
                            },
                            cache: false,
                            success: function (data)
                            {
                                ShowLoader();
                                OpenPopup("PaymentAddLocation", "New ~ Location", null, "auto", 400, true, data);
                            }
                        });
                    }
                    else
                    {
                        DevExpress.ui.dialog.alert(data.message, "Error").done(function (result) { $("#Look_LocList").dxDropDownBox("focus") });
                    }
                }
            });
        }
    </script>
