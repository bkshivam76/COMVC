@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("Frm_Location_Map_Window_GLookUp_ProList_datagrid")

    .Columns(columns =>
    {
        columns.Add().DataField("Institute").Caption("Institute");
        columns.Add().DataField("LB_ID").Visible(false);
        columns.Add().DataField("LED_ID").Visible(false);
        columns.Add().DataField("CURR_VALUE").Visible(false);
        columns.Add().DataField("REC_EDIT_ON").Visible(false);
        columns.Add().DataField("TYPE");
        columns.Add().DataField("PROP_NAME").Caption("PROP_NAME");
        columns.Add().DataField("CATEGORY");
        columns.Add().DataField("OWNERSHIP");
        columns.Add().DataField("USE_OF_PROPERTY").Caption("USE OF PROPERTY");
    })

    .Selection(s => s.Mode(SelectionMode.Single))
    .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}")

)