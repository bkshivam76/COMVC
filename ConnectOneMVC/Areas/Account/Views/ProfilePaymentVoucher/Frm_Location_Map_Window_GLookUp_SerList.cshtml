
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("Frm_Location_Map_Window_GLookUp_SerList_datagrid")
    .Columns(columns =>
    {
        columns.Add().DataField("SP_ID").Visible(false);
        columns.Add().DataField("Institute").Caption("Institute");
        columns.Add().DataField("Centre_No").Caption("Centre No.");
        columns.Add().DataField("UID");
        columns.Add().DataField("No").Caption("No.");
        columns.Add().DataField("Service_Place_Name").Caption("Service Place Name");
        columns.Add().DataField("Place_Type");
        columns.Add().DataField("REC_EDIT_ON").Visible(false);
    })

    .Selection(s => s.Mode(SelectionMode.Single))
    .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}")

)