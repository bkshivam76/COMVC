@{
    bool FilterVisible = ViewBag.FilterVisible == null ? false : ViewBag.FilterVisible;
    bool SearchVisible = ViewBag.SearchVisible == null ? false : ViewBag.SearchVisible;
    bool ShowGroupedColumns = ViewBag.ShowGroupedColumns == null ? false : ViewBag.ShowGroupedColumns;
}

@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "PropertyListGrid_PaymentVoucher"; /*RedmineBug#134909*/
        settings.CallbackRouteValues = new
        {
            Controller = "ProfilePaymentVoucher",
            Action = "Frm_Property_Select_Grid"
        };
        settings.Settings.VerticalScrollBarMode = ScrollBarMode.Visible;
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Visible;
        settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.Control;
        settings.EnableRowsCache = false;
        settings.KeyboardSupport = true;
        //settings.AccessKey = "G";
        settings.Width = Unit.Percentage(100);
        settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.HideDataCells;



        settings.Settings.ShowGroupFooter = GridViewGroupFooterMode.Hidden;

        settings.SettingsBehavior.AutoExpandAllGroups = true;
        settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
        settings.Settings.UseFixedTableLayout = true;
        settings.SettingsBehavior.ColumnMoveMode = GridColumnMoveMode.AmongSiblings;
        settings.SettingsBehavior.AllowSort = true;
        settings.SettingsBehavior.EnableCustomizationWindow = true;

        settings.Settings.ShowHeaderFilterButton = true;

        settings.Settings.ShowFilterRow = false;
        settings.Settings.AutoFilterCondition = AutoFilterCondition.Contains;

        settings.SettingsSearchPanel.ShowApplyButton = true;
        settings.SettingsPager.Mode = GridViewPagerMode.ShowAllRecords;
        settings.SettingsSearchPanel.ShowClearButton = true;

        //settings.SettingsBehavior.AllowFoscusedRow = true;
        settings.ClientSideEvents.FocusedRowChanged = "OnPropertyListGridFocusedRowChanged";
        settings.ClientSideEvents.Init = "OnPropertyListGridInit";

        settings.Settings.ShowHeaderFilterBlankItems = false;
        settings.SettingsContextMenu.Enabled = false;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;
        settings.SettingsPager.Mode = GridViewPagerMode.ShowAllRecords;        

        settings.CustomDataActionRouteValues = new { Controller = "ProfilePaymentVoucher", Action = "PropertyListCustomDataAction" };
        // DXCOMMENT: Specify the grid's key field name and define grid columns in accordance with data model fields

        //------------------------------------------------//------------------------------------------------//------------------------------------------------//------------------------------------------------
        settings.KeyFieldName = "REC_ID";

        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "REC_ID",
            Caption = "ID",
            Visible = false
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "REC_EDIT_ON",
            Caption = "Rec_Edit_On",
            Visible = false
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Final_Amount",
            Caption = "Final Amount",
            Visible=false
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Name",
            Caption = "Name",
            Width= System.Web.UI.WebControls.Unit.Percentage(15)
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Address",
            Caption = "Address",
            Width = System.Web.UI.WebControls.Unit.Percentage(40)

        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Type",
            Caption = "Type",
            Width = System.Web.UI.WebControls.Unit.Percentage(15)

        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Category",
            Caption = "Category",
            Width = System.Web.UI.WebControls.Unit.Percentage(15)
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "Use",
            Caption = "Use",
            Width = System.Web.UI.WebControls.Unit.Percentage(15)
        });



        // show filter control
        settings.Settings.ShowFilterBar = GridViewStatusBarMode.Hidden;
        settings.SettingsFilterControl.ViewMode = true ? FilterControlViewMode.VisualAndText : FilterControlViewMode.Visual;
        settings.SettingsFilterControl.AllowHierarchicalColumns = true;// AllowHierarchicalColumns;
        settings.SettingsFilterControl.ShowAllDataSourceColumns = true;//FilterBuilderDemoHelper.Options.ShowAllDataSourceColumns;
        settings.SettingsFilterControl.MaxHierarchyDepth = 1;

        settings.Settings.ShowGroupedColumns = ShowGroupedColumns;
        MyExtensions.GridViewHelper.CustomGridView(settings);
    }).Bind(Model).GetHtml()
