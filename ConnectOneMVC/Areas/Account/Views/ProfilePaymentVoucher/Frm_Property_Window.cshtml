    <script>
        function Cmd_PCategory_SelectedIndexChanged(e,FirstCall=false)
        {
            var value;
            if (e)
            {
                value = e.value;
            }
            else
            {
                value = $("#Cmd_PCategory").dxSelectBox("option", "value");
            }
            if (value)
            {
                var tabpanel = $("#PaymentLBTab").dxTabPanel("instance");
                if (value.includes("PURCHASED") || value.includes("GIFTED")) {
                    tabpanel.option("items[0].visible", false);
                    tabpanel.option("items[1].visible", true);
                    tabpanel.option("selectedIndex", 2); //Bug #134771 fix
                }
                else if (value.includes("LEASED")) {
                    tabpanel.option("items[0].visible", true);
                    tabpanel.option("items[1].visible", true);
                    tabpanel.option("selectedIndex", 2); //Bug #134771 fix
                    tabpanel.option("items[0].title", value.toProperCase());
                    $("#Txt_Dep_Amt").dxNumberBox("instance").focus();
                }
                else {
                    tabpanel.option("selectedIndex", 2);
                }
                if (FirstCall == false)
                {
                    if (value.includes("PURCHASED") || value.includes("GIFTED"))
                    {
                        $("#Cmd_Ownership").dxSelectBox({ value: "INSTITUTION" });
                    }
                    else
                    {
                        $("#Cmd_Ownership").dxSelectBox({ value: "THIRD PARTY" });
                    }
                }
                Cmd_PType_SelectedIndexChanged();
            }
        }
        function Cmd_PType_SelectedIndexChanged(e)
        {
            var Cmd_PType = $("#Cmd_PType").dxSelectBox("instance");
            var Cmd_PCategory = $("#Cmd_PCategory").dxSelectBox("instance");
            if (Cmd_PType.option("value") == "LAND")
            {
                $("#Txt_Con_Area").dxNumberBox({ readOnly: true });
                $("#Cmd_Con_Year").dxSelectBox({ readOnly: true });
                $("#Cmd_RccType").dxSelectBox({ readOnly: true });
                $("#Txt_Con_Area").dxNumberBox({ focusStateEnabled: false });
                $("#Cmd_Con_Year").dxSelectBox({ focusStateEnabled: false });
                $("#Cmd_RccType").dxSelectBox({ focusStateEnabled: false });
                $("#Txt_Con_Area").dxNumberBox({ value: null });
                $("#Cmd_Con_Year").dxSelectBox({ value: "" });
                $("#Cmd_RccType").dxSelectBox({ value: "NO" });
            }
            else
            {
                $("#Txt_Con_Area").dxNumberBox({ readOnly: false });
                $("#Cmd_Con_Year").dxSelectBox({ readOnly: false });
                $("#Cmd_RccType").dxSelectBox({ readOnly: false });
                $("#Txt_Con_Area").dxNumberBox({ focusStateEnabled: true });
                $("#Cmd_Con_Year").dxSelectBox({ focusStateEnabled: true });
                $("#Cmd_RccType").dxSelectBox({ focusStateEnabled: true });
                $("#Txt_Con_Area").dxNumberBox({ value: null });
                $("#Cmd_Con_Year").dxSelectBox({ value: "" });
                $("#Cmd_RccType").dxSelectBox({ value: "" });
            }
            if (Cmd_PCategory.option("value"))
            {
                if ((Cmd_PCategory.option("value").includes("PURCHASED") || Cmd_PCategory.option("value").includes("GIFTED") || Cmd_PCategory.option("value").includes("LEASED")) && Cmd_PType.option("value") != "LAND")
                {
                    $("#payment_LB_constructedRoof").addClass("text-red");
                }
                else
                {
                    $("#payment_LB_constructedRoof").removeClass("text-red");
                }
            }
            if (Cmd_PType.option("value") == "LAND")
            {
                $("#payment_LB_plotarea").addClass("text-red");
                $("#payment_LB_constructedRoof").removeClass("text-red");
                $("#payment_LB_constructedArea").removeClass("text-red");
                $("#payment_LB_constructionYear").removeClass("text-red");
            }
            else if (Cmd_PType.option("value") == "BUILDING")
            {
                $("#payment_LB_plotarea").addClass("text-red");
                $("#payment_LB_constructedRoof").addClass("text-red");
                $("#payment_LB_constructedArea").addClass("text-red");
                $("#payment_LB_constructionYear").addClass("text-red");
            }
            else
            {
                $("#payment_LB_plotarea").removeClass("text-red");
                $("#payment_LB_constructedRoof").addClass("text-red");
                $("#payment_LB_constructedArea").addClass("text-red");
                $("#payment_LB_constructionYear").addClass("text-red");
            }
            LB_setvalidation();
        }
