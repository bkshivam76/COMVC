<div class="VoucherPropertyProfile_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    @model ConnectOneMVC.Areas.Account.Models.Frm_Property_Window_Model
    @{
        var isvisible = (Model.Tag == Common_Lib.Common.Navigation_Mode._View || Model.Tag == Common_Lib.Common.Navigation_Mode._Delete) ? true : false;
        bool From_DNK = (bool)ViewBag.FromDNK;
        bool From_JV = (bool)ViewBag.FromJV;
    }
    <style>
        #Frm_Property_Window_ParentDiv {
            padding-right: 0px !important;
            padding-left: 0px !important;
        }
        #But_LB_ManageOwner .dx-icon {
            width: 32px;
            height: 32px;
            /*line-height: normal;*/
            left: 5px;
            /*     top: -10px;
        bottom: 0;*/
        }

        #But_LB_ManageOwner .dx-button-content {
            height: inherit;
            padding-top: 10px;
            padding-bottom: 20px;
            padding-left: 15px;
        }
    </style>
    <div id="Frm_Property_Window_ParentDiv">

        @using (Ajax.BeginForm("Frm_Property_Window_BUT_SAVE_Click", "ProfilePaymentVoucher",
            new AjaxOptions
            {
                HttpMethod = "POST",
                UpdateTargetId = "Frm_Property_Window_popup",
                InsertionMode = InsertionMode.InsertAfter,
                OnBegin = "AjaxBeginFormPost",
                OnSuccess = "Frm_Property_Window_AjaxSuccessForm"
            },
            new
            {
                id = "ID_Frm_Property_Window_Form",
                @class = "edit_form form-horizontal"
            }))
        {
            @Html.HiddenFor(x => x.ActionMethodPropertyWindow)
            @Html.HiddenFor(x => x.Chk_OtherDoc)
            @Html.HiddenFor(x => x.Cmd_PUse_Text)
            @Html.HiddenFor(x => x.IsGift)
            @Html.HiddenFor(x => x.IsJV)
            @Html.HiddenFor(x => x.xID)
            using (Html.DevExtreme().ValidationGroup("paymentVoucher_LB"))
            {
                <div class="full-width-header-bg2">
                    <div class="row">
                        <div class="col-sm-8 pll">
                            <h3 class="popuphead"><i class="far fa-edit"></i>Land & Building</h3>
                        </div>
                        <div class="col-sm-4 prm">
                            <h5 class="mand-txt-align"><i class="fas fa-info-circle"></i> Red Fields are mandatory</h5>
                        </div>
                    </div>
                    @Html.ValidationSummary(true, "", new { @class = "text-red" })
                </div><!--[Header]-->
                <div class="row">
                    <div class="col-sm-4 col-md-4 col-lg-4">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <label class="control-label text-red" id="payment_LB_Category">Property Category:</label><br />
                                    @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("Cmd_PCategory").Name("Cmd_PCategory").Items(new[] { "PURCHASED", "PURCHASED AND CONSTRUCTED", "LEASED (Long Term)", "LEASED AND CONSTRUCTED (Long Term)", "GIFTED", "GIFTED AND CONSTRUCTED" }).OnValueChanged("Cmd_PCategory_SelectedIndexChanged").ReadOnly(isvisible).Placeholder("Select..").Value(Model.Cmd_PCategory) )
                                    @Html.ValidationMessageFor(model => model.Cmd_PCategory, "", new { @class = "text-red" })
                                </div>
                            </div>
                        </div>
                    </div><!--[Category]-->
                    <div class="col-sm-4 col-md-4 col-lg-4">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <label class="control-label text-red" id="payment_LB_Type">Property Type:</label><br />
                                    @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("Cmd_PType").Name("Cmd_PType").Items(new[] { "LAND", "BUILDING", "FLAT", "FLAT (in Multiple Floor)" }).OnValueChanged("Cmd_PType_SelectedIndexChanged").ReadOnly(isvisible).Placeholder("Select.."))
                                    @Html.ValidationMessageFor(model => model.Cmd_PType, "", new { @class = "text-red" })
                                </div>
                            </div>
                        </div>
                    </div><!--[Type]-->
                    <div class="col-sm-4 col-md-4 col-lg-4">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <label class="control-label text-red" id="payment_LB_Use">Use Of Property:</label><br />
                                    @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("Cmd_PUse").Name("Cmd_PUse").ReadOnly(isvisible).Placeholder("Select..").DataSource(Model.PuseListData).ValueExpr("Index").DisplayExpr("Value").OnValueChanged("Cmd_PUse_SelectedIndexChanged").ReadOnly(isvisible).Value(Model.Cmd_PUse) )
                                    @Html.ValidationMessageFor(model => model.Cmd_PUse, "", new { @class = "text-red" })
                                </div>
                            </div>
                        </div>
                    </div><!--[Use]-->
                </div><!--[Category/Type/Use]-->
                <div class="row">
                    <div class="col-sm-6 col-md-6 col-lg-6">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <label class="control-label text-red" id="payment_LB_Name">Property/Building Name:</label><br />
                                    @(Html.DevExtreme().TextBox().CustomTextBox(true).ID("Txt_PName").Name("Txt_PName").Value(Model.Txt_PName).MaxLength(100).ReadOnly(isvisible).Placeholder("Type Property/Building Name.. ") )
                                    @Html.ValidationMessageFor(model => model.Txt_PName, "", new { @class = "text-red" })
                                </div>
                            </div>
                        </div>
                    </div><!--[Name]-->
                    <div class="col-sm-6 col-md-6 col-lg-6">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <label class="control-label text-red" id="payment_LB_Address">Property/Building Address:</label><br />
                                    @(Html.DevExtreme().TextBox().CustomTextBox(true).ID("Txt_Add").Name("Txt_Add").Value(Model.Txt_Add).OnKeyDown("LoadPropertyBuildingAddress_Popup").ReadOnly(isvisible).ElementAttr("OnClick", "LoadPropertyBuildingAddress_Popup()").ShowClearButton(false))
                                    @Html.ValidationMessageFor(model => model.Txt_Add, "", new { @class = "text-red" })
                                </div>
                            </div>
                        </div>
                    </div><!--[Address]-->
                </div><!--[Name/Address]-->
                <div class="row">
                    <div class="col-sm-2 col-md-2 col-lg-2">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <label class="control-label text-red" id="payment_LB_ownership">Ownership:</label><br />

                                    @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("Cmd_Ownership").Name("Cmd_Ownership").ReadOnly(true).FocusStateEnabled(false).DataSource(new[] { "INSTITUTION", "THIRD PARTY" }).OnValueChanged("cmd_ownership_ValueChange").Value(Model.Cmd_Ownership).ReadOnly(true).ShowClearButton(false))
                                    @Html.ValidationMessageFor(model => model.Cmd_Ownership, "", new { @class = "text-red" })
                                </div>
                            </div>
                        </div>
                    </div><!--[Ownership]-->
                    <div class="col-sm-8 col-md-8 col-lg-8">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <div id="lb_ownershipDiv">
                                        <label class="control-label text-red" id="payment_LB_ownerName">Owner Name:</label><br />
                                        @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("Look_OwnList").Name("Look_OwnList").ValueExpr("ID").DisplayExpr("Name").DataSource(Model.OwnerListData,"ID").Value(Model.Look_OwnList)
                                          .ContentTemplate(@<text>@Html.Partial("Frm_Property_Window_GLookUp_OwnList")</text>).ReadOnly(true).OnValueChanged("Property_OwnerName_Change").Placeholder("Select.."))
                                        @(Html.DevExtreme().TextBox().ID("TextEdit1").CustomTextBox().Name("TextEdit1").Value(Model.TextEdit1).ReadOnly(true).Visible(false))
                                        @Html.ValidationMessageFor(model => model.Look_OwnList, "", new { @class = "text-red" })
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div><!--[Owner Name]-->
                    <div class="col-sm-2 col-md-2 col-lg-2">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <div id="lb_manageownerDiv">
                                        @(Html.DevExtreme().Button().ID("But_LB_ManageOwner").Text("Manage Owner").Width("100%").Height("inherit").Disabled(true).OnClick("Property_ManageParty_Click").Icon(Url.Content("../../../../Icons/manage user.png")))
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div><!--[Manage Owner]-->
                </div><!--[Ownership]-->
                <div class="row">
                    <div class="col-sm-2 col-md-2 col-lg-2">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <label class="control-label text-red" id="payment_LB_survey">Survey No.:</label><br />
                                    @(Html.DevExtreme().TextBox().CustomTextBox(true).ID("Txt_SNo").Name("Txt_SNo").Value(Model.Txt_SNo).MaxLength(100).ReadOnly(isvisible).Placeholder("Type Survey No..") )
                                    @Html.ValidationMessageFor(model => model.Txt_SNo, "", new { @class = "text-red" })
                                </div>
                            </div>
                        </div>
                    </div><!--[Survey]-->
                    <div class="col-sm-2 col-md-2 col-lg-2">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <label class="control-label text-red" id="payment_LB_plotarea" style="white-space: nowrap;">Total Plot Area (Sq.Ft.):</label><br />
                                    @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Txt_Tot_Area").Name("Txt_Tot_Area").Value(Model.Txt_Tot_Area).Format("#0.00").ReadOnly(isvisible).Placeholder("Type Total Plot Area(Sq.Ft.).."))
                                    @Html.ValidationMessageFor(model => model.Txt_Tot_Area, "", new { @class = "text-red" })
                                </div>
                            </div>
                        </div>
                    </div><!--[Plot Area]-->
                    <div class="col-sm-3 col-md-3 col-lg-3">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <label class="control-label text-red" id="payment_LB_constructedArea">Constructed Area(Sq.Ft.):</label><br />
                                    @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Txt_Con_Area").Name("Txt_Con_Area").Value(Model.Txt_Con_Area).Format("#0.00").ReadOnly(isvisible).Placeholder("Type Constructed Area(Sq.Ft.)..") )
                                    @Html.ValidationMessageFor(model => model.Txt_Con_Area, "", new { @class = "text-red" })
                                </div>
                            </div>
                        </div>
                    </div><!--[Constructed Area]-->
                    <div class="col-sm-2 col-md-2 col-lg-2">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <label class="control-label text-red" id="payment_LB_constructionYear" style="white-space: nowrap;">Construction Year:</label><br />
                                    @(Html.DevExtreme().SelectBox().ID("Cmd_Con_Year").CustomSelectBox().Name("Cmd_Con_Year").Placeholder("Year..").DataSource(Model.Cmd_Con_Year_Bind).Value(Model.Cmd_Con_Year).ReadOnly(isvisible))
                                    @Html.ValidationMessageFor(model => model.Cmd_Con_Year, "")
                                </div>
                            </div>
                        </div>
                    </div><!--[Construction Year]-->
                    <div class="col-sm-3 col-md-3 col-lg-3">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <label class="control-label text-red" id="payment_LB_constructedRoof">RCC Constructed Roof:</label><br />
                                    @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("Cmd_RccType").Name("Cmd_RccType").Value(Model.Cmd_RccType).DataSource(new[] { "YES", "NO" }).ReadOnly(isvisible).Placeholder("Select.."))
                                    @Html.ValidationMessageFor(model => model.Cmd_RccType, "")
                                </div>
                            </div>
                        </div>
                    </div><!--[Constructed Roof]-->
                </div><!--[Row 4]-->
                <div class="row">
                    <div class="col-sm-12 col-md-12 col-lg-12">
                        <div class="form-field">
                            <div class="container-fluid">
                                @(Html.DevExtreme().TabPanel().ID("PaymentLBTab").Items(items => {
                            items.Add().Title("Leased And Constructed (Long Term)").Template(@<text> @LeasedAndConstructedView() </text>);
                            items.Add().Title("Extended Property").Template(@<text> @ExtendedPropertyView() </text>);
                            items.Add().Title("Documents").Template(@<text> @DocumentsView() </text>);
                            }).DeferRendering(false))
                                @helper LeasedAndConstructedView()
                                {
                                    /**/
                                    @Html.Partial("LeasedConstructed_View", Model);
                                }
                                @helper ExtendedPropertyView()
                                {
                                    /**/
                                    @Html.Partial("ExtendedProperty_View", Model);
                                }
                                @helper DocumentsView()
                                {
                                    /**/
                                    @Html.Partial("LB_Documents_View", Model);
                                }
                            </div>
                        </div>
                    </div>
                </div><!--[Tabs]-->
                <div class="row">
                    <div class="col-md-12">
                        <div class="form-field">
                            <div class="container-fluid">
                                @Html.Label("Other Details:", htmlAttributes: new { @class = "control-label col-md-2", @id = "Payment_LB_remarks" })
                                <div class="col-md-10">
                                    @(Html.DevExtreme().TextBox().CustomTextBox(true).ID("Txt_Remarks_Pw").Name("Txt_Remarks_Pw").Value(Model.Txt_Remarks_Pw).MaxLength(8000).ReadOnly(isvisible).Placeholder("Type any other detail / remarks..") )
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Other Details]-->
                <div class="row">
                    <div class="col-sm-12 col-md-12 col-lg-12">
                        <div class="row">
                            <div class="col-sm-6 col-md-6 col-lg-6">
                                @Html.Partial("Drop_Request", String.Format("Send Your Request to Madhuban for ( {0} ~ Item Detail (Land & Building Detail)...)...", Model.Tag.ToString().Substring(1)))
                            </div>
                            <div class="col-sm-6 col-md-6 col-lg-6">
                                <div class="styleActionBtn">
                                    @(Html.DevExtreme().Button().CustomSaveButton().ID("LB_Save").Text(Model.Tag.ToString() == "_Delete" ? "Delete" : "Save").UseSubmitBehavior(false).OnClick("Payment_property_saveClick").Visible(Model.Tag.ToString() == "_View" ? false : true) )
                                    @(Html.DevExtreme().Button().CustomCloseButton().ID("LB_Cancel").Text(Model.Tag.ToString() == "_View" ? "Close" : "Cancel").FocusStateEnabled(true).OnClick("ClosePropertyDetail"))

                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Buttons]-->


                @(Html.DevExtreme().Popup().CustomPopup().ID("Frm_Property_Window_Property_Address_popup").Title("Property/Building Address...").Width(680).Height("auto").ShowCloseButton(false).CloseOnOutsideClick(true).ShowTitle(true).OnShowing("AddPropertyAddressPopupScroll").OnHiding("PopupContainerEdit1_Closed").ContentTemplate(@<text> <div id="result_Frm_Property_Window_Property_Address_popup"> @Html.Action("Frm_Property_Window_Property_Address", "ProfilePaymentVoucher", new { @area = "Account", @Txt_Address = Model.Txt_Address, @Txt_R_Add1 = Model.Txt_R_Add1, @Txt_R_Add2 = Model.Txt_R_Add2, @Txt_R_Add3 = Model.Txt_R_Add3, @Txt_R_Add4 = Model.Txt_R_Add4, @GLookUp_StateList = Model.GLookUp_StateList, @GLookUp_DistrictList = Model.GLookUp_DistrictList, @GLookUp_CityList = Model.GLookUp_CityList, @Txt_R_Pincode = Model.Txt_R_Pincode, @model = Model }) </div> </text>) )
            }
        }

    </div>

    @(Html.DevExtreme().Popup().CustomPopup().ID("Frm_Property_Window_Property_Ext_popup").Height("200").Width("350").CloseOnOutsideClick(false).ShowTitle(true).Title("New ~ Extended Property").ContentTemplate(@<text> <div id="result_Frm_Property_Window_Property_Ext_popup"> </div> </text>) )

<script>

    var resStateCode = "";
    var GLookUp_StateName = "";
    var GLookUp_DistrictName = "";
    var GLookUp_CityName = "";
    var DistrictID_OnMainCenter_Selection = "";
      var CityID_OnMainCenter_Selection = "";
      var StateDDvalueChangeFinishExecution = true;

    $(document).ready(async function ()
    {
        //debugger;
        ShowLoader_Ready();
        TransformTextForDB("ID_Frm_Property_Window_Form");
        if ("@From_DNK" == "True") //From DNK
        {
            $("#Calc_Allow_DNK_Itm").val(false);
        }
        else if ("@From_JV" == "True") //From JV
        {
            $("#Calc_Allow_JV_Itm").val(false);
        }
        else // From payment
        {
            $("#Calc_Allow").val(false);
        }
        $("#lb_manageownerDiv").height($("#lb_ownershipDiv").height());
        $("#Frm_Property_Window_Property_Address_popup").dxPopup("show");
        $("#Frm_Property_Window_Property_Address_popup").dxPopup("hide");
        InitAllDropdownDataGrid_LB();
        var pCategoryitem = $("#Cmd_PCategory").dxSelectBox('instance').option('items');
        var pTypeitem = $("#Cmd_PType").dxSelectBox('instance').option('items');
        var tabpanel = $("#PaymentLBTab").dxTabPanel("instance");
        tabpanel.option("items[0].visible", false);
        tabpanel.option("items[1].visible", false);
        tabpanel.option("selectedIndex", 2);
        await LookUp_Get_StateList(true);
        if ("@Model.IsGift" == "True")
        {
            pCategoryitem.shift();
            pCategoryitem.shift();
            pCategoryitem.shift();
            pCategoryitem.shift();
            $("#Cmd_PCategory").dxSelectBox('instance').option('items', pCategoryitem);
        }
        else if ("@Model.IsJV" == "False")
        {
            pCategoryitem.pop();
            pCategoryitem.pop();
            $("#Cmd_PCategory").dxSelectBox('instance').option('items', pCategoryitem);
        }
        await LookUp_GetOwnList_LB(true);
        if ("@Model.Tag" == "_Edit" || "@Model.Tag" == "_View" || "@Model.Tag" == "_Delete")
        {
            $("#Cmd_PType").dxSelectBox("instance").option("value", "@Model.Cmd_PType");
            Cmd_PCategory_SelectedIndexChanged(null, true);            
            Cmd_PUse_SelectedIndexChanged(null, true);
            $("#Txt_PName").dxTextBox("instance").option("value", TransformText("@Model.Txt_PName"));
            $("#Txt_Address").dxTextArea("instance").option("value", "@Model.Txt_Address");
            $("#Txt_Add").dxTextBox("instance").option("value", TransformText("@Model.Txt_Add"));
            if ("@Model.Txt_R_Add1".length > 0)
            {
                $("#Txt_R_Add1").dxTextBox("instance").option("value", TransformText("@Model.Txt_R_Add1"));
                $("#Txt_R_Add2").dxTextBox("instance").option("value", TransformText("@Model.Txt_R_Add2"));
                $("#Txt_R_Add3").dxTextBox("instance").option("value", TransformText("@Model.Txt_R_Add3"));
                $("#Txt_R_Add4").dxTextBox("instance").option("value", TransformText("@Model.Txt_R_Add4"));
                if ("@Model.GLookUp_StateList".length > 0)
                {
                    await ChangeBuildingAddressState(null, true);
                }
                Control_SetReadOnly("GLookUp_StateList", "dxDropDownBox", false);
                if ("@Model.GLookUp_DistrictList".length > 0)
                {
                    await ChangeBuildingAddressDistrict(null, true);
                }
                Control_SetReadOnly("GLookUp_DistrictList", "dxDropDownBox", false);
                if ("@Model.GLookUp_CityList".length > 0)
                {
                    await ChangeBuildingAddressCity(null, true);
                }
                Control_SetReadOnly("GLookUp_CityList", "dxDropDownBox", false);
                $("#Txt_R_Pincode").dxTextBox("instance").option("value", "@Model.Txt_R_Pincode");
                var Txt_R_Add1 = $("#Txt_R_Add1").dxTextBox('instance').option('value');
                var Txt_R_Add2 = $("#Txt_R_Add2").dxTextBox('instance').option('value');
                var Txt_R_Add3 = $("#Txt_R_Add3").dxTextBox('instance').option('value');
                var Txt_R_Add4 = $("#Txt_R_Add4").dxTextBox('instance').option('value');
                var Txt_R_Pincode = $("#Txt_R_Pincode").dxTextBox('instance').option('value');
                var Address = Txt_R_Add1 + (Txt_R_Add2 != null && Txt_R_Add2.length > 0 ? ", " + Txt_R_Add2 : "") +
                    (Txt_R_Add3 != null && Txt_R_Add3.length > 0 ? ", " + Txt_R_Add3 : "") +
                    (Txt_R_Add4 != null && Txt_R_Add4.length > 0 ? ", " + Txt_R_Add4 : "") + ", " + (GLookUp_CityName == null ? "" : GLookUp_CityName.toUpperCase()) +
                    ",Dist. " + (GLookUp_DistrictName == null ? "" : GLookUp_DistrictName) + ", " + (GLookUp_StateName == null ? "" : GLookUp_StateName) + "-" + Txt_R_Pincode;
                $("#Txt_Add").dxTextBox({ value: TransformText(Address) });
            }
            cmd_ownership_ValueChange(null, true);
            if ("@Model.Look_OwnList".length > 0)
            {
                Property_OwnerName_Change();
            }
            $("#Txt_SNo").dxTextBox("instance").option("value", TransformText("@Model.Txt_SNo"));
            $("#Txt_Tot_Area").dxNumberBox("instance").option("value", parseFloat("@Model.Txt_Tot_Area"));
            $("#Txt_Con_Area").dxNumberBox("instance").option("value", parseFloat("@Model.Txt_Con_Area"));
            $("#Cmd_Con_Year").dxSelectBox("instance").option("value", "@Model.Cmd_Con_Year");
            $("#Cmd_RccType").dxSelectBox("instance").option("value", "@Model.Cmd_RccType");

            $("#Chk_OtherDoc_temp").dxCheckBox("instance").option("value", "@Model.Chk_OtherDoc"=="True"?true:false);
            $("#Txt_OtherDoc").dxTextBox("instance").option("value", TransformText("@Model.Txt_OtherDoc")); /*RedmineBug#134887*/
        }
        var CmdType_Instance = $("#Cmd_PType").dxSelectBox('instance');
        if ("@Model.ITEM_ID" == "f8f4b6c3-f340-4e99-892b-16ebf33c8c28")
        {
            pTypeitem.splice(1, 1);
            pTypeitem.splice(1, 1);
            pTypeitem.splice(1, 1);
            CmdType_Instance.option('items', pTypeitem);
            CmdType_Instance.option('value', CmdType_Instance.option('items')[0]);
        }
        else if ("@Model.ITEM_ID" == "c4d9b556-6a36-41f5-8f56-245d2c6e0be4") {
            pTypeitem.splice(0, 1);
            pTypeitem.splice(1, 1);
            pTypeitem.splice(1, 1);
            CmdType_Instance.option('items', pTypeitem);
            CmdType_Instance.option('value', CmdType_Instance.option('items')[0]);
        }
        else if ("@Model.ITEM_ID" == "e769d245-0299-4737-9b74-55cc2147f389")
        {
            pTypeitem.splice(0, 1);
            pTypeitem.splice(0, 1);
            pTypeitem.splice(1, 1);
            CmdType_Instance.option('items', pTypeitem);
            CmdType_Instance.option('value', CmdType_Instance.option('items')[0]);
        }
        else if ("@Model.ITEM_ID" == "f90dfc01-7c18-447e-8331-3eae64288087")
        {
            pTypeitem.splice(0, 1);
            pTypeitem.splice(0, 1);
            pTypeitem.splice(0, 1);
            CmdType_Instance.option('items', pTypeitem);
            CmdType_Instance.option('value', CmdType_Instance.option('items')[0]);
        }
        Set_Form_View_Delete_Mode(null, "ID_Frm_Property_Window_Form", "@Model.Tag");
        Focus_FirstEditable_Field("ID_Frm_Property_Window_Form");
        HideLoader_Ready();      
    });
    @* document.body.addEventListener("keydown", PaymentItem_LB, false);
    function PaymentItem_LB(evt) {
        if (evt.ctrlKey && evt.keyCode == 79)//ctrl+o save
        {
            evt.preventDefault();
            if ("@Model.Tag" == "_New" || "@Model.Tag" == "_Edit" || "@Model.Tag" == "_New_From_Selection") {
                $("#LB_Save").trigger("dxclick");
            }
        }
        else if (evt.ctrlKey && evt.keyCode == 68)//ctrl+d delete
        {
            evt.preventDefault();
            if ("@Model.Tag" == "_Delete") {
                $("#LB_Save").trigger("dxclick");
            }
        }
    }*@ //shortcuts
    function Lb_setDisable()
    {
        var list = document.getElementById("ID_Frm_Property_Window_Form").getElementsByTagName("LABEL");
        for (var i = 0; i < list.length; i++)
        {
            var labelid = "#" + list[i].id;
            $(labelid).addClass("disabletxt").removeClass("text-red");
        }
