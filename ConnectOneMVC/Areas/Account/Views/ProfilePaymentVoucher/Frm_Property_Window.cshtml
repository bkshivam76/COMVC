        function cmd_ownership_ValueChange(e, FirstCall = false)
        {
            //debugger;
            var value;
            if (e)
            {
                value = e.value;
            }
            else
            {
                value = $("#Cmd_Ownership").dxSelectBox("option", "value");
            }
            if (value)
            {
                if (value.toUpperCase() == "INSTITUTION")
                {
                    $("#TextEdit1").dxTextBox({ visible: true });
                    $("#Look_OwnList").dxDropDownBox({ visible: false, readOnly: true });
                    $("#But_LB_ManageOwner").dxButton({ disabled: true });
                    if (FirstCall == false)
                    {
                        LB_Owner_DG.clearSelection();
                    }
                }
                else if (value.toUpperCase() == "THIRD PARTY")
                {
                    $("#TextEdit1").dxTextBox({ visible: false });
                    $("#Look_OwnList").dxDropDownBox({ visible: true, readOnly: false });
                    if ("@isvisible" == "False")
                    {
                        $("#But_LB_ManageOwner").dxButton({ disabled: false });
                    }
                    if (FirstCall == false)
                    {
                        LB_Owner_DG.clearSelection();
                    }
                }
                OwnerValidation(value);
            }
        }
        function OwnerValidation(cmd_ownership)
    {
        $("#Look_OwnList").dxDropDownBox({})
            .dxValidator({
                validationRules: [{
                    type: 'custom',
                    validationCallback: function (options)
                    {
                        var result = true;
                        if (cmd_ownership == "THIRD PARTY")
                        {
                            if (options.value == "" || options.value == null)
                            {
                                result = false;
                            }
                        }
                        return result;
                    },
                    reevaluate:true,
                    message: "Owner Name Cannot Be Blank..!!"
                }],
                validationGroup: "paymentVoucher_LB"
            });
    }//removed validation from model and added here redmine bug 132934 fix
        function Chk_OtherDoc_CheckedChanged(e)
    {
        $("#Chk_OtherDoc").val(e.value);
        if (e.value)
        {
            $("#Txt_OtherDoc").dxTextBox({ readOnly: false });
            $("#Txt_OtherDoc").dxTextBox("instance").reset();
            $("#Txt_OtherDoc").dxTextBox("instance").focus();
        }
        else
        {
            $("#Txt_OtherDoc").dxTextBox("instance").reset();
            $("#Txt_OtherDoc").dxTextBox({ readOnly: true });
        }
    }
    </script>
    <script>
        function LoadPropertyBuildingAddress_Popup(e)
    {
        if (e)
        {
            if (e.event.keyCode == 9)//tab
            {
                return;
            }
        }
        if ("@isvisible" == "False")
        {
            $("#Frm_Property_Window_Property_Address_popup").dxPopup("show");
            $("#Txt_R_Pincode").dxTextBox("instance").option({
                "mask": 'NNNNNN',
                "maskRules":
                {
                    'N': /[0-9]/
                }
            });
            $("#Txt_R_Pincode").dxTextBox("instance").option("isValid", true);
            setTimeout(function () { $("#Txt_R_Add1").dxTextBox("focus"); },350);
        }
    }
        function AddPropertyAddressPopupScroll(e) {
            //$("#Frm_Property_Window_Property_Address_popup").dxScrollView();
            PopupOnShowing(e)
            $("#Txt_Add").dxTextBox({ value: "" });
        }

        function OnPropertyAddressOKClick(e)
        {
        ShowLoader();
        var Txt_R_Add1_PropertyAddress = $("#Txt_R_Add1").dxTextBox('instance').option('value');
        var Txt_R_Pincode_PropertyAddress = $("#Txt_R_Pincode").dxTextBox('instance').option('value');
        if (Txt_R_Pincode_PropertyAddress == null || Txt_R_Pincode_PropertyAddress.length == 0)
        {
            DevExpress.ui.dialog.alert("Pincode Cannot Be Blank...!", "Error..");
            HideLoader();
            return;
        }
        if ($("#Txt_R_Pincode").dxTextBox('instance').option('isValid') == false || Txt_R_Pincode_PropertyAddress.length < 6)
        {
            DevExpress.ui.dialog.alert("Pincode Is Invalid", "Error..");
            HideLoader();
            return;
        }
        $.ajax({
            type: 'GET',
            url: "/Account/ProfilePaymentVoucher/AddressChecks",
            data: { Txt_R_Add1: Txt_R_Add1_PropertyAddress, GLookUp_StateList: GLookUp_StateName, GLookUp_DistrictList: GLookUp_DistrictName, GLookUp_CityList: GLookUp_CityName, Txt_R_Pincode: Txt_R_Pincode_PropertyAddress },
            cache: false,
            success: function (data)
            {
                HideLoader();
                if (data.jsonParam.result)
                {
                    $("#Frm_Property_Window_Property_Address_popup").dxPopup("hide");
                }
                else
                {
                    var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                    alertclick.done(function (alertResult)
                    {
                        if (alertResult)
                        {
                            if (data.jsonParam.focusid)
                            {
                                var id = "#" + data.jsonParam.focusid;
                                setTimeout(function ()
                                {
                                    $(id).find('input').focus();
                                }, Timeout100);
                            }
                        }
                    });
                }
            }
        });
    }
        function PopupContainerEdit1_Closed(e)
    {
            $("#Txt_Add").dxTextBox("focus");
            $("#Txt_Add").dxTextBox({ value: TransformText($("#Txt_Address").dxTextArea("instance").option("value")) });
            var Txt_R_Add1 = $("#Txt_R_Add1").dxTextBox('instance').option('value');
            var Txt_R_Add2 = $("#Txt_R_Add2").dxTextBox('instance').option('value');
            var Txt_R_Add3 = $("#Txt_R_Add3").dxTextBox('instance').option('value');
            var Txt_R_Add4 = $("#Txt_R_Add4").dxTextBox('instance').option('value');
            var Txt_R_Pincode = $("#Txt_R_Pincode").dxTextBox('instance').option('value');
            if (Txt_R_Add1 != null && Txt_R_Add1.length > 0)
            {
                var Address = Txt_R_Add1 + (Txt_R_Add2 != null && Txt_R_Add2.length > 0 ? ", " + Txt_R_Add2 : "") +
                    (Txt_R_Add3 != null && Txt_R_Add3.length > 0 ? ", " + Txt_R_Add3 : "") +
                    (Txt_R_Add4 != null && Txt_R_Add4.length > 0 ? ", " + Txt_R_Add4 : "") + ", " + (GLookUp_CityName == null ? "" : GLookUp_CityName.toUpperCase()) +
                    ",Dist. " + (GLookUp_DistrictName == null ? "" : GLookUp_DistrictName) + ", " + (GLookUp_StateName == null ? "" : GLookUp_StateName) + "-" + Txt_R_Pincode;
                $("#Txt_Add").dxTextBox({ value: TransformText(Address) });
            }
    }
    </script>
