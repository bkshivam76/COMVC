    <script>
        async function ChangeBuildingAddressState(e, FirstCall = false)
        {
            var State;
            if (e) {
                State = e.value;
                if ((e.value == null || e.value.length == 0) && e.previousValue != null)
                {
                    LB_State_DG.clearSelection();
                    GLookUp_StateName = null;
                    resStateCode = null;
                    Promise.all([LookUp_Get_DistrictList(), LookUp_Get_CityList()]);
                    LB_State_DG.clearSelection();
                    LB_District_DG.clearSelection();
                    LB_City_DG.clearSelection();
                    return;
                }
            }
            else
            {
                State = $("#GLookUp_StateList").dxDropDownBox("instance").option("value");
            }           
            await LB_State_DG.selectRows(State);      
            if (LB_State_DG.getSelectedRowsData().length > 0)
            {
                var item = LB_State_DG.getSelectedRowsData()[0];
                GLookUp_StateName = item.R_ST_NAME;
                resStateCode = item.R_ST_CODE;               
                await Promise.all([LookUp_Get_DistrictList(FirstCall), LookUp_Get_CityList(FirstCall)]);  
                if (FirstCall == false)
                {
                    LB_District_DG.clearSelection();
                    LB_City_DG.clearSelection();
                }                
            }
        }
        async function ChangeBuildingAddressDistrict(e, FirstCall = false) {
            var district;
            if (e) {
                district = e.value;
                if ((e.value == null || e.value.length == 0) && e.previousValue != null) {
                    LB_District_DG.clearSelection();
                    GLookUp_DistrictName = null;
                    return;
                }
            }
            else {
                district = $("#GLookUp_DistrictList").dxDropDownBox("instance").option("value");
            }
            await LB_District_DG.selectRows(district);
            if (LB_District_DG.getSelectedRowsData().length > 0) {
                var item = LB_District_DG.getSelectedRowsData()[0];
                GLookUp_DistrictName = item.R_DI_NAME;
            }
        }
        async function ChangeBuildingAddressCity(e, FirstCall = false) {
            var city;
            if (e) {
                city = e.value;
                if ((e.value == null || e.value.length == 0) && e.previousValue != null) {
                    LB_City_DG.clearSelection();
                    GLookUp_CityName = null;
                    return;
                }
            }
            else {
                city = $("#GLookUp_CityList").dxDropDownBox("instance").option("value");
            }
            await LB_City_DG.selectRows(city);
            if (LB_City_DG.getSelectedRowsData().length > 0) {
                var item = LB_City_DG.getSelectedRowsData()[0];
                GLookUp_CityName = item.R_CI_NAME;
            }
        }
