    async function LookUp_GetOwnList_LB(FirstCall = false)
    {
        if (FirstCall === false)
        {
            ShowLoader();
            var DDvalue = $("#Look_OwnList").dxDropDownBox("instance").option("value");
            $.ajax({
                type: 'GET',
                url: "/Account/ProfilePaymentVoucher/RefreshPropOwner",
                cache: false,
                success: function (data)
                {
                    dataSource_PropOwner_PrfPay = new DevExpress.data.DataSource({ // need to dispose it in in clearreference
                        store:
                        {
                            type: "array",
                            key: "ID",
                            data: data
                        }
                    });
                    $("#Look_OwnList").dxDropDownBox("instance").option("dataSource", dataSource_PropOwner_PrfPay);
                    LB_Owner_DG.option("dataSource", dataSource_PropOwner_PrfPay);
                    dataSource_PropOwner_PrfPay.load().done((r) =>
                    {
                        $("#Look_OwnList").dxDropDownBox("reset");
                        if (data.some(data => data.ID === DDvalue))
                        {
                            $("#Look_OwnList").dxDropDownBox("instance").option("value", DDvalue);
                        }
                        $("#Look_OwnList").dxDropDownBox("focus");
                        HideLoader();
                    })
                }
            });
        }
