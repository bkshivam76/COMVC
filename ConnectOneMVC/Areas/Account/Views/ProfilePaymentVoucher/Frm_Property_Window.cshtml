    function LB_setvalidation()
    {
        var Cmd_PType = $("#Cmd_PType").dxSelectBox("instance").option("value");
        var Cmd_PCategory = $("#Cmd_PCategory").dxSelectBox("instance").option("value");
        Cmd_PType = (Cmd_PType == null ? "" : Cmd_PType);
        Cmd_PCategory = (Cmd_PCategory == null ? "" : Cmd_PCategory);
        $("#Cmd_Con_Year").dxSelectBox({})
            .dxValidator({
                validationRules: [{
                    type: 'custom',
                    validationCallback: function (options)
                    {
                        var result = true;
                        if (Cmd_PType != "LAND")
                        {
                            if (options.value == "" || options.value ==null)
                            {
                                result = false;
                            }
                        }
                        return result;
                    },
                    message: " Construction Year Cannot Be Blank..!!"
                }],
                validationGroup: "paymentVoucher_LB"
            });

        $("#Txt_Con_Area").dxNumberBox({})
            .dxValidator({
                validationRules: [{
                    type: 'custom',
                    validationCallback: function (options) {
                        var result = true;
                        if (Cmd_PType != "LAND") {
                            if (options.value == "" || options.value == null || options.value == 0) {
                                result = false;
                            }
                        }
                        return result;
                    },
                    message: " Constructed Area Cannot Be Blank or Zero..!!"
                },
                    { type: 'custom',
                    validationCallback: function (options) {
                        var result = true;
                        if (options.value < 0) {
                            result = false;
                        }
                        return result;
                    },
                    message: "Constructed Area Cannot Be Negative..!!"
                    }
                ],
                validationGroup: "paymentVoucher_LB"
            });

        $("#Txt_Tot_Area").dxNumberBox({})
            .dxValidator({
                validationRules: [
                    {
                    type: 'custom',
                    validationCallback: function (options)
                    {
                        var result = true;
                        if (Cmd_PType == "LAND" || Cmd_PType == "BUILDING")
                        {
                            if (options.value == "" || options.value == null )
                            {
                                result = false;
                            }
                        }
                        return result;
                    },
                    message: "Plot Area Cannot Be Blank Or Zero..!!"
                    },
                    {
                    type: 'custom',
                    validationCallback: function (options)
                    {
                        var result = true;
                        if (options.value < 0)
                        {
                           result = false;
                        }
                        return result;
                    },
             message: "Plot Area Cannot Be Negative..!!"
                    }],
                validationGroup: "paymentVoucher_LB"
            });

        $("#Cmd_RccType").dxSelectBox({})
            .dxValidator({
                validationRules: [{
                    type: 'custom',
                    validationCallback: function (options) {
                        var result = true;
                        if (Cmd_PType != "LAND" || ((Cmd_PCategory.includes("PURCHASED") || Cmd_PCategory.includes("GIFTED") || Cmd_PCategory.includes("LEASED")) && Cmd_PType != "LAND")) {

                            if (options.value == "" ||options.value == null)
                            {
                                result = false;
                            }
                        }
                        return result;
                    },
                    message: "Constructed Roof Cannot Be Blank..!!"
                }],
                validationGroup: "paymentVoucher_LB"
            });
    }
