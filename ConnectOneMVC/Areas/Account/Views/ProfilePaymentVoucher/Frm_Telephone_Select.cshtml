    function Frm_Telephone_Select_WindowAjaxSuccessForm(data)
    {
        HideLoader();
        if (data.jsonParam.result == false)
        {
            var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
            alertclick.done(function (alertResult)
            {
                if (alertResult)
                {
                    if (data.jsonParam.focusid)
                    {
                        var id = "#" + data.jsonParam.focusid;
                        setTimeout(function ()
                        {
                            $(id).find('input').focus();
                        }, Timeout100);
                    }
                }
            });
        }
        else if (data.jsonParam.result)
        {

            $("#X_TP_ID").val($("#GLookUp_TeleList").dxDropDownBox("instance").option('value'));
            $("#TP_BILL_NO").val($("#Txt_Bill_No").dxTextBox("instance").option('value'));
            $("#TP_BILL_DATE").val(data.billdate);
            $("#TP_PERIOD_FROM").val(data.periodfrom);
            $("#TP_PERIOD_TO").val(data.periodto);

            Fillgrid1_PaymentVoucher();
        }
    }
    function Payment_telephone_Save(e)
    {
        var result = e.validationGroup.validate();
        if (result.isValid)
        {
            $("#ID_Frm_Telephone_Select_Window").submit();
        }
    }
</script>@* save success *@
<script>
    var paymentvoucher_telephone_planType = "";
    $(document).ready(async function ()
    {
        await LookUp_GetTeleList();
        TransformTextForDB("ID_Frm_Telephone_Select_Window");
        if ("@Model.Tag" == "_Edit" || "@Model.Tag"== "_Delete" || "@Model.Tag"=="_View")
        {
            await GLookUp_TeleList_EditValueChanged(null, true);
            $("#GLookUp_TeleList").dxDropDownBox("instance").option("readOnly", false);
            $("#GLookUp_TeleList").dxDropDownBox("instance").option("focusStateEnabled", true);
        }
        telephone_setvalidation();
        Set_Form_View_Delete_Mode(null, "ID_Frm_Telephone_Select_Window", "@Model.Tag");
        Focus_FirstEditable_Field("ID_Frm_Telephone_Select_Window");
        HideLoader_Ready();       
    });
</script>@* document.ready *@
<script>
    var TeleList_DG;
    async function LookUp_GetTeleList(FirstCall=false)
    {
        var $TeleList_DG = $("#Frm_select_Payment_TeleList_datagrid");
        if ($TeleList_DG.length)
        {
            TeleList_DG = $TeleList_DG.dxDataGrid("instance");
            var DGItem = GetDataSourceItems("GLookUp_TeleList", "dxDropDownBox");
            var TotalCount = DGItem.length;            
            if (TotalCount == 1)
            {
                $("#GLookUp_TeleList").find('input').css('color', "#000080");
                if ("@Model.TempActionMethod" == "_New" || "@Model.TempActionMethod" == "_New_From_Selection")
                {
                    $("#GLookUp_TeleList").dxDropDownBox("instance").option("readOnly", true);
                    $("#GLookUp_TeleList").dxDropDownBox("instance").option("focusStateEnabled", false);
                    await GLookUp_TeleList_EditValueChanged(null, FirstCall); //Redmine Bug #134891 fix
                }
            }
            else
            {
                if ("@Model.TempActionMethod" == "_New" || "@Model.TempActionMethod" == "_New_From_Selection")
                {
                    $("#GLookUp_TeleList").dxDropDownBox("instance").option("readOnly", false);
                    $("#GLookUp_TeleList").dxDropDownBox("instance").option("focusStateEnabled", true);
                }
            }
        }
    }
</script>@* dd init *@
<script>

    async function GLookUp_TeleList_EditValueChanged(e,FirstCall=false)
    {
        var TP_ID;
        if (e)
        {
            TP_ID = e.value;
            if ((e.value == null || e.value.length == 0) && e.previousValue != null)
            {
                TeleList_DG.clearSelection();
                return;
            }
        }
        else
        {
            TP_ID = $("#GLookUp_TeleList").dxDropDownBox("instance").option("value");
        }
        await TeleList_DG.selectRows(TP_ID);
        if (TeleList_DG.getSelectedRowsData().length > 0)
        {
            var item = TeleList_DG.getSelectedRowsData()[0];
            $("#BE_Company").dxTextBox("instance").option('value', item["TP_COMPANY"]);
            $("#BE_Category").dxTextBox("instance").option('value', item["TP_CATEGORY"]);
            $("#BE_Plantype").dxTextBox("instance").option('value', item["TP_TYPE"]);
            paymentvoucher_telephone_planType = item["TP_TYPE"];          
            if (paymentvoucher_telephone_planType.toUpperCase().trim() == "POST PAID")
            {
                $("#payment_telephonePTo").addClass("text-red");
                $("#payment_telephoneBill").addClass("text-red");
                $("#payment_telephoneBillDate").addClass("text-red");
                $("#payment_telephonePfrom").addClass("text-red");
                $("#Txt_Bill_No").dxTextBox("instance").option('readOnly', false);
                $("#Txt_Bill_Date").dxDateBox("instance").option('readOnly', false);
                $("#Txt_Fr_Date").dxDateBox("instance").option('readOnly', false);
                $("#Txt_To_Date").dxDateBox("instance").option('readOnly', false);
                $("#Txt_Bill_No").dxTextBox("instance").option("focusStateEnabled", true);
                $("#Txt_Bill_Date").dxDateBox("instance").option("focusStateEnabled", true);
                $("#Txt_Fr_Date").dxDateBox("instance").option("focusStateEnabled", true);
                $("#Txt_To_Date").dxDateBox("instance").option("focusStateEnabled", true);
                $("#Txt_Bill_No").dxTextBox("instance").option('placeholder', "Type Bill No...");
                $("#Txt_Bill_Date").dxDateBox("instance").option('placeholder', "dd-mm-yyyy");
                $("#Txt_Fr_Date").dxDateBox("instance").option('placeholder', "dd-mm-yyyy");
                $("#Txt_To_Date").dxDateBox("instance").option('placeholder', "dd-mm-yyyy");
            }
            else
            {
                $("#payment_telephonePTo").removeClass("text-red");
                $("#payment_telephoneBill").removeClass("text-red");
                $("#payment_telephoneBillDate").removeClass("text-red");
                $("#payment_telephonePfrom").removeClass("text-red");
                $("#payment_telephonePTo").addClass("disabletxt");
                $("#payment_telephoneBill").addClass("disabletxt");
                $("#payment_telephoneBillDate").addClass("disabletxt");
                $("#payment_telephonePfrom").addClass("disabletxt");
                $("#Txt_Bill_No").dxTextBox("instance").option('readOnly', true);
                $("#Txt_Bill_Date").dxDateBox("instance").option('readOnly', true);
                $("#Txt_Fr_Date").dxDateBox("instance").option('readOnly', true);
                $("#Txt_To_Date").dxDateBox("instance").option('readOnly', true);
                $("#Txt_Bill_No").dxTextBox("instance").option("focusStateEnabled", false);
                $("#Txt_Bill_Date").dxDateBox("instance").option("focusStateEnabled", false);
                $("#Txt_Fr_Date").dxDateBox("instance").option("focusStateEnabled", false);
                $("#Txt_To_Date").dxDateBox("instance").option("focusStateEnabled", false);
                $("#Txt_Bill_No").dxTextBox("instance").option('placeholder', "");
                $("#Txt_Bill_Date").dxDateBox("instance").option('placeholder', "");
                $("#Txt_Fr_Date").dxDateBox("instance").option('placeholder', "");
                $("#Txt_To_Date").dxDateBox("instance").option('placeholder', "");
                $("#Txt_Bill_No").dxTextBox("instance").reset(); //Redmine Bug #134893 fix
                $("#Txt_Bill_Date").dxDateBox("instance").reset();//Redmine Bug #134893 fix
                $("#Txt_Fr_Date").dxDateBox("instance").reset();//Redmine Bug #134893 fix
                $("#Txt_To_Date").dxDateBox("instance").reset();//Redmine Bug #134893 fix   
            }          
        }
    }
    function telephone_setvalidation() {
        $("#Txt_Bill_No").dxTextBox({})
            .dxValidator({
                validationRules: [{
                    type: 'custom',
                    validationCallback: function (options) {
                        var result = true;
                        if (paymentvoucher_telephone_planType.toUpperCase().trim() == "POST PAID") {

                            if (options.value == "") {
                                result = false;
                            }
                        }
                        return result;
                    },
                    message: " Bill No. Cannot Be Blank..!!",
                    reevaluate:true
                }],
                validationGroup: "paymentVoucher_telephone"
            });
        $("#Txt_Bill_Date").dxDateBox({})
            .dxValidator({
                validationRules: [{
                    type: 'custom',
                    validationCallback: function (options) {
                        var result = true;
                        if (paymentvoucher_telephone_planType.toUpperCase().trim() == "POST PAID") {

                            if (options.value == null) {
                                result = false;
                            }
                        }
                        return result;
                    },
                    message: " Bill Date Cannot Be Blank..!!",
                    reevaluate: true
                }],
                validationGroup: "paymentVoucher_telephone"
            });
        $("#Txt_Fr_Date").dxDateBox({})
            .dxValidator({
                validationRules: [{
                    type: 'custom',
                    validationCallback: function (options) {
                        var result = true;
                        if (paymentvoucher_telephone_planType.toUpperCase().trim() == "POST PAID") {

                            if (options.value == null) {
                                result = false;
                            }
                        }
                        return result;
                    },
                    message: "From Date Cannot Be Blank..!!",
                    reevaluate: true
                }],
                validationGroup: "paymentVoucher_telephone"
            });
        $("#Txt_To_Date").dxDateBox({})
            .dxValidator({
                validationRules: [{
                    type: 'custom',
                    validationCallback: function (options) {
                        var result = true;
                        if (paymentvoucher_telephone_planType.toUpperCase().trim() == "POST PAID") {

                            if (options.value == null) {
                                result = false;
                            }
                        }
                        return result;
                    },
                    message: "To Date Cannot Be Blank..!!",
                    reevaluate: true,
                }],
                validationGroup: "paymentVoucher_telephone"
            });
    }
    function TelephonedetailSaveClick(e)
    {
        if (ValidateForm(e))
        {
            $("#ID_Frm_Telephone_Select_Window").submit();
        }
    }
</script>@* Value Change *@
