<div class="VoucherTelephone_ClearReferences">
@using DevExtreme.AspNet.Mvc;
@model ConnectOneMVC.Areas.Account.Models.Payment_Frm_Telephone_Select_Model
@{var isvisible = (Model.Tag == Common_Lib.Common.Navigation_Mode._View || Model.Tag == Common_Lib.Common.Navigation_Mode._Delete) ? true : false; }

<div>
    @using (Ajax.BeginForm("Frm_Telephone_Select_Window", "Profile",
                            new AjaxOptions
                            {
                                HttpMethod = "POST",
                                UpdateTargetId = "Frm_Telephone_Select_Content",
                                InsertionMode = InsertionMode.InsertAfter,
                                OnBegin = "AjaxBeginFormPost",
                                OnSuccess = "Frm_Telephone_Select_WindowAjaxSuccessForm"
                            },
                            new
                            {
                                id = "ID_Frm_Telephone_Select_Window",
                                @class = "edit_form"
                            }))
    {
        @Html.AntiForgeryToken()
        using (Html.DevExtreme().ValidationGroup("paymentVoucher_telephone"))
        {
            @Html.HiddenFor(x => x.Tag)
            @Html.HiddenFor(x => x.TempActionMethod)
            @Html.HiddenFor(x => x.xID)
            <div class="full-width-header-bg2">
                <div class="row">
                    <div class="col-sm-8 pll">
                        <h3 class="popuphead"><i class="far fa-edit"></i>Telephone Detail</h3>
                    </div>
                    <div class="col-sm-4 prm">
                        <h5 class="mand-txt-align"><i class="fas fa-info-circle"></i> Red Fields are mandatory</h5>
                    </div>
                </div>
            </div><!--[Header]-->
            <div class="row">
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-3 col-md-3 col-lg-3 pll"><label class="control-label text-red" id="payment_telephone">Telephone No.:</label></div>
                                <div class="col-sm-9 col-md-9 col-lg-9 prm ">
                                    @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_TeleList").Name("GLookUp_TeleList").ValueExpr("TP_ID").DisplayExpr("TP_NO").DataSource(Model.TelephoneListData,"TP_ID").Placeholder("Select Item")
                                                  .OnValueChanged("GLookUp_TeleList_EditValueChanged").ContentTemplate(@<text> @Html.Partial("Frm_Telephone_Select_GLookUp_TeleList") </text>).ReadOnly(true).FocusStateEnabled(false).Value(Model.GLookUp_TeleList))
                                    @Html.ValidationMessageFor(model => model.GLookUp_TeleList, "", new { @class = "text-red" })
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Telephone No]-->
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-3 col-md-3 col-lg-3 pll"><label class="control-label text-red" id="payment_telephoneBill">Bill No.:</label></div>
                                <div class="col-sm-9 col-md-9 col-lg-9 prm ">
                                    @(Html.DevExtreme().TextBoxFor(x => x.Txt_Bill_No).CustomTextBox(true,true).Value(Model.Txt_Bill_No).MaxLength(25).ID("Txt_Bill_No").Placeholder("Type Bill No...").ReadOnly(isvisible) )
                                    @Html.ValidationMessageFor(model => model.Txt_Bill_No, "", new { @class = " text-red" })
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Bill No]-->
            </div><!--[Row 1]-->
            <div class="row">
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-3 col-md-3 col-lg-3 pll"><label class="control-label disabletxt" id="payment_tele_company">Company:</label></div>
                                <div class="col-sm-9 col-md-9 col-lg-9 prm ">
                                    @(Html.DevExtreme().TextBoxFor(x => x.BE_Company).CustomTextBox().ID("BE_Company").ReadOnly(true).FocusStateEnabled(false) )
                                    @Html.ValidationMessageFor(model => model.BE_Company, "", new { @class = " text-red" })
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Company]-->
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-3 col-md-3 col-lg-3 pll"><label class="control-label text-red" id="payment_telephoneBillDate">Bill Date:</label></div>
                                <div class="col-sm-9 col-md-9 col-lg-9 prm ">
                                    @(Html.DevExtreme().DateBox().CustomDateBox().ReadOnly(isvisible).Value(Model.Txt_Bill_Date).ID("Txt_Bill_Date").Name("Txt_Bill_Date").Min(new DateTime(1900,01,01)))
                                    @Html.ValidationMessageFor(model => model.Txt_Bill_Date, "", new { @class = " text-red" })
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Bill Date]-->
            </div><!--[Row 2]-->
            <div class="row">
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-3 col-md-3 col-lg-3 pll"><label class="control-label disabletxt" id="payment_tele_category">Category:</label></div>
                                <div class="col-sm-9 col-md-9 col-lg-9 prm ">
                                    @(Html.DevExtreme().TextBoxFor(x => x.BE_Category).CustomTextBox().ID("BE_Category").ReadOnly(true).FocusStateEnabled(false)  )
                                    @Html.ValidationMessageFor(model => model.BE_Category, "", new { @class = " text-red" })
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Category]-->
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-3 col-md-3 col-lg-3 pll"><label class="control-label text-red" id="payment_telephonePfrom">Period From:</label></div>
                                <div class="col-sm-9 col-md-9 col-lg-9 prm ">
                                    @(Html.DevExtreme().DateBox().CustomDateBox().Value(Model.Txt_Fr_Date).ID("Txt_Fr_Date").Name("Txt_Fr_Date").Min(new DateTime(1900, 01, 01)).ReadOnly(isvisible) )
                                    @Html.ValidationMessageFor(model => model.Txt_Fr_Date, "", new { @class = " text-red" })
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[From]-->
            </div><!--[Row 3]-->
            <div class="row">
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-3 col-md-3 col-lg-3 pll"><label class="control-label disabletxt" id="payment_telephone_plan">Plan Type:</label></div>
                                <div class="col-sm-9 col-md-9 col-lg-9 prm ">
                                    @(Html.DevExtreme().TextBoxFor(x => x.BE_Plantype).CustomTextBox().ID("BE_Plantype").ReadOnly(true).FocusStateEnabled(false) )
                                    @Html.ValidationMessageFor(model => model.BE_Plantype, "", new { @class = " text-red" })
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Plan Type]-->
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-3 col-md-3 col-lg-3 pll"><label class="control-label text-red" id="payment_telephonePTo">Period To:</label></div>
                                <div class="col-sm-9 col-md-9 col-lg-9 prm ">
                                    @(Html.DevExtreme().DateBox().CustomDateBox().Value(Model.Txt_To_Date).Min(new DateTime(1900, 01, 01)).ID("Txt_To_Date").Name("Txt_To_Date").ReadOnly(isvisible) )
                                    @Html.ValidationMessageFor(model => model.Txt_To_Date, "", new { @class = " text-red" })
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[To]-->
            </div><!--[Row 4]-->


            <div class="row">
                <div class="col-sm-12 col-md-12 col-lg-12">
                    <div class="row">
                        <div class="col-sm-6 col-md-6 col-lg-6">
                            @Html.Partial("Drop_Request", String.Format("Send Your Request to Madhuban for ( {0} ~ Item Detail (Telephone Detail)...)...", Model.Tag.ToString().Substring(1)))
                        </div>
                        <div class="col-sm-6 col-md-6 col-lg-6">
                            <div class="styleActionBtn">
                                @(Html.DevExtreme().Button().CustomSaveButton().ID("Tele_save").Text(Model.TempActionMethod == "_Delete" ? "Delete" : "Save").Icon("fa fa-check").UseSubmitBehavior(false).Visible(Model.TempActionMethod == "_View" ? false : true).OnClick("TelephonedetailSaveClick") )
                                @(Html.DevExtreme().Button().CustomCloseButton().ID("Tele_Cancel").Text(Model.TempActionMethod == "_View" ? "Close" : "Cancel").Icon("fa fa-times").OnClick(@<text> function () { $("#Frm_Voucher_Item_Content_popup").dxPopup("hide"); } </text>) )
                            </div>
                        </div>
                    </div>
                </div>
            </div><!--[Buttons]-->


        }
    }
</div>

