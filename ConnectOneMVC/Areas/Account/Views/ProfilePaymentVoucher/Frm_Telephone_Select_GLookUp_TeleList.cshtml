
@using DevExtreme.AspNet.Data;
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("Frm_select_Payment_TeleList_datagrid")  
    .Columns(columns =>
    {
        columns.Add().DataField("TP_NO").Caption("Name");
        columns.Add().DataField("TP_ID").Visible(false);
        columns.Add().DataField("TP_COMPANY").Caption("Company");
        columns.Add().DataField("TP_CATEGORY").Caption("Category");
        columns.Add().DataField("TP_TYPE").Caption("Plan Type");
    })
   
    .Selection(s => s.Mode(SelectionMode.Single))
    .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}")
)




