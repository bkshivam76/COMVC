    function AddCustomDatatoMake()
    {
        var Cmd_Make = $("#Cmd_Make").dxSelectBox("instance");
        var dataSource = Cmd_Make.getDataSource();
        var dataItems = dataSource.items();
        var flag = false;
        for (var i = 0; dataItems.length > i; i++)
        {
            if (dataItems[i].Name == "@Model.Cmd_Make")
            {
                flag = true;
                break;
            }
        }
        if (flag == true)
        {
            Cmd_Make.option("value", "@Model.Cmd_Make");
