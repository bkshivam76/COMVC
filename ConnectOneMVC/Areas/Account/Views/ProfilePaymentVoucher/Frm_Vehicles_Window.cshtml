    function PaymentItem_Vehicle(evt) {
        if (evt.ctrlKey && evt.keyCode == 83)//ctrl+s save
        {
            evt.preventDefault();
            if ("@Model.Tag" == "_New" || "@Model.Tag" == "_Edit" || "@Model.Tag" == "_New_From_Selection") {
                $("#Vehicle_Save").trigger("dxclick");
            }
        }
        else  if (evt.ctrlKey && evt.keyCode == 68)//ctrl+d delete
        {
            evt.preventDefault();
            if ("@Model.Tag" == "_Delete") {
                $("#Vehicle_Save").trigger("dxclick");
            }
        }
    }*@ //shortcuts
    var Vehiclies_Cmd_Make = "@Model.Cmd_Make";

    function Frm_Vehicle_Window_ChangeCmd_Ownership(e)
    {
        var evalue = $("#Cmd_Ownership").dxSelectBox("instance").option("value");
        if (evalue == "INSTITUTION")
        {
            $("#TextEdit1").dxTextBox("instance").option("visible", true);
            $("#TextEdit1").dxTextBox("instance").option("readOnly", true);
            $("#OwnList").dxDropDownBox("instance").reset();
            $("#OwnList").dxDropDownBox("instance").option("visible", false);
            $("#OwnList").dxDropDownBox("instance").option("disabled", true);            
            $("#But_ManageOwner").dxButton("instance").option("disabled", true);
        }
        else
        {
            $("#TextEdit1").dxTextBox("instance").option("visible", false);
            $("#OwnList").dxDropDownBox("instance").option("visible", true);
            $("#OwnList").dxDropDownBox("instance").option("disabled", false);
            if ("@isvisible" == "False")
            {
                $("#But_ManageOwner").dxButton("instance").option("disabled", false);
            }
        }
    }


    $("#Txt_PolicyNo").bind('paste', function (evt)
    {
        setTimeout(function ()
        {           
            evt.target.value = evt.target.value.replace(/[^a-zA-Z0-9-/?]/gi, '');
        });
    });
    $("#Txt_RegNo").bind('paste', function (evt)
    {
        if ($("#RAD_RegPattern").dxRadioGroup('instance').option("value") == "Other")
        {
            setTimeout(function ()
            {
                evt.target.value = evt.target.value.replace(/[^a-zA-Z0-9-/?]/gi, '');
            });
        }
    });

    $("#Txt_PolicyNo").keypress(function (e) {
        e = e || window.event;
        key = e.keyCode || e.which;
        //For Firefox
        if (key == 8 || key == 127 || key == 9)
            return true
        var txt = String.fromCharCode(key);
        var reg = /[a-zA-Z0-9-/?]/;
        if (reg.test(txt))
            return true;
        e.preventDefault();
        return false;
    });
    $("#Txt_RegNo").keypress(function (e) {

        if ($("#RAD_RegPattern").dxRadioGroup('instance').option("value") == "Other") {
            e = e || window.event;
            key = e.keyCode || e.which;
            //For Firefox
            if (key == 8 || key == 127 || key == 9)
                return true
            var txt = String.fromCharCode(key);
            var reg = /[a-zA-Z0-9-/?]/;
            if (reg.test(txt))
                return true;
            e.preventDefault();
            return false;
        }
    });

    function OnChange_RAD_RegPattern(e)
    {

        var value = $("#RAD_RegPattern").dxRadioGroup('instance').option("value");
        var Txt_RegNo = $("#Txt_RegNo").dxTextBox("instance");
        Txt_RegNo.reset();
        if (value == "New")
        {
            $("#payment_vehicle_registration").text("Registration No.(New Pattern)");
            Txt_RegNo.option
                ({
                    "mask": 'AA-NN-AA-NNNN',
                    "maskRules":
                    {
                        'A': /[A-Za-z]/,
                        'N': /[0-9]/
                    }
                });
           Txt_RegNo.option("isValid", true);

        }
        else if (value == "Old")
        {
            $("#payment_vehicle_registration").text("Registration No.(Old Pattern)");
            Txt_RegNo.option({
                "mask": 'AAA-NNNN',
                "maskRules": {
                    'A': /[A-Za-z]/,
                    'N': /[0-9]/
                }
            });
            Txt_RegNo.option("isValid", true);

        } else if (value == "Other")
        {
            $("#payment_vehicle_registration").text("Registration No.(Other Pattern)");
            Txt_RegNo.option("mask", '');
            Txt_RegNo.option("maskRules", {});
            Txt_RegNo.option("maxLength", 15);
            Txt_RegNo.option("isValid", true);
        }
    }
    function OnChange_Chk_OtherDoc(e)
    {
        if (e.value == "True" || e.value == true)
        {
            $("#Txt_OtherDoc").dxTextBox("instance").option("disabled", false);
            $("#Txt_OtherDoc").dxTextBox("instance").reset();
            $("#Txt_OtherDoc").dxTextBox("instance").focus();
        }
        else
        {
            $("#Txt_OtherDoc").dxTextBox("instance").option("disabled", true);
            $("#Txt_OtherDoc").dxTextBox("instance").option("value", "");
        }
    }

</script>
<script>
    var LocList_vehicle_DG;
    var Owner_DG;
    var dataSource_VehLocation_PrfPay = null;
    var dataSource_VehOwner_PrfPay = null;
    var dataSource_VehModel_PrfPay = null;
    async function LookUp_GetLocList_Vehicle(FirstCall = false)
    {
        var $LocList_vehicle_DG = $("#Frm_Window_GLookUp_LocList_datagrid");
        if ($LocList_vehicle_DG.length)
        {
            LocList_vehicle_DG = $LocList_vehicle_DG.dxDataGrid("instance");
            if (FirstCall === false)
            {
                ShowLoader();
                var DDvalue = $("#LocList").dxDropDownBox("instance").option("value");
                $.ajax({
                    type: 'GET',
                    url: "/Account/ProfilePaymentVoucher/RefreshLocationList",
                    cache: false,
                    success: function (data)
                    {
                        dataSource_VehLocation_PrfPay = new DevExpress.data.DataSource({ // need to dispose it in in clearreference
                            store:
                            {
                                type: "array",
                                key: "AL_ID",
                                data: data
                            }
                        });
                        $("#LocList").dxDropDownBox("instance").option("dataSource", dataSource_VehLocation_PrfPay);
                        LocList_vehicle_DG.option("dataSource", dataSource_VehLocation_PrfPay);
                        dataSource_VehLocation_PrfPay.load().done((r) =>
                        {
                            $("#LocList").dxDropDownBox("reset");
                            if (data.some(data => data.AL_ID === DDvalue))
                            {
                                $("#LocList").dxDropDownBox("instance").option("value", DDvalue);
                            }
                            VehLocation_Settings_PrfPay(FirstCall);
                            $("#LocList").dxDropDownBox("focus")
                            HideLoader();
                        })
                    }
                });
            }
            else
            {
                VehLocation_Settings_PrfPay(FirstCall);
            }
        }
    }
    async function VehLocation_Settings_PrfPay(FirstCall)
        {
            var DGItem = GetDataSourceItems("LocList", "dxDropDownBox");
            var TotalCount = DGItem.length;
            if (TotalCount == 1)
            {
                if (FirstCall === true)
                {
                    await Frm_Vehicle_Window_LocList_OnValueChanged();
                }
                else
                {
                    $("#LocList").dxDropDownBox("instance").option("value", DGItem[0].AL_ID);
                }
                Control_SetReadOnly("LocList", "dxDropDownBox", true, "#696969");
            }
            else
            {
                Control_SetReadOnly("LocList", "dxDropDownBox", false);
            }
            if (TotalCount > 1)
            {
                $("#payment_vehicle_location").addClass("text-red");
            }
            else
            {
                $("#payment_vehicle_location").removeClass("text-red");
            }
        }
    async function Frm_Vehicle_Window_LocList_OnValueChanged(e)
    {
        var LocID;
        if (e)
        {
            LocID = e.value;
            if (e.value == null && e.previousValue != null)
            {
                LocList_vehicle_DG.clearSelection();
                return;
            }
        }
        else
        {
            LocID = $("#LocList").dxDropDownBox("instance").option("value");
        }
        await LocList_vehicle_DG.selectRows(LocID);
    }
    function Vehicle_addLocation(e)
    {
         if ("@ProfileCore__AddRight" == "False")
         {
             DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
             return;
        }
        ShowLoader();
         $.ajax({
             type: 'GET',
             url: "/Account/ProfilePaymentVoucher/AddLocations_Check",
             data: { ActionMethod: "New" },
             cache: false,
             success: function (data)
             {
                 HideLoader();
                 if (data.result)
