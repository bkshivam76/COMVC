    function MakeCustomItemCreating_Vehicle(e)
    {
        if (e.text == null || e.text.length == 0) {
            e.customItem = null;
            return;
        }
        var dataSource = e.component.getDataSource();
        var newItem = { Name: e.text, ID: e.text };
        var result = dataSource.store().insert(newItem);

        result.done(function ()
        {
            dataSource.reload().done(function ()
            {
                e.component.option("value", e.text);
                Vehiclies_Cmd_Make = e.text;
                //Get_Vehicle_Model_List();
            });
        })
        e.customItem = result;
