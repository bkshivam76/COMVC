                         data: {
                             ActionMethod: "New",
                             PopupID: "PaymentAddLocation",
                             DropdownRefreshFunction: "LookUp_GetLocList_Vehicle"
                         },
                         cache: false,
                         success: function (data)
                         {
                             ShowLoader();
                             OpenPopup("PaymentAddLocation", "New ~ Location", null, "auto", 400, true, data);
