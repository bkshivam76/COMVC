


@using DevExtreme.AspNet.Data;
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid()
    .ID("DistrictList-datagrid").CustomDataGrid()
   
    .Columns(columns =>
    {
        columns.Add().DataField("R_DI_NAME").Caption("District");
        columns.Add().DataField("R_DI_CODE").Visible(false);
        columns.Add().DataField("R_DI_REC_ID").Visible(false);
    })
   
    .Selection(s => s.Mode(SelectionMode.Single))
  .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}")
)

