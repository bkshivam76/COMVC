                {
                    $("#lbl_rpt_Diff").text($("#iOffSet_Item").val() + ":")
                }
                else
                {
                    $("#lbl_rpt_Diff").text("Balance:")
                }
                Calc_Diff_Rpt();
            }
        }
        function Calc_Diff_Rpt()
        {
            var Rpt_Txt_Out_Standing = $("#Rpt_Txt_Out_Standing").dxNumberBox("instance").option("value");
            var RAD_ReceiptValue = $("#Rpt_RAD_Receipt").dxRadioGroup("instance").option("value");
            if ($("#iLink_ID").val().length > 0 && Rpt_Txt_Out_Standing > 0)
            {
                if (RAD_ReceiptValue == 1 || RAD_ReceiptValue == 2)
                {
                    var Rpt_Txt_Amount = parseFloat($("#Rpt_Txt_Amount").dxNumberBox("instance").option("value") ?? 0.00);
                    var Txt_Diff_Value = Rpt_Txt_Out_Standing - Rpt_Txt_Amount;
                    $("#Rpt_Txt_Diff").dxNumberBox("instance").option("value", parseFloat(Txt_Diff_Value));
                }
                else
                {
                    $("#Rpt_Txt_Diff").dxNumberBox("instance").reset();
                }
            }
            else
            {
                $("#Rpt_Txt_Diff").dxNumberBox("instance").reset();
            }
        }
        function Txt_Amount_EditValueChanged_Rpt()
        {
            Calc_Diff_Rpt();
        }
