                                    <div class="col-sm-10 prm mrb-2">
                                        @(Html.DevExtreme().TextBox().CustomTextBox(true,true).ID("Rpt_Txt_Ref_Branch").Name("Rpt_Txt_Ref_Branch").Value(Model.Rpt_Txt_Ref_Branch).Placeholder("Type Branch Name...").MaxLength(25).OnValueChanged("Txt_RefBranch_ValueChange_Rpt") )
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-12 col-md-4">
                                        <div class="row">
                                            <div class="col-sm-2 col-md-6 pll">
                                                <label id="lbl_rpt_Ref_No" class="control-label disabletxt" for="Rpt_Txt_Ref_No">Ref No.:</label>
                                            </div>
                                            <div class="col-sm-10 col-md-6 prm">
                                                @(Html.DevExtreme().TextBox().CustomTextBox(true,true).ID("Rpt_Txt_Ref_No").Name("Rpt_Txt_Ref_No").Value(Model.Rpt_Txt_Ref_No).Placeholder("Type No...").MaxLength(25).OnValueChanged("Txt_RefNo_ValueChange_Rpt") )
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-sm-12 col-md-4">
                                        <div class="row">
                                            <div class="col-sm-2 col-md-4 pll align-rts">
                                                <label id="lbl_rpt_Ref_Date" class="control-label disabletxt" for="Rpt_Txt_Ref_Date">Date:</label>
                                            </div>
                                            <div class="col-sm-10 col-md-8 prm">
                                                @(Html.DevExtreme().DateBox().CustomDateBox().ID("Rpt_Txt_Ref_Date").Name("Rpt_Txt_Ref_Date").Value(Model.Rpt_Txt_Ref_Date).Min(new DateTime(1900,1,1)) )
                                                @Html.ValidationMessageFor(model => model.Rpt_Txt_Ref_Date, "", new { @class = "text-red" })
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-sm-12 col-md-4">
                                        <div class="row">
                                            <div class="col-sm-2 col-md-5 pll">
                                                <label id="lbl_rpt_Ref_Cdate" class="control-label disabletxt" for="Rpt_Txt_Ref_CDate">Clearing Date :</label>
                                            </div>
