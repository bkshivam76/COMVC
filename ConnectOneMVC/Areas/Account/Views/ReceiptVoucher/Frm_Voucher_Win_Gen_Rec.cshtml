<script>
    async function Frm_Voucher_Win_Receipt_SaveClick(e)
    {
        var GetDialogResult = true;
        if (ValidateForm(e))
        {
            $("#IsAdjustmentEnable").val($("#Rpt_GLookUp_Adjustment").dxDropDownBox("instance").option("readOnly") || $("#rpt_LayoutControlItem11").prop("disabled") ? false : true);
            var form = $("#id_Receipt_Voucher_Form");
            if (e.component.option("text") == "Delete")
            {
                DeleteAfterConfirmation("@Model.Me_Text", "", form);      
            }
            else
            {
                if ("@Model.ActionMethod" == "_New" || "@Model.ActionMethod" == "_Edit" || "@Model.ActionMethod" == "_New_From_Selection")
                {
                    if ($("#iVoucher_Type").val().toUpperCase() == "RECEIPTS - INSTITUTE")
                    {
                        await CreateCustomConfirmDialog("Message...", "<b>Received from other Institute not allowed <font color='red'>without Head-Quarter Permission</font><br><br>Do you want To Continue...?</b>", true).show().done(function (dialogResult)
                        {
                            if (!dialogResult)
                            {
                                $("#Rpt_GLookUp_ItemList").dxDropDownBox("instance").focus();
                                GetDialogResult = false;
                                return;
                            }
                        });
                    }
                    if (GetDialogResult == true)
                    {
                        if ($("#Rpt_Txt_Slip_Count").dxNumberBox("instance").option("value") > 0)
                        {
                            var prompt_data = await CheckSliptxn_Rpt();
                            if (prompt_data.result == false)
                            {
                                await CreateCustomConfirmDialog("@Model.Me_Text", "Some Transaction(s) have been posted in deposit slip being used by you<br><br>Continue posting voucher using same Deposit Slip...?", true).show().done(function (dialogResult)
                                {
                                    if (!dialogResult)
                                    {
                                        GetDialogResult = false;
                                        return;
                                    }
                                });
                            }
                        }
                    }
                    if (GetDialogResult == true)
                    {
                        form.submit();
                    }
                }
            }
        }
    }
    function CheckSliptxn_Rpt()
    {
       return  $.ajax({
            type: 'POST',
            url: "/Account/ReceiptVoucher/CheckSlipNo",
            data:
            {
                SlipNo: $("#Rpt_Txt_Slip_No").dxNumberBox("instance").option("value"),
                BankId: $("#Rpt_GLookUp_BankList").dxDropDownBox("instance").option('value'),
                xMID: $("#xMID").val(),
                SlipCount: $("#Rpt_Txt_Slip_Count").dxNumberBox("instance").option("value")
            },
            cache: false
        });
    }
    function Frm_Voucher_Win_Gen_Rec_AjaxSuccessVoucherReceipt(data)
    {
        HideLoader();
        if (data.jsonParam.result == false)
        {
            if (data.jsonParam.closeform)
            {
                dontaskpopupcloseconfirmation = true;
                $("#Dynamic_Content_popup").dxPopup("hide");
            }
            if (data.jsonParam.refreshgrid)
            {
                RefreshGridView("@ViewBag.GridToRefresh");
            }
            var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
            alertclick.done(function (alertResult)
            {
                if (alertResult)
                {
                    if (data.jsonParam.focusid)
                    {
                        var id = "#" + data.jsonParam.focusid;
                        setTimeout(function ()
                        {
                            $(id).find('input').focus();
                        }, Timeout100);
                    }
                }
            });
        }
        else if (data.jsonParam.result == true)
        {
            dontaskpopupcloseconfirmation = true;
            var _ActiveTab_ID = $(".TabPanalMenu-tabs .active").attr("id");
            var SavealertClick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
            SavealertClick.done(function (result)
            {
                if (result)
                {
                    if ("@ViewBag.GridToRefresh" != "CashBookListGrid")
                    {
                        RefreshGridView("@ViewBag.GridToRefresh");
                    }
                    if (/*typeof CashBookListGrid !== 'undefined'*/ _ActiveTab_ID == "contact_Frm_Voucher_Info_CB")
                    {
                        AfterVoucherClose_CB($("#Rpt_Txt_V_Date").dxDateBox("instance").option("value"), "@Model.ActionMethod", IsUndefinedOrNull(data.CashbookGridPK) ? "" : data.CashbookGridPK);
                    }
                    else if (_ActiveTab_ID == "contact_Frm_Voucher_Info") {
                        AfterVoucherClose_VoucherEntry();
                    }
                    $("#Dynamic_Content_popup").dxPopup("hide");
                }
            });
        }
    }

</script>  @*Save Success and other functions*@
