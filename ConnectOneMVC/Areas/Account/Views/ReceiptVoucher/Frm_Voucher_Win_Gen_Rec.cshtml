    function RPT_cmdmode_validations()
    {
        $("#Rpt_Txt_Ref_No").dxTextBox({})
            .dxValidator({
                validationRules: [{
                    type: 'custom',
                    validationCallback: function (options)
                    {
                        var result = true;
                        var RPT_Cmd_Mode = $("#Rpt_Cmd_Mode").dxSelectBox('instance').option('value');
                        if (RPT_Cmd_Mode == "CHEQUE" || RPT_Cmd_Mode == "DD")
                        {
                            var reg = /^[0-9]{6,6}$/;
                            if (!(reg.test(options.value))) {
                                result = false
                            }
                        }
                        return result;
                    },
                    reevaluate:true,
                    message: 'Invalid Format (Need To Be of 6 Digits)'
                }],
                validationGroup: "Receipt_Voucher"
            });
        $("#Rpt_Txt_V_Date").dxDateBox({})
            .dxValidator({
                validationRules: [{
                    type: 'custom',
                    validationCallback: function (options)
                    {
                        return true;
                    },
                    reevaluate: true
                }],
                validationGroup: "Receipt_Voucher"
            });
    }
