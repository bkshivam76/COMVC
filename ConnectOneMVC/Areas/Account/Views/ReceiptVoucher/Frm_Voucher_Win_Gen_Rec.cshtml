                setTimeout(function () {
                    ShowLoader();
                    Rpt_GetSlipTxnCount().done(function (data) {
                        $("#Rpt_Txt_Slip_Count").dxNumberBox("instance").option("value", data.count);
                        HideLoader();
                    });
                }, 0);
            }
            else{
                $("#Rpt_Txt_Slip_Count").dxNumberBox("instance").reset();
            }            
        }
