                                                @(Html.DevExtreme().DateBox().CustomDateBox().ID("Rpt_Txt_Ref_CDate").Name("Rpt_Txt_Ref_CDate").Value(Model.Rpt_Txt_Ref_CDate).Min(new DateTime(1900, 1, 1)) )
                                                @Html.ValidationMessageFor(model => model.Rpt_Txt_Ref_CDate, "", new { @class = "text-red" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </fieldset>
                </div>
            </div>
        </div><!--[ref bank]-->
