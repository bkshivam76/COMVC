<div class="Receipt_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    @model ConnectOneMVC.Areas.Account.Models.ReceiptVoucherModel
    <style>
        .dx-radio-value-container {
            padding-left: 0px;
        }

        .dx-item-content {
            font-size: 11px;
        }

        .dx-radiogroup-horizontal .dx-radiobutton {
            margin-right: 10px;
        }

        .dx-radio-value-container {
            padding-right: 5px;
        }

        #Rpt_AddPArty .dx-icon {
            width: 32px;
            height: 32px;
            /*line-height: normal;
        left: 45px;
        top: -10px;
        bottom: 0;*/
        }

        #Rpt_ManageParty .dx-icon {
            width: 32px;
            height: 32px;
            /*  line-height: normal;
        left: 45px;
        top: -10px;
        bottom: 0;*/
        }

        #Rpt_ManageParty .dx-button-content {
            height: inherit;
            padding-top: 14px;
            padding-bottom: 14px;
            padding-left: 30px;
        }

        #Rpt_AddPArty .dx-button-content {
            height: inherit;
            padding-top: 14px;
            padding-bottom: 14px;
        }
        /*FCRA Related*/
        #ListSpecialVoucherRef_Rpt .dx-list-item-content {
            padding: 4.5px;
        }

        @@media screen and (min-width:767px){
            .align-rts{text-align:right}
        }
    </style>
    @{
        Html.EnableClientValidation();
        Html.EnableUnobtrusiveJavaScript();
        bool isdisabled = (Model.Tag == Common_Lib.Common.Navigation_Mode._View || Model.Tag == Common_Lib.Common.Navigation_Mode._Delete) ? true : false;

        bool RecVoucher_AddFacilityAddress = (bool)ViewData["RecVoucher_AddFacilityAddress"];
        bool RecVoucher_ListFacilityAddress = (bool)ViewData["RecVoucher_ListFacilityAddress"];
    }


<div id="Frm_Voucher_Win_Gen_Rec_popup">
    @using (Ajax.BeginForm("Frm_Voucher_Win_Gen_Rec_Save", "ReceiptVoucher",
                new AjaxOptions
                {
                    HttpMethod = "POST",
                    UpdateTargetId = "Frm_Voucher_Win_Gen_Rec_popup",
                    InsertionMode = InsertionMode.InsertAfter,
                    OnBegin = "AjaxBeginFormPost",
                    OnSuccess = "Frm_Voucher_Win_Gen_Rec_AjaxSuccessVoucherReceipt"
                },
                new
                {
                    id = "id_Receipt_Voucher_Form",
                    @class = "edit_form"
                }))
    {
        @Html.HiddenFor(x => x.ActionMethod)
        @Html.HiddenFor(x => x.Tag)
        @Html.HiddenFor(x => x.iTrans_Type)
        @Html.HiddenFor(x => x.iVoucher_Type)
        @Html.HiddenFor(x => x.iLed_ID)
        @Html.HiddenFor(x => x.iParty_Req)
        @Html.HiddenFor(x => x.iProfile)
        @Html.HiddenFor(x => x.iCond_Ledger_ID)
        @Html.HiddenFor(x => x.iMinValue)
        @Html.HiddenFor(x => x.iMaxValue)
        @Html.HiddenFor(x => x.iTDS_CODE)
        @Html.HiddenFor(x => x.iLink_ID)
        @Html.HiddenFor(x => x.iOffSet_ID)
        @Html.HiddenFor(x => x.iOffSet_Item)
        @Html.HiddenFor(x => x.xMID)
        @Html.HiddenFor(x => x.PartyList_REC_EDIT_ON)
        @Html.HiddenFor(x => x.Bank_REC_EDIT_ON)
        @Html.HiddenFor(x => x.IsAdjustmentEnable)
        @Html.HiddenFor(x => x.REF_OUTSTAND_NEXT_YEAR)
        @Html.HiddenFor(x => x.LastEditedOn)
        @Html.HiddenFor(x => x.Info_LastEditedOn)
        @Html.HiddenFor(x => x.xID)
        @Html.HiddenFor(x => x.lbl_Ref_No_Tag)
        @Html.HiddenFor(x => x.TitleX)
        @Html.HiddenFor(x => x.Me_Text)
        @Html.HiddenFor(x => x.Rpt_SplVchrReferenceSelected)
        @Html.HiddenFor(x => x.splVchrRefsCount_Rpt)
        @Html.HiddenFor(x => x.SelectedDepositSlipNo)
        @Html.HiddenFor(x => x.SelectedBankID)
        @Html.HiddenFor(x => x.SelectedRefBankID)

        using (Html.DevExtreme().ValidationGroup("Receipt_Voucher"))
        {
    <div class="container-fluid">
        <div class="full-width-header-bg">
            <div class="row">

                <div class="col-sm-8 pll">
                    <h3 class="popuphead"><i class="far fa-edit"></i> Receipt </h3>
                </div>
                <div class="col-sm-4 prm">
                    <h5 class="mand-txt-align"><i class="fas fa-info-circle"></i> Red Fields are mandatory</h5>
                </div>
                @Html.ValidationSummary(true, "", new { @class = "text-red" })
            </div>
        </div><!--[Header]-->
        <div class="row">
            <div class="col-sm-6">
                <div class="form-field">
                    <div class="row">
                        <div class="col-sm-4 pll">
                            @Html.Label("Item Name:", htmlAttributes: new { @class = "control-label text-red", @id = "lbl_rpt_itemname" })
                        </div>
                        <div class="col-sm-8 prm">
                            @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("Rpt_GLookUp_ItemList").Name("Rpt_GLookUp_ItemList").ValueExpr("ITEMID").DisplayExpr("ITEMNAME").ReadOnly(true).FocusStateEnabled(false).DataSource(Model.ItemList_DD_Data_Rpt, "ITEMID").Value(Model.Rpt_GLookUp_ItemList).Placeholder("Select Item...").OnValueChanged("GLookUp_ItemList_EditValueChanged_Rpt").ContentTemplate(@<text> @Html.Partial("Receipt_LookUp_GetItemList") </text>) )
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6">
                <div class="form-field">
                    <div class="row">
                        <div class="col-sm-4 pll">
                            @Html.Label("Voucher Date:", htmlAttributes: new { @class = "control-label text-red", @id = "lbl_rpt_vdate" })
                        </div>
                        <div class="col-sm-8 prm">
                            @(Html.DevExtreme().DateBox().CustomDateBox().ID("Rpt_Txt_V_Date").Name("Rpt_Txt_V_Date").Value(Model.Rpt_Txt_V_Date))
                        </div>
                    </div>
                </div>
            </div>
        </div><!--[row 1]-->
        <div class="row">
            <div class="col-sm-6">
                <div class="form-field">
                    <div class="row">
                        <div class="col-sm-4 pll">
                            @Html.Label("Head:", htmlAttributes: new { @class = "control-label", @id = "lbl_rpt_head" })
                        </div>
                        <div class="col-sm-8 prm">
                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("Rpt_BE_Item_Head").Name("Rpt_BE_Item_Head").ReadOnly(true).MaxLength(50).FocusStateEnabled(false))
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6">
                <div class="form-field">
                    <div class="row">
                        <div class="col-sm-4 pll">
                            @Html.Label("Voucher No:", htmlAttributes: new { @class = "control-label", @id = "lbl_rpt_vno" })
                        </div>
                        <div class="col-sm-8 prm">
                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("Rpt_Txt_V_NO").Value(Model.Rpt_Txt_V_NO).Name("Rpt_Txt_V_NO").ReadOnly(true).MaxLength(50).FocusStateEnabled(false))
                        </div>
                    </div>
                </div>
            </div>
        </div><!--[row 2]-->
        <div class="row">
            <div class="col-sm-12">
                <div class="form-field">
                    <fieldset id="rpt_partydetails" class="default-fieldset">
                        <legend class="custom-legend mlm"> Party Detail:</legend>
                        <div class="row">
                            <div class="col-sm-8" id="RptPartyDetail_div">
                                <div class="row ">
                                    <div class="col-sm-3 pll">
                                        <label class="control-label" id="lbl_rpt_partyname" for="Name">Name:</label>
                                    </div>
                                    <div class="col-sm-9 prm">
                                        @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("Rpt_GLookUp_PartyList1").Name("Rpt_GLookUp_PartyList1").ValueExpr("C_ID").DisplayExpr("C_NAME").Placeholder("Select Party Name...").DataSource(Model.PartyList_DD_Data_Rpt, "C_ID").Value(Model.Rpt_GLookUp_PartyList1).ReadOnly(true).FocusStateEnabled(false).OnValueChanged("GLookUp_PartyList1_EditValueChanged_Rpt").ContentTemplate(@<text> @Html.Partial("LookUp_GetPartyList") </text>) )
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-3 pll">
                                        <label class="control-label" id="lbl_rpt_city" for="Name">City:</label>
                                    </div>
                                    <div class="col-sm-4 prm">
                                        @(Html.DevExtreme().TextBox().CustomTextBox().ID("Rpt_BE_City").Name("Rpt_BE_City").Value(Model.Rpt_BE_City).ReadOnly(true).FocusStateEnabled(false))
                                    </div>
                                    <div class="col-sm-2 pll align-rts">
                                        <label class="control-label" id="lbl_rpt_pan" for="Name">PAN No.:</label>
                                    </div>
                                    <div class="col-sm-3 prm">
                                        @(Html.DevExtreme().TextBox().CustomTextBox().ID("Rpt_BE_PAN_No").Name("Rpt_BE_PAN_No").Value(Model.Rpt_BE_PAN_No).ReadOnly(true).FocusStateEnabled(false))
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-2" id="Rpt_AddPartyDiv">
                                @(Html.DevExtreme().Button().ID("Rpt_AddPArty").Text("Add Party").Width("100%").Height("inherit").OnClick("Rpt_AddParty").Icon(Url.Content("../../../../Icons/add user.png")).Disabled(Model.ActionMethod=="_View"|| Model.ActionMethod == "_Delete") )
                            </div>
                            <div class="col-sm-2" id="Rpt_ManPartyDiv">
                                @(Html.DevExtreme().Button().ID("Rpt_ManageParty").Text("Manage Party").Width("100%").Height("inherit").OnClick("Rpt_Manage_party").Icon(Url.Content("../../../../Icons/manage user.png")).Disabled(Model.ActionMethod == "_View" || Model.ActionMethod == "_Delete"))
                            </div>
                        </div>
                    </fieldset>
                </div>
            </div>
        </div><!--[party]-->
        <div class="row">
            <div class="col-sm-12">
                <div class="form-field">
                    <fieldset id="rpt_LayoutControlItem11" class="default-fieldset">
                        <legend id="lbl_Adjust_Title" class="custom-legend mlm disabletxt"> Adjustment Reference:</legend>
                        <div class="row">
                            <div class="col-sm-6">
                                <div class="row">
                                    <div class="col-sm-4 pll">
                                        <label class="control-label disabletxt" id="lbl_rpt_Payment" for="Name">Payment:</label>
                                    </div>
                                    <div class="col-sm-8 prm">
                                        @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("Rpt_GLookUp_Adjustment").Name("Rpt_GLookUp_Adjustment").ValueExpr("REF_ID").DisplayExpr("REF_AMT").DataSource(Model.PaymentList_DD_Data_Rpt,"REF_ID").Value(Model.Rpt_GLookUp_Adjustment).Placeholder("Select Payment").ReadOnly(true).FocusStateEnabled(false).OnValueChanged("GLookUp_Adjustment_EditValueChanged_Rpt").ContentTemplate(@<text> @Html.Partial("Party_Outstanding_DepositsAndOutstanding_Advances") </text>) )

                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-4 pll">
                                        <label class="control-label disabletxt" id="lbl_rpt_Receipt" for="Name">Receipt Type:</label>
                                    </div>
                                    <div class="col-sm-8">
                                        <div class="radiobtn-outer2">
                                            @(Html.DevExtreme().RadioGroup().ID("Rpt_RAD_Receipt").Name("Rpt_RAD_Receipt").DisplayExpr("text").Layout(DevExtreme.AspNet.Mvc.Orientation.Horizontal).ValueExpr("value").Value(Model.Rpt_RAD_Receipt).DataSource(new object[] { new { text = "PARTIAL", value = 0 }, new { text = "FINAL", value = 1 }, new { text = "NILL", value = 2 } }).OnValueChanged("RAD_Receipt_SelectedIndexChanged_Rpt") )

                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="row">
                                    <div class="col-sm-7 pll align-rts">
                                        <label class="control-label disabletxt" id="lbl_rpt_Out_Standing" for="Name">o---> Total Out-Standing Amount:</label>
                                    </div>
                                    <div class="col-sm-5 prm">
                                        @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Rpt_Txt_Out_Standing").Name("Rpt_Txt_Out_Standing").Value(Model.Rpt_Txt_Out_Standing).ReadOnly(true).Format("#.##").FocusStateEnabled(false))
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-7 pll align-rts">
                                        <label class="control-label disabletxt" id="lbl_rpt_Diff" for="Name">Difference:</label>
                                    </div>
                                    <div class="col-sm-5 prm">
                                        @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Rpt_Txt_Diff").Name("Rpt_Txt_Diff").ReadOnly(true).Format("#0.##").FocusStateEnabled(false))
                                    </div>
                                </div>
                            </div>
                        </div>
                    </fieldset>
                </div>
            </div>
        </div><!--[adj]-->
        <div class="row">
            <div class="col-sm-6">
                <div class="form-field">
                    <div class="row">
                        <div class="col-sm-4 pll">
                            @Html.Label("Mode:", htmlAttributes: new { @class = "control-label text-red", @id = "lbl_rpt_mode" })
                        </div>
                        <div class="col-sm-8 prm">
                            @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("Rpt_Cmd_Mode").Name("Rpt_Cmd_Mode").Value(string.IsNullOrWhiteSpace(Model.Rpt_Cmd_Mode)?"CASH": Model.Rpt_Cmd_Mode).DataSource(new[] { "CASH", "CHEQUE", "DD", "CBS", "RTGS", "NEFT", "ECS", "BANK ACCOUNT", "CASH TO BANK" }).OnValueChanged("Receipt_Cmd_Mode_SelectedIndexChanged_Rpt").ShowClearButton(false) )

                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6">
                <div class="form-field">
                    <div class="row">
                        <div class="col-sm-4 pll">
                            @Html.Label("Amount:", htmlAttributes: new { @class = "control-label text-red", @id = "lbl_rept_amount" })
                        </div>
                        <div class="col-sm-8 prm">
                            @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Rpt_Txt_Amount").Name("Rpt_Txt_Amount").Placeholder("Type Amount...").OnValueChanged("Txt_Amount_EditValueChanged_Rpt").Format("#0.00").Min(0.00))

                        </div>
                    </div>
                </div>
            </div>
        </div><!--[mode]-->
        <div class="row">
            <div class="col-sm-12">
                <div class="form-field">
                    <fieldset id="rpt_LayoutControlItem3" class="default-fieldset">
                        <legend id="lbl_rpt_Ref_Title" class="custom-legend mlm disabletxt"> Reference Detail:</legend>
                        <div class="row">
                            <div class="col-sm-12 col-md-12 ">
                                <div class="row">
                                    <div class="col-sm-2 pll">
                                        <label id="lbl_rpt_Ref_Bank" class="control-label disabletxt" for="Rpt_GLookUp_RefBankList">Bank Name:</label>
                                    </div>
                                    <div class="col-sm-10 prm mrb-2">
                                        @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("Rpt_GLookUp_RefBankList").Name("Rpt_GLookUp_RefBankList").ValueExpr("BI_ID").DisplayExpr("BI_BANK_NAME")
                                                      .DataSource(Model.RefBankList_DD_Data_Rpt, "BI_ID").Value(Model.Rpt_GLookUp_RefBankList).Placeholder("Select Bank...").FocusStateEnabled(false).ReadOnly(true).OnValueChanged("GLookUp_RefBankList_EditValueChanged_Rpt").ContentTemplate(@<text> @Html.Partial("ReceiptLookUp_GetRefBankList") </text>) )
                                    </div>

                                </div>
                                <div class="row">
                                    <div class="col-sm-2 pll">
                                        <label id="lbl_rpt_Ref_Branch" class="control-label disabletxt" for="Rpt_Txt_Ref_Branch">Branch Name:</label>
