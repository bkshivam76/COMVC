
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("Frm_Voucher_Win_Gen_Rec_Receipt_LookUp_GetAdjustmentList_datagrid")
 
    .Columns(columns =>
    {
        columns.Add().DataField("REF_ID").Caption("REF_ID").Visible(false);
        columns.Add().DataField("REF_ITEM").Caption("Reference Item Name");
        columns.Add().DataField("REF_DATE").Caption("Date").DataType(GridColumnDataType.Date).Format("dd/MM/yyyy");
        columns.Add().DataField("REF_AMT").Caption("Payment").DataType(GridColumnDataType.Number).Format("#0.00");
        columns.Add().DataField("REF_ADDITION").Caption("Addition").Format("#0.00");
        columns.Add().DataField("REF_ADJUSTED").Caption("Adjusted").Format("#0.00");        
        columns.Add().DataField("REF_REFUND").Caption("Refund").Format("#0.00");
        columns.Add().DataField("REF_OUTSTAND").Caption("Out-Standing").Format("#0.00");
        columns.Add().DataField("REF_PURPOSE").Caption("Purpose");
        columns.Add().DataField("REF_OTHER_DETAIL").Caption("Other Details");
        columns.Add().DataField("REF_OUTSTAND_NEXT_YEAR").Caption("REF_OUTSTAND_NEXT_YEAR").Visible(false);
    })

    .Selection(s => s.Mode(SelectionMode.Single))
    .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}")
)