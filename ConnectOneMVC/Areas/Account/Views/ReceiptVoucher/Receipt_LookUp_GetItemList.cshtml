
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("Frm_Voucher_Win_Gen_Rec_Receipt_LookUp_GetItemList_datagrid")
    .DataSource(new JS(@"component.option(""dataSource"")"))
    .Columns(columns =>
    {
        columns.Add().DataField("ITEMID").Caption("ID").Visible(false);
        columns.Add().DataField("ITEMNAME").Caption("Name");
        columns.Add().DataField("LED_NAME").Caption("Head");
        columns.Add().DataField("ITEM_TRANS_TYPE").Caption("ITEM_TRANS_TYPE").Visible(false);
        columns.Add().DataField("ITEM_LED_ID").Caption("ITEM_LED_ID").Visible(false);
        columns.Add().DataField("ITEM_VOUCHER_TYPE").Caption("ITEM_VOUCHER_TYPE").Visible(false);
        columns.Add().DataField("ITEM_PARTY_REQ").Caption( "ITEM_PARTY_REQ").Visible(false);
        columns.Add().DataField("ITEM_PROFILE").Caption("ITEM_PROFILE").Visible(false);
        columns.Add().DataField("ITEM_CON_LED_ID").Caption("ITEM_CON_LED_ID").Visible(false);
        columns.Add().DataField("ITEM_CON_MIN_VALUE").Caption("ITEM_CON_MIN_VALUE").Visible(false);
        columns.Add().DataField("ITEM_CON_MAX_VALUE").Caption("ITEM_CON_MAX_VALUE").Visible(false);
        columns.Add().DataField("ITEM_TDS_CODE").Caption("ITEM_TDS_CODE").Visible(false);
        columns.Add().DataField("ITEM_LINK_REC_ID").Caption("ITEM_LINK_REC_ID").Visible(false);
        columns.Add().DataField("ITEM_OFFSET_REC_ID").Caption("ITEM_OFFSET_REC_ID").Visible(false);
        columns.Add().DataField("ITEM_OFFSET_NAME").Caption("ITEM_OFFSET_NAME").Visible(false);
    })

    .Selection(s => s.Mode(SelectionMode.Single))
    .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}")
)



