    function Get_Asset_Item_SaleA(e)
    {
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Account/SaleAsset/Get_Asset_Items",
            async: false,
            data:
            {
                Profile: e.value,
                ActionMethod: "@Model.ActionMethod",
                xMID: $("#xMID").val()
            },
            cache: false,
            success:
                function (data)
                {
                    if (data.result == true)
                    {
                        GLookUp_Get_AssetList_SaleA();
                    }
                    else
                    {
                        DevExpress.ui.dialog.alert(data.message, "Error..");
                    }
                }
        });
        HideLoader();
    }
