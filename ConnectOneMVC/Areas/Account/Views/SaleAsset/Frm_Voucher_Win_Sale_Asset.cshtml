    <script>

    async function LookUp_GetItemList_SaleA(FirstCall = false)
    {
        if (FirstCall === false) {
            ItemDDRefresh_SaleA = true;
            await Item_Name_SaleA_DG.refresh();
            ItemDDRefresh_SaleA = false;
        }
        var TotalCount = Item_Name_SaleA_DG.totalCount();
        if (TotalCount < 0) //dd has not been loaded so total count will return -1 in this case
        {
            var ds = $("#GLookUp_ItemList_SaleA").dxDropDownBox("getDataSource");
            var store = ds.store();
            TotalCount = await store.totalCount();
        }
        if (TotalCount == 1) {
            $("#GLookUp_ItemList_SaleA").find('input').css('color', '#000080');
            if ("@Model.ActionMethod" == "_New" || "@Model.ActionMethod" == "_New_From_Selection") {
                await Item_Name_SaleA_DG.selectRowsByIndexes(0);
                Control_SetReadOnly("GLookUp_ItemList_SaleA", "dxDropDownBox", true);
            }
        }
        else {
            if ("@Model.ActionMethod" == "_New" || "@Model.ActionMethod" == "_New_From_Selection") {
                Control_SetReadOnly("GLookUp_ItemList_SaleA", "dxDropDownBox", false);
            }
        }
    }
