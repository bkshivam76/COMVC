                if ($("#Cmb_Asset_Type_SaleA").dxSelectBox("instance").option("value") == "GOLD" || $("#Cmb_Asset_Type_SaleA").dxSelectBox("instance").option("value") == "SILVER") {
                    $("#Txt_Qty_SaleA").dxNumberBox("instance").option("format", "#0.000");
