                    $("#Txt_CurQty_SaleA").dxNumberBox("instance").option("format", "#");
                }
                $("#Txt_Qty_SaleA").dxNumberBox("instance").reset();
                $("#REF_AMT").val(item["REF_AMT"]);
                $("#Txt_Desc_SaleA").dxTextBox("instance").option("value", item["REF_DESC"]);
                $("#Txt_CurQty_SaleA").dxNumberBox("instance").option("value", item["REF_QTY"]);
                $("#REF_QTY").val(item["REF_QTY"]);
                $("#GLookUp_AssetList_Text_SaleA").val(item["REF_ITEM"]);
                $("#iLed_ID").val(item["REF_LED_ID"]);
                $("#REF_CREATION_or_Purchase_Date").val(item["REF_CREATION_DATE"]);
