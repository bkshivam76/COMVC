@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid()
    .ID("GLookUp_PartyList1_SaleA_datagrid")
    .CustomDataGrid()
    .Columns(columns =>
    {
        columns.Add().DataField("C_NAME").Caption("Name").SortOrder(SortOrder.Asc);
        columns.Add().DataField("C_PAN_NO").Caption("PAN No.").Visible(false);
        columns.Add().DataField("C_CITY").Caption("City").Visible(false);
        columns.Add().DataField("C_ID").Caption("C_ID").Visible(false);
        columns.Add().DataField("REC_EDIT_ON").Caption("REC_EDIT_ON").Visible(false);
    })
    .Selection(s => s.Mode(SelectionMode.Single))    
)

