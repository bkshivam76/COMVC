
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid()
    .ID("Frm_Voucher_Win_SaleAsset_GLookUp_AssetList_datagrid")
    .DataSource(new JS(@"component.option(""dataSource"")"))
    .Columns(columns =>
    {
        columns.Add().DataField("REF_ITEM").Caption("REF_ITEM").Width(0);
        columns.Add().DataField("REF_ITEM_ID").Caption("REF_ITEM_ID").Width(200);
        columns.Add().DataField("REF_QTY").Caption("REF_QTY").Width(200);
        columns.Add().DataField("REF_DESC").Caption("REF_DESC").Width(200);
        columns.Add().DataField("REF_MISC_ID").Caption("REF_MISC_ID").Width(200);
        columns.Add().DataField("REF_LED_ID").Caption("REF_LED_ID").Width(200);
        columns.Add().DataField("REF_TRANS_TYPE").Caption("REF_TRANS_TYPE").Width(0);
        columns.Add().DataField("REF_ID").Caption("REF_ID").Width(0);
        columns.Add().DataField("SALE_QTY").Caption("SALE_QTY").Width(0);
        //columns.Add().DataField("REF_LOC_ID").Caption("REF_LOC_ID").Width(200);
        //columns.Add().DataField("REF_OWNERSHIP").Caption("REF_OWNERSHIP").Width(200);
        //columns.Add().DataField("REF_OWNERSHIP_ID").Caption("REF_OWNERSHIP_ID").Width(0);
        //columns.Add().DataField("REF_USE").Caption("REF_USE").Width(0);
        columns.Add().DataField("REF_AMT").Caption("REF_AMT").Width(0);
        columns.Add().DataField("REC_EDIT_ON").Caption("REC_EDIT_ON").Width(0);
        columns.Add().DataField("REF_CREATION_DATE").Caption("REF_CREATION_DATE").Width(0);
        columns.Add().DataField("ITEM_CON_LED_ID").Caption("ITEM_CON_LED_ID").Width(200);
        //columns.Add().DataField("ITEM_CON_MIN_VALUE").Caption("ITEM_CON_MIN_VALUE").Width(0);
        //columns.Add().DataField("ITEM_CON_MAX_VALUE").Caption("ITEM_CON_MAX_VALUE").Width(0);
        columns.Add().DataField("AI_TYPE").Caption("AI_TYPE").Width(0);
    })
    .HoverStateEnabled(true)
    .Paging(p => p.PageSize(100))
    .FilterRow(f => f.Visible(true))
    .Scrolling(s => s.Mode(GridScrollingMode.Infinite))
    .Height(300)
    .Selection(s => s.Mode(SelectionMode.Single))
    .SelectedRowKeys(new JS(@"[component.option(""value"")]"))
    .OnSelectionChanged(@<text>
        function(selectedItems) {

        var keys = selectedItems.selectedRowKeys;
        component.option("value", keys);
        }
    </text>)
)