@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
}

@(Html.DevExtreme().DataGrid().CustomDataGridListing((int)ViewBag.ShowHorizontalBar)
    .ID("TdsRegisterGrid")
    .DataSource(d => d.Mvc().Controller("TDSRegister").LoadAction("Tds_Register_Grid_Data").LoadMode(DataSourceLoadMode.Raw))
    .Columns(columns =>
    {
        columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false).AllowGrouping(false);
        columns.Add().Caption("Particulars").Alignment(HorizontalAlignment.Left).CssClass("dxDatagridHeaderBand").AllowGrouping(false).IsBand(true)
        .Columns
        (
            s =>
            {
                s.Add().DataField("Center").Caption("Center");
                s.Add().DataField("UID").Caption("UID");
                s.Add().DataField("PARTY").Caption("Party");
                s.Add().DataField("PAN").Caption("PAN");
            }
        );
        columns.Add().Caption("TDS Deduction").Alignment(HorizontalAlignment.Center).CssClass("dxDatagridHeaderBand").AllowGrouping(false).IsBand(true)
        .Columns
        (
            s =>
            {
                s.Add().DataField("TDS_CODE").Caption("TDS Code");
                s.Add().DataField("ACTUAL_DED_DATE").Caption("Actual Ded Date").DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                s.Add().DataField("DECLARED_DED_DATE").Caption("Declared Ded Date").DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                s.Add().DataField("BILL").Caption("Bill Amt").Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                s.Add().DataField("TDS_DED").Caption("TDS Ded").Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
            }
        );
        columns.Add().Caption("TDS Recd. At HQ").Alignment(HorizontalAlignment.Center).CssClass("dxDatagridHeaderBand").AllowGrouping(false).IsBand(true)
        .Columns
        (
            s =>
            {

                s.Add().DataField("RECD_DATE").Caption("Recd on").DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                s.Add().DataField("RECD_TDS").Caption("TDS").Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                s.Add().DataField("INTEREST_RECD_ON_TDS").Caption("Interest").Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                s.Add().DataField("PENALTY_RECD_ON_TDS").Caption("Penalty").Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
            }
        );
        columns.Add().Caption("TDS Paid to Govt.").Alignment(HorizontalAlignment.Center).CssClass("dxDatagridHeaderBand").AllowGrouping(false).IsBand(true)
        .Columns
        (
            s =>
            {
                s.Add().DataField("PAID_DATE").Caption("Paid on").DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                s.Add().DataField("PAID_TDS").Caption("TDS").Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                s.Add().DataField("INTEREST_PAID_ON_TDS").Caption("Interest").Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                s.Add().DataField("PENALTY_PAID_ON_TDS").Caption("Penalty").Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
            }
        );
        columns.Add().Caption("Balances").Alignment(HorizontalAlignment.Center).CssClass("dxDatagridHeaderBand").AllowGrouping(false).IsBand(true)
        .Columns
        (
        s =>
        {
            s.Add().DataField("Receivable_Center").Caption("Due from Center").Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
            s.Add().DataField("Received_Excess_Center").Caption("Excess Recd.").Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
        }
        );
        columns.Add().DataField("RECD_TDS_M_ID").Caption("RECD_TDS_M_ID").Visible(false);
        columns.Add().DataField("PAID_TDS_M_ID").Caption("PAID_TDS_M_ID").Visible(false);
        columns.Add().DataField("DED_TR_M_ID").Caption("DED_TR_M_ID").Visible(false);
        columns.Add().DataField("ACTION_STATUS").Caption("ACTION_STATUS").Visible(false);
        columns.Add().DataField("REC_ADD_BY").Caption("REC_ADD_BY").Visible(false);
        columns.Add().DataField("REC_ADD_ON").Caption("REC_ADD_ON").Visible(false).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss");
        columns.Add().DataField("REC_EDIT_BY").Caption("REC_EDIT_BY").Visible(false);
        columns.Add().DataField("REC_EDIT_ON").Caption("REC_EDIT_ON").Visible(false).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss");
        columns.Add().DataField("REC_STATUS_BY").Caption("REC_STATUS_BY").Visible(false);
        columns.Add().DataField("REC_STATUS_ON").Caption("REC_STATUS_ON").Visible(false).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss");
        columns.Add().DataField("DED_TR_SR_NO").Caption("DED_TR_SR_NO").Visible(false);
        columns.Add().DataField("RECD_TR_SR_NO").Caption("RECD_TR_SR_NO").Visible(false);
        columns.Add().DataField("PAID_TR_SR_NO").Caption("PAID_TR_SR_NO").Visible(false);
    })
    .Summary(s =>
    {
        s.TotalItems(item =>
        {
            item.Add().Name("BILL_BILL_sum").SummaryType(SummaryType.Sum).Column("BILL").ShowInColumn("BILL").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
            item.Add().Name("TDS_DED_TDS_DED_sum").SummaryType(SummaryType.Sum).Column("TDS_DED").ShowInColumn("TDS_DED").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
            item.Add().Name("RECD_TDS_RECD_TDS_sum").SummaryType(SummaryType.Sum).Column("RECD_TDS").ShowInColumn("RECD_TDS").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
            item.Add().Name("INTEREST_RECD_ON_TDS_INTEREST_RECD_ON_TDS_sum").SummaryType(SummaryType.Sum).Column("INTEREST_RECD_ON_TDS").ShowInColumn("INTEREST_RECD_ON_TDS").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
            item.Add().Name("PENALTY_RECD_ON_TDS_PENALTY_RECD_ON_TDS_sum").SummaryType(SummaryType.Sum).Column("PENALTY_RECD_ON_TDS").ShowInColumn("PENALTY_RECD_ON_TDS").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
            item.Add().Name("PAID_TDS_PAID_TDS_sum").SummaryType(SummaryType.Sum).Column("PAID_TDS").ShowInColumn("PAID_TDS").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
            item.Add().Name("INTEREST_PAID_ON_TDS_INTEREST_PAID_ON_TDS_sum").SummaryType(SummaryType.Sum).Column("INTEREST_PAID_ON_TDS").ShowInColumn("INTEREST_PAID_ON_TDS").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
            item.Add().Name("PENALTY_PAID_ON_TDS_PENALTY_PAID_ON_TDS_sum").SummaryType(SummaryType.Sum).Column("PENALTY_PAID_ON_TDS").ShowInColumn("PENALTY_PAID_ON_TDS").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
            item.Add().Name("Receivable_Center_Receivable_Center_sum").SummaryType(SummaryType.Sum).Column("Receivable_Center").ShowInColumn("Receivable_Center").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
            item.Add().Name("Received_Excess_Center_Received_Excess_Center_sum").SummaryType(SummaryType.Sum).Column("Received_Excess_Center").ShowInColumn("Received_Excess_Center").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));

        });
    })
    .OnContextMenuPreparing("TdsRegister_ContextMenuPreparing")
    .OnContentReady("TdsRegister_OnContentReady")
    .OnInitialized("TdsRegister_OnInitialized")

)