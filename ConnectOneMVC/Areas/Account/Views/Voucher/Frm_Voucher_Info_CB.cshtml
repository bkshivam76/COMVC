                CB_AllowCellMerge = false;
                await CashBookListGrid.PerformCallback({ "_ActiveFilterString": CB_ActiveFilterString, "GetLatestData": false, "ShowHorizontalBar": CB_ShowHorizontalBar, "AllowCellMerge": CB_AllowCellMerge});
