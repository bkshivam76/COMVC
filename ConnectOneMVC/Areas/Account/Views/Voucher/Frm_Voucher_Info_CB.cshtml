    <script>
    //"use strict";

    var CashBook_NestedRowUniqueID;
    var CashBookSearchVisible = true;
    var CashBookFilterVisible = true;
    var CB_IsDetailRowExpanded = false;
    var CB_ExpandedRowIndex = -1;
    var CBGrid_PageSize;
    var CB_SearchPanelExp = "";
    var Grid_Display_AfterActionItemClick_Count = 0;
    var CB_GridLayout = null;
    var CashbookFocusedRowIndexBeforeRefresh;
    var CB_Select_xID = "";
    var CashBookPageData;
    var CB_ColumnToBeShownIndex = "";
    var CB_ColumnToBeHidddenIndex = "";
    var CB_PageChangeAfterPeriodChange = false;
    var CB_Prev_TempID = null;
    function CB_Grid_init(s, e)
    {
        CB_grid_AdjustSize(s, e);
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt)
        {
            CB_grid_AdjustSize(s, e);
        });
        s.SetFocusedRowIndex(-1);
        $(".CashBookListGrid_PreviewRow").hide();
    }
    function CB_ContextMenuOpen(s, e)
    {
        if (e.objectType == "row")
        {
            s.SetFocusedRowIndex(e.index);
        }
    }
    function CB_Grid_begincallback(s, e)
    {
        CashbookFocusedRowIndexBeforeRefresh = s.GetFocusedRowIndex();
        e.customArgs["command"] = e.command;
        e.customArgs["_ActiveFilterString"] = CB_ActiveFilterString;
        e.customArgs["ShowHorizontalBar"] = CB_ShowHorizontalBar;
        e.customArgs["AllowCellMerge"] = CB_AllowCellMerge;
        e.customArgs["ViewMode"] = CBGrid_ViewMode;
        e.customArgs["VouchingMode"] = CB_IsVouchingMode;
        e.customArgs["ColumnToBeShownIndex"] = CB_ColumnToBeShownIndex;
        e.customArgs["ColumnToBeHidddenIndex"] = CB_ColumnToBeHidddenIndex;
        e.customArgs["RowKeyToFocus"] = CB_Select_xID;
        e.customArgs["showDynamicBankColumns"] = CB_ShowDynamicBankColumns;
        if (e.command == "REFRESH")
        {
            e.customArgs["PageIndex"] = CB_Grid_PageIndex;
        }
    }
    function CB_Grid_endcallback(s, e)
    {
        CashBookPageData = s.cpPagedata;
        CB_ColumnToBeShownIndex = s.cpColumnToBeShownIndex;
        CB_ColumnToBeHidddenIndex = s.cpColumnToBeHidddenIndex;
        $("#CashBookListGrid").hover(function () {
            CashBookListGrid.Focus();
        })
        if (CB_IsVouchingMode==true)
        {
            $(".CashBookListGrid_PreviewRow").hide();
        }
        else
        {
            if ($("#But_Narration").dxButton("instance").option("text") == "Hide Narration")
            {
                $(".CashBookListGrid_PreviewRow").show();
            }
            else
            {
                $(".CashBookListGrid_PreviewRow").hide();
            }
        }
        GetSessionStorage("CashBookListGrid");
        CB_ActiveFilterString = s.cpFilterExpression;
        CB_SearchPanelExp = s.cpSearchPanelExpression;
        CB_GridLayout = s.cpClientLayout;
        if ($('#CashBookListGrid_DXFilterRow').is(":visible"))
        {
            CashBookFilterVisible = false;
        }
        else
        {
            CashBookFilterVisible = true;
        }
        if ($('#CashBookListGrid_DXSearchPanel').is(":visible")) {
            CashBookSearchVisible = false;
        }
        else {
            CashBookSearchVisible = true;
        }
        $("#CB_BE_Cash_Bank").text(s.cpCashBankText);
        CBGrid_PageSize = s.cpPageSize;
        CB_Grid_PageCount = s.GetPageCount();
        CB_Grid_PageIndex = s.GetPageIndex();
        SendCustomArgs_FilterControl(s, e);
        if (e.command == "GOTOPAGE")
        {
            if (CB_PageChangeAfterPeriodChange == false)
            {
                CashBookListGrid.ExpandDetailRow(CB_Next_Unattended_Attachment_Index);
            }
            else
            {
                CB_PageChangeAfterPeriodChange = false;
            }
        }
        else if (e.command == "REFRESH")
        {
            if (/*CB_IsVouchingMode == true &&*/ CB_Grid_Display_AfterPeriodChange == false && (CB_Grid_Display_AfterActionItemClick == false || CB_IsToBeAuto == false)) //Redmine Bug #134875 fix //Redmine Bug #135022 fix
            {
                if ((CashbookFocusedRowIndexBeforeRefresh == s.GetFocusedRowIndex() && CashbookFocusedRowIndexBeforeRefresh != -1) || (CashbookFocusedRowIndexBeforeRefresh > -1 && s.GetFocusedRowIndex()==-1))
                {
                    s.SetFocusedRowIndex(-1);
                    var Rowtofocus = -1;
                    if (CashbookFocusedRowIndexBeforeRefresh >= s.cpTotalRowCount)
                    {
                        Rowtofocus = s.cpTotalRowCount - 1;
                    }
                    else
                    {
                      Rowtofocus=CashbookFocusedRowIndexBeforeRefresh;
                    }
                    s.SetFocusedRowIndex(Rowtofocus);
                    s.MakeRowVisible(Rowtofocus);
                }
                CB_Select_xID = "";
            }
            if (CB_Grid_Display_AfterActionItemClick)
            {
                if ((CB_ActiveFilterString == null || CB_ActiveFilterString.length <= 0) && (CB_SearchPanelExp == null || CB_SearchPanelExp.length <= 0))
                {
                    if (CB_IsToBeAuto == true)
                    {
                        MoveToUnattendedDoc();
                    }
                    else
                    {
                        if (CB_NestedGrid_AccessID != null)
                        {
                            if (ASPxClientControl.GetControlCollection().GetByName(CB_NestedGrid_AccessID) != null) {
                                if (typeof ASPxClientControl.GetControlCollection().GetByName(CB_NestedGrid_AccessID) !== 'undefined')
                                {
                                    ASPxClientControl.GetControlCollection().GetByName(CB_NestedGrid_AccessID).SetFocusedRowIndex(-1);
                                    fab.SetActionContext("AddAttachmentContext", false);
                                }
                            }
                        }
                        if (CB_IsVouchingMode)
                        {
                            if (s.GetFocusedRowIndex() >= 0 && isSuperuserOrAuditor == true) {
                                fab.SetActionContext("AuditActionContext", true);
                            }
                            else { fab.SetActionContext("AddAttachmentContext", false);}
                        }
                    }
                }
                else
                {
                    if (CB_NestedGrid_AccessID != null)
                    {
                        if (ASPxClientControl.GetControlCollection().GetByName(CB_NestedGrid_AccessID) != null)
                        {
                            if (typeof ASPxClientControl.GetControlCollection().GetByName(CB_NestedGrid_AccessID) !== 'undefined')
                            {
                                ASPxClientControl.GetControlCollection().GetByName(CB_NestedGrid_AccessID).SetFocusedRowIndex(-1);
                            }
                        }
                    }
                    if (CB_IsToBeAuto == true)
                    {
                        Grid_Display_AfterActionItemClick_Count++;
                        if (Grid_Display_AfterActionItemClick_Count <= 1)
                        {
                            DevExpress.ui.dialog.alert("Kindly Clear All Filters And Search Panel For Auto Expansion Of The Row Where Attachments Are Required...!!<br>OR<br>You Can Manually Expand The Rows And Perform The Desired Action...!!", 'Information!');
                        }
                    }
                }
                CB_Grid_Display_AfterActionItemClick = false;
            }
            if (CB_Grid_Display_AfterPeriodChange)
            {
                CB_Grid_Display_AfterPeriodChange = false;
                if (CB_FirstLoad == true)
                {
                    CB_FirstLoad = false;
                    if (CB_SetVouchingModeOn == true)
                    {
                        $("#CashbookVouchingModeSwitch").dxSwitch("instance").option("value", true);    // Redmine Bug #133345 fixed
                    }
                    else
                    {
                        CashBookListGrid.SetFocusedRowIndex(-1);
                        if (CB_ExpandedRowIndex > -1)
                        {
                            CashBookListGrid.CollapseDetailRow(CB_ExpandedRowIndex);
                        }
                    }
                }
                else
                {
                    if (CB_PeriodChange_AfterVoucherOperation == false) {
                        CashBookListGrid.SetFocusedRowIndex(-1);
                    }
                    if (CB_IsVouchingMode)
                    {
                        ClearLeftPane();
                        ClearRightPane();
                    }
                    if (CB_ExpandedRowIndex > -1)
                    {
                        CB_DetailRowCollapsing();
                    }
                    if (CB_Grid_PageIndex > 0 && CB_PeriodChange_AfterVoucherOperation == false) {
                        CB_PageChangeAfterPeriodChange = true;
                        CashBookListGrid.GotoPage(0);
                    }
                    else if (CB_PeriodChange_AfterVoucherOperation == true)
                    {
                        CB_Select_xID = "";
                        CB_PeriodChange_AfterVoucherOperation = false;
                        if (CB_MoreEntry_AfterVoucherOperation == true)
                        {
                            CB_AddMoreEntry();
                        }
                    }
                }
            }
            else if (CB_MoreEntry_AfterVoucherOperation == true)
            {
                CB_AddMoreEntry();
            }
        }
        else if (e.command == "PAGERONCLICK")
        {
            CashBookListGrid.SetFocusedRowIndex(-1);
            if (CB_ExpandedRowIndex > -1) {
                CB_DetailRowCollapsing();
                CashBookListGrid.CollapseDetailRow(CB_ExpandedRowIndex);
            }
        }
        else if (e.command == "HIDEDETAILROW")
        {
        }
        else if (e.command == "APPLYSEARCHPANELFILTER")
        {
            CashBookListGrid.SetFocusedRowIndex(-1);
            if (CB_ExpandedRowIndex > -1)
            {
                CB_DetailRowCollapsing();
                CashBookListGrid.CollapseDetailRow(CB_ExpandedRowIndex);
            }
        }
        else if (e.command != "SHOWDETAILROW" && e.command != "HIDEALLDETAIL" && e.command != "HIDEDETAILROW" && e.command != "FUNCTION" && e.command != "SELECTROWS"&&e.command!="CUSTOMCALLBACK")
        {
            if (CB_ActiveFilterString != null && CB_ActiveFilterString.length > 0)
            {
                CashBookListGrid.SetFocusedRowIndex(-1);
                if (CB_ExpandedRowIndex > -1)
                {
                    CB_DetailRowCollapsing();
                    CashBookListGrid.CollapseDetailRow(CB_ExpandedRowIndex);
                }
            }
        }
        HideLoader();
    }
    function CB_grid_AdjustSize(s, e) {
        var height = (document.documentElement.clientHeight * 90) / 100;
        s.SetHeight(height);
    }
    function CashBookVoucherOnGridFocusedRowChanged(s, e)
    {
        s.Focus();
        CB_Grid_FousedRowIndex = s.GetFocusedRowIndex();
        if (CB_Grid_FousedRowIndex >= 0)
        {
            //CB_Grid_PK = s.GetRowKey(CB_Grid_FousedRowIndex);
            CB_GetRowData(CB_Grid_FousedRowIndex);
            if (CB_ExpandedRowIndex >= 0 && CB_ExpandedRowIndex != CB_Grid_FousedRowIndex)
            {
                CashBookListGrid.CollapseDetailRow(CB_ExpandedRowIndex);
                CB_GridFocusedOrExpandedIndex = CB_Grid_FousedRowIndex;
            }
            if (CB_ExpandedRowIndex < 0)
            {
                CB_GridFocusedOrExpandedIndex = CB_Grid_FousedRowIndex;
            }
            if (CB_GridFocusedOrExpandedIndex < CB_Next_Unattended_Attachment_Index)
            {
                CB_Next_Unattended_Attachment_Index = -3;
            }
            if (CB_IsVouchingMode == true)
            {
                if (isSuperuserOrAuditor == true) {
                    fab.SetActionContext("AuditActionContext", true);
                }

                if (CB_MID_Or_XID != CB_Prev_TempID)
                {
                    OpenLeftPane();
                    LoadDocumentAndAdditionalInfoInLeftPane("Account", "Voucher", "LeftPaneContent", CB_XID, CB_IsVouchingMode, CB_MID);
                }
                else
                {
                    RefreshGridView("CashBook_AdditionalInfo_Grid");
                }
                CB_Prev_TempID = CB_MID_Or_XID;
            }
        }
        else
        {
            CB_Grid_FousedRowIndex = -1;
            CB_Grid_PK = null;
            CB_MID_Or_XID = null;
            CB_XID = null;
            CB_MID = null;
            CB_Prev_TempID = null;
        }
        CB_CreationDetail(CB_XID, CB_ACTION_STATUS, CB_REC_ADD_ON, CB_REC_ADD_BY, CB_REC_STATUS_Date, CB_REC_STATUS_BY, CB_REC_EDIT_Date, CB_REC_EDIT_BY);
    }
    function GetVoucherScreenName(iTR_CODE)
    {
        iTR_CODE = iTR_CODE != null ? iTR_CODE.toString() : "";
        switch (iTR_CODE) {
            case "1":
                CB_VoucherScreen_Name = "Cash_Deposit_Withdrawn";
                break;
            case "2":
                CB_VoucherScreen_Name = "Bank_To_Bank_Transfer";
                break;
            case "3":
                CB_VoucherScreen_Name = "Payment";
                break;
            case "4":
                CB_VoucherScreen_Name = "Receipt";
                break;
            case "5":
                CB_VoucherScreen_Name = "Donation_Regular";
                break;
            case "6":
                CB_VoucherScreen_Name = "Donation_Foreign";
                break;
            case "7":
                CB_VoucherScreen_Name = "Donation_Gift";
                break;
            case "8":
                CB_VoucherScreen_Name = "Internal_Transfer";
                break;
            case "9":
                CB_VoucherScreen_Name = "Collection_Box";
                break;
            case "10":
                CB_VoucherScreen_Name = "Fixed_Deposits";
                break;
            case "11":
                CB_VoucherScreen_Name = "Sale_Asset";
                break;
            case "12":
                CB_VoucherScreen_Name = "Membership";
                break;
            case "13":
                CB_VoucherScreen_Name = "Membership_Renewal";
                break;
            case "14":
                CB_VoucherScreen_Name = "Journal";
                break;
            case "15":
                CB_VoucherScreen_Name = "Asset_Transfer";
                break;
            case "16":
                CB_VoucherScreen_Name = "Membership_Conversion";
                break;
            case "17":
                CB_VoucherScreen_Name = "WIP_Finalization";
                break;
        }
    }
    function CB_CreationDetail(ID, Action_Status, Add_Date, Add_By, Action_Date, Action_By, Edit_Date, Edit_By)
    {
        var Status = "";
        var Lbl_Status = "";
        var Lbl_StatusBy = "";
        var Pic_Status = "";
        var Lbl_Create = "";
        var Lbl_Modify = "";
        var Lbl_Status_Color = "";
        var Lbl_ActionOn = "";
        var Lbl_ActionBy = "";
        var StatusStr = "";
        if (ID != null)
        {
            Add_Date = (moment(Add_Date, "DD/MM/YYYY HH:mm:ss").format("DD/MM/YYYY HH:mm:ss"));
            Edit_Date = (moment(Edit_Date, "DD/MM/YYYY HH:mm:ss").format("DD/MM/YYYY HH:mm:ss"));
            Action_Date = (moment(Action_Date, "DD/MM/YYYY HH:mm:ss").format("DD/MM/YYYY HH:mm:ss"));
            Status = Action_Status;
            StatusStr = Status == "Locked" ? "Locked" : Status == null ? null : "UnLocked";
            if (Status && Status.toUpperCase() == "LOCKED")
            {
                Lbl_Status = "Completed";
                Lbl_Status_Color = "blue";
                Pic_Status = "fa fa-lock";
            }
            else
            {
                Pic_Status = "fa fa-unlock";
                Lbl_Status = Status;
                if (Status && Status.toUpperCase() == "COMPLETED")
                {
                    Lbl_Status_Color = "green";
                }
                else
                {
                    Lbl_Status_Color = "red";
                }
            }
            if (Action_Date)
            {
                Lbl_ActionOn = StatusStr + " On: " + Action_Date;
                Lbl_ActionBy = StatusStr + " By: " + Action_By;
            }

            else
            {
                Lbl_ActionOn = "";
                Lbl_ActionBy = "";
            }
            if (Add_Date)
            {
                Lbl_Create = "Add On: " + Add_Date + ", By: " +Add_By;
            }
            else
            {
                Lbl_Create = "";
            }

            if (Edit_Date)
            {
                Lbl_Modify = "Edit On: " + Edit_Date + ", By: " + Edit_By;
            }
            else
            {
                Lbl_Modify = "";
            }
        }
        $('#CBLbl_Status').text(Lbl_Status);
        $('#CB_Lbl_ActionOn').text(Lbl_ActionOn);
        $('#CB_Lbl_ActionBy').text(Lbl_ActionBy);
        $('#CBLbl_Create').text(Lbl_Create);
        $('#CBLbl_Modify').text(Lbl_Modify);
        if (Lbl_Status_Color != "")
        {
            $('#CBLbl_Status').css('color', Lbl_Status_Color);
        }
        if (Pic_Status == "fa fa-lock")
        {
            $('#CB_LockICON').addClass(Pic_Status).removeClass("fa-unlock");
        }
        else if (Pic_Status == "fa fa-unlock")
        {
            $('#CB_LockICON').addClass(Pic_Status).removeClass("fa-lock");
        }
        else
        {
            $('#CB_LockICON').removeClass("fa");
            $('#CB_LockICON').removeClass("fa-lock");
            $('#CB_LockICON').removeClass("fa-unlock");
        }
    }
    function CBVoucherdblclickEdit(s, e)
    {
        if (CB_IsVouchingMode == false)
        {
            ShowLoader();
            CashbookButtonClick("EDIT");
            HideLoader();
        }
    }
    function CB_GetRowData(RowIndex = null)
    {
        debugger;
        var focusedrow = RowIndex == null ? CashBookListGrid.GetFocusedRowIndex() : RowIndex;
        var topindex = CashBookListGrid.GetTopVisibleIndex();
        var Index = focusedrow - topindex;
        CashBookPageData = CashBookListGrid.cpPagedata;
        if (CashBookPageData != null && CashBookPageData.length > 0 && Index < CashBookPageData.length)
        {
            CB_iTR_CODE = CashBookPageData[Index][0];
            CB_XID = CashBookPageData[Index][1];
            CB_MID = CashBookPageData[Index][2];
            CB_Grid_PK = CashBookPageData[Index][3];
