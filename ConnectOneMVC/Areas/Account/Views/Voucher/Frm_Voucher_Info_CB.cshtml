    async function CashbookButtonClick(_ActionType, Voucher_Type = "", Selected_Item_ID = "", Selection_By_Item = false)
    {
        console.log(Voucher_Type + " Voucher Load Start")
        ShowLoader();
        var isRight = "False";
        var result;
        var ShouldProceed = false;
        CashBookPageData = CashBookListGrid.cpPagedata;
        if (_ActionType != "NEW")
        {
            if (CashBookListGrid.GetFocusedRowIndex()<0)
            {
                HideLoader();
                DevExpress.ui.dialog.alert("Please Select A Row..", "Error");
                return;
            }
            var focusedrow = CashBookListGrid.GetFocusedRowIndex();
            var topindex = CashBookListGrid.GetTopVisibleIndex();
            CB_Grid_PK = CashBookPageData[focusedrow - topindex][3];
            CB_XID = CashBookPageData[focusedrow - topindex][1];
            CB_MID = CashBookPageData[focusedrow - topindex][2];
        }
        if (_ActionType == "EDIT_COMMON")
        {
            var TRCODE = CashBookPageData[CashBookListGrid.GetFocusedRowIndex() - CashBookListGrid.GetTopVisibleIndex()][0]
            Edit_Common(CB_XID, CB_MID, "CashBookListGrid", TRCODE);
            return;
        }
        if (_ActionType == "VOUCHER")
        {
            var TRCODE = CashBookPageData[CashBookListGrid.GetFocusedRowIndex() - CashBookListGrid.GetTopVisibleIndex()][0]
            GetVoucherScreenName(TRCODE != null ? TRCODE.toString() : "");
            if (CB_VoucherScreen_Name != "Collection_Box")
            {
                HideLoader();
                DevExpress.ui.dialog.alert("Coming Soon...", "Voucher Print");
            }
            else
            {
                $.ajax({
                    type: 'GET',
                    url: "/Account/Voucher/Frm_PrintVoucher_CollectionBox",
                    data:
                    {
                        RecID: CB_XID
                    },
                    cache: false,
                    success: function (data)
                    {
                        HideLoader();
                        if (data.jsonParam)
                        {
                            DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                        }
                        else
                        {
                            OpenDynamicPopup("Collection Box Voucher", null, "auto", "100%", true, data)
                        }
                    }
                });
            }
            return;
        }
        if (Check_Voucher_Allow_AEDV(_ActionType, Voucher_Type) == false)
        {
            HideLoader();
            DevExpress.ui.dialog.alert("Coming Soon...!", "Information");
            return;
        }
        isRight = CheckRights_CB(_ActionType);
        if (isRight == "False")
        {
            HideLoader();
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        if (_ActionType != "NEW")
        {
            if (CB_XID.toLowerCase() == "note-book")
            {
                if ($("#NoteBook_ParentDiv").length > 0)
                {
                    HideLoader();
                    DevExpress.ui.dialog.alert("Note Book Already Opened...!<br>Please Close Notebook Opened In Tab First", "Information..");
                    return;
                }
            }
        }
        if (_ActionType == "MATCH TRANSFERS" || _ActionType == "LOCKED" || _ActionType == "UNLOCKED")
        {
            result = await GetUserConfirmation(_ActionType);
            if (result.jsonParam.refreshgrid)
            {
                Grid_Display();
            }
            if (result.jsonParam.result == true)
            {
                ShouldProceed = true;
            }
            else
            {
                if (result.jsonParam.isconfirm)
                {
                    ShouldProceed = await DevExpress.ui.dialog.confirm(result.jsonParam.message, result.jsonParam.title);
                }
                else
                {
                    ShouldProceed = false;
                    DevExpress.ui.dialog.alert(result.jsonParam.message, result.jsonParam.title);
                }
            }
        }
        else
        {
            ShouldProceed = true;
        }
        if (ShouldProceed == false)
        {
            HideLoader();
            return;
        }
        //if (_ActionType == "DELETE" && (Voucher_Type == "ASSET TRANSFER" || CB_VoucherScreen_Name == "Asset_Transfer"))
        //{
        //    result = await GetAssetTransferDeleteConfirmation();
        //    if (result.jsonParam.result == true)
        //    {
        //        ShouldProceed = true;
        //    }
        //    else
        //    {
        //        if (result.jsonParam.isconfirm)
        //        {
        //            ShouldProceed = await DevExpress.ui.dialog.confirm(result.jsonParam.message, result.jsonParam.title);
        //            if (ShouldProceed == false)
        //            {
        //                HideLoader();
        //                return;
        //            }
        //        }
        //    }
        //}
        DataNavigation_CB(_ActionType, Voucher_Type, Selection_By_Item, Selected_Item_ID);
    }
    function DataNavigation_CB(_ActionType, Voucher_Type, Selection_By_Item, Selected_Item_ID)
    {
        ShowLoader();
        var editon = JS_Json_Date_To_ddMMyyyy((CB_REC_EDIT_Date ?? ""), "DD-MM-YYYY HH:mm:ss.SSS")
        var addon = JS_Json_Date_To_ddMMyyyy((CB_REC_ADD_ON ?? ""), "DD-MM-YYYY HH:mm:ss.SSS")
        var trDate = JS_Json_Date_To_ddMMyyyy((CB_iTR_DATE ?? ""), "DD-MM-YYYY HH:mm:ss.SSS")
        if (_ActionType == "VIEW") {
            Vouchers_View_AllEntryData(CB_XID, CB_MID, editon, "Cash Book", trDate, CB_iTR_CODE, "CashBookListGrid", CB_Grid_PK);
        }
        else if (_ActionType == "DELETE") {
            Vouchers_Delete_AllEntryData(CB_XID, CB_MID, editon, addon, "Cash Book", trDate, CB_ACTION_STATUS, CB_iTR_CODE, CB_ITEM_ID, CB_ITR_SR_NO, CB_ITR_TYPE, "CashBookListGrid", CB_Grid_PK, false, false);
        }
        else if (_ActionType == "EDIT") {
            Vouchers_Edit_AllEntryData(CB_XID, CB_MID, editon, addon, "Cash Book", trDate, CB_ACTION_STATUS, CB_iTR_CODE, CB_ITEM_ID, CB_ITR_SR_NO, CB_ITR_TYPE, "CashBookListGrid", CB_Grid_PK, false);
        }
        else if (_ActionType == "NEW") {
            Vouchers_New(Voucher_Type, Selection_By_Item, Selected_Item_ID)
        }
        else
        {
            $.ajax({
                type: 'GET',
                url: "/Account/Voucher/DataNavigation",
                data:
                {
                    ActionType: _ActionType,
                    GridPK: CB_Grid_PK,
                    Voucher_Type: Voucher_Type,
                    Selection_By_Item: Selection_By_Item,
                    Selected_Item_ID: Selected_Item_ID,
                    iREC_ID: CB_XID,
                    iTR_M_ID: CB_MID,
                    iACTION_STATUS: CB_ACTION_STATUS,
                    EditOn: editon,
                    iTR_CODE: CB_iTR_CODE,
                    iTR_AB_ID_1: CB_AB_ID_1,
                    iTR_DATE: trDate,
                    FocusedRowIndex: CashBookListGrid.GetFocusedRowIndex()
                },
                cache: false,
                success: function (data)
                {
                    HideLoader();
                    if (data.jsonParam.result == false)
                    {
                        DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                        if (data.jsonParam.refreshgrid)
                        {
                            Grid_Display();
                        }
                    }
                    else
                    {
                        if (data.jsonParam.popup_form_name != null && data.jsonParam.popup_form_name.length > 0) {
                            if (data.jsonParam.popup_form_name == "Frm_Action_Items_Info" || data.jsonParam.popup_form_name == "Frm_Action_Items_Window") {
                                $("#ActionItemsvalidationForm").remove();//Redmine Bug #133231 fixed
                                OpenPopup("CB_ActionItem_Popup", data.jsonParam.popup_title, data.jsonParam.popup_form_path + "?" + encodeURI(data.jsonParam.popup_querystring), "auto", 1000, false, false);
                            }
                            else if (data.jsonParam.popup_form_name == "Frm_Voucher_Win_FD_Type") {
                                OpenDynamicPopup(data.jsonParam.popup_title, data.jsonParam.popup_form_path + "?" + encodeURI(data.jsonParam.popup_querystring), "auto", 300, false, false);
                            }
                            else if (data.jsonParam.popup_form_name == "Frm_NoteBook_Info") {
                                OpenPopup("Notebook_Popup_ID", data.jsonParam.popup_title, data.jsonParam.popup_form_path + "?" + encodeURI(data.jsonParam.popup_querystring), "auto", 1230, false, false);
                            }
                            else
                            {
                                var width = 1000;
                                switch (data.jsonParam.popup_form_name)
                                {
                                    case "Frm_Voucher_Win_Donation_R":
                                        width = 750;
                                        break;
                                    case "Frm_Voucher_Win_Cash":
                                        width = 840;
                                        break;
                                    case "Frm_Voucher_Win_WIP_Finalization":
                                        width = 750;
                                        break;
                                    case "Frm_Voucher_Win_FD":
                                        width = 750;
                                        break;
                                    case "Frm_Voucher_Win_B2B":
                                        width = 750;
                                        break;
                                    case "Frm_Voucher_Win_C_Box":
                                        width = 840;
                                        break;
                                    case "Frm_Voucher_Win_Gen_Rec":
                                        width = 850;
                                        break;
                                }
                                OpenDynamicPopup(data.jsonParam.popup_title, data.jsonParam.popup_form_path + "?" + encodeURI(data.jsonParam.popup_querystring), "auto", width, false, false);
                            }
                        }
                        else
                        {
                            if (data.jsonParam.message != null && data.jsonParam.message.length > 0)
                            {
                                DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                                if (data.jsonParam.refreshgrid)
                                {
                                    Grid_Display();
                                }
                            }
                        }
                    }
                }
            });
        }
    }
