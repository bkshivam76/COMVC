    @* Grid Functions *@
    <script>
        //"use strict";

        var CB_Attachment_Action_Status;
        function OnActionItemClick(s, e) {
            var img = document.getElementById('RightPane_Img');

            fab.ExpandActionGroupItems();
            if (e.actionName == "InitialClick") {
                CB_IsToBeAuto = CB_IsVouchingMode == true ? false : true;
                if (CB_IsToBeAuto == true) {
                    MoveToUnattendedDoc();
                }
                else {
                    DevExpress.ui.dialog.alert("Auto Search Of Entry For Attachments Is Disabled in Vouching On Mode<br>Kindly Select A Row To Perform The Desired Action", 'Information!');
                }
            }
            if (e.actionName == "Add_doc" || e.actionName == "add_attach" || e.actionName == "Add_doc_Auto") {
                if (e.actionName == "Add_doc_Auto") {
                    CB_IsToBeAuto = CB_IsVouchingMode == true ? false : true;
                }
                else {
                    CB_IsToBeAuto = false;
                }
                if (CB_Nested_Params_Mandatory == 1) {
                    OnCashBookAddAttachmentPopup();
                }
                else {
                    CB_DirectBrowseOpen(); // direct browse open
                }
            }
            if (e.actionName == "Add_Reason" || e.actionName == "Add_Reason_Auto") {
                if (e.actionName == "Add_Reason_Auto") {
                    CB_IsToBeAuto = CB_IsVouchingMode == true ? false : true;
                }
                else {
                    CB_IsToBeAuto = false;
                }
                if (CB_Doc_Category.toLowerCase() == "others") {
                    DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
                }
                else {
                    Add_Reason(e);
                }
            }
            if (e.actionName === "edit_attach") {
                CB_IsToBeAuto = false;
                OnCashBookEditAttachmentPopup();
            }
            if (e.actionName === "delete_attach") {
                CB_IsToBeAuto = false;
                OnCashBookDeleteAttachmentPopup();
            }
            if (e.actionName === "view_attach") {
                CB_IsToBeAuto = false;
                OnCashBookViewAttachmentPopup();
            }
            else if (e.actionName == "Link_Attach") {
                if (fab.GetActionContext() == "AutoItemContext") {
                    CB_IsToBeAuto = CB_IsVouchingMode == true ? false : true;
                }
                else { CB_IsToBeAuto = false; }
                OnCashBookLinkAttachment();

            }
            if (e.actionName === "Edit_Reason") {
                CB_IsToBeAuto = false;
                Edit_Reason(e);
            }
            if (e.actionName === "Delete_Reason") {
                CB_IsToBeAuto = false;
                Delete_Reason(e);
            }
            if (e.actionName === "Rotate") {
                CB_IsToBeAuto = false;
                ImageRotate(img);
            }
            if (e.actionName === "ZoomOut") {
                CB_IsToBeAuto = false;
                ImageZoomOut(img);
            }
            if (e.actionName === "ZoomIn") {
                CB_IsToBeAuto = false;
                ImageZoomIn(img);
            }
            else if (e.actionName == "Fit") {
                CB_IsToBeAuto = false;
                ImageFit(img);
            }
            else if (e.actionName == "Back") {
                CB_IsToBeAuto = false;
                ImageBack("fab", "actionItemContext");

            }
            else if (e.actionName == "AuditAction") {
                CB_IsToBeAuto = false;
                fab.SetActionContext("AuditActionContext", true);
            }
            else if (e.actionName == "BackAudit") {
                CB_IsToBeAuto = false;
                if (CB_Nested_Doc_Status == "") {
                    fab.SetActionContext("AutoItemContext", true);
                    if (isMobile) { //removed by saurabh
                        $('.dx-fab-text').hide();
                    }
                }
                if (CB_Nested_Doc_Status == "NO") {
                    fab.SetActionContext("EditItemContext", true);
                    if (isMobile) {
                        $('.dx-fab-text').hide();
                    }
                }
                if (CB_Nested_Doc_Status == "YES") {
                    fab.SetActionContext("actionItemContext", true);
                    if (isMobile) {
                        $('.dx-fab-text').hide();
                    }
                }
            }
            else if (e.actionName == "Accept") {
                CB_IsToBeAuto = false;
                OnCB_AcceptwithoutRemarks();
            }
            else if (e.actionName == "Reject") {
                CB_IsToBeAuto = false;
                OnCB_AcceptRejectVoucher("Reject");
            }
            else if (e.actionName == "AcceptWithRemarks") {
                CB_IsToBeAuto = false;
                OnCB_AcceptRejectVoucher("Accept");
            }
            else if (e.actionName == "AcceptDoc") {
                CB_IsToBeAuto = false;
                OnCB_AcceptDoc();
            }
            else if (e.actionName == "RejectDoc") {
                CB_IsToBeAuto = false;
                OnCB_RejectDoc();
            }
        }
        function OnCB_RejectDoc() {
            if (CB_Attachment_ID == null || CB_Attachment_ID.length == 0) {
                DevExpress.ui.dialog.alert("No Document Attached..", "Error");
                return;
            }
            RejectAttachment(CB_Attachment_ID, "CashBookListGrid", CB_NestedGrid_AccessID);
        }
        function OnCB_AcceptDoc() {
            if (CB_Attachment_ID == null || CB_Attachment_ID.length == 0) {
                DevExpress.ui.dialog.alert("No Document Attached..", "Error");
                return;
            }
            AcceptAttachment(CB_Attachment_ID, null, CB_NestedGrid_AccessID);
        }
        function OnCB_AcceptwithoutRemarks() {
            var Recid;
            if (CB_IsDetailRowExpanded == true || CB_IsVouchingMode == true) {
                if (CB_MasterRowMID == null || CB_MasterRowMID == "") {
                    if (CB_MasterRowRecID == null || CB_MasterRowRecID == "") {
                        Recid = CB_MID_Or_XID;
                    }
                    else {
                        Recid = CB_MasterRowRecID;
                    }
                }
                else {
                    Recid = CB_MasterRowMID;
                }
            }
            else { Recid = CB_MID_Or_XID; }
            Entry_AcceptwithoutRemarks(Recid, "CashBook", "CashBookListGrid", CB_Attachment_ID, CB_Nested_RowReasonID, CashBook_NestedRowUniqueID);
        }
        function OnCB_AcceptRejectVoucher(_actionMethod) {
            var Recid;
            if (CB_IsDetailRowExpanded == true || CB_IsVouchingMode == true) {
                if (CB_MasterRowMID == null || CB_MasterRowMID == "") {
                    if (CB_MasterRowRecID == null || CB_MasterRowRecID == "") {
                        Recid = CB_MID_Or_XID;
                    }
                    else {
                        Recid = CB_MasterRowRecID;
                    }
                }
                else {
                    Recid = CB_MasterRowMID;
                }
            }
            else { Recid = CB_MID_Or_XID; }
            Entry_AcceptReject(_actionMethod, Recid, "CashBook", "CashBookListGrid", CB_Attachment_ID, CB_Nested_RowReasonID, CashBook_NestedRowUniqueID);
        }
        function MoveToUnattendedDoc() {
            if ((CB_ActiveFilterString != null && CB_ActiveFilterString.length > 0) || (CB_SearchPanelExp != null && CB_SearchPanelExp.length > 0)) {
                DevExpress.ui.dialog.alert("Kindly Clear All Filters And Search Panel For Auto Expansion Of The Row Where Attachments Are Required...!!<br>OR<br>You Can Manually Expand The Rows And Perform The Desired Action...!!", 'Information!');
                return;
            }
            if (CB_NestedGrid_AccessID != null) {
                if (ASPxClientControl.GetControlCollection().GetByName(CB_NestedGrid_AccessID) != null) {
                    if (typeof ASPxClientControl.GetControlCollection().GetByName(CB_NestedGrid_AccessID) !== 'undefined') {
                        ASPxClientControl.GetControlCollection().GetByName(CB_NestedGrid_AccessID).SetFocusedRowIndex(-1);
                    }
                }
            }
            if (CB_GridFocusedOrExpandedIndex != null && CB_GridFocusedOrExpandedIndex > -1 && CB_GridFocusedOrExpandedIndex > CB_Next_Unattended_Attachment_Index && CB_Next_Unattended_Attachment_Index != -1 && CB_Next_Unattended_Attachment_Index != -2) {
                Grid_Display(null, true);
            }
            else if (CB_Next_Unattended_Attachment_Index >= 0) {
                fab.SetActionContext("ShivbabaItemContext", true); // used only to change context
                var calculatePageNumber = (CB_Next_Unattended_Attachment_Index + 1) / CBGrid_PageSize;
                var pageNumber = Math.ceil(calculatePageNumber);
                if ((pageNumber - 1) != CashBookListGrid.GetPageIndex() && CashBookListGrid.GetPageIndex() >= 0) {
                    GridViewDoCallback(CashBookListGrid, function () { CashBookListGrid.GotoPage(pageNumber - 1) });
                    //CashBookListGrid.GotoPage(pageNumber - 1);
                }
                else {
                    GridViewDoCallback(CashBookListGrid, function () { CashBookListGrid.ExpandDetailRow(CB_Next_Unattended_Attachment_Index) });
                    // CashBookListGrid.ExpandDetailRow(CB_Next_Unattended_Attachment_Index);
                }
            }
            else if (CB_Next_Unattended_Attachment_Index == -1) {
                var result = DevExpress.ui.dialog.alert("Congrats!! No Pending Attachments In Open Period", 'Information!');
                result.done(function (dialogResult) {
                    if (dialogResult) {
                        CashBookListGrid.SetFocusedRowIndex(-1);
                        if (CB_ExpandedRowIndex > -1) {
                            GridViewDoCallback(CashBookListGrid, function () { CashBookListGrid.CollapseDetailRow(CB_ExpandedRowIndex) });
                            //CashBookListGrid.CollapseDetailRow(CB_ExpandedRowIndex);
                        }
                    }
                });
            }
            else if (CB_Next_Unattended_Attachment_Index == -2)// rows have been skipped
            {
                var result = DevExpress.ui.dialog.confirm("Do You Want To Start The Checking From The First Row..?", 'Confirm');
                result.done(function (dialogResult) {
                    if (dialogResult) {

                        CashBookListGrid.SetFocusedRowIndex(-1);
                        CB_GridFocusedOrExpandedIndex = -1;
                        Grid_Display(null, true);
                    }
                    else {

                        CashBookListGrid.SetFocusedRowIndex(-1);
                        CB_Next_Unattended_Attachment_Index = -3;
                        if (CB_ExpandedRowIndex > -1) {
                            GridViewDoCallback(CashBookListGrid, function () { CashBookListGrid.CollapseDetailRow(CB_ExpandedRowIndex) });
                            //CashBookListGrid.CollapseDetailRow(CB_ExpandedRowIndex);
                        }
                    }
                });
            }

            else if (CB_Next_Unattended_Attachment_Index == -3) {
                Grid_Display(null, true);
            }
        }


        function OnCashBookListGridNestedFocusedRowChange(s, e) {
            if (CB_IsDetailRowExpanded || CB_IsVouchingMode == true) {
                CB_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
                if (CB_NestedRecord_FocusedRowIndex >= 0) {
                    CB_NestedGrid_AccessID = s.uniqueID;
                    CashBook_NestedRowUniqueID = s.GetRowKey(CB_NestedRecord_FocusedRowIndex);
                    CB_GetNestedGridRowData(s, e, CB_NestedRecord_FocusedRowIndex);
                    if (CB_IsVouchingMode == true) {
                        if (isSuperuserOrAuditor == true) {
                            fab.SetActionContext("AuditActionContext", true);
                        }
                        else {
                            if (CB_Nested_Doc_Status == "") {
                                fab.SetActionContext("AutoItemContext", true);
                            }
                            else if (CB_Nested_Doc_Status == "NO") {
                                fab.SetActionContext("EditItemContext", true);
                            }
                            else if (CB_Nested_Doc_Status == "YES") {
                                fab.SetActionContext("actionItemContext", true);
                            }
                            if (isMobile) {
                                $('.dx-fab-text').hide();
                            }
                        }
                        if (CB_filename != null && CB_filename.length > 0) {
                            OnCashBookViewAttachmentPopup();
                        }
                        else {
                            CloseRightPane();
                            ClearRightPane();
                        }
                    }
                    else {
                        if (CB_Nested_Doc_Status == "") {
                            fab.SetActionContext("AutoItemContext", true);
                        }
                        else if (CB_Nested_Doc_Status == "NO") {
                            fab.SetActionContext("EditItemContext", true);
                        }
                        else if (CB_Nested_Doc_Status == "YES") {
                            fab.SetActionContext("actionItemContext", true);
                        }
                        if (isMobile) {
                            $('.dx-fab-text').hide();
                        }
                    }
                }
                else {
                    CB_MasterRowMID = null;
                    CB_MasterRowRecID = null;
                    CashBook_NestedRowUniqueID = null;
                }
            }
        }
        function CB_GetNestedGridRowData(s, e, RowIndex = null) {
            var focusedrow = RowIndex == null ? s.GetFocusedRowIndex() : RowIndex;
            var topindex = s.GetTopVisibleIndex();
            var Index = focusedrow - topindex;
            var CashBook_Nested_PageData = s.cpPagedata;
            if (CashBook_Nested_PageData != null && CashBook_Nested_PageData.length > 0) {
                CB_Nested_Doc_Status = typeof CashBook_Nested_PageData[Index][0] !== "undefined" ? CashBook_Nested_PageData[Index][0] : null;
