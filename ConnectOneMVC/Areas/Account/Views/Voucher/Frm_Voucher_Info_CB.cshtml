        function UpdateCustomizationWindowVisibilityForVoucher() {
            if (CashBookListGrid.IsCustomizationWindowVisible()) {
                CashBookListGrid.HideCustomizationWindow();
            }
            else {
                CashBookListGrid.ShowCustomizationWindow();
            }
            $("#But_ShowColumn").find("i").toggleClass("dx-icon-add").toggleClass("dx-icon-close");
