        async function ShowGrandTotal() {
            if (CB_ShowHorizontalBar == 0) {
                await OnCBChangeMode();
            }
            var btntotal = $("#But_ShowTotal").dxButton("instance").option("text");
            $.ajax({
                type: 'GET',
                url: "/Account/Voucher/But_ShowTotal_Click",
                data:
                {
                    ButText: btntotal
                },
                cache: false,
                success: function (data) {
                    if (btntotal.toUpperCase() == 'SHOW TOTAL BAL.') {
                        btntotal = "Hide Total Bal.";
                    }
                    else {
                        btntotal = "Show Total Bal.";
                    }
                    $("#But_ShowTotal").dxButton("instance").option("text", btntotal);
                    $("#But_ShowTotal").attr("title", btntotal);
                    ShowLoader();
                    CashBookListGrid.PerformCallback({ "_ActiveFilterString": CB_ActiveFilterString, "GetLatestData": false, "ShowHorizontalBar": CB_ShowHorizontalBar });
                    HideLoader();
                }
            });
        }
