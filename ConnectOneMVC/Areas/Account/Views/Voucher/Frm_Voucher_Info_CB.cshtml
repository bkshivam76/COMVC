        function CashBookAdvanceFilterClick() {
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Account/Voucher/Frm_AdvancedFilters",
                data:
                {
                    _ActiveFilterString: CB_ActiveFilterString
                },
                cache: false,
                success: function (data) {
                    ShowLoader();
                    OpenPopup("popup_frm_Voucher_Advance_Filter", "", null, "auto", 350, true, data);
                    HideLoader();
                    CashBookListGrid.PerformCallback({ "GetLatestData": false, "ShowHorizontalBar": CB_ShowHorizontalBar });
                }
            });
