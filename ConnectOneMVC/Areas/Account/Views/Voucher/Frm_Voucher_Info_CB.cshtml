    <script>
    //"use strict";

    function Check_Voucher_Allow_AEDV(_ActionType, Voucher_Type)
    {
        debugger;
        if (_ActionType != "NEW")
        {
            CashBookPageData = CashBookListGrid.cpPagedata;
            var TRCODE = CashBookPageData[CashBookListGrid.GetFocusedRowIndex() - CashBookListGrid.GetTopVisibleIndex()][0]
            GetVoucherScreenName(TRCODE != null ? TRCODE.toString() : "");
            if (CB_VoucherScreen_Name == "Cash_Deposit_Withdrawn") {
                return Voucher_CDW_Allow_AEDV;
            }
            else if (CB_VoucherScreen_Name == "Bank_To_Bank_Transfer") {
                return Voucher_B2B_Allow_AEDV;
            }
            else if (CB_VoucherScreen_Name == "Payment") {
                return (Voucher_Payment_Allow_AEDV && Voucher_NoteBook_Allow_AEDV);
            }
            else if (CB_VoucherScreen_Name == "Receipt") {
                return Voucher_Receipt_Allow_AEDV;
            }
            else if (CB_VoucherScreen_Name == "Donation_Regular") {
                return Voucher_DonR_Allow_AEDV;
            }
            else if (CB_VoucherScreen_Name == "Donation_Foreign") {
                return Voucher_DonF_Allow_AEDV;
            }
            else if (CB_VoucherScreen_Name == "Donation_Gift") {
                return Voucher_DonationKind_Allow_AEDV;
            }
            else if (CB_VoucherScreen_Name == "Internal_Transfer") {
                return Voucher_ITrf_Allow_AEDV;
            }
            else if (CB_VoucherScreen_Name == "Collection_Box") {
                return Voucher_CBox_Allow_AEDV;
            }
            else if (CB_VoucherScreen_Name == "Fixed_Deposits") {
                return Voucher_FD_Allow_AEDV;
            }
            else if (CB_VoucherScreen_Name == "Sale_Asset") {
                return Voucher_SaleAsset_Allow_AEDV;
            }
            else if (CB_VoucherScreen_Name == "Membership") {
                return Voucher_Membership_Allow_AEDV;
            }
            else if (CB_VoucherScreen_Name == "Membership_Renewal") {
                return Voucher_Membership_Renewal_Allow_AEDV;
            }
            else if (CB_VoucherScreen_Name == "Journal") {
                return Voucher_JV_Allow_AEDV;
            }
            else if (CB_VoucherScreen_Name == "Asset_Transfer") {
                return Voucher_AssetTransfer_Allow_AEDV;
            }
            else if (CB_VoucherScreen_Name == "Membership_Conversion") {
                return Voucher_Membership_Conversion_Allow_AEDV;
            }
            else if (CB_VoucherScreen_Name == "WIP_Finalization") {
                return Voucher_WIP_Allow_AEDV;
            }
        }
        else
        {
            var CB_AllowVoucher_AEDV=false;
            switch (Voucher_Type.toUpperCase())
            {
                case "CASH":
                    CB_AllowVoucher_AEDV = Voucher_CDW_Allow_AEDV;
                    break;
                case "BANK":
                    CB_AllowVoucher_AEDV = Voucher_B2B_Allow_AEDV;
                    break;
                case "DONATION - REGULAR":
                    CB_AllowVoucher_AEDV = Voucher_DonR_Allow_AEDV;
                    break;
                case "DONATION - FOREIGN":
