    function CashBookOnGridDisplaySuccess(data=null)
    {
        if (data)
        {
            CB_Next_Unattended_Attachment_Index = data.jsonParam.Next_Unattended_Attachment_Index;
            if (data.jsonParam.result == false) {
                DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                if (data.jsonParam.closeform == true) {
                    btnCloseActiveTab();
                }
            } else {

                ShowLoader();
                CashBookRefresh();
                $("#CB_BE_Cash_Bank").text(data.BE_Cash_Bank_Text);
                CBGrid_TotalRowCount = data.TotalRowCount;
            }
        }
        else
        {           
            ShowLoader();
            CashBookRefresh();
            CB_Next_Unattended_Attachment_Index = CashBookListGrid.cpNext_Unattended_Attachment_Index;
            $("#CB_BE_Cash_Bank").text(CashBookListGrid.cpCashBankText);
            CBGrid_TotalRowCount = CashBookListGrid.cpTotalRowCount;
        }
        if (CB_IsVouchingMode == true) {
            $(".CashBookListGrid_PreviewRow").hide();
        }
        else {
            if ($("#But_Narration").dxButton("instance").option("text") == "Hide Narration") {
                $(".CashBookListGrid_PreviewRow").show();
            }
            else {
                $(".CashBookListGrid_PreviewRow").hide();
            }
        }
        CashbookShortCuts()      
    }
        function CashBookRefresh() {
            if (typeof window !== 'undefined') {
                if (typeof window.CashBookListGrid !== 'undefined') {
                    if (typeof window.CashBookListGrid.Refresh !== 'undefined') {
                        if (typeof CashBookListGrid.Refresh == 'function') {
                            HideLoader_Ready();
                            HideLoader();
                            GridViewDoCallback(CashBookListGrid, function () { CashBookListGrid.Refresh() });                            
                            //CashBookListGrid.Refresh();
                        }
                        else {
                            alert("refresh is not a function");
                        }
                    }
                    else {
                        ShowLoader();
                        setTimeout(function () {
                            CashBookRefresh();
                        }, Timeout100);
                    }
                }
                else {
                    alert('grid undefined')
                }
            }
            else {
                alert('window undefined')
            }
        }
