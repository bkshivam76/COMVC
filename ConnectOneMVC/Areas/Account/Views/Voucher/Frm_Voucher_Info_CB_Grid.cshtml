@Html.DevExpress().GridView(
        settings =>
        {
            settings.Name = "CashBookListGrid";
            settings.CallbackRouteValues = new
            {
                Controller = "Voucher",
                Action = "Frm_Voucher_Info_CB_Grid",
                SessionGUID = SessionGUID

            };
            settings.CustomDataActionRouteValues = new
            {
                Controller = "Voucher",
                Action = "CB_GetGridData",
                SessionGUID = SessionGUID
            };
            settings.Theme = "Aqua";

            settings.Settings.ShowPreview = true;
            settings.HtmlDataCellPrepared = (s, e) =>
            {
                MVCxGridView grid = (MVCxGridView)s;
                string colIdx = e.DataColumn.Index.ToString();
                string rowIdx = e.VisibleIndex.ToString();
                string KeyValue = "";
                if ((string)e.GetValue("iREC_ID") == "NOTE-BOOK")
                {
                    KeyValue = Regex.Replace((string)e.GetValue("iTR_M_ID"), "[^0-9A-Za-z]+", "_") + (string)e.GetValue("iTR_ITEM_ID");
                }
                else
                {
                    KeyValue = Regex.Replace((string)e.GetValue("Grid_PK"), "[^0-9A-Za-z]+", "_");
                }
                if (VouchingMode == true)
                {

                    if (e.DataColumn.FieldName.Length > 0)
                    {
                        e.Cell.Attributes.Add("ondblclick", "OnGridCellClick(event,this,'" + colIdx + "', '" + rowIdx + "','" + settings.Name + "','" + KeyValue + "','" + e.DataColumn.FieldName + "');");
                    }
                    if (e.DataColumn.Name == "iIcon")
                    {
                        e.Cell.Attributes.Add("onmouseover", "OnGridRowMouseHoverIn(event,this,'" + settings.Name + "','" + e.VisibleIndex + "','" + KeyValue + "')");
                        e.Cell.Attributes.Add("onmouseout", "OnGridRowMouseHoverOut(event,this,'" + settings.Name + "','" + e.VisibleIndex + "','" + KeyValue + "')");
                    }

                }

                e.Cell.CssClass += " col_" + e.DataColumn.FieldName + " row_" + KeyValue;
                e.Cell.ID = "Cell_" + KeyValue + "|" + e.DataColumn.FieldName;
            };
            settings.HtmlRowCreated = (s, e) =>
            {
                MVCxGridView grid = (MVCxGridView)s;
                string GridName = grid.ClientInstanceName;

                if (e.RowType == GridViewRowType.Data)
                {
                    string KeyValue = "";
                    if ((string)e.GetValue("iREC_ID") == "NOTE-BOOK")
                    {
                        KeyValue = Regex.Replace((string)e.GetValue("iTR_M_ID"), "[^0-9A-Za-z]+", "_") + (string)e.GetValue("iTR_ITEM_ID");
                    }
                    else
                    {
                        KeyValue = Regex.Replace((string)e.GetValue("Grid_PK"), "[^0-9A-Za-z]+", "_");
                    }
                    if (VouchingMode == true)
                    {
                        // e.Row.Attributes.Add("onmouseover", "OnGridRowMouseHoverIn(event,this,'" + settings.Name + "','" + e.VisibleIndex + "','" + KeyValue + "')");
                        // e.Row.Attributes.Add("onmouseout", "OnGridRowMouseHoverOut(event,this,'" + settings.Name + "','" + e.VisibleIndex + "','" + KeyValue + "')");
                    }
                    e.Row.CssClass += " " + settings.Name + "_DataRow_" + KeyValue;
                }
                else if (e.RowType == GridViewRowType.Preview)
                {
                    string KeyValue = "";
                    if ((string)e.GetValue("iREC_ID") == "NOTE-BOOK")
                    {
                        KeyValue = Regex.Replace((string)e.GetValue("iTR_M_ID"), "[^0-9A-Za-z]+", "_") + (string)e.GetValue("iTR_ITEM_ID");
                    }
                    else
                    {
                        KeyValue = Regex.Replace((string)e.GetValue("Grid_PK"), "[^0-9A-Za-z]+", "_");
                    }
                    if (VouchingMode == true)
                    {

                        e.Row.Attributes.Add("onmouseover", "OnGridPrevRowMouseHoverIn(event,this,'" + settings.Name + "','" + e.VisibleIndex + "','" + KeyValue + "')");
                        e.Row.Attributes.Add("onmouseout", "OnGridPrevRowMouseHoverOut(event,this,'" + settings.Name + "','" + e.VisibleIndex + "','" + KeyValue + "')");
                    }
                    else
                    {
                        //var AuditRemarks = e.GetValue("AUDITOR_REMARKS") == null ? "" : e.GetValue("AUDITOR_REMARKS").ToString();
                        //var VouchingRemarks = e.GetValue("VOUCHING_REMARKS") == null ? "" : e.GetValue("VOUCHING_REMARKS").ToString();
                        var Remarks = e.GetValue("iTR_NARRATION") == null ? "" : e.GetValue("iTR_NARRATION").ToString();
                        if (Remarks.Length == 0) //AuditRemarks.Length == 0 && VouchingRemarks.Length == 0 &&
                        {
                            e.Row.Visible = false;
                        }
                        //var Curr_RefNo = (int?)e.GetValue("iTR_REF_NO") ?? -1;
                        //var next_Refno = (int?)grid.GetRowValues(e.VisibleIndex + 1, "iTR_REF_NO") ?? -2;
                        //if (next_Refno == Curr_RefNo)
                        //{
                        //    e.Row.Visible = false;
                        //}
                    }
                    e.Row.BackColor = System.Drawing.Color.White;

                    e.Row.CssClass += " " + settings.Name + "_PreviewRow" + " " + settings.Name + "_PreviewRow_" + KeyValue;


                    //e.Row.ID = "PreviewRow_" + e.KeyValue;
                }


            };
            settings.SetPreviewRowTemplateContent(c =>
            {
                if (VouchingMode == true)
                {
                    string KeyValue = "";
                    string Screen = DataBinder.Eval(c.DataItem, "iREC_ID") == null ? "" : DataBinder.Eval(c.DataItem, "iREC_ID").ToString();
                    if (Screen == "NOTE-BOOK")
                    {
                        KeyValue = Regex.Replace(DataBinder.Eval(c.DataItem, "iTR_M_ID").ToString(), "[^0-9A-Za-z]+", "_") + DataBinder.Eval(c.DataItem, "iTR_ITEM_ID").ToString();
                    }
                    else
                    {
                        KeyValue = Regex.Replace(DataBinder.Eval(c.DataItem, "Grid_PK").ToString(), "[^0-9A-Za-z]+", "_");
                    }
                    Html.RenderAction("AuditButtons", "AuditButton", new { Area = "", Grid = settings.Name, KeyValue = KeyValue, VisibleIndex = c.VisibleIndex, SessionGUID = SessionGUID });
                    ViewContext.Writer.Write("<br><br>");
                }
                var Remarks = DataBinder.Eval(c.DataItem, "iTR_NARRATION") == null ? "" : DataBinder.Eval(c.DataItem, "iTR_NARRATION").ToString();
                if (Remarks.Length > 0)
