@using System.Text.RegularExpressions;
@{
    int CB_ShowHorizontalBar = ViewBag.CB_ShowHorizontalBar == null ? 0 : (int)ViewBag.CB_ShowHorizontalBar;
    string CashBookID = ViewBag.CashBookID == null ? "" : (string)ViewBag.CashBookID;
    string CashBookMID = ViewBag.CashBookMID == null ? "" : (string)ViewBag.CashBookMID;
    bool VouchingMode = (bool)ViewBag.VouchingMode;
    var SessionGUID = Request.QueryString["SessionGUID"];
}
@Html.DevExpress().GridView(settings =>
{
    settings.Name = "CashBookListGridNested" + CashBookID + CashBookMID;
    settings.SettingsDetail.MasterGridName = "CashBookListGrid";
    settings.CallbackRouteValues = new { Controller = "Voucher", Action = "Frm_Voucher_Info_CB_Grid_Nested", ID = CashBookID, MID = CashBookMID ,SessionGUID = SessionGUID, VouchingMode= VouchingMode };
    settings.CustomDataActionRouteValues = new
    {
        Controller = "Voucher",
        Action = "CB_GetNestedGridData"
    };
    settings.EnableTheming = true;
    settings.Theme = "Aqua";
    settings.HtmlRowPrepared = (s, e) =>
    {
        MVCxGridView grid = (MVCxGridView)s;
        if (e.RowType == GridViewRowType.Data)
        {
            if (e.VisibleIndex % 2 == 0)
            {
                e.Row.BackColor = System.Drawing.Color.Linen;
            }
            else
            {
                e.Row.BackColor = System.Drawing.Color.AliceBlue;
            }
        }
        if (e.RowType == GridViewRowType.Preview)
        {
            e.Row.BackColor = System.Drawing.Color.LightGray;
        }

    };
    settings.Styles.FocusedRow.BackColor = System.Drawing.Color.FromArgb(0, 114, 198);
    settings.Styles.FocusedRow.ForeColor = System.Drawing.Color.White;
    settings.HtmlRowCreated= (s, e) =>
    {
        MVCxGridView grid = (MVCxGridView)s;
        if (e.RowType == GridViewRowType.Preview)
        {
            var Rejection_Reason = e.GetValue("Rejection_Reason") == null ? "" : e.GetValue("Rejection_Reason").ToString();
            var VouchingRemarks = e.GetValue("Vouching_Remarks") == null ? "" : e.GetValue("Vouching_Remarks").ToString();
            var VouchingHistory=e.GetValue("Vouching_History") == null ? "" : e.GetValue("Vouching_History").ToString();
            var VouchingDetails = e.GetValue("Vouching_Details") == null ? "" : e.GetValue("Vouching_Details").ToString();
            if ((Rejection_Reason.ToString().Length == 0) && (VouchingRemarks.ToString().Length == 0)&&(VouchingHistory.ToString().Length == 0) && (VouchingDetails.ToString().Length == 0))
            {
                // e.Row.Visible = false;
            }
        }

        if (e.RowType == GridViewRowType.Data && grid.FocusedRowIndex == -1)
        {
            var Doc_Status = e.GetValue("Doc_Status");
            var Doc_Category = e.GetValue("Document_Category");

            if (VouchingMode == false)
            {
                if ((Doc_Status == null || (string)Doc_Status == "") && Doc_Category.ToString().ToLower() != "others")
                {
                    var index = e.VisibleIndex;
                    grid.FocusedRowIndex = index;
                    return;
                }
            }
        }
    };
    settings.Init = (s, e) =>
    {
        MVCxGridView grid = (MVCxGridView)s;
        if (VouchingMode==false)
        {
            grid.FocusedRowIndex = -1;
        }

    };

    settings.CustomJSProperties = (sender, e) =>
    {
        MVCxGridView grid = (MVCxGridView)sender;
        int startIndex = (grid.PageIndex == -1 || grid.SettingsPager.Mode == GridViewPagerMode.ShowAllRecords ? 0 : grid.PageIndex) * grid.SettingsPager.PageSize;
        int endIndex = grid.PageIndex == -1 || grid.SettingsPager.Mode == GridViewPagerMode.ShowAllRecords ? grid.VisibleRowCount : Math.Min(grid.VisibleRowCount, startIndex + grid.SettingsPager.PageSize);
        object[] Rowdata = new object[endIndex - startIndex];
        for (int n = startIndex; n < endIndex; n++)
        {
            Rowdata[n - startIndex] = grid.GetRowValues(n, new string[] { "Doc_Status", "Params_Mandatory", "LABEL_FROM_DATE", "LABEL_TO_DATE", "LABEL_DESCRIPTION", "Document_Category", "Document_ID", "ATTACH_ID", "TxnID", "TxnMID", "Tr_Code", "MAP_ID", "Reason", "ATTACH_FILE_NAME", "Attachment_Action_Status", "ReasonID" });
        }
        e.Properties["cpPagedata"] = Rowdata;
    };

    settings.Width = Unit.Percentage(100);
    settings.KeyFieldName = "UniqueID";

    if (CB_ShowHorizontalBar == 1)
    {
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Visible;
        settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.Off;
        settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.Control;
        settings.SettingsResizing.Visualization = ResizingMode.Postponed;
    }
    else
    {
        if (VouchingMode == true)
        {
            settings.Styles.AdaptiveHeaderPanel.CssClass = "hideHeader";
            settings.SettingsAdaptivity.AdaptiveDetailColumnCount = 2;
            settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.HideDataCellsWindowLimit;
            settings.SettingsAdaptivity.HideDataCellsAtWindowInnerWidth = 2000;
            settings.SettingsAdaptivity.AllowOnlyOneAdaptiveDetailExpanded = false;

            var mainLayoutGroup = new GridViewLayoutGroup();
            mainLayoutGroup.Width = Unit.Percentage(100);
            mainLayoutGroup.GroupBoxDecoration = GroupBoxDecoration.None;
            mainLayoutGroup.GridSettings.StretchLastItem = DefaultBoolean.True;
            mainLayoutGroup.GridSettings.Breakpoints.Add(new LayoutBreakpoint() { MaxWidth = 600, ColumnCount = 2, Name = "M" });
            mainLayoutGroup.GridSettings.Breakpoints.Add(new LayoutBreakpoint() { MaxWidth = 150, ColumnCount = 1, Name = "S" });
            var dataColumnsGroup = new GridViewLayoutGroup();
            dataColumnsGroup.Name = "dataColumnsGroup";
            dataColumnsGroup.Width = Unit.Percentage(100);
            dataColumnsGroup.GroupBoxDecoration = GroupBoxDecoration.None;
            dataColumnsGroup.ColumnCount = 2;
            dataColumnsGroup.UseDefaultPaddings = false;
            dataColumnsGroup.AlignItemCaptions = false;
            dataColumnsGroup.GridSettings.Breakpoints.Add(new LayoutBreakpoint() { MaxWidth = 600, ColumnCount = 2, Name = "M" });
            dataColumnsGroup.GridSettings.Breakpoints.Add(new LayoutBreakpoint() { MaxWidth = 150, ColumnCount = 1, Name = "S" });
            var Item_Name = dataColumnsGroup.Items.AddColumnItem("Item_Name");
            Item_Name.SpanRules.Add(new SpanRule() { BreakpointName = "M", ColumnSpan = 2, RowSpan = 1 });
            Item_Name.SpanRules.Add(new SpanRule() { BreakpointName = "S", ColumnSpan = 1, RowSpan = 1 });
            var Document_Name = dataColumnsGroup.Items.AddColumnItem("Document_Name");
            Document_Name.SpanRules.Add(new SpanRule() { BreakpointName = "M", ColumnSpan = 2, RowSpan = 1 });
            Document_Name.SpanRules.Add(new SpanRule() { BreakpointName = "S", ColumnSpan = 1, RowSpan = 1 });
            var Reason = dataColumnsGroup.Items.AddColumnItem("Reason");
            Reason.SpanRules.Add(new SpanRule() { BreakpointName = "M", ColumnSpan = 2, RowSpan = 1 });
            Reason.SpanRules.Add(new SpanRule() { BreakpointName = "S", ColumnSpan = 1, RowSpan = 1 });
            var ATTACH_FILE_NAME = dataColumnsGroup.Items.AddColumnItem("ATTACH_FILE_NAME");
            ATTACH_FILE_NAME.SpanRules.Add(new SpanRule() { BreakpointName = "M", ColumnSpan = 2, RowSpan = 1 });
            ATTACH_FILE_NAME.SpanRules.Add(new SpanRule() { BreakpointName = "S", ColumnSpan = 1, RowSpan = 1 });
            var FromDate = dataColumnsGroup.Items.AddColumnItem("FromDate");
            FromDate.Caption = "From";
            FromDate.SpanRules.Add(new SpanRule() { BreakpointName = "M", ColumnSpan = 1, RowSpan = 1 });
            FromDate.SpanRules.Add(new SpanRule() { BreakpointName = "S", ColumnSpan = 1, RowSpan = 1 });
            var ToDate = dataColumnsGroup.Items.AddColumnItem("ToDate");
            ToDate.Caption = "To";
            ToDate.SpanRules.Add(new SpanRule() { BreakpointName = "M", ColumnSpan = 1, RowSpan = 1 });
            ToDate.SpanRules.Add(new SpanRule() { BreakpointName = "S", ColumnSpan = 1, RowSpan = 1 });
            var Description = dataColumnsGroup.Items.AddColumnItem("Description");
            Description.SpanRules.Add(new SpanRule() { BreakpointName = "M", ColumnSpan = 2, RowSpan = 1 });
            Description.SpanRules.Add(new SpanRule() { BreakpointName = "S", ColumnSpan = 1, RowSpan = 1 });
            mainLayoutGroup.Items.Add(dataColumnsGroup);

            settings.SettingsAdaptivity.AdaptiveDetailLayoutProperties.Items.AddGroup(mainLayoutGroup);
        }
        else
        {
            settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.HideDataCells;
            settings.SettingsAdaptivity.AllowHideDataCellsByColumnMinWidth = true;
            settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Hidden;
            settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.Disabled;

        }
    }
    settings.Settings.ShowPreview = true;
    settings.SetPreviewRowTemplateContent(c =>
    {
        var Rejection_Reason = DataBinder.Eval(c.DataItem, "Rejection_Reason") == null ? "" : DataBinder.Eval(c.DataItem, "Rejection_Reason").ToString();
        var VouchingStatus = DataBinder.Eval(c.DataItem, "Vouching_Status") == null ? "" : DataBinder.Eval(c.DataItem, "Vouching_Status").ToString();
        var VouchingRemarks = DataBinder.Eval(c.DataItem, "Vouching_Remarks") == null ? "" : DataBinder.Eval(c.DataItem, "Vouching_Remarks").ToString();
        var VouchingDetails = DataBinder.Eval(c.DataItem, "Vouching_Details") == null ? "" : DataBinder.Eval(c.DataItem, "Vouching_Details").ToString();
        var Vouching_Auditor = DataBinder.Eval(c.DataItem, "Vouching_Auditor") == null ? "" : DataBinder.Eval(c.DataItem, "Vouching_Auditor").ToString();
        Boolean? Vouching_During_Audit = (Boolean?)DataBinder.Eval(c.DataItem, "Vouching_During_Audit");
        var Vouching_History = DataBinder.Eval(c.DataItem, "Vouching_History") == null ? "" : DataBinder.Eval(c.DataItem, "Vouching_History").ToString();
        string MainID= DataBinder.Eval(c.DataItem, "TxnID") == null ? "" : DataBinder.Eval(c.DataItem, "TxnID").ToString();
        string MainMID = DataBinder.Eval(c.DataItem, "TxnMID") == null ? "" : DataBinder.Eval(c.DataItem, "TxnMID").ToString();
        string TempID = MainMID.Length > 0 ? MainMID : MainID;
        TempID = Regex.Replace(TempID, "[^0-9A-Za-z-]+", "_");
        if (Rejection_Reason.Length > 0)
        {
            ViewContext.Writer.Write("<div><span style='color: #FF0000'> <i>Document has been rejected by Madhuban. Reason : " + Rejection_Reason + "</i></span></div>");
        }
        ViewContext.Writer.Write("<div id='Attachment_PrevRow_AuditInfo_CashBookListGrid" + TempID + c.KeyValue + "'>");
        if (VouchingRemarks.Length > 0 || VouchingDetails.Length > 0)
        {
            if (VouchingStatus.ToUpper() == "REJECTED")
            {
                ViewContext.Writer.Write("<div><span style='color:#FF0000'> <i>" + (Vouching_During_Audit == false ? "Vouching" : "Audit") + (VouchingRemarks.Length > 0 ? " Rejection Remarks: " : " Rejection Details: ") + VouchingRemarks + VouchingDetails +"</i></span></div>");
            }
            else if (VouchingStatus.ToUpper() == "ACCEPTED")
            {
                ViewContext.Writer.Write("<div><span style='color:#008000'> <i>" + (Vouching_During_Audit == false ? "Vouching" : "Audit") + (VouchingRemarks.Length > 0 ? " Acceptance Remarks: " : " Acceptance Details: ") + VouchingRemarks + VouchingDetails +"</i></span></div>");
            }
        }
        if (Vouching_History.Length>0)
        {
            ViewContext.Writer.Write("<div>" + Vouching_History + "</div>");
        }
        ViewContext.Writer.Write("</div>");
    });

    settings.Columns.Add(column =>
    {
        column.Caption = "";
        column.MinWidth = 30;
        column.MaxWidth = 30;
        column.Visible = VouchingMode == true ? false : true;
        column.SetDataItemTemplateContent(c =>
        {
            string Doc_Status = c.Grid.GetRowValues(c.VisibleIndex, "Doc_Status").ToString();
            string Doc_Checking_Status = c.Grid.GetRowValues(c.VisibleIndex, "Doc_Checking_Status").ToString();
            string ATTACH_FILE_NAME = c.Grid.GetRowValues(c.VisibleIndex, "ATTACH_FILE_NAME")==null?"" : c.Grid.GetRowValues(c.VisibleIndex, "ATTACH_FILE_NAME").ToString();
            string Rejection_Reason = c.Grid.GetRowValues(c.VisibleIndex, "Rejection_Reason") == null ? "" : c.Grid.GetRowValues(c.VisibleIndex, "Rejection_Reason").ToString();
            string VOUCHING_REMARKS = DataBinder.Eval(c.DataItem, "Vouching_Remarks") == null ? "" : DataBinder.Eval(c.DataItem, "Vouching_Remarks").ToString();
            string VOUCHING_STATUS = DataBinder.Eval(c.DataItem, "Vouching_Status") == null ? "" : DataBinder.Eval(c.DataItem, "Vouching_Status").ToString().ToUpper();
            string VOUCHING_DETAILS = DataBinder.Eval(c.DataItem, "Vouching_Details") == null ? "" : DataBinder.Eval(c.DataItem, "Vouching_Details").ToString().ToUpper();
            Boolean? Vouching_During_Audit = (Boolean?)DataBinder.Eval(c.DataItem, "Vouching_During_Audit");
            string ItemName = c.Grid.GetRowValues(c.VisibleIndex, "Item_Name").ToString();
            string MainID = DataBinder.Eval(c.DataItem, "TxnID") == null ? "" : DataBinder.Eval(c.DataItem, "TxnID").ToString();
            string MainMID = DataBinder.Eval(c.DataItem, "TxnMID") == null ? "" : DataBinder.Eval(c.DataItem, "TxnMID").ToString();
            string TempID = MainMID.Length > 0 ? MainMID : MainID;
            var VOUCHING_AUDITOR = DataBinder.Eval(c.DataItem, "Vouching_Auditor") == null ? "" : DataBinder.Eval(c.DataItem, "Vouching_Auditor").ToString();
            TempID = Regex.Replace(TempID, "[^0-9A-Za-z-]+", "_");
            Html.RenderAction("AttachmentIcons_Attachment", "AuditButton", new { Area = "", Doc_Status = Doc_Status, Doc_Checking_Status = Doc_Checking_Status, ATTACH_FILE_NAME = ATTACH_FILE_NAME, Rejection_Reason = Rejection_Reason, ItemName = ItemName, SessionGUID = SessionGUID });
            ViewContext.Writer.Write("<span id='Attachment_Icon_CashBookListGrid" + TempID + c.KeyValue + "'>");
            Html.RenderAction("VouchingAuditIcons_Attachment", "AuditButton", new { Area = "", VOUCHING_STATUS = VOUCHING_STATUS, VOUCHING_REMARKS = VOUCHING_REMARKS, VOUCHING_DETAILS = VOUCHING_DETAILS, Vouching_During_Audit = Vouching_During_Audit, VOUCHING_AUDITOR = VOUCHING_AUDITOR, SessionGUID = SessionGUID });
            ViewContext.Writer.Write("</span>");
        });
        column.AdaptivePriority = 0;
    });
    settings.Columns.Add(column =>
