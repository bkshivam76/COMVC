@using DevExtreme.AspNet.Mvc;
@{
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;
    var SessionGUID = Request.QueryString["SessionGUID"];
    int CB_ShowHorizontalBar = ViewBag.CB_ShowHorizontalBar == null ? 0 : (int)ViewBag.CB_ShowHorizontalBar;  

}
@(Html.DevExtreme().DataGrid().CustomDataGridListing(CB_ShowHorizontalBar)
            .ID("CashBookListGrid")
           // .DataSource(new List<ConnectOneMVC.Areas.Account.Models.CB_Grid_Model>(), "Grid_PK")
            .DataSource(new string[] { }, "Grid_PK")          
                         .Columns(columns =>
                         {
                             columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false).AllowGrouping(false);
                             columns.Add().DataField("iIcon").Name("iIcon").Caption("").CellTemplate(new JS("CashBookListGrid_dx_iIconTemplate")).Width(30)
                             .HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource")).AllowGrouping(false).HidingPriority(13);
                             columns.Add().DataField("CB_Compact_Column").Name("CB_Compact_Column").Caption("").Visible(false).CellTemplate(new JS("CashBookListGrid_dx_Compact_Column_Template"))
                             .CalculateCellValue("CashBookListGrid_dx_Compact_Column_CellValue").Width("100%").ShowInColumnChooser(false).AllowGrouping(false);
                             columns.Add().DataField("Attachment_IDs").Visible(false).AllowGrouping(false);
                             columns.Add().Caption("Voucher").Alignment(HorizontalAlignment.Center).CssClass("dxDatagridHeaderBand").AllowGrouping(false).IsBand(true)
                             .Columns
                             (
                                 s =>
                                 {
                                     s.Add().DataField("iTR_REF_NO").Caption(" ").Width(30).Visible(true).AllowGrouping(false);
                                     s.Add().DataField("iTR_VNO").Visible(false).AllowGrouping(false);
                                     s.Add().DataField("iTR_DATE").Caption("Date").Width(75).Visible(true).DataType(GridColumnDataType.Date).Format("dd-MM-yyyy").AllowGrouping(false).HidingPriority(12);

                                 }
                             );
                             columns.Add().Caption("Receipts").Alignment(HorizontalAlignment.Center).CssClass("dxDatagridHeaderBand").AllowGrouping(false).IsBand(true)
                             .Columns
                             (
                                 s =>
                                 {
                                     s.Add().DataField("iTR_REC_CASH").Caption("Cash").MinWidth(50).Visible(true).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}")).AllowGrouping(false).HidingPriority(7).DataType(GridColumnDataType.Number);
                                     s.Add().DataField("iTR_REC_BANK").Caption("Bank").MinWidth(50).Visible(true).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}")).AllowGrouping(false).HidingPriority(6).DataType(GridColumnDataType.Number);
                                     s.Add().DataField("iTR_REC_JOURNAL").Caption("Journal").MinWidth(50).Visible(true).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}")).AllowGrouping(false).HidingPriority(5).DataType(GridColumnDataType.Number);
                                     s.Add().DataField("iTR_REC_TOTAL").Caption("Total").MinWidth(50).Visible(true).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}")).AllowGrouping(false).HidingPriority(4).DataType(GridColumnDataType.Number);
                                 }
                             );
                             columns.Add().Caption("Particulars").Alignment(HorizontalAlignment.Center).CssClass("dxDatagridHeaderBand").AllowGrouping(false).IsBand(true)
                             .Columns
                             (
                                 s =>
                                 {
                                     s.Add().DataField("iTR_ITEM").Caption("Item").Width(100).Visible(true).CssClass("CbItemCol").AllowGrouping(false).HidingPriority(11);
                                     s.Add().DataField("iTR_HEAD").Caption("Head").Width(100).Visible(true).AllowGrouping(false).HidingPriority(9);
                                     s.Add().DataField("iTR_PARTY_1").Caption("Party/Bank").MinWidth(70).Visible(true).AllowGrouping(false).HidingPriority(10);
                                     s.Add().DataField("iRef_no").Caption("Chq/DD/Ref No").MinWidth(70).Visible(true).AllowGrouping(false).HidingPriority(8);
                                     s.Add().DataField("iTR_NARRATION").Caption("Narration").MinWidth(100).Visible(false).AllowGrouping(false);
                                     s.Add().DataField("ITEM_TDS_CODE").Caption("TDS Code").MinWidth(100).Visible(false).AllowGrouping(false);
                                     s.Add().DataField("LED_TYPE").Caption("Led. Type").MinWidth(100).Visible(false).AllowGrouping(false);
                                 }
                             );
                             columns.Add().Caption("Payments").Alignment(HorizontalAlignment.Center).CssClass("dxDatagridHeaderBand").AllowGrouping(false).IsBand(true)
                             .Columns
                             (
                                 s =>
                                 {
                                     s.Add().DataField("iTR_PAY_CASH").Caption("Cash").MinWidth(20).Visible(true).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}")).AllowGrouping(false).HidingPriority(3).DataType(GridColumnDataType.Number);
                                     s.Add().DataField("iTR_PAY_BANK").Caption("Bank").MinWidth(20).Visible(true).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}")).AllowGrouping(false).HidingPriority(2).DataType(GridColumnDataType.Number);
                                     s.Add().DataField("iTR_PAY_JOURNAL").Caption("Journal").MinWidth(20).Visible(true).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}")).AllowGrouping(false).HidingPriority(1).DataType(GridColumnDataType.Number);
                                     s.Add().DataField("iTR_PAY_TOTAL").Caption("Total").MinWidth(20).Visible(true).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}")).AllowGrouping(false).HidingPriority(0).DataType(GridColumnDataType.Number);
                                 }
                             );

                             columns.Add().DataField("iTR_ITEM_ID").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iLED_ID").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iTR_SUB_ID").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iTR_AB_ID_1").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iTR_CR_ID").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iTR_CR_NAME").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iTR_DATE_SERIAL").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iTR_DATE_SHOW").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iTR_ENTRY").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iTR_ROW_POS").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iTR_TYPE").Caption("Entry Tr. Type").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iTR_CODE").Caption("Entry Tr. Code").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iREC_ID").Caption("Entry Rec.ID").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iTR_M_ID").Caption("Entry Rec.M.ID").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iTR_SR_NO").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iTR_SORT").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iREC_ADD_ON").Caption("Entry Add On").Visible(false).AllowGrouping(false).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss");
                             columns.Add().DataField("iTR_TEMP_ID").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iACTION_STATUS").Caption("Entry Status").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iREC_EDIT_ON").Caption("Entry Edit On").Visible(false).AllowGrouping(false).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss");
                             columns.Add().DataField("iREC_STATUS_ON").Caption("Entry Status On").Visible(false).AllowGrouping(false).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss");
                             columns.Add().DataField("iREC_ADD_BY").Caption("Entry Add By").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iREC_EDIT_BY").Caption("Entry Edit By").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iREC_STATUS_BY").Caption("Entry Status By").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iCross_Ref_ID").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("iPurpose").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("SPECIAL_VOUCHER_REFERENCE").Caption("Vch.Reference").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("BA_ACC_NO").Caption("BankAccNo").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("Advanced_Filter").Visible(false).AllowGrouping(false);
                             //columns.Add().DataField("Sr").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("REQ_ATTACH_COUNT").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("COMPLETE_ATTACH_COUNT").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("RESPONDED_COUNT").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("REJECTED_COUNT").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("OTHER_ATTACH_CNT").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("ALL_ATTACH_CNT").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("Grid_PK").Visible(false).AllowGrouping(false);
                             columns.Add().DataField("TR_INV_NO").Caption("InvNo").Visible(false).AllowGrouping(false);
                         })
                         .Sorting(s => s.Mode(GridSortingMode.None))
                         .FilterPanel(s => s.Visible(true).CustomizeText("CashBookListGrid_dx_FilterPanelText"))
                         .FilterSyncEnabled(true)
                         .GroupPanel(s=>s.Visible(false))
.MasterDetail(md =>
{
    md.AutoExpandAll(false);
    md.Enabled(!VouchingMode);
    md.Template(new JS("CashBookListGrid_dx_DetailTemplate"));
})
.Summary(s =>
{
    s.TotalItems(item =>
    {
        item.Add().Name("iTR_DATE_iTR_DATE_count").SummaryType(SummaryType.Count).Column("iTR_DATE").ShowInColumn("iTR_DATE").DisplayFormat("Total :");
        item.Add().Name("iTR_REC_CASH_iTR_REC_CASH_sum").SummaryType(SummaryType.Sum).Column("iTR_REC_CASH").ShowInColumn("iTR_REC_CASH").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
        item.Add().Name("iTR_REC_BANK_iTR_REC_BANK_sum").SummaryType(SummaryType.Sum).Column("iTR_REC_BANK").ShowInColumn("iTR_REC_BANK").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
        item.Add().Name("iTR_REC_JOURNAL_iTR_REC_JOURNAL_sum").SummaryType(SummaryType.Sum).Column("iTR_REC_JOURNAL").ShowInColumn("iTR_REC_JOURNAL").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
        item.Add().Name("iTR_REC_TOTAL_iTR_REC_TOTAL_sum").SummaryType(SummaryType.Sum).Column("iTR_REC_TOTAL").ShowInColumn("iTR_REC_TOTAL").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
        item.Add().Name("iTR_PAY_CASH_iTR_PAY_CASH_sum").SummaryType(SummaryType.Sum).Column("iTR_PAY_CASH").ShowInColumn("iTR_PAY_CASH").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
        item.Add().Name("iTR_PAY_BANK_iTR_PAY_BANK_sum").SummaryType(SummaryType.Sum).Column("iTR_PAY_BANK").ShowInColumn("iTR_PAY_BANK").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
        item.Add().Name("iTR_PAY_JOURNAL_iTR_PAY_JOURNAL_sum").SummaryType(SummaryType.Sum).Column("iTR_PAY_JOURNAL").ShowInColumn("iTR_PAY_JOURNAL").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
        item.Add().Name("iTR_PAY_TOTAL_iTR_PAY_TOTAL_sum").SummaryType(SummaryType.Sum).Column("iTR_PAY_TOTAL").ShowInColumn("iTR_PAY_TOTAL").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));

    });
})
.OnInitialized("CashBookListGrid_dx_OnInitialized")
.OnCellPrepared("CashBookListGrid_dx_OnCellPrepared")
.OnRowPrepared("CashBookListGrid_dx_OnRowPrepared")
.OnContentReady("CashBookListGrid_dx_OnContentReady")
.OnCellDblClick("CashBookListGrid_dx_OnCellDblClick")
.OnSelectionChanged("CashBookListGrid_dx_OnSelectionChanged")
.OnRowExpanding("CashBookListGrid_dx_OnRowExpanding")
.OnRowCollapsing("CashBookListGrid_dx_OnRowCollapsing")
.OnContextMenuPreparing("CashBookListGrid_dx_OnContextMenuPreparing")
.OnOptionChanged("CashBookListGrid_dx_OnOnOptionChanged")
 //.OnKeyDown("DxGrid_KeyDown")


)