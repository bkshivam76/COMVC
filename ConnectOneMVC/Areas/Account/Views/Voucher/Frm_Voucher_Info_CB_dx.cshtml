        async function CashBookListGrid_dx_OnOnOptionChanged(e)
        {
            if (e.fullName === "paging.pageIndex")
            {
                var PageChangeAfterPeriodChange = CashBookListGrid.option("CustomProp.PageChangeAfterPeriodChange");
                var PageChangeOnAutoMode = CashBookListGrid.option("CustomProp.PageChangeOnAutoMode");
                PageChangeAfterPeriodChange = PageChangeAfterPeriodChange == void 0 ? false : PageChangeAfterPeriodChange;
                PageChangeOnAutoMode = PageChangeOnAutoMode == void 0 ? false : PageChangeOnAutoMode;
                if (PageChangeAfterPeriodChange == false)
                {
                    if (PageChangeOnAutoMode == true)
                    {
                        CashBookListGrid.option("CustomProp.PageChangeOnAutoMode", false);
                        await CashBookListGrid.expandRow(CB_Next_Unattended_Attachment_Key)
                        //CB_ScrollRowToView(CB_Next_Unattended_Attachment_Key)
                    }
                    else
                    {
                        const pageIndex = e.component.pageIndex();
                        const pageSize = e.component.pageSize();
                        var startIndex = pageIndex * pageSize;
                        var endIndex = startIndex + pageSize - 1;
                        if (CB_Grid_FousedRowIndex > -1)
                        {
                            if (CB_Grid_FousedRowIndex > endIndex || CB_Grid_FousedRowIndex < startIndex)
                            {
                                CashBookListGrid.clearSelection();
                            }
                        }
                       // CashBookListGrid.clearSelection();
                        if (CB_ExpandedRowKey != null && CB_ExpandedRowKey.length > 0)
                        {
                           await CashBookListGrid.collapseRow(CB_ExpandedRowKey)
                        }
                    }
                }
                else
                {
                    CashBookListGrid.option("CustomProp.PageChangeAfterPeriodChange", false);
                }
            }
            else if (e.fullName ==="paging.pageSize")
            {
                //const pageCount = e.component.pageCount();
                const pageIndex = e.component.pageIndex();
                const pageSize = e.component.pageSize();
                var startIndex = pageIndex * pageSize;
                var endIndex = startIndex + pageSize-1;
                if (CB_ExpandedRowKey != null && CB_ExpandedRowKey.length > 0)
                {
                   // if (CB_ExpandedRowIndex > endIndex || CB_ExpandedRowIndex < startIndex)
                   // {
                        await CashBookListGrid.collapseRow(CB_ExpandedRowKey)
                   // }
                }
                if (CB_Grid_FousedRowIndex > -1)
                {
                    //if (CB_Grid_FousedRowIndex > endIndex || CB_Grid_FousedRowIndex < startIndex)
                   // {
                      //  CashBookListGrid.clearSelection();
                    // }
                    e.component.navigateToRow(CB_Grid_PK)
                }
            }
        }
