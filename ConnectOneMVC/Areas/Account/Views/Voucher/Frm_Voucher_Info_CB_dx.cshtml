        function CashBookListGrid_dx_Detail_onRowPrepared(e)
        {
            if (e.rowType == "data")
            {
                var PreviewRowContent = CashBookListGrid_dx_Detail_PreviewRow_Template(e)
                var PreviewRowClass = "DataGridPreviewRow"
                var PreviewRowOptions = "";
                var EmptyTdshtml = "";
                var emptyTd = $(e.rowElement).find('td.dx-datagrid-group-space').length
                for (var i = 0; i < emptyTd; i++)
                {
                    EmptyTdshtml += "<td></td>"
                }
                ($(e.rowElement).parent()).append("<tr class='" + PreviewRowClass + "' " + PreviewRowOptions + ">" + EmptyTdshtml + "<td colspan='" + e.columns.length + "'>" + PreviewRowContent + "</td></tr>")
            }
        }
        function CashBookListGrid_dx_Detail_onContentReady(e)
        {
            var rows = e.component.getVisibleRows();
            var count = rows.length;
            var selectedKeys = CashBookListGrid.option("CustomProp.NestedGridSelectedKey");
            var ClearSelection = CashBookListGrid.option("CustomProp.NestedGridClearSelection")
            ClearSelection = ClearSelection == void 0 ? false : ClearSelection;
            if (ClearSelection == true)
            {
                e.component.clearSelection();
                CashBookListGrid.option("CustomProp.NestedGridClearSelection",false)
            }
            else
            {
                if (selectedKeys)
                {
                    CashBookListGrid.option("CustomProp.NestedGridSelectedKey", null)
                    e.component.clearSelection();
                    e.component.option('selectedRowKeys', selectedKeys);                
                }
                else
                {
                    selectedKeys = e.component.getSelectedRowKeys();
                    for (var i = 0; i < count; i++)
                    {
                        if (rows[i].rowType == "data")
                        {
                            var Doc_Status = rows[i].data.Doc_Status;
                            var Doc_Category = rows[i].data.Document_Category;
                            if (CB_IsVouchingMode == false && (selectedKeys == null || selectedKeys.length == 0))
                            {
                                if ((Doc_Status == null || Doc_Status == "") && Doc_Category.toLowerCase() != "others")
                                {
                                  //  await e.component.selectRows(rows[i].key);
                                    e.component.clearSelection();
                                    e.component.option('selectedRowKeys', [rows[i].key]);
                                    break;
                                }
                            }
                            if (CB_IsVouchingMode == true) {
                                if (selectedKeys == null || selectedKeys.length == 0) {
                                    if (i == 0) {
                                        e.component.clearSelection();
                                        e.component.option('selectedRowKeys', [rows[i].key]);
                                        break;
                                    }
                                }
                            }
                        }
                    }
                }
            }
            DxGrid_SetGridUIinColHiding(e.element[0].id, CB_ShowHorizontalBar, true)
            DxGrid_GetFIlterBuilderDataSource(e)
        }
        function CashBookListGrid_dx_Detail_onSelectionChanged(e)
        {
            if (CB_IsDetailRowExpanded || CB_IsVouchingMode == true)
            {
                if (e.selectedRowsData != null && e.selectedRowsData.length > 0)
                {
                    CB_NestedGrid_AccessID = e.element[0].id;
                    CashBookListGrid_dx_Detail_SelectedRowData(e.selectedRowsData);
                    if (CB_IsVouchingMode == true)
                    {
                        if (isSuperuserOrAuditor) {
                            fab.SetActionContext("AuditActionContext", true);
                        }
                        else {
                            if (CB_Nested_Doc_Status == "") {
                                fab.SetActionContext("AutoItemContext", true);
                            }
                            else if (CB_Nested_Doc_Status == "NO") {
                                fab.SetActionContext("EditItemContext", true);
                            }
                            else if (CB_Nested_Doc_Status == "YES") {
                                fab.SetActionContext("actionItemContext", true);
                            }
                        }
                        if (CB_filename != null && CB_filename.length > 0)
                        {
                            OnCashBookViewAttachmentPopup();
                        }
                        else
                        {
                            CloseRightPane();
                            ClearRightPane();
                        }
                    }
                    else
                    {
                        if (CB_Nested_Doc_Status == "")
                        {
                            fab.SetActionContext("AutoItemContext", true);
                        }
                        else if (CB_Nested_Doc_Status == "NO")
                        {
                            fab.SetActionContext("EditItemContext", true);
                        }
                        else if (CB_Nested_Doc_Status == "YES")
                        {
                            fab.SetActionContext("actionItemContext", true);
                        }
                    }
                }
                else
                {
                    CB_MasterRowMID = null;
                    CB_MasterRowRecID = null;
                    CashBook_NestedRowUniqueID = null;
                    fab.SetActionContext("AddAttachmentContext", false);
                }
            }
        }
        function CashBookListGrid_dx_Detail_SelectedRowData(selectedData = null)
        {
            if (selectedData == null)
            {
                selectedData = $("div[id='" + CB_NestedGrid_AccessID + "']").dxDataGrid("getSeletedRowsData");
            }
            if (selectedData != null && selectedData.length > 0) {
                var values = selectedData[0];
                CashBook_NestedRowUniqueID = values.UniqueID;
                CB_Nested_Doc_Status = values.Doc_Status;
                CB_Nested_Params_Mandatory = values.Params_Mandatory;
                CB_Nested_LABEL_FROM_DATE = values.LABEL_FROM_DATE;
                CB_Nested_LABEL_TO_DATE = values.LABEL_TO_DATE;
                CB_Nested_LABEL_DESCRIPTION = values.LABEL_DESCRIPTION;
                CB_Doc_Category = values.Document_Category;
                CB_Doc_ID = values.Document_ID;
                CB_Attachment_ID = values.ATTACH_ID;
                IndexAttachmentID = CB_Attachment_ID;
                CB_MasterRowRecID = values.TxnID;
                CB_MasterRowMID = values.TxnMID ?? "";
                CB_MasterRowTrCode = values.Tr_Code;
                GetVoucherScreenName(CB_MasterRowTrCode);
                CB_NestedRowMapID = values.MAP_ID;
                CB_reason = values.Reason;
                CB_filename = values.ATTACH_FILE_NAME;
                CB_Attachment_Action_Status = values.Attachment_Action_Status;
                CB_Nested_RowReasonID = values.ReasonID;
                IndexAttachmentReasonID = CB_Nested_RowReasonID;
            }
            else
            {
                CB_MasterRowMID = null;
                CB_MasterRowRecID = null;
                CashBook_NestedRowUniqueID = null;
                fab.SetActionContext("AddAttachmentContext", false);
            }
        }
        function CashBookListGrid_dx_Detail_onContextMenuPreparing(e)
        {
            if (!e.items) e.items = [];
            if (e.target == "header") {
                DxGrid_HeaderContextMenu(e)
            }
            else if ((e.target == "content" && e.row && e.row.rowType == "groupFooter") || e.target == "footer") {
                DxGrid_FooterContextMenu(e);
            }

            else if (e.target == "content" && e.row && e.row.rowType == "data") {
                e.items = [{
                    text: "Refresh",
                    icon: "fa-solid fa-arrow-rotate-right text-success",
                    onItemClick: function ()
                    {
                        var selectedRowKey = e.component.getSelectedRowKeys();
                        e.component.refresh().done(function ()
                        {
                            if (selectedRowKey)
                            {
                                e.component.clearSelection();
                                e.component.selectRows(selectedRowKey)
                            }
                        });
                    }
                }]
            }
            else if (e.target == "content" && e.row == void 0) {
                e.items = [
                    {
                        text: "Refresh",
                        icon: "fa-solid fa-arrow-rotate-right text-success",
                        onItemClick: function () {
                            var selectedRowKey = e.component.getSelectedRowKeys();
                            e.component.refresh().done(function () {
                                if (selectedRowKey) {
                                    e.component.clearSelection();
                                    e.component.selectRows(selectedRowKey)
                                }
                            });
                        }
                    }
                ]
            }
        }

