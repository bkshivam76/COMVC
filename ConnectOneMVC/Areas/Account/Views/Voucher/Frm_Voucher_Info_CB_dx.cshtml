        function CashBookListGrid_dx_Compact_Column_CellValue(rowData) {
            var data = [rowData.iTR_REF_NO, (JS_Json_Date_To_ddMMyyyy((rowData.iTR_DATE ?? ""), "DD-MM-YYYY") ?? ""), rowData.iTR_HEAD, rowData.iTR_ITEM, rowData.iTR_PARTY_1, rowData.iRef_no];
            var PayCash = rowData.iTR_PAY_CASH;
            var PayBank = rowData.iTR_PAY_CASH;
            var PayJournal = rowData.iTR_PAY_CASH;
            var RecCash = rowData.iTR_REC_CASH;
            var RecBank = rowData.iTR_REC_BANK;
            var RecJournal = rowData.iTR_REC_JOURNAL;
            if (PayCash != null || PayBank != null || PayJournal != null) {
                if (PayCash != null) { data.push(PayCash) }
                if (PayBank != null) { data.push(PayBank) }
                if (PayJournal != null) { data.push(PayJournal) }
            }
            if (RecCash != null || RecBank != null || RecJournal != null) {
                if (RecCash != null) { data.push(RecCash) }
                if (RecBank != null) { data.push(RecBank) }
                if (RecJournal != null) { data.push(RecJournal) }
            }
            return data.join(" ")
        }
