        async function CashBookListGrid_dx_OnRowExpanding(e)
        {
            if (Array.isArray(e.key) == false) //not group row
            {
                CB_KeyToSelect = e.key;
                if (CB_ExpandedRowKey != null && CB_ExpandedRowKey.length > 0)
                {
                    await e.component.collapseRow(CB_ExpandedRowKey)
                }              
                //e.component.selectRows(e.key);   
                fab.SetActionContext("AddAttachmentContext", false);
                CB_ExpandedRowKey = e.key;
                CB_ExpandedRowIndex = GetRowIndexAsPerDataSource("CashBookListGrid", "dxDataGrid", e.key)
                CB_IsDetailRowExpanded = true;
                CB_GridFocusedOrExpandedIndex = CB_ExpandedRowIndex;
                if (CB_GridFocusedOrExpandedIndex < CB_Next_Unattended_Attachment_Index)
                {
                    CB_Next_Unattended_Attachment_Index = -3;
                }
                var DetailGridID = e.element[0].id + e.key;
                var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
                if (instance != void 0)
                {
                    instance.state(null) // grid maintains its state after collapsing so resetting the state when expands again as per old grid
                }
                //e.component.collapseAll(-1);
            }
            else {
                e.component.option("CustomProp.groupRowExpanded", true);
            }
        }
        function CashBookListGrid_dx_OnRowCollapsing(e)
        {
            if (Array.isArray(e.key) == false) //not group row
            {
                CB_ExpandedRowKey = null;
                CB_IsDetailRowExpanded = false;
                CB_ExpandedRowIndex = -1;
                //e.component.selectRows(e.key);
                if (CB_Grid_FousedRowIndex >= 0)
                {
                    CB_GridFocusedOrExpandedIndex = CB_Grid_FousedRowIndex;
                }
                else
                {
                    CB_GridFocusedOrExpandedIndex = -1;
                }
                if (CB_GridFocusedOrExpandedIndex < CB_Next_Unattended_Attachment_Index)
                {
                    CB_Next_Unattended_Attachment_Index = -3;
                }
                fab.SetActionContext("AddAttachmentContext", false);
                var DetailGridID = e.element[0].id + e.key;
                sessionStorage.removeItem(DetailGridID + "_DetailGridState"); //removing grid state from session storage on collapse
                var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
                if (instance != void 0)
                {
                    instance.clearSelection();
                }
            }
            else {
                e.component.option("CustomProp.groupRowCollapsed", true);
            }
            if (CB_IsVouchingMode == false)
            {
                CloseRightPane();
            }
        }
