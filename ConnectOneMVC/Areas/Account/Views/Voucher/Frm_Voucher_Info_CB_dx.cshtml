        async function IfRowIsPresent_CB(key)
        {
            var rowPresentInDataSource = false;
            var rowPresentAfterFilter = false;
            var rowPresentInVisiblePage = false;
            var CombinedFilter = CashBookListGrid.getCombinedFilter(true);
            var CB_gridData = GetDataSourceItems("CashBookListGrid", "dxDataGrid")
            var ifRowToSelectPresent = CB_gridData.filter(x => x.Grid_PK == key)
            if (ifRowToSelectPresent != null && ifRowToSelectPresent.length > 0)
            {
                rowPresentInDataSource = true;
            }      
            if (CombinedFilter)
            {
                var CB_filteredData = await CashBookListGrid
                    .getDataSource()
                    .store()
                    .load({ filter: CombinedFilter })
                var ifRowToSelectPresent = CB_filteredData.filter(x => x.Grid_PK == key)
                if (ifRowToSelectPresent != null && ifRowToSelectPresent.length > 0)
                {
                    rowPresentAfterFilter= true
                }
                CB_filteredData = null;
            }
            else
            {
                rowPresentAfterFilter = true
            }        
            var visibleRows = CashBookListGrid.getVisibleRows()
            var ifRowToSelectPresent = visibleRows.filter(x => x.rowType == "data" && x.key == key)
            if (ifRowToSelectPresent != null && ifRowToSelectPresent.length > 0)
            {
                rowPresentInVisiblePage = true;
            }
            CB_gridData = null;
            return [rowPresentInDataSource && rowPresentAfterFilter, rowPresentInVisiblePage]
        }
