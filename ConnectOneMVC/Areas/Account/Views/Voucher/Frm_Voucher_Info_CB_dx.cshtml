        async function ActionAfter_CashBookListGrid_Refresh(GridData, AdvFilterString)
        {
            debugger
            var DataSource = CashBookListGrid.getDataSource();
            var isLoaded = DataSource.isLoaded();
            if (isLoaded == false)
            {
              await DataSource.load();
            }           
            if (AdvFilterString != null && AdvFilterString.length > 0)
            {
                var AdvancedFilter = [];
                var newFilter = [];            
                var searchText = CashBookListGrid.option("searchPanel.text")
                CashBookListGrid.clearFilter("search");              
                CashBookListGrid.columnOption('Advanced_Filter', 'filterValue', null);   // clears row filter
                CashBookListGrid.columnOption('Advanced_Filter', 'filterValues', null); // clears header filter           
                var CurrentFilters = CashBookListGrid.getCombinedFilter(true) ?? [];  
                var filterSplit = AdvFilterString.split(',');
                AdvancedFilter.push(filterSplit[0].trim())
                AdvancedFilter.push(filterSplit[1].trim())
                AdvancedFilter.push(filterSplit[2].trim())
                if (CurrentFilters.length > 0)
                {
                    let removedIndices = new Set();
                    for (var i = 0; i < CurrentFilters.length; i++)
                    {
                        let array = CurrentFilters[i];
                        if (Array.isArray(array) && array.some(item => typeof item === 'string' && item.includes('Advanced_Filter')))
                        {
                            // Mark current array for removal
                            removedIndices.add(i);
                        }
                        else if (!Array.isArray(array) && typeof array === 'string' && array.includes('Advanced_Filter'))
                        {
                            removedIndices.add(i);
                            // Mark next two consecutive elements for removal (if they exist)
                            if (i + 1 < CurrentFilters.length) removedIndices.add(i + 1);
                            if (i + 2 < CurrentFilters.length) removedIndices.add(i + 2);
                        }
                    }
                    // Filter out elements based on removedIndices
                    let filteredArrays = CurrentFilters.filter((_, index) => !removedIndices.has(index));                 
                    if (filteredArrays && filteredArrays.length > 0)
                    {
                        let removedFilterArray = Array.from(removedIndices);
                        if (removedFilterArray && removedFilterArray.length > 0)
                        {
                            if (removedFilterArray[0] == 0) {
                                filteredArrays.splice(1, 1);
                            }
                            else
                            {
                                filteredArrays.splice((removedFilterArray[0]-1), 1);
                            }
                        }
                    }
                    newFilter.push(filteredArrays)
                    newFilter.push('or')
                }
                newFilter.push(AdvancedFilter)
                CashBookListGrid.option('filterValue', newFilter)
                if (searchText)
                {
                    CashBookListGrid.option("searchPanel.text", searchText)
                }
            }
            var Refresh_AfterPeriodChange = CashBookListGrid.option("CustomProp.Refresh_AfterPeriodChange");
            var Refresh_AfterActionItemClick = CashBookListGrid.option("CustomProp.Refresh_AfterActionItemClick");
            var Refresh_AfterAuditActionClick = CashBookListGrid.option("CustomProp.Refresh_AfterAuditActionClick");
            var PeriodChange_AfterVoucherOperation = CashBookListGrid.option("CustomProp.PeriodChange_AfterVoucherOperation");
            var AddMoreEntry = CashBookListGrid.option("CustomProp.AddMoreEntry")
            var FocusedRowIndexBeforeRefresh = CashBookListGrid.option("CustomProp.FocusedRowIndexBeforeRefresh")
            var Refresh_AfterActionItemClickWithFilter_Count = CashBookListGrid.option("CustomProp.Refresh_AfterActionItemClickWithFilter_Count")
            Refresh_AfterPeriodChange = Refresh_AfterPeriodChange == void 0 ? false : Refresh_AfterPeriodChange;
            Refresh_AfterActionItemClick = Refresh_AfterActionItemClick == void 0 ? false : Refresh_AfterActionItemClick;
            Refresh_AfterAuditActionClick = Refresh_AfterAuditActionClick == void 0 ? false : Refresh_AfterAuditActionClick;
            PeriodChange_AfterVoucherOperation = PeriodChange_AfterVoucherOperation == void 0 ? false : PeriodChange_AfterVoucherOperation;
            AddMoreEntry = AddMoreEntry == void 0 ? false : AddMoreEntry;
            Refresh_AfterActionItemClickWithFilter_Count = Refresh_AfterActionItemClickWithFilter_Count == void 0 ? 0 : Refresh_AfterActionItemClickWithFilter_Count;         
            if (CB_Select_xID != null && CB_Select_xID.length > 0)
            {           
                CB_KeyToSelect = CB_Select_xID;
                CB_Select_xID = "";
            }
            else if (Refresh_AfterPeriodChange == false && (Refresh_AfterActionItemClick == false || CB_IsToBeAuto==false))
            {
                var keyToSelect = null;
                if (FocusedRowIndexBeforeRefresh > -1)
                {
                    if (FocusedRowIndexBeforeRefresh >= GridData.length)
                    {
                        if (GridData.length > 0)
                        {
                            keyToSelect=GridData[GridData.length - 1].Grid_PK;
                        }
                    }
                    else
                    {
                        keyToSelect=GridData[FocusedRowIndexBeforeRefresh].Grid_PK;
                    }
                }               
                if (keyToSelect != null && keyToSelect.length > 0)
                {
                    CB_KeyToSelect = keyToSelect;                       
                }
            }
            if (Refresh_AfterActionItemClick == true)
            {
                if (Refresh_AfterAuditActionClick == true)
                {             
                    CashBookListGrid.option("CustomProp.Refresh_AfterAuditActionClick",false)
                }
                else
                {
                    var combinedFilter = CashBookListGrid.getCombinedFilter(true)
                    if (combinedFilter)
                    {
                        if (CB_NestedGrid_AccessID != null && CB_IsVouchingMode==false)
                        {
                            var NestedGridInstance = $("div[id='" + CB_NestedGrid_AccessID + "']").dxDataGrid("instance")
                            if (NestedGridInstance != void 0)
                            {
                                //NestedGridInstance.clearSelection();
                                CashBookListGrid.option("CustomProp.NestedGridClearSelection", true)
                                CB_MasterRowMID = null;
                                CB_MasterRowRecID = null;
                                CashBook_NestedRowUniqueID = null;
                            }
                        }
                        if (CB_IsToBeAuto == true)
                        {
                            Refresh_AfterActionItemClickWithFilter_Count++;
                            CashBookListGrid.option("CustomProp.Refresh_AfterActionItemClickWithFilter_Count", Refresh_AfterActionItemClickWithFilter_Count)
                            if (Refresh_AfterActionItemClickWithFilter_Count <= 1)
                            {
                                DevExpress.ui.dialog.alert("Kindly Clear All Filters And Search Panel For Auto Expansion Of The Row Where Attachments Are Required...!!<br>OR<br>You Can Manually Expand The Rows And Perform The Desired Action...!!", 'Information!');
                            }
                        }
                    }
                    else
                    {
                        if (CB_IsToBeAuto == true)
                        {
                            await MoveToUnattendedDoc_CB();
                        }
                        else
                        {                       
                            if (CB_IsVouchingMode)
                            {
                                if (CashBookListGrid.getSelectedRowKeys() && isSuperuserOrAuditor == true)
                                {
                                    fab.SetActionContext("AuditActionContext", true);
                                }
                                else
                                {
                                    fab.SetActionContext("AddAttachmentContext", false);
                                }
                            }
                            else
                            {
                                if (CB_NestedGrid_AccessID != null)
                                {
                                    var NestedGridInstance = $("div[id='" + CB_NestedGrid_AccessID + "']").dxDataGrid("instance")
                                    if (NestedGridInstance != void 0)
                                    {
                                        //NestedGridInstance.clearSelection();
                                        CashBookListGrid.option("CustomProp.NestedGridClearSelection", true)
                                        CB_MasterRowMID = null;
                                        CB_MasterRowRecID = null;
                                        CashBook_NestedRowUniqueID = null;
                                    }
                                }
                            }
                        }
                    }
                }
                CashBookListGrid.option("CustomProp.Refresh_AfterActionItemClick", false);
            }
            if (Refresh_AfterPeriodChange == true) //grid refreshing due to period change
            {
                CashBookListGrid.option("CustomProp.Refresh_AfterPeriodChange", false);
                if (CB_IsVouchingMode)
                {
                    ClearLeftPane();
                    ClearRightPane();                
                }
                if (CB_ExpandedRowKey != null && CB_ExpandedRowKey.length > 0) {
                    await CashBookListGrid.collapseRow(CB_ExpandedRowKey)
                }              
                if (PeriodChange_AfterVoucherOperation == false) //period did not change due to new entry, user changed it
                {
                    CashBookListGrid.clearSelection()
                    var pageIndex = CashBookListGrid.pageIndex();
                    if (pageIndex > 0)
                    {
                        CashBookListGrid.option("CustomProp.PageChangeAfterPeriodChange", true);
                        CashBookListGrid.pageIndex(0); //move to first page on period change when user changes it
                    }
                    CB_MID_Or_XID = null;
                    CB_MasterRowMID = null; CB_MasterRowRecID = null;
                }
                else
                {
                    CashBookListGrid.option("CustomProp.PeriodChange_AfterVoucherOperation", false);
                    CB_Select_xID = "";
                }
            }
            if (AddMoreEntry == true)
            {
                CB_AddMoreEntry();
            }
        }
        function CB_CreationDetail(ID, Action_Status, Add_Date, Add_By, Action_Date, Action_By, Edit_Date, Edit_By) {
                var Status = "";
                var Lbl_Status = "";
                var Lbl_StatusBy = "";
                var Pic_Status = "";
                var Lbl_Create = "";
                var Lbl_Modify = "";
                var Lbl_Status_Color = "";
                var Lbl_ActionOn = "";
                var Lbl_ActionBy = "";
                var StatusStr = "";
                if (ID != null) {
                    Add_Date = (JS_Json_Date_To_ddMMyyyy((Add_Date ?? ""), "DD-MM-YYYY HH:mm:ss") ?? "")
                    Edit_Date = (JS_Json_Date_To_ddMMyyyy((Edit_Date ?? ""), "DD-MM-YYYY HH:mm:ss") ?? "")
                    Action_Date = (JS_Json_Date_To_ddMMyyyy((Action_Date ?? ""), "DD-MM-YYYY HH:mm:ss") ?? "")
                    Status = Action_Status;
                    StatusStr = Status == "Locked" ? "Locked" : Status == null ? null : "UnLocked";
                    if (Status && Status.toUpperCase() == "LOCKED") {
                        Lbl_Status = "Completed";
                        Lbl_Status_Color = "blue";
                        Pic_Status = "fa fa-lock";
                    }
                    else {
                        Pic_Status = "fa fa-unlock";
                        Lbl_Status = Status;
                        if (Status && Status.toUpperCase() == "COMPLETED") {
                            Lbl_Status_Color = "green";
                        }
                        else {
                            Lbl_Status_Color = "red";
                        }
                    }
                    if (Action_Date) {
                        Lbl_ActionOn = StatusStr + " On: " + Action_Date;
                        Lbl_ActionBy = StatusStr + " By: " + Action_By;
                    }

                    else {
                        Lbl_ActionOn = "";
                        Lbl_ActionBy = "";
                    }
                    if (Add_Date) {
                        Lbl_Create = "Add On: " + Add_Date + ", By: " + Add_By;
                    }
                    else {
                        Lbl_Create = "";
                    }

                    if (Edit_Date) {
                        Lbl_Modify = "Edit On: " + Edit_Date + ", By: " + Edit_By;
                    }
                    else {
                        Lbl_Modify = "";
                    }
                }
                $('#CBLbl_Status').text(Lbl_Status);
                $('#CB_Lbl_ActionOn').text(Lbl_ActionOn);
                $('#CB_Lbl_ActionBy').text(Lbl_ActionBy);
                $('#CBLbl_Create').text(Lbl_Create);
                $('#CBLbl_Modify').text(Lbl_Modify);
                if (Lbl_Status_Color != "") {
                    $('#CBLbl_Status').css('color', Lbl_Status_Color);
                }
                if (Pic_Status == "fa fa-lock") {
                    $('#CB_LockICON').addClass(Pic_Status).removeClass("fa-unlock");
                }
                else if (Pic_Status == "fa fa-unlock") {
                    $('#CB_LockICON').addClass(Pic_Status).removeClass("fa-lock");
                }
                else {
                    $('#CB_LockICON').removeClass("fa");
                    $('#CB_LockICON').removeClass("fa-lock");
                    $('#CB_LockICON').removeClass("fa-unlock");
                }
        }
        function AddDynamicColumns_CashBookListGrid(data)
        {         
            var _dt = data[0];         
            var ExisitngColumns = CashBookListGrid.option("columns");
            var FlattenedExisitingColumns = DxGrid_GetAllColumns(ExisitngColumns)          
            var _columns = Object.keys(_dt)
            var DynamicColumns = _columns.filter((x) => x.startsWith("Dyn_"))
            var IsCompactMode = CBGrid_ViewMode == "Compact";
            var ShowBankColumnClick = CashBookListGrid.option("CustomProp.ShowBankColumnClick")
            ShowBankColumnClick = ShowBankColumnClick == void 0 ? false : ShowBankColumnClick;            
            if (DynamicColumns && DynamicColumns.length > 0)
            {               
                for (var i = 0; i < DynamicColumns.length; i++)
                {
                    var ColSplit = DynamicColumns[i].split("_");
                    var band = ColSplit[1]
                    var Caption = ColSplit[ColSplit.length - 1]
                    var BandColumnIndex = ExisitngColumns.findIndex(x => x.caption && x.caption.startsWith(band) && x.isBand == true)
                    var index = FlattenedExisitingColumns.findIndex(x => x.dataField == DynamicColumns[i]);
                    if (index == -1)
                    {                  
                        //ExisitngColumns[BandColumnIndex].columns.push({
                        //    dataField: DynamicColumns[i],
                        //    caption: Caption + (band == "Rec" ? "(R)" : "(P)"),
                        //    visible: CB_ShowDynamicBankColumns,
                        //    showInColumnChooser: CB_ShowDynamicBankColumns,
                        //    dataType: "number",
                        //    format: DxGrid_FormatNumber,
                        //    allowGrouping: false,
                        //    minWidth:50
                        //});
                        var BankColIndex = ExisitngColumns[BandColumnIndex].columns.findIndex(x => x.caption == "Bank");
                        BankColIndex = BankColIndex > -1 ? BankColIndex : 1;
                        ExisitngColumns[BandColumnIndex].columns.splice(BankColIndex,0,{
                            dataField: DynamicColumns[i],
                            caption: Caption + (band == "Rec" ? "(R)" : "(P)"),
                            visible: CB_ShowDynamicBankColumns,
                            showInColumnChooser: CB_ShowDynamicBankColumns,
                            dataType: "number",
                            format: DxGrid_FormatNumber,
                            allowGrouping: false,
                            minWidth: 100
                        });
                    }
                    else
                    {
                        var visible = true;
                        if (ShowBankColumnClick == false)
                        {
                            visible = CashBookListGrid.columnOption(DynamicColumns[i], "visible");
                        }
                        var ColIndex = ExisitngColumns[BandColumnIndex].columns.findIndex(item => item.dataField === DynamicColumns[i]);
                        if (ColIndex !== -1)
                        {
                            ExisitngColumns[BandColumnIndex].columns[ColIndex]["showInColumnChooser"] = CB_ShowDynamicBankColumns;
                            ExisitngColumns[BandColumnIndex].columns[ColIndex]["visible"] = (CB_ShowDynamicBankColumns && visible);
                        }                                        
                    }              
                }
            }          
            let RemovedDynamicCol = FlattenedExisitingColumns.filter((x) => x.dataField.startsWith("Dyn_") && DynamicColumns.includes(x.dataField) == false);
            if (RemovedDynamicCol && RemovedDynamicCol.length > 0)
            {               
                for (var i = 0; i < RemovedDynamicCol.length; i++)
                {
                    var ColSplit = RemovedDynamicCol[i].dataField.split("_");
                    var band = ColSplit[1]
                    var Caption = ColSplit[ColSplit.length - 1]
                    var BandColumnIndex = ExisitngColumns.findIndex(x => x.caption && x.caption.startsWith(band) && x.isBand == true)
                    var ColIndex = ExisitngColumns[BandColumnIndex].columns.findIndex(item => item.dataField === RemovedDynamicCol[i].dataField);
                    if (ColIndex !== -1)
                    {
                        ExisitngColumns[BandColumnIndex].columns.splice(ColIndex,1)
                    }
                }
            }
            CashBookListGrid.beginUpdate();
            CashBookListGrid.option("columns", ExisitngColumns);
            if (IsCompactMode)
            {
                Cashbook_ViewSwitch_ValueChange()
            }
            CashBookListGrid.option("summary.totalItems", AddDynamicColumnsSummary_CashBookListGrid())
            CashBookListGrid.endUpdate();
            if (ShowBankColumnClick == true)
            {           
                CashBookListGrid.option("CustomProp.ShowBankColumnClick", false)
            }
            //CashBookListGrid.option("CustomProp.FilterBuilderFieldsReady",false)
        }
