    <div id="Cashbook_ParentDiv">
        <div class="report_header_div_main" id="contentCashbook">
            @*<div class="col-sm-4 padd report_header_div">
                    <label class="report_header_label"></label>
                </div>*@
            <div class="report_button_div">
                @(Html.DevExtreme().Switch().ID("CashbookVouchingModeSwitch").SwitchedOnText("Vouching On").SwitchedOffText("Vouching Off").OnValueChanged("Cashbook_VouchingSwitch_ValueChange").Width(100).Visible(true))
                @(Html.DevExtreme().Switch().ID("CashbookViewModeSwitch").SwitchedOnText("Compact").SwitchedOffText("Default").OnValueChanged("Cashbook_ViewSwitch_ValueChange").Width(70).Visible(true))
                @(Html.DevExtreme().Button().ID("CashBookModelUnlock").Text("Unlock").Icon("fa fa-unlock").OnClick(@<text> function () { CashbookButtonClick("UNLOCKED") } </text>).Visible(CB_Locked_Visible) )
                @(Html.DevExtreme().Button().ID("CashBookModelLock").Text("Lock").Icon("fa fa-lock").OnClick(@<text> function () { CashbookButtonClick("LOCKED") } </text>).Visible(CB_UnLocked_Visible) )
                @(Html.DevExtreme().Button().ID("CashBookModelNew").Text("New").Icon("add").OnClick(@<text> function () { OnCashBookNewClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("CashBookModelEdit").Text("Edit").Icon("edit").OnClick(@<text> function () { CashbookButtonClick("EDIT"); } </text>) )
                @(Html.DevExtreme().Button().ID("CashBookModelDelete").Text("Delete").Icon("trash").OnClick(@<text> function () { CashbookButtonClick("DELETE"); } </text>) )
                @(Html.DevExtreme().Button().ID("CashBookModelView").Text("View").Icon("doc").OnClick(@<text> function () { CashbookButtonClick("VIEW"); } </text>) )
                @(Html.DevExtreme().Button().ID("CashBookModelListPreview").Text("Export").Icon("print").OnClick(@<text> function () { OnCashBookListPreviewClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("CashBook_LinkAttachment").Text("Link").Icon("unpin").OnClick(@<text>function () {OnCBLinkAttachment_CalledFromAttachment(); } </text>).Visible(PopupID.Length > 0 ? true : false))
                @(Html.DevExtreme().Button().ID("btnCashbookLinkAttachment").Text("Link By Sr No").Icon("unpin").OnClick(@<text> function () {OnCashBookLinkAttachmentSrNo();}</text>))
                @(Html.DevExtreme().Button().ID("btnCashbookLinkAttachmentFileName").Text("Link By File Name").Icon("unpin").OnClick(@<text> function () {OnCashBookLinkAttachmentFileName();}</text>))
                @(Html.DevExtreme().Button().ID("CashBook_MasterToggleScrollBar").Text(ViewBag.CB_ShowHorizontalBar == 1 ? "Default Data" : "Full Data").Width(ViewBag.CB_ShowHorizontalBar == 1 ? 110 : 90).Icon("toolbox").OnClick(@<text>function () {OnCBChangeMode(); } </text>))
                @(Html.DevExtreme().Button().ID("CashBookModelCLOSE").Text("Close").Icon("close").OnClick(@<text> function (){CloseCashBook();} </text>) )
            </div>
        </div>@* btns *@
        <div class="report_header_div_main">
            <div class="col-sm-8">
                <div style="display:inline-block">
                    <input type="hidden" id="CB_Fr_Date" value="@ViewBag.xFr_Date" />
                    <input type="hidden" id="CB_To_Date" value="@ViewBag.xTo_Date" />
                    @(Html.DevExtreme().SelectBox().ID("CB_PeriodSelection").Name("CB_PeriodSelection").DataSource(d => d.Mvc().Controller("Voucher").LoadAction("Fill_Change_Period_Items_dx").Key("SelectedIndex").LoadMode(DataSourceLoadMode.Raw)).DisplayExpr("Period").ValueExpr("SelectedIndex").SearchEnabled(false).OnValueChanged("PeriodSelectionChange_CB").Width("100%").Width(125).Value(ViewBag.PeriodSelectedIndex))
                </div>
                <div style="display:inline-block">
                    @(Html.DevExtreme().Button().ID("CB_btnChangePeriod").Text("Change Period").Hint("Change Period").Disabled(true).OnClick(@<text> function () { ChangePeriodClick_CB(); } </text>).Width(110) )
                </div>
                <div style="display:inline-block">
                    @(Html.DevExtreme().TextBox().ID("CB_BE_View_Period").Name("CB_BE_View_Period").Value("View Period").ReadOnly(true).FocusStateEnabled(false).Width(190))
                </div>
            </div>
            <div class="col-sm-4" style="float:right;text-align:right">
                @{
                    if (self_posted == false)
                    {
                        <label id="CB_BE_Cash_Bank" style="color:#D2691E;font:bold;padding-top:6px"></label>
                    }
                }
                @(Html.DevExtreme().Button().ID("btnView_Summary").Text("Summary").Hint("Summary")
                        .ElementAttr(new Dictionary<string, object>() { { "class", "float-right" } }).OnClick(@<text> function () { ViewSummaryClick_CB(); } </text>).Visible(!self_posted).Disabled(self_posted)
                    )
            </div>
        </div> @* period Summary *@
        <div id="CB_GRID_DIV" class="parent_table">
            <form id="CashBookreloadPartialView">
                @Html.Partial("Frm_Voucher_Info_CB_Grid_dx", Model)
            </form>
        </div>   @*Grid*@
        <div class="col-sm-12 footer_smallbtns" id="CashbookFooterItem">
            @*@(Html.DevExtreme().Button().ID("But_HideBank").Text("").Hint("Show/Hide Bank").OnClick(@<text> function () { ShowBank(); } </text>) )*@
            @(Html.DevExtreme().Button().ID("But_ShowTotal").Text("Show Total Bal.").Hint("Show Total Bal.").OnClick(@<text> function () { ShowGrandTotal_CB(); } </text>) )
            @(Html.DevExtreme().Button().ID("But_Narration").Text("Show Narration").ElementAttr("class", "column-chooser").OnClick(@<text> function () { ShowNarration_CB(); } </text>))
            @(Html.DevExtreme().Button().ID("But_ShowColumn").Text("Customization").ElementAttr("class", "column-chooser").Hint("Show Customization").OnClick(@<text> function () { ShowColumnChooser_CB(); } </text>) )
            @(Html.DevExtreme().Button().ID("But_ShowFilter").Text("Filter Editor").Hint("Open Filter Builder").OnClick(@<text> function () { CashBookCreateFilterClick(); } </text>) )
            @(Html.DevExtreme().Button().ID("But_AdvFilters").Text("Adv.Filters").Hint("Advance Filter").OnClick(@<text> function () { CashBookAdvanceFilterClick(); } </text>) )
            @(Html.DevExtreme().Button().ID("But_DynamicBankColumns").Text("Show Bank Columns").Hint("Dynamic Bank Columns").Visible(false).OnClick(@<text> function () { CashBookBankColumnsClick(); } </text>) )


        </div>  @* Ftr Btns*@
        <div class="footer-MainBoxdiv" style="display:inline-block;width:100%">
            <div class="col-md-8">
                <div class="setFooterItem">
                    <div class="footer-inner">
                        <div class="list_footer_left_margin">
                            <div class="footericon">
                                <i id="CB_LockICON" style="color:red;font-size:35px;"></i>
                            </div>
                            @*<div class="footer-locktext">
                                    <div id="CBLbl_Status" style="font-size:23px" class="left_footertext_top"></div>
                                </div>*@
                            <div class="footer-locktext">
                                <div id="CB_Lbl_ActionOn" class="left_footertext_top"></div>
                                <div id="CB_Lbl_ActionBy" class="left_footertext_bottom"></div>
                            </div>
                        </div>
                        <div class="list_footer_left_margin">
                            <div class="footer-text">
                                <p id="CBLbl_Create" class="right_footertext_top"></p>
                                <p id="CBLbl_Modify" class="right_footertext_bottom"></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>  @* Ftr add/edit details *@
    </div>
    <div>
        @(Html.DevExtreme().Popup().CustomPopup().ID("popup_frm_Frm_View_Summary").ShowCloseButton(true).OnShowing("PopupOnShowing").Height(900).Width(1000).OnHiding("CB_Summary_close").Title("Summary").ContentTemplate( @<text> <div id='popup_frm_Frm_View_Summary_result'>  </div> </text>) )
        @(Html.DevExtreme().Popup().CustomPopup().ID("popup_frm_Voucher_Advance_Filter").OnShowing("PopupOnShowing").Title("Advanced Filters").Height(900).Width(1000).ContentTemplate( @<text> <div id='popup_frm_Voucher_Advance_Filter_result'>  </div> </text>) )
        @(Html.DevExtreme().Popup().CustomPopup().ID("CB_Reason_popup").OnShowing("PopupOnShowing").Title("Reason").Height("auto").MaxHeight(250).Width(250).ShadingColor("rgba(255, 255, 255, 0)").ContentTemplate( @<text> <div id='popup_cb_reason_result'>  </div> </text>) )
        @(Html.DevExtreme().Popup().CustomPopup().ID("report_modal").Title("Cash Book List Preview").FullScreen(false).ShowCloseButton(true).Height("auto").ContentTemplate(@<text> <div id='CB_report_modal_result'> </div> </text>) )
        @(Html.DevExtreme().Popup().CustomPopup().ID("popup_frm_Cash_Book_Attachment").ResizeEnabled(true).DragEnabled(true).Shading(false).CloseOnOutsideClick(false).ShowCloseButton(true)@*.OnShowing("PopupOnShowing")*@.Title("Attached Files").ContentTemplate( @<text>
            <div id='popup_frm_Cash_Book_Attachment_result'>
                <iframe id="AttachmentFrm" src="" style="height: 600px; width: 100%;"></iframe>
