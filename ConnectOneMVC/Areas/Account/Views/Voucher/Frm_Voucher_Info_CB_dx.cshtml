                if (CB_XID.toLowerCase() == "note-book")
                {
                    HideLoader();
                    DevExpress.ui.dialog.alert("This functionality is not for Notebook entries", "Information");
                    return;
                }
                if (CB_iTR_CODE == null)
                {
                    HideLoader();
                    DevExpress.ui.dialog.alert("This functionality is only for Voucher Entries", "Information");
                    return;
                }
                Edit_Common(CB_XID, CB_MID, "CashBookListGrid", CB_iTR_CODE);
                return;
            }
            if (_ActionType == "VOUCHER") {
                if (CB_VoucherScreen_Name != "Collection_Box") {
                    HideLoader();
                    DevExpress.ui.dialog.alert("This functionality is only for Collection Box voucher", "Voucher Print");
                }
                else {
                    $.ajax({
                        type: 'GET',
                        url: "/Account/Voucher/Frm_PrintVoucher_CollectionBox",
                        data:
                        {
                            RecID: CB_XID
                        },
                        cache: false,
                        success: function (data) {
                            HideLoader();
                            if (data.jsonParam) {
                                DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                            }
                            else {
                                OpenDynamicPopup("Collection Box Voucher", null, "auto", "100%", true, data)
                            }
                        }
                    });
                }
                return;
            }
            if (Check_Voucher_Allow_AEDV(_ActionType, Voucher_Type) == false) {
                HideLoader();
                DevExpress.ui.dialog.alert("Coming Soon...!", "Information");
                return;
            }
            isRight = CheckRights_CB(_ActionType);
            if (isRight == "False") {
                HideLoader();
                DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
                return;
            }
            if (_ActionType != "NEW") {
                if (CB_XID.toLowerCase() == "note-book") {
                    if ($("#NoteBook_ParentDiv").length > 0) {
                        HideLoader();
                        DevExpress.ui.dialog.alert("Note Book Already Opened...!<br>Please Close Notebook Opened In Tab First", "Information..");
                        return;
                    }
                }
            }
            if (_ActionType == "MATCH TRANSFERS" || _ActionType == "LOCKED" || _ActionType == "UNLOCKED") {
                result = await GetUserConfirmation(_ActionType);
                if (result.jsonParam.refreshgrid) {
                    Grid_Display_CB();
                }
                if (result.jsonParam.result == true) {
                    ShouldProceed = true;
                }
                else {
                    if (result.jsonParam.isconfirm) {
                        ShouldProceed = await DevExpress.ui.dialog.confirm(result.jsonParam.message, result.jsonParam.title);
                    }
                    else {
                        ShouldProceed = false;
                        DevExpress.ui.dialog.alert(result.jsonParam.message, result.jsonParam.title);
                    }
                }
            }
            else {
                ShouldProceed = true;
            }
            if (ShouldProceed == false) {
                HideLoader();
                return;
            }
            //if (_ActionType == "DELETE" && (Voucher_Type == "ASSET TRANSFER" || CB_VoucherScreen_Name == "Asset_Transfer"))
            //{
            //    result = await GetAssetTransferDeleteConfirmation();
            //    if (result.jsonParam.result == true)
