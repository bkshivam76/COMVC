                CB_REC_STATUS_Date = values.iREC_STATUS_ON;
                CB_REC_ADD_BY = values.iREC_ADD_BY;
                CB_REC_ADD_ON = values.iREC_ADD_ON;
                CB_REC_EDIT_BY = values.iREC_EDIT_BY;
                CB_REC_EDIT_Date = values.iREC_EDIT_ON;
