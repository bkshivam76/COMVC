            //        ShouldProceed = true;
            //    }
            //    else
            //    {
            //        if (result.jsonParam.isconfirm)
            //        {
            //            ShouldProceed = await DevExpress.ui.dialog.confirm(result.jsonParam.message, result.jsonParam.title);
            //            if (ShouldProceed == false)
            //            {
            //                HideLoader();
            //                return;
            //            }
            //        }
            //    }
            //}
            DataNavigation_CB(_ActionType, Voucher_Type, Selection_By_Item, Selected_Item_ID);
        }
        function DataNavigation_CB(_ActionType, Voucher_Type, Selection_By_Item, Selected_Item_ID) {
            ShowLoader();
            if (_ActionType == "VIEW") {
                Vouchers_View_AllEntryData(CB_XID, CB_MID, CB_REC_EDIT_Date, "Cash Book", CB_iTR_DATE, CB_iTR_CODE, "CashBookListGrid", CB_Grid_PK);
            }
            else if (_ActionType == "DELETE") {
                Vouchers_Delete_AllEntryData(CB_XID, CB_MID, CB_REC_EDIT_Date, CB_REC_ADD_ON, "Cash Book", CB_iTR_DATE, CB_ACTION_STATUS, CB_iTR_CODE, CB_ITEM_ID, CB_ITR_SR_NO, CB_ITR_TYPE, "CashBookListGrid", CB_Grid_PK, false, false);
            }
            else if (_ActionType == "EDIT") {
                Vouchers_Edit_AllEntryData(CB_XID, CB_MID, CB_REC_EDIT_Date, CB_REC_ADD_ON, "Cash Book", CB_iTR_DATE, CB_ACTION_STATUS, CB_iTR_CODE, CB_ITEM_ID, CB_ITR_SR_NO, CB_ITR_TYPE, "CashBookListGrid", CB_Grid_PK, false);
            }
            else if (_ActionType == "NEW")
            {
                Vouchers_New(Voucher_Type, Selection_By_Item, Selected_Item_ID)             
