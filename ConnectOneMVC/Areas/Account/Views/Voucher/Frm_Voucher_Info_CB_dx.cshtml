        function AddDynamicColumnsSummary_CashBookListGrid(SummaryItems = null, ValFormat=null)
        {
            var btntotal = $("#But_ShowTotal").dxButton("instance").option("text");
            var ExisitngColumns = CashBookListGrid.option("columns");
            var FlattenedExisitingColumns = DxGrid_GetAllColumns(ExisitngColumns)            
            var DynamicColumns = FlattenedExisitingColumns.filter((x) => x.dataField.startsWith("Dyn_"))
            if (SummaryItems == null)
            {
                SummaryItems = CashBookListGrid.option("summary.totalItems")
            }
            if (ValFormat == null) {
                ValFormat = function (value) { return DxGrid_FormatNumber(value) };
            }
            for(var i = 0; i < DynamicColumns.length; i++)
            {
                var dataField = DynamicColumns[i].dataField
                var SummaryName = dataField + "_" + dataField;
                var SummaryIndex = SummaryItems.findIndex(x => x.name == SummaryName+"_sum");
                if (SummaryIndex == -1)
                {
                    SummaryItems.push(
                        {
                            "name": SummaryName + "_sum", "column": dataField, "summaryType": "sum", "showInColumn": dataField, "recalculateWhileEditing": true, valueFormat: ValFormat, "displayFormat": "{0}",
                        })
                }
                if (btntotal == "Hide Total Bal.") // total balance is shown
                {
                    var ColSplit = dataField.split("_");
                    var band = ColSplit[1]
                    if (band == "Pay")
                    {
                        var RecColName = dataField.replaceAll("Pay", "Rec");
                        SummaryIndex = SummaryItems.findIndex(x => x.name == SummaryName + "_custom");
                        if (SummaryIndex == -1)
                        {
                            SummaryItems.push(
                                {
                                    "name": SummaryName + "_custom", "summaryType": "custom", "showInColumn": dataField, "recalculateWhileEditing": true, valueFormat: ValFormat, "displayFormat": "{0}"
                                })
                        }
                        SummaryIndex = SummaryItems.findIndex(x => x.name == RecColName + "_" + dataField + "_sum");
                        if (SummaryIndex == -1)
                        {
                            SummaryItems.push(
                                {
                                    "name": RecColName + "_" + dataField + "_sum", "column": RecColName, "summaryType": "sum", "showInColumn": dataField, "recalculateWhileEditing": true, valueFormat: ValFormat, "displayFormat": "{0}"
                                })

                        }
                    }
                }
            }
            return SummaryItems;
        }
        function CB_CustomSummaryCalculation(options)
        {
            //if (options.name == "iTR_PAY_CASH_iTR_PAY_CASH_custom" || options.name == "iTR_PAY_BANK_iTR_PAY_BANK_custom" || options.name == "iTR_PAY_JOURNAL_iTR_PAY_JOURNAL_custom")
            //{
                if (options.summaryProcess)
                {
                    if (options.summaryProcess === "start")
                    {
                        options.totalValue = 0;
                        options.RecSum = 0;
                        options.PaySum = 0;

                    }
                    else if (options.summaryProcess === "calculate")
                    {
                        if (options.name == "iTR_PAY_CASH_iTR_PAY_CASH_custom") {
                            options.RecSum += options.value.iTR_REC_CASH;
                            options.PaySum += options.value.iTR_PAY_CASH;
                        }
                        else if (options.name == "iTR_PAY_BANK_iTR_PAY_BANK_custom") {
                            options.RecSum += options.value.iTR_REC_BANK;
                            options.PaySum += options.value.iTR_PAY_BANK;
                        }
                        else if (options.name == "iTR_PAY_JOURNAL_iTR_PAY_JOURNAL_custom") {
                            options.RecSum += options.value.iTR_REC_JOURNAL;
                            options.PaySum += options.value.iTR_PAY_JOURNAL;
                        }
                        else if (options.name.startsWith("Dyn"))
                        {
                            var DataField = (options.name.split("_Dyn"))[0]
                            var OppositeDataFiled = DataField.replaceAll("Pay", "Rec")
                            options.RecSum += options.value[OppositeDataFiled];
                            options.PaySum += options.value[DataField];
                        }
                    }
                    else if (options.summaryProcess === "finalize")
                    {
                        if (options.name == "iTR_PAY_CASH_iTR_PAY_CASH_custom")
                        {
                            options.totalValue = options.RecSum - options.PaySum
                        }
                        else if (options.name == "iTR_PAY_BANK_iTR_PAY_BANK_custom")
                        {
                            options.totalValue = options.RecSum - options.PaySum
                        }
                        else if (options.name == "iTR_PAY_JOURNAL_iTR_PAY_JOURNAL_custom")
                        {
                            options.totalValue = options.RecSum - options.PaySum
                        }
                        else if (options.name.startsWith("Dyn"))
                        {
                            options.totalValue = options.RecSum - options.PaySum
                        }
                    }
                }
           // }
        }
