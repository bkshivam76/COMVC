    <script>
        async function Cashbook_VouchingSwitch_ValueChange(e) {
            CB_IsVouchingMode = e.value;
            if (e.value == true) {
                $("#But_Narration").dxButton("instance").option("visible", false);
            }
            else {
                $("#But_Narration").dxButton("instance").option("visible", true);
            }
            if (CB_IsVouchingMode == true) {
                OpenRightPane();
                OpenLeftPane();
            }
            else {
                CloseRightPane();
                CloseLeftPane();
            }
            ClearLeftPane();
            ClearRightPane();
            CashBookListGrid.clearSelection();
            CashBookListGrid.option("masterDetail.enabled", !CB_IsVouchingMode)
            if (CB_SetVouchingModeOn == true)
            {
                CB_SetVouchingModeOn = false;
                $("#CashbookViewModeSwitch").dxSwitch("instance").option("value", true);
            }
            else
            {               
                CB_GridFocusedOrExpandedIndex = -1;
                CB_IsDetailRowExpanded = false;
                CB_ExpandedRowKey = null;
                CB_ExpandedRowIndex = -1;
                if (CB_ExpandedRowKey != null && CB_ExpandedRowKey.length > 0) {
                    await CashBookListGrid.collapseRow(CB_ExpandedRowKey)
                }
                //CashBookListGrid.CollapseAllDetailRows();
                fab.SetActionContext("AddAttachmentContext", false);
                CashBookListGrid.repaint();
            }
        }
        async function Cashbook_ViewSwitch_ValueChange(e) {         
            var Value = $("#CashbookViewModeSwitch").dxSwitch("option","value")
            CBGrid_ViewMode = Value == false ? "Default" : "Compact";
            fab.SetActionContext("AddAttachmentContext", false);
            if (CB_ExpandedRowKey != null && CB_ExpandedRowKey.length > 0) {
                await CashBookListGrid.collapseRow(CB_ExpandedRowKey)
            }
            CashBookListGrid.beginUpdate();
            var columns = CashBookListGrid.option("columns");
            if (CBGrid_ViewMode == "Compact") {
                VisibleColumns_CB = [];
                for (var i = 0; i < columns.length; i++) {
                    var name = columns[i].dataField;
                    if (name == void 0) {
                        name = columns[i].caption;
                    }
                    var ColumnVisible = CashBookListGrid.columnOption(name, "visible");
                    if (name == "CB_Compact_Column") {
                        CashBookListGrid.columnOption(name, "visible", true);
                    }
                    else if (ColumnVisible == true && name != "iIcon") {
                        VisibleColumns_CB.push(name);
                        CashBookListGrid.columnOption(name, "visible", false);
                    }
                }
            }
            else {
                CashBookListGrid.columnOption("CB_Compact_Column", "visible", false);
                for (var i = 0; i < VisibleColumns_CB.length; i++) {
                    CashBookListGrid.columnOption(VisibleColumns_CB[i], "visible", true);
                }
            }
            CashBookListGrid.repaint();
            CashBookListGrid.endUpdate();
        }
        async function OnCBChangeMode() {
            CashBookListGrid.beginUpdate();
            if (CB_ShowHorizontalBar == 0) {
