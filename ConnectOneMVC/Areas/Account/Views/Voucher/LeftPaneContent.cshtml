@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    var ID = (string)ViewBag.ID;
    var VouchingMode = (bool)ViewBag.VouchingMode;
    var MID = (string)ViewBag.MID;
}
<div class="col-md-12">
    <label>Documents Attached:</label>
    <div class="row">
        <div class="col-md-12" id="CashBookNestedGrid_Div">
            <form>
                @Html.Action("Frm_Voucher_Info_CB_Grid_Nested", "Voucher", new { ID = ID,MID=MID, VouchingMode = VouchingMode,command = "REFRESH", SessionGUID = SessionGUID})
            </form>
        </div>
    </div>
    <label>Additional Info:</label>
    <div class="row">
        <div class="col-md-12" id="CAshBookAdditionalInfo_Div">
            <form>
                @Html.Action("AdditionalInfo_Grid", "Voucher", new { SessionGUID = SessionGUID })
            </form>
        </div>
    </div>
</div>

