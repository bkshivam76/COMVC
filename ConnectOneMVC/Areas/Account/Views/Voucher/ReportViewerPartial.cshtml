@using DevExpress.XtraReports.UI;

@Html.DevExpress().DocumentViewer(
            settings =>
            {
                settings.Name = "CBReportViewer";
                settings.AutoHeight = true;
                settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
                settings.Report = (XtraReport)Session["CBReport"];
                settings.CallbackRouteValues = new { Controller = "Voucher", Action = "ReportViewerPartial", isFromReportViewer = true };
                settings.ExportRouteValues = new { Controller = "Voucher", Action = "ReportViewerExportTo" };
            }).GetHtml()