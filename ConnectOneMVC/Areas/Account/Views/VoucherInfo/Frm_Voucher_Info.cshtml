    <script>
        function ChooseDonationType_Voucher()
    {
        ShowLoader();
        $("#CheckDonationType_Form").remove();
        $.ajax({
            type: 'GET',
            url: "/Account/VoucherInfo/Frm_Voucher_Win_D_Type",
            cache: false,
            data: { CallFromVoucherInfo:true},
            success: function (data)
            {
                OpenPopup("Popup_Donation_Check", "Donation", null, "auto", 300, true, data);
                HideLoader();
            }
        });
    }
    function DataNavigation_Voucher(_VoucherType, _selectionByItem, _Additionalparam = "")
    {
        if (Check_Voucher_Allow_AEDV_Vinfo(_VoucherType)==false)
        {
            DevExpress.ui.dialog.alert("Coming Soon..!", "Information");
            return;
        }
        Vouchers_New(_VoucherType, _selectionByItem, ItemID_Voucher, SelectedItemName, _Additionalparam, Sel_Led_Name, Sel_Led_ID)
    }
    function BUT_CashBook_Click()
    {
        if ("@Acc_Vou_CashBank_ListRight" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        if (typeof CashBookListGrid !== 'undefined') {
            DevExpress.ui.dialog.alert("Cash Book Already Opened...!", "Voucher Entry");
        }
        else
        {
            OpenTabControl('Frm_Voucher_Info_CB', 'Cash Book', '@Url.Action("Frm_Voucher_Info_CB", "Voucher", new { @area = "Account" })');
        }
        $("#GLookUp_ItemList_VoucherInfo").dxDropDownBox("instance").reset();
    }
    function BUT_NB_Entry_Click()
    {
        if (Voucher_NoteBook_Allow_AEDV == false)
        {
            DevExpress.ui.dialog.alert("Coming Soon..!", "Information");
            return;
        }
        if ("@Acc_Vou_NoteBook_ListRight" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        if ($("#NoteBook_ParentDiv").length > 0)
        {
            HideLoader();
            DevExpress.ui.dialog.alert("Note Book Already Opened...!<br>Please Close Notebook Opened In Tab First", "Information..");
            return;
        }
        $("#GLookUp_ItemList_VoucherInfo").dxDropDownBox("instance").reset();
        OpenPopup("Notebook_Popup_ID",'Note-Book Entry', '/Account/NoteBook/Frm_NoteBook_Info?Tag="_New"', "auto", "90%", false);
    }
    function Check_Voucher_Allow_AEDV_Vinfo(VoucherType)
    {
        var AllowVoucher_AEDV;
        switch (VoucherType.toUpperCase())
        {
            case "CASH":
                AllowVoucher_AEDV = Voucher_CDW_Allow_AEDV;
                break;
            case "BANK":
                AllowVoucher_AEDV = Voucher_B2B_Allow_AEDV;
                break;
            case "DONATION - REGULAR":
                AllowVoucher_AEDV = Voucher_DonR_Allow_AEDV;
                break;
            case "DONATION - FOREIGN":
                AllowVoucher_AEDV = Voucher_DonF_Allow_AEDV;
                break;
            case "COLLECTION BOX":
                AllowVoucher_AEDV = Voucher_DonF_Allow_AEDV;
                break;
            case "PAYMENT":
                AllowVoucher_AEDV = Voucher_Payment_Allow_AEDV;
                break;
            case "RECEIPTS":
                AllowVoucher_AEDV = Voucher_Receipt_Allow_AEDV;
                break;
            case "DONATION - GIFT":
                AllowVoucher_AEDV = Voucher_DonationKind_Allow_AEDV;
                break;
            case "INTERNAL TRANSFER":
                AllowVoucher_AEDV = Voucher_ITrf_Allow_AEDV;
                break;
            case "FD":
                AllowVoucher_AEDV = Voucher_FD_Allow_AEDV;
                break;
            case "SALE OF ASSET":
                AllowVoucher_AEDV = Voucher_SaleAsset_Allow_AEDV;
                break;
            case "JOURNAL":
                AllowVoucher_AEDV = Voucher_JV_Allow_AEDV;
                break;
            case "MEMBERSHIP":
                AllowVoucher_AEDV = Voucher_Membership_Allow_AEDV;
                break;
            case "MEMBERSHIP RENEWAL":
                AllowVoucher_AEDV = Voucher_Membership_Renewal_Allow_AEDV;
                break;
            case "ASSET TRANSFER":
                AllowVoucher_AEDV = Voucher_AssetTransfer_Allow_AEDV;
                break;
            case "WIP FINALIZATION":
                AllowVoucher_AEDV = Voucher_WIP_Allow_AEDV;
                break;
        }
        return AllowVoucher_AEDV;
        }
        function AfterVoucherClose_VoucherEntry()
        {
            $("#GLookUp_ItemList_VoucherInfo").dxDropDownBox("focus");
        }
    </script>
