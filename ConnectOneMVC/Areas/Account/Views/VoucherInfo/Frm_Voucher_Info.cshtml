    <script>
    var Get_Voucher_Type_Voucher = "";
    var Sel_Led_ID = "";
    var Sel_Led_Name = "";
    var Selection_By_Item_Voucher = false;
    var ItemID_Voucher = "";
    var Voucher_Type_Voucher = "";
    var SelectedItemName = "";
    var AdditionalParam = "";
    $(document).ready(function ()
    {
        $("#Voucher_PeriodSelection").dxSelectBox("instance").option("value", parseInt('@ViewBag.PeriodSelectedIndex'));
        $("#Voucher_BE_View_Balance").find('input').css('color', "#D2691E");
        setTimeout(function () {
            $("#GLookUp_ItemList_VoucherInfo").dxDropDownBox("instance").focus();
        }, 10);
   	});
    function voucher_close_click()
    {
        $(".TabPanalMenu-tabs .active span").click();
    }
    $(".TabPanalMenu-tabs .active span").on("click", function () {
        $.ajax({
            type: 'GET',
            url: "/Account/VoucherInfo/SessionClear",
            cache: false
        });
        ClearAllReferences_VoucherInfoScreen();
    });
        function ClearAllReferences_VoucherInfoScreen() {
            Get_Voucher_Type_Voucher = null;
            Sel_Led_ID = null;
            Sel_Led_Name = null;
            Selection_By_Item_Voucher = null;
            ItemID_Voucher = null;
            Voucher_Type_Voucher = null;
            SelectedItemName = null;
            AdditionalParam = null;

            ClearAllReferences("Frm_Voucher_Info_ClearReferences")
        }
    function VoucherType_LookUp_GetItemList_ChangeEvent(e)
    {
        e.component.close();
        ItemID_Voucher = e.value;
        if (e.value!=null && e.value.length>0)
        {
            $("#Voucher_BUT_OK").dxButton("instance").option("disabled", false);
        }
        else
        {
            $("#Voucher_BUT_OK").dxButton("instance").option("disabled", true);
        }
        var $dataGrid = $("#VoucherType_LookUp_GetItemList_datagrid");
        if ($dataGrid.length)
        {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(e.value, false);
            if (dataGrid.getSelectedRowsData().length > 0)
            {
                var item = dataGrid.getSelectedRowsData()[0];
                Get_Voucher_Type_Voucher = item["ITEM_VOUCHER_TYPE"];
                Sel_Led_ID = item["ITEM_LED_ID"];
                Sel_Led_Name = item["LED_NAME"];
                SelectedItemName = item["ITEMNAME"];
                ItemID_Voucher = item["ITEMID"];
            }
        }
    }
    </script>
    @* Document.ready,dd value change,close btn *@
    <script>
    function VoucherOK_Click()
    {
        console.log(Get_Voucher_Type_Voucher+" Voucher Load Start")
        Selection_By_Item_Voucher = true;
        Voucher_Type_Voucher = "";
        var hasRight = "True";

        switch (Get_Voucher_Type_Voucher.toUpperCase())
        {
            case "CASH DEPOSITED":
            case "CASH WITHDRAWN":
                Voucher_Type_Voucher = "CASH";
                hasRight = "@Acc_Vou_CashBank_AddRight";
                break;
            case "BANK TRANSFER":
                Voucher_Type_Voucher = "BANK";
                hasRight = "@Acc_Vou_B2B_AddRight";
                break;
            case "DONATION":
                Voucher_Type_Voucher = "DONATION - REGULAR";
                hasRight = "@Acc_Vou_Donation_AddRight";
                break;
            case "DONATION - FOREIGN":
                Voucher_Type_Voucher = "DONATION - FOREIGN";
                hasRight = "@Acc_Vou_Donation_AddRight";
                break;
            case "COLLECTION BOX":
                Voucher_Type_Voucher = "COLLECTION BOX";
                hasRight = "@Acc_Vou_ColBox_AddRight";
                break;
            case "PAYMENT":
            case "PAYMENT - INSTITUTE":
            case "LAND & BUILDING / GIFT":
            case "LAND & BUILDING":
                Voucher_Type_Voucher = "PAYMENT";
                hasRight = "@Acc_Vou_Payment_AddRight";
                break;
            case "RECEIPTS - INSTITUTE":
                case "RECEIPTS":
                Voucher_Type_Voucher = "RECEIPTS";
                hasRight = "@Acc_Vou_Receipt_AddRight";
                    break;
            case "DONATION - GIFT":
                Voucher_Type_Voucher = "DONATION - GIFT";
                hasRight = "@Acc_Vou_Gift_AddRight";
                break;
            case "INTERNAL TRANSFER - INSTITUTE":
            case "INTERNAL TRANSFER WITH H.Q.":
                case "INTERNAL TRANSFER":
                Voucher_Type_Voucher = "INTERNAL TRANSFER";
                hasRight = "@Acc_Vou_Int_Transfer_AddRight";
                    break;
                case "FD":
                Voucher_Type_Voucher = "FD";
                hasRight = "@Acc_Vou_FD_AddRight";
                    break;
                case "SALE OF ASSET":
                Voucher_Type_Voucher = "SALE OF ASSET";
                hasRight = "@Acc_Vou_SaleAsset_AddRight";
                    break;
                case "MEMBERSHIP":
                Voucher_Type_Voucher = "MEMBERSHIP";
                    break;
                case "MEMBERSHIP RENEWAL":
                Voucher_Type_Voucher = "MEMBERSHIP RENEWAL";
                    break;
                case "ASSET TRANSFER":
                Voucher_Type_Voucher = "ASSET TRANSFER";
                hasRight = "@Acc_Vou_AsetTransfer_AddRight";
                    break;
                case "WIP FINALIZATION":
                Voucher_Type_Voucher = "WIP FINALIZATION";
                hasRight = "@Acc_Vou_WIP_Finalization_AddRight";
                    break;
                default:
                    DevExpress.ui.dialog.alert("Coming Soon...!", "Voucher Entry...");
                    break;
        }
        if (hasRight == "False") {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        if (Voucher_Type_Voucher.length > 0)
        {
            DataNavigation_Voucher(Voucher_Type_Voucher, Selection_By_Item_Voucher);
        }
    }
    function All_Voucher_Button_Click(btn)
    {
        console.log(btn+" Voucher Load Start")
        Selection_By_Item_Voucher = false;
        Voucher_Type_Voucher = "";
        AdditionalParam = "";
        var hasRight = "True";

        switch (btn)
        {
            case "BUT_CASH":
                hasRight = "@Acc_Vou_CashBank_AddRight";
                Voucher_Type_Voucher = "CASH";
                break;
            case "BUT_BANK":
                Voucher_Type_Voucher = "BANK";
                hasRight = "@Acc_Vou_B2B_AddRight";
                break;
            case "BUT_DONATION":
                 hasRight = "@Acc_Vou_Donation_AddRight";
                if ("@AllowForeignDonation" == "True")
                {
                    Voucher_Type_Voucher="Check Donation Type";
                }
                else {
                    Voucher_Type_Voucher = "DONATION - REGULAR";
                }
                break;
            case "BUT_C_BOX":
                 hasRight = "@Acc_Vou_ColBox_AddRight";
                Voucher_Type_Voucher = "COLLECTION BOX";
                break;
            case "BUT_PAYMENT":
                 hasRight = "@Acc_Vou_Payment_AddRight";
                Voucher_Type_Voucher = "PAYMENT";
                break;
            case "BUT_RECEIPT":
                  hasRight = "@Acc_Vou_Receipt_AddRight";
                Voucher_Type_Voucher = "RECEIPTS";
                break;
            case "BUT_GIFT":
                  hasRight = "@Acc_Vou_Gift_AddRight";
                Voucher_Type_Voucher="DONATION - GIFT";
                break;
            case "BUT_INT_TRANSFER":
                  hasRight = "@Acc_Vou_Int_Transfer_AddRight";
                Voucher_Type_Voucher = "INTERNAL TRANSFER";
                break;
            case "BUT_FD":
                  hasRight = "@Acc_Vou_FD_AddRight";
                Voucher_Type_Voucher = "FD";
                break;
            case "BUT_S_ASSET":
                  hasRight = "@Acc_Vou_SaleAsset_AddRight";
                Voucher_Type_Voucher = "SALE OF ASSET";
                break;
            case "BUT_J_Entry":
                  hasRight = "@Acc_Vou_Journal_AddRight";
                Voucher_Type_Voucher="JOURNAL";
                break;
            case "BUT_ASSET_TFER":
                  hasRight = "@Acc_Vou_AsetTransfer_AddRight";
                Voucher_Type_Voucher="ASSET TRANSFER";
                break;
            case "BUT_WIP_FINAL":
                  hasRight = "@Acc_Vou_WIP_Finalization_AddRight";
                Voucher_Type_Voucher="WIP FINALIZATION";
                break;
            case "BUT_CASH_PAY_VOLUME":
                  hasRight = "@Acc_Vou_Payment_AddRight";
                Voucher_Type_Voucher = "PAYMENT";
                AdditionalParam = "CASH";
                break;
            case "BUT_BANK_PAY_VOLUME":
                  hasRight = "@Acc_Vou_Payment_AddRight";
                Voucher_Type_Voucher = "PAYMENT";
                AdditionalParam = "BANK";
                break;
            case "BUT_CONTRA_VOLUME":
                  hasRight = "@Acc_Vou_Journal_AddRight";
                Voucher_Type_Voucher = "JOURNAL";
                break;
            case "BUT_JV_VOLUME":
                  hasRight = "@Acc_Vou_Payment_AddRight";
                Voucher_Type_Voucher = "PAYMENT";
                AdditionalParam = "JV";
                break;
            default:
                DevExpress.ui.dialog.alert("Coming Soon...!", "Voucher Entry...");
                break;
        }
        if (hasRight == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        if (Voucher_Type_Voucher == "Check Donation Type")
        {
            ChooseDonationType_Voucher();
        }
        else if (Voucher_Type_Voucher.length > 0)
        {
            DataNavigation_Voucher(Voucher_Type_Voucher, Selection_By_Item_Voucher, AdditionalParam);
        }
    }
    </script>
