    <script>
        function Voucher_PeriodSelectionChange(e) {
            if (e.value < 0) { return; }
            $("#Voucher_btnChangePeriod").dxButton("instance").option("disabled", true);
            if (e.value == 20) {
                $("#Voucher_btnChangePeriod").dxButton("instance").option("disabled", false);
                Voucher_ChangePeriodClick();
            }
            else {
                ShowLoader();
                $.ajax({
                    type: 'GET',
                    url: "/Account/VoucherInfo/Cmb_View_SelectedIndexChanged",
                    data:
                    {
                        SelectedIndex: e.value
                    },
                    cache: false,
                    success: function (result) {
                        $("#Voucher_BE_View_Period").dxTextBox("instance").option("value", result.BE_View_Period);
                        $("#Voucher_Fr_Date").val(result.FromDate);
                        $("#Voucher_To_Date").val(result.ToDate);
                        Grid_Display_VoucherInfo();
                    }
                });
                HideLoader();
            }
        }
        function Voucher_ChangePeriodClick() {
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Account/VoucherInfo/frm_Specific_Period_voucherInfo",
                cache: false,
                success: function (data) {
                    ShowLoader();
                    OpenPopup("PopupVoucher_speceficPeriod", "Change Period", false, "auto", "45%", true, data);
                    HideLoader();
                }
            });
        }
        function Frm_Change_Period_Success_Voucher(data) {
            HideLoader();
            if (data.result == false) {
                DevExpress.ui.dialog.alert(data.message, 'Error!!');
            }
            else {
                $("#Voucher_BE_View_Period").dxTextBox("instance").option("value", data.BE_View_Period);
                $("#Voucher_Fr_Date").val(data.FromDate);
                $("#Voucher_To_Date").val(data.ToDate);
                Grid_Display_VoucherInfo();
                $("#PopupVoucher_speceficPeriod").dxPopup("hide");
            }
        }
    </script>
    @* Period Change *@
    <script>
        $("#VoucherInfo_ParentDiv").keydown(function (e) {
            console.log(e);
            if (e.originalEvent.repeat == true) {
                return false;
            }
            if (e.key == "F6" && e.shiftKey) //calculator
            {
                e.preventDefault();
                DevExpress.ui.dialog.alert("Coming Soon... ", 'Calculator..');
            }
            else if (e.key == "F2" && e.altKey) //change period
            {
                e.preventDefault();
                $("#Voucher_PeriodSelection").dxSelectBox("instance").option("value", -1);
                $("#Voucher_PeriodSelection").dxSelectBox("instance").option("value", 20);
            }
        });
        function VoucherItemDD_EnterKey(e)
        {
            if ($("#Voucher_BUT_OK").dxButton("instance").option("disabled") == false)
            {
                $("#Voucher_BUT_OK").trigger("dxclick");
            }
        }
    </script>
