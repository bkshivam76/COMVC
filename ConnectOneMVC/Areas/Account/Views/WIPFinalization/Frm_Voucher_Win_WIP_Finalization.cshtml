    <script>
    function BUT_SAVE_Click_WIPF(e)
    {
        if (ValidateForm(e))
        {
            if (Tag_WIPF == "_Delete")
            {
                DeleteAfterConfirmation("@Model.Me_Text", "",$("#Frm_WIP_Finalization_Window"));
                @*CreateCustomConfirmDialog("@Model.Me_Text", "", true).show().done(function (dialogResult)
