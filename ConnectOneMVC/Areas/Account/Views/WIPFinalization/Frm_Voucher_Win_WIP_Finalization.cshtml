            }
            else {
                $("#Saving_From_Asset_Window").val(false);
                $("#Saving_From_Select_Asset").val(false);
                $("#Frm_WIP_Finalization_Window").submit();
            }
        }
    }
    function DataNavigation_WIPF(Action)
    {
        if (Tag_WIPF == "_New" || Tag_WIPF == "_New_From_Selection"|| Tag_WIPF == "_Edit" /*|| Tag_WIPF == "_View"*/)
        {
            switch (Action)
            {
                case "EDIT":
                case "VIEW":
                    WIPFinal_EditReference(Action);
                    break;
                case "Txn_Report":
                    WIPFinal_OpenTxn_Report();
                    break;
            }
        }
    }
      function WIPFinal_OpenTxn_Report()
      {
          if (WIPFinal_Reference_Grid.GetFocusedRowIndex() < 0)
          {
              DevExpress.ui.dialog.alert('Please Select one row', 'Alert');
              return;
          }
          var GridKey = WIPFinal_Reference_Grid.GetRowKey(WIPFinal_Reference_Grid.GetFocusedRowIndex());
          ShowLoader();
          $.ajax({
              type: 'GET',
              url: "/Account/ProfilePaymentVoucher/Frm_Txn_Report",
              data:
              {
                  CallingGridBaseSessionKey: "Reference_Grid_ExportData_WIPFinal",
                  LedgerID: LED_ID_WIPF,
                  LedgerName:LEDGER_WIPF,
                  popupID: "WIPFin_Txn_Report_Popup",
                  GridPK: GridKey
              },
              cache: false,
              success: function (data)
              {
                  OpenPopup("WIPFin_Txn_Report_Popup", "Transaction Report",null, "auto", 750, true, data);
              }
          });
        }
        $("#WIPFinal_Reference_Grid").keydown(function (evt) {
            if (evt.keyCode == 13) //enter key
            {
                evt.preventDefault();
                evt.stopImmediatePropagation();
                evt.stopPropagation();
                $("#WIPFinal_BUT_EDIT").trigger("dxclick");
            }
        })
      function WIPFinal_EditReference(Action)
      {
          if (WIPFinal_Reference_Grid.GetFocusedRowIndex() < 0)
          {
              DevExpress.ui.dialog.alert('Please Select one row', 'Alert');
              return;
          }
          var GridKey = WIPFinal_Reference_Grid.GetRowKey(WIPFinal_Reference_Grid.GetFocusedRowIndex());
          var Title_Item_Detail;
          if (Tag_WIPF == "_View")
          {
              Title_Item_Detail = "View ~ Item Detail";
          }
          else
          {
              Title_Item_Detail = "Edit ~ Item Detail";
          }
          ShowLoader();
          $.ajax({
              type: 'GET',
              url: "/Account/WIPFinalization/Frm_Voucher_WIP_Item_Detail",
              data:
              {
                  ActionMethod: Action,
                  xMID: "@Model.xMID",
                  Sr:GridKey
              },
              cache: false,
              success: function (data)
              {
                  OpenPopup("WIP_Item_Detail_Popup", Title_Item_Detail,null, "auto", 500, true, data);
              }
          });
      }
    </script>
