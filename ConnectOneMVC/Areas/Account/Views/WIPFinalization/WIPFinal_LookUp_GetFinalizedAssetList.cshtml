
@using DevExtreme.AspNet.Data;
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("FinalizedAssetList_datagrid")    
    .Columns(columns =>
    {
        columns.Add().DataField("Finalized_Asset").Caption("Finalized_Asset").Visible(true);
        columns.Add().DataField("LED_TYPE").Visible(false);
        columns.Add().DataField("CON_LED_TYPE").Visible(false);
        columns.Add().DataField("ITEM_CON_MIN_VALUE").Visible(false);
        columns.Add().DataField("ITEM_CON_MAX_VALUE").Visible(false);
        columns.Add().DataField("Asset_Item_ID").Visible(false);
        columns.Add().DataField("Asset_LED_ID").Visible(false);
        columns.Add().DataField("ITEM_CON_LED_ID").Visible(false);
    })
    .SelectedRowKeys(new JS(@"component.option(""value"")"))
    .Selection(s => s.Mode(SelectionMode.Single)) 
)
