            function readFilterParamValues() {

                if ($("#StartDate_Accom_Register").dxDateBox("instance").option("value") != null) {
                    fromDate_fltr_AccomRgstr = JS_Json_Date_To_ddMMyyyy($("#StartDate_Accom_Register").dxDateBox("instance").option("value"));
                } else { fromDate_fltr_AccomRgstr = null; }
                if ($("#StartTime_Accom_Register").dxDateBox("instance").option("value") != null) {
                    fromtime_fltr_AccomRgstr = JS_Json_Date_To_ddMMyyyy($("#StartTime_Accom_Register").dxDateBox("instance").option("value"));
                } else { fromtime_fltr_AccomRgstr = null; }
                if ($("#EndDate_Accom_Register").dxDateBox("instance").option("value") != null) {
                    toDate_fltr_AccomRgstr = JS_Json_Date_To_ddMMyyyy($("#EndDate_Accom_Register").dxDateBox("instance").option("value"));
                } else { toDate_fltr_AccomRgstr = null; }
                if ($("#EndTime_Accom_Register").dxDateBox("instance").option("value") != null) {
                    totime_fltr_AccomRgstr = JS_Json_Date_To_ddMMyyyy($("#EndTime_Accom_Register").dxDateBox("instance").option("value"));
                } else { totime_fltr_AccomRgstr = null; }

                if (($("#StartDate_Accom_Register").dxDateBox("instance").option("value") != null && $("#StartDate_Accom_Register").dxDateBox("instance").option("value") != undefined) &&
                    ($("#EndDate_Accom_Register").dxDateBox("instance").option("value") == null || $("#EndDate_Accom_Register").dxDateBox("instance").option("value") == undefined)) {
                    DevExpress.ui.notify({ message: 'To Date should not be Empty', width: 300, shading: true, position: 'center' }, "error", 1500);
                    return;
                }
                if (($("#StartDate_Accom_Register").dxDateBox("instance").option("value") == null && $("#StartDate_Accom_Register").dxDateBox("instance").option("value") == undefined) &&
                    ($("#EndDate_Accom_Register").dxDateBox("instance").option("value") != null || $("#EndDate_Accom_Register").dxDateBox("instance").option("value") != undefined)) {
                    DevExpress.ui.notify({ message: 'From Date should not be Empty', width: 300, shading: true, position: 'center' }, "error", 1500);
                    return;
                }
                if ($("#StartDate_Accom_Register").dxDateBox("instance").option("value") > $("#EndDate_Accom_Register").dxDateBox("instance").option("value")) {
                    DevExpress.ui.notify({ message: 'From Date should not be greater than To Date', width: 300, shading: true, position: 'center' }, "error", 2000);
                    return;
                }
                eventid_AccomRgstr = $("#Event_AccmRegstr").dxDropDownBox("option", "value");
                filterBy_AcommRgstr = $("#Acomm_Regstr_Filterby").dxSelectBox("option", "value");
