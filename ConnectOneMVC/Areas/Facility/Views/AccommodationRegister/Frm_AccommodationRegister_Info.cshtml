                        function Accom_RegisterInfo_GetSelectedRowData(_Action) {
                            ShowLoader();
                            AccommodationRegister_InfoGrid.GetSelectedFieldValues("CHART_ID;CHART_SR_ID;ServiceReportID;UserID;AB_ID;RESP_ID;Remarks;Arrival;Departure;Beds;RegNo;Event;Form;Name;City;Slip_By;Registrations;Accom From;Accom To;",
                                function (values) { GetSelectedFieldValuesCallback_Accom_Register(values, _Action) })                          
                        }
                        function GetSelectedFieldValuesCallback_Accom_Register(values, _Action) {                          
                            HideLoader();                
                            if (values != null) {
                                for (var Index = 0; Index < values.length; Index++) {                                
                                    if (Index == 0) {
                                        chartInstanceID_AccRgstr = values[Index][1];
                                        Chart_Response_ID_AccRgstr = values[Index][5];
                                        Chart_Response_Remarks_AccRgstr = values[Index][6];
                                        UserID_AccRgstr = values[Index][3];
                                        UserABID_AccRgstr = values[Index][4];
                                        fromDate_AccomRgstr = values[Index][7];
                                        toDate_AccomRgstr = values[Index][8];
                                        bedCounts_AccomRegstr = values[Index][9];
                                        registrations_AccomRegstr = values[Index][16];
                                        NamesofRegistrations_AccomRegstr = values[Index][13]; //Names of the registrated person.
                                        AcommodationFrom_AccomRegstr = values[Index][17];
                                        AcommodationTo_AccomRegstr = values[Index][18];
                                    }
                                    else {
                                        chartInstanceID_AccRgstr = chartInstanceID_AccRgstr + "|" + values[Index][1];
                                        Chart_Response_ID_AccRgstr = Chart_Response_ID_AccRgstr + "|" + values[Index][5];
                                        Chart_Response_Remarks_AccRgstr = Chart_Response_Remarks_AccRgstr + "|" + values[Index][6];
                                        UserID_AccRgstr = UserID_AccRgstr + "|" + values[Index][3];
                                        UserABID_AccRgstr = UserABID_AccRgstr + "|" + values[Index][4];
                                        fromDate_AccomRgstr = fromDate_AccomRgstr + "|" + values[Index][7];
                                        toDate_AccomRgstr = toDate_AccomRgstr + "|" + values[Index][8];
                                        bedCounts_AccomRegstr = bedCounts_AccomRegstr + "|" + values[Index][9];
                                        registrations_AccomRegstr = registrations_AccomRegstr + "|" + values[Index][16];
                                        NamesofRegistrations_AccomRegstr = NamesofRegistrations_AccomRegstr + "|" + values[Index][13];
                                        AcommodationFrom_AccomRegstr = AcommodationFrom_AccomRegstr + "|" + values[Index][17];
                                        AcommodationTo_AccomRegstr = AcommodationTo_AccomRegstr + "|" + values[Index][18];
                                    }
                                }
                            }
                            else {
                                UserID_AccRgstr = "";
                                UserABID_AccRgstr = "";
                            }

                            if (_Action == "PRINT") {
                                var SelectedRowCount = AccommodationRegister_InfoGrid.GetSelectedRowCount();
                                if (SelectedRowCount == 1) {
                                    if (parseInt(bedCounts_AccomRegstr) == 0) {
                                        var result = DevExpress.ui.dialog.confirm("Accommodation has not been allocated for the selected Registration.Do you want to Allott Accommodation ?", "Confirmation");
                                        result.done(function (dialogResult) {
                                            if (dialogResult) {
                                                Accom_RegisterInfo_Accommodation();
                                            }
                                        });
                                    }
                                    else { openPrintOptionsOrSlip(); }
                                }
                                else if (SelectedRowCount > 1) {
                                    var bedsCountarray = bedCounts_AccomRegstr.split("|");
                                    var index = bedsCountarray.indexOf("0")
                                    if (index > -1) {
                                        var result = DevExpress.ui.dialog.confirm("Accommodation has not been allocated for one or more of selected Registrations. Do you want to Allott Accommodation?", "Confirmation");
                                        result.done(function (dialogResult) {
                                            if (dialogResult) {
                                                Accom_RegisterInfo_Accommodation();
                                            }
                                        });
                                    }
                                    else {
                                        openPrintOptionsOrSlip();
                                    }
                                }
                            }
                            else if (_Action == "MarkArrived" || _Action == "UnMarkArrived") {
                                MarkorUnMark_AccomRegstr(_Action)
                            }

                            else if (_Action == "ACCOMMODATION") {
                                continueEvenDatesNotEqual_AccomRegstr = "false"
                                openAccommodationSettingsWindow();
                            }
                            else if (_Action == "GROUPDETAILS") {
                                ShowLoader();
                                $.ajax({
                                    type: 'GET',
                                    url: "/Facility/Chart/Frm_ChartResponse_GroupDetails",
                                    cache: false,
                                    data:
                                    {
                                        ChartResponseID: Chart_Response_ID_AccRgstr,
                                    },
                                    success: function (data) {
                                        HideLoader();
                                        OpenPopup("ResponseGroupDetails_Popup", "Group Registration Details", null, "auto", 800, true, data);
                                    }
                                });
                            }
                            else if (_Action == "EditResponse") {
                                ShowLoader();
                                if (UserID_AccRgstr == null) { UserID_AccRgstr = ""; }
                                if (UserABID_AccRgstr == null) { UserABID_AccRgstr = ""; }

                                HideLoader();
                                var URL = "@ServicePath" + "ViewChartUser/" + chartInstanceID_AccRgstr + "/" + UserID_AccRgstr + "/" + UserABID_AccRgstr + "/?ActionMethod=_Edit&ResponseID=" + Chart_Response_ID_AccRgstr;
                                OpenFormPopup(chartInstanceID_AccRgstr, false, URL, "ViewFormUserSidePopup", "Edit ~ Response")
                                window.onmessage = function (e) {
                                    if (e.data == 'FormOperationCompleted') {
                                        $("#ViewFormUserSidePopup").dxPopup("hide");
                                        ShowLoader();
                                        GoAccomRegister();
                                        HideLoader();
                                    }
                                };
                            }
                        }

