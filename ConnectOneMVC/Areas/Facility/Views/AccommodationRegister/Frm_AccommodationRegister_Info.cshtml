        function MarkorUnMark_AccomRegstr(_Action) {
            var result = false;
            if (_Action == "MarkArrived") {
                result = DevExpress.ui.dialog.confirm('Are You Sure You want To Mark as Arrived...?', "Confirm");
            }
            else if (_Action == "UnMarkArrived") {
                result = DevExpress.ui.dialog.confirm('Are You Sure You want To UnMark as Arrived...?', "Confirm");
            }

            result.done(function (dialogResult) {
                dontaskpopupcloseconfirmation = dialogResult;
                if (dialogResult) {
                    ShowLoader();
                    $.ajax({
                        type: 'GET',
                        url: "/Facility/Chart/ChangeResponseArrivalStatus",
                        cache: false,
                        data:
                        {
                            chartResponseID: Chart_Response_ID_AccRgstr,
                            _Action: _Action == "MarkArrived" ? "MARK" : "UNMARK"
                        },
                        success: function (data) {
                            HideLoader();
                            var alertClick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                            alertClick.done(function (alertResult) {
                                if (alertResult) {
                                    AccommodationRegister_InfoGrid.UnselectAllRowsOnPage();
                                    GoAccomRegister();
                                }
                            })
                        }
                    });
                }
                else {

                }
            });
        }

