    <script>
        function Accom_RegisterInfo_Accommodation() {

            var SelectedRowCount = AccommodationRegister_InfoGrid.GetSelectedRowCount();
            if (SelectedRowCount < 1) {
                DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                return;
            }        
            Accom_RegisterInfo_GetSelectedRowData("ACCOMMODATION");
            ShowLoader();
        }
        var continueEvenDatesNotEqual_AccomRegstr = "false";
        function openAccommodationSettingsWindow() {      
            var arrival_date = null; var departure_date = null;
            var SelectedRowCount = AccommodationRegister_InfoGrid.GetSelectedRowCount();
            if (SelectedRowCount == 1) {
                if (AcommodationFrom_AccomRegstr != "" && AcommodationFrom_AccomRegstr != " " && AcommodationFrom_AccomRegstr != "null" && AcommodationFrom_AccomRegstr != undefined) {
                    arrival_date = AcommodationFrom_AccomRegstr
                    departure_date = AcommodationTo_AccomRegstr
                } else {
                    arrival_date = fromDate_AccomRgstr
                    departure_date = toDate_AccomRgstr
                }
            }
            else if (SelectedRowCount > 1) {
                var accommodationFromArray = AcommodationFrom_AccomRegstr.split("|")
                var accommodationFromdate = accommodationFromArray.find(dt => dt != "null" && dt != "" && dt != " "); //y.find(y=>y=="null")
                if (accommodationFromdate == undefined) {
                    arrival_date = fromDate_AccomRgstr
                    departure_date = toDate_AccomRgstr
                } else if (accommodationFromdate != "null" && accommodationFromdate != undefined) {
                    arrival_date = AcommodationFrom_AccomRegstr
                    departure_date = AcommodationTo_AccomRegstr
                }
            }
            $.ajax({
                type: 'GET',
                url: "/Facility/AccommodationRegister/Frm_AccomodationSettings_Multi",
                cache: false,
                data:
                {
                    _ChartResponseID: Chart_Response_ID_AccRgstr,
                    _ChartInstanceID: chartInstanceID_AccRgstr,
                    arrivalDate: arrival_date, //fromDate_AccomRgstr,
                    departureDate: departure_date, //toDate_AccomRgstr,
                    bedCounts: bedCounts_AccomRegstr,
                    Registrations: registrations_AccomRegstr,
                    gridToRefresh: "AccommodationRegister_InfoGrid",
                    Names: NamesofRegistrations_AccomRegstr,
                    ContinueEvenDatesNotEqual: continueEvenDatesNotEqual_AccomRegstr
                },
                success: function (data) {
                    HideLoader();

                    if (typeof (data) == 'string') {
                        OpenPopup("Response_Accomodation_popup", "Add Accomodation", null, "auto", 800, true, data);
                    }
                    else if (typeof (data) == 'object') {
                        if (data.jsonParam.isconfirm) {
                            var result = DevExpress.ui.dialog.confirm(data.jsonParam.message, "Confirm");
                            result.done(function (dialogResult) {
                                if (dialogResult) {
                                    continueEvenDatesNotEqual_AccomRegstr = "true";
                                    openAccommodationSettingsWindow();
                                }
                            });
                        } else {
                            DevExpress.ui.dialog.alert(data.jsonParam.message, "Alert");
                        }
                    }

                }
            });
        }
        function DataNavigation_Accom_Register(_action) {

            var SelectedRowCount = AccommodationRegister_InfoGrid.GetSelectedRowCount();
            if (SelectedRowCount < 1 && _action == "SAVE") {
                DevExpress.ui.dialog.alert("Please Select Rows", "Alert");
                return;
            }
            Accom_RegisterInfo_GetSelectedRowData(_action);
        }



    </script>

