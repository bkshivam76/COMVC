<div class="Accom_RegisterFacility_ClearReferences" onkeydown="keydown_AccommRegstr(event)">
    @using DevExtreme.AspNet.Mvc;
    @model System.Data.DataTable
    @{
        string ScreenHeaderLabel = "Accommodation Register";
        var ChartID = ViewBag.Chartid;
        string SessionGUID = Request.QueryString["SessionGUID"];
        string ServicePath = ViewBag.ServicePath;
    }
    @*<div id="Accom_Register_ParentDiv">*@

    <style>
        /*.ar_filter .col-sm-3{padding:0 0 0 10px}*/
        .maxheightPrintSlip > div {
            max-height: 99vh;
        }

        #selectedCount_div {
            font: 500;
            padding-top: 15px;
            padding-right: 5px;
            text-align: right;
        }

        #filtersdiv_accomRegstr { background: rgb(243, 251, 254); }

        @@media (max-width:768px) { #selectedCount_div {
                text-align: center;
                padding-top: 5px;
            }
            #selectedCount_div label:empty{display:none}
        }
    </style>
    <script>

        var Chart_Response_ID_AccRgstr = "";
        var Chart_Response_Status_AccRgstr = "";
        var Chart_Response_Remarks_AccRgstr = "";
        var chartInstanceID_AccRgstr = "";
        var AccomRegstr_ShowHorizontalBar = parseInt("@ViewBag.AccomRegstr_ShowHorizontalBar");
        var AccomRegstr_ColumnToBeShownIndex = "";
        var AccomRegstr_ColumnToBeHidddenIndex = "";
        var AccomRegstr_FocusedRowIndexBeforeRefresh = "";
        @*var Chart_Instance_ID = "@chartInstanceID";*@
        @*var ServicePath = "@ServicePath";*@
        @*//var Chart_Approval_Required = "@chartApprovalRequired" == "False" ? false: true;*@
        var AccomRegstr_GridLayout = null;
        var UserID_AccRgstr = "";
        var UserABID_AccRgstr = "ggg";
        var ShareMessage_ChartResponse_AccRgstr = "";
        var MobNo_AccRgstr = "";
        var NextLinkedForm_Inst_ID_ChartResponse_AccRgstr = 0;
        var FeedbackFormInstID_ChartResponse_AccRgstr = 0;
        var TravelFormInstID_ChartResponse_AccRgstr = 0;
        var CompactMode_AccRgstr = "Default"; //"Compact";


        function keydown_AccommRegstr(event) {

            event.stopPropagation();
            event.stopImmediatePropagation()
            console.log(event.key);
        }
    </script>

    <div id="Accom_Register_content" class="report_header_div_main">
        <div class="row">
            <div class="col-sm-6">
                <div class="report_header_div">
                    <label class="report_header_label">@ScreenHeaderLabel</label>
                </div>
            </div>
            <div class="col-sm-6">
                <div id="selectedCount_div"><label></label></div>
            </div>
        </div>
        <div class="row row1">
            <div class="col-md-12">
                <div class="report_button_div">
                    @(Html.DevExtreme().Button().ID("Btn_GroupDetails_Accom_Regstr").Text("Group Details").OnClick("GroupDetails_Accom_Regstr_Click"))
                    @(Html.DevExtreme().Button().ID("Btn_AddResponse_Accom_Regstr").Text("Add Response")//.Icon("save")
                        .OnClick("AccomRegstr_AddResponse"))
                    @(Html.DevExtreme().DropDownButton().ID("Btn_ViewSummary_AccomRegstr").Text("Summaries").OnItemClick("Chart_ViewSummary_Accom_Regstr_Click")
                                .DataSource(new[] { "Guest Summary","Accommodation Details", "Accommodation Summary","Accommodation Chart", "Food Summary", "Food Detail", "Food Details NextTenDays", "Sevadhari Summary" @*"Travel Summary"*@}))
                    <script>
                        function GroupDetails_Accom_Regstr_Click() {
                            var SelectedRowCount = AccommodationRegister_InfoGrid.GetSelectedRowCount();
                            if (SelectedRowCount < 1) {
                                DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                                return;
                            }
                            if (SelectedRowCount > 1) {
                                DevExpress.ui.dialog.alert("Multiple Rows Are Selected <br> Please Select One Row", "Alert");
                                return;
                            }
                            Accom_RegisterInfo_GetSelectedRowData("GROUPDETAILS");
                        }
                        function AccomRegstr_AddResponse() {
                            eventid_AccomRgstr = $("#Event_AccmRegstr").dxDropDownBox("option", "value");
                            if (eventid_AccomRgstr == undefined || eventid_AccomRgstr == "") { eventid_AccomRgstr = null }
                            $.ajax({
                                type: 'GET',
                                url: "/Facility/AccommodationRegister/Frm_LiveFormsList_AccRegstr",
                                cache: false,
                                //data: { eventid: eventid_AccomRgstr, },
                                success: function (data) {

                                    HideLoader();
                                    OpenPopup("LiveFormsPopup_AccomRegstr", "Live Forms List", null, "auto", 800, true, data, "maxheightPrintSlip");

                                },
                                error: function (jqXHR, textStatus, errorThrown) {
                                    HideLoader();
                                    //console.log(jqXHR);
                                    //console.log(textStatus);
                                    //console.log(errorThrown);
                                    DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
                                }
                            });
                        }
                        function Chart_ViewSummary_Accom_Regstr_Click(e) {
                            if (e.itemData == "Guest Summary") {
                                showGuestSummary_AccRgstr();
                            }
                            else if (e.itemData == "Sevadhari Summary") {
                                showSevadhariSummary_AccRgstr();
                            }
                            //else if (e.itemData == "Travel Summary") {
                            //    showTravelSummary();
                            //}
                            else if (e.itemData == "Accommodation Summary") {
                                showAccommodationSummary_AccRgstr();
                            }
                            else if (e.itemData == "Accommodation Details") {
                                showAccommodationDetails_AccRgstr();
                            }
                            else if (e.itemData == "Accommodation Chart") {
                                showAccommodationChart_AccRgstr();
                            }
                            else if (e.itemData == "Food Summary") {
                                showFoodSummary_AccRgstr();
                            }
                            else if (e.itemData == "Food Detail") {
                                showFoodDetail_AccRgstr();
                            }
                            else if (e.itemData == "Food Details NextTenDays") {
                                showFoodDetailNextTenDays_AccRgstr();
                            }
                        }
                    </script>

                    @(Html.DevExtreme().Button().ID("Btn_AddRemarks_Accom_Regstr").Text("Add Remarks")//.Icon("save")
                        .OnClick("AccomRegstr_AddRemarks"))
                    @(Html.DevExtreme().Button().ID("Btn_ResponseArrived_Accom_Regstr").Text("Arrived")//.Icon("save")
                        .OnClick(@<text> function () { AccomRegstr_Arrived("MarkArrived"); } </text>))
                    @(Html.DevExtreme().Button().ID("Btn_ResponseNotArrived_Accom_Regstr").Text("Not Arrived")//.Icon("save")
                        .OnClick(@<text> function () { AccomRegstr_Arrived("UnMarkArrived"); } </text>))
                    @(Html.DevExtreme().Button().ID("Btn_EditResponse_Accom_Regstr").Text("Edit").Icon("edit")
                        .OnClick("AccomRegstr_Edit"))
                    @(Html.DevExtreme().Button().ID("Btn_PreviewResponse_Accom_Regstr").Text("Preview").Icon("save")
                        .OnClick("AccomRegstr_Preview"))
                    @(Html.DevExtreme().Button().ID("Btn_ResponseAccomodation_Accom_Regstr").Text("Accommodation").Icon("save")
                        .Visible(true).OnClick("Accom_RegisterInfo_Accommodation"))
                    @(Html.DevExtreme().Button().ID("AccomRegstr_MasterToggleScrollBar").Text(ViewBag.AccomRegstr_ShowHorizontalBar == 1 ? "Default Data" : "Full Data")
                        .Width(ViewBag.AccomRegstr_ShowHorizontalBar == 1 ? 110 : 90)
                        .Icon("toolbox").OnClick("OnAccomRegstrChangeMode"))
                    <script>

                    function OnAccomRegstrChangeMode(e)
                    {

                        ShowLoader();
                        AccomRegstr_FocusedRowIndexBeforeRefresh = AccommodationRegister_InfoGrid.GetFocusedRowIndex();
                            if (AccomRegstr_ShowHorizontalBar == 0)
                            {
                                AccomRegstr_ShowHorizontalBar = 1;
                                $("#AccomRegstr_MasterToggleScrollBar").find("span").text("Default Data");
                            }
                            else
                            {
                                AccomRegstr_ShowHorizontalBar = 0;
                                $("#AccomRegstr_MasterToggleScrollBar").find("span").text("Full Data");
                            }
                        readFilterParamValues()

                            $.ajax({
                                url: '@Url.Action("Frm_AccommodationRegister_Info_Grid", "AccommodationRegister")',
                                type: "GET",

                                data: {
                                    fromdate: fromDate_fltr_AccomRgstr,
                                    todate: toDate_fltr_AccomRgstr,
                                    fromtime: fromtime_fltr_AccomRgstr,
                                    totime: totime_fltr_AccomRgstr,
                                    eventid: eventid_AccomRgstr,
                                    buildingid: buildingid_AccomRgstr,
                                    //command: "REFRESH",
                                    reg_Number: registrationNumber_AccomRgstr,
                                    ShowHorizontalBar: AccomRegstr_ShowHorizontalBar,
                                    Layout: AccomRegstr_GridLayout,
                                    ViewMode: CompactMode_AccRgstr,
                                    ColumnToBeHidddenIndex: AccomRegstr_ColumnToBeHidddenIndex,
                                    ColumnToBeShownIndex: AccomRegstr_ColumnToBeShownIndex,
                                    Chart_Inst_ID: chart_inst_id_filter_AccomRgstr
                                },
                                success: function (res)
                                {
                                    $("#Accom_RegisterGridPartialView").html(res);
                                    AccommodationRegister_InfoGrid.SetFocusedRowIndex(AccomRegstr_FocusedRowIndexBeforeRefresh);
                                }
                            });

                            HideLoader();
                        }//full data button click
                    </script>
                    @(Html.DevExtreme().Switch().ID("AccomRegstrInfoViewModeSwitch").SwitchedOnText("Compact").Visible(false)
                        .SwitchedOffText("Default").OnValueChanged("AccomRegister_ViewSwitch_ValueChange").Width(70).Value(string.IsNullOrWhiteSpace(SessionGUID)?false:true))
                    @(Html.DevExtreme().Button().ID("AccomRegstrInfoModelListPreview").Text("List Preview").Icon("save").Visible(false)
                            .OnClick("OnAccomRegstrInfoListPreviewClick"))

                    <script>
                            function AccomRegister_ViewSwitch_ValueChange(e)
                            {
                                CompactMode_AccRgstr = e.value ? "Compact" : "Default";
                                ReloadGrid_AccomRegister();
                            }
                            function ReloadGrid_AccomRegister()
                            {
                                ShowLoader();
                                $.ajax({
                                    url: '@Url.Action("Frm_Chart_Responses_Info_Grid", "Chart")',
                                    type: "POST",
                                    data:
                                    {
                                        ShowHorizontalBar: 1,
                                        Layout: AccommodationRegister_InfoGrid.cpClientLayout,
                                        VouchingMode: false,
                                        ViewMode: CompactMode_AccRgstr,
                                        ColumnToBeHidddenIndex: AccommodationRegister_InfoGrid.cpColumnToBeHidddenIndex,
                                        ColumnToBeShownIndex: AccommodationRegister_InfoGrid.cpColumnToBeShownIndex,
                                        Chart_Instance_ID: chartInstanceID_AccRgstr,
                                        //isApprovalRequired:Chart_Approval_Required
                                    },
                                    success: function (res)
                                    {
                                        $("#ChartResponsesGridDiv").html(res);
                                        HideLoader();
                                    }
                                });
                            }
                            function OnAccomRegstrInfoListPreviewClick() {
                                ShowLoader();
                                OpenPopup("AccmRgstrInfo_modal", "Export Option", "@Url.Action("Frm_Export_Options_AccomRestr", "AccommodationRegister", new { @area = "Facility" })", "auto",130);

                            }
                    </script>

                    @(Html.DevExtreme().Button().ID("Accom_Register_PrintSlip").Text("PrintSlip").Icon("add").Visible(true).OnClick("printSlipfromBtn_AccomRegstr"))
                    <script>
                        var printFromButton = false
                        function printSlipfromBtn_AccomRegstr() {
                            printFromButton = true
                            printSlip_AccomRegstr()
                        }
                        function printSlip_AccomRegstr() {
                            var SelectedRowCount = AccommodationRegister_InfoGrid.GetSelectedRowCount();
                            if (SelectedRowCount < 1) {
                                DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                                return;
                            }
                            Accom_RegisterInfo_GetSelectedRowData("PRINT");
                        }
                        function openPrintOptionsOrSlip() {

                            var SelectedRowCount = AccommodationRegister_InfoGrid.GetSelectedRowCount();
                            if (SelectedRowCount == 1) {
                                $.ajax({
                                    type: 'GET',
                                    url: "/Facility/AccommodationRegister/Frm_PrintSlip_AccomRegstr",
                                    cache: false,
                                    data:
                                    {
                                        Chart_Inst_ID: chartInstanceID_AccRgstr,
                                        Chart_Resp_ID: Chart_Response_ID_AccRgstr,
                                        PrintOption: "Individual"
                                    },
                                    success: function (data) {
                                        HideLoader();
                                        OpenPopup("PrintSlipPopup_AccomRegstr", "Print Slip Options", null, "auto", 360, true, data, "maxheightPrintSlip");

                                    },
                                    error: function (jqXHR, textStatus, errorThrown) {
                                        HideLoader();
                                        console.log(jqXHR);
                                        console.log(textStatus);
                                        console.log(errorThrown);
                                        DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
                                    }
                                });
                            }
                            else if (SelectedRowCount > 1) {
                                $.ajax({
                                    type: 'GET',
                                    url: "/Facility/AccommodationRegister/Frm_PrintSlipOptions",
                                    cache: false,
                                    data:
                                    {
                                        Chart_Inst_ID: chartInstanceID_AccRgstr,
                                        Chart_Resp_ID: Chart_Response_ID_AccRgstr,
                                        NamesList: NamesofRegistrations_AccomRegstr,
                                    },
                                    success: function (data) {
                                        HideLoader();
                                        OpenPopup("PrintSlipPopup_AccomRegstr", "PrintSlip(s)", null, "auto", 380, true, data, "maxheightPrintSlip");
                                    },
                                    error: function (jqXHR, textStatus, errorThrown) {
                                        HideLoader();
                                        console.log(jqXHR);
                                        console.log(textStatus);
                                        console.log(errorThrown);
                                        DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
                                    }
                                });
                            }
                        }
                    </script>
                    @(Html.DevExtreme().Button().ID("Accom_Register_ListPreview").Text("List Preview").Icon("save").OnClick("OnAccom_RegisterListPreviewClick"))
                    <script>
                        function OnAccom_RegisterListPreviewClick() {
                            ShowLoader();
                            OpenPopup("Accommodation_Register_modal", "Export Option", "@Url.Action("Frm_Export_Options", "AccommodationRegister", new { @area = "Facility" })", "auto",130);
                        }
                    </script>
                    @(Html.DevExtreme().Button().ID("Accom_Register_ModelCLOSE").Text("Close").Icon("clear").OnClick("closeAccom_Register") )
                </div>
            </div>
        </div>

        <div id="Accom_Register_hideFilters" class="filhdr" onclick="hideFiltersAccom_Register()">
            <span>Click to Hide Filters</span>
            <i class="bx bx-up-arrow-alt"></i>
        </div>


        <div>

            <div id="filtersdiv_accomRegstr" style="display:block;">
                <div class="row row2" style="padding:10px;">
                    <div class="col-sm-3">
                        <label>Filter By</label>
                        @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("Acomm_Regstr_Filterby").Name("Acomm_Regstr_Filterby")
                            .Items(new[] { "Event Start And End Dates", "Arrival and Departure Dates", "Accommodation From and To Dates" }).Value("Event Start And End Dates")
                            .ShowClearButton(false).OnValueChanged("Accom_Register_filterBy_ValueChange"))
                    </div>
                    <script>
                        function hideFiltersAccom_Register() {
                            var div = document.getElementById("filtersdiv_accomRegstr");
                            if (div.style.display !== "none") {
                                div.style.display = "none";
                                $("#Accom_Register_hideFilters").find('span').text("Click to Show Filters");
                                $("#Accom_Register_hideFilters").find('i').removeClass('bx-up-arrow-alt').addClass('bx-down-arrow-alt');
                            }
                            else {
                                div.style.display = "block";
                                $("#Accom_Register_hideFilters").find('span').text("Click to Hide Filters")
                                $("#Accom_Register_hideFilters").find('i').removeClass('bx-down-arrow-alt').addClass('bx-up-arrow-alt');
                            }

                        }
                        function Accom_Register_filterBy_ValueChange(e) {
                            filterBy_AcommRgstr = e.value;
                        }
                    </script>
                    <div class="col-sm-2">
                        <label>Start Date</label>
                        @(Html.DevExtreme().DateBox().CustomDateBox().Name("StartDate_Accom_Register").ID("StartDate_Accom_Register").Min(new DateTime(1990,01,01))
                            .OnValueChanged("StartDate_Accom_Register_ValueChange").Value(DateTime.Today))
                    </div>
                    <div class="col-sm-2">
                        <label>Start Time</label>
                        @(Html.DevExtreme().DateBox().CustomDateBox().Name("StartTime_Accom_Register").ID("StartTime_Accom_Register").Min(DateTime.MinValue).Type(DateBoxType.Time)
                            .Type(DateBoxType.Time).DisplayFormat("hh:mm a").UseMaskBehavior(true).Placeholder("hh:mm AM/PM").Interval(15).OnValueChanged("StartTime_Accom_Register_ValueChange"))

                    </div>
                    <div class="col-sm-2">
                        <label>End Date</label>
                        @(Html.DevExtreme().DateBox().CustomDateBox().Name("EndDate_Accom_Register").ID("EndDate_Accom_Register").Min(new DateTime(1990, 01, 01))
                            .OnValueChanged("EndDate_Accom_Register_ValueChange").Value(DateTime.Today.AddDays(1)))
                    </div>

                    <div class="col-sm-2">
                        <label>End Time</label>
                        @(Html.DevExtreme().DateBox().CustomDateBox().Name("EndTime_Accom_Register").ID("EndTime_Accom_Register").Type(DateBoxType.Time).Min(DateTime.MinValue)
                            .DisplayFormat("hh:mm a").UseMaskBehavior(true).Placeholder("hh:mm AM/PM").Interval(15).OnValueChanged("EndTime_Accom_Register_ValueChange"))
                    </div>
                    <div class="col-sm-1">
                        <label>Mode</label>
                        @(Html.DevExtreme().Switch().ID("ModeSwitch_Accom_Register").Name("ModeSwitch_Accom_Register").Value(true).SwitchedOnText("Concise").SwitchedOffText("Full").Width(70).OnValueChanged("ModeSwitch_Accom_Register_ValueChange"))
                    </div>
                </div>

                <div class="row row3" style="padding:10px;">
                    <div class="col-sm-3">
                        <label>Service Report/Event</label>
                        @(Html.DevExtreme().DropDownBox().CustomDropDown().Name("Event_AccmRegstr").ID("Event_AccmRegstr").Placeholder("Choose..").DisplayExpr("Name").ValueExpr("ID")
                        .DataSource(d => d.Mvc().Controller("AccommodationRegister").LoadAction("LookUp_Get_EventsList").Key("ID").LoadMode(DataSourceLoadMode.Raw))
                        .ContentTemplate(@<text>
                            @(Html.DevExtreme().DataGrid().CustomDataGrid().ID("Event_AccmRegstr_datagrid")
                                .Columns(columns =>
                                {
                                    columns.Add().DataField("Name").Caption("Name");
                                    columns.Add().DataField("ID").Visible(false);
                                    columns.Add().DataField("ProjID").Visible(false);
                                    columns.Add().DataField("Type");
                                    columns.Add().DataField("FromDate").DataType(GridColumnDataType.Date).Format("dd/MM/yyyy");
                                    columns.Add().DataField("ToDate").DataType(GridColumnDataType.Date).Format("dd/MM/yyyy");
                                    columns.Add().DataField("Venue");
                                })
                                .Selection(s => s.Mode(SelectionMode.Single))
                                .FilterRow(s=>s.Visible(false))
                                .OnSelectionChanged("function(selectedItems)" +
                                "{ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}"))
                        </text>).OnValueChanged("Event_AccmRegstr_ValueChange")
                    )
                    </div>
                    <div class="col-sm-3">
                        <label>Form</label>
                        @(Html.DevExtreme().DropDownBox().CustomDropDown().Name("Form_AccmRegstr").ID("Form_AccmRegstr").Placeholder("Choose..").DisplayExpr("FORM_NAME").ValueExpr("INSTANCE_ID")
                        .DataSource(d => d.Mvc().Controller("AccommodationRegister").LoadAction("LookUp_Get_LiveFormsList").Key("INSTANCE_ID").LoadMode(DataSourceLoadMode.Raw))
                        .ContentTemplate(@<text>
                            @(Html.DevExtreme().DataGrid().CustomDataGrid().ID("Form_AccmRegstr_datagrid")
                                .Columns(columns =>
                                {
                                    columns.Add().DataField("FORM_NAME").Caption("Form Name").Visible(true);
                                    columns.Add().DataField("EVENTNAME").Caption("Event Name").Visible(true);
                                    columns.Add().DataField("CSN_CHART_ID").Caption("ChartID").Visible(false);
                                    columns.Add().DataField("CSN_SERVICE_REPORT_ID").Caption("EventID").Visible(false);
                                    columns.Add().DataField("CSN_SRNO").Caption("CSN_SRNO").Visible(false);
                                    columns.Add().DataField("INSTANCE_ID").Caption("INSTANCEID").Visible(false);
                                    columns.Add().DataField("FROMDATE").DataType(GridColumnDataType.Date).Format("dd/MM/yyyy").Visible(true);
                                    columns.Add().DataField("TODATE").DataType(GridColumnDataType.Date).Format("dd/MM/yyyy").Visible(true);
                                })
                                .Selection(s => s.Mode(SelectionMode.Single))
                                .FilterRow(s=>s.Visible(false))
                                .OnSelectionChanged("function(selectedItems)" +
                                "{ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}"))
                        </text>).OnValueChanged("Form_AccmRegstr_ValueChange")
                    )
                    </div>
                    <div class="col-sm-2">
                        <label>Building Name</label>
                        @(Html.DevExtreme().DropDownBox().CustomDropDown().Name("Building_AccmRegstr").ID("Building_AccmRegstr").Placeholder("Choose..").DisplayExpr("BUILDING_NAME").ValueExpr("REC_ID")
                        .DataSource(d => d.Mvc().Controller("AccommodationRegister").LoadAction("LookUp_Get_BuildingsList").Key("REC_ID").LoadMode(DataSourceLoadMode.Raw))
                        .ContentTemplate(@<text>
                            @(Html.DevExtreme().DataGrid().CustomDataGrid().ID("Building_AccmRegstr_datagrid")
                                .Columns(columns =>
                                {
                                    columns.Add().DataField("BUILDING_NAME").Caption("Building Name");
                                    columns.Add().DataField("REC_ID").Visible(false);
                                })
                                .Selection(s => s.Mode(SelectionMode.Single))

                                )
                                    </text>)
                                .OnValueChanged("Building_AccmRegstr_ValueChange")
                    )
                    </div>
                    <script>
                        async function Building_AccmRegstr_ValueChange(e, FirstCall = false) {
                            var value;
                            var DG = $("#Building_AccmRegstr_datagrid").dxDataGrid("instance");
                            if (e) {
                                value = e.value;
                                if ((e.value == null || e.value.length == 0) && e.previousValue != null) {
                                    DG.clearSelection();

                                    return;
                                }
                            }
                            else {
                                //value = $("#Event_AccmRegstr").dxDropDownBox("option", "value");
                                var bldgid = "";
                                var buildingid_array = $("#Building_AccmRegstr").dxDropDownBox("option", "value");
                                if (buildingid_array != null) { bldgid = buildingid_array[0]; }
                                value = bldgid;
                            }
                            await DG.selectRows(value);
                            if (DG.getSelectedRowsData().length > 0) {
                                var item = DG.getSelectedRowsData()[0];
                                ////  $("#ProjectID_createForm").dxSelectBox("option", "readOnly", true);
                                //$("#ProjectID_createForm").dxSelectBox("option", "value", item.ProjID);
                                //if (item.Type == "Service Report") {
                                //    $("#SR_ID").val(item.ID);
                                //}
                                //else {
                                //    $("#Event_ID").val(item.ID);
                                //}
                                //if (FirstCall == false) {
                                //    await $("#PreReq_createForm_datagrid").dxDataGrid("instance").refresh();
                                //}
                            }
                        }
                    </script>
                    <div class="col-sm-2">
                        <label>Registration Number</label>
                        @(Html.DevExtreme().TextBox().ID("RegistrationNumber_AccomRegstr"))
                    </div>
                    <script>
                        var elem = document.getElementById("RegistrationNumber_AccomRegstr");
                        elem.onkeyup = function (e) {
                            if (e.keyCode == 13) {
                                GoAccomRegister();
                            }
                        }
                        function makeglobalNull_AccRgstr() {
                            if (eventid_AccomRgstr == undefined || eventid_AccomRgstr == "") { eventid_AccomRgstr = null }
                            if (buildingid_AccomRgstr == undefined || buildingid_AccomRgstr == "") { buildingid_AccomRgstr = null }
                            if (fromDate_fltr_AccomRgstr == undefined || fromDate_fltr_AccomRgstr == "") { fromDate_fltr_AccomRgstr = null }
                            if (toDate_fltr_AccomRgstr == undefined || toDate_fltr_AccomRgstr == "") { toDate_fltr_AccomRgstr = null }
                            if (fromtime_fltr_AccomRgstr == undefined || fromtime_fltr_AccomRgstr == "") { fromtime_fltr_AccomRgstr = null }
                            if (totime_fltr_AccomRgstr == undefined || totime_fltr_AccomRgstr == "") { totime_fltr_AccomRgstr = null }
                        }
                        function showAccommodationSummary_AccRgstr(e) {
                            readFilterParamValues()
                            //var focusIndex = AccommodationRegister_InfoGrid.GetFocusedRowIndex();
                            //if (focusIndex < 0) {
                            //    DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                            //    return;
                            //}
