            }
            else if (e.RowType == GridViewRowType.Data)
            {
                if (e.GetValue("REC_STATUS") != null && (Convert.ToInt32(e.GetValue("REC_STATUS")) == -1)) // REJECTED RESPONSE
                {
                    // e.Row.BackColor = System.Drawing.Color.Plum;
                    e.Row.BackColor = System.Drawing.Color.FromArgb(0, 233, 210, 224);
                }
                if (e.GetValue("REC_STATUS") != null && (Convert.ToInt32(e.GetValue("REC_STATUS")) == 2)) // APPROVED RESPONSE
                {
                    //e.Row.BackColor = System.Drawing.Color.DarkSeaGreen;
                    e.Row.BackColor = System.Drawing.Color.FromArgb(0, 238, 251, 233);
                }
                if ((int)e.GetValue("Beds") > 0)
