@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    SessionGUID = SessionGUID == "null" ? null : SessionGUID;
    var ShowHorizontalBar = (int)ViewBag.AccomRegstr_ShowHorizontalBar;
}

@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar)
.ID("AccommodationRegister_InfoGrid_dx")
.DataSource(d => d.Mvc().Controller("AccommodationRegister")
.LoadAction("AccommodationRegister_Info_Grid_Load")
//.LoadParams(new {Chart_Inst_ID = new JS("chart_inst_id_filter_AccomRgstr") })
//.LoadParams(new { Filter_By = new JS("Event Start And End Dates"), Chart_Inst_ID = new JS("chart_inst_id_filter_AccomRgstr") })
.OnBeforeSend("onBeforeSend")
.LoadMode(DataSourceLoadMode.Raw).Key("RESP_ID"))


.WordWrapEnabled(false)

.ColumnResizingMode(ColumnResizingMode.Widget)
.Selection(s => s.Mode(SelectionMode.Multiple)
.ShowCheckBoxesMode(GridSelectionShowCheckBoxesMode.Always)
.AllowSelectAll(true))




.OnInitialized("AccommodationRegister_InfoGrid_dx_OnInitialized")
.OnCellPrepared("AccommodationRegister_InfoGrid_dx_OnCellPrepared")
.OnRowPrepared("AccommodationRegister_InfoGrid_dx_OnRowPrepared")
.OnContentReady("AccommodationRegister_InfoGrid_dx_OnContentReady")
//.OnCellDblClick("AccommodationRegister_InfoGrid_dx_OnCellDblClick")
.OnSelectionChanged("AccommodationRegister_InfoGrid_dx_OnSelectionChanged")
////.OnFocusedRowChanged("BankListGrid_dx_OnFocusedRowChanged")
//.OnRowExpanding("AccommodationRegister_InfoGrid_dx_OnRowExpanding")
//.OnRowCollapsing("AccommodationRegister_InfoGrid_dx_OnRowCollapsing")
.OnContextMenuPreparing("AccommodationRegister_InfoGrid_dx_OnContextMenuPreparing")
//.OnOptionChanged("AccommodationRegister_InfoGrid_dx_OnOptionChanged")
.OnRowClick("AccommodationRegister_InfoGrid_dx_OnRowClick")
)