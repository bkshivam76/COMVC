                            .DisplayExpr(new JS("function (item){{return Look_AccommodationRooms_Multi_DisplayExpr(item)}}"))
                            .DataSource(d => d.Mvc().Controller("AccommodationRegister").LoadAction("LookUp_Get_AccomodationList").LoadMode(DataSourceLoadMode.Raw)
                            .Key("REC_ID").LoadParams(new { DDRefresh = new JS("function (){ return Look_Accommodation_DDrefresh;}"),
                                end_date = new JS("function() { return todate_str;}"),
                                fromdate = new JS("function() { return fromdate_str;}"),
                                fromtime = new JS("function() { return fromtime_str;}" ),
                                end_time = new JS("function() { return totime_str;}" ),
                                ChartResponseID = new JS("function() { return chartresponseid;}")
                            }))
                            .OnValueChanged("AccommodationMiscID_Multi_ValueChange").ShowClearButton(false)
                            .OnInitialized("OnInitialized_SelectDropdownValues_AccomMulti")
                            .ContentTemplate(@<text> @Render_DetailDG() </text>)
                        )
                    </div>
                </div>
            </div>
            <script>

                    var Look_Accommodation_DDrefresh, Look_AccommodationDetail_DDrefresh; var chartresponseid = "@Model.resp_ids";
                    var Look_AccommodationList_DataGrid = $("#LookUp_Get_AccommodationList_datagrid").dxDataGrid("instance");
                    function clearAccommodationDropdown() {
                        Look_AccommodationList_DataGrid = $("#LookUp_Get_AccommodationList_datagrid").dxDataGrid("instance");
                        Look_AccommodationList_DataGrid.clearSelection();
                        $("#AccommodationMiscID_Multi").dxDropDownBox("instance").reset();
                    }
                    function Look_AccommodationRooms_Multi_DisplayExpr(item) {

                        var displayExpr = "";
                        if (item != null)
                        {
                            //displayExpr = item.Building;
                            //if (item.CurrentAllottment != null && item.CurrentAllottment > 0) {
                                displayExpr = item.Building + " (" + item.Room + ")";
                            //}
                        }
                        return displayExpr;
                    }
            </script>

            <div class="row">
                <div class="col-sm-12 md-12 pll">
                    <div class="form-field">
                        <label class="control-label text-red" for="user">Remarks:</label>
                        @(Html.DevExtreme().TextArea().ID("Remarks_AccomRegstr").Name("Remarks_AccomRegstr").Value(Model.Remarks).ReadOnly(false).FocusStateEnabled(true))
                    </div>
                </div>
                <div class="col-sm-12 styleActionBtn">
                    @(Html.DevExtreme().Button().CustomSaveButton().Text("Update & Print").ID("Response_Accomodation_Add_Print").FocusStateEnabled(true)
                                .UseSubmitBehavior(false).OnClick("updateAndPrint"))
                    @(Html.DevExtreme().Button().CustomSaveButton().Text("Update").ID("Response_Accomodation_Add").FocusStateEnabled(true).UseSubmitBehavior(false).OnClick("update"))
                    @(Html.DevExtreme().Button().CustomCloseButton().Text("Cancel").ID("Response_Accomodation_Cancel").FocusStateEnabled(true).OnClick(@<Text> function () { CloseAddAccomodation();} </Text>))
                </div>
            </div>

        </form>
    </div><!--[Form Div]-->

    <script>
        var pageUpdatedorNot = false;

        function updateAndPrint() {
            updatewithprint = true;
            printFromButton = false;
            addResponseAccomodation('UpdateAndPrint')
        }
        function update() {
            addResponseAccomodation('Update');
        }
        $(document).ready(function () {
            pageUpdatedorNot = false;
            $("#LookUp_Get_AccommodationList_datagrid").dxDataGrid("instance").columnOption("command:select", "visible", false); //This code is to hide selection boxes in the datagrid.
        });

        $(function () {
            $("#Response_Accomodation_popup").dxPopup({
                onHiding: function (e) {
                    $.ajax({
                        type: 'GET',
                        url: "/Facility/Chart/SessionClearChartAccommodation",
                        cache: false
                    });
                }
            });
        });
        function CloseAddAccomodation(){
            HidePopup('Response_Accomodation_popup');
        }

        function addResponseAccomodation(updateOrWithPrint)
        {

            var countdata = 0; var totalAllottedBedCount = 0;
            //allUpdatedData();
            var gridInstance = $("#LookUp_Get_AccommodationList_datagrid").dxDataGrid("instance");
            //var originalgridData = gridInstance.getDataSource()._store.__rawData
            var originalgridData = gridInstance.getDataSource().store().__rawData
            var editData = gridInstance.getController('editing')._editData
            //if (editData.length <= 0 && pageUpdatedorNot == false) {
            //    DevExpress.ui.dialog.alert('You have not allotted any beds. Please allott.', "Alert");
            //    return;
            //}
            if (parseInt(document.getElementById("Allocating_Beds_p").innerHTML) > parseInt("@Model.TotalRegistrations")) {
                DevExpress.ui.dialog.alert('You have allotted the beds more than the required beds. Please recheck and correct the count.', "error");
                return;
            }
            for (i = 0; i < editData.length; i++) {
                totalAllottedBedCount = totalAllottedBedCount + parseInt(editData[i].data['CurrentAllottment'])
                editData[i].validationResults = [];
                editData[i].brokenRules = [];
            }

            //for(var i = 0; i < editData.length; i++) {
                //if (editData[i].type === 'update') {
            if (editData.length > 0) {
                var AccomodationMiscID = editData[0].key //$("#AccommodationMiscID_Multi").dxDropDownBox("instance").option("value"); //key of the editdata needs to be taken
                var Txt_BedCount = parseInt(editData[0].data['CurrentAllottment']) //$("#BedCount_AccomRegMlt").dxNumberBox("instance").option("value"); //needs to be taken edited data from the editData variable.
            } else {
                AccomodationMiscID = "";
            }
            var Txt_Remarks = $("#Remarks_AccomRegstr").dxTextArea("instance").option("value");
            var _fromdate = $("#fromdate_AccomRegstr").dxDateBox("instance").option("value");
            var _todate = $("#todate_AccomRegstr").dxDateBox("instance").option("value");
            var _fromtime = $("#fromtime_AccomRegstr").dxDateBox("instance").option("value");
            var _totime = $("#totime_AccomRegstr").dxDateBox("instance").option("value");
            if (_fromdate > _todate) {
                DevExpress.ui.dialog.alert('From Date should not be greater than to date.', "error");
                return;
            }
            ShowLoader();

            $.ajax({
                type: 'Post',
                url: "/Facility/AccommodationRegister/UpdateChartResponseAccomodation",
                cache: false,
                data: {
                    ChartResponseID: "@Model.resp_ids",
                    Accommodation: AccomodationMiscID,
                    BedCount: "@Model.bedcounts",
                    remarksText: Txt_Remarks,
                    fromdate: _fromdate == null ? null : JS_Json_Date_To_ddMMyyyy(_fromdate),
                    todate: _todate == null ? null : JS_Json_Date_To_ddMMyyyy(_todate),
                    fromtime: _fromtime == null ? null : JS_Json_Date_To_ddMMyyyy(_fromtime),
                    totime: _totime == null ? null : JS_Json_Date_To_ddMMyyyy(_totime),
                    editedData: JSON.stringify(editData),
                    gridToRefresh: "@gridToRefresh",
                    Registrations: "@Model.registrations",
                    Reg_Names: "@Model.namesOfRegisteredPersons",
                    originalData: JSON.stringify(originalgridData),
                    performAction: updateOrWithPrint
                },
                success: function (data)
                {
                    debugger;
                    HideLoader();
                    if (typeof data.jsonParam === "undefined")
                    {
                        if (data.length > 0)
                        {
                            HidePopup('Response_Accomodation_popup');
                            GoAccomRegister()
                            if ("@Model.resp_ids".length > 36)
                            {
                                OpenPopup("PrintSlipPopup_AccomRegstr", "Print Slip Options", null, "auto", 360, true, data, "maxheightPrintSlip");
                            }
                            else
                            {
                                OpenPopup("PrintSlipPopup_AccomRegstr", "PrintSlip(s)", null, "auto", 380, true, data, "maxheightPrintSlip");
                            }
                        }
                    }
                    else if (data.jsonParam.result) {
                        HideLoader();
                        HidePopup('Response_Accomodation_popup');
                        if (data.jsonParam.message == "Accomodation Has Been Allotted/Updated Successfully" && updateOrWithPrint == "UpdateAndPrint") {
                            GoAccomRegister()

                        }
                        else {
                            var alertClick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                            alertClick.done(function (alertResult) {
                                if (alertResult) {
                                    if (data.jsonParam.flag == 'AccommodationRegister_InfoGrid') {
                                        GoAccomRegister()
                                        AccommodationRegister_InfoGrid.UnselectRows();
                                    }
                                    else if (data.jsonParam.flag.toLocaleLowerCase().includes("dx"))
                                    {
                                        var GridInstance = $('#' + data.jsonParam.flag.trim()).data("dxDataGrid")//BK SOUMY
                                        if (GridInstance !== void 0) {

                                            window[data.jsonParam.flag + "_Refresh"]();
                                        }
                                    }

                                    else {
                                        ASPxClientControl.GetControlCollection().GetByName(data.jsonParam.flag).Refresh();
                                    }
                                }
                            });
                        }




                    }
                    else if (data.jsonParam.result == false) {
                        HideLoader();
                        if (data.jsonParam.flag != undefined && data.jsonParam.flag == "refeshDropdown") {
                            //var AccomodationDDinstance = $("#AccommodationMiscID_Multi").dxDropDownBox("instance");
                            //$("#LookUp_Get_AccommodationList_datagrid").dxDataGrid("instance").cancelEditData();
                            $("#LookUp_Get_AccommodationList_datagrid").dxDataGrid("instance").refresh();
                        }
                        DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                    }
                }
            });
        }
    </script>

</div>