        function validate_RoomCapacity(e) {
            return e.value<=(e.data["Allowed"]-e.data["Allotted"]);
        }
        function LookUp_Get_AccommodationList_datagrid_SetCellValue(newData, value, rowData) {
            newData.CurrentAllottment = value;            
            var gridInstance = $("#LookUp_Get_AccommodationList_datagrid").dxDataGrid("instance");
            if (value > 0) {
                gridInstance.selectRows(rowData.REC_ID, true);
            }
            else
            {
                gridInstance.deselectRows(rowData.REC_ID);
            }
            //return e;
        }
        async function AccommodationMiscID_Multi_ValueChange(e, FirstCall = false)
        {
            var value;
            var DG = $("#LookUp_Get_AccommodationList_datagrid").dxDataGrid("instance");
            if (e) {
                value = e.value;
                if ((e.value == null || e.value.length == 0) && e.previousValue != null) {
                    DG.clearSelection();                   
                    return;
                }
            }
            else
            {
                value = $("#AccommodationMiscID_Multi").dxDropDownBox("option", "value");
            }
            await DG.selectRows(value);           
        }
        function OnInitialized_SelectDropdownValues_AccomMulti(e)
        {
            var value = [];
            var ds = e.component.option("dataSource");
            ds.store.load().done(function (original_Data)
            {
                for (var originalDataIndex = 0; originalDataIndex < original_Data.length; originalDataIndex++)
                {
                    if (original_Data[originalDataIndex].CurrentAllottment > 0)
                    {
                        value.push(original_Data[originalDataIndex].REC_ID);                       
                    }
                }
                if (value != null && value.length > 0) {
                    e.component.option("value", value);
                }
                
            });
       
        }
               
        function calculatedAvailableBeds(rowData) {
            //var AccomodationDDinstance = $("#AccommodationMiscID_Multi").dxDropDownBox("instance");            
            var returnedCount = rowData.Allowed - (rowData.Allotted + rowData.CurrentAllottment);
            var allocatingbedsCount = parseInt(document.getElementById("Allocating_Beds_p").innerHTML);
            var requirementBedsCount = parseInt(document.getElementById("required_Beds_p").innerHTML);
            allocatingbedsCount = 0;
            var gridInstance = $("#LookUp_Get_AccommodationList_datagrid").dxDataGrid("instance");
            //gridInstance.clearSelection();
            var editData = gridInstance.getController('editing')._editData
            //var original_Data = gridInstance.getDataSource();
            var original_Data = gridInstance.getDataSource().store().__rawData;
            for (var originalDataIndex = 0; originalDataIndex < original_Data.length; originalDataIndex++) {
                var allottmentvalueInLoop = undefined;
                for (var updatedDataIndex = 0; updatedDataIndex < editData.length; updatedDataIndex++) {
                    if (editData[updatedDataIndex].key == original_Data[originalDataIndex].REC_ID && editData[updatedDataIndex].type == 'update') {
                        allottmentvalueInLoop = editData[updatedDataIndex].data.CurrentAllottment
                        if (allottmentvalueInLoop > 0) {
                            //gridInstance.selectRows(original_Data._store.__rawData[originalDataIndex].REC_ID, true);
                        }                        
                    }
                }
                if (allottmentvalueInLoop == undefined) {
                    allocatingbedsCount = allocatingbedsCount + original_Data[originalDataIndex].CurrentAllottment
                    if (original_Data[originalDataIndex].CurrentAllottment > 0) {
                        //gridInstance.selectRows(original_Data._store.__rawData[originalDataIndex].REC_ID, true);
                    }
                }
                else {
                    allocatingbedsCount = allocatingbedsCount + allottmentvalueInLoop
                }
            }
            
            document.getElementById("Allocating_Beds_p").innerHTML = allocatingbedsCount;
            return returnedCount;
        }
        
        function allUpdatedData() {
            //
            var gridInstance = $("#LookUp_Get_AccommodationList_datagrid").dxDataGrid("instance");
            var editData = gridInstance.getController('editing')._editData,
                rowCount = 0;
            for (var i = 0; i < editData.length; i++) {
                if (editData[i].type === 'update') {
                    rowCount++;
                }
            }
        }
        function expandDetailedGrid() {
            var mainDDGrid = $("#LookUp_Get_AccommodationList_datagrid").dxDataGrid("instance");
            mainDDGrid.expandAll(-1);
        }
    </script>
