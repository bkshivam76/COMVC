    @helper Render_DetailDG()
    {
        @(Html.DevExtreme().DataGrid().CustomDataGrid()
            .ID("LookUp_Get_AccommodationList_datagrid")
            .Paging(paging => paging.Enabled(false))
            .Editing(editing =>
            {
                editing.Mode(GridEditMode.Batch);
                editing.AllowUpdating(true);
                editing.AllowAdding(false);
                editing.AllowDeleting(false);
                editing.SelectTextOnEditStart(true);
                editing.StartEditAction(GridStartEditAction.Click);
            })
            .Columns(columns =>
            {
                columns.Add().DataField("REC_ID").Caption("REC_ID").Visible(false).AllowEditing(false);
                columns.Add().DataField("Building").Caption("Building").AllowEditing(false);
                columns.Add().DataField("Room").Caption("Room").AllowEditing(false);
                columns.Add().DataField("Allowed").Caption("Capacity").AllowEditing(false).Alignment(HorizontalAlignment.Center).Width(67);
                columns.Add().DataField("Allotted").Caption("Already Allotted").Visible(true).AllowEditing(false).Width(65).Alignment(HorizontalAlignment.Center);
                columns.Add().DataField("CurrentAllottment").Caption("Current Allottment").Visible(true).AllowEditing(true).SetCellValue("LookUp_Get_AccommodationList_datagrid_SetCellValue")
                .Width(80).Alignment(HorizontalAlignment.Center)
                    .ValidationRules(x =>
                    {
                        x.AddCustom().IgnoreEmptyValue(true).Message("Room Capacity Exceeded").Reevaluate(true).ValidationCallback("function(e){{ return validate_RoomCapacity(e);}}");
                    });
                columns.Add().Visible(true).AllowEditing(false).Caption("Available").CalculateCellValue("calculatedAvailableBeds").Width(70).Alignment(HorizontalAlignment.Center);
            }).Selection(s => s.Mode(SelectionMode.Multiple).AllowSelectAll(false).ShowCheckBoxesMode(GridSelectionShowCheckBoxesMode.Always))
             .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys);};}")
             .OnRowClick("Accomodation_DG_RowClick").OnRowDblClick("LookUp_Get_AccommodationList_datagrid_onCellDblclick")//.OnRowPrepared("LookUp_Get_AccommodationList_datagrid_OnRowPrepared")
             //.SelectedRowKeys(string.IsNullOrWhiteSpace(Model.AccommodationMiscID_Multi) ? null:Model.AccommodationMiscID_Multi.spilt(','))
                    .MasterDetail(md =>
                     {
                     md.Enabled(true);
                     md.AutoExpandAll(false);
                     md.Template(@<text><div class="master-detail-caption">
                                            @(Html.DevExtreme().DataGrid()//.ID("LookUp_Get_AccommodationDetailList_datagrid")
                                                .ColumnAutoWidth(true)
                                                .ShowBorders(true)
                                                .Columns(columns =>
                                                {
                                                    columns.Add().DataField("CNAME").Caption("Name").Visible(true);
                                                    columns.Add().DataField("GENDER").Caption("Gender");
                                                    //columns.Add().DataField("CITY").Caption("City");
                                                    //columns.Add().DataField("CenterName");
                                                    //columns.Add().DataField("Arr_Date").DataType(GridColumnDataType.Date).Format("dd/MM/yyyy hh:mm").Visible(true);
                                                    columns.Add().DataField("Dep_Date").DataType(GridColumnDataType.Date).Format("dd/MM/yyyy hh:mm").Visible(true);
                                                    columns.Add().DataField("Dep_Time").DataType(GridColumnDataType.DateTime).Format("hh:mm").Visible(true);
                                                    columns.Add().DataField("ROOMID").Visible(false);
                                                }).ElementAttr("data-masterid", new JS("data.REC_ID"))
                                                .DataSource(d => d.Mvc().Controller("Chart").LoadAction("LookUp_Get_AccomodationDetailsList").LoadMode(DataSourceLoadMode.Raw)
                                                .LoadParams(
                                                    new
                                                    {
                                                        DDRefresh = new JS("function (){ return Look_Accommodation_DDrefresh;}"),
                                                        end_date = new JS("function() { return todate_str;}"),
                                                        fromdate = new JS("function() { return fromdate_str;}"),
                                                        fromtime = new JS("function() { return fromtime_str;}"),
                                                        end_time = new JS("function() { return totime_str;}"),
                                                        roomid = new JS("data.REC_ID")
                                                    }).LoadMode(DataSourceLoadMode.Raw)
                                                )
                                            )
                                    </div>
                                </text>);
                    })               
