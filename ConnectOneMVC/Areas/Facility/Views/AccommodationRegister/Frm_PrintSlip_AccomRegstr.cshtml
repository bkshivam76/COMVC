    function printPrintSlip_AccomRegstr()
    {
        var printWindow = window.open('', '', 'height=800,width=700');
        if (printWindow)
        {
            printWindow.document.open();
            printWindow.document.write('<html><head><title>Accommodation Slip</title>');
            printWindow.document.write('<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@3.4.1/dist/css/bootstrap.min.css" integrity="sha384-HSMxcRTRxnN+Bdg0JdbxYKrThecOKuH5zCYotlSAcp1+c8xmyTe9GYg1l9a69psu" crossorigin="anonymous">');
            printWindow.document.write('</head><body>');
            printWindow.document.write($("#print_Area_AccomRegstr").html());
            printWindow.document.write('</body></html>');
            printWindow.document.close();
            $("#PrintSlipPopup_AccomRegstr").dxPopup("hide");
            printFromButton = false;
            WaitForCssLinkToLoad(printWindow);
        }
    }
    function WaitForCssLinkToLoad(printWindow)
    {
        var CssLoaded = false;
        if (printWindow)
        {
            if (printWindow.document)
            {
                var RowElement = printWindow.document.getElementsByClassName('row');
                if (RowElement != null && RowElement.length > 0)
                {
                    var style = printWindow.getComputedStyle(RowElement[0])
                    if (style.marginLeft == "-15px")
                    {
                        CssLoaded = true;
                        // setTimeout(function ()
                        //{

                        printWindow.print();
                        printWindow.close();
                        //}, 150);
                    }
                }
            }
        }
        if (CssLoaded == false)
        {
            setTimeout(function ()
            {
                WaitForCssLinkToLoad(printWindow);
            }, 100)
        }
    }

    function closePrintSlip_AccomRegstr()
    {
        $("#PrintSlipPopup_AccomRegstr").dxPopup("hide");
    }
    $(document).ready(function ()
    {
        $("#PrintSlipPopup_AccomRegstr").dxPopup({
            onHiding: function (e)
            {
                
                if ("@Model.PrintFromscreen" == "AccommodationRegister") {
                    var GridInstance = $('#AccommodationRegister_InfoGrid_dx').data("dxDataGrid")//BK SOUMY
                    if (GridInstance !== void 0) {
                        var grid_Instance = $("#AccommodationRegister_InfoGrid_dx").dxDataGrid("instance");
                        grid_Instance.clearSelection();
                    }
                    //GridViewDoCallback(AccommodationRegister_InfoGrid, function () { AccommodationRegister_InfoGrid.UnselectRows() });
                    /*AccommodationRegister_InfoGrid.UnselectRows();*/
                }
            }
        });
        if (!printFromButton)
        {
            if (parseInt("@Model.dt_SelectedSlipsData.Rows.Count") > 1 && "@Model.printOption" == "Individual")
            {
                $("#btn_printSlip_AccomRegstr").trigger("dxclick")
                //printPrintSlip_AccomRegstr();
            }
            else
            {
                $("#btn_printSlip_AccomRegstr").trigger("dxclick")
                //printPrintSlip_AccomRegstr();
            }
        }
    });
</script>