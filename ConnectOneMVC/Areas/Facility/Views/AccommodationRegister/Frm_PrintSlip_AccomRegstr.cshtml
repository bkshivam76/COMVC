                    </div>
                    @{
                        var bedsCount = 0;
                        for (var j = 0; j < Model.dt_SelectedSlipsData.Rows.Count; j++)
                        {
                            if (Convert.IsDBNull(Model.dt_SelectedSlipsData.Rows[j]["Beds"]) == false)
                            {
                                bedsCount = bedsCount + Convert.ToInt32(Model.dt_SelectedSlipsData.Rows[j]["Beds"]);
                            }
                        }
                    }
