                            @*<div class="col-xs-1">:</div>*@
                            <div class="col-xs-9"> : @Model.dt_SelectedSlipsData.Rows[i]["Beds"] </div>
                        </div>
                        <div class="row" style="font-size:14.5px">
                            <div class="col-xs-3">Building</div>
                            @*<div class="col-xs-1">:</div>*@
                            <div class="col-xs-9"> : @Html.Raw(Model.dt_SelectedSlipsData.Rows[i]["Building"].ToString().Replace(",", "<br>&nbsp;")) </div>
                        </div>
                        <div class="row" style="font-size:14.5px">
                            <div class="col-xs-3">Room No.</div>
                            @*<div class="col-xs-1">:</div>*@
                            <div class="col-xs-9"> : @Html.Raw(Model.dt_SelectedSlipsData.Rows[i]["RoomAndCount"].ToString().Replace(",", "<br>&nbsp;")) </div>
                        </div>
                        <div class="row" style="margin-bottom:8px;">
                            <div class="col-xs-3" style="letter-spacing: -.5px ">Slip Issued By</div>
                            @*<div class="col-xs-1">:</div>*@
                            <div class="col-xs-9"> : @Model.dt_SelectedSlipsData.Rows[i]["Slip_By"] </div>
                        </div>
                        <div class="row text-center">
                            <div class="col-xs-12" style="font-family: 'Parisienne', cursive; font-size: x-large; font-style: italic;">Om Shanti</div>

                        </div>
                        <div class="row" style="margin-bottom: 12px;">
                            <div class="col-xs-8"></div>
                            <div class="col-xs-8"></div>
                        </div>
                    </div>
                    <hr />
                }
            }
            else if (Model.printOption == "Group")
            {
                <div class="acc-slip">
                    <div class="text-center">
                        <p class="text-right" style="font-size: x-small;">@DateTime.Now.ToString("dd-MM-yyyy hh:mm")</p>
                        <img class="imgcut" src="~/Content/Image/bk_icon.jpg" />
                        <h2>@Model.centerName</h2>
                        <h3>Accommodation Slip</h3>
                    </div>
