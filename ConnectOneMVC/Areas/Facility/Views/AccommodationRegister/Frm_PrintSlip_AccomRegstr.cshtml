                    <div class="col-xs-9"> : @Html.Raw(Model.dt_SelectedSlipsData.Rows[0]["RoomAndCount"].ToString().Replace(",", "<br>&nbsp;")) </div>
                </div>
                <div class="row" style="margin-bottom: 8px;">
