                    @*<div class="col-xs-1">:</div>*@
                    <div class="col-xs-9"> : @Model.dt_SelectedSlipsData.Rows[0]["Beds"] </div>
                </div>
                <div class="row" style="font-size:14.5px">
                    <div class="col-xs-3">Building</div>
                    @*<div class="col-xs-1">:</div>*@
                    <div class="col-xs-9"> : @Html.Raw(Model.dt_SelectedSlipsData.Rows[0]["Building"].ToString().Replace(",", "<br>&nbsp;")) </div>
                </div>
                <div class="row" style="font-size:14.5px">
                    <div class="col-xs-3">Room No.</div>
