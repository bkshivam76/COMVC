@using DevExtreme.AspNet.Mvc;
@using System.Data;

@model ConnectOneMVC.Areas.Facility.Models.printparams
@{
    //var t = ViewBag.respids;
    var arrivaldate = "";
    var departuredate = "";
    var countforloop = 0;
}
<div id="printarea_AccomRegstr">
    <div class="text-right">
        @Html.DevExtreme().Button().OnClick("printPrintSlip_AccomRegstr").Text("Print (Alt+p)").ID("btn_printSlip_AccomRegstr")
        @Html.DevExtreme().Button().OnClick("closePrintSlip_AccomRegstr").Text("Close")
    </div>
    <div id="print_Area_AccomRegstr">
        <style>
            @@import url('https://fonts.googleapis.com/css2?family=Great+Vibes&family=Parisienne&display=swap');

            .acc-slip {
                max-width: 360px;
                width: 90%;
                margin: 0 auto;
                font-weight: bold;
                font-size: 11px;
                line-height: 20px;
            }

                .acc-slip .imgcut {
                    width: 40px;
                    height: 40px;
                    object-fit: cover;
                    object-position: left;
                    margin-top: 0px;
                }

                .acc-slip h2 {
                    font-size: 13px;
                    margin-top: 10px;
                    margin-bottom: 5px;
                    font-weight: bold;
                }

                .acc-slip h3 {
                    font-size: 13px;
                    font-weight: bold;
                    margin-top: 0;
                    margin-bottom: 4px
                }

            .mrB15 {
                margin-bottom: 2px;
                font-size: 11px;
            }

            .acc-slip .col-xs-1 {
                text-align: center;
                padding: 0
            }

            .acc-slip .col-xs-3 {
                padding-right: 0;
            }

            .acc-slip .col-xs-8 {
                padding-left: 5px
            }
        </style>
        @if (Model.dt_SelectedSlipsData.Rows.Count == 1)
        {
            <div class="acc-slip">
                <div class="text-center">
                    <p class="text-right" style="font-size: x-small;margin-bottom:-8px;">@DateTime.Now.ToString("dd-MM-yyyy hh:mm")</p>
                    @{
                        if (Model.dt_SelectedSlipsData.Rows[0]["Accom From"].ToString() != "")
                        {
                            arrivaldate = Model.dt_SelectedSlipsData.Rows[0]["Accom From"] != null ? Convert.ToDateTime(Model.dt_SelectedSlipsData.Rows[0]["Accom From"]).ToString("dd-MM-yyyy hh:mm t") : "";
                        }
                        if (Model.dt_SelectedSlipsData.Rows[0]["Accom To"].ToString() != "")
                        {
                            departuredate = Model.dt_SelectedSlipsData.Rows[0]["Accom To"] != null ? Convert.ToDateTime(Model.dt_SelectedSlipsData.Rows[0]["Accom To"]).ToString("dd-MM-yyyy hh:mm t") : "";
                        }
                    }
                    <img class="imgcut" src="~/Content/Image/bk_icon.jpg" />
                    <h2>@Model.centerName</h2>
                    <h3>Accommodation Slip</h3>
                </div>
                <div class="row mrB15">
                    <div class="col-xs-3"><u>Reg. No.:-</u></div>
                    @*<div class="col-xs-1">:</div>*@
                    <div class="col-xs-9"> : @Model.dt_SelectedSlipsData.Rows[0]["RegNo"] </div>
                </div>
                <div class="row mrB15">
                    <div class="col-xs-3"><u>Event</u> </div>
                    @*<div class="col-xs-1">:</div>*@
                    <div class="col-xs-9"> : <u>@Model.dt_SelectedSlipsData.Rows[0]["Event"]</u></div>
                </div>
                <div class="row">
                    <div class="col-xs-3">Name</div>
                    @*<div class="col-xs-1">:</div>*@
                    <div class="col-xs-9"> : @Model.dt_SelectedSlipsData.Rows[0]["Name"] </div>
                </div>
                <div class="row">
                    <div class="col-xs-3">Gender</div>
                    @*<div class="col-xs-1">:</div>*@
                    <div class="col-xs-9"> : @Model.dt_SelectedSlipsData.Rows[0]["Gender"] </div>
                </div>
