                                {
                                    if (RoomsList != "")
                                    {
                                        RoomsList = RoomsList + "," + item.col1;
                                    }
                                }
                            }
                            countforloop = countforloop + 1;
                        }
                        var b = RoomsList.Split(',').Distinct().ToArray();
                        Array.Sort(b);
                        var RoomsCountList = "";
                        var countforloop2 = 0;
                        foreach (dynamic item in UniqueRoomandCountssObj)
                        {
                            if (item.col1.GetType().Name != "DBNull")
                            {
                                if (countforloop2 == 0 || RoomsList == "")
                                {
                                    RoomsCountList = item.col1;
                                }
                                else
                                {
                                    if (RoomsCountList != "")
                                    {
                                        RoomsCountList = RoomsCountList + "," + item.col1;
                                    }
                                }
                            }
                            countforloop2 = countforloop2 + 1;
                        }
                        var c = RoomsCountList.Split(',').ToArray();


                        for (int i = 0; i < b.Length; i++)
                        {
                            int total = 0;
                            for (int lenth = 0; lenth < c.Length; lenth++)
                            {
                                if (c[lenth] != "" && c[lenth] != null)
                                {
                                    if (c[lenth].Contains(b[i].ToString()))
                                    {
                                        var word = c[lenth].ToString().Replace(b[i] + "(", "");
                                        total = total + Convert.ToInt32(word.Replace(")", ""));
                                    }
                                }
                            }
                            if (total != 0) { b[i] = b[i] + "(" + total + ")"; }
                        }

                        RoomsList = String.Join(",", b);
                    }
                    <div class="row" style="font-size:14.5px">
                        <div class="col-xs-3">Room No.</div>
                        @*<div class="col-xs-1">:</div>*@
                        <div class="col-xs-9"> : <span style="white-space: pre-line">@Html.Raw(RoomsList.ToString().Replace(",", "<br>&nbsp;")) </span></div>
                    </div>

                    <div class="row" style="margin-bottom: 8px;">
                        <div class="col-xs-3" style="letter-spacing: -.5px ">Slip Issued By</div>
                        @*<div class="col-xs-1">:</div>*@
                        <div class="col-xs-9"> : @Model.dt_SelectedSlipsData.Rows[0]["Slip_By"] </div>
                    </div>
                    <div class="row text-center">
                        <div class="col-xs-12" style="font-family: 'Parisienne', cursive; font-size: x-large; font-style: italic;">Om Shanti</div>

                    </div>
                    <div class="row">
                        <div class="col-xs-8"></div>
                        <div class="col-xs-8"></div>
                    </div>
                </div>
            }
        }
    </div>
</div>
<script>
