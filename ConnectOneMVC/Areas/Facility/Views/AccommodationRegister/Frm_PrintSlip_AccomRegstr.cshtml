                                                       select l.Field<string>("City");

                            //var city_GroupSlipOption = Model.dt_SelectedSlipsData.AsEnumerable().Where(r => r.Field<string>("RESP_ID") == Model.selectedRespID).Select(row => row.Field<string>("City").ToString());


