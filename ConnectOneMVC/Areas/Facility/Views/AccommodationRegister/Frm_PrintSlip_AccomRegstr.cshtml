                        foreach (dynamic item in UniqueDepartureObj)
                        {
                            if (item.col1.GetType().Name != "DBNull")
                            {
                                if (countforloop == 0 || depdate == "") { depdate = Convert.ToString(item.col1); }
                                else
                                {
                                    if (!String.IsNullOrWhiteSpace(depdate)) { if (Convert.ToDateTime(depdate) < Convert.ToDateTime(item.col1)) { depdate = Convert.ToString(item.col1); } }
                                }
                            }
                            countforloop = countforloop + 1;
                        }
                        if (!String.IsNullOrWhiteSpace(depdate))
                        { departuredate = Convert.ToDateTime(depdate).ToString("dd-MM-yyyy hh:mm t"); }
