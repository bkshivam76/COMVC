                    <div class="col-xs-9"> : @Model.dt_SelectedSlipsData.Rows[0]["Slip_By"] </div>
                </div>
                <div class="row text-center">
                    <div class="col-xs-12" style="font-family: 'Parisienne', cursive; font-size: x-large; font-style: italic;">Om Shanti</div>

                </div>
                <div class="row">
                    <div class="col-xs-8"></div>
                    <div class="col-xs-8"></div>
                </div>

            </div>
        }
