                        @*<div class="col-xs-1">:</div>*@
                        <div class="col-xs-9"> : @bedsCount </div>
                    </div>
                    @{
                        var UniqueBldgsObj = (from DataRow dRow in Model.dt_SelectedSlipsData.Rows
                                              select new { col1 = dRow["Building"] }).Distinct();
                        var BldgsList = "";
                        countforloop = 0;
                        foreach (dynamic item in UniqueBldgsObj)
                        {
                            if (item.col1.GetType().Name != "DBNull")
                            {
                                if (countforloop == 0 || BldgsList == "")
                                {
                                    BldgsList = item.col1;
                                }
                                else
                                {
                                    if (BldgsList != "")
                                    {
                                        BldgsList = BldgsList + "," + item.col1;
                                    }
                                }
                            }
                            countforloop = countforloop + 1;
                        }
                        var blds = BldgsList.Split(',').Distinct().ToArray();
                        BldgsList = String.Join(",", blds);
                    }
                    <div class="row" style="font-size:14.5px">
                        <div class="col-xs-3">Building</div>
                        @*<div class="col-xs-1">:</div>*@
                        <div class="col-xs-9"> : <span style="white-space: pre-line">@Html.Raw(BldgsList.ToString().Replace(",", "<br>&nbsp;"))</span></div>
                    </div>
