                    @{
                        var UniqueArrivalObj = (from DataRow dRow in Model.dt_SelectedSlipsData.Rows
                                                select new { col1 = dRow["Accom From"] }).Distinct();
                        //DateTime minimumDate = Model.dt_SelectedSlipsData.Rows.OfType<DataRow>().Where(k => k["Accom From"] != DBNull.Value).Select(k => Convert.ToDateTime(k["Accom From"])).Min();
                        countforloop = 0;
                        var arrdate = "";
                        foreach (dynamic item in UniqueArrivalObj)
                        {
                            if (item.col1.GetType().Name != "DBNull")
                            {
                                if (countforloop == 0 || arrdate == "") { arrdate = Convert.ToString(item.col1); }
                                else
                                {
                                    if (!String.IsNullOrWhiteSpace(arrdate)) { if (Convert.ToDateTime(arrdate) > Convert.ToDateTime(item.col1)) { arrdate = Convert.ToString(item.col1); } }
                                }
                            }
                            countforloop = countforloop + 1;
                        }
                        if (!String.IsNullOrWhiteSpace(arrdate)) { arrivaldate = Convert.ToDateTime(arrdate).ToString("dd-MM-yyyy hh:mm t"); }
                    }
                    <div class="row">
                        <div class="col-xs-3">Arrival</div>
                        @*<div class="col-xs-1">:</div>*@
                        <div class="col-xs-9"> : @arrivaldate </div>
                    </div>
                    @{
