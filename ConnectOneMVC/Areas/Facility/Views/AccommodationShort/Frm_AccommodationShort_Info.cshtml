        <script>
            function onInitialized_users_datagrid_AccomShort(e) {
                //debugger;
                if (e.component.shouldSkipNextReady) {
                    e.component.shouldSkipNextReady = false;
                }
                else {
                    e.component.shouldSkipNextReady = true;
                    e.component.columnOption("command:select", "width", 30);
                    e.component.updateDimensions();
                }
                e.component.columnOption("Gender", "width", 60);
            }
            function onSelectionChanged_users_datagrid_AccomShort(data) {
                //debugger;
                //dataGrid.option('selection.showCheckBoxesMode', data.value);
                var dataGrid = $("#users_datagrid_AccomShort").dxDataGrid("instance");
                var selectedRowsData = dataGrid.getSelectedRowsData();
                var arrdts = []; var depdts = []
                if (selectedRowsData.length == 0) {
                    document.getElementById("PersonNames_AccomShort").innerHTML = "";
                    document.getElementById("bedsReq_AccomShort").innerHTML = "";
                    $("#totime_AccomShort").dxDateBox("instance").reset();
                    $("#todate_AccomShort").dxDateBox("instance").reset();
                    $("#fromtime_AccomShort").dxDateBox("instance").reset();
                    $("#fromdate_AccomShort").dxDateBox("instance").reset();
                }
                else {//Here we are filling the minimum arrival date and maximum departure date of all the selection data and also filling the names in brackets gender
                    //in the yellow area on top  of this grid. and also filling the selected data into respids, registrationNumbers, names global variables 
                    //which will be used in saving the accommodation.
                    result_respids = "";
                    result_regNumbs = "";
                    result_names = "";
                    document.getElementById("bedsReq_AccomShort").innerHTML = selectedRowsData.length;
                    for (var i = 0; i < selectedRowsData.length; i++) {
                        arrdts.push([0]);
                        depdts.push([0]);
                        arrdts[i] = selectedRowsData[i][2]
                        depdts[i] = selectedRowsData[i][3]

                        // Convert date strings to Moment objects
                        var arrivalDates = arrdts.map(function (dateString) {
                            return moment(dateString, 'DD-MM-YYYY HH:mm:ss');
                        });
                        var departureDates = depdts.map(function (dateString) {
                            return moment(dateString, 'DD-MM-YYYY HH:mm:ss');
                        });
                        // Find the minimum date
                        var minDate = moment.min(arrivalDates);
                        var maxDate = moment.max(departureDates);
                        $("#fromdate_AccomShort").dxDateBox("instance").option("value", moment(minDate, "DD/MM/YYYY"))
                        $("#fromtime_AccomShort").dxDateBox("instance").option("value", moment(minDate, "DD/MM/YYYY hh:mm:ss"))
                        $("#todate_AccomShort").dxDateBox("instance").option("value", moment(maxDate, "DD/MM/YYYY"))
                        $("#totime_AccomShort").dxDateBox("instance").option("value", moment(maxDate, "DD/MM/YYYY hh:mm:ss"))

                        if (i == 0) {
                            document.getElementById("PersonNames_AccomShort").innerHTML = selectedRowsData[i][7]
                            result_respids = selectedRowsData[i][6]
                            result_regNumbs = selectedRowsData[i][5]
                            result_names = selectedRowsData[i][0]
                        }
                        else {
                            document.getElementById("PersonNames_AccomShort").innerHTML = document.getElementById("PersonNames_AccomShort").innerHTML
                                + "," + selectedRowsData[i][7]
                            result_respids = result_respids + "|" + selectedRowsData[i][6]
                            result_regNumbs = result_regNumbs + "|" + selectedRowsData[i][5]
                            result_names = result_names + "|" + selectedRowsData[i][0]
                        }
                    }
                }
            }
            function hideUnhideNamesGrid() {
                if (document.getElementById("hideUnhideNamesGrid_btn_AccomShort").innerText == "+") {
                    document.getElementById("namesGrid_AccomShort").style.display = "block";
                    document.getElementById("hideUnhideNamesGrid_btn_AccomShort").innerText = "-";
                }
                else {
                    document.getElementById("namesGrid_AccomShort").style.display = "none";
                    document.getElementById("hideUnhideNamesGrid_btn_AccomShort").innerText = "+";
                }
            }
        </script>
        <div style="padding:0 0 10px 0;">
