        function saveAccommodation(updateOrWithPrint) {
            var Txt_Remarks = $("#Remarks_AccomShort").dxTextArea("instance").option("value");
            var _fromdate = $("#fromdate_AccomShort").dxDateBox("instance").option("value");
            var _todate = $("#todate_AccomShort").dxDateBox("instance").option("value");
            var _fromtime = $("#fromtime_AccomShort").dxDateBox("instance").option("value");
            var _totime = $("#totime_AccomShort").dxDateBox("instance").option("value");
            if (_fromdate == null || _fromdate == '') {
                DevExpress.ui.dialog.alert('From Date should not be null.', "error");
                return;
            }
            if (_todate == null || _todate == '') {
                DevExpress.ui.dialog.alert('To Date should not be null.', "error");
                return;
            }
            if (_fromtime == null || _fromtime == '') {
                DevExpress.ui.dialog.alert('From time should not be null.', "error");
                return;
            }
            if (_totime == null || _totime == '') {
                DevExpress.ui.dialog.alert('To time should not be null.', "error");
                return;
            }
            if (_fromdate > _todate) {
                DevExpress.ui.dialog.alert('From Date should not be greater than to date.', "error");
                return;
            }
            var gridInstance = $("#RoomNumbersList_AccomShort_datagrid").dxDataGrid("instance");
            var selectedRoomsData = gridInstance.getSelectedRowsData();
            var editData = gridInstance.getController('editing')._editData;
            ShowLoader();

            $.ajax({
                type: 'Post',
                url: "/Facility/AccommodationShort/updateAccomShort",
                cache: false,
                data: {
                    ChartResponseID: result_respids,
                    remarksText: Txt_Remarks,
                    fromdate: _fromdate == null ? null : JS_Json_Date_To_ddMMyyyy(_fromdate),
                    todate: _todate == null ? null : JS_Json_Date_To_ddMMyyyy(_todate),
                    fromtime: _fromtime == null ? null : JS_Json_Date_To_ddMMyyyy(_fromtime),
                    totime: _totime == null ? null : JS_Json_Date_To_ddMMyyyy(_totime),
                    selectedRoomsData: JSON.stringify(selectedRoomsData),
                    editedData: JSON.stringify(editData),
                    Registrations: result_regNumbs,
                    Reg_Names: result_names,
                    performAction: updateOrWithPrint,
                    //BedCount : I need to get from sp and send from here.
                },
                success: function (data) {
                    HideLoader();
                    
                    if (typeof data.jsonParam === "undefined") {
                        if (data.length > 0) {
                            if (result_respids.length > 36) {
                                OpenPopup("PrintSlipPopup_AccomRegstr", "Print Slip Options", null, "auto", 360, true, data, "maxheightPrintSlip");
                            }
                            else {
                                OpenPopup("PrintSlipPopup_AccomRegstr", "PrintSlip(s)", null, "auto", 380, true, data, "maxheightPrintSlip");
                            }
                        }
                    }
                    else if (data.jsonParam.result) {
                        HideLoader();
