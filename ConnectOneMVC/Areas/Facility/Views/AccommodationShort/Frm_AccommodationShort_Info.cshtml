        function bedsCalculation(val, key_curnt) {
            
            var gridInstance = $("#RoomNumbersList_AccomShort_datagrid").dxDataGrid("instance");
            var alreadyfilled_s = 0;
            var editData = gridInstance.getController('editing')._editData
            var neworedited = 'new'
            for (var i = 0; i < editData.length; i++) {//In this loop we are checking the edited key which has come through bedsCalculation function is new or already in edited.
                if (editData[i]['key'] == key_curnt) {
                    neworedited = 'alreadEdited'
                }
            }
            if (neworedited == 'new') { alreadyfilled_s = val;} //this function was not handling with new selected row. that is why this if condition and above for loop was created.
            for (var i = 0; i < editData.length; i++) {//Here we are calculating already allotted beds count
                //editData[0]['key'] //useful code for any urgent purpose to find key of each row in editdata.
                if (gridInstance.isRowSelected(editData[i]['key'])) {
                    var curr_Allot;
                    if (editData[i]['key'] == key_curnt) {
                        curr_Allot = val
                    } else {
                        curr_Allot = editData[i]['data']['CURRENT_ALLOTMENT'];
                    }
                    
                    if (curr_Allot == undefined) { curr_Allot = 0; }
                    alreadyfilled_s = alreadyfilled_s + curr_Allot
                }
            }
            fill:
            document.getElementById("bedsReq_AccomShort").innerHTML = result_respids.split("|").length;
            document.getElementById("bedsAllotted_AccomShort").innerHTML = alreadyfilled_s //- e.component.cellValue(rowindex_Curr, "CURRENT_ALLOTMENT");
            document.getElementById("bedsRemainToAllot_AccomShort").innerHTML = result_respids.split("|").length - (alreadyfilled_s) //- e.component.cellValue(rowindex_Curr, "CURRENT_ALLOTMENT"));  

            //Focussed Room details filling
            document.getElementById("focusedRoom_AccomShort").innerHTML = "<span>" + gridInstance.cellValue(gridInstance.getRowIndexByKey(key_curnt), "AL_LOC_NAME") +
                "(" + gridInstance.cellValue(gridInstance.getRowIndexByKey(key_curnt), "AL_MAXCAPACITY") + ")-" + val + "</span>"
        }
