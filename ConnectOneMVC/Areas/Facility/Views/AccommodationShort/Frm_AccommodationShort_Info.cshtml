        <div id="namesGrid_AccomShort" style="height:180px; display: none;">
            @(
            
                Html.DevExtreme().DataGrid().ID("users_datagrid_AccomShort").ColumnAutoWidth(true).AllowColumnResizing(true).Height("150").DataSource(new List<string>())
                    .Selection(s=>s.Mode(SelectionMode.Multiple)).OnInitialized("onInitialized_users_datagrid_AccomShort")
                    .Columns(columns =>
                    {
                        columns.Add().DataField("5").Caption("RegNumbers").Visible(true).Alignment(HorizontalAlignment.Center);
                        columns.Add().DataField("0").Caption("Name").Visible(true).Alignment(HorizontalAlignment.Center);
                        columns.Add().DataField("1").Caption("Gender").Visible(true).Alignment(HorizontalAlignment.Center);
                        columns.Add().DataField("2").Caption("ArrivalDate").Visible(true).Alignment(HorizontalAlignment.Center);
                        columns.Add().DataField("3").Caption("DepartureDate").Visible(true).Alignment(HorizontalAlignment.Center);
                        columns.Add().DataField("4").Caption("ChartID").Visible(false).Alignment(HorizontalAlignment.Center);
                        columns.Add().DataField("6").Caption("RespID").Visible(false).Alignment(HorizontalAlignment.Center);
                        columns.Add().DataField("7").Caption("NamesWithGenders").Visible(false).Alignment(HorizontalAlignment.Center);
                        columns.Add().DataField("8").Caption("Selection").Visible(false).Alignment(HorizontalAlignment.Center);
                        
                    })
                    .OnSelectionChanged("onSelectionChanged_users_datagrid_AccomShort").OnContentReady("selectingRows_AccomShort")
                    
            )
