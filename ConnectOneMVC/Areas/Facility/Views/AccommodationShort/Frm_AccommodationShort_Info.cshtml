    <script>
        function print_AccomShort_Onclick() {
            var nameslist = result_names_genders_str.replaceAll("(M)", "");
            nameslist = result_names_genders_str.replaceAll("(F)", "")
            var instid = "";
            $.ajax({
                type: 'GET',
                url: "/Facility/AccommodationRegister/Frm_PrintSlipOptions",
                cache: false,
                data:
                {
                    Chart_Inst_ID: instid,
                    Chart_Resp_ID: result_respids,
                    NamesList: nameslist,
                    PrintFromscreen : "AccommodationShort",
                },
                success: function (data) {
                    HideLoader();
                    OpenPopup("PrintSlipPopup_AccomShort", "PrintSlip(s)", null, "auto", 380, true, data, "maxheightPrintSlip");
                },
                error: function (jqXHR, textStatus, errorThrown) {
                    HideLoader();                    
                    DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
                }
            });
        }
    </script>
    <script>
        var printFromButton = false;
        /*var selectedEvent_AccomShort;*/
        var selectedForm_AccomShort;
        var selectedRegistrationNumbers;
        var selectedPhoneNumbers;
        var selectedInstanceId_AccomShort;
        var regNos_or_PhNos_AccomShort;
        var ph_numbers_AccomShort;

        var result_regNumbs;
        var result_chartids;
        var result_respids;
        var result_names;
        var result_gender;
        var result_names_genders_str;

        $(document).ready(function () {
            printFromButton = false;
        });
        $('#RoomNumbersList_AccomShort_datagrid').dxDataGrid({
            onContentReady: function (e) {
                if (e.component.shouldSkipNextReady) {
                    e.component.shouldSkipNextReady = false;
