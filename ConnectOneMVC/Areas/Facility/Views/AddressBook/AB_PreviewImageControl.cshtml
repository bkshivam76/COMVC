@{ 
    var AB_Asset_Image = ViewBag.AB_Asset_Image == null ? null : (byte[])ViewBag.AB_Asset_Image;
}
@Html.DevExpress().BinaryImage(
    settings =>
    {
        settings.Name = "AB_binaryImage_show";
        settings.ClientEnabled = true;
        settings.ClientVisible = true;
        settings.Properties.ClientInstanceName = "AB_binaryImage_show";
        settings.Properties.EnableClientSideAPI = true;
        settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
        settings.Height = System.Web.UI.WebControls.Unit.Percentage(60);       
        settings.ContentBytes = AB_Asset_Image;
        settings.Properties.ImageSizeMode = ImageSizeMode.FitProportional;
        settings.ControlStyle.CssClass = "DevexpressComponents";
    }).GetHtml()