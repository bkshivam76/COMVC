    function OnAddressNewClick()
    {
        console.log("New Click");
        if (!Addressbook_AddRight)
        {
            DevExpress.ui.dialog.alert("Not Allowed", 'No Rights'); return;
        }
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Facility/AddressBook/Frm_Address_Info_Window",
            data: { ActionMethod: "New", DropDownFunctionName: "@PartyRefreshFunction" },
            cache: false,
            success: function (data)
            {
                OpenPopup("popup_frm_Address_Window", "New ~ Contact", null, "auto", 900, true, data);
            }
        });
