    <script>
        var AB_Select_xid = "";
        var ABFocusedRowIndexBeforeRefresh;
        function AddressBookOnInit(s, e) {
            AddressBookAdjustSize();
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                AddressBookAdjustSize();
            });
        }
        function AddressBookAdjustSize() {
            var height = (document.documentElement.clientHeight * 90) / 100;
            try {
                AddressListGrid.SetHeight(height);
            }
            catch (err) {
            }
        }
        function AddressBookListGrid_BeginCallback(s, e) {
            ShowLoader_GridView();
            ABFocusedRowIndexBeforeRefresh = s.GetFocusedRowIndex();
            e.customArgs["command"] = e.command;
            e.customArgs["VouchingMode"] = AddressBook_IsVouchingMode;
            e.customArgs["ShowHorizontalBar"] = AB_ShowHorizontalBar;
            e.customArgs["ViewMode"] = AdresBook_ViewMode;
            e.customArgs["ColumnToBeShownIndex"] = AB_ColumnToBeShownIndex;
            e.customArgs["ColumnToBeHidddenIndex"] = AB_ColumnToBeHidddenIndex;
            e.customArgs["RowKeyToFocus"] = AB_Select_xid;
            e.customArgs["ShowAttachmentIndicator"] = AddressBook_ShowAttachmentIndicator;
            e.customArgs["ShowVouchingIndicator"] = AddressBook_ShowVouchingIndicator;
        }
        var AB_ColumnToBeShownIndex = "";
        var AB_ColumnToBeHidddenIndex = "";
