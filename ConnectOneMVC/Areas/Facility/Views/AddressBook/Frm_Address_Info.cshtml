    }
    function OnAddressEditClick()
    {
        console.log("Edit Click");
        if (!Addressbook_EditRight)
        {
            DevExpress.ui.dialog.alert("Not Allowed", 'No Rights'); return;
        }
        AddressBook_GetRowData();
        if (Addressbook_ID==null)
        {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        ShowLoader()
        $.ajax({
            type: 'GET',
            url: "/Facility/AddressBook/DataNavigation",
            data:
            {
                ActionMethod: "Edit",
                ID: Addressbook_ID,
                Edit_Date: Addressbook_Edit_Date
            },
            cache: false,
            success: function (data)
            {
                if (data.result == true)
                {
                    ShowLoader();
                    $.ajax({
                        type: 'GET',
                        url: "/Facility/AddressBook/Frm_Address_Info_Window",
                        data: { ActionMethod: "Edit", ID: Addressbook_ID, EditedOn: Addressbook_Edit_Date, DropDownFunctionName: "@PartyRefreshFunction" },
                        cache: false,
                        success: function (data)
                        {
                            if (typeof (data) == "string")
                            {
                                OpenPopup("popup_frm_Address_Window", "Edit ~ Contact", null, "auto", 900, true, data);
                            }
                            else
                            {
                                DevExpress.ui.dialog.alert(data.jsonParam.message, 'Warning!');
                                HideLoader();
                            }
                        }
                    });
                }
                else
                {
                    AddressListGrid.Refresh();
                    HideLoader();
                    DevExpress.ui.dialog.alert(data.Message, "Warning...");

                }
            }
        });
    }

    function OnAddressDeleteClick()
    {
        console.log("Delete Click");
        if (!Addressbook_DeleteRight)
        {
            DevExpress.ui.dialog.alert("Not Allowed", 'No Rights'); return;
        }
        AddressBook_GetRowData();
        if (Addressbook_ID == null)
        {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        var result = DevExpress.ui.dialog.confirm("Sure you want to delete?", "Confirm changes");
        result.done(function (dialogResult)
        {
            if (dialogResult)
            {
                ShowLoader();
                $.ajax({
                    type: 'GET',
                    url: "/Facility/AddressBook/DataNavigation",
                    data:
                    {
                        ActionMethod: "Delete",
                        id: Addressbook_ID,
                        Edit_Date: encodeURIComponent(Addressbook_Edit_Date)
                    },
                    cache: false,
                    success: function (data)
                    {
                        if (data.result == true)
                        {
                            DevExpress.ui.dialog.alert(data.Message, "Address(s) Book");
                            @*if ("@PartyRefreshFunction".length > 0)
                            {
                                var fn = window["@PartyRefreshFunction"];
                                if (typeof fn == "function")
                                {
                                    fn();
                                }
                            }*@
                            console.log("Delete success");
                            AddressListGrid.Refresh();
                        }
                        else if (data.result == "NoDeleteRights")
                        {
                            $("#AddressModelDelete").hide();
                            DevExpress.ui.dialog.alert(data.Message, "No Rights");
                        }
                        else
                        {
                            DevExpress.ui.dialog.alert(data.Message, "Address(s) Book");
                            //AddressListGrid.Refresh();
                        }
                        HideLoader();
                    }
                });
            }
        });
    }
        async function OnAddressMergeClick()
        {
