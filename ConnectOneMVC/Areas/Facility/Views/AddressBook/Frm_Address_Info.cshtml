            var AddressBook_ShowAttachmentIndicator = AddressBook_IsIndicatorSwitchOn;
            var AddressBook_ShowVouchingIndicator = AddressBook_IsIndicatorSwitchOn;
            var AddressBook_Trigger_IndicatorSwitch_ValueChange = "@AddressBook_Auto_Vouching_Mode" == "True" ? false : true;
            var AdresBook_ViewMode = "Default";

    function AddressBook_IndicatorSwitch_ValueChange(e) {

        if (AddressBook_Trigger_IndicatorSwitch_ValueChange) {
            AddressBook_IsIndicatorSwitchOn = e.value;
            AddressBook_ShowAttachmentIndicator = AddressBook_IsIndicatorSwitchOn;
            AddressBook_ShowVouchingIndicator = AddressBook_IsIndicatorSwitchOn;

            AddressListGrid.Refresh();
        }
        else {
            AddressBook_Trigger_IndicatorSwitch_ValueChange = true;
        }
    }

    function AddressBook_VouchingSwitch_ValueChange(e)
    {
        ShowLoader();
        AddressBook_IsVouchingMode = e.value;
        //AddressListGrid.SetFocusedRowIndex(-1);
        if (AddressBook_SetVouchingModeOn == true)
        {
            AddressBook_SetVouchingModeOn = false;
        }
        else
        {
            AddressBook_FAB.SetVisible(false);
        }
        if (AddressBook_IsVouchingMode == true)
        {
            if (AddressBook_IsIndicatorSwitchOn == false) {
                $("#AddressBookIndicatorVisibilitySwitch").dxSwitch("instance").option("value", true);
            }
            OpenRightPane();
            ClearLeftPane();
            OpenLeftPane();
        }
        else
        {
            //AddressBook_FAB.SetActionContext("AddAttachmentContext", false);
            CloseRightPane();
            ClearLeftPane();
            CloseLeftPane();
        }
        AddressListGrid_CollapseAllDetailRows();
    }
    function AddressListGrid_CollapseAllDetailRows()
    {
        ShowLoader();
        if (typeof window !== 'undefined')
        {
            if (typeof window.AddressListGrid !== 'undefined')
            {
                if (typeof window.AddressListGrid.CollapseAllDetailRows !== 'undefined')
                {
                    if (typeof AddressListGrid.CollapseAllDetailRows == 'function')
                    {
                        HideLoader();
                        AddressListGrid.SetFocusedRowIndex(-1);
                        AddressListGrid.CollapseAllDetailRows();
                    }
                    else
                    {
                        alert("CollapseAllDetailRows is not a function");
                    }
                }
                else
                {
                    setTimeout(function ()
                    {
                        AddressListGrid_CollapseAllDetailRows();
                    }, Timeout100);
                }
            }
            else
            {
                alert('grid undefined')
            }
        }
        else
        {
            alert('window undefined')
        }
    }
    function AdresBook_ViewSwitch_ValueChange(e)
    {
        ShowLoader();
        AdresBook_ViewMode = e.value == false ? "Default" : "Compact";
        if (AddressBook_SetVouchingModeOn == true)
        {
            $("#AddressBookVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }
        else
        {
            //AddressListGrid_CollapseAllDetailRows();
            if (AddressBook_IsVouchingMode == false)
            {
                AddressBook_FAB.SetVisible(false);
            }
            AddressListGrid.CollapseAllDetailRows();
        }
        HideLoader();
    }
