                    $("#AddressreloadPartialView").html(res);
                    ASPxClientControl.AdjustControls(document.getElementById("AddressreloadPartialView"));
                    $(".AddressListGrid_PreviewRow").hide();
                    GetSessionStorage("AddressListGrid");
                    HideLoader();
                }
            });

        }
