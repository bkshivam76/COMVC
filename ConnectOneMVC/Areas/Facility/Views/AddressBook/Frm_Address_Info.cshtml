                //if (AddressBook_ID != null || AddressBook_ID == 'undefined' || AddressBook_ID == undefined)
                //
                OnAddressEditClick();//redmine Bug #133474 fixed

            }
        }
        function OnAddressBookGridFocusedRowChanged(s, e) {
            if (s.GetFocusedRowIndex() > -1) {
                if (AddressBook_IsVouchingMode) {
                    AddressBook_FAB.SetVisible(true);
                    AddressBook_FAB.SetActionContext("VouchingActionContext", true);
                }
                Addressbook_ID = s.GetRowKey(s.GetFocusedRowIndex());
                AddressBook_GetRowData(s.GetFocusedRowIndex())
                //ShowLoader;
                //s.GetValuesOnCustomCallback({ ID: s.GetRowKey(s.GetFocusedRowIndex()) }, OnGetRowValues_AddressInfo);
