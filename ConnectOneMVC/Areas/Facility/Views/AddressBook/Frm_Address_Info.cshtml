        function ExcelUpload_valueChange(e) {
            //$("#Txt_ProfilePic_FileName").val(null);
            var files = e.value;
            //debugger;
            if (files.length > 0) {
                if ((files[0].type).includes("sheet")) {
                    const blob = new Blob([files[0]], { type: files[0].type });
                    var url = URL.createObjectURL(blob);
                    file_path = url;
                    file_name = files[0].name;
                    //debugger;
                    UploadProcessAfterBrowse();
                }
                else {
                    DevExpress.ui.dialog.alert('No File is Selected', "Information...").done(function () { });
                }
            }
        }

        function UploadProcessAfterBrowse() {
            //debugger;
            var formdata = new FormData($('#uploadExcel_Address').get(0));
            var tablename = "ADDRESS_BOOK"
            //formdata.append("file_name", file_name);
            //formdata.append("file_path", file_path);
            formdata.append("table_name", tablename);
                if (file_name) {
                    $.ajax({
                url: "/Base/ReadUploadedExcel",
                        type: "POST",
                        cache: false,
                        data: formdata,
                        processData: false,
                        contentType: false,
                        success: function (res) {
                        //debugger;
                        if (res.jsonParam.result == true) {
                            DevExpress.ui.dialog.alert(res.jsonParam.message, res.jsonParam.title);
                        }
                        if (res.jsonParam.result == false) {
                            //DevExpress.ui.notify({ message: res.jsonParam.message, width: 500, shading: true, position: 'center' }, "error", 1000);
                            DevExpress.ui.dialog.alert(res.jsonParam.message, res.jsonParam.title);
                        }
                        HideLoader();
                    }
                });
            }
        }


