        }
        function AddressBook_GetRowData(RowIndex = null) {
            var focusedrow = RowIndex == null ? AddressListGrid.GetFocusedRowIndex() : RowIndex;
            var topindex = AddressListGrid.GetTopVisibleIndex();
            var Index = focusedrow - topindex;
            var AB_PageData = AddressListGrid.cpPagedata;
            if (AB_PageData != null && AB_PageData.length > 0 && Index < AB_PageData.length && Index >= 0) {
                Addressbook_ID = typeof AB_PageData[Index][0] !== "undefined" ? AB_PageData[Index][0] : null;
                Addressbook_Add_By = typeof AB_PageData[Index][1] !== "undefined" ? AB_PageData[Index][1] : null;
                Addressbook_Add_Date = typeof AB_PageData[Index][2] !== "undefined" ? AB_PageData[Index][2] : null;
                Addressbook_Edit_By = typeof AB_PageData[Index][3] !== "undefined" ? AB_PageData[Index][3] : null;
                Addressbook_Edit_Date = typeof AB_PageData[Index][4] !== "undefined" ? AB_PageData[Index][4] : null;
                Addressbook_Action_By = typeof AB_PageData[Index][5] !== "undefined" ? AB_PageData[Index][5] : null;
                Addressbook_Action_Date = typeof AB_PageData[Index][6] !== "undefined" ? AB_PageData[Index][6] : null;
                Addressbook_Action_Status = typeof AB_PageData[Index][7] !== "undefined" ? AB_PageData[Index][7] : null;
                Addressbook_Name = typeof AB_PageData[Index][8] !== "undefined" ? AB_PageData[Index][8] : null;
            }
            else {
                Addressbook_ID = null;
            }
        }
        function OnGetRowValues_AddressInfo(value) {
            if (value != null)//redmine Bug #133518 fix
            {
                var values = value.split("![");
                Addressbook_ID = values[0];
                Addressbook_Add_By = values[1];
                Addressbook_Add_Date = values[2];
                Addressbook_Edit_By = values[3];
                Addressbook_Edit_Date = values[4];
                Addressbook_Action_Status = values[5];
                Addressbook_Action_By = values[6];
                Addressbook_Action_Date = values[7];
                Addressbook_UpdateFooterDetail(Addressbook_ID, Addressbook_Action_Status, Addressbook_Add_Date, Addressbook_Add_By,
                    Addressbook_Action_Date, Addressbook_Action_By, Addressbook_Edit_Date, Addressbook_Edit_By);
                if (AddressBook_IsVouchingMode == true) {
                    OpenLeftPane();
                    LoadDocumentAndAdditionalInfoInLeftPane("Facility", "AddressBook", "LeftPaneContent", Addressbook_ID, AddressBook_IsVouchingMode, "");
                }
            }
            HideLoader();
        }
        function Addressbook_UpdateFooterDetail(Addressbook_ID, Addressbook_Action_Status, Addressbook_Add_Date, Addressbook_Add_By, Addressbook_Action_Date, Addressbook_Action_By, Addressbook_Edit_Date, Addressbook_Edit_By) {
            var Status = "";
            var Lbl_Status = "";
            var Lbl_StatusBy = "";
            var Pic_Status = "";
            var Lbl_Create = "";
            var Lbl_Modify = "";
            var Lbl_Status_Color = "";
            var Lbl_ActionOn = "";
            var Lbl_ActionBy = "";
            var StatusStr = "";
            if (Addressbook_ID != null) {
                //Addressbook_Add_Date = (moment(Addressbook_Add_Date, "DD/MM/YYYY HH:mm:ss").format("DD/MM/YYYY HH:mm:ss"));
                //Addressbook_Edit_Date = (moment(Addressbook_Edit_Date, "DD/MM/YYYY HH:mm:ss").format("DD/MM/YYYY HH:mm:ss"));
                //Addressbook_Action_Date = (moment(Addressbook_Action_Date, "DD/MM/YYYY HH:mm:ss").format("DD/MM/YYYY HH:mm:ss"));
                Status = Addressbook_Action_Status;
                StatusStr = Status == "Locked" ? "Locked" : Status == null ? null : "UnLocked";
                if (Status && Status.toUpperCase() == "LOCKED") {
                    Lbl_Status = "Completed";
                    Lbl_Status_Color = "blue";
                    Pic_Status = "fa fa-lock";
                }
                else {
                    Pic_Status = "fa fa-unlock";
                    Lbl_Status = Status;
                    if (Status && Status.toUpperCase() == "COMPLETED") {
                        Lbl_Status_Color = "green";
                    }
                    else {
                        Lbl_Status_Color = "red";
                    }
                }
                if (Addressbook_Action_Date) {
                    Lbl_ActionOn = StatusStr + " On: " + Addressbook_Action_Date;
                    Lbl_ActionBy = StatusStr + " By: " + Addressbook_Action_By;
                }
                else {
                    Lbl_ActionOn = "";
                    Lbl_ActionBy = "";
                }
                if (Addressbook_Add_Date) {
                    Lbl_Create = "Add On: " + Addressbook_Add_Date + ", By: " + Addressbook_Add_By;
                }
                else {
                    Lbl_Create = "";
                }
                if (Addressbook_Edit_Date) {
                    Lbl_Modify = "Edit On: " + Addressbook_Edit_Date + ", By: " + Addressbook_Edit_By;
                }
                else {
                    Lbl_Modify = "";
                }
            }
            $('#AB_Status').text(Lbl_Status);
            $('#AB_Lbl_ActionOn').text(Lbl_ActionOn)
            $('#AB_Lbl_ActionBy').text(Lbl_ActionBy);
            $('#AB_Create').text(Lbl_Create);
            $('#AB_Modify').text(Lbl_Modify);
            if (Lbl_Status_Color != "") {
                $('#ActionItem_Status').css('color', Lbl_Status_Color);
            }
            if (Pic_Status == "fa fa-lock") {
                $('#ActionItem_LockICON').addClass(Pic_Status).removeClass("fa-unlock");
            }
            else if (Pic_Status == "fa fa-unlock") {
                $('#ActionItem_LockICON').addClass(Pic_Status).removeClass("fa-lock");
            }
            else {
                $('#ActionItem_LockICON').removeClass("fa");
                $('#ActionItem_LockICON').removeClass("fa-lock");
                $('#ActionItem_LockICON').removeClass("fa-unlock");
            }
        }
        function AddressBookContextMenuFunction(s, e) {
            if (e.item.name == 'New') {
                OnAddressNewClick();
            }
            else if (e.item.name == 'Edit') {
                OnAddressEditClick();
            }
            else if (e.item.name == 'Delete') {
                OnAddressDeleteClick();
            }
            else if (e.item.name == 'Merge') {
                OnAddressMergeClick();
            }
            else if (e.item.name == 'ListPreview') {
                OnAddressListPreviewClick();
            }
            else if (e.item.name == 'Close') {
                closeAddressBook();
            }
            else if (e.item.name == 'LabelPrinting') {
                DevExpress.ui.dialog.alert("Coming Soon", "Information");
            }
            else if (e.item.name == 'EnvelopPrinting') {
                DevExpress.ui.dialog.alert("Coming Soon", "Information");
            }
            else if (e.item.name == 'Import') {
                DevExpress.ui.dialog.alert("Coming Soon", "Information");
            }
            else if (e.item.name == 'Export') {
                DevExpress.ui.dialog.alert("Coming Soon", "Information");
            }
            else if (e.item.name == 'Refresh') {
                AddressListGrid.Refresh();
            }

        }
    </script>
    @* Grid Functions *@
    <script>
    var AddressBookInfo_IsDetailRowExpanded = false;
    var AddressBookInfo_NestedRecord_FocusedRowIndex = -1;
    var AddressBookInfo_NestedGrid_AccessID;
    var AddressBookInfo_AtachmentID;
    var AddressBookInfo_FileName;
    var AddressBookInfo_ParamMandatory;
    var AddressBookInfo_FromDateLabel;
    var AddressBookInfo_ToDateLabel;
    var AddressBookInfo_DescriptionLabel;
    var AddressBookInfo_Doc_ID;
    var AddressBookInfo_Doc_Category;
    var AddressBookInfo_MasterRowRecID;
    var AddressBookInfo_MasterRowMID;
    var AddressBookInfo_NestedRowMapID;
    var AddressBookInfo_reason;
    var AddressBookInfo_Attachment_RecStatus;
    var AddressBookInfo_Nested_Doc_Status;
    var AddressBookInfo_NestedRowReasonID;
    var AddressBookInfo_NestedRowKeyValue;

    function On_AddressBookFacility_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@Help_Attachment_AddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (AddressBookInfo_ParamMandatory == 1)
            {
                AddAttachment(AddressBookInfo_MasterRowRecID, "Facility_AddressBook", AddressBookInfo_Doc_ID, AddressBookInfo_Doc_Category, AddressBookInfo_ParamMandatory, AddressBookInfo_FromDateLabel, AddressBookInfo_ToDateLabel, AddressBookInfo_DescriptionLabel, "AddressBookFacilityAttachment", null, "AddressListGrid", AddressBookInfo_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(AddressBookInfo_MasterRowRecID, "Facility_AddressBook", AddressBookInfo_Doc_ID, "AddressBookFacilityAttachment", "AddressListGrid", AddressBookInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (AddressBookInfo_Nested_Doc_Status == "NO" || AddressBookInfo_Nested_Doc_Status == "")
            {
                DevExpress.ui.dialog.alert("Please Attach document First", "Error");
                return;
            }
            if (AddressBookInfo_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(AddressBookInfo_MasterRowRecID, "Facility_AddressBook", AddressBookInfo_AtachmentID, AddressBookInfo_ParamMandatory, AddressBookInfo_FromDateLabel, AddressBookInfo_ToDateLabel, AddressBookInfo_DescriptionLabel, "AddressBookFacilityAttachment", null, "AddressListGrid", AddressBookInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (AddressBookInfo_Nested_Doc_Status == "NO" || AddressBookInfo_Nested_Doc_Status == "")
            {
                DevExpress.ui.dialog.alert("Please Attach document First", "Error");
                return;
            }
            DeleteAttachment(AddressBookInfo_MasterRowRecID, "Facility_AddressBook", AddressBookInfo_AtachmentID, AddressBookInfo_ParamMandatory, AddressBookInfo_FromDateLabel, AddressBookInfo_ToDateLabel, AddressBookInfo_DescriptionLabel, null, "AddressListGrid", AddressBookInfo_NestedGrid_AccessID, AddressBookInfo_Attachment_RecStatus);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@Help_Attachment_ViewRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (AddressBookInfo_Nested_Doc_Status == "NO" || AddressBookInfo_Nested_Doc_Status == "")
            {
                DevExpress.ui.dialog.alert("Please Attach document First", "Error");
                return;
            }

            ViewDocument(AddressBookInfo_AtachmentID, AddressBookInfo_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(AddressBookInfo_MasterRowRecID, "Facility_AddressBook", "Address Book", "AddressListGrid", AddressBookInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Add_Reason")
        {
            if (AddressBookInfo_Doc_Category.toLowerCase() == "others")
            {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else
            {
                AttachmentAddReason(AddressBookInfo_MasterRowRecID, AddressBookInfo_NestedRowMapID, "Facility_AddressBook", "AddressListGrid", AddressBookInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(AddressBookInfo_MasterRowRecID, AddressBookInfo_NestedRowMapID, "Facility_AddressBook", "AddressListGrid", AddressBookInfo_NestedGrid_AccessID, AddressBookInfo_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(AddressBookInfo_MasterRowRecID, AddressBookInfo_NestedRowMapID, "AddressListGrid", AddressBookInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
        else if (e.actionName == "AuditAction")
        {
            AddressBook_FAB.SetActionContext("AuditActionContext", true);
        }
        else if (e.actionName == "BackAudit")
        {
            if (AddressBookInfo_Nested_Doc_Status == "")
            {
                AddressBook_FAB.SetActionContext("AutoItemContext", true);
            }
            if (AddressBookInfo_Nested_Doc_Status == "NO")
            {
                AddressBook_FAB.SetActionContext("EditItemContext", true);
            }
            if (AddressBookInfo_Nested_Doc_Status == "YES")
            {
                AddressBook_FAB.SetActionContext("actionItemContext", true);
            }
        }
        else if (e.actionName == "Accept") {

            AddressBookInfo_AcceptwithoutRemarks();
        }
        else if (e.actionName == "Reject") {

            AddressBookInfo_AcceptRejectVoucher("Reject");
        }
        else if (e.actionName == "AcceptWithRemarks") {

            AddressBookInfo_AcceptRejectVoucher("Accept");
        }
        else if (e.actionName == "AcceptDoc") {

            OnAddressBookInfo_AcceptDoc();
        }
        else if (e.actionName == "RejectDoc") {

            OnAddressBookInfo_RejectDoc();
        }
    }
    function OnAddressBookInfo_RejectDoc() {
        if (AddressBookInfo_AtachmentID == null || AddressBookInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        RejectAttachment(AddressBookInfo_AtachmentID, "AddressListGrid", AddressBookInfo_NestedGrid_AccessID);
    }
    function OnAddressBookInfo_AcceptDoc() {
        if (AddressBookInfo_AtachmentID == null || AddressBookInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        AcceptAttachment(AddressBookInfo_AtachmentID, "AddressListGrid", AddressBookInfo_NestedGrid_AccessID);
    }
    function AddressBookInfo_AcceptwithoutRemarks()
    {
        var Recid;
        if (AddressBookInfo_IsDetailRowExpanded == true || AddressBook_IsVouchingMode == true)
        {
            if (AddressBookInfo_MasterRowRecID == null || AddressBookInfo_MasterRowRecID == "")
            {
                Recid = Addressbook_ID;
            }
            else
            {
                Recid = AddressBookInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = Addressbook_ID;
        }
        Entry_AcceptwithoutRemarks(Recid, "Facility_AddressBook", "AddressListGrid", AddressBookInfo_AtachmentID, AddressBookInfo_NestedRowReasonID, AddressBookInfo_NestedRowKeyValue);
    }
    function AddressBookInfo_AcceptRejectVoucher(_actionMethod)
    {
        var Recid;
        if (AddressBookInfo_IsDetailRowExpanded == true || AddressBook_IsVouchingMode == true)
        {
            if (AddressBookInfo_MasterRowRecID == null || AddressBookInfo_MasterRowRecID == "")
            {
                Recid = Addressbook_ID;
            }
            else
            {
                Recid = AddressBookInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = Addressbook_ID;
        }
        Entry_AcceptReject(_actionMethod, Recid, "Facility_AddressBook", "AddressListGrid", AddressBookInfo_AtachmentID, AddressBookInfo_NestedRowReasonID, AddressBookInfo_NestedRowKeyValue);
    }
    function OnAddressBookListGridNestedFocusedRowChange(s, e)
    {
        if (AddressBookInfo_IsDetailRowExpanded == true || AddressBook_IsVouchingMode == true)
        {
            AddressBookInfo_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
            if (AddressBookInfo_NestedRecord_FocusedRowIndex >= 0)
            {
                ShowLoader();
                AddressBook_FAB.SetVisible(true);
                AddressBookInfo_NestedGrid_AccessID = s.uniqueID;
                s.GetRowValues(s.GetFocusedRowIndex(), 'Doc_Status;Params_Mandatory;LABEL_FROM_DATE;LABEL_TO_DATE;LABEL_DESCRIPTION;Document_Category;Document_ID;ATTACH_ID;TxnID;TxnMID;MAP_ID;Reason;ATTACH_FILE_NAME;Attachment_Action_Status;UniqueID;ReasonID', OnAddressBookInfo_GetGridRowValues);
            }
            else
            {
                AddressBook_FAB.SetVisible(false);
            }
        }
    }
    function OnAddressBookInfo_GetGridRowValues(values)
    {
        
        HideLoader();
        if (values[14] != null)
        {
            AddressBookInfo_Nested_Doc_Status = values[0];
            AddressBook_FAB.SetVisible(true);
            if (AddressBook_IsVouchingMode == true)
            {
                AddressBook_FAB.SetActionContext("AuditActionContext", true);
            }
            else
            {
                if (AddressBookInfo_Nested_Doc_Status == "")
                {
                    AddressBook_FAB.SetActionContext("AutoItemContext", true);
                }
                else if (AddressBookInfo_Nested_Doc_Status == "NO")
                {
                    AddressBook_FAB.SetActionContext("EditItemContext", true);
                }
                else if (AddressBookInfo_Nested_Doc_Status == "YES")
                {
                    AddressBook_FAB.SetActionContext("actionItemContext", true);
                }
            }
           // AddressBook_FAB.SetActionContext("actionItemContext", true);
            AddressBookInfo_ParamMandatory = values[1];
            AddressBookInfo_FromDateLabel = values[2];
            AddressBookInfo_ToDateLabel = values[3];
            AddressBookInfo_DescriptionLabel = values[4];
            AddressBookInfo_Doc_Category = values[5];
            AddressBookInfo_Doc_ID = values[6];
            AddressBookInfo_AtachmentID = values[7];
            IndexAttachmentID = AddressBookInfo_AtachmentID;
            AddressBookInfo_MasterRowRecID = values[8];
            AddressBookInfo_MasterRowMID = values[9];
            AddressBookInfo_NestedRowMapID = values[10];
            AddressBookInfo_reason = values[11];
            AddressBookInfo_FileName = values[12];
            AddressBookInfo_Attachment_RecStatus = values[13];
            AddressBookInfo_NestedRowKeyValue = values[14];

            if (AddressBook_IsVouchingMode == true)
            {
                if (AddressBookInfo_FileName != null && AddressBookInfo_FileName.length > 0)
                {
                    ViewDocument(AddressBookInfo_AtachmentID, AddressBookInfo_FileName, "AddressBook_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else
                {
                    CloseRightPane();
                    ClearRightPane();
                }
            }
        }
        AddressBookInfo_NestedRowReasonID = values[15];
        IndexAttachmentReasonID = AddressBookInfo_NestedRowReasonID;
    }
    function AddressBookGrid_Nested_BeginCallBack(s, e)
    {
        e.customArgs["ShowHorizontalBar"] = AB_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = AddressBook_IsVouchingMode;
        e.customArgs["command"] = e.command;
    }
    function AddressBookGrid_DetailRowExpanding(s, e)
    {
        AddressBookInfo_IsDetailRowExpanded = true;
        s.SetFocusedRowIndex(e.visibleIndex);
        var pane = Mainspliter.GetPaneByName('RightPane');
        if (AddressBook_IsVouchingMode == true)
        {
            pane.Expand();
        }
        else
        {
            pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
        }
    }
    function AddressBookGrid_DetailRowCollapsing(s, e)
    {
        AddressBookInfo_IsDetailRowExpanded = false;
        s.SetFocusedRowIndex(e.visibleIndex);
        if (AddressBook_IsVouchingMode == true)
        {
            if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false)
            {
                CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
        else
        {
            AddressBook_FAB.SetVisible(false);
        }
    }
    </script>
