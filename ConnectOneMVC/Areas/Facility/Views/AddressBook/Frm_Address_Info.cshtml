        {
            MergeInNextYearToo= await DevExpress.ui.dialog.confirm("Do you Want to make Merge Same Contact in year " + "@next_Unaudited_YearID".substring(0, 2) + "-" + "@next_Unaudited_YearID".substring(2) + " too?", "Confirm");
        }
            ShowLoader();
            $.ajax({
                type: 'GET',
