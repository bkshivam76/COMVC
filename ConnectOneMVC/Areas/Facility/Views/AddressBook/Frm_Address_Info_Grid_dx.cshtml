@using System.Text.RegularExpressions;
@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    int ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;
}
@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar)
          .ID("AddressListGrid_dx")
          .DataSource(d => d.Mvc().Controller("AddressBook").LoadAction("Frm_Address_Info_GridData_dx").LoadMode(DataSourceLoadMode.Raw).Key("ID")
                            .LoadParams(new { ShowAttachmentIndicator = new JS("function (){return AddressBook_ShowAttachmentIndicator_dx;}"), ShowVouchingIndicator = new JS("function (){ return AddressBook_ShowVouchingIndicator_dx;}") }).UpdateAction("Frm_Address_Info_SaveEdited_GridData_dx")
                            //.OnBeforeSend("AddressInfoGrid_dx_OnBeforeSend")
                            )
          .Columns(columns =>
          {
              columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);//Bug #137209 Fix
              columns.Add().DataField("iIcon").Name("iIcon").Caption("").CellTemplate(new JS("AddressListGrid_dx_iIconTemplate")).Width(30)
           .HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource")).RenderAsync(true).AllowEditing(false);
              columns.Add().DataField("AddressListGrid_dx_Compact_Column").Name("AddressListGrid_dx_Compact_Column").Caption("").Visible(false).CellTemplate(new JS("AddressListGrid_dx_Compact_Column_Template")).CalculateCellValue("AddressListGrid_dx_Compact_Column_CellValue").Width("100%").RenderAsync(true);
              columns.Add().DataField("EditColumn").Name("EditColumn").Caption("").Visible(false).Type(GridCommandColumnType.Buttons).Buttons(b =>
              {
                  b.Add().Name(GridColumnButtonName.Edit);
                  b.Add().Visible(new JS("function(e){return e.row.isEditing}")).OnClick("cancelEdit_AB").Name(GridColumnButtonName.Cancel);
                  b.Add().Text("Save").Visible(new JS("function(e){return e.row.isEditing}")).OnClick("saveRecord_AB").Name(GridColumnButtonName.Save);

              });
              columns.Add().DataField("Title").Caption("Title").MinWidth(100).AllowEditing(false);
              columns.Add().DataField("Name").Caption("Name").MinWidth(Request.Browser.IsMobileDevice?100:200);
              columns.Add().DataField("Country").Caption("Country").MinWidth(250).EditCellTemplate(new JS("Country_DropDownBoxTemplate_AddressInfo_dx"));
              columns.Add().DataField("State").Caption("State").MinWidth(275).EditCellTemplate(new JS("State_DropDownBoxTemplate_AddressInfo_dx"));
              columns.Add().DataField("City").Caption("City").MinWidth(210).EditCellTemplate(new JS("City_DropDownBoxTemplate_AddressInfo_dx"));              
              columns.Add().DataField("Organization").Caption("Organization").MinWidth(120).AllowEditing(false);
              columns.Add().DataField("Designation").Caption("Designation").MinWidth(120).AllowEditing(false);
              columns.Add().DataField("Occupation").Caption("Occupation").MinWidth(230).EditCellTemplate(new JS("occupationSelectBoxEditorTemplate_AddressInfo_dx"));
              columns.Add().DataField("Education").Caption("Education").MinWidth(120).EditCellTemplate(new JS("educationSelectBoxEditorTemplate_AddressInfo_dx"));
              columns.Add().DataField("Passport_No").Caption("Passport No.").MinWidth(185);
              columns.Add().DataField("PAN_No").Caption("PAN No.").MinWidth(140).EditCellTemplate(new JS("PANTemplate"));
              columns.Add().DataField("VAT_TIN_No").Caption("VAT TIN No.").MinWidth(150).AllowEditing(false);
              columns.Add().DataField("GST_TIN_No").Caption("GST TIN No.").MinWidth(150).AllowEditing(false);
              columns.Add().DataField("CST_TIN_No").Caption("CST TIN No.").MinWidth(150).AllowEditing(false);
              columns.Add().DataField("TAN_No").Caption("TAN No.").MinWidth(150).AllowEditing(false);
              columns.Add().DataField("UID_No").Caption("Aadhar No.").MinWidth(160).EditCellTemplate(new JS("UIDTemplate"));
              columns.Add().DataField("Service_Tax_Reg_No").Caption("Service Tax Reg. No.").MinWidth(160).AllowEditing(false);
              columns.Add().DataField("Voter_ID").Caption("VOTER ID No.").MinWidth(160);
              columns.Add().DataField("Ration_Card_No").Caption("RATION No.").MinWidth(160).AllowEditing(false);
              columns.Add().DataField("DL_No").Caption("DL No.").MinWidth(160);
              columns.Add().DataField("Taxpayer_ID").Caption("Tax ID No.").MinWidth(160).AllowEditing(false);
              columns.Add().DataField("Address_Line1").Caption("Address Line.1").MinWidth(170).EditCellTemplate(new JS("Add1Template"));
              columns.Add().DataField("Address_Line2").Caption("Address Line.2").MinWidth(170).EditCellTemplate(new JS("Add2Template"));
              columns.Add().DataField("Address_Line3").Caption("Address Line.3").MinWidth(170).EditCellTemplate(new JS("Add3Template"));
              columns.Add().DataField("Address_Line4").Caption("Address Line.4").MinWidth(150).EditCellTemplate(new JS("Add4Template"));
              columns.Add().DataField("PinCode").Caption("Pin Code").MinWidth(100).EditCellTemplate(new JS("NumberBoxTemplate_Pincode_dx"));
              columns.Add().DataField("District").Caption("District").MinWidth(100).AllowEditing(false);
              columns.Add().DataField("Resi_Tel_No").Caption("Resi Tel No(s)").MinWidth(120).AllowEditing(false);
              columns.Add().DataField("Office_Tel_No").Caption("Office Tel No(s)").MinWidth(120).AllowEditing(false);
              columns.Add().DataField("Office_Fax_No").Caption("Office Fax No.").MinWidth(120).AllowEditing(false);
              columns.Add().DataField("Resi_Fax_No").Caption("Resi. Fax No(s").MinWidth(120).AllowEditing(false);
              columns.Add().DataField("Mobile_No").Caption("Mobile No(s)").MinWidth(150).EditCellTemplate(new JS("MobileTemplate"));
              columns.Add().DataField("Email").Caption("Email").MinWidth(240).EditCellTemplate(new JS("EmailTemplate"));
              columns.Add().DataField("Website").Caption("Website").MinWidth(180).AllowEditing(false);
              columns.Add().DataField("Date_of_Birth_Lokik").Caption("Date of Birth (Lokik)").MinWidth(190)
              .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
              columns.Add().DataField("Blood_Group").Caption("Blood Group").MinWidth(120).AllowEditing(false);
              columns.Add().DataField("Status").Caption("Status").EditCellTemplate(new JS("Status_SelectBoxTemplate_AddressInfo_dx")).MinWidth(120);
              columns.Add().DataField("Date_of_Birth_Alokik").Caption("Date of Birth (Alokik)").MinWidth(190)
              .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
              columns.Add().DataField("BK_Title").Caption("BK Title").EditCellTemplate(new JS("Title_SelectBoxTemplate_AddressInfo_dx")).MinWidth(190);
              columns.Add().DataField("BK_PAD_No").Caption("BK PAD No.").MinWidth(100).AllowEditing(false);
              columns.Add().DataField("Class_At").Caption("Class At").MinWidth(100).AllowEditing(false);
              columns.Add().DataField("Centre_Category").Caption("Centre Category").MinWidth(200).EditCellTemplate(new JS("Centre_Category_SelectBoxTemplate_AddressInfo_dx"));
              columns.Add().DataField("Centre_Name").Caption("Centre Name").MinWidth(150).EditCellTemplate(new JS("centreDropdownBoxEditorTemplate_AddressInfo_dx"));
              columns.Add().DataField("Category").Caption("Category").MinWidth(100).AllowEditing(false);
              columns.Add().DataField("Referene").Caption("Referene").MinWidth(200).AllowEditing(false);
              columns.Add().DataField("Remarks").Caption("Remarks").MinWidth(200);
              columns.Add().DataField("Events").Caption("Events").MinWidth(500).AllowEditing(false);
              columns.Add().DataField("Action_By").Caption("Action By").Visible(false).MinWidth(125).AllowEditing(false);
              columns.Add().DataField("Action_Date").Caption("Action Date").Visible(false).MinWidth(125).AllowEditing(false);
              columns.Add().DataField("Action_Status").Caption("Action Status").Visible(false).MinWidth(125).AllowEditing(false);
              columns.Add().DataField("Add_By").Caption("Added By").Visible(false).MinWidth(100).AllowEditing(false);
              columns.Add().DataField("Add_Date").Caption("Added Date").Visible(false).MinWidth(100).AllowEditing(false);
              columns.Add().DataField("Edit_By").Caption("Edited By").Visible(false).MinWidth(100).AllowEditing(false);
              columns.Add().DataField("Edit_Date").Caption("Edited Date").Visible(false).MinWidth(100).AllowEditing(false);
              columns.Add().DataField("ID").Caption("ID").Visible(false).MinWidth(120).AllowEditing(false);
              columns.Add().DataField("REJECTED_COUNT").Caption("iREJECTED_COUNT").Visible(false).MinWidth(120).AllowEditing(false);
              columns.Add().DataField("RESPONDED_COUNT").Caption("iRESPONDED_COUNT").Visible(false).MinWidth(120).AllowEditing(false);
              columns.Add().DataField("COMPLETE_ATTACH_COUNT").Caption("iCOMPLETE_ATTACH_COUNT").Visible(false).MinWidth(120).AllowEditing(false);
              columns.Add().DataField("REQ_ATTACH_COUNT").Caption("iREQ_ATTACH_COUNT").Visible(false).MinWidth(120).AllowEditing(false);
              columns.Add().DataField("OTHER_ATTACH_CNT").Caption("OTHER_ATTACH_CNT").Visible(false).MinWidth(120).AllowEditing(false);
              columns.Add().DataField("ALL_ATTACH_CNT").Caption("ALL_ATTACH_CNT").Visible(false).MinWidth(120).AllowEditing(false);

          })

            .MasterDetail(md =>
            {
                md.AutoExpandAll(false);
                md.Enabled(!VouchingMode);
                md.Template(new JS("AddressListGrid_dx_DetailTemplate"));
            })
            .Editing(editing =>
            {
                if (ShowHorizontalBar == 1)
                {
                    editing.Mode(GridEditMode.Row);
                    editing.AllowAdding(false);
                    editing.AllowDeleting(false);
                    editing.AllowUpdating(true);
                }
                else
                {
                    editing.Mode(GridEditMode.Row);
                    editing.AllowAdding(false);
                    editing.AllowDeleting(false);
                    editing.AllowUpdating(false);
                }
            })
            .OnRowUpdating(@<text> function(e) { AddressBookInfoGrid_RowUpdating(e); } </text>)
            .OnRowUpdated(@<text> function(e) { AddressBookInfoGrid_RowUpdated(e); } </text>)
            @*.OnEditingStart(@<text> function(e) { AddressBookInfoGrid_EditingStart(e); } </text>)*@
            @*.OnEditorPreparing(@<text> function(e) { AddressBookInfoGrid_EditorPreparing(e); } </text>)*@
            .OnEditingStart("AddressBookInfoGrid_EditingStart")

            .OnInitialized("AddressListGrid_dx_OnInitialized")
            .OnCellPrepared("AddressListGrid_dx_OnCellPrepared")
            .OnRowPrepared("AddressListGrid_dx_OnRowPrepared")
            .OnContentReady("AddressListGrid_dx_OnContentReady")
            .OnCellDblClick("AddressListGrid_dx_OnCellDblClick")
            .OnSelectionChanged("AddressListGrid_dx_OnSelectionChanged")
            .OnRowExpanding("AddressListGrid_dx_OnRowExpanding")
            .OnRowCollapsing("AddressListGrid_dx_OnRowCollapsing")
            .OnContextMenuPreparing("AddressListGrid_dx_OnContextMenuPreparing")           

            @*  *@)