    async function GLookUp_RCountryList_EditValueChanged_AB(e, FirstCall = false)
    {
        if (e)
        {
            SelectedCountryId_AB = e.value;
            if ((e.value == null || e.value.length == 0) && e.previousValue != null)
            {
                Country_DG_AB.clearSelection();
                State_DG_AB.clearSelection();
                District_DG_AB.clearSelection();
                City_DG_AB.clearSelection();
                SelectedCountryId_AB = "";
                Country_AccessibleDescription_AB = "";
                LookUp_Get_R_StateList_AB(FirstCall)
                var Txt_Pincode = $("#Txt_R_Pincode_AB").dxTextBox("instance");
                Txt_Pincode.option("mask", '');
                Txt_Pincode.option("maskRules", {});
                Txt_Pincode.option("isValid", true);
                $("#Txt_R_Pincode_AB").find('input').addClass("CleanTextForDB");
                TransformTextForDB("AddressBookForm");
                return;
            }
        }
        else
        {
            SelectedCountryId_AB = $("#GLookUp_RCountryList_AB").dxDropDownBox("option", "value");
        }
        await Country_DG_AB.selectRows(SelectedCountryId_AB)
        if (Country_DG_AB.getSelectedRowsData().length > 0)
        {
            var item = Country_DG_AB.getSelectedRowsData()[0];
            SelectedCountryId_AB = item["R_CO_REC_ID"];
            Country_AccessibleDescription_AB = item["R_CO_CODE"];
            LookUp_Get_R_StateList_AB(FirstCall)
            if (SelectedCountryId_AB != "f9970249-121c-4b8f-86f9-2b53e850809e") //india
            {
                LookUp_Get_R_CityList_AB(FirstCall)
            }
            var Txt_Pincode = $("#Txt_R_Pincode_AB").dxTextBox("instance");
            if (Country_AccessibleDescription_AB == "IN")
            {
                Txt_Pincode.option
                    ({
                        "mask": 'NNNNNN',
                        "maskRules":
