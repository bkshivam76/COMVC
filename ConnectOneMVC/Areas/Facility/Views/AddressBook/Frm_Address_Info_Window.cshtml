<div class="AddressBookWindow_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    @model ConnectOneMVC.Areas.Facility.Models.Address_Book_ViewModel
    <link href="/content/fontawesome/css/fontawesome-all.css" rel="stylesheet">

    @{
        Html.EnableClientValidation();
        Html.EnableUnobtrusiveJavaScript();
        var next_Unaudited_YearID = (int)ViewBag.next_Unaudited_YearID;

        var AB_Asset_Image = ViewBag.ABImage;
        bool IsVisible = Model != null && (Model.ActionMethod.ToString().Trim() == "_View" || Model.ActionMethod.ToString().Trim() == "_Delete") ? true : false;
    }

    <style>
        .control-label {
            text-align: left !important;
        }
    </style>

    <div id="AddressInfoWindow">
        @using (Ajax.BeginForm("Frm_Address_Info_Window", "Facility",
                                                    new AjaxOptions
                                                    {
                                                        HttpMethod = "POST",
                                                        UpdateTargetId = "AddressInfoWindow",
                                                        InsertionMode = InsertionMode.InsertAfter,
                                                        OnBegin = "AjaxBeginFormPost",
                                                        OnSuccess = String.Format("{0}", Model.PostSuccessFunction)
                                                    },
                                            new
                                            {
                                                id = "AddressBookForm",
                                                @class = "edit_form"
                                            }))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(x => x.TempActionMethod)
            @Html.HiddenFor(x => x.ActionMethod)
            @Html.HiddenFor(x => x.ID)
            @Html.HiddenFor(x => x.Rec_ID)
            @Html.HiddenFor(x => x.LastEditedOn)
            @Html.HiddenFor(x => x.Info_LastEditedOn)
            @Html.HiddenFor(x => x.Org_RecID)
            @Html.HiddenFor(x => x.PostSuccessFunction)
            @Html.HiddenFor(x => x.PopUpId)
            @Html.HiddenFor(x => x.Party_DataGridID)
            @Html.HiddenFor(x => x.NewFunctionName)
            @Html.HiddenFor(x => x.DropDownFunctionName)
            @Html.HiddenFor(x => x.Replicate_Confirm)
            @Html.HiddenFor(x => x.New_Confirm)
            @Html.HiddenFor(x => x.Edit_Confirm)
            using (Html.DevExtreme().ValidationGroup("AddressBookValidator"))

            {
                <div class="full-width-header-bg3">
                    <div class="row">
                        <div class="col-xs-4 pll">
                            <h3 class="popuphead"><i class="far fa-edit"></i>Contact </h3>
                        </div>
                        <div class="col-sm-8 prl">
                            <div id="div-lbl-contact" class="popuphead"><span id="Lbl_ContactName_AB"></span></div>
                        </div>
                    </div>
                </div>
                <div class="form-horizontal">
                    <div>
                        @(Html.DevExtreme().TabPanel().ID("tabPanel_AB")
                    .Items(items =>
                    {
                    items.Add().Title("Basic").Template(@<text>  @Html.Partial("Frm_Basic_tab", Model) </text>);
                    items.Add().Title("Address").Template(@<text> @Html.Partial("Frm_Address_tab", Model) </text>);
                    items.Add().Title("Contact").Template(@<text> @Html.Partial("Frm_Contacts_tab", Model) </text>);
                    items.Add().Title("General").Template(@<text> @Html.Partial("Frm_General_tab", Model) </text>);
                    items.Add().Title("Status").Template(@<text> @Html.Partial("Frm_Status_tab", Model) </text>);
                    items.Add().Title("Special").Template(@<text> @Html.Partial("Frm_Special_tab", Model) </text>);
                    }).DeferRendering(false))
                    </div>
                </div>
            }
        }
    </div>
    <script>
    function Look_TitleList_EditValueChanged_AB(e)
    {
        var Name = $("#Txt_Name_AB").dxTextBox("instance").option("value") == null ? "" : $("#Txt_Name_AB").dxTextBox("instance").option("value");
        var Title = $("#Look_TitleList_AB").dxSelectBox("instance").option("value") == null ? "" : $("#Look_TitleList_AB").dxSelectBox("instance").option("value");
        try
        {
            $("#Lbl_ContactName_AB").text(Title + " " + Name);
        }
