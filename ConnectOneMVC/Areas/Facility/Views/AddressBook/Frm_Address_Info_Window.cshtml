                cache: false,
                data: { CountryCode: Country_AccessibleDescription_AB },
                success: function (_data) {
                    $("#GLookUp_RStateList_AB").dxDropDownBox("option", "dataSource", new DevExpress.data.ArrayStore({
                        key: "R_ST_REC_ID",
                        data: _data
                    }))
                    State_DG_AB.option("dataSource", $("#GLookUp_RStateList_AB").dxDropDownBox("option", "dataSource"))
                }
            });
