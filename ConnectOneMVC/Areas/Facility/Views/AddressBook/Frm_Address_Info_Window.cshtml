                        WaitForCityDDToLoad(dd_value);
                    }, 500)
                }
            }
            CheckIfAllCompletedTohideLoader();
            function CheckIfAllCompletedTohideLoader()
            {
                var complete = 0;
                if ($("#GLookUp_RDistrictList_AB").dxDropDownBox("instance").option("value") == $("#GLookUp_ODistrictList_AB").dxDropDownBox("instance").option("value")) { complete++; }
                if ($("#GLookUp_RCityList_AB").dxDropDownBox("instance").option("value") == $("#GLookUp_OCityList_AB").dxDropDownBox("instance").option("value")) { complete++; }
                if ($("#GLookUp_RStateList_AB").dxDropDownBox("instance").option("value") == $("#GLookUp_OStateList_AB").dxDropDownBox("instance").option("value")) { complete++; }
                if (complete == 3)
                {
                    HideLoader();
                }
                else {
                    setTimeout(function () {
                        CheckIfAllCompletedTohideLoader();
                    }, 300)
                }
            }
        }
