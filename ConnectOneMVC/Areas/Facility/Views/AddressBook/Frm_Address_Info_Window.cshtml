                WaitForStateDDToLoad($("#GLookUp_RStateList_AB").dxDropDownBox("instance").option("value"));
            }
            async function WaitForStateDDToLoad(dd_value)
            {
                var result = CheckIFDDHasValue_AB(State_O_DG_AB, dd_value);
                if (result)
                {
                    State_O_DG_AB.selectRows(dd_value, false);
                    $("#GLookUp_OStateList_AB").dxDropDownBox("instance").option("readOnly", false);
                }
                else
                {
