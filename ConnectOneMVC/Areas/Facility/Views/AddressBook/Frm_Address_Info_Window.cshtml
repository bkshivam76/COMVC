    function CheckIFDDHasValue_AB(DG_instance, value)
    {
        var DS = DG_instance.getDataSource();
        if (DS === void 0) { return false; }
        var keyfield = DS.store().key();
        var items = DS._store._array;
        if (items == null || items.length == 0){return false;}
        var index= items.findIndex(x => x[keyfield]==value)
        return index==-1?false:true;
    }
