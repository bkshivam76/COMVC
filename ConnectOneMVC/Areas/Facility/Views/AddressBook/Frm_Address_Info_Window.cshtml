    function AB_FileUpload_Value_Change(e)
    {
        if (e.value[0] != null)
        {
            var filename = e.value[0].name;
            var fileExt = (filename.split('.'))[1];
            if (fileExt.Length <= 1) {
                DevExpress.ui.dialog.alert('File Without Extension Is Not Allowed...', 'Error!!');
                return;
            }
            var AllowedExtension = ["jpg", "jpeg", "png"];
            if (AllowedExtension.indexOf(fileExt) == -1) {
                DevExpress.ui.dialog.alert('Only Files With jpg,jpeg,png Extension Is Allowed..', 'Error!!');
                return;
            }
        }
    }
    function AB_FileUploaded(e)
    {
        $("#AB_fileview").load("@Url.Action("AB_PreviewImageControl", "AddressBook", new { @area = "Facility" })", function () { });
        $("#AB_fileRemove").show();
    }
    function ABImageDelete(e)
    {
        $.ajax({
            type: 'GET',
            url: "/Facility/AddressBook/RemoveABImage",
            cache: false,
            success: function ()
            {
                $("#AB_file-uploader").dxFileUploader("instance").reset();
               $("#AB_fileview").load("@Url.Action("AB_PreviewImageControl", "AddressBook", new { @area = "Facility" })", function () { });
                $("#AB_fileRemove").hide();
            }
        });
    }
    function EducationCustomItemCreating_AB(e)
    {
        if (e.text == null || e.text.length == 0) {
            e.customItem = null;
            return;
        }
        var dataSource = e.component.getDataSource();

        var newID = createGuid();
        var newItem = { C_TITLE_NAME: e.text, C_TITLE_ID: newID };
        var result = dataSource.store().insert(newItem);

        result.done(function () {
            dataSource.reload();
        })
        e.customItem = result;
    }
