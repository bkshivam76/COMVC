    function AB_SaveClick(e)
    {
        var result = e.validationGroup.validate();
        if (result.isValid) {
            if (ActionMethod_AB == "_Delete") {
                var confirm = DevExpress.ui.dialog.confirm("Sure You Want To Delete This Entry...?", "Confirm");
                confirm.done(function (result) {
                    if (result) {
                        $("#AddressBookForm").submit();
                    }
                });
            }
            else {
                if (ActionMethod_AB == "_Edit") {
                    if (parseInt("@next_Unaudited_YearID") != 0) {
                        var confirm = DevExpress.ui.dialog.confirm("Do You Want To Make Same Changes In This Contact in Year " + "@next_Unaudited_YearID".substring(0, 2) + "-" + "@next_Unaudited_YearID".substring(2) + " too?", "Confirm");
                        confirm.done(function (result) {
                            if (result) {
                                $("#Replicate_Confirm").val(true);
                                $("#AddressBookForm").submit();
                            }
                            else {
                                $("#Replicate_Confirm").val(false);
                                $("#AddressBookForm").submit();
                            }
                        });
                    }
                    else {
                        $("#AddressBookForm").submit();
                    }
                }
                else {
                    $("#AddressBookForm").submit();
                }
            }
        }
        else //Redmine Bug #134089 fixed
        {
            var ElementParentClass = result.brokenRules[0].validator._$element[0].parentElement.className;
            if (ElementParentClass.includes("Tab0_AB")) {
                $("#tabPanel_AB").dxTabPanel("instance").option("selectedIndex", 0);
            }
            else if (ElementParentClass.includes("Tab1_AB")) {
                $("#tabPanel_AB").dxTabPanel("instance").option("selectedIndex", 1);
            }
            else if (ElementParentClass.includes("Tab2_AB")) {
                $("#tabPanel_AB").dxTabPanel("instance").option("selectedIndex", 2);
            }
            else if (ElementParentClass.includes("Tab3_AB")) {
                $("#tabPanel_AB").dxTabPanel("instance").option("selectedIndex", 3);
            }
            else if (ElementParentClass.includes("Tab4_AB")) {
                $("#tabPanel_AB").dxTabPanel("instance").option("selectedIndex", 4);
            }
            else if (ElementParentClass.includes("Tab5_AB")) {
                $("#tabPanel_AB").dxTabPanel("instance").option("selectedIndex", 5);
            }
        }
    }
    function AjaxSuccessAddressBook(data)
    {
        AddressBook_Window_save_Success(data, "@Model.ActionMethod", "@Model.NewFunctionName", "@Model.DropDownFunctionName", "@Model.Party_DataGridID")
    }
    async function AB_ClosePopUP(Xid="")
    {
        if ($("#AddressListGrid").length == 0 || AllOpenControlTabs.includes("Frm_Address_Info"))
        {
            if ("@Model.DropDownFunctionName".length > 0)
            {
                var fn = window["@Model.DropDownFunctionName"];
                if (typeof fn == "function")
                {
                    if ("@Model.DropDownFunctionName" == "LookUp_GetPartyList_PaymentItem" || "@Model.DropDownFunctionName" == "RefreshAdmin_ServiceProject")
                    {
                        if (Xid.length > 0)
                        {
                            fn(Xid);
                        }
                        else
                        {
                            fn();
                        }
                    }
                    else
                    {
                        fn();
                    }
                    RefreshAddressBookGrid_AddressBook()
                    close_AddressBook();
                }
            }
            else if ("@Model.Party_DataGridID".length > 0)
            {
                var DatagridID = "#" + "@Model.Party_DataGridID";
                await $(DatagridID).dxDataGrid("instance").refresh();
                RefreshAddressBookGrid_AddressBook()
                close_AddressBook();
            }
            else
            {
                RefreshAddressBookGrid_AddressBook()
                close_AddressBook();
            }
        }
        else
        {
            RefreshAddressBookGrid_AddressBook()
            close_AddressBook();
        }
    }
    function RefreshAddressBookGrid_AddressBook()
    {
        var GridInstance = $('#AddressListGrid_dx').data("dxDataGrid")
        if (GridInstance !== void 0)
        {
            AddressListGrid_dx_Refresh();
        }
        else
        {
            if (typeof AddressListGrid !== "undefined" && ASPxClientUtils.IsExists(AddressListGrid) && AddressListGrid.GetMainElement())
            {
                RefreshGridView("AddressListGrid")
            }
        }
    }
    function close_AddressBook()
    {
        var popupid = "#" + "@Model.PopUpId";
        $(popupid).dxPopup("hide");
    }
    $(function ()
    {
        $("#" + "@Model.PopUpId").dxPopup({
            onHiding: function (e)
            {
                if (AB_TakepopUpcloseConfirmation == false)
                {
                    $.ajax({
                        type: 'GET',
                        url: "/Facility/AddressBook/SessionClear_Window",
                        cache: false
                    });
                }
                else
                {
                    e.cancel = true;
                    var result = DevExpress.ui.dialog.confirm("Are you sure to cancel this entry...?", "Confirm changes");
                    result.done(function (dialogResult)
                    {
                        AB_TakepopUpcloseConfirmation = !dialogResult;
                        if (dialogResult)
                        {
                            $("#" + "@Model.PopUpId").dxPopup("hide");
                        }
                    });
                }
            }
        });
    });
