    function AddCustomDatatoDesignation()
    {
        var Txt_Desig_AB = $("#Txt_Desig_AB").dxSelectBox("instance");
        var dataSource = Txt_Desig_AB.getDataSource();
        var dataItems = dataSource.items();

        var flag = false;
        for (var i = 0; dataItems.length > i; i++)
        {
            if (dataItems[i].C_TITLE_NAME == "@Model.Txt_Desig_AB")
            {
                flag = true;
                break;
            }
        }
        if (flag == true)
        {
            Txt_Desig_AB.option("value", "@Model.Txt_Desig_AB");
        }
        else
        {
            var newID = createGuid();
            var newItem = { C_TITLE_NAME: "@Model.Txt_Desig_AB", C_TITLE_ID: newID };
            var result = dataSource.store().insert(newItem);

            result.done(function ()
            {
                dataSource.reload();
                Txt_Desig_AB.option("value", "@Model.Txt_Desig_AB");
            })
        }
    }
