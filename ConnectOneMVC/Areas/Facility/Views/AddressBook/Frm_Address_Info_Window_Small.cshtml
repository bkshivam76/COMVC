<script>
    function ClosePopUp_ABSmall(e)
    {
        HidePopup("@Model.PopUpId");
    }
    function ABSmall_SaveClick(e)
    {
        if (ActionMethod_ABSmall == "_Delete")
        {
            var confirm = DevExpress.ui.dialog.confirm("Sure You Want To Delete This Entry...?", "Confirm");
            confirm.done(function (result)
            {
                if (result)
                {
                    $("#AddressBookSmallForm").submit();
                }
            });
        }
        else
        {
            if (ActionMethod_ABSmall == "_Edit")
            {
                if (parseInt("@next_Unaudited_YearID") != 0)
                {                  
                    var confirm = DevExpress.ui.dialog.confirm("Do You Want To Make Same Changes In This Contact in Year " + "@next_Unaudited_YearID".substring(0, 2) + "-" + "@next_Unaudited_YearID".substring(2) + " too?", "Confirm");
                    confirm.done(function (result)
                    {
                        if (result)
                        {
                            $("#Replicate_Confirm").val(true);
                            $("#AddressBookSmallForm").submit();
                        }
                        else
                        {
                            $("#Replicate_Confirm").val(false);
                            $("#AddressBookSmallForm").submit();
                        }
                    });
                }
                else
                {
                    $("#AddressBookSmallForm").submit();
                }
            }
            else
            {
                $("#AddressBookSmallForm").submit();
            }
        }
    }
    function AddressBookSmallSuccessForm(data)
    {
        ABSmall_TakePopupCloseConfirmation = false;
        HideLoader();
        if (data.jsonParam.result == false)
        {
            if (data.jsonParam.isconfirm == true)
            {
                var confirm = DevExpress.ui.dialog.confirm(data.jsonParam.message, data.jsonParam.title);
                confirm.done(function (dialogResult)
                {
                    if (dialogResult)
                    {
                        if (ActionMethod_ABSmall == "_New")
                        {
                            $("#New_Confirm").val(true);
                        }
                        else if (ActionMethod_ABSmall == "_Edit")
                        {
                            $("#Edit_Confirm").val(true);
                        }
                        $("#AddressBookSmallForm").submit();
                    }
                });
            }
            else
            {
                var alert = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                alert.done(function (dialogResult)
                {
                    if (data.jsonParam.focusid != null)
                    {
                        if (dialogResult)
                        {
                            var id = "#" + data.jsonParam.focusid;
                            setTimeout(function ()
                            {
                                $(id).find('input').focus();
                            }, Timeout100);
                        }
                    }
                });
            }
        }
        else
        {
            
            if ("@Model.DropDownFunctionName".length > 0)
            {
                var fn = window["@Model.DropDownFunctionName"];
                if (typeof fn == "function")
                {
                    fn(data.xid);
                }
            }
            else if ("@Model.Party_DataGridID".length > 0)
            {
                var DatagridID = "#" + "@Model.Party_DataGridID";
                $(DatagridID).dxDataGrid("instance").refresh();
            }
            if ("@CallingScreen".trim() != "CoreProfile_RegisterForAudit" && "@CallingScreen".trim() != "CoreProfile_")
            {          
                DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
            }

        }
        if (data.jsonParam.closeform)
        {
            ClosePopUp_ABSmall();
        }
    }
</script>@* Save & Save Success *@
    </div>


















      

            <script>
                $("#ResTel1, #ResTel2, #ResFax1, #ResFax2, #OffTel1, #OffTel2, #OffFax1, #OffFax2, #Mob1, #Mob2").keypress(function (e) {
                    e = e || window.event;
                    key = e.keyCode || e.which;
                    //For Firefox
                    if (key == 8 || key == 127 || key == 9)
                        return true
                    var txt = String.fromCharCode(key);
                    var reg = /[0-9]/;
                    if (reg.test(txt))
                        return true;

                    e.preventDefault();
                    return false;

                });
