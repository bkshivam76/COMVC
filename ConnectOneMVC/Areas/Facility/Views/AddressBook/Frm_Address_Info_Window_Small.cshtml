<script>
    var Country_DG_ABSmall;
    var State_DG_ABSmall;
    var District_DG_ABSmall;
    var City_DG_ABSmall;
    var ActionMethod_ABSmall = "@Model.ActionMethod";
    function InitAllDropDown_ABSmall()
    {
        var $Country_DG_ABSmall = $("#CountryList-datagrid_ABSmall");
        if ($Country_DG_ABSmall.length)
        {
            Country_DG_ABSmall = $Country_DG_ABSmall.dxDataGrid("instance");
        }
        var $State_DG_ABSmall = $("#StateList-datagrid_ABSmall");
        if ($State_DG_ABSmall.length)
        {
            State_DG_ABSmall = $State_DG_ABSmall.dxDataGrid("instance");
        }
        var $District_DG_ABSmall = $("#DistrictList-datagrid_ABSmall");
        if ($District_DG_ABSmall.length)
        {
            District_DG_ABSmall = $District_DG_ABSmall.dxDataGrid("instance");
        }
        var $City_DG_ABSmall = $("#CityList-datagrid_ABSmall");
        if ($City_DG_ABSmall.length) {
            City_DG_ABSmall = $City_DG_ABSmall.dxDataGrid("instance");
        }
    }
    async function LookUp_GetCountryList_ABSmall()
    {
        var $Country_DG_ABSmall = $("#CountryList-datagrid_ABSmall");
        if ($Country_DG_ABSmall.length) {
            Country_DG_ABSmall = $Country_DG_ABSmall.dxDataGrid("instance");
            var ddRefresh = false;
            $.ajax({
                type: 'GET',
                url: "/Facility/AddressBook/RefreshCountryList_ABSmall",
                cache: false,
                async: false,
                success: function (data)
                {
                    ddRefresh = data.result;
                    if (data.result == false)
                    {
                        DevExpress.ui.dialog.alert(data.message, "Error..");
                    }
                }
            });
            if (ddRefresh)
            {
                await Country_DG_ABSmall.refresh();
                if (ActionMethod_ABSmall == "_New")
                {
                    await Country_DG_ABSmall.selectRows("f9970249-121c-4b8f-86f9-2b53e850809e", false);
                    Control_SetReadOnly("GLookUp_RCountryList_ABSmall", "dxDropDownBox", false);
                }
            }
        }
    }
    async function LookUp_Get_R_StateList_ABSmall()
    {
        var $State_DG_ABSmall = $("#StateList-datagrid_ABSmall");
        if ($State_DG_ABSmall.length) {
            State_DG_ABSmall = $State_DG_ABSmall.dxDataGrid("instance");
            var ddRefresh = false;
            $.ajax({
                type: 'GET',
                url: "/Facility/AddressBook/RefreshStateList_ABSmall",
                cache: false,
                async: false,
                data:
                {
                    CountryAccessibleDescription: Country_AccessibleDescription_ABSmall
                },
                success: function (data)
                {
                    ddRefresh = data.result;
                    if (data.result == false)
                    {
                        DevExpress.ui.dialog.alert(data.message, "Error..");
                    }
                }
            });
            if (ddRefresh)
            {
                await State_DG_ABSmall.refresh();
                if (ActionMethod_ABSmall == "_New") {
                   
                    Control_SetReadOnly("GLookUp_RStateList_ABSmall", "dxDropDownBox", false);
                }
            }
        }
    }
    async function LookUp_Get_R_DistrictList_ABSmall()
    {        
        var $District_DG_ABSmall = $("#DistrictList-datagrid_ABSmall");
        if ($District_DG_ABSmall.length)
        {
            District_DG_ABSmall = $District_DG_ABSmall.dxDataGrid("instance");
            var ddRefresh = false;
            $.ajax({
                type: 'GET',
                url: "/Facility/AddressBook/RefreshDistrictList_ABSmall",
                cache: false,
                async: false,
                data:
                {
                    CountryAccessibleDescription: Country_AccessibleDescription_ABSmall,
                    StateAccessibleDescription: State_AccessibleDescription_ABSmall
                },
                success: function (data)
                {
                    ddRefresh = data.result;
                    if (data.result == false)
                    {
                        DevExpress.ui.dialog.alert(data.message, "Error..");
                    }
                }
            });
            if (ddRefresh)
            {
                await District_DG_ABSmall.refresh();
                if (ActionMethod_ABSmall == "_New")
                {
                    Control_SetReadOnly("GLookUp_RDistrictList_ABSmall", "dxDropDownBox", false);
                }
            }
        }
    }
    async function LookUp_Get_R_CityList_ABSmall()
    {
        var $City_DG_ABSmall = $("#CityList-datagrid_ABSmall");
        if ($City_DG_ABSmall.length)
        {
            City_DG_ABSmall = $City_DG_ABSmall.dxDataGrid("instance");
            var ddRefresh = false;
            $.ajax({
                type: 'GET',
                url: "/Facility/AddressBook/RefreshCityList_ABSmall",
                cache: false,
                async: false,
                data:
                {
                    CountryID: SelectedCountryId_ABSmall,
                    CountryAccessibleDescription: Country_AccessibleDescription_ABSmall,
                    StateAccessibleDescription: State_AccessibleDescription_ABSmall
                },
                success: function (data)
                {
                    ddRefresh = data.result;
                    if (data.result == false)
                    {
                        DevExpress.ui.dialog.alert(data.message, "Error..");
                    }
                }
            });
            if (ddRefresh)
            {
                await City_DG_ABSmall.refresh();
                if (ActionMethod_ABSmall == "_New")
                {
                    Control_SetReadOnly("PC_City_Name_ABSmall", "dxDropDownBox", false);
                }
            }
        }
    }
</script>@* dd init *@
<script>
    var SelectedCountryId_ABSmall;
    var Country_AccessibleDescription_ABSmall;
    var State_AccessibleDescription_ABSmall;
    var CountryDDValueChangeFinishExecution = false;
    var StateDDValueChangeFinishExecution = false;
    function GLookUp_RCountryList_EditValueChanged(e)
    {
        CountryDDValueChangeFinishExecution = false;
        e.component.close();
        if (e.value == null && e.previousValue != null)
        {
            Country_DG_ABSmall.clearSelection();
            State_DG_ABSmall.clearSelection();
            District_DG_ABSmall.clearSelection();
            City_DG_ABSmall.clearSelection();
            $("#PC_City_Name_Text_ABSmall").val("");
            SelectedCountryId_ABSmall = "";
            Country_AccessibleDescription_ABSmall = "";
            CountryDDValueChangeFinishExecution = true;
            return;
        }
        if (Country_DG_ABSmall.getSelectedRowsData().length > 0)
        {
            var item = Country_DG_ABSmall.getSelectedRowsData()[0];
            SelectedCountryId_ABSmall = item["R_CO_REC_ID"];
            Country_AccessibleDescription_ABSmall = item["R_CO_CODE"];
            Promise.all([LookUp_Get_R_StateList_ABSmall(), LookUp_Get_R_CityList_ABSmall()]).then((r) =>
            {
                var Txt_Pincode = $("#Txt_R_Pincode_ABSmall").dxTextBox("instance");             
                if (item["R_CO_CODE"] == "IN")
                {
                    Txt_Pincode.option
                        ({
                            "mask": 'NNNNNN',
                            "maskRules":
                            {
                                'N': /[0-9]/
                            }
                        });
                    Txt_Pincode.option("isValid", true);
                }
                else
                {
                    Txt_Pincode.option("mask", '');
                    Txt_Pincode.option("maskRules", {});
                    Txt_Pincode.option("isValid", true);
                }
                CountryDDValueChangeFinishExecution = true;
            });
        }
    }
    function GLookUp_RStateList_EditValueChanged(e)
    {      
        StateDDValueChangeFinishExecution = false;
        e.component.close();
        if (e.value == null && e.previousValue != null)
        {
            State_DG_ABSmall.clearSelection();           
            District_DG_ABSmall.clearSelection();
            City_DG_ABSmall.clearSelection();
            $("#PC_City_Name_Text_ABSmall").val("");
            State_AccessibleDescription_ABSmall = "0";
            LookUp_Get_R_DistrictList_ABSmall();
            LookUp_Get_R_CityList_ABSmall();
            StateDDValueChangeFinishExecution = true;
            return;
        }
        if (State_DG_ABSmall.getSelectedRowsData().length > 0)
        {
            var item = State_DG_ABSmall.getSelectedRowsData()[0];
            State_AccessibleDescription_ABSmall = item["R_ST_CODE"];
            Promise.all([LookUp_Get_R_DistrictList_ABSmall(), LookUp_Get_R_CityList_ABSmall()]).then((r) =>
            {            
                StateDDValueChangeFinishExecution = true;
            });
        }
    }
    function GLookUp_RDistrictList_EditValueChanged(e)
    {
        e.component.close();
        if (e.value == null && e.previousValue != null)
        {  
            District_DG_ABSmall.clearSelection();
            return;
        }
    }
    function GLookUp_RCityList_EditValueChanged(e)
    {
        e.component.close();
        if (e.value == null && e.previousValue != null)
        {
            City_DG_ABSmall.clearSelection();
            $("#PC_City_Name_Text_ABSmall").val("");
            return;
        }
        if (City_DG_ABSmall.getSelectedRowsData().length > 0)
        {
            var item = City_DG_ABSmall.getSelectedRowsData()[0];
            $("#PC_City_Name_Text_ABSmall").val(item["R_CI_NAME"]);
        }
    }
    function Txt_Name_EditValueChanged_ABSmall(e)
    {
        $("#LBl_ContactName_Div").text(e.value);
    }
</script>@* Value Chnage *@
<script>
    var ABSmall_TakePopupCloseConfirmation = true;
    $(document).ready(function ()
    {
        ShowLoader_Ready();
        var form = "AddressBookSmallForm";
        AssignIDtoLabel(form, "ABSmall");
        InitAllDropDown_ABSmall();
        if (ActionMethod_ABSmall == "_View")
        {
            ABSmall_TakePopupCloseConfirmation = false;
        }
        if (ActionMethod_ABSmall == "_Delete")
        {
            $("#BUT_CANCEL_ABSMALL").dxButton("instance").option("text", "No");
            $("#BUT_SAVE_ABSMALL").dxButton("instance").option("text", "Yes");
            Set_Properties_ABSmall(false, true);
        }
        LookUp_GetCountryList_ABSmall().then((r) =>
        {
            if (ActionMethod_ABSmall == "_Delete" || ActionMethod_ABSmall == "_Edit" || ActionMethod_ABSmall == "_New")
            {
                if ("@Model.GLookUp_RCountryList_ABSmall".length > 0) {
                    Country_DG_ABSmall.selectRows("@Model.GLookUp_RCountryList_ABSmall", false);
                }
                else { CountryDDValueChangeFinishExecution = true; }
                $("#GLookUp_RCountryList_ABSmall").dxDropDownBox("instance").option("readOnly", false);
                WaitForCountryDDToGetOver();
                function WaitForCountryDDToGetOver()
                {
                    HideLoader();
                    ShowLoader();
                    if (CountryDDValueChangeFinishExecution == true)
                    {
                        if ("@Model.GLookUp_RStateList_ABSmall".length > 0)
                        {
                            State_DG_ABSmall.selectRows("@Model.GLookUp_RStateList_ABSmall", false);
                        }
                        else { StateDDValueChangeFinishExecution = true; }
                        HideLoader();
                    }
                    else
                    {
                        setTimeout(function ()
                        {
                            WaitForCountryDDToGetOver();
                        }, Timeout100)
                    }
                }
                $("#GLookUp_RStateList_ABSmall").dxDropDownBox("instance").option("readOnly", false);

                WaitForStateDDToGetOver();
                function WaitForStateDDToGetOver()
                {
                    HideLoader();
                    ShowLoader();
                    if (StateDDValueChangeFinishExecution == true)
                    {
                        if ("@Model.GLookUp_RDistrictList_ABSmall".length > 0)
                        {
                            District_DG_ABSmall.selectRows("@Model.GLookUp_RDistrictList_ABSmall", false);
                        }

                        if ("@Model.PC_City_Name_ABSmall".length > 0)
                        {
                            City_DG_ABSmall.selectRows("@Model.PC_City_Name_ABSmall", false);
