        function AddressListGrid_dx_OnRowPrepared(e)
        {
            if (e.rowType == "data")
            {
                var GridName = e.element[0].id;
                var keyvalue = e.key != null ? e.key.replace(/^0-9A-Za-z/gi, "_") : "Null" + e.rowIndex;
                $(e.rowElement).addClass(GridName + "_DataRow_" + keyvalue)
                DxGrid_CreatePreviewRow(e, AddressBook_IsVouchingMode_dx, "Master", null, keyvalue)
            } else if (e.rowType == "detailAdaptive") {
                DxGrid_MovePreviewRowAfterAdaptiveRow(e)
            }
