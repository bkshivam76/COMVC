        async function getChangedData_AB(oldData, newData) {
            var changedData = {};
            var result = false;
            let userProfileKeyArray = ["ID", "Replicate_Confirm", "PinCode"];
            if (parseInt("@next_Unaudited_YearID") != 0) {
                result = await DevExpress.ui.dialog.confirm("Do You Want To Make Same Changes In This Contact in Year " + "@next_Unaudited_YearID".substring(0, 2) + "-" + "@next_Unaudited_YearID".substring(2) + " too?", "Confirm");
            }
            userProfileKeyArray.forEach(key => {
                if (!newData.hasOwnProperty(key)) {
                    newData[key] = oldData[key];
                }
                if (key === "Replicate_Confirm" && confirm !== null) {
                    newData[key] = result;
                }
                else if (key.includes("ID")) {
                    changedData[key] = oldData[key];
                }
                else if (key.includes("PinCode")) {
                    changedData[key] = oldData[key];
                }
            });
            // Iterate through the new data
            for (var key in newData) {
                // Check if the value has changed
                if (oldData[key] !== newData[key]) {
                    changedData[key] = newData[key];
                }
            }
            return changedData;
        }
