                //width: 400,
                showClearButton: true,
                value: GetValueCentreDD_Template_AB(cellInfo),
                deferRendering: false,
                contentTemplate: function (e, element) {
                    let dataGridEl = $("<div>");
                    $("<div id='Centre_dd_AddressInfo_dg_dx" + cellInfo.key + "'>").dxDataGrid({
                        dataSource: e.component.option("dataSource"),
                        hoverStateEnabled: true,
                        height: 350,
                        showBorders: true,
                        scrolling: { mode: "infinite" }, // Enable infinite scrolling
                        columns: [
                            { dataField: "CEN_NAME", caption: "Centre", width: 150 },
                            { dataField: "CEN_BK_PAD_NO", caption: "Cert No.", width: 50 },
                            { dataField: "CEN_INCHARGE", caption: "Incharge", width: 100 },
                            { dataField: "CEN_ZONE_ID", caption: "Zone", width: 20 }
                        ],
                        selection: { mode: "single" },
                        filterRow: { visible: true },
                        onSelectionChanged(selectedItems) {
                            var keys = selectedItems.selectedRowKeys;
                            var DDvalue = e.component.option('value');
                            if (keys != DDvalue && keys.length>0) { e.component.option('value', keys[0]); }
                            e.component.close();
                        }
                    }).appendTo(dataGridEl);
                    element.append(dataGridEl);
                },
                onInitialized: async function (e) {
                    let data = await e.component.option("dataSource").store().load();
                    let IsOverseasCentre = IsOverseasCentre_AB(cellInfo);
                    if (IsOverseasCentre) {
                        overseas_Centre_AddressInfo_dx = data;
                        let value = e.component.option("value");
                        if (value != null) {
                            e.component.option("readOnly", false);
                            await Centre_ValueChange_AB(null, cellInfo)
                        }
                        else {
                            var centre_rec_id = GetValueCentreDD_Template_AB(cellInfo)
                            if (centre_rec_id) {
                                e.component.option("value", centre_rec_id)
                            }
                        }
                    }
                    else {
                        centre_AddressInfo_dx = data;
                        let value = e.component.option("value");
                        if (value != null) {
                            e.component.option("readOnly", false);
                            await Centre_ValueChange_AB(null, cellInfo)
                        }
                        else {
