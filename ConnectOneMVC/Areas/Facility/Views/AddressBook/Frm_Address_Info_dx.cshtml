        function centreDropdownBoxEditorTemplate_AddressInfo_dx(cellElement, cellInfo) {
            let centreDropDownBox = $("<div id='Centre_dd_AddressInfo_dx" + cellInfo.key + "'>").dxDropDownBox({
                dataSource: getCentreDataSource_AB(cellInfo),
                valueExpr: "CEN_ID",
