    <script>
        $(function ()
        {

            if ("@CalledFromOtherScreen".length > 0)
            {

                if ("@CalledFromOtherScreen" != "Dynamic_Content_popup")
                {
                    $("#" + "@CalledFromOtherScreen").dxPopup({
                        onHiding: function (e)
                        {
                            e.cancel = !Close_AddressBookInfo;
                            if (Close_AddressBookInfo)
                            {
                                $.ajax({
                                    type: 'GET',
                                    url: "/Facility/AddressBook/SessionClear",
                                    cache: false
                                });
                                if ("@PartyRefreshFunction".length > 0)
                                {
                                    var fn = window["@PartyRefreshFunction"];
                                    if (typeof fn == "function")
                                    {
                                        fn();
                                    }
                                }
                                if (AddressBook_IsVouchingMode_dx == true)
                                {
                                    ClearLeftPane();
                                    CloseLeftPane();
                                    ClearRightPane();
                                    CloseRightPane();
                                }
                            }
                            else
                            {
                                setTimeout(function ()
                                {
                                    closeAddressBook_dx();
                                })
                            }
                        }
                    });
                }
            }
            $(".TabPanalMenu-tabs .active span").on("click", function (e)
            {
                if (Close_AddressBookInfo == false)

                {
                    e.stopImmediatePropagation();
                    closeAddressBook_dx()
                }
                else
                {
                    $.ajax({
                        type: 'GET',
                        url: "/Facility/AddressBook/SessionClear",
                        cache: false
                    });
                    CloseRightPane();
                    ClearLeftPane();
                    CloseLeftPane();
                    DxGrid_EventsOnScreenClose(AddressListGrid_dx);
                    ClearAllReferences_AddressBook_dx();
                }
            });
        });

        function closeAddressBook_dx()
        {
            Close_AddressBookInfo = true;
            if (AddressListGrid_dx.hasEditData())
            {
                var confirm = DevExpress.ui.dialog.confirm("Are you sure you wish to close window? <b>Unsaved changes will be lost</b>.", "Alert");
                confirm.done(function (dialogResult)
                {
                    Close_AddressBookInfo = dialogResult;
                    if (dialogResult)
                    {
                        close_AB_Info();
                    }
                });
            }
            else
            {
                close_AB_Info();
            }
        }
        function close_AB_Info()
        {
               DxGrid_EventsOnScreenClose(AddressListGrid_dx);
            if ("@CalledFromOtherScreen".length > 0)
            {
                var popupid = "#" + "@CalledFromOtherScreen";
                $(popupid).dxPopup("hide");
            }
            else
            {
                btnCloseActiveTab();
            }
        }
