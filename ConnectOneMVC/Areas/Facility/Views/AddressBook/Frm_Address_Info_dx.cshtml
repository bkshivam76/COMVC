        function AddressListGrid_dx_OnContentReady(e)
        {
            DxGrid_RowSelectionTobeCheckedAfterAnyAction(e, Expanded_Row_Key_AddressBook_dx, AB_Select_xid_dx)
            AB_Select_xid_dx = null;
            DxGrid_OnContentReady(e, AB_ShowHorizontalBar_dx);//It should always be in last. Grid layout may get disturbed if position is changed.
        }
        function AddressListGrid_dx_OnCellDblClick(e) {
            if (e.rowType == "data") {
                if (AddressBook_IsVouchingMode_dx == true && AdresBook_ViewMode_dx == "Default") {
                    var keyvalue = e.key != null ? e.key.replace(/^0-9A-Za-z/gi, "_") : "Null" + e.rowIndex;
                    OnGridCellClick(e.event, e.cellElement[0], e.columnIndex, e.rowIndex, e.element[0].id, keyvalue, e.column.dataField)
                }
                else if (AddressBook_IsVouchingMode_dx == false) { OnAddressEditClick_dx(); }
            }
        }
        function AddressListGrid_dx_OnSelectionChanged(e)
        {
            var selectedRowKeys = e.selectedRowKeys;
            if (selectedRowKeys != null && selectedRowKeys.length > 0)
            {
                if (AddressBook_IsVouchingMode_dx)
                {
                    AddressBook_FAB_dx.SetVisible(true);
                    AddressBook_FAB_dx.SetActionContext("AddAttachmentContext", false);
                }
                AddressListGrid_dx_SelectedRowData(e.selectedRowsData);
            }
            else
            {
                Addressbook_ID_dx = null;
                Addressbook_UpdateFooterDetail_dx(Addressbook_ID_dx, Addressbook_Action_Status_dx, Addressbook_Add_Date_dx, Addressbook_Add_By_dx,
                    Addressbook_Action_Date_dx, Addressbook_Action_By_dx, Addressbook_Edit_Date_dx, Addressbook_Edit_By_dx);
            }
        }
        function AddressListGrid_dx_SelectedRowData(selectedData = null)
        {
            if (selectedData == null)
            {
                selectedData = AddressListGrid_dx.getSelectedRowsData();
            }
            if (selectedData != null && selectedData.length > 0) {
                var values = selectedData[0]
                Addressbook_ID_dx = values["ID"];
                Addressbook_Add_By_dx = values["Add_By"];
                Addressbook_Add_Date_dx = values["Add_Date"];
                Addressbook_Edit_By_dx = values["Edit_By"];
                Addressbook_Edit_Date_dx = values["Edit_Date"];
                Addressbook_Action_By_dx = values["Action_By"];
                Addressbook_Action_Date_dx = values["Action_Date"];
                Addressbook_Action_Status_dx = values["Action_Status"];
                Addressbook_Name_dx = values["Name"];
                Addressbook_UpdateFooterDetail_dx(Addressbook_ID_dx, Addressbook_Action_Status_dx, Addressbook_Add_Date_dx, Addressbook_Add_By_dx,
                    Addressbook_Action_Date_dx, Addressbook_Action_By_dx, Addressbook_Edit_Date_dx, Addressbook_Edit_By_dx);
                if (AddressBook_IsVouchingMode_dx == true) {
                    OpenLeftPane();
                    LeftPaneContent_AddressBook_dx("AddressListGrid_dx", Addressbook_ID_dx, AddressBook_IsVouchingMode_dx)
                }
            }
            else
            {
                Addressbook_ID_dx = null;
            }
        }
        async function AddressListGrid_dx_OnRowExpanding(e) {
            if (Array.isArray(e.key) == false) //not group row
            {
                e.component.collapseRow(Expanded_Row_Key_AddressBook_dx)
                e.component.selectRows(e.key);
                Expanded_Row_Key_AddressBook_dx = e.key;
                AddressBookInfo_IsDetailRowExpanded_dx = true;
                var DetailGridID = e.element[0].id + e.key;
                var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
                if (instance != void 0) {
                    instance.state(null) // grid maintains its state after collapsing so resetting the state when expands again as per old grid
                }
                if (AddressListGrid_dx.hasEditData()) await DevExpress.ui.dialog.alert("Editing cannot be performed when row is Expanded", "Alert");
                AddressListGrid_dx.cancelEditData();
                DisplayFABEditOrSave_AB();
                //e.component.collapseAll(-1);
            }
            else {
                e.component.option("CustomProp.groupRowExpanded", true);
            }
        }
        function AddressListGrid_dx_OnRowCollapsing(e) {
            if (Array.isArray(e.key) == false) //not group row
            {
                var DetailGridID = e.element[0].id + e.key;
                sessionStorage.removeItem(DetailGridID + "_DetailGridState") //removing grid state from session storage on collapse

                AddressBookInfo_IsDetailRowExpanded_dx = false;
                e.component.selectRows(e.key);
                if (AddressBook_IsVouchingMode_dx == false) {
                   AddressBook_FAB_dx.SetVisible(false);
                }
                var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
                if (instance != void 0) {
                    instance.clearSelection();
                }
                DisplayFABEditOrSave_AB();
            }
            else {
                e.component.option("CustomProp.groupRowCollapsed", true);
            }
        }
        function DisplayFABEditOrSave_AB() {
            if (AddressBookInfo_IsDetailRowExpanded_dx == false) {
                if (AddressListGrid_dx.hasEditData()) {
                    AddressBook_FAB_dx.SetActionContext("SaveCancelContext", true);
                }
                else {
                    AddressBook_FAB_dx.SetActionContext("EditContext", true);
                }
                AddressBook_FAB_dx.SetVisible(true);
            }
            else {
                if (AddressListGrid_dx.hasEditData()) {
                    AddressBook_FAB_dx.SetActionContext("SaveCancelContext", false);
                }
                else {
                    AddressBook_FAB_dx.SetActionContext("EditContext", false);
                }
                AddressBook_FAB_dx.SetVisible(false);
            }
        }
        function AddressListGrid_dx_OnContextMenuPreparing(e)
        {
            if (!e.items) e.items = [];
            if (e.target == "header") {
                DxGrid_HeaderContextMenu(e)
            }
            else if ((e.target == "content" && e.row && e.row.rowType == "groupFooter") || e.target == "footer") {
                if (AdresBook_ViewMode_dx == "Compact")
                    DxGrid_FooterContextMenu(e, true);
                else
                    DxGrid_FooterContextMenu(e);
            }
            else if (e.target == "content" && e.row && e.row.rowType == "data")
            {
                var key = e.component.getKeyByRowIndex(e.row.rowIndex);
                e.component.selectRows(key);
                var expanded = e.component.isRowExpanded(key);
                e.items = [
                    {
                        text: "Expand Detail",
                        icon: "fa-solid fa-arrow-down-wide-short " + (expanded ? "text-muted" : "text-info"),
