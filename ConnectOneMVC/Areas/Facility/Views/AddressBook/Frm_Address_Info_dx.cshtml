        function AddressBook_IndicatorSwitch_ValueChange_dx(e)
        {
            AddressBook_ShowAttachmentIndicator_dx = e.value;
            AddressBook_ShowVouchingIndicator_dx = e.value;
            AddressListGrid_dx.refresh();
        }
        async function AddressBook_VouchingSwitch_ValueChange_dx(e)
        {
            AddressBook_IsVouchingMode_dx = e.value;
            if (AddressBook_SetVouchingModeOn_dx == true)
            {
                AddressBook_SetVouchingModeOn_dx = false;
            }
            else
            {
               AddressBook_FAB_dx.SetVisible(false);
            }
            if (flagDxSwitchVouching_AddressBookInfo) {
                flagDxSwitchVouching_AddressBookInfo = false;
                return;
            }
            if (AddressBook_IsVouchingMode_dx == true) {
                if (AddressListGrid_dx.hasEditData()) {
                    var Confirmation_1 = await DevExpress.ui.dialog.confirm("Are you sure you wish to switch to Vocuhing ON mode? <b>Unsaved changes will be lost</b>.", "Alert");
                    if (Confirmation_1) {
                        OpenRightPane();
                        ClearLeftPane();
                        OpenLeftPane();
                    }
                    else {
                        flagDxSwitchVouching_AddressBookInfo = true;// Set it for second time value chage call
                        e.component.option("value", e.previousValue);
                        return;
                    }
                }
                else {
                    OpenRightPane();
                    ClearLeftPane();
                    OpenLeftPane();
                }
            }
            else
            {
                CloseRightPane();
                ClearLeftPane();
                CloseLeftPane();
            }
            AddressListGrid_dx.clearSelection();
            AddressListGrid_dx.option("masterDetail.enabled", !AddressBook_IsVouchingMode_dx)
            AddressListGrid_dx.repaint();
            displayHideEditColumn_AB(AB_ShowHorizontalBar_dx, AdresBook_ViewMode_dx, AddressBookInfo_IsDetailRowExpanded_dx, AddressBook_IsVouchingMode_dx);

        }

        function displayHideEditColumn_AB(AB_ShowHorizontalBar, AdresBook_ViewMode, AddressBookInfo_IsDetailRowExpanded, AddressBook_IsVouchingMode) {
            if (AdresBook_ViewMode == "Default" && AB_ShowHorizontalBar == 1 && AddressBook_IsVouchingMode == false) {//DEfault View && Full Data && VouchingMode == OFF
                AddressListGrid_dx.option("editing",
                    {
                        mode: "row",  // Row-wise editing
                        allowUpdating: true,  // Enable updating rows
                        allowAdding: false,    // Disable adding rows
                        allowDeleting: false   // Disable deleting rows
                    });
                AddressListGrid_dx.columnOption("type:buttons", "visible", true);
                if (AddressBookInfo_IsDetailRowExpanded == false) {
                    AddressBook_FAB_dx.SetActionContext("EditContext", true);
                    AddressBook_FAB_dx.SetVisible(true);
                }
            }
            else {
                AddressListGrid_dx.option("editing",
                    {
                        mode: "row",  // Row-wise editing
                        allowUpdating: false,
                        allowAdding: false,
                        allowDeleting: false
                    });
                AddressListGrid_dx.columnOption("type:buttons", "visible", false);
                if (AddressBookInfo_IsDetailRowExpanded_dx == false) {
                    AddressBook_FAB_dx.SetActionContext("EditContext", false);
                    AddressBook_FAB_dx.SetVisible(false);
                }
            }
        }
        async function AdresBook_ViewSwitch_ValueChange_dx(e)
        {
            if (e.value)
            {
                if (AddressListGrid_dx.hasEditData())
                {
                    var Confirmation_1 = await DevExpress.ui.dialog.confirm("Are you sure you wish to switch to compact mode? <b>Unsaved changes will be lost</b>.", "Alert");
                    if (Confirmation_1)
                    {
                        AdresBook_ViewMode_dx = e.value == false ? "Default" : "Compact";
                        AddressBookGrid_dx_Load_Columns(AdresBook_ViewMode_dx)
                        return;
                    }
                    else
                    {
                        flagDxSwitch_AddressBookInfo = true;
                        e.component.option("value", e.previousValue);
                        return
                    }
                }
            }
            AdresBook_ViewMode_dx = e.value == false ? "Default" : "Compact";
            if (flagDxSwitch_AddressBookInfo == false) {
                AddressBookGrid_dx_Load_Columns(AdresBook_ViewMode_dx)
            }
            else {
                flagDxSwitch_AddressBookInfo = false;
            }
        }

        function AddressBookGrid_dx_Load_Columns(AB_ViewMode)
        {
            if (AddressBook_SetVouchingModeOn_dx == true)
            {
                $("#AddressBookVouchingModeSwitch_dx").dxSwitch("instance").option("value", true);
            }
            AddressListGrid_dx.beginUpdate();
            var columns = AddressListGrid_dx.option("columns");
            if (AB_ViewMode == "Compact")
            {
                VisibleColumns_AddressBook_dx = [];
                for (var i = 0; i < columns.length; i++)
                {
                    var name = columns[i].dataField;
                    var ColumnVisible = AddressListGrid_dx.columnOption(name, "visible");
                    if (name == "AddressListGrid_dx_Compact_Column")
                    {
                        AddressListGrid_dx.columnOption(name, "visible", true);
                    }
                    else if (ColumnVisible == true && name != "iIcon")
                    {
                        VisibleColumns_AddressBook_dx.push(name);
                        AddressListGrid_dx.columnOption(name, "visible", false);
                    }
                }
            }
            else
            {
                AddressListGrid_dx.columnOption("AddressListGrid_dx_Compact_Column", "visible", false);
                for (var i = 0; i < VisibleColumns_AddressBook_dx.length; i++)
                {
                    AddressListGrid_dx.columnOption(VisibleColumns_AddressBook_dx[i], "visible", true);
                }
                //AddressListGrid_dx.columnOption("type:buttons", "visible", true);
            }
            displayHideEditColumn_AB(AB_ShowHorizontalBar_dx, AdresBook_ViewMode_dx, AddressBookInfo_IsDetailRowExpanded_dx, AddressBook_IsVouchingMode_dx);
            AddressListGrid_dx.repaint();
            AddressListGrid_dx.endUpdate();
        }
        function AddressBookchangeMode_dx()
        {
            AddressListGrid_dx.beginUpdate();
            if (AB_ShowHorizontalBar_dx == 0)
            {
                AB_ShowHorizontalBar_dx = 1;
                $("#AddressToggleScrollBar_dx").find("span").text("Default Data");
                $("#AddressToggleScrollBar_dx").width(110);
                AddressListGrid_dx.option("columnHidingEnabled", false);
                AddressListGrid_dx.option("allowColumnResizing", true)
                AddressListGrid_dx.option("columnResizingMode", "widget")
            }
            else
            {
                AB_ShowHorizontalBar_dx = 0;
                $("#AddressToggleScrollBar_dx").find("span").text("Full Data");
                $("#AddressToggleScrollBar_dx").width(90);
                AddressListGrid_dx.option("columnHidingEnabled", true)
                AddressListGrid_dx.option("allowColumnResizing", false)
                AddressListGrid_dx.option("columnResizingMode", "nextColumn")
            }
            displayHideEditColumn_AB(AB_ShowHorizontalBar_dx, AdresBook_ViewMode_dx, AddressBookInfo_IsDetailRowExpanded_dx, AddressBook_IsVouchingMode_dx);
            AddressListGrid_dx.endUpdate();
        }

        function OnAddressListPreviewClick_dx()
        {
            if (!Addressbook_ExportRight_dx)
            {
                DevExpress.ui.dialog.alert("Not Allowed", 'No Rights'); return;
            }
            OpenPopup("AddressBook_report_modal", "Export Option", "@Url.Action("Frm_Export_Options_dx", "AddressBook", new { @area = "Facility" })", "auto", 125);
        }
        function Addressbook_UpdateFooterDetail_dx(Addressbook_ID, Addressbook_Action_Status, Addressbook_Add_Date, Addressbook_Add_By, Addressbook_Action_Date, Addressbook_Action_By, Addressbook_Edit_Date, Addressbook_Edit_By) {
            var Status = "";
            var Lbl_Status = "";
            var Lbl_StatusBy = "";
            var Pic_Status = "";
            var Lbl_Create = "";
            var Lbl_Modify = "";
            var Lbl_Status_Color = "";
            var Lbl_ActionOn = "";
            var Lbl_ActionBy = "";
            var StatusStr = "";
            if (Addressbook_ID != null)
            {
                //Addressbook_Add_Date = (moment(Addressbook_Add_Date, "DD/MM/YYYY HH:mm:ss").format("DD/MM/YYYY HH:mm:ss"));
                //Addressbook_Edit_Date = (moment(Addressbook_Edit_Date, "DD/MM/YYYY HH:mm:ss").format("DD/MM/YYYY HH:mm:ss"));
                //Addressbook_Action_Date = (moment(Addressbook_Action_Date, "DD/MM/YYYY HH:mm:ss").format("DD/MM/YYYY HH:mm:ss"));
                Status = Addressbook_Action_Status;
                StatusStr = Status == "Locked" ? "Locked" : Status == null ? null : "UnLocked";
                if (Status && Status.toUpperCase() == "LOCKED") {
                    Lbl_Status = "Completed";
                    Lbl_Status_Color = "blue";
                    Pic_Status = "fa fa-lock";
                }
                else {
                    Pic_Status = "fa fa-unlock";
                    Lbl_Status = Status;
                    if (Status && Status.toUpperCase() == "COMPLETED") {
                        Lbl_Status_Color = "green";
                    }
                    else {
                        Lbl_Status_Color = "red";
                    }
                }
                if (Addressbook_Action_Date) {
                    Lbl_ActionOn = StatusStr + " On: " + Addressbook_Action_Date;
                    Lbl_ActionBy = StatusStr + " By: " + Addressbook_Action_By;
                }
                else {
                    Lbl_ActionOn = "";
                    Lbl_ActionBy = "";
                }
                if (Addressbook_Add_Date) {
                    Lbl_Create = "Add On: " + Addressbook_Add_Date + ", By: " + Addressbook_Add_By;
                }
                else {
                    Lbl_Create = "";
                }
                if (Addressbook_Edit_Date) {
                    Lbl_Modify = "Edit On: " + Addressbook_Edit_Date + ", By: " + Addressbook_Edit_By;
                }
                else {
                    Lbl_Modify = "";
                }
            }
            $('#AB_Status_dx').text(Lbl_Status);
            $('#AB_Lbl_ActionOn_dx').text(Lbl_ActionOn)
            $('#AB_Lbl_ActionBy_dx').text(Lbl_ActionBy);
            $('#AB_Create_dx').text(Lbl_Create);
            $('#AB_Modify_dx').text(Lbl_Modify);
            if (Lbl_Status_Color != "") {
                $('#ActionItem_Status_dx').css('color', Lbl_Status_Color);
            }
            if (Pic_Status == "fa fa-lock") {
                $('#ActionItem_LockICON_dx').addClass(Pic_Status).removeClass("fa-unlock");
            }
            else if (Pic_Status == "fa fa-unlock") {
                $('#ActionItem_LockICON_dx').addClass(Pic_Status).removeClass("fa-lock");
            }
            else {
                $('#ActionItem_LockICON_dx').removeClass("fa");
                $('#ActionItem_LockICON_dx').removeClass("fa-lock");
                $('#ActionItem_LockICON_dx').removeClass("fa-unlock");
            }
        }

