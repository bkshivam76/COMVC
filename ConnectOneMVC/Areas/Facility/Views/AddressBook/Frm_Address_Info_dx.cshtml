        function AddressListGrid_dx_DetailTemplate(container, templateData)
        {
            var GridName = templateData.component.element()[0].id
            var RecID = templateData.data.ID;
            AddressListGrid_dx_Detail(container, GridName, RecID, AddressBook_IsVouchingMode_dx, AB_ShowHorizontalBar_dx);
        }

        function AddressListGrid_dx_Detail(container, GridName, RecID, vouchingMode, AllColumns)
        {
            var url = "/Facility/AddressBook/Frm_Address_Info_GridData_detail_dx?VouchingMode=" + vouchingMode + "&RecID=" + RecID
            var instance = DxGrid_AttachmentGrid_Create(container, GridName, RecID, vouchingMode, AllColumns, url)
            instance.option("onSelectionChanged", AddressListGrid_dx_Detail_onSelectionChanged);           
        } 
        function AddressListGrid_dx_Detail_onSelectionChanged(e)
        {
            if (AddressBookInfo_IsDetailRowExpanded_dx || AddressBook_IsVouchingMode_dx)
            {
                if (e.selectedRowsData != null && e.selectedRowsData.length > 0)
                {
                    AddressBookInfo_NestedGrid_AccessID_dx = e.element[0].id;
                    AddressListGrid_dx_Detail_SelectedRowData(e.selectedRowsData)
                   //AddressBook_FAB_dx.SetVisible(true);
                }
                else
                {
                    AddressBook_FAB_dx.SetActionContext("AddAttachmentContext", false);
                }
            }
        }
        function AddressListGrid_dx_Detail_SelectedRowData(selectedData = null)
        {
            if (selectedData == null)
            {
                selectedData = $("div[id='" + AddressBookInfo_NestedGrid_AccessID_dx + "']").dxDataGrid("getSeletedRowsData");
            }
            var values = selectedData[0];
            if (values["UniqueID"] != null)
            {
                AddressBook_FAB_dx.SetVisible(true);
                AddressBookInfo_Nested_Doc_Status_dx = values["Doc_Status"];
                if (AddressBook_IsVouchingMode_dx == true) {
                    AddressBook_FAB_dx.SetActionContext("AuditActionContext", true);
                }
                else {
                    if (AddressBookInfo_Nested_Doc_Status_dx == "") {
                        AddressBook_FAB_dx.SetActionContext("AutoItemContext", true);
                    }
                    else if (AddressBookInfo_Nested_Doc_Status_dx == "NO") {
                        AddressBook_FAB_dx.SetActionContext("EditItemContext", true);
                    }
                    else if (AddressBookInfo_Nested_Doc_Status_dx == "YES") {
                        AddressBook_FAB_dx.SetActionContext("actionItemContext", true);
                    }
                }
                AddressBookInfo_ParamMandatory_dx = values["Params_Mandatory"];
                AddressBookInfo_FromDateLabel_dx = values["LABEL_FROM_DATE"];
                AddressBookInfo_ToDateLabel_dx = values["LABEL_TO_DATE"];
                AddressBookInfo_DescriptionLabel_dx = values["LABEL_DESCRIPTION"];
                AddressBookInfo_Doc_Category_dx = values["Document_Category"];
                AddressBookInfo_Doc_ID_dx = values["Document_ID"];
                AddressBookInfo_AtachmentID_dx = values["ATTACH_ID"];
                IndexAttachmentID = AddressBookInfo_AtachmentID_dx;
                AddressBookInfo_MasterRowRecID_dx = values["TxnID"];
                AddressBookInfo_MasterRowMID_dx = values["TxnMID"];
                AddressBookInfo_NestedRowMapID_dx = values["MAP_ID"];
                AddressBookInfo_reason_dx = values["Reason"];
                AddressBookInfo_FileName_dx = values["ATTACH_FILE_NAME"];
                AddressBookInfo_Attachment_RecStatus_dx = values["Attachment_Action_Status"];
                AddressBookInfo_NestedRowKeyValue_dx = values["UniqueID"];
                if (AddressBook_IsVouchingMode_dx == true) {
                    if (AddressBookInfo_FileName_dx != null && AddressBookInfo_FileName_dx.length > 0) {
                        ViewDocument(AddressBookInfo_AtachmentID_dx, AddressBookInfo_FileName_dx, "AddressBook_FAB_dx", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                    }
                    else {
                        CloseRightPane();
                        ClearRightPane();
                    }
                }
            }
            AddressBookInfo_NestedRowReasonID_dx = values["ReasonID"];
            IndexAttachmentReasonID = AddressBookInfo_NestedRowReasonID_dx;
        }
            
        function LeftPaneContent_AddressBook_dx(GridName, RecID, vouchingMode, AllColumns = 0)
        {
            $("#LeftPane_Div_Content").html(null);
            $("#LeftPane_Div_Content").append("<div class='col-xs-12'><label>Documents Attached:</label><div class='AttachmentGrid'><form></form></div></div><div class='col-xs-12'><label>Additional Info:</label><div class='AdditionalInfoGrid'><form></form></div></div>")
            AddressListGrid_dx_Detail($("#LeftPane_Div_Content .AttachmentGrid>form"), GridName, RecID, vouchingMode, AllColumns)
            setTimeout(function () {
                AdditionalInfoGrid_AddressBook_dx($("#LeftPane_Div_Content .AdditionalInfoGrid>form"), GridName, RecID, vouchingMode, AllColumns)
            })
        }
        function AdditionalInfoGrid_AddressBook_dx(container, GridName, RecID, vouchingMode, AllColumns)
        {
            var url = "/Facility/AddressBook/Frm_Address_Info_AdditionalGridData_dx?VouchingMode=" + vouchingMode + "&RecID=" + RecID
            DxGrid_CreateAdditionalInfoGrid(container, GridName, RecID, vouchingMode, AllColumns, url) 
        }
