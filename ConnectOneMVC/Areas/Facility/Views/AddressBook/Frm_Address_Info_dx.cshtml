                            if (centre_rec_id) {
                                e.component.option("value", centre_rec_id)
                            }
                        }
                    }                    
                },
                onClosed: function (e) {
                    let component = e.component;
                    if (!component.isFocusOutInProgress) {
                        component.isFocusOutInProgress = true;
                        if (IsNullOrWhitespace(null, null, cellInfo.value)) return;
                        cellInfo.component.columnOption(cellInfo.columnIndex + 1, "width", 350);
                        cellInfo.component.updateDimensions();
                        component.isFocusOutInProgress = false;
                    }
                },
                onOpened: function (e) {                   
                    cellInfo.component.columnOption(cellInfo.columnIndex + 1, "width", 400);
                    cellInfo.component.updateDimensions();
                },
                onValueChanged: async function (e) { await Centre_ValueChange_AB(e, cellInfo) }
            });
            cellElement.append(centreDropDownBox);
        }
        async function Centre_ValueChange_AB(e, cellInfo) {
            let centre_DG_Instance = $('#Centre_dd_AddressInfo_dg_dx' + cellInfo.key).dxDataGrid('instance');
            let centre_Dd_Instance = $('#Centre_dd_AddressInfo_dx' + cellInfo.key).dxDropDownBox('instance');
            let value = null;
            if (e) {
                value = e.value;
            }
            else {
                value = centre_Dd_Instance.option("value");
            }
            if (e && e.value == null && e.previousValue != null) {
                cellInfo.setValue(null);
                if (centre_DG_Instance) centre_DG_Instance.clearSelection();
                return;
            }
            if (centre_DG_Instance) {
                await centre_DG_Instance.selectRows(value);
            }
            cellInfo.setValue(value);
        }
