    <script>
        async function On_AddressBookFacility_dx_FABActionItemClick(s, e)
        {
            var img = document.getElementById('RightPane_Img');
            s.ExpandActionGroupItems();
            //DxFAB_Expand("AddressBook_FAB_dx")
            if (e.actionName === "add_attach")
            {
                if ("@Help_Attachment_AddRight" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                if (AddressBookInfo_ParamMandatory_dx == 1)
                {
                    AddAttachment(AddressBookInfo_MasterRowRecID_dx, "Facility_AddressBook", AddressBookInfo_Doc_ID_dx, AddressBookInfo_Doc_Category_dx, AddressBookInfo_ParamMandatory_dx, AddressBookInfo_FromDateLabel_dx, AddressBookInfo_ToDateLabel_dx, AddressBookInfo_DescriptionLabel_dx, "AddressBookFacilityAttachment_dx", null, "AddressListGrid_dx", AddressBookInfo_NestedGrid_AccessID_dx);
                }
                else
                {
                    Attachment_DirectBrowse(AddressBookInfo_MasterRowRecID_dx, "Facility_AddressBook", AddressBookInfo_Doc_ID_dx, "AddressBookFacilityAttachment_dx", "AddressListGrid_dx", AddressBookInfo_NestedGrid_AccessID_dx);
                }
            }
            else if (e.actionName === "edit_attach")
            {
                if ("@Help_Attachment_EditRight" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                if (AddressBookInfo_Nested_Doc_Status_dx == "NO" || AddressBookInfo_Nested_Doc_Status_dx == "")
                {
                    DevExpress.ui.dialog.alert("Please Attach document First", "Error");
                    return;
                }
                if (AddressBookInfo_Attachment_RecStatus_dx.toUpperCase() == "LOCKED")
                {
                    DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                    return;
                }
                EditAttachment(AddressBookInfo_MasterRowRecID_dx, "Facility_AddressBook", AddressBookInfo_AtachmentID_dx, AddressBookInfo_ParamMandatory_dx, AddressBookInfo_FromDateLabel_dx, AddressBookInfo_ToDateLabel_dx, AddressBookInfo_DescriptionLabel_dx, "AddressBookFacilityAttachment_dx", null, "AddressListGrid_dx", AddressBookInfo_NestedGrid_AccessID_dx);
            }
            else if (e.actionName === "delete_attach")
            {
                if ("@Help_Attachment_DeleteRight" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                if (AddressBookInfo_Nested_Doc_Status_dx == "NO" || AddressBookInfo_Nested_Doc_Status_dx == "")
                {
                    DevExpress.ui.dialog.alert("Please Attach document First", "Error");
                    return;
                }
                DeleteAttachment(AddressBookInfo_MasterRowRecID_dx, "Facility_AddressBook", AddressBookInfo_AtachmentID_dx, AddressBookInfo_ParamMandatory_dx, AddressBookInfo_FromDateLabel_dx, AddressBookInfo_ToDateLabel_dx, AddressBookInfo_DescriptionLabel_dx, null, "AddressListGrid_dx", AddressBookInfo_NestedGrid_AccessID_dx, AddressBookInfo_Attachment_RecStatus_dx);
            }
            else if (e.actionName === "view_attach")
            {
                if ("@Help_Attachment_ViewRight" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                if (AddressBookInfo_Nested_Doc_Status_dx == "NO" || AddressBookInfo_Nested_Doc_Status_dx == "")
                {
                    DevExpress.ui.dialog.alert("Please Attach document First", "Error");
                    return;
                }
                ViewDocument(AddressBookInfo_AtachmentID_dx, AddressBookInfo_FileName_dx, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
            }
            else if (e.actionName == "Link_Attach")
            {
                LinkAttachment(AddressBookInfo_MasterRowRecID_dx, "Facility_AddressBook", "Address Book", "AddressListGrid_dx", AddressBookInfo_NestedGrid_AccessID_dx);
            }
            else if (e.actionName === "Add_Reason")
            {
                if (AddressBookInfo_Doc_Category_dx.toLowerCase() == "others")
                {
                    DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
                }
                else
                {
                    AttachmentAddReason(AddressBookInfo_MasterRowRecID_dx, AddressBookInfo_NestedRowMapID_dx, "Facility_AddressBook", "AddressListGrid_dx", AddressBookInfo_NestedGrid_AccessID_dx);
                }
            }
            else if (e.actionName === "Edit_Reason")
            {
                    AttachmentEditReason(AddressBookInfo_MasterRowRecID_dx, AddressBookInfo_NestedRowMapID_dx, "Facility_AddressBook", "AddressListGrid_dx", AddressBookInfo_NestedGrid_AccessID_dx, AddressBookInfo_reason_dx);
            }
            else if (e.actionName === "Delete_Reason")
            {
                    AttachmentDeleteReason(AddressBookInfo_MasterRowRecID_dx, AddressBookInfo_NestedRowMapID_dx, "AddressListGrid_dx", AddressBookInfo_NestedGrid_AccessID_dx);
            }
            else if (e.actionName === "Rotate")
            {
                ImageRotate(img);
            }
            else if (e.actionName === "ZoomOut")
            {
                ImageZoomOut(img);
            }
            else if (e.actionName === "ZoomIn")
            {
                ImageZoomIn(img);
            }
            else if (e.actionName == "Fit")
            {
                ImageFit(img);
            }
            else if (e.actionName == "Back")
            {
                ImageBack(s.uniqueID, "actionItemContext");
            }
            else if (e.actionName == "AuditAction")
            {
               AddressBook_FAB_dx.SetActionContext("AuditActionContext", true);
            }
            else if (e.actionName == "BackAudit")
            {
                if (AddressBookInfo_Nested_Doc_Status_dx == "")
                {
                  AddressBook_FAB_dx.SetActionContext("AutoItemContext", true);
                }
                if (AddressBookInfo_Nested_Doc_Status_dx == "NO")
                {
                   AddressBook_FAB_dx.SetActionContext("EditItemContext", true);
                }
                if (AddressBookInfo_Nested_Doc_Status_dx == "YES")
                {
                    AddressBook_FAB_dx.SetActionContext("actionItemContext", true);
                }
            }
            else if (e.actionName == "Accept") {
                AddressBookInfo_AcceptwithoutRemarks_dx();
            }
            else if (e.actionName == "Reject") {
                AddressBookInfo_AcceptRejectVoucher_dx("Reject");
            }
            else if (e.actionName == "AcceptWithRemarks")
            {
                AddressBookInfo_AcceptRejectVoucher_dx("Accept");
            }
            else if (e.actionName == "AcceptDoc")
            {
                OnAddressBookInfo_AcceptDoc_dx();
            }
            else if (e.actionName == "RejectDoc")
            {
                OnAddressBookInfo_RejectDoc_dx();
            }
            else if (e.actionName == "Edit_GridRow")
            {
                if (!RightAndRowSelectionCheckforEdit_AB()) return;
                $("#AddressListGrid_dx_Cell_" + Addressbook_ID_dx + "\\|EditColumn").find("a.dx-link-edit").trigger("click");
            }
            else if (e.actionName == "Save_GridRow")
            {
                if (!RightAndRowSelectionCheckforEdit_AB()) return;
                document.activeElement.blur();
                $("#AddressListGrid_dx_Cell_" + Addressbook_ID_dx + "\\|EditColumn").find("a.dx-link-save").trigger("click");
            }
            else if (e.actionName == "Cancel_GridRow")
            {
                if (!RightAndRowSelectionCheckforEdit_AB()) return;
                AddressListGrid_dx.cancelEditData();
                DisplayFABEditOrSave_AB();
            }
        }
        function RightAndRowSelectionCheckforEdit_AB() {
            if (!Addressbook_EditRight_dx) {
                DevExpress.ui.dialog.alert("Not Allowed", 'No Rights');
                return false;
            }
            AddressListGrid_dx_SelectedRowData();
            if (Addressbook_ID_dx == null) {
                DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
                return false;
            }
            return true;
        }
        function OnAddressBookInfo_RejectDoc_dx()
        {
            if (AddressBookInfo_AtachmentID_dx == null || AddressBookInfo_AtachmentID_dx.length == 0)
            {
                DevExpress.ui.dialog.alert("No Document Attached..", "Error");
                return;
            }
            RejectAttachment(AddressBookInfo_AtachmentID_dx, "AddressListGrid_dx", AddressBookInfo_NestedGrid_AccessID_dx);
        }
        function OnAddressBookInfo_AcceptDoc_dx()
        {
            if (AddressBookInfo_AtachmentID_dx == null || AddressBookInfo_AtachmentID_dx.length == 0) {
                DevExpress.ui.dialog.alert("No Document Attached..", "Error");
                return;
            }
            AcceptAttachment(AddressBookInfo_AtachmentID_dx, "AddressListGrid_dx", AddressBookInfo_NestedGrid_AccessID_dx);
        }
        function AddressBookInfo_AcceptwithoutRemarks_dx()
        {
            var Recid;
            if (AddressBookInfo_IsDetailRowExpanded_dx == true || AddressBook_IsVouchingMode_dx == true)
            {
                if (AddressBookInfo_MasterRowRecID_dx == null || AddressBookInfo_MasterRowRecID_dx == "")
                {
                    Recid = Addressbook_ID_dx;
                }
                else
                {
                    Recid = AddressBookInfo_MasterRowRecID_dx;
                }
            }
            else
            {
                Recid = Addressbook_ID_dx;
            }
            Entry_AcceptwithoutRemarks(Recid, "Facility_AddressBook", "AddressListGrid_dx", AddressBookInfo_AtachmentID_dx, AddressBookInfo_NestedRowReasonID_dx, AddressBookInfo_NestedRowKeyValue_dx);
        }
        function AddressBookInfo_AcceptRejectVoucher_dx(_actionMethod)
        {
            var Recid;
            if (AddressBookInfo_IsDetailRowExpanded_dx == true || AddressBook_IsVouchingMode_dx == true)
            {
                if (AddressBookInfo_MasterRowRecID_dx == null || AddressBookInfo_MasterRowRecID_dx == "")
                {
                    Recid = Addressbook_ID_dx;
                }
                else
                {
                    Recid = AddressBookInfo_MasterRowRecID_dx;
                }
            }
            else
            {
                Recid = Addressbook_ID_dx;
            }
            Entry_AcceptReject(_actionMethod, Recid, "Facility_AddressBook", "AddressListGrid_dx", AddressBookInfo_AtachmentID_dx, AddressBookInfo_NestedRowReasonID_dx, AddressBookInfo_NestedRowKeyValue_dx);
        }
    </script>
