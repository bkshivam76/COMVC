            var CountryCode = "";
            if (city_AddressInfo_dx && city_AddressInfo_dx.length > 0) {
                cityDataSource = new DevExpress.data.DataSource({
                    store: new DevExpress.data.ArrayStore({
                        data: city_AddressInfo_dx,
                        key: 'R_CI_REC_ID',
                    }),
                    filter: function (data) {
                        stateCode = null;
                        CountryCode = "";
                        if (cellInfo.row.data.State) {
                            let stateObj = state_AddressInfo_dx.find(s => s.REC_ID === cellInfo.row.data.State);
                            if (stateObj) {
                                if (stateObj.ST_CODE) {
                                    stateCode = parseInt(stateObj.ST_CODE)
                                }
                            }
                        }
                        if (cellInfo.row.data.Country) {
                            let countryObj = country_AddressInfo_dx.find(c => c.R_CO_REC_ID === cellInfo.row.data.Country);
                            if (countryObj) {
                                CountryCode = countryObj.R_CO_CODE
                            }
                        }
                        if (cellInfo.row.data.Country !== 'f9970249-121c-4b8f-86f9-2b53e850809e') {
                            //if (CountryCode && stateCode) {
                            //    if (stateCode == data.STATE_CODE && CountryCode.includes(data.COUNTRY_CODE)) {
                            //        return true
                            //    }
                            //}
                            //if (stateCode) {
                            //    if (stateCode == data.STATE_CODE) { return true; }
                            //}
                            if (CountryCode && CountryCode.includes(data.COUNTRY_CODE)) {
                                return true;
                            }                            
                        }
                        else {
                            if (CountryCode && stateCode) {
                                if (stateCode == data.STATE_CODE && CountryCode.includes(data.COUNTRY_CODE)) {
                                    return true
                                }
                            }
                        }
                    }
                });
            }
            else {
                cityDataSource = new DevExpress.data.DataSource({
                    store: new DevExpress.data.AspNet.createStore({
                        key: "R_CI_REC_ID",
                        loadMode: "raw",
                        loadUrl: "/Facility/Chart/GetCitiesWithSTandCO_Code?CountryAccessibleDescription="
                    }),
                    filter: function (data) {
                        stateCode = null;
                        CountryCode = "";
                        if (cellInfo.row.data.State) {
                            let stateObj = state_AddressInfo_dx.find(s => s.REC_ID === cellInfo.row.data.State);
                            if (stateObj) {
                                if (stateObj.ST_CODE) {
                                    stateCode = parseInt(stateObj.ST_CODE)
                                }
                            }
                        }
                        if (cellInfo.row.data.Country) {
                            let countryObj = country_AddressInfo_dx.find(c => c.R_CO_REC_ID === cellInfo.row.data.Country);
                            if (countryObj) {
                                CountryCode = countryObj.R_CO_CODE
                            }
                        }
                        if (cellInfo.row.data.Country === 'f9970249-121c-4b8f-86f9-2b53e850809e') {
                            if (CountryCode && stateCode) {
                                if (stateCode == data.STATE_CODE && CountryCode.includes(data.COUNTRY_CODE)) {
                                    return true
                                }
                            }
                        }
                        else {
                            if (CountryCode && stateCode) {
                                if (stateCode == data.STATE_CODE && CountryCode.includes(data.COUNTRY_CODE)) {
                                    return true
                                }
                            }
                            if (stateCode) {
                                if (stateCode == data.STATE_CODE) { return true; }
                            }
                            if (CountryCode) {
                                if (CountryCode.includes(data.COUNTRY_CODE)) {
                                    return true;
                                }
                            }
                        }
                    }
                })
            }
            return cityDataSource;
        }
        function AddCustomDatatoEducation_AddressInfo_dx(cellInfo, e) {
            var Txt_Education_AB = e.component;
            var dataSource = Txt_Education_AB.getDataSource();
            var dataItems = education_AddressInfo_dx;
            var flag = false;
            for (var i = 0; dataItems.length > i; i++) {
                if (dataItems[i].C_TITLE_NAME == cellInfo.value) {
                    flag = true;
                    break;
                }
            }
            if (flag == true){
                Txt_Education_AB.option("value", cellInfo.value);
                cellInfo.setValue(cellInfo.value);
            }
            else {
                //Below code will add saved education qualification by user which is not present in Datasource then it sets it to SelectBox
                var newID = createGuid();
                var newItem = { C_TITLE_NAME: cellInfo.value, C_TITLE_ID: newID };
                if (dataSource._store._array) {
                    dataSource._store._array.push(newItem);
                }
                if (dataSource._store.__rawData) {
                    dataSource._store.__rawData.push(newItem);
                }
                education_AddressInfo_dx.push(newItem)
                dataSource.store().load().done(function (data) {
                    Txt_Education_AB.option("value", cellInfo.value);
                    cellInfo.setValue(cellInfo.value);
                })
            }
        }
