<div class="AddressBookExport_ClearReferences">
@using DevExtreme.AspNet.Mvc;
<div>
    @(Html.DevExtreme().Button()
                .ID("Address_ExportGridDatapdf")
                .Text("Export to PDF")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                .OnClick("ExportPDF")
                .Visible(true)
                .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                .ID("Address_ExportGridDataxls")
                .Text("Export to XLS")
                //.Icon("fa-file-excel-o")
                .OnClick("ExportXLS")
                .Visible(true)
                .Width(120)
    )<br />
    @(Html.DevExtreme().Button()
                .ID("Address_ExportGridDataxlsx")
                .Text("Export to XLSX")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                .OnClick("ExportXLSX")
                .Visible(true)
                .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                .ID("Address_ExportGridDatadocx")
                .Text("Export to DOCX")
                //.Icon("export_exporttodocx_16x16office2013")
                .OnClick("ExportDOCX")
                .Visible(true)
                .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                .ID("Address_ExportGridDatartf")
                .Text("Export to RTF")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                .OnClick("ExportRTF")
                .Visible(true)
                .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                .ID("Address_ExportGridDatacsv")
                .Text("Export to CSV")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                .OnClick("ExportCSV")
                .Visible(true)
                .Width(120)
    )
</div>
<script>
    function ExportPDF() {
        AddressListGrid.ExportTo(ASPxClientGridViewExportFormat.Pdf);
        $("#AddressBook_report_modal").dxPopup("hide");
    }
    function ExportXLS() {
        AddressListGrid.ExportTo(ASPxClientGridViewExportFormat.Xls);
        $("#AddressBook_report_modal").dxPopup("hide");
    }
    function ExportXLSX() {
        AddressListGrid.ExportTo(ASPxClientGridViewExportFormat.Xlsx);
        $("#AddressBook_report_modal").dxPopup("hide");
    }
    function ExportCSV() {
        AddressListGrid.ExportTo(ASPxClientGridViewExportFormat.Csv);
        $("#AddressBook_report_modal").dxPopup("hide");
    }
    function ExportDOCX() {
        AddressListGrid.ExportTo(ASPxClientGridViewExportFormat.Docx);
        $("#AddressBook_report_modal").dxPopup("hide");
    }
    function ExportRTF() {
        AddressListGrid.ExportTo(ASPxClientGridViewExportFormat.Rtf);
        $("#AddressBook_report_modal").dxPopup("hide");
    }
</script>
    </div>