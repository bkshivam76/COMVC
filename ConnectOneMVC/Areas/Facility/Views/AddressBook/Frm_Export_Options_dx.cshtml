<div class="AddressBookExport_ClearReferences">
@using DevExtreme.AspNet.Mvc;
<div>
    @(Html.DevExtreme().Button()
                .ID("Address_ExportGridDatapdf_dx")
                .Text("Export to PDF")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                .OnClick("ExportPDF")
                .Visible(false)
                .Width(120)
    )

    @(Html.DevExtreme().Button()
                .ID("Address_ExportGridDataxls_dx")
                .Text("Export to XLS")
                //.Icon("fa-file-excel-o")
                .OnClick("ExportXLS")
                .Visible(false)
                .Width(120)
    )
    @(Html.DevExtreme().Button()
                .ID("Address_ExportGridDataxlsx_dx")
                .Text("Export to XLSX")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                .OnClick("ExportXLSX_dx")
                .Visible(true)
                .Width(120)
    )

    @(Html.DevExtreme().Button()
                .ID("Address_ExportGridDatadocx_dx")
                .Text("Export to DOCX")
                //.Icon("export_exporttodocx_16x16office2013")
                .OnClick("ExportDOCX")
                .Visible(false)
                .Width(120)
    )

    @(Html.DevExtreme().Button()
                .ID("Address_ExportGridDatartf_dx")
                .Text("Export to RTF")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                .OnClick("ExportRTF")
                .Visible(false)
                .Width(120)
    )

    @(Html.DevExtreme().Button()
                .ID("Address_ExportGridDatacsv_dx")
                .Text("Export to CSV")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                .OnClick("ExportCSV")
                .Visible(false)
                .Width(120)
    )
</div>
<script>
    function ExportPDF() {
        AddressListGrid.ExportTo(ASPxClientGridViewExportFormat.Pdf);
        $("#AddressBook_report_modal").dxPopup("hide");
    }
    function ExportXLS() {
        AddressListGrid.ExportTo(ASPxClientGridViewExportFormat.Xls);
        $("#AddressBook_report_modal").dxPopup("hide");
    }
    function ExportXLSX() {
        AddressListGrid.ExportTo(ASPxClientGridViewExportFormat.Xlsx);
        $("#AddressBook_report_modal").dxPopup("hide");
    }
    function ExportCSV() {
        AddressListGrid.ExportTo(ASPxClientGridViewExportFormat.Csv);
        $("#AddressBook_report_modal").dxPopup("hide");
    }
    function ExportDOCX() {
        AddressListGrid.ExportTo(ASPxClientGridViewExportFormat.Docx);
        $("#AddressBook_report_modal").dxPopup("hide");
    }
    function ExportRTF() {
        AddressListGrid.ExportTo(ASPxClientGridViewExportFormat.Rtf);
        $("#AddressBook_report_modal").dxPopup("hide");
    }
    function ExportXLSX_dx()
    {
        const workbook = new ExcelJS.Workbook();
        const worksheet = workbook.addWorksheet('Sheet');

        DevExpress.excelExporter.exportDataGrid({
            worksheet: worksheet,
            component: $("#AddressListGrid_dx").dxDataGrid("instance"),
            autoFilterEnabled: true,
            customizeCell({ excelCell, gridCell }) {
                if (gridCell.rowType === 'header') {
                    const columnDataField = gridCell.column.dataField;
                    if (columnDataField === 'iIcon') {
                        const Column = worksheet.getColumn(excelCell.col);
                        Column.width = 20;
                    }
                }
            }
        }).then(function (exportRange) {     
            workbook.xlsx.writeBuffer().then(function (buffer) {
                saveAs(new Blob([buffer], { type: 'application/octet-stream' }), 'AddressListGrid_dx.xlsx');
            });
        });
        $("#AddressBook_report_modal").dxPopup("hide");
    }
</script>
    </div>