@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("CityList_AB_datagrid")    
    .Columns(columns =>
    {
        columns.Add().DataField("R_CI_NAME").Caption("City");
        columns.Add().DataField("R_CI_CODE").Visible(false);
    })
  
    .Selection(s => s.Mode(SelectionMode.Single))
    .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}")
)
