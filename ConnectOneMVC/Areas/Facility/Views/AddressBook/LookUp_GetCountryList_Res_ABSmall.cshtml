
@using DevExtreme.AspNet.Data;
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("CountryList-datagrid_ABSmall")
    .Columns(columns =>
    {
        columns.Add().DataField("R_CO_NAME").Caption("Country");
        columns.Add().DataField("R_CO_CODE").Visible(false);
        columns.Add().DataField("R_CO_REC_ID").Visible(false);
    })

    .Selection(s => s.Mode(SelectionMode.Single))

)