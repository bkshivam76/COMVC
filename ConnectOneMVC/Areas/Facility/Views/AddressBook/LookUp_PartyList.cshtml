@using DevExtreme.AspNet.Data;
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("MergeParty_datagrid")

    .Columns(columns =>
    {
        columns.Add().DataField("ID").Visible(false);
        columns.Add().DataField("Name").Caption("Name");
        columns.Add().DataField("BUILDING").Caption("Building");
        columns.Add().DataField("HOUSE NO").Caption("House No");
        columns.Add().DataField("AREA/STREET").Caption("Area/Street");
        columns.Add().DataField("DISTRICT").Caption("District");
        columns.Add().DataField("MOBILE").Caption("Mobile").Visible(false);
        columns.Add().DataField("REC_EDIT_ON").Caption("edit date").Visible(false);
    })

    .Selection(s => s.Mode(SelectionMode.Single))

)

