        <br />
        <p>Encrypted Data of the Statement Download: <span id="acct_stmt_encData_download_sbi"></span></p><br>
        <p>Downloaded: <span id="acct_stmt_download_sbi"></span></p>
        <hr />
        <div id="BankStatement_DG_sbi"></div>
    </div>

<script>
    $(document).ready(function () {
        $('input[name="bank_radio"]').on("change", function (evt) {
            $("#sbi").hide();
            $("#bob").hide();
            if (evt.target.id == "sbi_bank") {
                $("#sbi").show();
            }
            if (evt.target.id == "bob_bank") {
                $("#bob").show();
            }
        })
    })

</script>
@*BOB*@
<script>
    function authclick() {
        debugger;
        authclick_new();
    }
    function authclick_new() {
        debugger;
        var accnt_Number = document.getElementById("acno_balanceEnquiry").value;//"07590100022904";//"26220100001136"; //"03290100005239"
        $.ajax({
            type: 'POST',
             @*url: '@Url.Action("AuthenticationCall", "BankEnquiries", new { area = "Facility" })',*@
            url: '@Url.Action("GetAuthenticationToken", "BankAPI", new { area = "Profile" })',
            cache: false,
            data:
            {
                AccountNumber: accnt_Number,
            },
            success: function (data)
            {
              //  HideLoader();
                debugger;
                var parsedToken = JSON.parse(data)
                $("#encryptedData_Auth").text(data);
                if (parsedToken.error) {
                    $("#auth_Token").text(parsedToken.error_description)
                }
                else {
                    $("#auth_Token").text(parsedToken.access_token);
                }
            },
            error: function (jqXHR, textStatus, errorThrown) {
                HideLoader();
                DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
            }
        });
    }
