@* SBI *@
<script>
    //41866719821
    function authclick_sbi()
    {
        ShowLoader();
        var accnt_Number = document.getElementById("acno_balanceEnquiry_sbi").value;//"07590100022904";//"26220100001136"; //"03290100005239"
        $.ajax({
            type: 'POST',
            url: '@Url.Action("AuthenticationService_SBI", "BankAPI", new { area = "Profile" })',
            cache: false,
            data:
            {
                AccountNumber: accnt_Number,
            },
            success: function (data)
            {
                HideLoader();
                $("#encryptedData_Auth_sbi").text(JSON.stringify(data.jsonParam));
                $("#auth_Token_sbi").text(data.jsonParam.responseData);
            },
            error: function (jqXHR, textStatus, errorThrown)
            {
                HideLoader();
                DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
            }
        });
    }
    function acctStatement_sbi()
    {
        ShowLoader();
        var accnt_Number_accstmnt = document.getElementById("acno_acctStmt_sbi").value;
        var fromdate_acctStmnt = document.getElementById("fromdate_acctStmt_sbi").value;
        var todate_acctStmt = document.getElementById("todate_acctStmt_sbi").value;
        var authToken = document.getElementById("auth_Token_sbi").innerHTML;
        $.ajax({
            type: 'POST',
            url: '@Url.Action("GenerateStatement_SBI", "BankAPI", new { area = "Profile" })',      
            cache: false,
            data:
            {
                AccessToken :authToken,
                AccNo: accnt_Number_accstmnt,
                FromDate: fromdate_acctStmnt,
                ToDate: todate_acctStmt
            },
            success: function (data)
            {
                HideLoader();
                console.log(data);
                $("#acct_stmt_sbi").text(data.jsonParam.responseData);
                $("#acct_stmt_encData_sbi").text(JSON.stringify(data.jsonParam));
                $("#encReq_sbi").text(data.jsonParam.encryptedRequest)
                $("#encRes_sbi").text(data.jsonParam.encryptedResponse)
                if (data.jsonParam.responseData) {
                    plotStatementGrid(data.jsonParam.responseData)
                }
            },
            error: function (jqXHR, textStatus, errorThrown) {
                HideLoader();
                DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
            }
        });
    }
    function acctBalance_sbi()
    {
        ShowLoader();
        var accnt_Number = document.getElementById("acno_balanceEnquiry_sbi").value
        var authToken = document.getElementById("auth_Token_sbi").innerHTML;
        $.ajax({
            type: 'POST',
            url: '@Url.Action("AccountBalance_SBI", "BankAPI", new { area = "Profile" })',
            cache: false,
            data:
            {
                AccessToken :authToken,
                AccNo: accnt_Number,
            },
            success: function (data)
            {
                HideLoader();
                console.log(data);
                $("#bal_encData_sbi").text(JSON.stringify(data.jsonParam));
                $("#balance_balAPI_sbi").text(data.jsonParam.responseData);
            },
            error: function (jqXHR, textStatus, errorThrown) {
                HideLoader();
                DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
            }
        });
    }
    function acctStatement_download_sbi()
    {
        ShowLoader();
        var accnt_Number_accstmnt = document.getElementById("acno_acctStmt_download_sbi").value;
        var refno_acctStmnt = document.getElementById("refno_acctStmt_download_sbi").value;
        var authToken = document.getElementById("auth_Token_sbi").innerHTML;
        $.ajax({
            type: 'POST',
            url: '@Url.Action("DownloadStatement_SBI", "BankAPI", new { area = "Profile" })',
            cache: false,
            data:
            {
                AccessToken :authToken,
                AccNo: accnt_Number_accstmnt,
                RefNo: refno_acctStmnt
            },
            success: function (data)
            {
                HideLoader();
                console.log(data);
                $("#acct_stmt_download_sbi").text(data.jsonParam.responseData);
                $("#acct_stmt_encData_download_sbi").text(JSON.stringify(data.jsonParam));
                if (data.jsonParam.responseData) {
                    plotStatementGrid(data.jsonParam.responseData)
                }
            },
            error: function (jqXHR, textStatus, errorThrown) {
                HideLoader();
                DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
            }
        });
    }
