@using DevExtreme.AspNet.Mvc.Builders
@using DevExtreme.AspNet.Mvc
@using System.Net.Http;

@{
    bool showHorizontalBar = ViewBag.ShowHorizontalBar ?? false;
}

@(Html.DevExtreme().DataGrid().CustomDataGridListing()
   .ID("CenterPurposeListGrid")
   .DataSource(d => d.Mvc()
       .Controller("CenterPurpose")
       .LoadAction("GetCenterPurposeDetail")
       .LoadMode(DataSourceLoadMode.Raw)
       .Key("ID")
   )

   .Columns(columns =>
   {
       columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);
       columns.Add().DataField("Purpose").Caption("Purpose").Width("auto").MinWidth(150).AllowEditing(false);
       columns.Add().DataField("Active").Caption("Active").Width("auto").MinWidth(100);
       columns.Add().DataField("Add_By").Visible(false);
       columns.Add().DataField("Add_Date").Caption("Add On").DataType(GridColumnDataType.Date).Format("dd-MM-yyyy HH:mm:ss");
       columns.Add().DataField("Edit_By").Visible(false);
       columns.Add().DataField("Edit_Date").Visible(false);
       columns.Add().DataField("Action_Status").Visible(false);
       columns.Add().DataField("Action_By").Visible(false);
       columns.Add().DataField("Action_Date").Visible(false);
       columns.Add().DataField("ID").Visible(false);
   })
   //.Summary(summary =>
   //{
   //    summary.TotalItems(total =>
   //    {
   //        total.Add().Column("Purpose").SummaryType(SummaryType.Count).DisplayFormat("Total Records: {0}");
   //        total.Add().Column("Active").SummaryType(SummaryType.Count).DisplayFormat("Active Count: {0}");
   //    });

   //    summary.GroupItems(group =>
   //    {
   //        group.Add().Column("Purpose").SummaryType(SummaryType.Count)
   //            .DisplayFormat("Group Total: {0}")
   //            .ShowInGroupFooter(true);
   //    });
   //})
   .ColumnResizingMode(ColumnResizingMode.Widget)
   .RenderAsync(true)
   .Sorting(sorting => sorting.Mode(GridSortingMode.Multiple))
   .Grouping(g => g.AutoExpandAll(true).ContextMenuEnabled(true).ExpandMode(GridGroupingExpandMode.ButtonClick))
   .OnInitialized("CenterPurpose_OnInitialized")
   .OnSelectionChanged("CenterPurpose_OnSelectionChanged")
   .OnContextMenuPreparing("CenterPurpose_OnContextMenuPreparing")
   .OnCellDblClick("CenterPurpose_OnCellDblClick")
)