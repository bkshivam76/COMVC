@using DevExtreme.AspNet.Mvc;
@using System.Web.Mvc.Html;
@using System.Data;
@model ConnectOneMVC.Areas.Facility.Models.Chart
@{
    //ViewBag.Title = "center_website";
    Layout = "";
    string ThanksYouImageURL = Request.Url.Scheme + "://" + Request.Url.Authority + "/Content/Events/images/thankyou.png";
}
<table width="100%" border="0" align="center" cellpadding="0" cellspacing="0">
    <tbody>
        <tr>
            <td align="center">
                <table border="0" align="center" cellpadding="0" cellspacing="0">
                    <tbody>
                        <tr>
                            <td align="center">
                                <table border="0" align="center" cellpadding="0" cellspacing="0" style=" max-width:900px">
                                    <tbody>
                                        <tr>
                                            <td style="text-align: left; border: ridge 2px grey; box-shadow: 7px 10px 1px rgba(0,0,0,.1); border-radius: 10px; font-size: 18px; margin: 0 auto; background: #fff; margin-top: 40px; padding-bottom: 15px ">
                                                <img style="display:inline-block; border:0px; width: 100%;border-radius: 7px 7px 0 0" src="@Model.header_image" @*width="@Model.header_width" height="@Model.header_height"*@ />
                                                @*<img style="display:inline-block; line-height:0px; font-size:0px; border:0px; max-width: 400px;" src= "@ThanksYouImageURL" class="thankyou" />*@
                                                @*<p style="font-size: 20px;">@Html.Raw(Model.confirmation_message)</p>*@
                                            <div style="padding: 0 20px 10px 20px">
                                                @if (Model.chartResponseStatus == "APPROVE")
                                                {
                                                    @Html.Raw(Model.approval_message)
                                                }
                                                else if (Model.chartResponseStatus == "REJECT")
                                                {
                                                    @Html.Raw(Model.rejection_message)
                                                }
                                                else
                                                {
                                                    @Html.Raw(Model.confirmation_message)
                                                }                                                
                                                @if (Model.show_reg_slip && Model.chartResponseStatus == "APPROVE")
                                                {
                                                    <a href="@Model.urlOrigin/Facility/Chart/ChatResponse_Success?ChartInstanceId=@Model.ChartInstanceId&chartResponseStatus=@Model.chartResponseStatus&ChartResponseId=@Model.ChartResponseId&FromEmail=true" style="display:inline-block; color:#fff; text-decoration:none; background:#703b99; border:none; padding:10px 30px; border-radius:30px; text-transform:capitalize; box-shadow: 0 6px 10px 1px rgb(112 59 153 / 40%); cursor:pointer; transition: .5s all;font-family: 'Source Sans Pro', sans-serif;">
                                                        Print Registration Slip
                                                    </a>
                                                }
                                            </div>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </td>
        </tr>
    </tbody>
</table>