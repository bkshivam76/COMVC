                selected_ac_nonac_BlkInfo = data.AC_R_NONAC_BLK
                selected_category_BlkInfo = data.CATEGORY_BLK
                selected_room_capacity_BlkInfo = data.ROOMCAPACITY_BLK
                selected_bed_count_BlkInfo = data.BEDCOUNT_BLK
                selected_fromdate_BlkInfo = data.FROMDATE_BLK
