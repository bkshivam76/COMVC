@using DevExtreme.AspNet.Mvc;

@model ConnectOneMVC.Areas.Facility.Models.ResponseMiscDetails

<div class="ResponseAccomodation_ClearReferences">
    @using DevExtreme.AspNet.Mvc;

    @{
        Html.EnableClientValidation();
        Html.EnableUnobtrusiveJavaScript();
        Html.AntiForgeryToken();

        var responseID = (string)ViewBag.ChartResponseID;
        var instanceID = (Int64)ViewBag.ChartInstanceID;
        var gridToRefresh = (string)ViewBag.gridToRefresh;
    }
    <style>
        .dx-datagrid-headers.dx-datagrid-nowrap td {background-color: white !important; color: #85859f; font-size: smaller;}
        .dx-datagrid-nodata{display:none;}
        .dx-master-detail-cell {padding: 0 !Important;}
        .master-detail-caption {padding: 0 0 5px 10px;font-size: 14px; font-weight: bold; }
        .dx-empty {display:none  !important;}
    </style>
    <script>

        var todate_str = "@Model.todate";
        var fromdate_str = "@Model.fromdate";
        var fromtime_str = "@Model.fromtime";
        var totime_str = "@Model.totime";
    </script>
    @helper Render_DetailDG()
    {
        @(Html.DevExtreme().DataGrid().CustomDataGrid()
        .ID("LookUp_Get_AccommodationList_datagrid")
        .Columns(columns =>
        {
            columns.Add().DataField("REC_ID").Caption("REC_ID").Visible(false);
            columns.Add().DataField("NAME").Caption("Name");
            columns.Add().DataField("Allowed").Caption("Allowed");
            columns.Add().DataField("Allotted").Caption("Allotted").Visible(true);
            columns.Add().DataField("Available").Visible(true);
        }).Selection(s => s.Mode(SelectionMode.Single))
        .MasterDetail(md =>
        {
        md.Enabled(true);
        md.AutoExpandAll(false);
        md.Template(@<text><div class="master-detail-caption">
                            @(Html.DevExtreme().DataGrid()//.ID("LookUp_Get_AccommodationDetailList_datagrid")
                                .ColumnAutoWidth(true)
                                .ShowBorders(true)
                                .Columns(columns =>
                                {
                                    columns.Add().DataField("CNAME").Caption("Name").Visible(true);
                                    columns.Add().DataField("CITY").Caption("City");
                                    columns.Add().DataField("CenterName");
                                    columns.Add().DataField("Arr_Date").DataType(GridColumnDataType.Date).Format("dd/MM/yyyy hh:mm").Visible(true);
                                    columns.Add().DataField("Dep_Date").DataType(GridColumnDataType.Date).Format("dd/MM/yyyy hh:mm").Visible(true);
                                    //columns.Add().DataField("Dep_Time").DataType(GridColumnDataType.DateTime).Format("hh:mm").Visible(true);
                                    columns.Add().DataField("ROOMID").Visible(false);
                                })
                                .DataSource(d => d.Mvc().Controller("Chart").LoadAction("LookUp_Get_AccomodationDetailsList").LoadMode(DataSourceLoadMode.Raw)
                                .LoadParams(
                                    new
                                    {
                                        DDRefresh = new JS("function (){ return Look_Accommodation_DDrefresh;}"),
                                        end_date = new JS("function() { return todate_str;}"),
                                        fromdate = new JS("function() { return fromdate_str;}"),
                                        fromtime = new JS("function() { return fromtime_str;}"),
                                        end_time = new JS("function() { return totime_str;}"),
                                        roomid = new JS("data.REC_ID")
                                    }).LoadMode(DataSourceLoadMode.Raw)
                                )
                            )
        </div>
                        </text>);
        })               
    )

    }
    <script>
        function expandDetailedGrid() {
            var mainDDGrid = $("#LookUp_Get_AccommodationList_datagrid").dxDataGrid("instance");
            mainDDGrid.expandAll(-1);
        }
    </script>
    <div id="Frm_ChartResponse_Accomodation" class="container-fluid">
        <form>
            <div class="row">

                <div class="row">
                    <div class="col-sm-12 md-12 px-10">
                        <div class="col-sm-6 md-6 pll">
                            <div class="form-field">
                                <label class="control-label text-red" for="user">From Date:</label>
                                @(Html.DevExtreme().DateBox().CustomDateBox().ID("fromdate_Accom").Name("fromdate_Accom").ShowClearButton(true).Value(Model.fromdate)
                                .Type(DateBoxType.Date).Placeholder("From Date").Min(new DateTime(1990, 01, 01)).Max(new DateTime(2038, 12, 31)).OnValueChanged("fromdate_Valuechanged_Accom")
                            )
                            </div>
                        </div>
                        <div class="col-sm-6 md-6 pll">
                            <div class="form-field">
                                <label class="control-label text-red" for="user">From Time:</label>
                                @(Html.DevExtreme().DateBox().CustomDateBox().Name("fromtime_Accom").ID("fromtime_Accom").Min(DateTime.MinValue).Type(DateBoxType.Time).Value(Model.fromtime)
                                .DisplayFormat("hh:mm a").UseMaskBehavior(true).Placeholder("hh:mm AM/PM").Interval(15).OnValueChanged("fromtime_ValueChange_Accom")
                            )
                            </div>
                        </div>
                    </div>
                </div>
                <script>
                    function fromdate_Valuechanged_Accom() {
                        fromdate_str = JS_Json_Date_To_ddMMyyyy($("#fromdate_Accom").dxDateBox("instance").option("value"));
                        var AccomodationDDinstance = $("#AccommodationMiscID").dxDropDownBox("instance");
                        AccomodationDDinstance.getDataSource().reload();
                        $("#LookUp_Get_AccommodationList_datagrid").dxDataGrid("instance").getDataSource().reload();
                        //clearAccommodationDropdown()
                    }
                    function fromtime_ValueChange_Accom() {
                        fromtime_str = JS_Json_Date_To_ddMMyyyy($("#fromtime_Accom").dxDateBox("instance").option("value"));
                        var AccomodationDDinstance = $("#AccommodationMiscID").dxDropDownBox("instance");
                        AccomodationDDinstance.getDataSource().reload();
                        $("#LookUp_Get_AccommodationList_datagrid").dxDataGrid("instance").getDataSource().reload();
                        //clearAccommodationDropdown()
                    }
                </script>
                <div class="row">
                    <div class="col-sm-12 md-12 px-10">
                        <div class="col-sm-6 md-6 pll">
                            <div class="form-field">
                                <label class="control-label text-red" for="user">To Date:</label>
                                @(Html.DevExtreme().DateBox().CustomDateBox().ID("todate_Accom").Name("todate_Accom").ShowClearButton(true).Value(Model.todate)
                                    .Type(DateBoxType.Date).Placeholder("To Date").Min(new DateTime(1990, 01, 01)).Max(new DateTime(2038, 12, 31)).OnValueChanged("todate_Valuechanged_Accom")
                                )
                            </div>
                        </div>
                        <div class="col-sm-6 md-6 pll">
                            <div class="form-field">
                                <label class="control-label text-red" for="user">To Time:</label>
                                @(Html.DevExtreme().DateBox().CustomDateBox().Name("totime_Accom").ID("totime_Accom").Type(DateBoxType.Time).Min(DateTime.MinValue).Value(Model.totime)
                                    .DisplayFormat("hh:mm a").UseMaskBehavior(true).Placeholder("hh:mm AM/PM").Interval(15).OnValueChanged("totime_ValueChange_Accom")
                                )
                            </div>
                        </div>
                    </div>
                </div><br />
                <script>
                    function todate_Valuechanged_Accom() {
                        todate_str = JS_Json_Date_To_ddMMyyyy($("#todate_Accom").dxDateBox("instance").option("value"));
                        var AccomodationDDinstance = $("#AccommodationMiscID").dxDropDownBox("instance");
                        AccomodationDDinstance.getDataSource().reload();
                        $("#LookUp_Get_AccommodationList_datagrid").dxDataGrid("instance").getDataSource().reload();
                        //clearAccommodationDropdown()
                    }
                    function totime_ValueChange_Accom() {
                        totime_str = JS_Json_Date_To_ddMMyyyy($("#totime_Accom").dxDateBox("instance").option("value"));
                        var AccomodationDDinstance = $("#AccommodationMiscID").dxDropDownBox("instance");
                        AccomodationDDinstance.getDataSource().reload();
                        $("#LookUp_Get_AccommodationList_datagrid").dxDataGrid("instance").getDataSource().reload();
                        //clearAccommodationDropdown()
                    }

                </script>
                <div class="col-sm-12 md-12 pll">
                    <div class="form-field">
                        <label class="control-label text-red" for="user">Choose Accomodation:</label>
                        @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("AccommodationMiscID").Name("AccommodationMiscID").Placeholder("Choose Accomodation")
                            .ValueExpr("REC_ID").DisplayExpr("NAME")
                            .DataSource(d => d.Mvc().Controller("Chart").LoadAction("LookUp_Get_AccomodationList").LoadMode(DataSourceLoadMode.Raw)
                            .Key("REC_ID").LoadParams(new { DDRefresh = new JS("function (){ return Look_Accommodation_DDrefresh;}"),
                                end_date = new JS("function() { return todate_str;}"),
                                fromdate = new JS("function() { return fromdate_str;}"),
                                fromtime = new JS("function() { return fromtime_str;}" ),
                                end_time = new JS("function() { return totime_str;}" )
                            }))
                            //.OnValueChanged("Look_Accommodation_EditValueChanged")
                            .ContentTemplate(@<text> @Render_DetailDG() </text>)
                        )
                    </div>
                </div>
                <script>
                    var Look_Accommodation_DDrefresh, Look_AccommodationDetail_DDrefresh;
                    var Look_AccommodationList_DataGrid = $("#LookUp_Get_AccommodationList_datagrid").dxDataGrid("instance");
                    function clearAccommodationDropdown() {
                        Look_AccommodationList_DataGrid = $("#LookUp_Get_AccommodationList_datagrid").dxDataGrid("instance");
                        Look_AccommodationList_DataGrid.clearSelection();
                        $("#AccommodationMiscID").dxDropDownBox("instance").reset();
                    }
                </script>
                <div class="col-sm-12 md-12 pll">
                    <div class="form-field">
                        <label class="control-label text-red" for="user">Bed Count:</label>
                        @(Html.DevExtreme().NumberBox().CustomNumberBox() .ID("BedCount") .Name("BedCount").Value(Model.BedCount).ReadOnly(false).FocusStateEnabled(true).Format("#0") )
                    </div>
                </div>
                <div class="col-sm-12 md-12 pll">
                    <div class="form-field">
                        <label class="control-label text-red" for="user">Remarks:</label>
                        @(Html.DevExtreme().TextArea().ID("Remarks_Accd").Name("Remarks_Accd").Value(Model.Remarks).ReadOnly(false).FocusStateEnabled(true))
                    </div>
                </div>

            </div>
            <div class="row">
                <div class="col-sm-12 styleActionBtn">
                    @(Html.DevExtreme().Button().CustomSaveButton().Text("Update").ID("Response_Accomodation_Add").FocusStateEnabled(true).UseSubmitBehavior(false).OnClick("addResponseAccomodation"))
                    @(Html.DevExtreme().Button().CustomCloseButton().Text("Cancel").ID("Response_Accomodation_Cancel").FocusStateEnabled(true).OnClick(@<Text> function () { CloseAddAccomodation();} </Text>))
                </div>
            </div>
        </form>
    </div><!--[Form Div]-->

    <script>
        $(document).ready(function () {
            //expandDetailedGrid();

        });
        $(function () {
            $("#Response_Accomodation_popup").dxPopup({
                onHiding: function (e) {
                    $.ajax({
                        type: 'GET',
                        url: "/Facility/Chart/SessionClearChartAccommodation",
                        cache: false
                    });
                }
            });
        });
        function CloseAddAccomodation(){
            HidePopup('Response_Accomodation_popup');
        }

        function addResponseAccomodation(e)
        {
            var AccomodationMiscID = $("#AccommodationMiscID").dxDropDownBox("instance").option("value");
            var Txt_BedCount = $("#BedCount").dxNumberBox("instance").option("value");
            var Txt_Remarks = $("#Remarks_Accd").dxTextArea("instance").option("value");
            var _fromdate = $("#fromdate_Accom").dxDateBox("instance").option("value");
            var _todate = $("#todate_Accom").dxDateBox("instance").option("value");
            var _fromtime = $("#fromtime_Accom").dxDateBox("instance").option("value");
            var _totime = $("#totime_Accom").dxDateBox("instance").option("value");
            ShowLoader();
            $.ajax({
            type: 'Post',
            url: "/Facility/Chart/UpdateChartResponseAccomodation",
            cache: false,
            data: {
                ChartResponseID: "@responseID",
                Accomodation: AccomodationMiscID,
                BedCount: Txt_BedCount,
                remarksText: Txt_Remarks,
                fromdate: _fromdate == null ? null : JS_Json_Date_To_ddMMyyyy(_fromdate),
                todate: _todate == null ? null : JS_Json_Date_To_ddMMyyyy(_todate),
                fromtime: _fromtime == null ? null : JS_Json_Date_To_ddMMyyyy(_fromtime),
                totime: _totime == null ? null : JS_Json_Date_To_ddMMyyyy(_totime),
                gridToRefresh: "@gridToRefresh"
            },
            success: function (data)
            {
                HideLoader();
                
                if (data.jsonParam.result) {
                    var alertClick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                    HidePopup('Response_Accomodation_popup');
                    alertClick.done(function (alertResult) {
                        if (alertResult) {
                            if (data.jsonParam.flag == 'AccommodationRegister_InfoGrid') {
                                GoAccomRegister()
                            }
                            else {
                                ASPxClientControl.GetControlCollection().GetByName(data.jsonParam.flag).Refresh();
                            }
                        }
                    })
                }
                else if (data.jsonParam.result == false) {
                    if (data.jsonParam.flag != undefined && data.jsonParam.flag == "refeshDropdown") {
                        var AccomodationDDinstance = $("#AccommodationMiscID").dxDropDownBox("instance");
                        AccomodationDDinstance.getDataSource().reload();
                    }
                    DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                }

            }
        });
    }
    </script>

</div>