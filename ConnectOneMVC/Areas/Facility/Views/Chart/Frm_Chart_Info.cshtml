        function ChartInfo_ViewSwitch_ValueChange(e)
        {
            CompactMode_chartInfo = e.value ? "Compact" : "Default";
            if (CompactMode_chartInfo == "Default") { document.getElementById("ChartInfo_hideFilters").style.display = "none"; }
            else { document.getElementById("ChartInfo_hideFilters").style.display = "block";}
            ReloadGrid_ChartInfo();
        }
        function ChartInfo_ViewSwitchInstances_ValueChange(e) {
            InstanceSwitchMode_chartInfo = e.value;
            if (e.value) {
                $("#ChartInfoViewInstancesModeSwitch").dxSwitch("instance").option("value", true);
            }
            else {
                $("#ChartInfoViewInstancesModeSwitch").dxSwitch("instance").option("value", false);
            }
            RefreshGridView("ChartInfoGrid");
        }
        function ReloadGrid_ChartInfo()
        {
            $.ajax({
                url: '@Url.Action("Frm_Chart_Info_Grid", "Chart")',
                type: "POST",
                data:
                {
                    ShowHorizontalBar: 1,
                    Layout: ChartInfoGrid.cpClientLayout,
                    VouchingMode: false,
                    ViewMode: CompactMode_chartInfo,
                    ColumnToBeHidddenIndex: ChartInfoGrid.cpColumnToBeHidddenIndex,
                    ColumnToBeShownIndex: ChartInfoGrid.cpColumnToBeShownIndex
                },
                success: function (res)
                {
                    $("#ChartInfoGridPartialView").html(res);
                }
            });
        }
        function ChartInfoGrid_ContextMenuFunction(s, e)
        {
            if (e.item.name == "CreateForm") {
                CreateForm_Click();
            }
            if (e.item.name == "CopyForm") {
                CreateCopy_Click();
            }
            if (e.item.name == "ShiftForm") {
                ShiftForm_Click();
            }
            else if (e.item.name == 'Export2GoogleSheet') {
                Export2GoogleSheet_Click();
            }
            else if (e.item.name == 'EditForm') {
                EditForm_Click();
            }
            else if (e.item.name == 'DeleteForm') {
                DeleteForm_Click();
            }
            else if (e.item.name == 'Responses') {
                showResponses();
            }
            else if (e.item.name == 'ChartVisibility') {
                FormVisibility_Click();
            }
            else if (e.item.name == 'GuestSummary') {
                showGuestSummary();
            }
            else if (e.item.name == 'MapUserChart') {
                ViewMappedUserstoChart();
            }
            else if (e.item.name == 'MapUserProject') {
                ServiceProjectMapSubject();
            }
            else if (e.item.name == 'ViewMapUserProject') {
                ServiceProjectMappedSubject();
            }
            else if (e.item.name == 'ListPreview') {
                OnChartInfoListPreviewClick();
            }
            else if (e.item.name == 'Close') {
                closeChartInfo();
            }
        }
        function GetConfirmbox(title, DisplayMessage, YesMsg, NoMsg) {
            var _confirmbox = DevExpress.ui.dialog.custom({
                title: title,
                messageHtml: DisplayMessage,
                showCloseButton: true,
                buttons: [
                    {
                        text: YesMsg,
                        elementAttr:
                        {
                            id: "CustomConfirmDialog_YesButton"
                        },
                        onClick: function () {
                            return true
                        }
                    },
                    {
                        text: NoMsg,
                        elementAttr:
                        {
                            id: "CustomConfirmDialog_NoButton"
                        },
                        onClick: function () {
                            return false
                        }
                    }
                ],
                popupOptions:
                {
                    elementAttr:
                    {
                        id: "CustomConfirmDialog_Popup"
                    },
                    onShown: function (e) {
                        $(".dx-dialog-button:first").focus();
                    },
                    onHidden: function (e) {
                        e.component.dispose();
                        $("#CustomConfirmDialog_Popup").remove();
                    }
                }
            });
            return _confirmbox;
        }
        function Export2GoogleSheet_Click()
        {
            var focusIndex = ChartInfoGrid.GetFocusedRowIndex();
            if (focusIndex < 0) {
                DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                return;
            }
            ChartInfo_GetRowData(focusIndex);
            var Confirmation_1 = DevExpress.ui.dialog.confirm("<div> Are You Sure you want to export responses of Form: <br><b>" + formName  +"</b> </div>", "Confirmation");
            Confirmation_1.done(function (confirmResult_1) {
                if (confirmResult_1) {
