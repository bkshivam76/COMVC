        function OnChartListGridNestedFocusedRowChange(s, e) {
            //if (ChartInfo_IsDetailRowExpanded == true) {
            if (s.GetTopVisibleIndex() >= 0) {
                ChartInfo_IsDetailRowExpanded = true;
                ChartInfo_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
                //ChartInfo_NestedGrid_AccessID = s.uniqueID;
                if (ChartInfo_NestedRecord_FocusedRowIndex >= 0) {
                    ShowLoader();
                    s.GetRowValues(s.GetFocusedRowIndex(), 'Zone;Centre;CEN_ID;Pending;Approved;Rejected;Cancelled;Total', OnChartInfo_GetGridRowValues);
                }
                else {
                    ChartInfo_NestedGrid_RowID = null;
                }
            }
        }
        function OnChartInfo_GetGridRowValues(values) {
            HideLoader();
            if (values[2] != null) {
                ChartInfoNested_Zone = values[0];
                ChartInfoNested_Centre = values[1];
                ChartInfoNested_CenId = values[2];
                ChartInfoNested_Pending = values[3];
                ChartInfoNested_Approved = values[4];
                ChartInfoNested_Rejected = values[5];
                ChartInfoNested_Cancelled = values[6];
                ChartInfoNested_Total = values[7];
            }
            else {
                ChartInfoNested_CenId = null
            }
        }

        function ChartGrid_Nested_BeginCallBack(s, e) {
            e.customArgs["command"] = e.command;
            ChartInfo_GetRowData(ChartInfoGrid.GetFocusedRowIndex());
            /*$('#ChartInfoDetailGrid').dxDataGrid("instance").GetRowValues(ChartInfo_NestedRecord_FocusedRowIndex, 'Zone;Centre;CEN_ID;Pending;Approved;Rejected;Cancelled;Total', OnChartInfo_GetGridRowValues)*/
            e.customArgs["regCenId"] = ChartInfoNested_CenId;
            e.customArgs["CHART_INSTANCE_ID"] = chartInstanceID;
            e.customArgs["ShowHorizontalBar"] = Chart_ShowHorizontalBar;
        }
        
        function ChartGrid_DetailRowExpanding(s, e) {
            ChartInfo_IsDetailRowExpanded = true;
            s.SetFocusedRowIndex(e.visibleIndex);
            ChartInfoNested_Zone = null;
            ChartInfoNested_Centre = null;
            ChartInfoNested_CenId = null;
            ChartInfoNested_Pending = null;
            ChartInfoNested_Approved = null;
            ChartInfoNested_Rejected = null;
            ChartInfoNested_Cancelled = null;
            ChartInfoNested_Total = null;
        }
        function ChartGrid_DetailRowCollapsing(s, e) {
            ChartInfo_IsDetailRowExpanded = false;
            s.SetFocusedRowIndex(-1);
            ChartInfoNested_Zone = null;
            ChartInfoNested_Centre = null;
            ChartInfoNested_CenId = null;
            ChartInfoNested_Pending = null;
            ChartInfoNested_Approved = null;
            ChartInfoNested_Rejected = null;
            ChartInfoNested_Cancelled = null;
            ChartInfoNested_Total = null;
        }

