        function ChartInfo_GetRowData(RowIndex = null) {
            debugger;
            var focusedrow = RowIndex == null ? ChartInfoGrid.GetFocusedRowIndex() : RowIndex;
            var topindex = ChartInfoGrid.GetTopVisibleIndex();
            var Index = focusedrow - topindex;
            var ChartInfoPageData = ChartInfoGrid.cpPagedata;
            if (ChartInfoPageData != null && ChartInfoPageData.length > 0 && Index < ChartInfoPageData.length) {
                chartInstanceID = ChartInfoPageData[Index][0];
                formName = ChartInfoPageData[Index][1];
                isApprovalRequired = ChartInfoPageData[Index][2];
                formDescription = ChartInfoPageData[Index][3];
                formTitle = ChartInfoPageData[Index][4];
                formID = ChartInfoPageData[Index][5];
                TravelFormID_chart = ChartInfoPageData[Index][6];
                EventID_chartInfo = ChartInfoPageData[Index][7];
                ServiceReportID_chartInfo = ChartInfoPageData[Index][6];
                totalRegistrationCount = ChartInfoPageData[Index][9];
                purpose_chartinfo = ChartInfoPageData[Index][10];
                registrations_chartinfo = ChartInfoPageData[Index][11];
                approved_chartinfo = ChartInfoPageData[Index][12];
                rejected_chartinfo = ChartInfoPageData[Index][13];
                if (formDescription != null && formDescription.trim().length > 0)
                {
                    //responseTabName = formName + " - " + formDescription;
                    responseTabName = formName;
                }
                else
                {
                    responseTabName = formName;
                }

            }
            else {
                chartInstanceID = null;
            }
        }
