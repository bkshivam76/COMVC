@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool InstanceMode = ViewBag.InstanceMode == null ? false : (bool)ViewBag.InstanceMode;
    int ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;


}

@(Html.DevExtreme().DataGrid().CustomDataGridListing(1)
        .ID("ChartInfoGrid_dx")
        .DataSource(d => d.Mvc().Controller("Chart")
        .LoadAction("ChartInfoGrid_dx_load").LoadMode(DataSourceLoadMode.Raw)
        .Key("CHART_INSTANCE_ID").LoadParams(new { AllInstances = InstanceMode })
        .OnBeforeSend("ChartInfoGrid_dx_OnBeforeSend")
        )

        .Columns(columns =>
        {
            columns.Add().DataField("ChartInfoGrid_dx_Compact_Column")
            .Name("ChartInfoGrid_dx_Compact_Column").Caption("").Visible(false).ShowInColumnChooser(false)
            .CellTemplate(new JS("ChartInfoGrid_dx_Compact_Column_Template")).DataType(GridColumnDataType.String)
            .CalculateCellValue("ChartInfoGrid_dx_Compact_Column_CellValue").Width("100%").RenderAsync(true);
            columns.Add().DataField("Sr").Width(40).Visible(true);
            columns.Add().DataField("From").Width(140).Visible(true)
            .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy").Width(140);

            columns.Add().DataField("To").Width(140).Visible(true)
           .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
            columns.Add().DataField("PROJECT").Width(100).Visible(true);
            columns.Add().DataField("Event Name").Width(150).Visible(true);
            columns.Add().DataField("Form").Visible(true);
            columns.Add().DataField("Purpose").Width(100).Visible(true);
            columns.Add().DataField("Form Link").Width(80).Visible(true).EncodeHtml(false);

            columns.Add().DataField("Login Requirement").Caption("Login Required").Width(120).Visible(true);
            columns.Add().DataField("Approval Requirement").Caption("Approval Required")
            .Width(120).Visible(true).TrueText("True").FalseText("False").ShowEditorAlways(false);
            columns.Add().DataField("Reg Allowed").Caption("Generate Reg No.")
            .Width(120).Visible(true).TrueText("True").FalseText("False").ShowEditorAlways(false);
            columns.Add().DataField("Gen RegNo On Approval").Caption("Generate Reg No. On Approval")
            .Width(120).Visible(true).TrueText("True").FalseText("False").ShowEditorAlways(false);
            columns.Add().DataField("Reg No Format").Width(130).Visible(true);
            columns.Add().DataField("Form Title").Width(250).Visible(true);
            columns.Add().DataField("Form Description").Width(250).Visible(true);
            columns.Add().DataField("Confirmation Msg").Width(250).Visible(true);
            columns.Add().DataField("Approval Msg").Width(250).Visible(true);
            columns.Add().DataField("Rejection Msg").Width(250).Visible(true);
            columns.Add().DataField("Display Mode").Width(100).Visible(true);
            columns.Add().DataField("From Time").Width(100).Visible(true)
            .HeaderFilter(s=>s.DataSource("function (e){return DxGrid_TimeColHeaderDS(e,'From Time')}")).CalculateFilterExpression("DxGrid_TimeColFilterExp")
            .DataType(GridColumnDataType.DateTime).Format("HH:mm:ss").CalculateCellValue("function (rowData) {return DxGrid_TimeColCellValue(rowData,'From Time'); }");
            columns.Add().DataField("To Time").Width(100).Visible(true)
            .HeaderFilter(s => s.DataSource("function (e){return DxGrid_TimeColHeaderDS(e,'To Time')}")).CalculateFilterExpression("DxGrid_TimeColFilterExp")
            .DataType(GridColumnDataType.DateTime).Format("HH:mm:ss").CalculateCellValue("function (rowData) {return DxGrid_TimeColCellValue(rowData,'To Time'); }");
            columns.Add().DataField("Registrations").Width(90).Visible(true).Visible(true).DataType(GridColumnDataType.Number);
            columns.Add().DataField("Approved").Width(80).Visible(true);
            columns.Add().DataField("Rejected").Width(80).Visible(true);
            columns.Add().DataField("Arrived").Width(80).Visible(true);
            columns.Add().DataField("Not Arrived").Width(80).Visible(true);
            columns.Add().DataField("Males").Width(80).Visible(true).DataType(GridColumnDataType.Number);
            columns.Add().DataField("Females").Width(80).Visible(true).DataType(GridColumnDataType.Number);
            columns.Add().DataField("CHART_INSTANCE_ID").Caption("Form Instance ID").Width(160)
            .Visible(true).SortIndex(1).SortOrder(SortOrder.Desc);//.Alignment(HorizontalAlignment.Left);
            columns.Add().DataField("CHART_ID").Width(80)
            .Visible(false).SortIndex(0).SortOrder(SortOrder.Desc).GroupIndex(0).ShowWhenGrouped(false)
            .GroupCellTemplate(new JS("ChartInfoGrid_dx_GroupCell_Template"));
            columns.Add().DataField("Project_ID").Visible(false);
            columns.Add().DataField("SR_ID").Visible(false);
            columns.Add().DataField("Event_ID").Visible(false);
            columns.Add().DataField("TravelInsID").Visible(false).DataType(GridColumnDataType.Number);
            columns.Add().DataField("CI_FROM_DATE").Caption("Chart From Date").Visible(false)
            .DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss").Width(140);//Bug #137472
            columns.Add().DataField("CI_TO_DATE").Caption("Chart To Date").Visible(false)
            .DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss").Width(140);//Bug #137472
            columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);//Bug #137209 Fix

        })
  
        .SearchPanel(g => g.Visible(true))
        //.Summary(s =>
        //{
        //    s.TotalItems(item => item.Add().Column("SummaryColumn").DisplayFormat(""));
        //    s.GroupItems(Gitem => Gitem.Add().Column("SummaryColumn")
        //    .ShowInGroupFooter(true).DisplayFormat(""));

        //})
        .MasterDetail(md =>
        {
            md.AutoExpandAll(false);
            md.Enabled(true);
            md.Template(new JS("ChartInfoGrid_dx_DetailTemplate"));
        })
        .OnInitialized("ChartInfoGrid_dx_OnInitialized")
        //.OnCellPrepared("ChartInfoGrid_dx_OnCellPrepared")
        //.OnRowPrepared("ChartInfoGrid_dx_OnRowPrepared")
        .OnContentReady("ChartInfoGrid_dx_OnContentReady")
        //.OnCellDblClick("ChartInfoGrid_dx_OnCellDblClick")
        .OnSelectionChanged("ChartInfoGrid_dx_OnSelectionChanged")
        ////.OnFocusedRowChanged("ChartInfoGrid_dx_OnFocusedRowChanged")
        .OnRowExpanding("ChartInfoGrid_dx_OnRowExpanding")
        .OnRowCollapsing("ChartInfoGrid_dx_OnRowCollapsing")
        .OnContextMenuPreparing("ChartInfoGrid_dx_OnContextMenuPreparing")     
        .OnEditorPreparing("ChartInfoGrid_dx_OnEditorPreparing")  
        .WordWrapEnabled(false)       
)