        function GetConfirmbox_ChartInfodx(title, DisplayMessage, YesMsg, NoMsg, DeleteMsg) {
            var _confirmbox = DevExpress.ui.dialog.custom({
                title: title,
                messageHtml: DisplayMessage,
                showCloseButton: true,
                buttons: [
                    {
                        text: YesMsg,
                        elementAttr:
                        {
                            id: "CustomConfirmDialog_YesButton_ChartInfo"
                        },
                        onClick: function () {
                            return "Overwrite"
                        }
                    },
                    {
                        text: NoMsg,
                        elementAttr:
                        {
                            id: "CustomConfirmDialog_NoButton_ChartInfo"
                        },
                        onClick: function () {
                            return "Append"
                        }
                    },
                    {
                        text: DeleteMsg,
                        elementAttr:
                        {
                            id: "CustomConfirmDialog_DeleteButton_ChartInfo"
                        },
                        onClick: function () {
                            return "Remove"
                        }
                    }
                ],
                popupOptions:
                {
                    elementAttr:
                    {
                        id: "CustomConfirmDialog_Popup_ChartInfo"
                    },
                    onShown: function (e) {
                        $(".dx-dialog-button:first").focus();
                    },
                    onHidden: function (e) {
                        e.component.dispose();
                        $("#CustomConfirmDialog_Popup_ChartInfo").remove();
                    }
                }
            });
            return _confirmbox;
        }

