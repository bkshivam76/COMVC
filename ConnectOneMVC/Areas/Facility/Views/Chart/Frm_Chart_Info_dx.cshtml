        function ChartInfoGrid_dx_GroupCell_Template(container, templateData)
        {
            var ChartFromDate, ChartToDate, InstCount, ChartForm = "";
            var RowData = DxGrid_GetGroupRowData(templateData.data)
            if (RowData != null)
            {
                ChartFromDate = RowData.CI_FROM_DATE;
                ChartToDate = RowData.CI_TO_DATE;
                InstCount = RowData.INST_COUNT;
                ChartForm = RowData.Form;
            }
            if (templateData.groupContinuesMessage && ChartForm.length == 0) {
                $(container).html(templateData.groupContinuesMessage);
                return
            }
            var dateString = "";
            if (ChartFromDate) {

                var fromdate = new Date(ChartFromDate);
                dateString = " From " + fromdate.getDate() + "-" + (fromdate.getMonth() + 1) + "-" + fromdate.getFullYear();
            }
            if (ChartToDate) {

                var todate = new Date(ChartToDate);
                dateString = dateString + " Till " + todate.getDate() + "-" + (todate.getMonth() + 1) + "-" + todate.getFullYear();
            }
            if (dateString) {
                if (dateString.length > 0) { dateString = "   (" + dateString + " )"; }
            }

            $(container).html(ChartForm + dateString + "   (Total Instances:" + InstCount + ")");


        }

        function ChartInfoGrid_dx_Compact_Column_Template(container, templateData) {
                var From = (JS_Json_Date_To_ddMMyyyy((templateData.data.From ?? ""), "DD-MM-YY") ?? ""),
                    To = (JS_Json_Date_To_ddMMyyyy((templateData.data.To ?? ""), "DD-MM-YY") ?? "");
                var FromTime = templateData.data["From Time"], ToTime = templateData.data["To Time"];
                var FromTM = "", ToTM = "";
                var InsFromTo = "", InsFromToTime = "";

                if ((From.length > 0) && (To.length > 0)) {
                    InsFromTo = From + " to " + To;
                }
                else if ((To.length > 0)) {
                    InsFromTo = "Valid till " + To;
                }
                else if ((From.length > 0)) {
                    InsFromTo = "Valid from " + From;
                }
                if (FromTime) {
                    FromTM = ConvertTimeStringToJsDate(FromTime)
                        .toLocaleString('en-US', { hour: 'numeric', minute: 'numeric', hour12: true });
                }
                if (ToTime) {
                    ToTM = ConvertTimeStringToJsDate(ToTime)
                        .toLocaleString('en-US', { hour: 'numeric', minute: 'numeric', hour12: true });;
                }

                if ((FromTM.length > 0) && (ToTM.length > 0)) {
                    InsFromToTime = FromTM + " to " + ToTM;
                }
                else if ((ToTM.length > 0)) {
                    InsFromToTime = "Active till " + ToTM;
                }
                else if ((FromTM.length > 0)) {
                    InsFromToTime = "Active from " + FromTM;
                }
                var ApprovalRequirement = templateData.data["Approval Requirement"];
                var GenRegNo = templateData.data["Reg Allowed"];
                var GenRegNoApproval = templateData.data["Gen RegNo On Approval"];
                var Resubmission = templateData.data["Resubmission"];
                var approvalReqIconClass = "fa fa-check green";
                var GenRegNoIconClass = "fa fa-check green";
                var GenRegNoApprovalIconClass = "fa fa-check green";
                var ResubmissionIconClass = "fa fa-check green";
                if (ApprovalRequirement == false) {
                    approvalReqIconClass = "fa fa-times red";
                }
                if (GenRegNo == false) {
                    GenRegNoIconClass = "fa fa-times red";
                }
                if (GenRegNoApproval == false) {
                    GenRegNoApprovalIconClass = "fa fa-times red";
                }
                if (Resubmission == false) {
                    ResubmissionIconClass = "fa fa-times red";
                }
                var imagePath = templateData.data.ChartImageLink;
                if (imagePath.Length == 0) {
                    imagePath = "../../Content/image/No_Image.jpg";
                }
                var Purpose = templateData.data["Purpose"];
                var htmlString = "<div class='clearfix form-row'>" +
                    "<div class='evt-details col-md-2 clearfix'>" +
                    "<div class='col-xs-3 p-r-5 p-l-0'>" +
