        function checkColumnChanged(colList1, colList2) {
            for (var i = 0; i < colList1.length; i++) {
                var col = colList1[i].dataField;
                if (col) {
                    var foundcol = false;
                    for (var a = 0; a < colList2.length; a++) {
                        var colOld = colList2[a].dataField;
                        if (col == colOld) {
                            foundcol = true;
                        }
                    }
                    if (!foundcol) {
                        return col;
                    }
                }
            }
            return "";
        }
