                formName = ChartInfoPageData[Index]["Form"];
                isApprovalRequired = ChartInfoPageData[Index]["Approval Requirement"];
                formDescription = ChartInfoPageData[Index]["Form Description"];
                formTitle = ChartInfoPageData[Index]["Form Title"];
                formID = ChartInfoPageData[Index]["CHART_ID"];
                TravelFormID_chart = ChartInfoPageData[Index]["TravelInsID"];
                EventID_chartInfo = ChartInfoPageData[Index]["SR_ID"];
                ServiceReportID_chartInfo = ChartInfoPageData[Index]["TravelInsID"];
                totalRegistrationCount = ChartInfoPageData[Index]["Registrations"];
                purpose_chartinfo = ChartInfoPageData[Index]["Purpose"];
                registrations_chartinfo = ChartInfoPageData[Index]["Registrations"];
                approved_chartinfo = ChartInfoPageData[Index]["Approved"];
                rejected_chartinfo = ChartInfoPageData[Index]["Rejected"];

                if (formDescription != null && formDescription.trim().length > 0) {
                    //responseTabName = formName + " - " + formDescription;
                    responseTabName = formName;
                }
                else {
                    responseTabName = formName;
                }

