                <script>
                    function BulkAllotment_ChartInfo() {
                        var focusIndex = ChartInfoGrid_dx.getSelectedRowsData();//ChartInfoGrid.GetFocusedRowIndex();
                        if (focusIndex.length < 1) {
                            DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                            return;
                        }
                        //ChartInfo_GetRowData(focusIndex);
                        if (purpose_chartinfo == "REGISTRATION" || purpose_chartinfo == "ACCOMMODATION") {
                            ShowLoader();
                            BulkAllotment_Accommodation(chartInstanceID, totalRegistrationCount);
                        }
                        else {
                            DevExpress.ui.dialog.alert("Please Select The Form With The Purpose 'Accommodation' or 'Registration' Only", "Alert");
                        }
                    }
                </script>
