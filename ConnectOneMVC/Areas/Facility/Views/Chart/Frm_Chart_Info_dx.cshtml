            else {
                chartInstanceID = null;
            }
        }

        function ChartInfoGrid_dx_DetailTemplate(container, templateData) {
            var GridName = templateData.component.element()[0].id
            var chartInstanceID = templateData.data.CHART_INSTANCE_ID;
            ChartInfoGrid_dx_Detail(container, GridName, chartInstanceID, Chart_ShowHorizontalBar);
        }

        function ChartInfoGrid_dx_Detail(container, GridName, chartInstanceID,  AllColumns) {
            var DetailGridID = GridName + chartInstanceID;
            $(container).append("<div id='" + DetailGridID + "' class='DG_DetailGrid DataGridListing'></div>");
            $("div[id='" + DetailGridID + "']").dxDataGrid({
                dataSource:
                    new DevExpress.data.DataSource({

                        store: new DevExpress.data.CustomStore(
                            {
                                key: "CEN_ID",
                                loadMode: "raw",
                                load: function () {
                                    return $.getJSON("/Facility/Chart/ChartInfoGridDetailGrid_Load?chartInstanceID=" + chartInstanceID );
                                }
                            }),
                        //key: "CEN_ID",
                        //loadUrl: "/Facility/Chart/ChartInfoGridDetailGrid_Load?chartInstanceID=" + chartInstanceID
                    }),
            /*     keyExpr:"UniqueID",*/
                width: "100%",
                columns:
                    [
                        {
                            dataField: "Zone", caption: "Zone",width: 150, visible: true
                        },
                        {
                            dataField: "Centre", caption: "Centre", width: "130", visible: true
                        },
                        {
                            dataField: "CEN_ID", caption: "Centre ID", width: 130, visible: false
                        },
                        {
                            dataField: "Pending", caption: "Pending", width: 130, visible: true
                        },
                        {
                            dataField: "Approved", caption: "Approved", width: 130, visible: true
                        },
                        {
                            dataField: "Rejected", caption: "Rejected", width: 130, visible: true
                        },
                        {
                            dataField: "Cancelled", caption: "Cancelled", width: 130, visible: true
                        },
                        {
                            dataField: "Total", caption: "Total", width: 130, visible: true
                        },
                        {
                            dataField: "SummaryColumn", visible: false, showInColumnChooser: false
                        }
                    ],
                //summary: {
                //    totalItems: [{
                //        column: 'CEN_ID',
                //        summaryType: 'count',
                //        name:'count'
                //    }],
                //},
               // onRowPrepared: function (e) { ChartInfoGrid_dx_Detail_onRowPrepared(e) },
                onContentReady: function (e) { ChartInfoGrid_dx_Detail_onContentReady(e) },
                onSelectionChanged: function (e) { ChartInfoGrid_dx_Detail_onSelectionChanged(e) },
                onContextMenuPreparing: function (e) { ChartInfoGrid_dx_Detail_onContextMenuPreparing(e) }
            });
            var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance");
            DxGrid_CustomDataGridListing(DetailGridID, AllColumns, instance)

            instance.option("filterRow.visible", false);
            instance.option("paging.enabled", false);
        }
        function ChartInfoGrid_dx_Detail_onContentReady(e) {
            debugger;
            DxGrid_SetGridUIinColHiding(e.element[0].id, Chart_ShowHorizontalBar, true)
            DxGrid_GetFIlterBuilderDataSource(e)
        }
        function ChartInfoGrid_dx_Detail_onContextMenuPreparing(e) {
            if (!e.items) e.items = [];
            if (e.target == "header") {
                DxGrid_HeaderContextMenu(e)
            }
            else if ((e.target == "content" && e.row && e.row.rowType == "groupFooter") || e.target == "footer") {
               // if (!(CompactMode_chartInfo == "Compact"))
                DxGrid_FooterContextMenu(e);
            }
            else if (e.target == "content" && e.row && e.row.rowType == "data") {
                e.items = [{
                    text: "Refresh",
                    icon: "fa-solid fa-arrow-rotate-right text-success",
                    onItemClick: function () {
                        e.component.refresh();
                    }
                }]
            }
        }
        function ChartInfoGrid_dx_Detail_onSelectionChanged(e) {
            var selectedRowKeys = e.selectedRowKeys;
            if (selectedRowKeys != null && selectedRowKeys.length > 0) {
                ChartInfo_Dx_GetDetailGridRowData(e.selectedRowsData);
            }
            else {
                detailGridClearReference();
            }
        }
        function ChartInfo_Dx_GetDetailGridRowData(rowdata) {
            HideLoader();
            values = rowdata[0];
            if (values["CEN_ID"] != null) {
                ChartInfoNested_Zone = values["Zone"];
                ChartInfoNested_Centre = values["Centre"];
                ChartInfoNested_CenId = values["CEN_ID"];
                ChartInfoNested_Pending = values["Pending"];
                ChartInfoNested_Approved = values["Approved"];
                ChartInfoNested_Rejected = values["Rejected"];
                ChartInfoNested_Cancelled = values["Cancelled"];
                ChartInfoNested_Total = values["Total"];
            }
            else {
                ChartInfoNested_CenId = null
            }
        }
        function detailGridClearReference() {
            ChartInfoNested_CenId = null
            ChartInfoNested_Zone = null;
            ChartInfoNested_Centre = null;
            ChartInfoNested_CenId = null;
            ChartInfoNested_Pending = null;
            ChartInfoNested_Approved = null;
            ChartInfoNested_Rejected = null;
            ChartInfoNested_Cancelled = null;
            ChartInfoNested_Total = null;}
    </script>

