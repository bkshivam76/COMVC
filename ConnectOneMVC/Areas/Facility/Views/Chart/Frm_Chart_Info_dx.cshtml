        function ChartInfoGrid_dx_Compact_Column_CellValue(rowData) {
            var data =
                [
                    rowData.Form, rowData.PROJECT, rowData.Sr, rowData.CHART_INSTANCE_ID, rowData["Form Link"],
                    rowData["Form Title"], rowData["Form Description"],rowData["Event Name"], rowData.Frequency, rowData.Registrations, rowData.Approved,
                    rowData.Rejected, rowData.Accommodation, rowData.Arrived, rowData["Login Requirement"],
                    rowData["Reg No Format"], rowData["Display Mode"], rowData["Confirmation Msg"], rowData["Approval Msg"],
                    rowData["Rejection Msg"], rowData["Not Arrived"]
                ]
            return data.join(" ")
        }

