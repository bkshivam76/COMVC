
<div class="ResponseAddApprovalRemarks_ClearReferences">
    @using DevExtreme.AspNet.Mvc;

    @{
        Html.EnableClientValidation();
        Html.EnableUnobtrusiveJavaScript();
        Html.AntiForgeryToken();

        var instanceID = (string)ViewBag.ChartInstanceID;
        var chartResponseID = (string)ViewBag.ChartResponseID;
        var remarks = (string)ViewBag.ChartResponseApprovalRemarks;
        var gridnametorefresh = (string)ViewBag.GridNameToRefresh;
    }
    <script src="~/Content/fontawesome/js/fontawesome_v5_all.js"></script>

    <div id="Frm_Chart_FormResponse_Approval_AddRemark">
        <form>
            <div class="row">
                <div class="form-field">
                    <div class="container-fluid">
                        <div class="col-sm-12 md-12 pll">
                            <label class="control-label text-red" for="user">Enter Reason:</label>
                            @(Html.DevExtreme().TextArea().ID("Approval_Response_Reason").Name("Approval_Response_Reason").MinHeight(150).Placeholder("Enter reason....").Value(remarks).AutoResizeEnabled(true))
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="form-field">
                    <div class="container-fluid">
                        <div class="col-sm-12 styleActionBtn">
                            @(Html.DevExtreme().Button().CustomSaveButton().Text("Approval").ID("Approval_Response_Reason_Add").FocusStateEnabled(true).UseSubmitBehavior(false).OnClick("addResponseApprovalReason"))
                            @(Html.DevExtreme().Button().CustomCloseButton().Text("Cancel").ID("Approval_Response_Reason_Cancel").FocusStateEnabled(true).OnClick(@<Text> function () { CloseAddApprovalReasons();} </Text>))

                        </div>
                    </div>
                </div>
            </div><!--[Buttons]-->
        </form>
    </div><!--[Form Div]-->

    <script>

        function CloseAddApprovalReasons(){
            HidePopup('Approve_Response_Reason_popup');
        }

        function addResponseApprovalReason(e)
        {
           
            var reason = $("#Approval_Response_Reason").dxTextArea("instance").option("value").trim();

            var GridInstance = $('#ChartResponsesInfoGrid_dx').data("dxDataGrid")//BK SOUMY
            if (GridInstance !== void 0) {
                updateStatusResponseAPICall_Dx("@instanceID", "@chartResponseID", "APPROVE", reason);
            }

            else
                updateStatusResponseAPICall("@instanceID", "@chartResponseID", "APPROVE", reason);
        }
    </script>

</div>