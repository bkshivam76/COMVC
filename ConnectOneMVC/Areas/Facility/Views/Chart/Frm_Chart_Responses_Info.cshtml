        function ChartResponsesInfoGrid_ContextMenuInit(s, e)
        {
            if (e.objectType == "row")
            {                
                if (Chart_Approval_Required == false || Show_Approval == false)
                {
                    var Item = e.menu.GetItemByName("Approve");
                    if (Item != null) Item.SetVisible(false);
                     Item = e.menu.GetItemByName("Draft");
                    if (Item != null) Item.SetVisible(false);
                     Item = e.menu.GetItemByName("Reject");
                    if (Item != null) Item.SetVisible(false);
                }
                s.SelectRowOnPage(e.index);
            }
        }
        function ChartResponsesInfoGrid_ContextMenuFunction(s, e)
        {
            if (e.item.name == "Close")
            {
                closeChartResponsesInfo();
            }
            if (e.item.name == "AddRemarks")
            {
                ChartResponses_AddRemarks();
            }
            else if (e.item.name == 'AddResponse') {
                ChartResponses_AddResponse();
            }
            else if (e.item.name == 'AddLinkedResponse') {
                ChartResponses_AddLinkedFormResponse();
            }
            else if (e.item.name == 'Approve') {
                ChartResponses_ChangeStatus("APPROVE");
            }
            else if (e.item.name == 'Draft') {
                ChartResponses_ChangeStatus("DRAFT");
            }
            else if (e.item.name == 'Reject') {
                ChartResponses_ChangeStatus("REJECT");
            }
            else if (e.item.name == 'MarkArrived') {
                ChartResponses_Arrived("MarkArrived");
            }
            else if (e.item.name == 'UnMarkArrived') {
                ChartResponses_Arrived("UnMarkArrived");
            }
            else if (e.item.name == 'Accomodation') {
                ChartResponses_Accomodation();
            }
            else if (e.item.name == 'EditResponse') {
                ChartResponses_EditResponse();
            }
            else if (e.item.name == 'DeleteResponse') {
                ChartResponses_DeleteResponse();
            }
            else if (e.item.name == 'ViewResponse') {
                ChartResponses_Preview();
            }
            else if (e.item.name == 'CopyViewResponseLink') {
                ChartResponses_CopyResponseLink("CopyViewResponseLink");
            }
            else if (e.item.name == 'ImportResponse') {
                ChartResponses_ImportResponse()
            }
