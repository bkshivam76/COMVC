                    var URL = ServicePath + "ViewChartUser/" + Chart_Instance_ID + "/" + UserID + "/" + UserABID + "/?ActionMethod=_View&ResponseID=" + Chart_Response_ID;
                    navigator.clipboard.writeText(URL); DevExpress.ui.notify({ message: 'Response Preview Link Has Been Copied ! You can paste it as Required...', width: 500, shading: true, position: 'center' }, "success", 1500);
                }
                else if (_Action == "GroupDetails") {
                    ShowLoader();
                    $.ajax({
                        type: 'GET',
                        url: "/Facility/Chart/Frm_ChartResponse_GroupDetails",
                        cache: false,
                        data:
                        {
                            ChartResponseID: Chart_Response_ID,
                        },
                        success: function (data) {
                            HideLoader();
                            OpenPopup("ResponseGroupDetails_Popup", "Group Registration Details", null, "auto", 800, true, data);
                        }
                    });
                }
                else if (_Action == "CreateLocalAddress") {

                    if (UserABID == null || UserABID.length == 0) {
                        DevExpress.ui.dialog.alert("The details of the User are not available for this response ! ", "Alert");
                        return;
                    }

                    ShowLoader();
                    $.ajax({
                        type: 'GET',
                        url: "/Facility/Chart/CreateLocalAddress",
                        cache: false,
                        data:
                        {
                            AB_ID: UserABID,
                        },
                        success: function (data) {
                            HideLoader();
                            DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                        }
                    });
                }
                else if (_Action == "Highlight") {
                    ShowLoader();
                    $.ajax({
                        type: 'GET',
                        url: "/Facility/Chart/saveResponseHighlight",
                        cache: false,
                        data:
                        {
                            ChartResponseID: Chart_Response_ID,
                            Highlight: HighlightColor
                        },
                        success: function (data) {
                            HideLoader();
                            if (data.jsonParam.result == false) {
                                DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                            }
                            else {
                                //ASPxClientControl.GetControlCollection().GetByName("ChartResponsesInfoGrid").PerformCallback();
                                ASPxClientControl.GetControlCollection().GetByName("ChartResponsesInfoGrid").UnselectRows();
                            }
                        }
                    });
                }
                else if (_Action == "Notify") {
                    OpenPopup("ChartResponsesNotificationAdd_modal", "Notification Settings", "@Url.Action("Frm_ChartResponses_Add_Notification", "Chart", new { @area = "Facility" })?ActionMethod=_New&Chart_Instance_Id=" + Chart_Instance_ID + "&Chart_Response_Id=" + Chart_Response_ID + "&Chart_Response_Status=" + Chart_Response_Status + "&RegistrationsTotalCount=" + @RegistrationsTotalCount+ "&ApprovedResponseCount=" + @ApprovedResponseCount+ "&RejectionResponseCount=" + @RejectionResponseCount+ "&DefaultStatus=" + @DefaultStatus, "100%",700);
                }
            }
        }
