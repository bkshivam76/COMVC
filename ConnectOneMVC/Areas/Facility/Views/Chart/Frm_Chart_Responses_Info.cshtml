                        {
                            id: "CustomConfirmDialog_YesButton"
                        },
                        onClick: function () {
                            return true
                        }
                    },
                    {
                        text: NoMsg,
                        elementAttr:
                        {
                            id: "CustomConfirmDialog_NoButton"
                        },
                        onClick: function () {
                            return false
                        }
                    }
                ],
                popupOptions:
                {
                    elementAttr:
                    {
                        id: "CustomConfirmDialog_Popup"
                    },
                    onShown: function (e) {
                        $(".dx-dialog-button:first").focus();
                    },
                    onHidden: function (e) {
                        e.component.dispose();
                        $("#CustomConfirmDialog_Popup").remove();
                    }
                }
            });
            return _confirmbox;
