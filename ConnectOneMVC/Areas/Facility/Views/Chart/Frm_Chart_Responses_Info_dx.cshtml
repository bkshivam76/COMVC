        function ViewMore_FormResponse() {
            $(".form-que").find('.row').each(function () {
                if ($(this).height() > 50) {
                    if ($(this).hasClass('hit') == false) {
                        $(this).addClass('hit').after("<a class='small text-muted' id='formResponse_viewmore'>View <span>more</span></a>")
                    }
                }
            });
            setTimeout(function () {
                $('.form-que #formResponse_viewmore').unbind('click');
                $('.form-que #formResponse_viewmore').click(function () {
                    var tish = $(this).prev('.row')
                    $(tish).toggleClass('hit');

                    if ($('span', this).text() == "more")
                        $('span', this).text("less")
                    else
                        $('span', this).text("more");
                });
            }, 500)
        }
        function GetConfirmbox(YesMsg, NoMsg) {
            var _confirmbox = DevExpress.ui.dialog.custom({
                title: "Post Form Response...",
                messageHtml: "Do you want to Post Form Repsonse by Self or Share Posting Link with Others ?",
                buttons: [
                    {
                        text: YesMsg,
                        elementAttr:
                        {
                            id: "CustomConfirmDialog_YesButton"
                        },
                        onClick: function () {
                            return true
                        }
                    },
                    {
                        text: NoMsg,
                        elementAttr:
                        {
                            id: "CustomConfirmDialog_NoButton"
                        },
                        onClick: function () {
                            return false
                        }
                    }
                ],
                popupOptions:
                {
                    elementAttr:
                    {
                        id: "CustomConfirmDialog_Popup"
                    },
                    onShown: function (e) {
                        $(".dx-dialog-button:first").focus();
                    },
                    onHidden: function (e) {
                        e.component.dispose();
                        $("#CustomConfirmDialog_Popup").remove();
                    }
                }
            });
            return _confirmbox;
        }
        function ChartResponses_AddResponse_Click(e) {
            if (e.itemData == "Add Response") {
                ChartResponses_AddResponse_Dx();
            }
            else if (e.itemData == "Add Linked Form Response") { ChartResponses_AddLinkedFormResponse_Dx(); }
            else if (e.itemData == "Add Travel Details") { ChartResponses_AddMiscFormResponse_Dx("Travel") }
            else if (e.itemData == "Add Feedback") { ChartResponses_AddMiscFormResponse_Dx("Feedback") }
            else if (e.itemData == "Import Response") { ChartResponses_ImportResponse_Dx() }
        }
        function chartResponseShareClick(e)
        {
            $("#ChartResponseActionSheet").dxActionSheet("instance").option('target', e.element);
            $("#ChartResponseActionSheet").dxActionSheet("instance").option('visible', true);
        }
        function ClosePopupPreview_SM() {

            $("#ChartResponse_Preview").dxPopup("hide");
