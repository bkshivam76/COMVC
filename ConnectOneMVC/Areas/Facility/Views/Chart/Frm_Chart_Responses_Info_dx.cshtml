        function CRInfoGrid_dx_Load_Columns(CRInfoGrid_ViewMOde)
        {
            ChartResponsesInfoGrid_dx.beginUpdate();
            var _columns = ChartResponsesInfoGrid_dx.option("columns");
            if (CRInfoGrid_ViewMOde == "Compact")
            {
                VisibleColumns_CRInfoGrid_dx = [];
                for (var i = 0; i < _columns.length; i++)
                {
                    var name = _columns[i].dataField;
                    var ColumnVisible = ChartResponsesInfoGrid_dx.columnOption(name, "visible");
                    if (name == "ChartResponsesInfoGrid_dx_Compact_Column" || name=="iIcon")
                    {
                        ChartResponsesInfoGrid_dx.columnOption(name, "visible", true);
                    }
                    else if (ColumnVisible == true)
                    {
                        VisibleColumns_CRInfoGrid_dx.push(name);
                        ChartResponsesInfoGrid_dx.columnOption(name, "visible", false);
                    }
                }
                ChartResponsesInfoGrid_dx.option("editing",
                    {
                    mode: "row",  // Row-wise editing
                    allowUpdating: false,  // Disable updating rows
                    allowAdding: false,    // Disable adding rows
                    allowDeleting: false   // Disable deleting rows
                });
            }
            else
            {
                ChartResponsesInfoGrid_dx.columnOption("ChartResponsesInfoGrid_dx_Compact_Column", "visible", false);
                for (var i = 0; i < VisibleColumns_CRInfoGrid_dx.length; i++)
                {
                    ChartResponsesInfoGrid_dx.columnOption(VisibleColumns_CRInfoGrid_dx[i], "visible", true);
                }
                ChartResponsesInfoGrid_dx.option("editing", {
                    mode: "row",  // Row-wise editing
                    allowUpdating: true,  // Enable updating rows
                    allowAdding: false,    // Disable adding rows
                    allowDeleting: false   // Disable deleting rows
                });
            }
            var SummaryItems = ChartResponsesInfoGrid_dx.option("summary.groupItems")
            if (SummaryItems == void 0 || SummaryItems == null || SummaryItems.length == 0) {
                SummaryItems = [];
            }
            var index = SummaryItems.findIndex(obj => { return obj.name === 'Name_Name_count' })
            if (index == -1)
            {
                SummaryItems.push({
                    column: 'Name',
                    displayFormat: "Total Registrations: {0}",
                    summaryType: 'count',
                    name: 'Name_Name_count'
                })
            }
            index = SummaryItems.findIndex(obj => { return obj.name === 'REGISTRATIONS_REGISTRATIONS_sum' })
            if (index == -1)
            {
                SummaryItems.push({
                    column: 'REGISTRATIONS',
                    displayFormat: "Total Registered Souls: {0}",
                    summaryType: 'sum',
                    name: 'REGISTRATIONS_REGISTRATIONS_sum'
                })
            }
            ChartResponsesInfoGrid_dx.option("summary.groupItems", SummaryItems)
           // ChartResponsesInfoGrid_dx.repaint();
            ChartResponsesInfoGrid_dx.endUpdate();
           // ChartResponsesInfoGrid_dx.updateDimensions();
        }
