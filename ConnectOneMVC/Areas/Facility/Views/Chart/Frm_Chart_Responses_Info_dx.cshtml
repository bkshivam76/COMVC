            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                DxGrid_AdjustSize(e.component, $("#Chart_Responses_ParentDiv_dx .report_button_div"),"Dynamic_Content_popup",evt)
            });
            ChartResponsesInfoGrid_dx = e.component;
            ShowLoader();
