        function ChartResponsesInfoGrid_RowUpdating(e) {
            let newData = e.newData;
            let userProfileKeyArray = ["AB_ID", "Course", "CenCategory", "ID_NAME"/*, "Address", "Age", "BK_TITLE", "Centre", "City", "Country", "Course", "DATE_OF_COURSE", "DOB", "Education", "Email1", "Gender", "ID_NAME", "ID_NO", "Mob1", "Name", "Occupation", "PIN", "RESP_ID", "Specialities", "State"*/];
            userProfileKeyArray.forEach(key => {
                if (!newData.hasOwnProperty(key)) {
                    newData[key] = e.oldData[key];
                    if (key.includes("CenCategory")) {
                        var centreCategory = $("#Centre_dd_radio" + e.key).dxRadioGroup("instance")
                        if (centreCategory) {
                            newData[key] = centreCategory.option("value");
                        }
                    }
                }
                else if (key.includes("DOB")) {
                    newData[key] = JS_Json_Date_To_ddMMyyyy(e.oldData[key]);
                }
                else if (key.includes("DATE_OF_COURSE")) {
                    newData[key] = e.oldData[key];
                }
            });
            e.newData = newData;
        }
