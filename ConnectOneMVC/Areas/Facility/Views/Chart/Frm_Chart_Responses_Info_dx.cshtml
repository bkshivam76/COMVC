        function updateStatusResponseAPICall_Dx(instanceId, chartResponseId, status, reason) {

            $.ajax({
                type: 'GET',
                url: "/Facility/Chart/ChangeChartResponseStatus",
                cache: false,
                data: {
                    status: status,
                    ChartResponseID: chartResponseId,
                    chartInstanceID: instanceId,
                    responseReason: reason
                },
                success: function (data) {
                    HideLoader();
                    if (status == "REJECT") {
                        HidePopup('Reject_Response_Reason_popup');
                    }
                    else if (status == "APPROVE") {
                        HidePopup('Approve_Response_Reason_popup');
                    }
                    else if (status == "CANCEL") {
                        HidePopup('Cancel_Response_Reason_popup');
                    }
                    var alertClick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                    alertClick.done(function (alertResult)
                    {
                        if (alertResult)
                        {
                            var GridInstance = $('#ChartResponsesInfoGrid_dx').data("dxDataGrid")
                            if (GridInstance !== void 0)
                            {
                                ChartResponsesInfoGrid_dx.clearSelection();
