    <script>
        function ExportPDF() {
            ChartResponsesInfoGrid.ExportTo(ASPxClientGridViewExportFormat.Pdf);
            $("#ChartResponsesInfo_modal").dxPopup("hide");
        }
        function ExportXLS() {
            ChartResponsesInfoGrid.ExportTo(ASPxClientGridViewExportFormat.Xls);
            $("#ChartResponsesInfo_modal").dxPopup("hide");
        }
        function ExportXLSX() {
