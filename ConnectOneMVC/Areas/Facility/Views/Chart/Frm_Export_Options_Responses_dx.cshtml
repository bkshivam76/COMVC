        }
        function ExportRTF() {
            ChartResponsesInfoGrid.ExportTo(ASPxClientGridViewExportFormat.Rtf);
            $("#ChartResponsesInfo_modal").dxPopup("hide");
            }
        function CRExportXLSX_dx() {
            //debugger;
            const workbook = new ExcelJS.Workbook();
            const worksheet = workbook.addWorksheet('Sheet');
            var gridComponent = $("#ChartResponsesInfoGrid_dx").dxDataGrid("instance");
            var _columns = gridComponent.option("columns");
            var iscompact = false;
            var VisibleColumns_CRInfoGrid_dx = [];
            gridComponent.beginUpdate();
            for (var i = 0; i < _columns.length; i++)
            {
                var name = _columns[i].dataField;
                var ColumnVisible = ChartResponsesInfoGrid_dx.columnOption(name, "visible");
                if (name == "ChartResponsesInfoGrid_dx_Compact_Column")
                {
                    if (ColumnVisible == true)
                    {
                        iscompact = true;
                    }
                    gridComponent.columnOption("ChartResponsesInfoGrid_dx_Compact_Column", "visible", false);
                    continue;
                }
                if (ColumnVisible == false)
                {
                    switch (name) //not visible in export
                    {
                        case "FeedbackFormInstID":
                        case "TravelFormInstID":
                        case "NextLinkedFormInstID":
                        case "UserID":
                        case "SHARE_MESSAGE":
                        case "REC_STATUS":
                        case "ConnectOne_User_ID":
                        case "ConnectOne_Cen_ID":
                        case "SummaryColumn":
                            break;
                        default:
                            VisibleColumns_CRInfoGrid_dx.push(name);
                            gridComponent.columnOption(name, "visible", true);
                    }
                }               
            }
            //gridComponent.option({
            //    summary: {
            //        totalItems: [{
            //            column: "REGISTRATIONS",
            //            summaryType: "count",
            //            displayFormat: "Registration: {0}",
            //            showInColumn: "ChartResponsesInfoGrid_dx_Compact_Column"
            //        }]
            //    }
            //});
            gridComponent.endUpdate();
            DevExpress.excelExporter.exportDataGrid({
                worksheet: worksheet,
                component: gridComponent,
                autoFilterEnabled: true,
                keepColumnWidths: true,
                customizeCell: function (options) {
                    const { gridCell } = options;
                    const { excelCell } = options;
                    if (gridCell.rowType === 'totalFooter' && excelCell.value) {
                        excelCell.font.italic = true;
                    }
                }
            }).then(function (exportRange) {
                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: 'application/octet-stream' }), 'ChartResponsesInfoGrid_dx.xls');
                });
            }).then(function () {
                gridComponent.beginUpdate();
                for (var i = 0; i < VisibleColumns_CRInfoGrid_dx.length; i++)
                {
                    gridComponent.columnOption(VisibleColumns_CRInfoGrid_dx[i], "visible", false);
                }
                if (iscompact)
                    gridComponent.columnOption("ChartResponsesInfoGrid_dx_Compact_Column", "visible", true);
                gridComponent.endUpdate();
            });
            $("#ChartResponsesInfo_modal").dxPopup("hide");
        }
    </script>

</div>
