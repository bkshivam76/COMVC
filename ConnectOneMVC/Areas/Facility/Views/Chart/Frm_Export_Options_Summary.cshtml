<div class="ChartInfo_Export_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    @using DevExpress.XtraReports.UI;
    <div>
            @(Html.DevExtreme().Button()
                    .ID("ChartSummaryInfo_ExportGridDatapdf")
                    .Text("Export to PDF")
                    //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                    .OnClick("ExportPDF")
                    .Visible(true)
                    .Width(120)
        )<br />

            @(Html.DevExtreme().Button()
                    .ID("ChartSummaryInfo_ExportGridDataxls")
                    .Text("Export to XLS")
                    //.Icon("fa-file-excel-o")
                    .OnClick("ExportXLS")
                    .Visible(true)
                    .Width(120)
        )<br />
            @(Html.DevExtreme().Button()
                    .ID("ChartSummaryInfo_ExportGridDataxlsx")
                    .Text("Export to XLSX")
                    //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                    .OnClick("ExportXLSX")
                    .Visible(true)
                    .Width(120)
        )<br />

            @(Html.DevExtreme().Button()
                    .ID("ChartSummaryInfo_ExportGridDatadocx")
                    .Text("Export to DOCX")
                    //.Icon("export_exporttodocx_16x16office2013")
                    .OnClick("ExportDOCX")
                    .Visible(true)
                    .Width(120)
        )<br />

            @(Html.DevExtreme().Button()
                    .ID("ChartSummaryInfo_ExportGridDatartf")
                    .Text("Export to RTF")
                    //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                    .OnClick("ExportRTF")
                    .Visible(true)
                    .Width(120)
        )<br />

            @(Html.DevExtreme().Button()
                    .ID("ChartSummaryInfo_ExportGridDatacsv")
                    .Text("Export to CSV")
                    //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                    .OnClick("ExportCSV")
                    .Visible(true)
                    .Width(120)
        )
        </div>
        <script>
        function ExportPDF() {
            ChartResponse_SummaryInfoGrid.ExportTo(ASPxClientGridViewExportFormat.Pdf);
            $("#ChartSummaryInfo_modal").dxPopup("hide");
        }
        function ExportXLS() {
            ChartResponse_SummaryInfoGrid.ExportTo(ASPxClientGridViewExportFormat.Xls);
            $("#ChartSummaryInfo_modal").dxPopup("hide");
        }
        function ExportXLSX() {
            ChartResponse_SummaryInfoGrid.ExportTo(ASPxClientGridViewExportFormat.Xlsx);
            $("#ChartSummaryInfo_modal").dxPopup("hide");
        }
        function ExportCSV() {
            ChartResponse_SummaryInfoGrid.ExportTo(ASPxClientGridViewExportFormat.Csv);
            $("#ChartSummaryInfo_modal").dxPopup("hide");
        }
        function ExportDOCX() {
            ChartResponse_SummaryInfoGrid.ExportTo(ASPxClientGridViewExportFormat.Docx);
            $("#ChartSummaryInfo_modal").dxPopup("hide");
        }
        function ExportRTF() {
            ChartResponse_SummaryInfoGrid.ExportTo(ASPxClientGridViewExportFormat.Rtf);
            $("#ChartSummaryInfo_modal").dxPopup("hide");
        }
        </script>

</div>
