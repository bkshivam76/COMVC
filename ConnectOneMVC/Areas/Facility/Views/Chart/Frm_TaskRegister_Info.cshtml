                        },
                        success: function (data) {
                            HideLoader();
                            OpenPopup("Response_Accomodation_popup", "Add Accomodation", null, "auto", 800, true, data);
                        }
                    });
                }
                else if (_Action == "ShareFacebook") {
                    window.open("https://www.facebook.com/sharer.php?t=" + ShareMessage_TaskRegister)
                }
                else if (_Action == "ShareTwitter") {
                    window.open("https://twitter.com/intent/tweet?text=" + ShareMessage_TaskRegister)
                }
                else if (_Action == "ShareWhatsApp") {
                    if (MobNo_TaskRegister != null && MobNo_TaskRegister.length > 0) {
                        window.open("https://api.whatsapp.com/send?phone=" + MobNo_TaskRegister + "&text=" + ShareMessage_TaskRegister)
                    }
                    else {
                        DevExpress.ui.dialog.alert("User Mobile No. Not Available", "Information!!");
                    }
                }
                else if (_Action == "ShareTelegram") {
                    window.open("https://telegram.me/share/url/?url" + ShareMessage_TaskRegister)
                }
                else if (_Action == "ShareMail") {
                    window.open("mailto:?subject=" + formName + "&body=:" + ShareMessage_TaskRegister)
                }
                else if (_Action == "ShareSMS") {
                    //window.open("sms:9667584019" + formName + "&body=:" + ShareMessage_TaskRegister)
                    if (MobNo_TaskRegister != null && MobNo_TaskRegister.length > 0) {
                        $.ajax({
                            type: 'GET',
                            url: "/Facility/Chart/SendRegSMS",
                            cache: false,
                            data:
                            {
                                ChartResponseId: Chart_Response_ID_TaskRegister,
                                MobNo: MobNo_TaskRegister,
                                SMSType: "share_reg_no"
                            },
                            success: function (data) {
                                HideLoader();
                                var alertClick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                                alertClick.done(function (alertResult) {
                                })
                            }
                        });
                    }
                    else {
                        DevExpress.ui.dialog.alert("User Mobile No. Not Available", "Information!!");
                    }
                }
                else if (_Action == "ShareCopy") {
                    navigator.clipboard.writeText(ShareMessage_TaskRegister); DevExpress.ui.notify({ message: 'Message has been Copied ! You can paste it as Required...', width: 500, shading: true, position: 'center' }, "success", 1000);
                }
                else if (_Action == "Travel" || _Action == "Feedback")
                {
                    var OpenLnikedResponseForm = true;
                    var ReqFormInstID = 0;
                    if (_Action == "Travel")
                    {
                        ReqFormInstID = TravelFormInstID_TaskRegister;
                    }
                    else
                    {
                        ReqFormInstID = FeedbackFormInstID_TaskRegister;
                    }
                    if (ReqFormInstID)
                    {
                        GetConfirmbox('Post by Self', 'Share With Others').show().done(function (confirmboxResult)
                        {
                            OpenLnikedResponseForm = confirmboxResult;
                            ShowLoader();
                            var GuideSessionID = "";
                            $.ajax({
                                type: 'GET',
                                url: "/Facility/Chart/AddGuideSessionID",
                                cache: false,
                                data:
                                {

                                },
                                success: function (data)
                                {
                                    GuideSessionID = data.GuideSessionID;
                                    var URL = ServicePath + "ViewChartUser/" + ReqFormInstID + "/" + UserID_TaskRegister + "/" + UserABID_TaskRegister + "/?GuideSessionID=" + GuideSessionID;
                                    if (OpenLnikedResponseForm)
                                    {
                                        window.open(URL, "_blank");
                                    }
                                    else
                                    {
                                        navigator.clipboard.writeText(URL); DevExpress.ui.notify({ message: 'Link has been Copied ! You can paste it as Required...', width: 500, shading: true, position: 'center' }, "success", 1000);
                                    }
                                    HideLoader();
                                }
                            });
                        });
                    }
                    else
                    {
                        DevExpress.ui.dialog.alert(_Action+" Form Not Found", "Information");
                    }
                }
            }
        }
        function TaskRegisterInfo_ViewSwitch_ValueChange(e)
        {
            CompactMode_TaskRegister = e.value ? "Compact" : "Default";
            ReloadGrid_ChartResponesInfo();
        }
        function ReloadGrid_ChartResponesInfo()
        {
            ShowLoader();
            $.ajax({
                url: '@Url.Action("Frm_TaskRegister_Info_Grid", "Chart")',
                type: "POST",
                data:
                {
                    ShowHorizontalBar: 1,
                    Layout: TaskRegisterInfoGrid.cpClientLayout,
                    VouchingMode: false,
                    ViewMode: CompactMode_TaskRegister,
                    ColumnToBeHidddenIndex: TaskRegisterInfoGrid.cpColumnToBeHidddenIndex,
                    ColumnToBeShownIndex: TaskRegisterInfoGrid.cpColumnToBeShownIndex,
                    Chart_Instance_ID: Chart_Instance_ID_TaskRegister,
                    isApprovalRequired:Chart_Approval_Required_TaskRegister
                },
                success: function (res)
                {
                    $("#TaskRegisterGridDiv").html(res);
                    HideLoader();
                }
            });
        }
        function TaskRegisterInfoGrid_BeginCallback(s, e) {

            e.customArgs["command"] = e.command;
            e.customArgs["Chart_Instance_ID"] = Chart_Instance_ID_TaskRegister;
            e.customArgs["isApprovalRequired"] = Chart_Approval_Required_TaskRegister;
            e.customArgs["Layout"] = s.cpClientLayout;
            e.customArgs["ColumnToBeHidddenIndex"] = s.cpColumnToBeHidddenIndex;
            e.customArgs["ColumnToBeShownIndex"] = s.cpColumnToBeShownIndex;
            e.customArgs["ViewMode"] = CompactMode_TaskRegister;
        }
        function TaskRegisterInfoGrid_EndCallback(s, e)
        {
            if (e.command == "REFRESH")
            {
                s.UnselectRows();               
            }    
            ViewMore_FormResponse();
            HideLoader();
        }
        function ViewMore_FormResponse()
        {
            $(".form-que").find('.row').each(function () {
                if ($(this).height() > 50) {
                    if ($(this).hasClass('hit') == false) {
                        $(this).addClass('hit').after("<a class='small text-muted' id='formResponse_viewmore'>View <span>more</span></a>")
                    }
                }
            });
            setTimeout(function () {
                $('.form-que #formResponse_viewmore').unbind('click');
                $('.form-que #formResponse_viewmore').click(function () {
                    var tish = $(this).prev('.row')
                    $(tish).toggleClass('hit');

                    if ($('span', this).text() == "more")
                        $('span', this).text("less")
                    else
                        $('span', this).text("more");
                });
            }, 500)
        }
        function GetConfirmbox(YesMsg, NoMsg) {
            var _confirmbox = DevExpress.ui.dialog.custom({
                title: "Post Form Response...",
                messageHtml: "Do you want to Post Form Repsonse by Self or Share Posting Link with Others ?",
                buttons: [
                    {
                        text: YesMsg,
                        elementAttr:
                        {
                            id: "CustomConfirmDialog_YesButton"
                        },
                        onClick: function () {
                            return true
                        }
                    },
                    {
                        text: NoMsg,
                        elementAttr:
                        {
                            id: "CustomConfirmDialog_NoButton"
                        },
                        onClick: function () {
                            return false
                        }
                    }
                ],
                popupOptions:
                {
                    elementAttr:
                    {
                        id: "CustomConfirmDialog_Popup"
                    },
                    onShown: function (e) {
                        $(".dx-dialog-button:first").focus();
                    },
                    onHidden: function (e) {
                        e.component.dispose();
                        $("#CustomConfirmDialog_Popup").remove();
                    }
                }
            });
            return _confirmbox;
        }

