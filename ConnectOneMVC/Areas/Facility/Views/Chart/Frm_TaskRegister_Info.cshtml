        function OnTaskRegisterInfoListPreviewClick()
        {
            ShowLoader();
            OpenPopup("TaskRegisterInfo_modal", "Export Option", "@Url.Action("Frm_Export_Options_TaskRegister", "Chart", new { @area = "Facility" })", "auto",130);
        }
        function closeTaskRegisterInfo() {
            if ($(".TabPanalMenu-tabs .active").attr("id").includes("_dynamic")==true) {
                btnCloseActiveTab();
            } else {

                $("#Dynamic_Content_popup").dxPopup("hide")
            }
        }
        function TaskRegisterInfoOnInit(s, e) {
            s.ExpandAll();
            TaskRegisterInfoAdjustSize();
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                TaskRegisterInfoAdjustSize();
            });
        }
        function TaskRegisterInfoAdjustSize() {            
            var height = (document.documentElement.clientHeight * 80) / 100;
            if ("@SessionGUID".length == 0) { var height = (document.documentElement.clientHeight * 100) / 100; }
            try {
                TaskRegisterInfoGrid.SetHeight(height);
            }
            catch (err) {
            }
        }
        function TaskRegisterInfoGrid_ContextMenuInit(s, e)
        {
            if (e.objectType == "row")
            {
                if (Chart_Approval_Required_TaskRegister == false)
                {
                    var Item = e.menu.GetItemByName("Approve");
                    if (Item != null) Item.SetVisible(false);
                     Item = e.menu.GetItemByName("Draft");
                    if (Item != null) Item.SetVisible(false);
                     Item = e.menu.GetItemByName("Reject");
                    if (Item != null) Item.SetVisible(false);
                }
            }
        }
        function TaskRegisterInfoGrid_ContextMenuFunction(s, e)
        {
            if (e.item.name == "Close")
            {
                closeTaskRegisterInfo();
            }
            if (e.item.name == "AddRemarks")
            {
                TaskRegister_AddRemarks();
            }
            else if (e.item.name == 'AddResponse') {
                TaskRegister_AddResponse();
            }
            else if (e.item.name == 'AddLinkedResponse') {
                TaskRegister_AddLinkedFormResponse();
            }
            else if (e.item.name == 'Approve') {
                TaskRegister_ChangeStatus("APPROVE");
            }
            else if (e.item.name == 'Draft') {
                TaskRegister_ChangeStatus("DRAFT");
            }
            else if (e.item.name == 'Reject') {
                TaskRegister_ChangeStatus("REJECT");
            }
            else if (e.item.name == 'MarkArrived') {
                TaskRegister_Arrived("MarkArrived");
            }
            else if (e.item.name == 'UnMarkArrived') {
                TaskRegister_Arrived("UnMarkArrived");
            }
            else if (e.item.name == 'Accomodation') {
                TaskRegister_Accomodation();
            }
            else if (e.item.name == 'EditResponse') {
                TaskRegister_EditResponse();
            }
            else if (e.item.name == 'DeleteResponse') {
                TaskRegister_DeleteResponse();
            }
            else if (e.item.name == 'ViewResponse') {
                TaskRegister_Preview();
            }
        }
        function OnTaskRegisterInfoGridFocusedRowChanged(s, e)
        {
            TaskRegisterInfoGrid.SetFocusedRowIndex(-1)
        }
        function TaskRegisterInfo_GetRowData(RowIndex = null)
        {
            var focusedrow = RowIndex == null ? TaskRegisterInfoGrid.GetFocusedRowIndex() : RowIndex;
            var topindex = TaskRegisterInfoGrid.GetTopVisibleIndex();
            var Index = focusedrow - topindex;
            var TaskRegisterInfoPageData = TaskRegisterInfoGrid.cpPagedata;
            if (TaskRegisterInfoPageData != null && TaskRegisterInfoPageData.length > 0 && Index < TaskRegisterInfoPageData.length) {
                Chart_Response_ID_TaskRegister = TaskRegisterInfoPageData[Index][0];
                Chart_Response_Status_TaskRegister = TaskRegisterInfoPageData[Index][1];
                Chart_Response_Remarks_TaskRegister = TaskRegisterInfoPageData[Index][2];
                UserID_TaskRegister = TaskRegisterInfoPageData[Index][3];
                UserABID_TaskRegister = TaskRegisterInfoPageData[Index][4];
            }
            else
            {
                Chart_Response_ID_TaskRegister = null;
                Chart_Response_Status_TaskRegister = "";
                Chart_Response_Remarks_TaskRegister = "";
            }
        }
        function TaskRegisterInfoGrid_SelectionChanged(s, e) {
            if (TaskRegisterInfoGrid.GetSelectedRowCount() == 0) {
                Chart_Response_ID_TaskRegister = null;
                Chart_Response_Status_TaskRegister = "";
                Chart_Response_Remarks_TaskRegister = "";
            }
        }
        function TaskRegisterInfo_GetSelectedRowData(_Action)
        {
            if (TaskRegisterInfoGrid.GetSelectedRowCount() > 0)
            {                
                ShowLoader();
                TaskRegisterInfoGrid.GetSelectedFieldValues("RESP_ID;Status;Remarks;UserID;AB_ID;SHARE_MESSAGE;Mob1;NextLinkedFormInstID;TravelFormInstID;FeedbackFormInstID",
                    function (values) { GetSelectedFieldValuesCallback_TaskRegister(values, _Action) })
            }
            else
            {
                Chart_Response_ID_TaskRegister = null;
                Chart_Response_Status_TaskRegister = "";
                Chart_Response_Remarks_TaskRegister = "";
                NextLinkedForm_Inst_ID_TaskRegister = 0;
            }
        }
        function GetSelectedFieldValuesCallback_TaskRegister(values, _Action)
        {            
            HideLoader();
            if (values != null)
            {
                for (var Index = 0; Index < values.length; Index++)
                {
                    if (Index == 0)
                    {
                        Chart_Response_ID_TaskRegister = values[Index][0];
                        Chart_Response_Status_TaskRegister = values[Index][1];
                        Chart_Response_Remarks_TaskRegister = values[Index][2];
                        UserID_TaskRegister = values[Index][3];
                        UserABID_TaskRegister = values[Index][4];
                        ShareMessage_TaskRegister = values[Index][5];
                        MobNo_TaskRegister = values[Index][6];
                        NextLinkedForm_Inst_ID_TaskRegister = values[Index][7];
                        FeedbackFormInstID_TaskRegister = values[Index][9];
                        TravelFormInstID_TaskRegister = values[Index][8];
                    }
                    else
                    {
                        Chart_Response_ID_TaskRegister = Chart_Response_ID_TaskRegister + "," + values[Index][0];
                        Chart_Response_Status_TaskRegister = Chart_Response_Status_TaskRegister + "," + values[Index][1];
                        Chart_Response_Remarks_TaskRegister = Chart_Response_Remarks_TaskRegister + "![" + values[Index][2];
                        UserID_TaskRegister = UserID_TaskRegister + "," + values[Index][3];
                        UserABID_TaskRegister = UserABID_TaskRegister + "," + values[Index][4];
                        ShareMessage_TaskRegister = ShareMessage_TaskRegister + "![" + values[Index][5];
                        MobNo_TaskRegister = MobNo_TaskRegister + "," + values[Index][6];
                        NextLinkedForm_Inst_ID_TaskRegister = NextLinkedForm_Inst_ID_TaskRegister + "," + values[Index][7];
                        TravelFormInstID_TaskRegister = TravelFormInstID_TaskRegister + "," + values[Index][8];
                        FeedbackFormInstID_TaskRegister = FeedbackFormInstID_TaskRegister + "," + values[Index][9];
                    }
                }
                if (_Action == "AddRemarks") {
                    ShowLoader();
                    $.ajax({
                        type: 'GET',
                        url: "/Facility/Chart/Frm_ChartResponse_AddRemarks",
                        cache: false,
                        data:
                        {
                            ChartResponseID: Chart_Response_ID_TaskRegister,
                            ChartResponseRemarks: Chart_Response_Remarks_TaskRegister,
                            GridNametoRefreshAfterAdd: "TaskRegisterInfoGrid"
                        },
                        success: function (data) {
                            HideLoader();
                            OpenPopup("Response_Remark_popup", "Add Remarks", null, "auto", 330, true, data);
                        }
                    });
                }
                else if (_Action == "DRAFT" || _Action == "REJECT" || _Action == "APPROVE" || _Action == "CANCEL")
                {
                    if (Chart_Response_Status_TaskRegister!=null && Chart_Response_Status_TaskRegister.includes("Approved") && _Action != "CANCEL")
                    {
                        //var alertMessage = "The selected record is <b>already in " + Chart_Response_Status_TaskRegister + " </b>status. You <b>cannot " + _Action + "  </b> it."
                        var alertMessage = "You <b>cannot " + _Action + "  </b> forms in Approved Status<br>There are forms in <b>Approved</b> status among the selected forms.<br>Please unselect them"
                        DevExpress.ui.dialog.alert(alertMessage, "!! Alert !!");
                        return;
                    }
                    var confirmationMessage = "";
                    if (_Action == "APPROVE") { confirmationMessage = "Are you sure, to mark this form as <b>Approved</b> !! <br> <br> Note: The Applicant will be informed via SMS & Email." }
                    if (_Action == "REJECT") { confirmationMessage = "Are you sure, to mark this form as <b>Rejected</b> !! <br> <br> Note: The Applicant will be informed via SMS & Email." }
                    if (_Action == "DRAFT") { confirmationMessage = "Are you sure, to mark this form as <b>Draft</b> ??" }
                    if (_Action == "CANCEL") { confirmationMessage = "Are you sure, to mark this form as <b>Cancelled</b> ??" }
                    var confirmClick = DevExpress.ui.dialog.confirm(confirmationMessage, "!! Confirm !!");
                    confirmClick.done(function (confirmresult) {
                        if (confirmresult) {                  
                            ShowLoader();
                            $.ajax({
                                type: 'GET',
                                url: "/Facility/Chart/ChangeChartResponseStatus",
                                cache: false,
                                data:
                                {
                                    status: _Action,
                                    chartResponseID: Chart_Response_ID_TaskRegister, 
                                    chartInstanceID: Chart_Instance_ID_TaskRegister
                                },
                                success: function (data) {
                                    HideLoader();
                                    var alertClick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                                    alertClick.done(function (alertResult) {
                                        if (alertResult) {
                                            TaskRegisterInfoGrid.Refresh();
                                        }
                                    })
                                }
                            });
                        }
                    })
                }
                else if (_Action == "EditResponse")
                {
                    ShowLoader();
                    if (UserID_TaskRegister == null) { UserID_TaskRegister = ""; }
                    if (UserABID_TaskRegister == null) { UserABID_TaskRegister = ""; }
                    //var URL = ServicePath + "ViewChartUser/" + Chart_Instance_ID_TaskRegister + "/" + UserID_TaskRegister + "/" + UserABID_TaskRegister + "/?ActionMethod=_Edit&ResponseID=" + Chart_Response_ID_TaskRegister;
                    //window.open(URL);
                    //var form = $("#CallServicesFormResponse")
                    //if (form.length > 0) {
                    //    let windowName = 'w_' + Date.now() + Math.floor(Math.random() * 100000).toString();
                    //    $(form).attr("target", windowName);
                    //    $("#ResponseID").val(Chart_Response_ID_TaskRegister)
                    //    $("#UserID").val(UserID_TaskRegister)
                    //    $("#User_AB_ID").val(UserABID_TaskRegister)
                    //    $("#ActionMethod").val("_Edit")
                    //    $("#ChartInstanceId").val(Chart_Instance_ID_TaskRegister)
                    //    window.open('', windowName);
                    //    $(form).submit();
                    //}
                    HideLoader();
                    var URL = ServicePath + "ViewChartUser/" + Chart_Instance_ID_TaskRegister + "/" + UserID_TaskRegister + "/" + UserABID_TaskRegister + "/?ActionMethod=_Edit&ResponseID=" + Chart_Response_ID_TaskRegister;
                    OpenFormPopup(Chart_Instance_ID_TaskRegister, false, URL,"ViewFormUserSidePopup","Edit ~ Response")
                    window.onmessage = function (e) 
                    {
                        console.log(e)
                        @*if ("@servicesPath".includes(e.origin))*@ 
                        //{
                            if (e.data == 'FormOperationCompleted') 
                            {
                                $("#ViewFormUserSidePopup").dxPopup("hide");
                                ShowLoader();
                                TaskRegisterInfoGrid.Refresh();                                
                            }
                       // }
                    };
                   
                }
                else if (_Action == "ResendConfirmation")
                {
                    ShowLoader();
                    if (UserID_TaskRegister == null) { UserID_TaskRegister = ""; }
                    if (UserABID_TaskRegister == null) { UserABID_TaskRegister = ""; }
                    var URL = ServicePath + "createForm/ChatResponse_Success/?ChartInstanceId=" + Chart_Instance_ID_TaskRegister + "&ChartResponseId=" + Chart_Response_ID_TaskRegister;
                    window.open(URL);
                    HideLoader();
                }
                else if (_Action == "PreviewResponse") {
                    ShowLoader();
