                    else {
                        DevExpress.ui.dialog.alert("Next Linked Chart Not Present", "Information");
                    }
                }
                else if (_Action == "MarkArrived" || _Action == "UnMarkArrived") {
                    var result = false;
                    if (_Action == "MarkArrived") {
                        result = DevExpress.ui.dialog.confirm('Are You Sure You want To Mark as Arrived...?', "Confirm");
                    }
                    else if (_Action == "UnMarkArrived") {
                        result = DevExpress.ui.dialog.confirm('Are You Sure You want To UnMark as Arrived...?', "Confirm");
                    }
                    
                    result.done(function (dialogResult) {
                        dontaskpopupcloseconfirmation = dialogResult;
                        if (dialogResult) {
                            ShowLoader();
