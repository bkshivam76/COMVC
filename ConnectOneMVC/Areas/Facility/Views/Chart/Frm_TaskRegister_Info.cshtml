                    //window.open(URL);
                    //let windowName = 'w_' + Date.now() + Math.floor(Math.random() * 100000).toString();
                    //$(form).attr("target", windowName);
                    //$("#ResponseID").val(Chart_Response_ID_TaskRegister)
                    //$("#UserID").val(UserID_TaskRegister)
                    //$("#User_AB_ID").val(UserABID_TaskRegister)
