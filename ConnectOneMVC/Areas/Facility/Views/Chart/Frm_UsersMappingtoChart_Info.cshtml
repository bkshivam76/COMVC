<div class="ChartUserMappingFacility_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    @model System.Data.DataTable
    @{
        string ScreenHeaderLabel = "Map Users To Form";
        var ChartID = ViewBag.Chartid;
    }
    <div id="ChartUserMapping_ParentDiv">
        <div id="ChartUserMapping_content" class="report_header_div_main">
            <div>
                <div class="report_header_div">
                    <label class="report_header_label">@ScreenHeaderLabel</label>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class="report_button_div">
                        @(Html.DevExtreme().Button().ID("ChartUserMapping_Save").Text("Save").Icon("add").Visible(true).OnClick(@<text> function () { DataNavigation_ChartUserMapping("SAVE"); } </text>))
                        @(Html.DevExtreme().Button().ID("ChartUserMapping_ModelCLOSE").Text("Close").Icon("clear").OnClick("closeChartUserMapping") )
                    </div>
                </div>
            </div>
            <div class="row" style="padding:5px 0px 5px 5px">
                <div class="col-sm-2">
                    <label>Start Date</label>
                    @(Html.DevExtreme().DateBox().CustomDateBox().Name("StartDate_chartUserMapping").ID("StartDate_chartUserMapping").Min(new DateTime(1990,01,01))
                    .OnValueChanged("StartDate_chartUserMapping_ValueChange"))
                </div>
                <div class="col-sm-2">
                    <label>Start Time</label>
                    @(Html.DevExtreme().DateBox().CustomDateBox().Name("StartTime_chartUserMapping").ID("StartTime_chartUserMapping").Min(DateTime.MinValue).Type(DateBoxType.Time)
                .Type(DateBoxType.Time).DisplayFormat("hh:mm a").UseMaskBehavior(true).Placeholder("hh:mm AM/PM").Interval(15).OnValueChanged("StartTime_chartUserMapping_ValueChange"))

                </div>
                <div class="col-sm-2">
                    <label>End Date</label>
                    @(Html.DevExtreme().DateBox().CustomDateBox().Name("EndDate_chartUserMapping").ID("EndDate_chartUserMapping").Min(new DateTime(1990, 01, 01))
                    .OnValueChanged("EndDate_chartUserMapping_ValueChange"))
                </div>

                <div class="col-sm-2">
                    <label>End Time</label>
                    @(Html.DevExtreme().DateBox().CustomDateBox().Name("EndTime_chartUserMapping").ID("EndTime_chartUserMapping").Type(DateBoxType.Time).Min(DateTime.MinValue)
                .DisplayFormat("hh:mm a").UseMaskBehavior(true).Placeholder("hh:mm AM/PM").Interval(15).OnValueChanged("EndTime_chartUserMapping_ValueChange"))
                </div>

            </div>
        </div>    
        <div class="row">
            <div class="col-md-12" id="ChartUserMapping_gridDiv">
                <form>
                    <div id="ChartUserMappingGridPartialView" class="parent_table">
                        @Html.Partial("Frm_UsersMappingtoChart_Info_Grid", Model)
                    </div>
                </form>
            </div>
        </div>
        <div class="footer-MainBoxdiv" style="display:inline-block;width:100%">
            <div class="setFooterItem">
                <div class="footer-inner">
                    <div class="list_footer_left_margin">
                        <div class="footericon">
                            <i id="ServiceReport_LockICON" style="color:red;font-size:35px;"></i>
                        </div>
                        @*<div class="footer-locktext">
                                <div id="BankLbl_Status" style="font-size:23px" class="left_footertext_top"></div>
                            </div>*@
                        <div class="footer-locktext">
                            <div id="SR_Lbl_ActionOn" class="left_footertext_top"></div>
                            <div id="SR_Lbl_ActionBy" class="left_footertext_bottom"></div>
                        </div>
                    </div>
                    <div class="list_footer_left_margin">
                        <div class="footer-text">
                            <p id="SR_Create" class="right_footertext_top"></p>
                            <p id="SR_Modify" class="right_footertext_bottom"></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script>

        var selectedUserIDs_MaptoChart = ""; var selectedUser_ABIDs_MaptoChart = ""; var selectedUser_PojectMapIds_MaptoChart = ""; var msgStr_MaptoChart = "";

    </script>    @*Global Variables*@
    <script>
        $(document).ready(function ()
        {


        });
        function closeChartUserMapping() {
            $("#ChartUser_Mapping_Screen_Modal").dxPopup("hide");
        }
        function ClearAllReferences_ChartUserMapping()
        {
            //Baba: Below function parameter  to be added in index.
            ClearAllReferences("ChartUserMappingFacility_ClearReferences")
        }
    </script>

    <script>
        function ChartUserMappingInfoOnInit(s, e) {
            ChartUserMappingAdjustSize();
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                ChartUserMappingAdjustSize();
            });       
        }

        function ChartUserMappingAdjustSize() {
            var height = (document.documentElement.clientHeight * 90) / 100;
            try {
                ChartUserMappingInfoGrid.SetHeight(height);
            }
            catch (err) {
            }
        }

        function ChartUserMappingInfoGrid_BeginCallback(s, e) {
            e.customArgs["command"] = e.command;

        }
        function ChartUserMappingInfoGrid_SelectionChanged(s, e)
        {
            if (s.GetSelectedRowCount() == 0)
            {
                selectedUserIDs_MaptoChart = "";
                selectedUser_ABIDs_MaptoChart = "";
            }
        }
    </script>    @* Grid Functions *@

    <script>

        function DataNavigation_ChartUserMapping(_action)
        {
            
            var SelectedRowCount = ChartUserMappingInfoGrid.GetSelectedRowCount();
            if (SelectedRowCount < 1 && _action =="SAVE")
            {
                DevExpress.ui.dialog.alert("Please Select Rows", "Alert");
                return;
            }
            ChartUserMappingInfo_GetSelectedRowData(_action);
        }
        function ChartUserMappingInfo_GetSelectedRowData(_Action)
        {
            ShowLoader();
            ChartUserMappingInfoGrid.GetSelectedFieldValues("USER_ID;User_AB_ID;projectMapId", function (values) { GetSelectedFieldValuesCallback_ChartUserMapping(values, _Action) })    
        }
        function GetSelectedFieldValuesCallback_ChartUserMapping(values, _Action)
        {
            HideLoader();
            if (values != null)
            {
                for (var Index = 0; Index < values.length; Index++)
                {
                    if (Index == 0)
                    {
                        selectedUserIDs_MaptoChart = values[Index][0];
                        selectedUser_ABIDs_MaptoChart = values[Index][1];
                        selectedUser_PojectMapIds_MaptoChart = values[Index][2];
                        if (selectedUser_PojectMapIds_MaptoChart == null || selectedUser_PojectMapIds_MaptoChart.length == 0 || selectedUser_PojectMapIds_MaptoChart == "undefined")
                        {
                            msgStr_MaptoChart = values[Index][0]
                        }
                    }
                    else
                    {
                        selectedUserIDs_MaptoChart = selectedUserIDs_MaptoChart + "|" + values[Index][0];
                        selectedUser_ABIDs_MaptoChart = selectedUser_ABIDs_MaptoChart + "|" + values[Index][1];
                        selectedUser_PojectMapIds_MaptoChart = selectedUser_PojectMapIds_MaptoChart + "|" + values[Index][2];
                        if (values[Index][2] == null || values[Index][2].length == 0 || values[Index][2] == "undefined")
                        {
                            if (msgStr_MaptoChart != "")
                            {
                                msgStr_MaptoChart = msgStr_MaptoChart + ", " + values[Index][0]
                            }
                            else
                            {
                                msgStr_MaptoChart = values[Index][0]
                            }                            
                        }
                    }
                }
            }
            else
            {
                selectedUserIDs_MaptoChart = "";
                selectedUser_ABIDs_MaptoChart = "";
            }
            if (_Action == "SAVE")
            {       
                Map_ChartServiceUsers();
            }            
        }
        function Map_ChartServiceUsers()
        {            
            ShowLoader();
            var fromdate = $("#StartDate_chartUserMapping").dxDateBox("instance").option("value");
            var todate = $("#EndDate_chartUserMapping").dxDateBox("instance").option("value");
            var fromtime = $("#StartTime_chartUserMapping").dxDateBox("instance").option("value");
            var totime = $("#EndTime_chartUserMapping").dxDateBox("instance").option("value");
            $.ajax({
                type: 'GET',
                url: "/Facility/Chart/Save_MapUsersToChart",
                cache: false,
                data:
                {
                    selectedUserIDs: selectedUserIDs_MaptoChart,                    
                    selectedUserABIDs: selectedUser_ABIDs_MaptoChart,
                    Chart_ID: "@ChartID",
                    fromdate: fromdate==null?null:JS_Json_Date_To_ddMMyyyy(fromdate),
                    todate: todate==null?null:JS_Json_Date_To_ddMMyyyy(todate),
                    fromtime: fromtime == null ? null : JS_Json_Date_To_ddMMyyyy(fromtime),
                    totime: totime == null ? null :JS_Json_Date_To_ddMMyyyy(totime)

                },
                success: function (data)
                {
                    HideLoader();
                    if (data.jsonParam.result == false)
                    {
                        DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title).done(function (alertResult)
                        {
                            if (alertResult) {
                                if (data.jsonParam.focusid) {
                                    var id = "#" + data.jsonParam.focusid;
                                    setTimeout(function () {
                                        $(id).find('input').focus();
                                    }, 100);
                                }
                            }
                        });
                    }
                    else
                    {
                        var messagetoshow = data.jsonParam.message;
                        if (msgStr_MaptoChart.length > 0 || msgStr_MaptoChart != "")
                        {
                            messagetoshow = messagetoshow + "<br><br>Below user(s) Cannot be mapped to the Form<br>Because those users are not mapped to the Project of the Form. <br> Userid(s) are: " + msgStr_MaptoChart
                        }                  
                        var alertClick = DevExpress.ui.dialog.alert(messagetoshow, data.jsonParam.title);
                        alertClick.done(function (alertResult)
                        {
                            if (alertResult)
                            {
                                MappedUserstoChartInfoGrid.Refresh();
                                closeChartUserMapping();
                            }
                        })
                    }
                }
            });
        }

    </script>

    <script>
        function StartDate_chartUserMapping_ValueChange(e)
        {            
      
        }
        function EndDate_chartUserMapping_ValueChange(e)
        {            
      
        }
        function StartTime_chartUserMapping_ValueChange(e)
        {
           
        }
        function EndTime_chartUserMapping_ValueChange(e)
        {
        
        }

    </script>

</div>
