        settings.DataBound = (s, e) =>
        {
            MVCxGridView grid = s as MVCxGridView;
            grid.TotalSummary.Clear();
            var cnt = grid.Columns.Count;
            for (var i = 0; i < cnt; i++)
            {
                grid.DataColumns[i].PropertiesEdit.EncodeHtml = false;
                if (grid.DataColumns[i].FieldName != "Building")
                {
                   grid.DataColumns[i].MinWidth = 150;
                }
                if (grid.DataColumns[i].FieldName == "Building")
                {
                    grid.DataColumns["Building"].MinWidth = 250;
                }
