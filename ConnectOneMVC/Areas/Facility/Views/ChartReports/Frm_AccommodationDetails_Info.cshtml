<div class="AccomDetails_ClearReferences">
    @using DevExtreme.AspNet.Mvc;

    @model System.Data.DataTable
    @{
        var centreId = (string)ViewBag.CentreId;
        if (String.IsNullOrWhiteSpace(centreId) == false)
        {
            Layout = "~/Views/Shared/_NoLoginAllLayout.cshtml";
        }
        string chartInstanceID = (string)ViewBag.chartInstanceID;
        string summary_type = (string)ViewBag.summary_type;
        string Theme = (string)ViewBag.Theme;

    }
    <style>
        .allotted {
            background-color: Plum;
            color: black;
            margin-bottom: -12px;
            position: relative;
            top: -7px;
            height: 25px;
            bottom: -5px;
            padding: 7px 5px;
            left: -5px;
            width: calc(100% + 10px);
        }

        .filled {
            background-color: #FF7B54;
            color: black;
            margin-bottom: -12px;
            position: relative;
            top: -7px;
            height: 25px;
            bottom: -5px;
            padding: 7px 5px;
            left: -5px;
            width: calc(100% + 10px);
        }

        #refreshInterval_AccomDetails {
            max-width: 40px;
            display: inline-block
        }

            #refreshInterval_AccomDetails + b {
                display: inline-block
            }

        .show_Btn {
            padding: 16px 0 0 0;
            margin-right: 20px;
            max-width: 80px;
        }

            .show_Btn .form-field {
                border-right: 1px solid #ddd
            }

        @@media (max-width:768px) {
            .show_Btn {
                padding: 0 13px
            }

                .show_Btn .form-field {
                    border-right: none;
                }

            #accomDetails_Filters_Div > div {
                margin-bottom: 5px;
            }

                #accomDetails_Filters_Div > div.set_Interval {
                    padding: 2px 17px
                }
        }
    </style>
    <script>
         $(document).ready(function ()
         {
             if ("@centreId" != "")
             {
                 $('#Close_Btn_AccomDetails').hide();
             }
        });
         function ListPreview_Btn_AccomDetails_Click()
         {
             ShowLoader();
             OpenPopup("ExportOptions_modal", "Export Option", "@Url.Action("Frm_Export_Options", "ChartReports", new { @area = "Facility" })?GridName=AccommDetailListGrid", "auto", 130);
         }
        function closeChartAccomDetailsInfo()
        {
            $(".TabPanalMenu-tabs .active span").click();
        }
         $(".TabPanalMenu-tabs .active span").on("click", function () {
            $.ajax({
                type: 'GET',
                url: "/Facility/ChartReports/SessionClearChartReports",
                cache: false,
                data: { SummaryType:"@summary_type"}
            });
        });
         function AccommDetail_ChartReports_BeginCallback(s, e) {
            e.customArgs["command"] = e.command;
            e.customArgs["Chart_Instance_ID"] = "@chartInstanceID";
            e.customArgs["summary_type"] = "@summary_type";
        }
         function AccommDetail_ChartReports_Init(s, e) {
            //s.ExpandAll();
            AccommDetail_ChartReports_AdjustSize();
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                AccommDetail_ChartReports_AdjustSize();
            });
        }
         function AccommDetail_ChartReports_AdjustSize() {
            var height = (document.documentElement.clientHeight * 80) / 100;
            try {
                AccommDetailListGrid.SetHeight(height);
            }
            catch (err) {
            }
        }

         function AccommDetail_ChartReports_FocusedRowChanged(s, e)
         {

         }
         function AccommDetail_ChartReports_ContextMenuFunction(s, e)
         {
             e.handled = true;
             if (e.item.name == "Refresh")
             {
                 ShowAccomDetails();
             }
             if (e.item.name == "Close")
             {
                 closeChartAccomDetailsInfo();
             }
         }
    </script>
    <div class="report_header_div_main">
        <div class="clearfix">
            <div class="report_header_div">
                <label class="report_header_label">@ViewBag.summary_type</label>
            </div>

            <div class="report_button_div">
                @(Html.DevExtreme().Button().ID("ListPreview_Btn_AccomDetails").Text("List Preview").Icon("save").OnClick("ListPreview_Btn_AccomDetails_Click").Visible(false))
                @(Html.DevExtreme().Button().ID("Close_Btn_AccomDetails").Text("Close").Icon("clear").OnClick("closeChartAccomDetailsInfo") )
            </div>
        </div>
        <div class="col-md-12 no-padding" id="accomDetails_gridDiv">
            <form>

                <div id="accomDetails_Filters_hdr" class="filhdr" onclick="accomDetails_FilterToggle()">
                    <span>Click to Hide Filters</span>
                    <i class="bx bx-up-arrow-alt"></i>
                </div>

                <script>
                    function accomDetails_FilterToggle() {
                        var div = document.getElementById("accomDetails_Filters_Div");
                        if (div.style.display !== "none") {
                            div.style.display = "none";
                            $("#accomDetails_Filters_hdr").find('span').text("Click to Show Filters");
                            $("#accomDetails_Filters_hdr").find('i').removeClass('bx-up-arrow-alt').addClass('bx-down-arrow-alt');
                        }
                        else {
                            div.style.display = "block";
                            $("#accomDetails_Filters_hdr").find('span').text("Click to Hide Filters")
                            $("#accomDetails_Filters_hdr").find('i').removeClass('bx-down-arrow-alt').addClass('bx-up-arrow-alt');
                        }

                    }
                </script>
                <div class="row" style="padding:10px;" id="accomDetails_Filters_Div">
                    <div class="col-sm-2">
                        <div class="form-field">
                            <label class="control-label text-red" for="user">From Date:</label>
                            @(Html.DevExtreme().DateBox().CustomDateBox().ID("fromdate_AccDetail").Name("fromdate_AccDetail").ShowClearButton(true).Value(ViewBag.fromdate)
                                .Type(DateBoxType.Date).Placeholder("From Date").Min(new DateTime(1990, 01, 01)).Max(new DateTime(2038, 12, 31))
                            )
                        </div>
                    </div>
                    <div class="col-sm-2">
                        <div class="form-field">
                            <label class="control-label text-red" for="user">To Date:</label>
                            @(Html.DevExtreme().DateBox().CustomDateBox().ID("todate_AccDetail").Name("todate_AccDetail").ShowClearButton(true).Value(ViewBag.todate)
                                    .Type(DateBoxType.Date).Placeholder("To Date").Min(new DateTime(1990, 01, 01)).Max(new DateTime(2038, 12, 31))
                                )
                        </div>
                    </div>
                    <div class="col-sm-2">
                        <div class="form-field">
                            <label class="control-label text-white" for="user">Building Name:</label><br />
                            @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("Chart_BuildingName_AccDet").Name("Chart_BuildingName_AccDet")
                                .DataSource(d => d.Mvc().Controller("Chart").LoadAction("LookUp_ServicePlaceNamesList").Key("REC_ID")).Value(ViewBag.buildingid)
                                .DisplayExpr("BUILDING_NAME").ValueExpr("REC_ID")
                                )
                        </div>
                    </div>

                    <div class="col-sm-2">
                        <label>Service Report/Event</label>
                        @(Html.DevExtreme().DropDownBox().CustomDropDown().Name("Chart_Event_AccomDetls").ID("Chart_Event_AccomDetls").Placeholder("Choose..").DisplayExpr("Name").ValueExpr("ID")
                                   .DataSource(d => d.Mvc().Controller("Chart").LoadAction("LookUp_Get_EventsList").Key("ID").LoadMode(DataSourceLoadMode.Raw))
                            .ContentTemplate(@<text>
                                @(Html.DevExtreme().DataGrid().CustomDataGrid().ID("Chart_Event_AccomDetls_datagrid")
                                    .Columns(columns =>
                                    {
                                        columns.Add().DataField("Name").Caption("Name");
                                        columns.Add().DataField("ID").Visible(false);
                                        columns.Add().DataField("ProjID").Visible(false);
                                        columns.Add().DataField("Type");
                                        columns.Add().DataField("FromDate").DataType(GridColumnDataType.Date).Format("dd/MM/yyyy");
                                        columns.Add().DataField("ToDate").DataType(GridColumnDataType.Date).Format("dd/MM/yyyy");
                                        columns.Add().DataField("Venue");
                                    })
                                    .Selection(s => s.Mode(SelectionMode.Single))
                                    .FilterRow(s=>s.Visible(false))
                                    .OnSelectionChanged("function(selectedItems)" +
                                    "{ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}"))
                            </text>).OnValueChanged("Chart_Event_AccomDetls_ValueChange").Value(ViewBag.eventid)
                        )
                    </div>
                    <script>

                        async function Chart_Event_AccomDetls_ValueChange(e, FirstCall = false) {
                            var value;
                            var DG = $("#Chart_Event_AccomDetls_datagrid").dxDataGrid("instance");
                            if (e) {
                                value = e.value;
                                if ((e.value == null || e.value.length == 0) && e.previousValue != null) {
                                    DG.clearSelection();

                                    return;
                                }
                            }
                            else {
                                value = $("#Chart_Event_AccomDetls").dxDropDownBox("option", "value");
                            }
                            await DG.selectRows(value);
                        }
                    </script>
                    <div class="col-sm-1 show_Btn">
                        <div class="form-field">
                            <label class="control-label text-white" for="user"></label>
                            @(Html.DevExtreme().Button().ID("btnShowSummary_AccDet").Text("Show").OnClick("ShowAccomDetails"))
                        </div>
                    </div>
                    <script>
                        function ShowAccomDetails() {
                            var fromdate = $("#fromdate_AccDetail").dxDateBox("instance").option("value")
                            var todate = $("#todate_AccDetail").dxDateBox("instance").option("value")
                            if (fromdate == null || fromdate == "" || fromdate == undefined) {
                                DevExpress.ui.notify({ message: 'From Date is mandatory', width: 300, shading: true, position: 'center' }, "error", 2000);
                                return;
                            }
                            if (todate == null || todate == "" || todate == undefined) {
                                DevExpress.ui.notify({ message: 'To Date is mandatory', width: 300, shading: true, position: 'center' }, "error", 2000);
                                return;
                            }
                            if (fromdate > todate) {
                                DevExpress.ui.notify({ message: 'From Date should not be greater than To Date', width: 300, shading: true, position: 'center' }, "error", 2000);
                                return;
                            }
                            fromDate = JS_Json_Date_To_ddMMyyyy($("#fromdate_AccDetail").dxDateBox("instance").option("value"));
                            toDate = JS_Json_Date_To_ddMMyyyy($("#todate_AccDetail").dxDateBox("instance").option("value"));
                            var building = $("#Chart_BuildingName_AccDet").dxSelectBox("instance").option("value")
                            var eventid = $("#Chart_Event_AccomDetls").dxDropDownBox("option", "value");
                            var summary_type_AccomDetails = "@summary_type" //Accomodation Details
                            AccommDetailListGrid.PerformCallback({ "fromdate": fromDate, "todate": toDate, "buildingid": building, "EventId": eventid, "summary_type": summary_type_AccomDetails,  "command": "REFRESH" });
                        }
                    </script>
                    @if (Theme == "")
                    {
                        <div class="pull-left set_Interval" style="">
                            <div class="form-field">
                                <label class="control-label text-white" for="user">Set Interval</label><br />
                                @(Html.DevExtreme().NumberBox().ID("refreshInterval_AccomDetails").Value(5).Format("#0"))
                                <b>Seconds</b>
                            </div>
                        </div>
                        <div class="col-sm-2" style="margin-top:4px;">
                            <div class="form-field">
                                <label class="control-label text-white" for="user"></label><br />
                                @(Html.DevExtreme().Button().ID("StartAutoRefresh_AccDet").Text("Start Auto Refresh").Hint("Change Period").OnClick("StartAutoRefresh_AccomDetails"))
                                @(Html.DevExtreme().Button().ID("StopAutoRefresh_AccDet").Text("Stop").Hint("Change Period").OnClick("StopAutoRefresh_AccomDetails"))
                            </div>
                        </div>
                    }
                    <script>
                        var timer_AccomDetails;
                        function StartAutoRefresh_AccomDetails(fn, timeout, interval) {
                            timer_AccomDetails = setInterval(function () {
                                if ($("#contact_Frm_AccommodationDetails_Info").hasClass('active')||"@centreId".length>0) {
                                    ShowAccomDetails()
                                } else {
                                    StopAutoRefresh_AccomDetails()
                                }
                            }, parseInt($("#refreshInterval_AccomDetails").dxNumberBox("instance").option("value")) * 1000)

                        }
                        function StopAutoRefresh_AccomDetails() {
                            clearInterval(timer_AccomDetails)
                        }
                    </script>
                </div>
                <div class="parent_table">
                    @Html.Partial("Frm_AccommodationDetails_Info_Grid", Model)
                </div>
            </form>
        </div>
    </div>
</div>
