@using System.Text.RegularExpressions;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    var ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;
    var summary_type = ViewBag.summary_type;
    var Layout = ViewData["Layout"];
}

@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "FoodDetailListNextTenDaysArrivalGrid";
        settings.CallbackRouteValues = new
        {
            Controller = "ChartReports",
            Action = "Frm_FoodDetail_NextTenDays_Info_Arrival_Grid",
            SessionGUID = SessionGUID
        };

        settings.Theme = "Aqua";
        settings.Styles.FocusedRow.BackColor = System.Drawing.Color.FromArgb(0, 114, 198);
        settings.Styles.FocusedRow.ForeColor = System.Drawing.Color.White;
        settings.Styles.AlternatingRow.BackColor = System.Drawing.Color.Linen;

        settings.SettingsBehavior.AllowFocusedRow = true;
        settings.SettingsBehavior.AllowSelectByRowClick = false;

        settings.Settings.VerticalScrollBarMode = ScrollBarMode.Visible;
        settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
        settings.Settings.UseFixedTableLayout = true;

        //Filter in Headings of the table.
        settings.Settings.ShowHeaderFilterButton = true;
        settings.Settings.AutoFilterCondition = AutoFilterCondition.Contains;
        settings.Settings.ShowHeaderFilterBlankItems = false;

        // show filter control at the bottom
        settings.Settings.ShowFilterBar = GridViewStatusBarMode.Visible;
        settings.Settings.ShowFilterRow = true;
        settings.SettingsFilterControl.ViewMode = true ? FilterControlViewMode.VisualAndText : FilterControlViewMode.Visual;
        settings.SettingsFilterControl.AllowHierarchicalColumns = true;// AllowHierarchicalColumns;
        settings.SettingsFilterControl.ShowAllDataSourceColumns = true;//FilterBuilderDemoHelper.Options.ShowAllDataSourceColumns;
        settings.SettingsFilterControl.MaxHierarchyDepth = 1;

        settings.Settings.ShowPreview = true;

        settings.SettingsDetail.ShowDetailRow = false;

        settings.KeyboardSupport = true;
        //settings.AccessKey = "G";
        settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
        settings.SettingsBehavior.ProcessColumnMoveOnClient = true;
        settings.SettingsBehavior.ColumnMoveMode = GridColumnMoveMode.AmongSiblings;

        if (summary_type == "FOOD DETAIL")
        {
            settings.DataBound = (s, e) =>
            {
                MVCxGridView grid = s as MVCxGridView;
                if (grid.Columns.IndexOf(grid.Columns["Event"]) > -1)
                {
                    grid.DataColumns["Event"].Width = 300;
                }
        if (grid.Columns.IndexOf(grid.Columns["Tea"]) > -1)
                {
                    grid.DataColumns["Tea"].Width = 60;
            grid.DataColumns["Tea"].HeaderStyle.HorizontalAlign = System.Web.UI.WebControls.HorizontalAlign.Center;
            grid.DataColumns["Tea"].CellStyle.HorizontalAlign = System.Web.UI.WebControls.HorizontalAlign.Center;
                }
        if (grid.Columns.IndexOf(grid.Columns["Breakfast"]) > -1)
                {
                    grid.DataColumns["Breakfast"].Width = 90;
            grid.DataColumns["Breakfast"].HeaderStyle.HorizontalAlign = System.Web.UI.WebControls.HorizontalAlign.Center;
            grid.DataColumns["Breakfast"].CellStyle.HorizontalAlign = System.Web.UI.WebControls.HorizontalAlign.Center;
                }
        if (grid.Columns.IndexOf(grid.Columns["Tea1"]) > -1)
                {
                    grid.DataColumns["Tea1"].Width = 90;
            grid.DataColumns["Tea1"].Caption = "Aft. Tea";
            grid.DataColumns["Tea1"].HeaderStyle.HorizontalAlign = System.Web.UI.WebControls.HorizontalAlign.Center;
            grid.DataColumns["Tea1"].CellStyle.HorizontalAlign = System.Web.UI.WebControls.HorizontalAlign.Center;
                }
        if (grid.Columns.IndexOf(grid.Columns["Lunch"]) > -1)
                {
                    grid.DataColumns["Lunch"].Width = 80;
            grid.DataColumns["Lunch"].HeaderStyle.HorizontalAlign = System.Web.UI.WebControls.HorizontalAlign.Center;
            grid.DataColumns["Lunch"].CellStyle.HorizontalAlign = System.Web.UI.WebControls.HorizontalAlign.Center;
                }
        if (grid.Columns.IndexOf(grid.Columns["Tea2"]) > -1)
                {
                    grid.DataColumns["Tea2"].Width = 90;
            grid.DataColumns["Tea2"].Caption = "Eve. Tea";
            grid.DataColumns["Tea2"].HeaderStyle.HorizontalAlign = System.Web.UI.WebControls.HorizontalAlign.Center;
            grid.DataColumns["Tea2"].CellStyle.HorizontalAlign = System.Web.UI.WebControls.HorizontalAlign.Center;
                }
        if (grid.Columns.IndexOf(grid.Columns["Dinner"]) > -1)
                {
                    grid.DataColumns["Dinner"].Width = 80;
            grid.DataColumns["Dinner"].HeaderStyle.HorizontalAlign = System.Web.UI.WebControls.HorizontalAlign.Center;
            grid.DataColumns["Dinner"].CellStyle.HorizontalAlign = System.Web.UI.WebControls.HorizontalAlign.Center;
                }
            };

            settings.TotalSummary.Add(new ASPxSummaryItem()
            { SummaryType = DevExpress.Data.SummaryItemType.Sum, FieldName = "Tea", DisplayFormat = "{0}", ShowInColumn = "Tea" });
            settings.TotalSummary.Add(new ASPxSummaryItem()
            { SummaryType = DevExpress.Data.SummaryItemType.Sum, FieldName = "Breakfast", DisplayFormat = "{0}", ShowInColumn = "Breakfast" });
            settings.TotalSummary.Add(new ASPxSummaryItem()
            { SummaryType = DevExpress.Data.SummaryItemType.Sum, FieldName = "Tea1", DisplayFormat = "{0}", ShowInColumn = "Tea1" });
            settings.TotalSummary.Add(new ASPxSummaryItem()
            { SummaryType = DevExpress.Data.SummaryItemType.Sum, FieldName = "Lunch", DisplayFormat = "{0}", ShowInColumn = "Lunch" });
            settings.TotalSummary.Add(new ASPxSummaryItem()
            { SummaryType = DevExpress.Data.SummaryItemType.Sum, FieldName = "Tea2", DisplayFormat = "{0}", ShowInColumn = "Tea2" });
            settings.TotalSummary.Add(new ASPxSummaryItem()
            { SummaryType = DevExpress.Data.SummaryItemType.Sum, FieldName = "Dinner", DisplayFormat = "{0}", ShowInColumn = "Dinner" });
            settings.Settings.ShowFooter = true;
            settings.Styles.Footer.Font.Bold = true;
        }



            settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.HideDataCells;
            settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Visible;
            settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.Disabled;
            settings.SettingsAdaptivity.AllowHideDataCellsByColumnMinWidth = true;

        settings.Settings.ShowPreview = true;

        //Group Settings
        settings.Settings.ShowGroupFooter = GridViewGroupFooterMode.VisibleIfExpanded;
        settings.Settings.ShowGroupPanel = false;
        settings.SettingsBehavior.AllowGroup = true;
        settings.SettingsBehavior.AutoExpandAllGroups = false;
        settings.SettingsBehavior.AllowFixedGroups = true;
        settings.Settings.ShowGroupedColumns = false;
        settings.Settings.ShowGroupButtons = true;

        settings.SettingsBehavior.AllowFocusedRow = true;
        settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
        settings.SettingsBehavior.AllowSelectByRowClick = false;
        settings.Settings.UseFixedTableLayout = true;
        settings.SettingsBehavior.AllowSort = true;
        settings.SettingsBehavior.AllowEllipsisInText = true;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsCustomizationDialog.ShowSortingPage = true;
        settings.SettingsCustomizationDialog.ShowGroupingPage = true;
        settings.SettingsCustomizationDialog.ShowFilteringPage = true;
        settings.SettingsCustomizationDialog.ShowColumnChooserPage = true;


        // Filter and serach
        settings.Settings.ShowHeaderFilterButton = true;
        settings.Settings.ShowHeaderFilterBlankItems = false;
        settings.Settings.AutoFilterCondition = AutoFilterCondition.Contains;
        // show filter control
        settings.Settings.ShowFilterBar = GridViewStatusBarMode.Visible;
        settings.SettingsFilterControl.ViewMode = true ? FilterControlViewMode.VisualAndText : FilterControlViewMode.Visual;
        settings.SettingsFilterControl.AllowHierarchicalColumns = true;// AllowHierarchicalColumns;
        settings.SettingsFilterControl.ShowAllDataSourceColumns = true;//FilterBuilderDemoHelper.Options.ShowAllDataSourceColumns;
        settings.SettingsFilterControl.MaxHierarchyDepth = 1;

        settings.SettingsSearchPanel.Visible = false;
        settings.SettingsSearchPanel.ShowApplyButton = true;
        settings.SettingsSearchPanel.ShowClearButton = true;

        settings.SettingsContextMenu.Enabled = true;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;
        //settings.SettingsContextMenu.RowMenuItemVisibility.Refresh = false;

        settings.SettingsPager.Visible = true;
        settings.SettingsPager.Mode = GridViewPagerMode.ShowPager;
        settings.SettingsPager.PageSizeItemSettings.Visible = true;
        settings.SettingsPager.PageSize = 200;
        settings.SettingsPager.AllButton.Visible = true;
        settings.KeyFieldName = "RESP_ID";

        //Export Settings
        settings.SettingsExport.EnableClientSideExportAPI = true;
        settings.SettingsExport.ExcelExportMode = DevExpress.Export.ExportType.DataAware;
        settings.SettingsExport.PageHeader.Center = "Food Detail";
        settings.SettingsExport.PageHeader.Left = ViewData["ExportGridHeaderLeft"].ToString();
        settings.SettingsExport.PageHeader.Right = ViewData["ExportGridHeaderRight"].ToString();
        settings.SettingsExport.PageFooter.Right = ViewData["ExportGridFooter"].ToString();
        settings.SettingsExport.PaperKind = System.Drawing.Printing.PaperKind.A4;
        settings.SettingsExport.TopMargin = 10;
        settings.SettingsExport.LeftMargin = 4;
        settings.SettingsExport.RightMargin = 2;
        settings.SettingsExport.BottomMargin = 10;
        settings.SettingsExport.Landscape = true;

        settings.ClientSideEvents.Init = "FoodDetail_NextTenDays_Arrival_ChartReports_Init";
        settings.ClientSideEvents.FocusedRowChanged = "FoodDetail_NextTenDays_Arrival_ChartReports_FocusedRowChanged";
        settings.ClientSideEvents.BeginCallback = "FoodDetail_NextTenDays_Arrival_ChartReports_BeginCallback";
        settings.ClientSideEvents.ContextMenuItemClick = "FoodDetail_NextTenDays_Arrival_ChartReports_ContextMenuFunction";

        settings.SettingsPopup.CustomizationWindow.VerticalAlign = PopupVerticalAlign.WindowCenter;
        settings.SettingsPopup.CustomizationWindow.HorizontalAlign = PopupHorizontalAlign.WindowCenter;
        MyExtensions.GridViewHelper.Custom_HeaderFilterFillItems_All(settings);
        MyExtensions.GridViewHelper.CustomGridView(settings);

    }).Bind(Model).GetHtml()