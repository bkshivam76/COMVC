    function getContenttype_fq(fileURL) {
        var ext = fileURL.split(".")?.at(-1)
        var allimageexts = "jpg,jpeg,jfi,jpe,jif,jfif,heif,heic,png,gif,svg,svgz,eps,tif,tiff,bmp,raw,cr2,nef,orf,sr2,zip";
        var allvideoexts = "mp4,mp3,webm,mpg,ogg,avi,mov,mp3,mpeg-4,divx,mp2,mpe,mpv,ogg,m4p,m4v,wmv,qt,flv,swf,avchd"
        var alldocx = "docx,doc,txt,xlsx,xlsm,xls,csv,docm,dot,dotx,ppt,pptm,pptx"
        if (allimageexts.includes(ext.toLowerCase())) {
            contenttype_fq = "image";
        }
        else if (allvideoexts.includes(ext.toLowerCase())) {
            contenttype_fq = "video"
        }
        else if (alldocx.includes(ext.toLowerCase())) {
            contenttype_fq = "document"
        }
        else if (ext.toLowerCase() == "pdf") {
            contenttype_fq = "pdf"
        }
        else {
            contenttype_fq="image"
        }       
    }
