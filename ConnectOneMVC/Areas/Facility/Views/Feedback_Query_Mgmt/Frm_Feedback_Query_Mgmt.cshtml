    function submitresponse(eventrecid, feedback_query_recid, userid, username, isanonymous, user_ab_id, reference_Name, reference_recid) {
        //debugger;
        var responseText = document.getElementById("txtBox").value;
        if (responseText.length == 0 || responseText == '') {
            alert('Please enter your response');            
        }
        else if (responseText.length > 0)
        {
            //formdata code starts from here onwards
            var formdata = new FormData($('#FeedQueryMgmtForm').get(0));

            //Below code is to append captions to the formdata
            const inputvalues = document.querySelectorAll('#galleryContainer_fq .form-control')
            for (var i = 0; i < inputvalues.length; i++) {
                formdata.append("file_captions[]", inputvalues[i].value);
            }
            uploadControl = $("#FeedQueryMgmt_myFile").dxFileUploader("instance");
            formdata.set("FeedQueryMgmt_myFile", null); // dxFileUploader's "Name" option value
            for (var i = 0; i < uploadControl._files.length; i++) { //This for loop is important to the whole logic of userButtons and shifting files to fromdata to work as form submit.
                formdata.append("File" + i.toString(), uploadControl._files[i].value);               
            }
            formdata.set('Help_uploadMethod', "fileCollection");        
            formdata.set('responseText', responseText);
            formdata.set('feed_Query_Response_RecId', feedback_query_recid);
            formdata.set('userid', userid);
            formdata.set('isanonymous', isanonymous);        
            formdata.set('eventrecid', eventrecid);
            formdata.set('User_Ab_ID', user_ab_id);
            formdata.set('referenceName', reference_Name);
            formdata.set('referenceRecid', reference_recid);            
            formdata.set('Help_Document_FileName', FeedQueryMgmt_Attached_FileName);            
            formdata.set('Help_Byte_SessionName', "FeedQueryMgmtAttachment");
            formdata.set('Help_Post_Area_Name', "Help");
            formdata.set('Help_Post_Controller_Name', "Attachment");
            formdata.set('Help_REF_REC_ID', FeedQueryMgmt_Attach_RefRecId); //I need to find out this
            formdata.set('Help_REF_SCREEN', FeedQueryMgmt_Attach_RefScreen);
            formdata.set('Help_Document_Description', 'FeedQueryMgmtPage');
            formdata.set('Help_Checked', false);
            formdata.set('Help_uploadControlName', "FeedQueryMgmt_myFile");
            formdata.set('Help_uploadControlActionMethod', "New");
            //formdata code ends here
        
            $.ajax({
                url: "/Facility/Feedback_Query_Mgmt/SubmitResponse",
                type: "post",
                data:formdata,
                //{
                //    'responseText': responseText, 'feed_Query_Response_RecId': feedback_query_recid, 'isanonymous': isanonymous,
                //    'userid': userid, 'eventrecid': eventrecid, 'User_Ab_ID': user_ab_id, 'referenceName': reference_Name, 'referenceRecid': reference_recid
                //},
                contentType: false,
                processData: false,
                success: function (data) {
                    debugger;
                    if (data.message == "success") {
                        //alert('Thankyou for your valuable Response!');
                        makeSbtbtn_empty();
                        captions_array_fq = []
                        getdetailrecords(eventrecid, userid, feedback_query_recid, username, isanonymous, user_ab_id, reference_Name, reference_recid); //This is to refresh third section after response given.-Working fine
                        document.getElementById("galleryContainer_fq").innerHTML = "";
                    }
                    else {
                        Alert('Some error occured. Please try again.');
                        captions_array_fq = [];
                    }
                }
            });
        }

    }
    function Cancelresponse(feedback_query_recid) {

        document.getElementById(feedback_query_recid).style.display = "block";
        event.srcElement.parentElement.style.display = 'none'
        event.srcElement.parentElement.previousElementSibling.style.display = 'none';
    }
    var onEditfilenames_fq = ""; var onEditfile_aliattachmentids_fq = ""; var onEditfileCaptions_fq = "";
    function getattachments_fq(Fqr_recid) {
        $.ajax({
            url: "/Facility/Feedback_Query_Mgmt/getAttachments",
            type: "post",
            data: {
                'fqr_recid': Fqr_recid
            },
            success: function (data) {
                if (data.message == "success") {
                    onEditfilenames_fq = data.filenames
                    onEditfile_aliattachmentids_fq = data.filerecids
                    onEditfileCaptions_fq = data.filecaptions
                    openattachments_fq(onEditfilenames_fq, onEditfile_aliattachmentids_fq, onEditfileCaptions_fq);

                }
                else {
                    Alert('Some error occured. Please try again.');
                }
            }
        });
    }
    var contenttype_fq = "";
    function openattachments_fq(filenames, fileids, filecaptions) {
        debugger;
        var filenames_array = filenames.split(',');
        var fileids_array = fileids.split(',');
        var filecaptions_array = filecaptions.split('!_(')
        document.getElementById("galleryContainerShow_fq").innerHTML = "";
        $('#showAllAttachments').modal('show');
        var str_array = filenames.split(',');
        

        for (var i = 0; i < filenames_array.length; i++) {
            var fileURL = str_array[i];
            var new_a = document.createElement("a")
            new_a.setAttribute('href', fileURL)
            new_a.setAttribute('target', '_blank')

            //*******below xhr related code is to find the content type of the attachment
            contenttype_fq = "";
            getContenttype_fq(fileURL)
            //*******

            var new_img;
            if (contenttype_fq == "" || contenttype_fq == null || contenttype_fq == undefined) {
                new_img = document.createElement("img")
                new_img.src = fileURL;
            }
            else {
                if (contenttype_fq.includes("video") || contenttype_fq.includes("mp4")) {
                    new_img = document.createElement("video")
                    new_img.src = fileURL;
                }
                else if (contenttype_fq.includes("pdf")) {
                    new_img = document.createElement("img")
                    new_img.src = "/Content/Events/images/pdficon.jpg";
                }
                else if (contenttype_fq.includes("document")) {
                    new_img = document.createElement("img")
                    new_img.src = "/Content/Events/images/docxicon.jpg";
                }
                else if (contenttype_fq.includes("image") || contenttype_fq.includes("jpeg") || contenttype_fq.includes("png")) {
                    new_img = document.createElement("img")
                    new_img.src = fileURL;
                }
                else {
                    new_img = document.createElement("img")
                    new_img.src = fileURL;
                }
            }
            new_a.appendChild(new_img)
            var new_input = document.createElement("textarea")
            new_input.className = "form-control"
            new_input.placeholder = "Caption..."
            new_input.value = filecaptions_array[i]
            new_a.appendChild(new_input)
            var MainCardviewDiv = document.getElementById("galleryContainerShow_fq")
            MainCardviewDiv.appendChild(new_a)

        }
    }
</script>

<script>
    //from here onwards the uploading of the images functions are there.
    function openBrowserPopup() {
        /*document.getElementById("attachmentPaperclick").showModal();*/
        $('#attachMdl').modal('show');
    }
    //var imgSrcs = [];
    var files = [];
    var captions_array_fq = [];
    var fromremovefile_fq = false;
    function countcaptions_fq() {
        const inputvalues = document.querySelectorAll('#galleryContainer_fq .form-control')
        for (var i = 0; i < inputvalues.length; i++) {
            if (i == 0) {
                captions_array_fq = [];
            }
            captions_array_fq.push(inputvalues[i].value)
        }
    }
    function AttachmentsOnValueChange_fq(e) {
        debugger;
        //var uploadControl = $("#FeedQueryMgmt_myFile").dxFileUploader("instance");
        const inputvalues = document.querySelectorAll('#galleryContainer_fq .form-control')
        if (!fromremovefile_fq) {
            for (var i = 0; i < inputvalues.length; i++) {
                if (i == 0) {
                    captions_array_fq = [];
                }
                captions_array_fq.push(inputvalues[i].value)
            }
        } else {
            fromremovefile_fq = false;
        }

        //Validations******************************
        var files = e.value;
        FeedQueryMgmt_FilesSelectedCount = files.length;
        if (FeedQueryMgmt_FilesSelectedCount > 25) {
            FeedQueryMgmt_uploadErrorDuetoFileCount = true;
            DevExpress.ui.dialog.alert("You Have Selected " + FeedQueryMgmt_FilesSelectedCount + " Files To Upload<br><b>More Than 25 Files Cannot Be Uploaded At Once<b>", 'Upload Error..');
            var fileUploader = $("#FeedQueryMgmt_myFile").dxFileUploader("instance");
            fileUploader.reset();
            return;
        }
        if (files.length > 0) {
            var totalContent = 0;         
            var NotAllowedFilePresent = false;
            var filenames = "";
            for (var i = 0; i < files.length; i++) {                
                var ErrMsg = PreventFileUpload(files[i])
                if (ErrMsg != null && ErrMsg.length > 0)
                {
                    NotAllowedFilePresent = true;
                    DevExpress.ui.dialog.alert(ErrMsg, 'Upload Error..');
                    break;
                }           
                else {
                    totalContent = totalContent + files[i].size
                    filenames = filenames + files[i].name
                    //document.getElementById("attached_filenames").innerHTML = filenames;
                }
            }
            if (totalContent > 524288000) {
                NotAllowedFilePresent = true;
                DevExpress.ui.dialog.alert("You Have In Total Selected <b>" + formatBytes(totalContent) + "</b> To Upload<br><b>Upto 500 MB Can Be Uploaded At Once<b>", 'Upload Error..');
            }
            if (NotAllowedFilePresent == true) {
                $("#FeedQueryMgmt_myFile").dxFileUploader("instance").reset();
                return;
            }
            FeedQueryMgmt_Attached_FileName = files[0].name;
        }
        else {
            FeedQueryMgmt_Attached_FileName = "";
        }
        FeedQueryMgmt_uploadErrorDuetoFileCount = false;
        //Validations ends here.****************************
        insertimages_fq(e.value)


    }
