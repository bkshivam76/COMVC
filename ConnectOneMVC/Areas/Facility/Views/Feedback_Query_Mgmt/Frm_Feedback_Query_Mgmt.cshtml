            var new_input = document.createElement("textarea")
            new_input.className = "form-control"
            new_input.placeholder = "Caption..."
            if (captions_array_fq.length > 0 && i <= captions_array_fq.length) {
                if (captions_array_fq[i] != "" && captions_array_fq[i] != undefined) {
                    new_input.value = captions_array_fq[i]
                }
            }
            new_a.appendChild(new_input)
            var new_i = document.createElement("i")
            new_i.className = "bx bxs-trash"
            new_i.role = "button"
            new_i.setAttribute("onclick", "remove_file_fq('" + e[i].name + "')")
            new_a.appendChild(new_i)
            var MainCardviewDiv = document.getElementById("galleryContainer_fq")
            MainCardviewDiv.appendChild(new_a)
            
        }
    }
