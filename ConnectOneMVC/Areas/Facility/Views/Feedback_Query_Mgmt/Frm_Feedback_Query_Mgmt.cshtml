    function remove_file_fq(file_name)
    {
        //debugger;
        countcaptions_fq()
        uploadControl = $("#FeedQueryMgmt_myFile").dxFileUploader("instance");
        var files = uploadControl.option('value')
        for (i = 0; i < files.length; i++) {
            if (files[i]['name'] == file_name) {
                files.splice(i, 1);
                captions_array_fq.splice(i, 1)
                fromremovefile_fq = true;
                index = i;
                break;
            }
        }
        uploadControl.reset();
        uploadControl.option('value', files);        
        if (files.length > 0) {
            FeedQueryMgmt_Attached_FileName = files[0]['name']
        }
    }


