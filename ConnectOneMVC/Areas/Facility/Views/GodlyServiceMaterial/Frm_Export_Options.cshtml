<div class="ServiceMaterial_Export_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    @using DevExpress.XtraReports.UI;
    <div>
            @(Html.DevExtreme().Button()
                    .ID("ServiceMaterial_ExportGridDatapdf")
                    .Text("Export to PDF")
                    //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                    .OnClick("ExportPDF")
                    .Visible(true)
                    .Width(120)
        )<br />

            @(Html.DevExtreme().Button()
                    .ID("ServiceMaterial_ExportGridDataxls")
                    .Text("Export to XLS")
                    //.Icon("fa-file-excel-o")
                    .OnClick("ExportXLS")
                    .Visible(true)
                    .Width(120)
        )<br />
            @(Html.DevExtreme().Button()
                    .ID("ServiceMaterial_ExportGridDataxlsx")
                    .Text("Export to XLSX")
                    //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                    .OnClick("ExportXLSX")
                    .Visible(true)
                    .Width(120)
        )<br />

            @(Html.DevExtreme().Button()
                    .ID("ServiceMaterial_ExportGridDatadocx")
                    .Text("Export to DOCX")
                    //.Icon("export_exporttodocx_16x16office2013")
                    .OnClick("ExportDOCX")
                    .Visible(true)
                    .Width(120)
        )<br />

            @(Html.DevExtreme().Button()
                    .ID("ServiceMaterial_ExportGridDatartf")
                    .Text("Export to RTF")
                    //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                    .OnClick("ExportRTF")
                    .Visible(true)
                    .Width(120)
        )<br />

            @(Html.DevExtreme().Button()
                    .ID("ServiceMaterial_ExportGridDatacsv")
                    .Text("Export to CSV")
                    //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                    .OnClick("ExportCSV")
                    .Visible(true)
                    .Width(120)
        )
    </div>
    <script>
        function ExportPDF()
        {
            ServiceMaterialListGrid.ExportTo(ASPxClientGridViewExportFormat.Pdf);
            $("#Service_Material_modal").dxPopup("hide");
        }
        function ExportXLS()
        {
            ServiceMaterialListGrid.ExportTo(ASPxClientGridViewExportFormat.Xls);
            $("#Service_Material_modal").dxPopup("hide");
        }
        function ExportXLSX()
        {
            ServiceMaterialListGrid.ExportTo(ASPxClientGridViewExportFormat.Xlsx);
            $("#Service_Material_modal").dxPopup("hide");
        }
        function ExportCSV()
        {
            ServiceMaterialListGrid.ExportTo(ASPxClientGridViewExportFormat.Csv);
            $("#Service_Material_modal").dxPopup("hide");
        }
        function ExportDOCX()
        {
            ServiceMaterialListGrid.ExportTo(ASPxClientGridViewExportFormat.Docx);
            $("#Service_Material_modal").dxPopup("hide");
        }
        function ExportRTF()
        {
            ServiceMaterialListGrid.ExportTo(ASPxClientGridViewExportFormat.Rtf);
            $("#Service_Material_modal").dxPopup("hide");
        }
    </script>    
</div>
