<script>
        $(document).ready(function ()
        {
            if ("@Service_Material_AddRight"=="False")
            {
                $("#GSMNew").hide();
            }
            if ("@Service_Material_UpdateRight"=="False")
            {
                $("#GSMEdit").hide();
            }
            if ("@Service_Material_DeleteRight"=="False")
            {
                $("#GSMDelete").hide();
            }
            if ("@Service_Material_ExportRight"=="False")
            {
                $("#ServiceMaterialModelListPreview").hide();
            }
            $(".ServiceMaterialListGrid_PreviewRow").hide();
            GetSessionStorage("ServiceMaterialListGrid");
            if (ServiceMaterial_SetVouchingModeOn == true)
            {
                //$("#ServiceMaterialViewModeSwitch").dxSwitch("instance").option("value", true);
            }
        });
        function DataNavigation_GSM(Action)
        {
            if (Action == "NEW")
            {
                if ("@Service_Material_AddRight"=="False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", 'No Rights'); return;
                }
                ShowLoader();
                OpenDynamicPopup("New ~ Godly Service Material", "@Url.Action("Frm_Service_Material_Window", "GodlyServiceMaterial", new { @area = "Facility" })?ActionMethod=_New", "auto", 750, false, null);
                HideLoader();
            }
            else if (Action == "COPY")
            {
                if ("@Service_Material_AddRight" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", 'No Rights'); return;
                }
                if (ServiceMaterial_ID == "" || ServiceMaterial_ID == null || ServiceMaterial_ID == 'undefined') {
                    DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                    return;
                }
                ShowLoader();
                $.ajax({
                    type: 'GET',
                    async: false,
                    url: "/Facility/GodlyServiceMaterial/Frm_Service_Material_Window",
                    cache: false,
                    data:
                    {
                        ActionMethod: "_New",
                        xID: ServiceMaterial_ID,
                        Info_LastEditedOn: JS_Json_Date_To_ddMMyyyy(ServiceMaterial_Edit_Date)
                    },
                    success: function (data) {
                        ShowLoader();
                        OpenPopup("Dynamic_Content_popup","New ~ Godly Service Material", null, "auto", 750, true, data);
                        HideLoader();
                    }
                });
            }
            else if (Action == "EDIT" || Action == "DELETE")
            {
                if (!"@Service_Material_UpdateRight" || !"@Service_Material_DeleteRight")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", 'No Rights'); return;
                }
                if (ServiceMaterial_ID == "" || ServiceMaterial_ID == null || ServiceMaterial_ID == 'undefined')
                {
                    DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                    return;
                }
                $.ajax({
                    type: 'GET',
                    async: false,
                    url: "/Facility/GodlyServiceMaterial/Frm_Service_Material_Window",
                    cache: false,
                    data:
                    {
                        ActionMethod: Action == "EDIT" ? "_Edit" : "_Delete",
                        xID: ServiceMaterial_ID,
                        Info_LastEditedOn: JS_Json_Date_To_ddMMyyyy(ServiceMaterial_Edit_Date)
                    },
                    success: function (data)
                    {
                        ShowLoader();
                        OpenPopup("Dynamic_Content_popup", Action == "EDIT" ? "Edit ~ Godly Service Material" : "Delete ~ Godly Service Material", null, "auto", 750, true, data);
                        HideLoader();
                    }
                });
            }
        }
        function AfterWindowClose_GSM(ActionMethod = "", xID = "")
        {
            if (ActionMethod == "_Delete" || ActionMethod == "Delete")
            {
                RefreshGridView("ServiceMaterialListGrid");
                return;
            }
            if (ActionMethod.includes("New"))
            {
                ServiceMaterial_MoreEntry = true;
            }
            SR_Select_xid = xID;
            RefreshGridView("ServiceMaterialListGrid");
        }
        function OnServiceMaterialListPreviewClick()
        {
            if (!"@Service_Material_ExportRight")
            {
                DevExpress.ui.dialog.alert("Not Allowed", 'No Rights'); return;
            }
            ShowLoader();
            OpenPopup("Service_Material_modal", "Export Option", "@Url.Action("Frm_Export_Options", "GodlyServiceMaterial", new { @area = "Facility" })", "auto",130);
        }
        function closeServiceMaterial()
        {
            $(".TabPanalMenu-tabs .active span").click();
        }

        $(".TabPanalMenu-tabs .active span").on("click", function () {
            $.ajax({
                type: 'GET',
                url: "/Facility/GodlyServiceMaterial/SessionClear",
                cache: false
            });
            CloseRightPane();
            ClearLeftPane();
            CloseLeftPane();
            ClearAllReferences_ServiceMaterial();
