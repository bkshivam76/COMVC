            padding: 10px
        }

        .pld-head {
            display: block;
            margin-top: -100px;
            text-align: center;
        }

        .pld-icn img {
            width: 120px
        }

        .bordertbl td {
            border-width: 1px
        }

        @@media (max-width: 620px) {
            body {
                width: 100%;
                display: table-row-group;
            }

            table {
                font-size: 14px;
                line-height: 50px;
                padding: 20px;
                display: block;
                width: 100% !important;
                line-height: 24px;
            }

            .pld-head {
                width: 100%
            }

                .pld-head h2 {
                    font-size: 22px
                }

            .pld-icn {
                width: 50%;
                display: inline-block;
                padding: 20px
            }

            .bordertbl {
                border: none
            }

            .pld-head {
                margin: 0 0 -30px;
            }

            .stackhead td:empty {
                display: none
            }
        }
    </style>*@
