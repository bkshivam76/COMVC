@{
    ViewBag.Title = "CorpusFDEmailer";
}
<!DOCTYPE html>
<html lang="en" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:v="urn:schemas-microsoft-com:vml">
<head>
    <style>
        body {
            font-family: Arial, sans-serif;
            font-size: 14px
        }

        .tg {
            border-collapse: collapse;
            border-spacing: 0;
            width: 100%;
        }

            .tg td {
                border-color: #dbd9d9;
                border-style: solid;
                border-width: 1px;
                overflow: hidden;
                padding: 10px 5px;
                word-break: normal;
            }

            .tg th {
                border-color: #dbd9d9;
                border-style: solid;
                border-width: 1px;
                font-weight: normal;
                overflow: hidden;
                padding: 10px 5px;
                word-break: normal;
            }
    </style>
</head>
<body>
    <table width="100%" border="0" align="center" cellpadding="0" cellspacing="0">
        <tbody>
            <tr>
                <td align="center">
                    <table class="col-700" width="900" border="0" align="center" cellpadding="0" cellspacing="0" style="margin-left:0px; margin-right:0px; ">
                        <tbody>
                            <tr>
                                <td height="35"></td>
                            </tr>

                            <tr>
                                <td height="10" align="right" style="line-height:24px; font-weight: 300; padding: 0 0px 0">
                                    @Html.Raw(Model.Tables[0].Rows[0]["DATE_TEXT"])
                                </td>
                            </tr>
                            <tr>
                                <td style="font-weight: 300; padding: 0 0px 0px; line-height:200%">
                                    @Html.Raw(Model.Tables[0].Rows[0]["PARA1_TEXT"])
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <table class="tg">
                                        <thead>
                                            <tr>
                                                <th style="border-color:inherit;font-weight:bold;text-align:left;vertical-align:top">Bank</th>
                                                <th style="border-color:inherit;font-weight:bold;text-align:left;vertical-align:top">FD No.</th>
                                                <th style="border-color:inherit;font-weight:bold;text-align:left;vertical-align:top">FD Date</th>
                                                <th style="border-color:inherit;font-weight:bold;text-align:left;vertical-align:top">FD Amount</th>
                                                <th style="border-color:inherit;font-weight:bold;text-align:left;vertical-align:top">Maturity Date</th>
                                                <th style="border-color:inherit;font-weight:bold;text-align:left;vertical-align:top">Maturity Amt</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (System.Data.DataRow row in Model.Tables[1].Rows)
                                            {
                                                <tr>
                                                    <td style="border-color:inherit;text-align:left;vertical-align:top">@Html.Raw(row["Bank"])</td>
                                                    <td style="border-color:inherit;text-align:left;vertical-align:top">@Html.Raw(row["FD No."])</td>
                                                    <td style="border-color:inherit;text-align:left;vertical-align:top">@Html.Raw(row["FD Date"])</td>
                                                    <td style="border-color:inherit;text-align:left;vertical-align:top">@Html.Raw(row["FD Amount"])</td>
                                                    <td style="border-color:inherit;text-align:left;vertical-align:top">@Html.Raw(row["Maturity Date"])</td>
                                                    <td style="border-color:inherit;text-align:left;vertical-align:top">@Html.Raw(row["Maturity Amt"])</td>
                                                </tr>
                                            }

                                        </tbody>
                                    </table>
                                </td>
                            </tr>

                        </tbody>
                    </table>
                    <table class="col-700" width="900" border="0" align="center" cellpadding="0" cellspacing="0" style="">
                        <tbody>
                            <tr>
                                <td style="font-weight: 300; padding-top: 20px; line-height:200%">@Html.Raw(Model.Tables[0].Rows[0]["PARA_2_TEXT"])</td>
                            </tr>
                        </tbody>
                    </table>


</body>
</html>