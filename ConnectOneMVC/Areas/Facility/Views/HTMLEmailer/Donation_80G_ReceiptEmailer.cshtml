@{ Layout = ""; }

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" id="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0, user-scalable=no" />

    <title>80G Donation Receipts</title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;700&amp;display=swap" rel="stylesheet">
    <!-- CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/Content/CSS/Pledge/pledge.css" rel="stylesheet">
    @*<style>
        .pld-head h2, .pld-head h3 {
            font-size: 22px
        }

        .pld-img {
            padding: 10px
        }

        .pld-head {
            display: block;
            margin-top: -100px;
            text-align: center;
        }

        .pld-icn img {
            width: 120px
        }

        .bordertbl td {
            border-width: 1px
        }

        @@media (max-width: 620px) {
            body {
                width: 100%;
                display: table-row-group;
            }

            table {
                font-size: 14px;
                line-height: 50px;
                padding: 20px;
                display: block;
                width: 100% !important;
                line-height: 24px;
            }

            .pld-head {
                width: 100%
            }

                .pld-head h2 {
                    font-size: 22px
                }

            .pld-icn {
                width: 50%;
                display: inline-block;
                padding: 20px
            }

            .bordertbl {
                border: none
            }

            .pld-head {
                margin: 0 0 -30px;
            }

            .stackhead td:empty {
                display: none
            }
        }
    </style>*@
</head>
<body style="font-family: Merriweather, serif; background: #fff; color: #000;">


    <table align="center" border="0" cellpadding="0" cellspacing="0" class="stackhead" role="presentation" style="mso-table-lspace: 0pt; mso-table-rspace: 0pt; color: #0d273b; width: 800px;" width="800">
        <tbody>
            <tr>
                <td class="pld-icn" style="vertical-align: middle;">
                <img align="left" style="background:#fff; float:left" width="120" height="120" src="https://connectone.app/Content/Images/Logos/INS_00001.jpg">
                <img align="right" width="120"  height="120" style="float:right" src=@Model.instituteLogoURL>
                </td>
            </tr>

            <tr>
                <td class="pld-head" style="font-weight: 400; text-align: left; vertical-align: middle; border:0; text-align: center" width="100%">
                    <h2 style="margin-top:10px"><b>@Model.instituteName</b> </h2>
                    <h4 style="margin-top: 15px; font-size:16px">Donation Receipt (Form 10BE)</h4>
                </td>
            </tr>
        </tbody>
    </table>

    <br />

    <table align="center" border="0" cellpadding="0" cellspacing="0" role="presentation" style="mso-table-lspace: 0pt; mso-table-rspace: 0pt; color: #000000; width: 800px; table-layout: fixed" width="800">
        <tbody>
            <tr>
                <td>
                    Divine Brother/Sister,
                    <BR /> <BR />
                    Thanks a lot for your contribution in @Model.instituteName . Please find below the link(s) to download the 80G Receipt(Form 10BE) for your Contribution.
                    <BR /> <BR />
                    Thanks
                    <BR />
                    @Model.instituteName
                    <BR />
                    @Model.cenID
                    <BR />
                </td>
            </tr>
        </tbody>
    </table>

    <br />

    <table class="bordertbl" style="border-color:#34495E; line-height:16px; text-align:left; font-size:13px; width: 800px; margin:0 auto 20px" cellspacing="0" cellpadding="3" border="1">
        <thead style="background: #34495E; color: #fff; font-size: 12px; padding: 8px 10px 5px; height: 30px; text-transform: uppercase; letter-spacing: 1px; font-weight: bold; line-height: 20px;">
            @Html.Raw(HttpUtility.HtmlDecode(@Model.donationDataHeader))
        </thead>
        <tbody>
            @Html.Raw(HttpUtility.HtmlDecode(@Model.donationDataRows))
        </tbody>
    </table>

    <hr>
    <table align="center" border="0" cellpadding="0" cellspacing="0" role="presentation" style="mso-table-lspace: 0pt; mso-table-rspace: 0pt; font-size:13px; color: #000000; width: 800px; margin-bottom:30px; table-layout: fixed" width="800">
        <tbody>
            <tr>
                <td>
                    **IT IS A COMPUTUER GENERATED MAIL. PLEASE DO NOT REPLY.
                    <br />
                    **IN CASE OF ANY QUERIES, PLEASE CONTACT THE PLACE AT WHICH YOU HAVE GIVEN THIS CONTRIBUTION.
                    <br />
                    **SAVE PAPER, SAVE ENVIRONMENT. DO NOT PRINT THIS UNLESS IT IS COMPULSORILY REQUIRED.
                </td>
            </tr>
        </tbody>
    </table>

</body>
</html>
