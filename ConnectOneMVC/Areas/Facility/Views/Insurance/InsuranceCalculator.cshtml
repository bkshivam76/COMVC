    <script>
        $(function () {
            // Calculate the first day of the next month
            var today = new Date();
            var nextMonth = today.getMonth() + 1;
            var nextMonthFirstDay = new Date(today.getFullYear(), nextMonth, 1);

            // Set the calculated date as the value of the DateBox
            $("#RenewalDate_InsuranceCalculator").dxDateBox("instance").option("value", nextMonthFirstDay);
        });

        function calculatePremium_InsuranceCalculator() {
            debugger;
            var dateInstance = $("#DateOfBirth_InsuranceCalculator").dxDateBox("instance");
            var dateOfBirth = dateInstance.option("value");
            var renewalInstance = $("#RenewalDate_InsuranceCalculator").dxDateBox("instance");
            var renewalDate = renewalInstance.option("value");

            if (dateOfBirth == null || renewalDate == null) {
                document.getElementById("selectedAge_InsuranceCalculator").innerHTML = "Please select your Date of Birth and Insurance policy renewal date to get the Premium Amount"
                document.getElementById("selectedAge_InsuranceCalculator").style.color = "red";
                document.getElementById('result_InsuranceCalculator').innerText = "Please select a proper date of birth and Insurance policy renewal date to get Premium.";
                return;
            }
            //var today = new Date();
            //var age = today.getFullYear() - dateOfBirth.getFullYear();
            //var monthDifference = today.getMonth() - dateOfBirth.getMonth();
            //var dayDifference = today.getDate() - dateOfBirth.getDate();

            
            var age = renewalDate.getFullYear() - dateOfBirth.getFullYear();
            var monthDifference = renewalDate.getMonth() - dateOfBirth.getMonth();
            var dayDifference = renewalDate.getDate() - dateOfBirth.getDate();

            // Adjust age if the birth month hasn't occurred yet this year
            // Adjust age if the birth month hasn't occurred yet this year
            //if (monthDifference < 0 || (monthDifference === 0 && dayDifference < 0)) {
            //    age--;
            //}

            // Increment age if even one day has passed beyond the last birthday
            if (monthDifference > 0 || (monthDifference === 0 && dayDifference > 0)) {
                age++;
            }
            //const age = parseInt(document.getElementById('age_InsuranceCalculator').value);
            document.getElementById("selectedAge_InsuranceCalculator").innerHTML = `Your Age is <strong>${age}</strong> years`
            document.getElementById("selectedAge_InsuranceCalculator").style.color = "black";
            const claimAmount = document.querySelector('input[name="claimAmount"]:checked').value;
            let premium = 0;
            if (age < 0) {
                document.getElementById("selectedAge_InsuranceCalculator").innerHTML = "Please Select a Proper Date of Birth"
                document.getElementById("selectedAge_InsuranceCalculator").style.color = "red";
                document.getElementById('result_InsuranceCalculator').innerText = "Please select a proper date of birth to get Premium.";
                return;
            }
            if (age < 18) {
                document.getElementById('result_InsuranceCalculator').innerText = "Age should be greater than 18 years.";
                return;
            }else if (age >= 18 && age <= 40) {
                premium = claimAmount == 2 ? 3600 : 9000;
            } else if (age >= 41 && age <= 50) {
                premium = claimAmount == 2 ? 5400 : 13500;
            } else if (age >= 51 && age <= 60) {
                premium = claimAmount == 2 ? 7200 : 18000;
            } else if (age >= 61 && age <= 70) {
                premium = claimAmount == 2 ? 9000 : 22500;
            } else if (age >= 71 && age <= 80) {
                premium = claimAmount == 2 ? 10800 : 27000;
            } else if (age >= 81 && age <= 100) {
                premium = claimAmount == 2 ? 15600 : 39000;
            } else {
                document.getElementById('result_InsuranceCalculator').innerText = "Invalid age. Please enter an age between 18 and 100.";
                return;
            }

            document.getElementById('result_InsuranceCalculator').innerText = `Amount : ₹${premium}`;
        }

        // Initial calculation
        //calculatePremium_InsuranceCalculator();
        window.addEventListener('load', function () {
            document.title = "Health Safety Scheme Premium Calculator";
        });
    </script>

