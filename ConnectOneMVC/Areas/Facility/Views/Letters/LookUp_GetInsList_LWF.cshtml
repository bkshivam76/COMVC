
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("Look_InsList_LWF_datagrid")
    .Columns(columns =>
    {
        columns.Add().DataField("INS_NAME").Caption("Name");
        columns.Add().DataField("INS_SHORT").Caption("Short Name");        
        columns.Add().DataField("INS_ID").Caption("INS_ID").Visible(false);
    })    
    .Selection(s => s.Mode(SelectionMode.Single))    
)
