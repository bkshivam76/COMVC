    function AddressBookGrid_notificationSet_iIconTemplate(container, templateData) {
        var iREQ_ATTACH_COUNT = templateData.data.REQ_ATTACH_COUNT
        var iCOMPLETE_ATTACH_COUNT = templateData.data.COMPLETE_ATTACH_COUNT
        var iRESPONDED_COUNT = templateData.data.RESPONDED_COUNT
        var iREJECTED_COUNT = templateData.data.REJECTED_COUNT
        var iOTHER_ATTACH_CNT = templateData.data.OTHER_ATTACH_CNT
        var iALL_ATTACH_CNT = templateData.data.ALL_ATTACH_CNT
        var iIcon = templateData.data.iIcon
        var UniqueID = templateData.component.element()[0].id
        var key = templateData.data.ID != null ? templateData.data.ID.replace(/^0-9A-Za-z/gi, "_") : "";
        var VisibleIndex = templateData.rowIndex
        var htmlString = "";
        htmlString = DxGrid_AttachmentIcons(iREQ_ATTACH_COUNT, iCOMPLETE_ATTACH_COUNT, iRESPONDED_COUNT, iREJECTED_COUNT, iOTHER_ATTACH_CNT, iALL_ATTACH_CNT);
        htmlString += DxGrid_VouchingAuditIcons(iIcon)
        htmlString += DxGrid_AuditIconAfterClick(UniqueID, key, VisibleIndex)
        $(container).html(htmlString)
    }
    function AddressBookGrid_notificationSet_OnInitialized(e) {
        DxGrid_AdjustSize(e.component, $("#AddressBook_notificationSet_ParentDiv_dx .report_button_div"))
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            DxGrid_AdjustSize(e.component, $("#AddressBook_notificationSet_ParentDiv_dx .report_button_div"), "", evt)
        });
        //Observer_Helper.subscribe(e.component, document.documentElement, e.component.updateDimensions, 100, 0, $("#AddressBook_notificationSet_ParentDiv_dx .report_button_div"));
        AddressBookGrid_notificationSet = e.component;
    }
    function AddressBookGrid_notificationSet_OnCellPrepared(e) {
        if (e.rowType == "data") {
            var keyvalue = e.key != null ? e.key.replace(/^0-9A-Za-z/gi, "_") : "Null" + e.rowIndex;
            if (AddressBook_notificationSet_IsVouchingMode_dx == true) {
                if (e.column.dataField === "iIcon") {
                    $(e.cellElement).attr("onmouseover", "OnGridRowMouseHoverIn(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + keyvalue + "')");
                    $(e.cellElement).attr("onmouseout", "OnGridRowMouseHoverOut(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + keyvalue + "')");
                }
            }
            $(e.cellElement).attr("id", e.element[0].id + "_Cell_" + keyvalue + "|" + e.column.dataField);
            /*$(e.cellElement).addClass("col_" + e.column.dataField + " row_" + keyvalue);*/
        }
    }
    function AddressBookGrid_notificationSet_OnRowPrepared(e) {
        if (e.rowType == "data") {
            var GridName = e.element[0].id;
            var keyvalue = e.key != null ? e.key.replace(/^0-9A-Za-z/gi, "_") : "Null" + e.rowIndex;
            $(e.rowElement).addClass(GridName + "_DataRow_" + keyvalue)

            var PreviewRowContent = AddressBookGrid_notificationSet_PreviewRow_Template(e)
            var PreviewRowClass = GridName + "_PreviewRow " + GridName + "_PreviewRow_" + keyvalue + " DataGridPreviewRow"
            var PreviewRowOptions = "";
            if (AddressBook_notificationSet_IsVouchingMode_dx == true) {
                PreviewRowOptions = "style='display:none' onmouseover=OnGridPrevRowMouseHoverIn(event,this,'" + GridName + "','" + e.rowIndex + "','" + keyvalue + "') onmouseout=OnGridPrevRowMouseHoverOut(event,this,'" + GridName + "','" + e.rowIndex + "','" + keyvalue + "')"
            }
            var EmptyTdshtml = "";
            var emptyTd = $(e.rowElement).find('td.dx-datagrid-group-space').length
            for (var i = 0; i < emptyTd; i++) {
                EmptyTdshtml += "<td></td>"
            }
            // ($(e.rowElement).parent()).append("<tr class='" + PreviewRowClass + "' " + PreviewRowOptions + ">" + EmptyTdshtml + "<td colspan='100%'>" + PreviewRowContent + "</td></tr>")
            ($(e.rowElement).parent()).append("<tr class='" + PreviewRowClass + "' " + PreviewRowOptions + ">" + EmptyTdshtml + "<td colspan='" + (e.columns.length) + "'>" + PreviewRowContent + "</td></tr>")
        }
    }
    function AddressBookGrid_notificationSet_OnContentReady(e) {
        //setTimeout(function ()
        //{
        //GetSessionStorage("AddressBookGrid_notificationSet");
        DxGrid_OnContentReady(e, AB_ShowHorizontalBar_dx);
        // DxGrid_SetGridUIinColHiding("AddressBookGrid_notificationSet", AB_ShowHorizontalBar_dx);
        /*})*/
    }
        function AddressBookGrid_notificationSet_OnCellDblClick(e) {
            if (e.rowType == "data") {
                if (AddressBook_notificationSet_IsVouchingMode_dx == true && AdresBook_ViewMode_dx == "Default") {
                    var keyvalue = e.key != null ? e.key.replace(/^0-9A-Za-z/gi, "_") : "Null" + e.rowIndex;
                    OnGridCellClick(e.event, e.cellElement[0], e.columnIndex, e.rowIndex, e.element[0].id, keyvalue, e.column.dataField)
                }
                else if (AddressBook_notificationSet_IsVouchingMode_dx == false) { OnAddressEditClick_dx(); }
            }
        }
    function AddressBookGrid_notificationSet_OnSelectionChanged(e) {
        var selectedRowKeys = e.selectedRowKeys;
        if (selectedRowKeys != null && selectedRowKeys.length > 0) {            
            selectedContacts_notificationSet = e.selectedRowKeys
            document.getElementById("selectedManualContactsCount_notificationSet").innerText = selectedContacts_notificationSet.length + " Contact(s) Selected Manually."
            document.getElementById("count_addressbookgridPage_notificationSet").innerText = selectedContacts_notificationSet.length + " Contact(s) Selected Manually."
        }
        else {            
            selectedContacts_notificationSet = null
            document.getElementById("selectedManualContactsCount_notificationSet").innerText = "You did not selected any contacts manually"
            document.getElementById("count_addressbookgridPage_notificationSet").innerText = ""
        }
    }

    function closeAddressBook_notificationSet() {
        selectedContacts_notificationSet = AddressBookGrid_notificationSet.getSelectedRowKeys();
        $("#AddressBook_notificationSet_modal").dxPopup("hide");
    }
    </script>
