    <script>
        function CustomNotification_addressbook_InfoGrid_dx_OnRowClick(e) {
            if (e.rowType === "data") {
                if (e.isSelected)
                    e.component.deselectRows(e.key);
                else
                    e.component.selectRows(e.key, true);
            }
        }
        $(document).ready(function () {
            var addressGridInstance = $("#AddressBookGrid_notificationSet").dxDataGrid("instance")
            if (selectedContacts_notificationSet != null || selectedContacts_notificationSet != undefined) {
                if (selectedContacts_notificationSet.length > 0) {
                    addressGridInstance.selectRows(selectedContacts_notificationSet);
                }
            }            
        });
    var AddressBook_notificationSet_IsVouchingMode_dx = false;
    var AB_ShowHorizontalBar_dx = parseInt("@ViewBag.ShowHorizontalBar");
    var AddressBook_notificationSet_ID_dx = null;
    var AddressBook_notificationSet_Edit_Date_dx;
    var AddressBook_notificationSet_Add_Date_dx;
