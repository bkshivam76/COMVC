    function AddressBookchangeMode_dx() {
        AddressBookGrid_notificationSet.beginUpdate();
        if (AB_ShowHorizontalBar_dx == 0) {
            AB_ShowHorizontalBar_dx = 1;
            $("#AddressToggleScrollBar_notificationSet").find("span").text("Default Data");
            $("#AddressToggleScrollBar_notificationSet").width(110);
            AddressBookGrid_notificationSet.option("columnHidingEnabled", false);
            AddressBookGrid_notificationSet.option("allowColumnResizing", true)
            AddressBookGrid_notificationSet.option("columnResizingMode", "widget")
        }
        else {
            AB_ShowHorizontalBar_dx = 0;
            $("#AddressToggleScrollBar_notificationSet").find("span").text("Full Data");
            $("#AddressToggleScrollBar_notificationSet").width(90);
            AddressBookGrid_notificationSet.option("columnHidingEnabled", true)
            AddressBookGrid_notificationSet.option("allowColumnResizing", false)
            AddressBookGrid_notificationSet.option("columnResizingMode", "nextColumn")
        }
        AddressBookGrid_notificationSet.endUpdate();
    }
    function AddressBookGrid_notificationSet_PreviewRow_Template(e) {
        if (AddressBook_notificationSet_IsVouchingMode_dx == true) {
            var keyvalue = e.key != null ? e.key.replace(/^0-9A-Za-z/gi, "_") : "Null" + e.rowIndex;
            return DxGrid_AuditButtons(e.element[0].id, keyvalue, e.rowIndex);
        }
        else {
            return ""
        }
    }
