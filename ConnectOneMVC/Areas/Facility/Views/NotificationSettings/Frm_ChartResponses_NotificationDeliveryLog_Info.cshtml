            </div>
            <div class="col-md-6">
                @(Html.DevExtreme().DateBox().CustomDateBox().ID("FromDate_NotificationDeliveryLog_ChartResponses").Name("FromDate_NotificationDeliveryLog_ChartResponses").Placeholder("From Date (dd-MM-yyyy)"))
                @(Html.DevExtreme().DateBox().CustomDateBox().ID("ToDate_NotificationDeliveryLog_ChartResponses").Name("ToDate_NotificationDeliveryLog_ChartResponses").Placeholder("To Date (dd-MM-yyyy)"))
