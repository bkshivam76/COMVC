                var GridName = e.element[0].id;
                //var keyvalue = e.key != null ? e.key.replace(/^0-9A-Za-z/gi, "_") : "Null" + e.rowIndex;
                var keyvalue = e.key.toString();
                $(e.rowElement).addClass(GridName + "_DataRow_" + keyvalue)

                var PreviewRowContent = EmailDeliveryLogNotificationSetInfoGrid_PreviewRow_Template(e)
                var PreviewRowClass = GridName + "_PreviewRow " + GridName + "_PreviewRow_" + keyvalue + " DataGridPreviewRow"
                var PreviewRowOptions = "";
                if (EmailDeliveryLog_notificationSet_IsVouchingMode_dx == true) {
                    PreviewRowOptions = "style='display:none' onmouseover=OnGridPrevRowMouseHoverIn(event,this,'" + GridName + "','" + e.rowIndex + "','" + keyvalue + "') onmouseout=OnGridPrevRowMouseHoverOut(event,this,'" + GridName + "','" + e.rowIndex + "','" + keyvalue + "')"
                }
                var EmptyTdshtml = "";
                var emptyTd = $(e.rowElement).find('td.dx-datagrid-group-space').length
                for (var i = 0; i < emptyTd; i++) {
                    EmptyTdshtml += "<td></td>"
                }
                // ($(e.rowElement).parent()).append("<tr class='" + PreviewRowClass + "' " + PreviewRowOptions + ">" + EmptyTdshtml + "<td colspan='100%'>" + PreviewRowContent + "</td></tr>")
                ($(e.rowElement).parent()).append("<tr class='" + PreviewRowClass + "' " + PreviewRowOptions + ">" + EmptyTdshtml + "<td colspan='" + (e.columns.length) + "'>" + PreviewRowContent + "</td></tr>")
            }
        }
        function EmailDeliveryLogNotificationSetInfoGrid_OnContentReady(e) {

            DxGrid_OnContentReady(e, EmailDeliveryLog_notificationSet_ShowHorizontalBar_dx);

        }
        function EmailDeliveryLogNotificationSetInfoGrid_OnCellDblClick(e) {
            if (e.rowType == "data") {
                if (EmailDeliveryLog_notificationSet_IsVouchingMode_dx == true && AdresBook_ViewMode_dx == "Default") {
                    var keyvalue = e.key != null ? e.key.replace(/^0-9A-Za-z/gi, "_") : "Null" + e.rowIndex;
                    OnGridCellClick(e.event, e.cellElement[0], e.columnIndex, e.rowIndex, e.element[0].id, keyvalue, e.column.dataField)
                }
                else if (EmailDeliveryLog_notificationSet_IsVouchingMode_dx == false) { OnAddressEditClick_dx(); }
            }
        }
        function EmailDeliveryLogNotificationSetInfoGrid_OnSelectionChanged(e) {
            var selectedRowKeys = e.selectedRowKeys;
            if (selectedRowKeys != null && selectedRowKeys.length > 0) {
                //EmailDeliveryLogNotificationSetInfoGrid_SelectedRowData(e.selectedRowsData);
                selectedContacts_notificationSet = e.selectedRowKeys
            }
            else {
                //EmailDeliveryLog_notificationSet_ID_dx = null;
                selectedContacts_notificationSet = null
            }
        }

        function closeEmailDeliveryLog_notificationSet() {
            selectedContacts_notificationSet = EmailDeliveryLogNotificationSetInfoGrid.getSelectedRowKeys();
            $("#EmailDeliveryLog_notificationSet_modal").dxPopup("hide");
        }
    </script>
