        $(document).ready(function() {
            var date = '@(FromDate.HasValue ? FromDate.Value.ToString("yyyy/MM/dd") : "")';
            if (date != "") {
                $("#FromDate_NotificationDeliveryLog_ChartResponses").dxDateBox("instance").option("value", new Date(date));
            }
            $("#SelectedTabTitleDeliveryLog_Notify_ChartResponses").val("Whatsapp");
        });
        function filterChartResponseDeliveryLogNotification() {
            debugger;
            ChartResponsesWhatsappDeliveryLogNotificationInfoGrid.Refresh();
            EmailDeliveryLogNotificationSetInfoGrid.refresh();
        }

        function EmailDeliveryLogNotificationSetInfoGrid_onBeforeSend(operation, ajaxOptions) {
            debugger;
            var param = {};
            var fromDate = null;
            var toDate = null;

            if ($("#FromDate_NotificationDeliveryLog_ChartResponses").dxDateBox("instance").option("value") != null) {
                //fromDate = JS_Json_Date_To_ddMMyyyy($("#FromDate_NotificationDeliveryLog_ChartResponses").dxDateBox("instance").option("value"));
                fromDate = moment($("#FromDate_NotificationDeliveryLog_ChartResponses").dxDateBox("instance").option("value")).format("DD/MM/YYYY HH:mm:ss");
            } else { fromDate = null; }
            if ($("#ToDate_NotificationDeliveryLog_ChartResponses").dxDateBox("instance").option("value") != null) {
                //toDate = JS_Json_Date_To_ddMMyyyy($("#ToDate_NotificationDeliveryLog_ChartResponses").dxDateBox("instance").option("value"));
                toDate = moment($("#ToDate_NotificationDeliveryLog_ChartResponses").dxDateBox("instance").option("value")).format("DD/MM/YYYY HH:mm:ss");
            } else { toDate = null; }
            if ($("#ToDate_NotificationDeliveryLog_ChartResponses").dxDateBox("instance").option("value") != null) {
                if ($("#FromDate_NotificationDeliveryLog_ChartResponses").dxDateBox("instance").option("value") > $("#ToDate_NotificationDeliveryLog_ChartResponses").dxDateBox("instance").option("value")) {
                    DevExpress.ui.notify({ message: 'From Date should not be greater than To Date', width: 300, shading: true, position: 'center' }, "error", 2000);
                    return;
                }
            }

            param["FromDate"] = fromDate;
            param["ToDate"] = toDate;

            ajaxOptions.data = param;
        }
        
            function RescheduleEmailLogs_Click(e) {
                if (e.itemData == "Failed in Last One Day") {
                    rescheduletoQueue('lastday', null)
                }
                else if (e.itemData == "Failed in Last Week") {
                    rescheduletoQueue('lastweek', null)
                }
                else if (e.itemData == "Failed in Last 30 Days") {
                    rescheduletoQueue('lastmonth', null)
                }
                else if (e.itemData == "Selected Logs To Queue") {
                    rescheduletoQueue(null, 'selected')
                }
            }
    
        function rescheduletoQueue(period, selectedrecids) {
            debugger;
            var selectedkeys = null;
            if (selectedrecids == 'selected') {
                var grid = $("#EmailDeliveryLogNotificationSetInfoGrid").dxDataGrid("instance")
                selectedkeys = grid.getSelectedRowKeys();
            } else if (period != null) {
                //
            }
            //ajax call
            ShowLoader()
            $.ajax({
                url: '/Facility/NotificationSettings/SendEmailLogsToEmailSchedulerQueue', // replace with your API endpoint
                type: 'GET',
                data: {
                    period: period,
                    recids_str: ((selectedkeys == null) || selectedkeys == "") ? null : selectedkeys.join(",")
                },
                success: function (data) {
                    HideLoader()
                    if (data.jsonParam.result) {
                        DevExpress.ui.dialog.alert(data.jsonParam.message, "Information!!!")
                        EmailDeliveryLogNotificationSetInfoGrid.refresh();
                    } else {
                        DevExpress.ui.dialog.alert(data.jsonParam.message, "Information!!!")
                    }                    
                },
                error: function (error) {
                    console.log(error);
                }
            });
        }
        
