    function CustomNotificationResponsesGrid_Load_Columns(CRInfoGrid_ViewMOde) {
        CustomNotification_ResponsesInfoGrid_dx.beginUpdate();
        var _columns = CustomNotification_ResponsesInfoGrid_dx.option("columns");
        if (CRInfoGrid_ViewMOde == "Compact") {
            VisibleColumns_CustomNotificationResponsesGrid = [];
            for (var i = 0; i < _columns.length; i++) {
                var name = _columns[i].dataField;
                var ColumnVisible = CustomNotification_ResponsesInfoGrid_dx.columnOption(name, "visible");
                if (name == "CustomNotification_ResponsesInfoGrid_dx_Compact_Column" || name == "iIcon") {
                    CustomNotification_ResponsesInfoGrid_dx.columnOption(name, "visible", true);
                }
                else if (ColumnVisible == true) {
                    VisibleColumns_CustomNotificationResponsesGrid.push(name);
                    CustomNotification_ResponsesInfoGrid_dx.columnOption(name, "visible", false);
                }
            }
        }
        else {
            CustomNotification_ResponsesInfoGrid_dx.columnOption("CustomNotification_ResponsesInfoGrid_dx_Compact_Column", "visible", false);
            for (var i = 0; i < VisibleColumns_CustomNotificationResponsesGrid.length; i++) {
                CustomNotification_ResponsesInfoGrid_dx.columnOption(VisibleColumns_CustomNotificationResponsesGrid[i], "visible", true);
            }
        }
        var SummaryItems = CustomNotification_ResponsesInfoGrid_dx.option("summary.groupItems")
        if (SummaryItems == void 0 || SummaryItems == null || SummaryItems.length == 0) {
            SummaryItems = [];
        }
        var index = SummaryItems.findIndex(obj => { return obj.name === 'Name_Name_count' })
        if (index == -1) {
            SummaryItems.push({
                column: 'Name',
                displayFormat: "Total Registrations: {0}",
                summaryType: 'count',
                name: 'Name_Name_count'
            })
        }
        index = SummaryItems.findIndex(obj => { return obj.name === 'REGISTRATIONS_REGISTRATIONS_sum' })
        if (index == -1) {
            SummaryItems.push({
                column: 'REGISTRATIONS',
                displayFormat: "Total Registered Souls: {0}",
                summaryType: 'sum',
                name: 'REGISTRATIONS_REGISTRATIONS_sum'
            })
        }
        CustomNotification_ResponsesInfoGrid_dx.option("summary.groupItems", SummaryItems)
        // CustomNotification_ResponsesInfoGrid_dx.repaint();
        CustomNotification_ResponsesInfoGrid_dx.endUpdate();
        // CustomNotification_ResponsesInfoGrid_dx.updateDimensions();
    }

