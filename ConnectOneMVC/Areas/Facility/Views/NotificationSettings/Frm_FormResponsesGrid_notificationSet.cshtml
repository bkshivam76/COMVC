    <div>
        @(Html.DevExtreme().Switch().ID("CustomNotification_ResponsesInfoViewModeSwitch").SwitchedOnText("Compact").SwitchedOffText("Default")
        .OnValueChanged("CustomNotification_ResponsesInfo_Dx_ViewSwitch_ValueChange").Width(70).Value(true))
        @(Html.DevExtreme().Button().ID("CustomNotification_ResponsesInfoModelCLOSE").Text("Ok & Close").Icon("clear").OnClick("closeFormResponses_notificationSet") )
        <span id="count_formresponsesgridPage_notificationSet"></span>
    </div>
    @(Html.DevExtreme().DataGrid().CustomDataGridListing(1)
        .ID("CustomNotification_ResponsesInfoGrid_dx")
        .DataSource(d => d.Mvc().Controller("NotificationSettings").LoadAction("FormResponsesData_Load")
                        .LoadMode(DataSourceLoadMode.Raw).Key("RESP_ID")
                        //.LoadParams(new { chartInstanceID= chartInstanceID, regCenId= regCenId, QuestionFilter= QuestionFilter })
                        .OnBeforeSend("CustomNotification_ResponsesInfoGrid_dx_OnBeforeSend")
                )

        .NoDataText("No Data").Columns(columns =>
        {
            columns.Add().DataField("iIcon").Name("iIcon").Caption("").Visible(true).AllowEditing(false)
            .HeaderFilter(filter => filter.DataSource("CRDxGrid_HeaderFilterDataSource")).RenderAsync(true).Width(30)
            .CellTemplate(new JS("HighlightRow_icon_CellTemplate")).CalculateCellValue("CustomNotification_ResponsesInfoGrid_dx_iIcon_CellValue");
            columns.Add().DataField("CustomNotification_ResponsesInfoGrid_dx_Compact_Column")
            .Name("CustomNotification_ResponsesInfoGrid_dx_Compact_Column").Caption("").Visible(false).Width("100%")
            .CellTemplate(new JS("CustomNotification_ResponsesInfoGrid_dx_Compact_Column_Template")).AllowEditing(false)
            .CalculateCellValue("CustomNotification_ResponsesInfoGrid_dx_Compact_Column_CellValue")
            .Visible(true).RenderAsync(true).ShowInColumnChooser(false);

            columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);//Bug #137209 Fix

        })
        .Selection(s => s.Mode(SelectionMode.Multiple)
        .ShowCheckBoxesMode(GridSelectionShowCheckBoxesMode.Always)
        .AllowSelectAll(true)
        )      
        .Summary(s =>
        {
            s.TotalItems(item => item.Add().Column("REGISTRATIONS").Name("REGISTRATIONS_CustomNotification_ResponsesInfoGrid_dx_Compact_Column_sum")
            .SummaryType(SummaryType.Sum).DisplayFormat("Registrations:{0}").ShowInColumn("CustomNotification_ResponsesInfoGrid_dx_Compact_Column"));
        })
        .OnInitialized("CustomNotification_ResponsesInfoGrid_dx_OnInitialized")
        .OnRowPrepared("CustomNotification_ResponsesInfoGrid_dx_OnRowPrepared")
        .OnContentReady("CustomNotification_ResponsesInfoGrid_dx_OnContentReady")
        .OnSelectionChanged("CustomNotification_ResponsesInfoGrid_dx_OnSelectionChanged")
        .OnRowClick("CustomNotification_ResponsesInfoGrid_InfoGrid_dx_OnRowClick")
        .WordWrapEnabled(false)
)
    <script>
        $(document).ready(function () {
            var FormRespnsesGridInstance = $("#CustomNotification_ResponsesInfoGrid_dx").dxDataGrid("instance")
            if (selectedFormResponses_notificationSet != null || selectedFormResponses_notificationSet != undefined) {
                if (selectedFormResponses_notificationSet.length > 0) {
                    FormRespnsesGridInstance.selectRows(selectedFormResponses_notificationSet);
                }
            }
        });
    var CustomNotification_Responses_FirstCall = true;
    var CustomNotification_ResponsesInfoGrid_dx = null;
    var CustomNotificationResponsesGrid_Content_ready = false;
    var CustomNotificationResponsesGrid_ViewMode = null;
    var _CustomNotificationResponsesGrid_DataSource = null;
        var VisibleColumns_CustomNotificationResponsesGrid = [];

    //var CustomNotificationResponsesGrid_SelectedData = [];
    var CompactMode_CustomNotificationResponses = "Compact";
    function closeFormResponses_notificationSet() {
        selectedFormResponses_notificationSet = CustomNotification_ResponsesInfoGrid_dx.getSelectedRowKeys(); //.selectedRowsData();
        $("#FormResponse_notificationSet_modal").dxPopup("hide");
    }
    function CustomNotification_ResponsesInfo_Dx_ViewSwitch_ValueChange(e) {
        CompactMode_CustomNotificationResponses = e.value == false ? "Default" : "Compact";
        CustomNotificationResponsesGrid_Load_Columns(CompactMode_CustomNotificationResponses);
    }
    function CustomNotification_ResponsesInfoGrid_dx_OnInitialized(e) {
        DxGrid_AdjustSize(e.component, $("#CustomNotification_Responses_ParentDiv_dx .report_button_div"), "Dynamic_Content_popup")
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            DxGrid_AdjustSize(e.component, $("#CustomNotification_Responses_ParentDiv_dx .report_button_div"), "Dynamic_Content_popup", evt)
        });
        CustomNotification_ResponsesInfoGrid_dx = e.component;
        e.component.option("dataSource").store.load().done(function (data) {
            CustomNotificationResponsesGrid_AddDynamic_Columns(data);
            CustomNotificationResponsesGrid_Load_Columns(CompactMode_CustomNotificationResponses);
            e.component.columnOption("command:select", "width", 30)
        });

    }
    function CustomNotification_ResponsesInfoGrid_dx_OnRowPrepared(e) {
        if (e.rowType == "data") {
            var GridName = e.element[0].id;
            $(e.rowElement).addClass(GridName + "_DataRow_" + e.key)
            if (e.data.REC_STATUS != null && e.data.REC_STATUS == -1) {
                $(e.rowElement).css("background-color", "rgb(233, 210, 224)");// REJECTED RESPONSE
            }
            if (e.data.REC_STATUS != null && e.data.REC_STATUS == 2) {
                $(e.rowElement).css("background-color", "rgb(238, 251, 233)");// APPROVED RESPONSE
            }
            if (!(e.data.Accomodation == "")) {
                $(e.rowElement).css("background-color", "rgb(255, 245, 223)");
            }
            if (e.data.Arrived) {
                $(e.rowElement).css("background-color", "rgb(212, 236, 244)");
            }
            if (e.data.REC_STATUS != null && e.data.REC_STATUS == -2) {
                $(e.rowElement).css("background-color", "rgb(255, 240, 240)");
            }

            if (e.data.Highlight !== null) {
                var Highlight = e.data.Highlight;
                if (Highlight) {
                    $(e.rowElement).css("background-color", Highlight);
                }
            }
            var PreviewRowContent = CustomNotification_ResponsesInfoGrid_dx_PreviewRow_Template(e)
            var PreviewRowClass = "DataGridPreviewRow"
            var PreviewRowOptions = "";
            ($(e.rowElement).parent()).append("<tr class='" + PreviewRowClass + "' " + PreviewRowOptions + "><td style='padding-left:30px' colspan='" + (e.columns.length) + "'>" + PreviewRowContent + "</td></tr>")
        }
    }
    function CustomNotification_ResponsesInfoGrid_dx_OnSelectionChanged(e) {
        var selectedRowKeys = e.selectedRowKeys;
        if (selectedRowKeys != null && selectedRowKeys.length > 0) {
            //CustomNotificationResponsesGrid_SelectedData = e.selectedRowsData;
            selectedFormResponses_notificationSet = e.selectedRowKeys
            document.getElementById("selectedManualResponsesCount_notificationSet").innerText = selectedFormResponses_notificationSet.length + " Response(s) Selected Manually."
            document.getElementById("count_formresponsesgridPage_notificationSet").innerText = selectedFormResponses_notificationSet.length + " Response(s) Selected Manually."
        }
        else {
            //CustomNotificationResponsesGrid_SelectedData = [];
            selectedFormResponses_notificationSet = null;
            document.getElementById("selectedManualResponsesCount_notificationSet").innerText = "You did not selected any Responses Manually.";
            document.getElementById("count_formresponsesgridPage_notificationSet").innerText = "";
        }
        $("#selectedCount_div_CustomNotification_Responses>label").text(selectedRowKeys.length + " Row(s) Selected")
    }
    function CustomNotification_ResponsesInfoGrid_dx_OnContentReady(e) {
        DxGrid_OnContentReady(e);
    }
    function CustomNotification_ResponsesInfoGrid_InfoGrid_dx_OnRowClick(e) {
        if (e.rowType === "data") {
            if (e.isSelected)
                e.component.deselectRows(e.key);
            else
                e.component.selectRows(e.key, true);
        }
    }
