    function CustomNotification_ResponsesInfoGrid_dx_PreviewRow_Template(e) {
        var htmlString = "";
        var Remarks = e.data.Remarks == null ? "" : e.data.Remarks;
        if (Remarks.length > 0) {
            htmlString += "<div><span style='color:#0000FF'> <i>Admin Remarks: " + Remarks + "</i></span></div>";
        }
        return htmlString;
    }
    function CRDxGrid_HeaderFilterDataSource(data) {
        data.dataSource.postProcess = function (results) {
            results = [];
            results.push({
                text: "Blue",
                value: "Blue"
            });
            results.push({
                text: "Green",
                value: "Green"
            });
            results.push({
                text: "Yellow",
                value: "Yellow"
            });
            results.push({
                text: "Orange",
                value: "Orange"
            });
            results.push({
                text: "Red",
                value: "Red"
            });
            return results;
        };
    }
    function CustomNotification_ResponsesInfoGrid_dx_iIcon_CellValue(rowData) {
        var Highlight = rowData.Highlight;
        if (Highlight != null && Highlight.length == 0) { Highlight = null; }
        return Highlight == "#30C5FF" ? "Blue" : Highlight == "#5DE23C" ? "Green" : Highlight == "#FBF719" ? "Yellow" : Highlight == "#FF793B" ? "Orange" : Highlight == "#F72F35" ? "Red" : Highlight == null ? "" : "Others";
    }
    function HighlightRow_icon_CellTemplate(container, templateData) {
        if (templateData.data.Highlight) {
            if (templateData.data.Highlight.includes("#")) {
                $(container).html("🖌");
            }
        }
    }
