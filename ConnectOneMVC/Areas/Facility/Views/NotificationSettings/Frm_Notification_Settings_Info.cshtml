        function InsertToWhatsappQueue_Notify_ChartResponses(formdata, newFormData, i = -1) {//i is passed to check whether call is going for Google sheet import or others
            debugger;
            for (var pair of formdata.entries()) {
                if (pair[0] !== 'Content_Email_Notify_ChartResponses' && pair[0] !== 'Content_Whatsapp_Notify_ChartResponses' && pair[0] !== 'File_Whatsapp_Notify_ChartResponses') {
                    newFormData.append(pair[0], $('<div/>').text(pair[1]).html());
                }
                else if (pair[0] == 'File_Whatsapp_Notify_ChartResponses') {
                    newFormData.append(pair[0], $('<div/>').text(pair[1]).html());
                }
                else if (pair[0] == 'Content_Whatsapp_Notify_ChartResponses') {
                    newFormData.append(pair[0], $('<div/>').text(pair[1]).html());
                }
                else if (pair[0] == 'Content_Email_Notify_ChartResponses') {
                    newFormData.append(pair[0], $('<div/>').text(pair[1]).html());
                }
                else {
                    // For these keys, directly append the raw value (or handle files as needed)
                    newFormData.append(pair, pair);
                }
            }
            let response = null;
            return new Promise((resolve, reject) => {
                $.ajax({
                    url: "/Facility/NotificationSettings/Frm_ChartResponses_Add_Notification",
                    type: "POST",
                    data: newFormData,
                    processData: false,
                    contentType: false,
                    success: function (data) {
                        HideLoader();
                        if (data.jsonParam.result) {
                            if (i == -1) {
                                DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title)
                                //ChartResponsesWhatsappQueueNotificationInfoGrid.Refresh()
                                //ChartResponsesEmailQueueNotificationInfoGrid.Refresh()
                                if (data.jsonParam.message != 'Queue Not created.') {
                                    //clear_Wtsapp_notificationSet_onclick();
                                    selectedContacts_notificationSet = null;//Not required when Data is imported from Google Sheets
                                    selectedFormResponses_notificationSet = null;//Not required when Data is imported from Google Sheets
                                }
                            }
                        }
                        else {
                            DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                            $("#ChartResponsesInfo_modal").dxPopup("hide");
                        }
                        resolve(data);
                    },
                    error: function (xhr, status, error) {
                        HideLoader();
                        reject(error);
                    }
                });
            });
        }
        function cleanPhoneNumbers(phoneNumbers) {
            // Split the input string into an array of phone numbers
            let phoneArray = phoneNumbers.split(',');

            // Function to clean individual phone numbers
            function cleanNumber(number) {
                // Trim spaces at the beginning and end
                number = number.trim();

                // Remove all non-digit characters
                let cleaned = number.replace(/\D/g, '');

                // Remove country code if present
                if (cleaned.startsWith('91') && cleaned.length > 10) {
                    cleaned = cleaned.substring(2);
                } else if (cleaned.startsWith('0') && cleaned.length > 10) {
                    cleaned = cleaned.substring(1);
                }

                // Return the cleaned number if it's 10 digits long
                return cleaned.length === 10 ? cleaned : null;
            }

            // Clean all phone numbers and filter out invalid ones
            let cleanedNumbers = phoneArray.map(cleanNumber).filter(Boolean);

            // Join the cleaned numbers back into a comma-separated string
            return cleanedNumbers.join(',');
        }
