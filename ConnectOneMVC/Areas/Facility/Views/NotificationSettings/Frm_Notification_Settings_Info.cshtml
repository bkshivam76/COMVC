    <script>
        function ChartResponses_ListNotificationBatchQueueGrid() {//Notification Batch queue
            var selectedradioInstance = $("#FormResponsesRadioOption_notificationSet").dxRadioGroup("instance")
            var selectedradiovalue = selectedradioInstance.option("value")

            if (selectedradiovalue == "formresponses") {
                if (selectedInstanceId_notificationSet != null && selectedInstanceId_notificationSet != undefined && selectedInstanceId_notificationSet != "") {
                    OpenPopup("ChartResponsesNotificationBatchQueue_modal", "Notification", "@Url.Action("Frm_ChartResponses_NotificationBatchQueue", "NotificationSettings",
                        new { @area = "Facility" })?Chart_Instance_Id=" + selectedInstanceId_notificationSet, "100%", 1200);
                } else {
                    DevExpress.ui.notify({ message: "Please Select Form which you want to see the Notification Batches.", width: "auto", shading: true, position: 'center' }, "info", 3000);
                }
            } else if (selectedradiovalue == "addressbook") {
                OpenPopup("ChartResponsesNotificationBatchQueue_modal", "Notification", "@Url.Action("Frm_ChartResponses_NotificationBatchQueue", "NotificationSettings",
                        new { @area = "Facility" })?Chart_Instance_Id=0", "100%", 1200);
            }
            else if (selectedradiovalue == "phonenumbers") {
                OpenPopup("ChartResponsesNotificationBatchQueue_modal", "Notification", "@Url.Action("Frm_ChartResponses_NotificationBatchQueue", "NotificationSettings",
                        new { @area = "Facility" })?Chart_Instance_Id=0", "100%", 1200);
            }

        }
        function PendingQueue_onclick_notificationSet() {
                OpenPopup("PendingQueueInfo_notificationSet_modal", "Notification", "@Url.Action("Frm_notificationSet_NotificationQueue_Info", "NotificationSettings",
                new { @area = "Facility" })", "100%", 1200);
            }
        function DeliveryLogs_onclick_notificationSet() {
            OpenPopup("ChartResponsesNotificationDeliveryLogInfo_modal", "Notification", "@Url.Action("Frm_ChartResponses_NotificationDeliveryLog_Info", "NotificationSettings",
            new { @area = "Facility" })?Chart_Instance_Id=" + selectedInstanceId_notificationSet, "100%", 1200);
        }


    </script>
