        function validateEmails_notificationSet(emailString) { // Split the string into an array of emails
            var emails = emailString.split(',');
            // Regular expression for validating an email
            var emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
            // Filter out invalid emails
            var validEmails = emails.filter(email => emailRegex.test(email.trim()));
            // Join the valid emails back into a comma-separated string
            return validEmails.join(',');
        }
