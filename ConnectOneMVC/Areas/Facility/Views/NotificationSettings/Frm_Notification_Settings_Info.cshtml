        function FileUploader_valueChanged_WhatsappPaid(e) {
            ShowLoader();
            debugger;
            if (isFileUploaderInitialized) {
                $("#FileDiv_WhatsappPaid_customNotification div div.imgContainer img").remove();
            }
            var files = e.value;
            $("#FormFileName").val(null);
            if (files.length > 1) {
                DevExpress.ui.dialog.alert("You have selected " + files.length + " Files To Upload<br><b>More Than 1 Files Cannot Be Uploaded.<b>", 'Upload Error..');
                var fileUploader = $("#File_WhatsappPaid_customNotification").dxFileUploader("instance");
                fileUploader.reset();
                HideLoader();
                return;
            }
            if (files.length > 0) {
                var totalContent = 0;
                var NotAllowedFilePresent = false;
                var err_msg = "";
                FileType = files[0].type;
                var ErrMsg = PreventFileUpload(files[0])
                if (ErrMsg != null && ErrMsg.length > 0) {
                    NotAllowedFilePresent = true;
                    err_msg = ErrMsg;
                    HideLoader();
                }
                else {
                    totalContent = totalContent + files[0].size
                    const blob = new Blob([files[0]], { type: files[0].type });
                    var path = URL.createObjectURL(blob);
                    if (FileType.includes("pdf")) {
                        $("#FileDiv_WhatsappPaid_customNotification").show();
                        document.getElementById('imgContainer_WhatsappPaid_customNotification').href = path;
                        $('#imgContainer_WhatsappPaid_customNotification img').attr('src', '/Content/events/images/pdficon.jpg');
                        $('#DeleteFile_WhatsappPaid').show();
                    }
                    else if (FileType.includes("image")) {
                        $("#FileDiv_WhatsappPaid_customNotification").show();
                        document.getElementById('imgContainer_WhatsappPaid_customNotification').href = path;
                        $('#imgContainer_WhatsappPaid_customNotification img').attr('src', path);
                        $('#DeleteFile_WhatsappPaid').show();
                    }
                    else if (FileType.includes("vnd.openxmlformats-officedocument.presentationml.presentation") || FileType.includes("ppt") || FileType.includes("pptx") || FileType.includes("vnd.openxmlformats-officedocument.spreadsheetml.sheet") || FileType.includes("vnd.ms-powerpoint") || FileType.includes("plain") || FileType.includes("msword") || FileType.includes("vnd.ms-excel") || FileType.includes("xls") || FileType.includes("xlsx") || FileType.includes("csv") || FileType.includes("rtf") || FileType.includes("doc") || FileType.includes("docx") || FileType.includes("document")) {
                        $("#FileDiv_WhatsappPaid_customNotification").show();
                        document.getElementById('imgContainer_WhatsappPaid_customNotification').href = path;
                        $('#imgContainer_WhatsappPaid_customNotification img').attr('src', '/Content/events/images/docxicon.png');
                        $('#DeleteFile_WhatsappPaid').show();
                    }
                    else if (FileType.includes("video") || FileType.includes("mp4")) {
                        $("#FileDiv_WhatsappPaid_customNotification").show();
                        document.getElementById('imgContainer_WhatsappPaid_customNotification').href = path;
                        $('#imgContainer_WhatsappPaid_customNotification img').attr('src', '/Content/events/images/video.jpg');
                        $('#DeleteFile_WhatsappPaid').show();
                    }
                }
                if (totalContent > 524288000) {
                    DevExpress.ui.dialog.alert("You Have In Total Selected <b>" + formatBytes(totalContent) + "</b> To Upload<br><b>Upto 500 MB Can Be Uploaded At Once<b>", 'Upload Error..');
                    totalContent = 0;
                    $("#File_WhatsappPaid_customNotification").dxFileUploader("instance").reset();
                    //$('#FileDiv_WhatsappPaid_customNotification').show();
                    HideLoader();
                    return;
                }
                if (NotAllowedFilePresent == true) {
                    DevExpress.ui.dialog.alert(err_msg, 'Upload Error..');
                    FileDeleteImageClick_WhatsappPaid(null);
                    $("#File_WhatsappPaid_customNotification").dxFileUploader("instance").reset();
                    //$('#FileDiv_WhatsappPaid_customNotification').show();
                    HideLoader();
                    return;
                }
            }
            HideLoader();
        }
        function FileDeleteImageClick_WhatsappPaid(e) {
            var url = document.getElementById("File_WhatsappPaid_customNotification").src;
            $("#File_WhatsappPaid_customNotification img").remove();
            $("#FileDiv_WhatsappPaid_customNotification div div.imgContainer img").remove();
            //document.getElementById("File_WhatsappPaid_customNotification").src = "";
            //document.getElementById("FileHref_Whatsapp_Notify_ChartResponses").href = "";
            $("#File_WhatsappPaid_customNotification").dxFileUploader("instance").reset();
            URL.revokeObjectURL(url);
            $("#FileDiv_WhatsappPaid_customNotification, #DeleteFile_WhatsappPaid").hide();
        }

