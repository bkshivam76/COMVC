            var htmlValue = $("#" + htmlEditorID).dxHtmlEditor("option", "value")
            var name = $("#FormResponsesRadioOption_notificationSet").dxRadioGroup("instance").option("value")
            if (name == "formresponses") {
                return ReplaceVariableHtmlEditor_notificationSet(htmlValue, VariablesMap_notificationSet)
            } else if (name == "addressbook") {
                return ReplaceVariableHtmlEditor_notificationSet(htmlValue, VariablesMap_addressBook_notificationSet)
            } else if (name == "wingmembers") {
                return ReplaceVariableHtmlEditor_notificationSet(htmlValue, VariablesMap_wingMembers_notificationSet)
            } else if (name == "phonenumbers") {
                return ReplaceVariableHtmlEditor_notificationSet(htmlValue, VariablesMap_givenPhNumbers_notificationSet)
            } else if (name == "googlesheet") {
                return ReplaceVariableHtmlEditor_notificationSet(htmlValue, VariablesMap_givenPhNumbers_notificationSet)
            }
        }
        function ReplaceVariableHtmlEditor_notificationSet(value, variablesMap) {
            if (value == null || value.length == 0) {
                return "";
            }
            const DX_VARIABLE_CLASS = 'dx-variable';
            const DATA_VAR_VALUE_ATTR = 'data-var-value';
            const parser = new DOMParser();
            const doc = parser.parseFromString(value, 'text/html');
            const variables = doc.querySelectorAll(`.${DX_VARIABLE_CLASS}`);

            variables.forEach(variable => {
                const variableValue = variablesMap[variable.getAttribute(DATA_VAR_VALUE_ATTR)];
                variable.outerHTML = variableValue;
            });

            let modifedHtml = doc.body.innerHTML.toString();
            for (var key in variablesMap) {
                var toReplace = "#" + key + "#";
                modifedHtml = modifedHtml.replaceAll(toReplace, variablesMap[key])
            }
            return modifedHtml;
        }
        function getCurrentTimestamp() {
            var date = new Date();
            var day = date.getDate();
            var hours = date.getHours();
            var minutes = date.getMinutes();
            var seconds = date.getSeconds();

            // Pad single-digit numbers with a leading zero
            hours = (hours < 10) ? "0" + hours : hours;
            minutes = (minutes < 10) ? "0" + minutes : minutes;
            seconds = (seconds < 10) ? "0" + seconds : seconds;

            return day + "_" + hours + "_" + minutes + "_" + seconds;
        }
