                        url: '/Facility/NotificationSettings/Frm_ChartResponses_Notification_ImportDataFromGoogleSheet',
                        type: 'GET',
                        data: {
                            url: googleSheetUrl,
                            email: 'bkshivam76@gmail.com'
                        },
                        success: function (response) {
                            if (response.jsonParam.result == true) {
                                ImportDataFromGoogleSheet_NotificationSet = JSON.parse(response.jsonParam.message);
                            }
                            else if (response.jsonParam.message == "Sheet must have 'Mobile' in A1 and 'Message' in B1 as the column heading in Sheet.") {
                                DevExpress.ui.dialog.alert("Invalid Sheet Tab is selected in Google Sheet. " + response.jsonParam.message, response.jsonParam.title)
                            }
                            else {
                                DevExpress.ui.dialog.alert(response.jsonParam.message, response.jsonParam.title)
                            }
                            console.log('GET request successful:', response.jsonParam);
                        },
                        error: function (jqXHR, textStatus, errorThrown) {
                            console.error('GET request failed:', textStatus, errorThrown, jqXHR);
                        }
                    });
                }
                function Selctbox_Opened_notificationSet(e) {
                    setTimeout(function () {
                        e.component.focus();
                    }, Timeout500);
