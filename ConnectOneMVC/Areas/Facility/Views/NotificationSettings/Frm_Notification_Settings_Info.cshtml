                    else if (FileType.includes("video") || FileType.includes("mp4")) {
                        $("#FileDiv_Whatsapp_Notify_ChartResponses").show();
                        document.getElementById('imgContainer_Whatsapp_Notify_ChartResponses').href = path;
                        $('#imgContainer_Whatsapp_Notify_ChartResponses img').attr('src', '/Content/events/images/video.jpg');
                        $('#DeleteFile_Notify_ChartResponses').show();
                    }
                }
                if (totalContent > 524288000) {
                    DevExpress.ui.dialog.alert("You Have In Total Selected <b>" + formatBytes(totalContent) + "</b> To Upload<br><b>Upto 500 MB Can Be Uploaded At Once<b>", 'Upload Error..');
                    totalContent = 0;
                    $("#File_Whatsapp_Notify_ChartResponses").dxFileUploader("instance").reset();
                    //$('#FileDiv_Whatsapp_Notify_ChartResponses').show();
                    HideLoader();
                    return;
                }
                if (NotAllowedFilePresent == true) {
                    DevExpress.ui.dialog.alert(err_msg, 'Upload Error..');
                    FileDeleteImageClick_ChartResponses(null);
                    $("#File_Whatsapp_Notify_ChartResponses").dxFileUploader("instance").reset();
                    //$('#FileDiv_Whatsapp_Notify_ChartResponses').show();
                    HideLoader();
                    return;
                }
            }
            HideLoader();
        }
