            <script>
                var ImportDataFromGoogleSheet_NotificationSet = null;
                function onGoogleSheetUrlChanged(e) {
                    debugger;
                    var url = '';
                    if (e && e.value !== undefined) {
                        url = e.value.trim();
                    } else if (e && e.target && e.target.value !== undefined) {
                        url = e.target.value.trim();
                    } else {
                        // Fallback: get value directly from the textarea
                        var textArea = $('#googleSheet_txtArea_notificationSet');
                        if (textArea.length > 0) {
                            url = textArea.dxTextArea('instance').option('value') || '';
                            url = url.trim();
                        }
                    }
                    var resultDiv = $('#validationResult');
                    resultDiv.removeClass('alert-danger alert-success visible invisible').text(''); // Clear previous results

                    if (url === "") {
                        resultDiv.addClass('alert-danger').removeClass('invisible').addClass('visible').text('Please enter a URL to validate.');
                        return;
                    }

                    // Regular Expression for Google Sheet URLs
                    // This regex captures common Google Sheet URL patterns:
                    // 1. https://docs.google.com/spreadsheets/d/SpreadsheetID/edit
                    // 2. https://docs.google.com/spreadsheets/d/SpreadsheetID/edit?pli=1&gid=0#gid=0
                    // 3. https://docs.google.com/spreadsheets/d/SpreadsheetID/edit#gid=SheetID
                    // 4. https://docs.google.com/spreadsheets/d/SpreadsheetID/view
                    // 5. https://docs.google.com/spreadsheets/d/SpreadsheetID/export?...
                    // 6. https://docs.google.com/spreadsheets/d/SpreadsheetID/
                    // 7. https://drive.google.com/file/d/SpreadsheetID/view
                    // 8. https://drive.google.com/file/d/SpreadsheetID/edit
                    // The SpreadsheetID part should be at least 25 characters (more realistic minimum)
                    var googleSheetRegex = /^https:\/\/(docs|drive)\.google\.com\/(spreadsheets\/d|file\/d)\/([a-zA-Z0-9_-]{25,})\/?(?:edit|view|export)?(?:\?[^#]*)?(?:#.*)?$/;

                    if (googleSheetRegex.test(url)) {
                        resultDiv.addClass('alert-success').removeClass('invisible').addClass('visible').text('URL is a valid Google Sheet format.');
                        $('#validationResultBtn').removeClass('invisible');
                        $('#ImportDataFromGoogleSheet_Notify_ChartResponses').removeClass('invisible');
                    } else {
                        resultDiv.addClass('alert-danger').removeClass('invisible').addClass('visible').text('URL is NOT a valid Google Sheet format. Please check the URL and ensure it starts with "https://docs.google.com/spreadsheets/d/" or "https://drive.google.com/file/d/" and contains a valid ID.');
                    }
                }
                function ImportDataFromGoogleSheet_Notify_ChartResponses_Click(e) {
                    debugger;
                    let googleSheetUrl = $('#googleSheet_txtArea_notificationSet').dxTextArea('instance').option('value');
