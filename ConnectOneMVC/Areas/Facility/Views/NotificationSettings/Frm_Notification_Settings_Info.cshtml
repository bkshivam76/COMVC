        function getHtmlCursorPosition(htmlContent, plainTextCursorPosition) {
            //console.log(htmlContent)
            //console.log("plainTextCursorPosition: "+plainTextCursorPosition)
            var plainTextIndex = 0;
            var htmlIndex = 0;
            while (plainTextIndex < plainTextCursorPosition && htmlIndex < htmlContent.length) {
            if (htmlContent[htmlIndex] === "<") {
            // Skip over HTML tags
            while (htmlContent[htmlIndex] !== ">" && htmlIndex < htmlContent.length) {
            htmlIndex++;
            }
            }
            //else if (htmlContent[htmlIndex] === "&") {
            //    // Skip over HTML entities
            //    while (htmlContent[htmlIndex] !== ";" && htmlIndex < htmlContent.length) {
            //        htmlIndex++;
            //    }
            //}
            else{
            // Increment the plain text index for non-HTML and non-encoded characters
            plainTextIndex++;
            }
            // Increment the HTML index
            htmlIndex++;
            }
            //console.log("htmlIndex: "+htmlIndex);
            return htmlIndex;
        }

