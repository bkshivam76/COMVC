        function countPlainTextCharacters(htmlString) {
            // Create a new DOM parser
            var parser = new DOMParser();
            // Parse the HTML string
            var dom = parser.parseFromString(htmlString, 'text/html');
            // Get the plain text content and remove leading/trailing white space
            var plainText = dom.body.textContent.trim();
            // Return the length of the plain text string
            $('#totalCharCount_notificationSet').text(plainText.length);
            return plainText.length;
        }
