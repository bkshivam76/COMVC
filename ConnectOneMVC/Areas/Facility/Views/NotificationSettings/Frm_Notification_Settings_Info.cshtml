    <div style="padding-top:10px" id="NotificationSetting_ParentDiv">
        <div></div>
        <div class="header_notificationSet">
            <div style="white-space: nowrap;">
                <label>Set Notification to</label>
                <!-- Wrap in a container -->
                @(Html.DevExtreme().RadioGroup().ID("FormResponsesRadioOption_notificationSet").DisplayExpr("text").Layout(DevExtreme.AspNet.Mvc.Orientation.Horizontal)
                    .ValueExpr("value").Value("formresponses")
                .DataSource(new object[] {
                    new { text = "Selected Form Responses", value = "formresponses" },
                    new { text = "Selected Address Book Data", value = "addressbook" },
                    @*new { text = "Wing Members", value = "wingmembers" },*@
                    new { text = "Given Contact Details", value = "phonenumbers" },
                    new { text = "Google Sheet", value = "googlesheet" },
                }).OnValueChanged("FormResponsesRadioOption_notificationSet_OnValueChanged"))
            </div>
            <script>
                function FormResponsesRadioOption_notificationSet_OnValueChanged(e) {
                    document.getElementById("FormResponsesRadioSection_notificationSet").style.display = "none"
                    document.getElementById("AddressBookRadioSection_notificationSet").style.display = "none"
                    document.getElementById("WingMembersRadioSection_notificationSet").style.display = "none"
                    document.getElementById("phoneNumbersRadioSection_notificationSet").style.display = "none"
                    document.getElementById("googleSheetRadioSection_notificationSet").style.display = "none"
                    //document.getElementById("LblContent_Whatsapp_notificationSet").innerText = "Content"
                    //document.getElementById("LblContent_Email_notificationSet").innerText = "Content"
                    var variableMap = {};
                    if (e.value != "formresponses") {
                        $("#ResponseStatus_Notify_ChartResponses").dxRadioGroup("instance").option("value", "All");
                        $("#Content_Whatsapp_Notify_ChartResponses").parent().show();
                    }
                    if (e.value == "formresponses") {
                        document.getElementById("FormResponsesRadioSection_notificationSet").style.display = "block";
                        document.getElementById("sendResponseToRadioSeciton_notificationSet").style.display = "block";
                        $("#Content_Whatsapp_Notify_ChartResponses").parent().show();
                        //var whatsappVarele = document.querySelector('#Content_Whatsapp_Notify_ChartResponses .dx-icon-variable')
                        //whatsappVarele.style.display = 'block';
                        //var emailVarele = document.querySelector('#Content_Email_Notify_ChartResponses .dx-icon-variable')
                        //emailVarele.style.display = 'block'
                        //document.getElementById("LblContent_Whatsapp_notificationSet").innerText = "Content (Choose placeholders from <#> for showing the required information)*";
                        //document.getElementById("LblContent_Email_notificationSet").innerText = "Content (Choose placeholders from <#> for showing the required information)*";
                        variableMap = VariablesMap_notificationSet;
                    }
                    else if (e.value == "addressbook") {
                        document.getElementById("AddressBookRadioSection_notificationSet").style.display = "block"
                        document.getElementById("sendResponseToRadioSeciton_notificationSet").style.display = "none"
                        $("#Content_Whatsapp_Notify_ChartResponses").parent().show();
                        //var whatsappVarele = document.querySelector('#Content_Whatsapp_Notify_ChartResponses .dx-icon-variable')
                        //whatsappVarele.style.display = 'none';
                        //var emailVarele = document.querySelector('#Content_Email_Notify_ChartResponses .dx-icon-variable')
                        //emailVarele.style.display = 'none';
                        variableMap = VariablesMap_addressBook_notificationSet;
                    }
                    else if (e.value == "wingmembers") {
                        document.getElementById("WingMembersRadioSection_notificationSet").style.display = "block"
                        document.getElementById("sendResponseToRadioSeciton_notificationSet").style.display = "none"
                        $("#Content_Whatsapp_Notify_ChartResponses").parent().show();
                        //var whatsappVarele = document.querySelector('#Content_Whatsapp_Notify_ChartResponses .dx-icon-variable')
                        //whatsappVarele.style.display = 'none';
                        //var emailVarele = document.querySelector('#Content_Email_Notify_ChartResponses .dx-icon-variable')
                        //emailVarele.style.display = 'none';
                        variableMap = VariablesMap_wingMembers_notificationSet;
                    }
                    else if (e.value == "phonenumbers") {
                        document.getElementById("phoneNumbersRadioSection_notificationSet").style.display = "block"
                        document.getElementById("sendResponseToRadioSeciton_notificationSet").style.display = "none"
                        $("#Content_Whatsapp_Notify_ChartResponses").parent().show();
                        //var whatsappVarele = document.querySelector('#Content_Whatsapp_Notify_ChartResponses .dx-icon-variable')
                        //whatsappVarele.style.display = 'none';
                        //var emailVarele = document.querySelector('#Content_Email_Notify_ChartResponses .dx-icon-variable')
                        //emailVarele.style.display = 'none';
                        variableMap = VariablesMap_givenPhNumbers_notificationSet;
                    }
                    else if (e.value == "googlesheet") {
                        document.getElementById("googleSheetRadioSection_notificationSet").style.display = "block"
                        document.getElementById("sendResponseToRadioSeciton_notificationSet").style.display = "none"
                        $("#Content_Whatsapp_Notify_ChartResponses").dxHtmlEditor("instance").option("value", null);
                        $("#Content_Whatsapp_Notify_ChartResponses").parent().hide();
                        variableMap = VariablesMap_givenPhNumbers_notificationSet;
                    }
                    updateHtmlEditorVariables(variableMap);
                }
                function updateHtmlEditorVariables(variableMap) {
                    var editorInstance = $("#Content_Whatsapp_Notify_ChartResponses").dxHtmlEditor("instance");
                    editorInstance.option("variables.dataSource", Object.keys(variableMap).sort());
                    var editorInstance = $("#Content_Email_Notify_ChartResponses").dxHtmlEditor("instance");
                    editorInstance.option("variables.dataSource", Object.keys(variableMap).sort());
                    //$("#Content_Email_Notify_ChartResponses").dxHtmlEditor("instance").option("toolbar.items", toolbarItems);
                }
            </script>
        </div>
