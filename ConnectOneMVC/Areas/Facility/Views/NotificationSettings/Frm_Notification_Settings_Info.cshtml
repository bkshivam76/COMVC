                <script>
                    var selectedInstanceId_notificationSet;
                    var selectedForm_notificationSet;
                    async function Form_notificationSet_ValueChange(e, FirstCall = false) {

                        var DG = $("#Form__Notify_ChartResponses_datagrid").dxDataGrid("instance");
                        var value;
                        if (e) {
                            value = e.value;
                            if ((e.value == null || e.value.length == 0) && e.previousValue != null) {
                                DG.clearSelection();
                                selectedInstanceId_notificationSet = null;
                                selectedForm_notificationSet = null;
                                return;
                            }
                        }
                        else {
                            value = $("#Form_Notify_notificationSet").dxDropDownBox("option", "value")
                        }
                        await DG.selectRows(value);
                        var selectedrowsdata = DG.getSelectedRowsData();
                        if (selectedrowsdata.length > 0) {
                            selectedInstanceId_notificationSet = DG.getSelectedRowsData()[0]['INSTANCE_ID']
                            selectedForm_notificationSet = DG.getSelectedRowsData()[0]['CSN_CHART_ID'];
                        }
                        else {
                            selectedInstanceId_notificationSet = null;
                            selectedForm_notificationSet = null;
                        }
                    }
