    function OnlyPlainTextinHtmlEditor_notificationSet(e) {
        e.component.getQuillInstance().clipboard.addMatcher(Node.ELEMENT_NODE, (node, delta) => {
            let ops = []
            delta.ops.forEach(op => {
                if (op.insert && typeof op.insert === 'string') {
                    ops.push({
                        insert: op.insert
                    })
                }
            })
            delta.ops = ops
            return delta
        })
    }
