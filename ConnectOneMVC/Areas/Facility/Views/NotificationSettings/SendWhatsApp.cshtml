    function cleanPhoneNumbers(phoneNumbers) {
        // Split the input string into an array of phone numbers
        let phoneArray = phoneNumbers.split(',');

        // Function to clean individual phone numbers
        function cleanNumber(number) {
            // Trim spaces at the beginning and end
            number = number.trim();

            // Remove all non-digit characters
            let cleaned = number.replace(/\D/g, '');

            // Remove country code if present
            if (cleaned.startsWith('91') && cleaned.length > 10) {
                cleaned = cleaned.substring(2);
            } else if (cleaned.startsWith('0') && cleaned.length > 10) {
                cleaned = cleaned.substring(1);
            }

            // Return the cleaned number if it's 10 digits long
            return cleaned.length === 10 ? cleaned : null;
        }

        // Clean all phone numbers and filter out invalid ones
        let cleanedNumbers = phoneArray.map(cleanNumber).filter(Boolean);

        // Join the cleaned numbers back into a comma-separated string
        return cleanedNumbers.join(',');
    }
    function batchUniqueName(id, Whtsapp_Email) //This section is to set the batch unique Name
    {
        var batchName = $("#" + id).dxTextBox("instance").option("value");
        var resp_status = "";
        var time_stamp = getCurrentTimestamp();
        var uniquBatchName = batchName + "_" + Whtsapp_Email + "_" + 0 + "_" + resp_status + time_stamp;
        return uniquBatchName;
    }
    function getCurrentTimestamp() {
        var date = new Date();
        var day = date.getDate();
        var hours = date.getHours();
        var minutes = date.getMinutes();
        var seconds = date.getSeconds();

        // Pad single-digit numbers with a leading zero
        hours = (hours < 10) ? "0" + hours : hours;
        minutes = (minutes < 10) ? "0" + minutes : minutes;
        seconds = (seconds < 10) ? "0" + seconds : seconds;

        return day + "_" + hours + "_" + minutes + "_" + seconds;
    }
    function Validations_SendWhstapp(e) {        
        var MobileNumbers = $("#phoneNumbers_txtArea_notificationSet").dxTextArea("option", "value");
        var AdminNo = $("#AdminWhatsappNo_Notify_ChartResponses").dxTextBox("option", "value");
        var Message = $("#Content_Whatsapp_Notify_ChartResponses").dxHtmlEditor("option", "value");
        var SenderNo = $("#SenderWhatsapp_Notify_ChartResponses").dxTextBox("option", "value");
        if (MobileNumbers == null || MobileNumbers.length == 0) {
            DevExpress.ui.dialog.alert("Mobile Numbers Are Required", "Information").done(function () {
                $("#phoneNumbers_txtArea_notificationSet").dxTextArea("focus")
            })
            return true
        }
        var Numbers = MobileNumbers.replace(/,\n/g, ',').replace(/\n,/g, ',')
            .replace(/\n/g, ',') // Replace newlines with commas
            .replace(/,\s*$/, '') // Remove any trailing comma and spaces
            .trim().split(",") // Trim leading and trailing whitespace MobileNumbers and split by comma
        for (var i = 0; i < Numbers.length; i++)
        {
            if (Numbers[i].trim().length > 0) {
                if (Numbers[i].length != 10) {
                    DevExpress.ui.dialog.alert("Mobile Numbers Must Be Of 10 Digits (" + Numbers[i] + ")", "Information").done(function () {
                        $("#phoneNumbers_txtArea_notificationSet").dxTextArea("focus")
                    })
                    return true
                }
            }
        }
        if (SenderNo == null || SenderNo.length == 0) {
            DevExpress.ui.dialog.alert("Sender Mobile Number Is Required", "Information").done(function () {
                $("#SenderWhatsapp_Notify_ChartResponses").dxTextBox("focus")
            })
            return true
        }
        if (SenderNo.length != 10) {
            DevExpress.ui.dialog.alert("Sender Mobile Number Is Incorrect", "Information").done(function () {
                $("#SenderWhatsapp_Notify_ChartResponses").dxTextBox("focus")
            })
            return true
        }
        if (AdminNo == null || AdminNo.length == 0) {
