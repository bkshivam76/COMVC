<script type="text/javascript">
    function OnShowClick() {
        debugger;
        var _PAN = $("#PAN_TextBox").dxTextBox("instance").option("value");
        if (_PAN == null || _PAN.length == 0) {
            DevExpress.ui.dialog.alert("Please Enter PAN!!", "Information");
            return;
        }
        var _dedDate = $("#Txt_Date_Deduction").dxDateBox("instance").option("value");

        var _dedDate_DT = moment(_dedDate).format(DateFormatCurrent.toUpperCase());

        if (_dedDate == null || _dedDate.length == 0) {
            DevExpress.ui.dialog.alert("Please Enter Date of TDS Deduction!!", "Information");
            return;
        }
        if ($("#Txt_Date_Deduction").dxDateBox("instance").option("isValid")) {
            var timestamp = Date.parse(_dedDate);
            if (isNaN(timestamp) == true) {
                DevExpress.ui.dialog.alert("Please Enter Valid Date of TDS Deduction!!", "Information");
                return;
            }
        }
        else {
            DevExpress.ui.dialog.alert("Please Enter Valid Date of TDS Deduction!!", "Information");
            return;
        }
        
        ShowLoader();
        $.ajax({
            type: 'GET',
            cache: false,
            url: "/Facility/PANData/ExcelData",
            data: {
                PAN: _PAN,
                DeductionDate: _dedDate_DT
            },
            success: function (data) {
                HideLoader();
                if (data.result == true) {
                    document.getElementById('PAN_Name').innerHTML = data.Name;
                    document.getElementById('PAN_Date').innerHTML = data.Date;
                    document.getElementById('PAN_Link').innerHTML = data.Link;
                    document.getElementById('lbl_Terms').innerHTML = data.Terms;
                    document.getElementById('PAN_Status').innerHTML = data.PAN_Status;
                    if (moment(_dedDate, DateFormatCurrent.toUpperCase()) < moment("2025-04-01", "YYYY-MM-DD")) {
                        document.getElementById('PAN_Specified').innerHTML = data.Specified;
                        document.getElementById('lbl_PAN_Specified').innerHTML = "Specified Person u / s 206AB & 206CCA: <br>Before " + data.SpecifiedEffectiveFrom + " - No<br>From " + data.SpecifiedEffectiveFrom + " - As per department Data";
                    }
                    document.getElementById('lbl_PAN_Link').innerHTML = "PAN - Aadhar Link Status:<br>Before " + data.LinkingEffectiveFrom + " - Not Applicable <br>From " + data.LinkingEffectiveFrom + " - As per department Data";
                    document.getElementById('lbl_Rate_Contractor_Value').innerHTML = data.Rate_Contractor;
                    document.getElementById('lbl_Rate_Transporter_upto_10_Value').innerHTML = data.Rate_Transporter_upto_10;
                    document.getElementById('lbl_Rate_Transporter_greater_10_Value').innerHTML = data.Rate_Transporter_greater_10;
                    document.getElementById('lbl_Rate_Rent_Value').innerHTML = data.Rate_Rent;
                    document.getElementById('lbl_Rate_Rent_Machinery_Value').innerHTML = data.Rate_Rent_Machinery;
                    document.getElementById('lbl_Rate_Property_Purchase_Value').innerHTML = data.Rate_Property_Purchase;
                    document.getElementById('lbl_Rate_Professional_Fees_Value').innerHTML = data.Rate_Professional_Fees;
                    document.getElementById('lbl_Rate_Technical_Fees_Value').innerHTML = data.Rate_Technical_Fees;
                    document.getElementById('lbl_Rate_Interest_Value').innerHTML = data.Rate_Interest;
                    document.getElementById('lbl_Rate_Commission_Value').innerHTML = data.Rate_Commission;

                    document.getElementById('lbl_PAN_Name').innerHTML = "Name:";
                    document.getElementById('lbl_PAN_Date').innerHTML = "PAN Allottment Date:";
                    document.getElementById('lbl_PAN_Status').innerHTML = "Status (Based on 4th Letter):";

                    document.getElementById('lbl_Rates_header').innerHTML = '<b>TDS Rates</b>';
                    //$("#lbl_Rates_header").val("<u><b>TDS Rates</b></u>";
                    document.getElementById('lbl_Rate_Contractor').innerHTML = data.paymentType_Contractor + ":";
                    document.getElementById('lbl_Rate_Transporter_upto_10').innerHTML = data.paymentType_Transporter_upto_10_Value + ":";
                    document.getElementById('lbl_Rate_Transporter_greater_10').innerHTML = data.paymentType_Transporter_greater_10_Value + ":";
                    document.getElementById('lbl_Rate_Rent').innerHTML = data.paymentType_Rent_Value + ":";
                    document.getElementById('lbl_Rate_Rent_Machinery').innerHTML = data.paymentType_Rent_Machinery_Value + ":";
                    document.getElementById('lbl_Rate_Property_Purchase').innerHTML = data.paymentType_Property_Purchase_Value + ":";
                    document.getElementById('lbl_Rate_Professional_Fees').innerHTML = data.paymentType_Professional_Fees_Value + ":";
                    document.getElementById('lbl_Rate_Technical_Fees').innerHTML = data.paymentType_Technical_Fees_Value + ":";
                    document.getElementById('lbl_Rate_Interest').innerHTML = data.paymentType_Interest_Value + ":";
                    document.getElementById('lbl_Rate_Commission').innerHTML = data.paymentType_Commission_Value + ":";

                    document.getElementById('lbl_Rate_Contractor_Amount').innerHTML = data.paymentAmount_Contractor ;
                    document.getElementById('lbl_Rate_Transporter_upto_10_Amount').innerHTML = data.paymentAmount_Transporter_upto_10_Value;
                    document.getElementById('lbl_Rate_Transporter_greater_10_Amount').innerHTML = data.paymentAmount_Transporter_greater_10_Value;
                    document.getElementById('lbl_Rate_Rent_Amount').innerHTML = data.paymentAmount_Rent_Value;
                    document.getElementById('lbl_Rate_Rent_Machinery_Amount').innerHTML = data.paymentAmount_Rent_Machinery_Value;
                    document.getElementById('lbl_Rate_Property_Purchase_Amount').innerHTML = data.paymentAmount_Property_Purchase_Value;
                    document.getElementById('lbl_Rate_Professional_Fees_Amount').innerHTML = data.paymentAmount_Professional_Fees_Value;
                    document.getElementById('lbl_Rate_Technical_Fees_Amount').innerHTML = data.paymentAmount_Technical_Fees_Value;
                    document.getElementById('lbl_Rate_Interest_Amount').innerHTML = data.paymentAmount_Interest_Value;
                    document.getElementById('lbl_Rate_Commission_Amount').innerHTML = data.paymentAmount_Commission_Value;

                    var divDetails = document.getElementById("divDetails");
                    divDetails.style.display = "block";

                    var divRates = document.getElementById("divRates");
                    divRates.style.display = "block";

                    var divTerms = document.getElementById("divTerms");
                    divTerms.style.display = "none";

                    var div_Rate_Interest = document.getElementById("div_Rate_Interest");
                    div_Rate_Interest.style.display = "none";

                    var divPAN_Specified = document.getElementById("div_PAN_Specified");

                    if (data.isSpecifiedPersonClauseApplicable == "Yes") {                        
                        divPAN_Specified.style.display = "block";
                    }
                    else {
                        divPAN_Specified.style.display = "none";
                    }

                    if (data.Link == "INOPERATIVE") {
                        DevExpress.ui.dialog.alert("PAN of the party is not linked with aadhar. Hence shown as inoperative. Ask the party to get the PAN linked with aadhar or else 20% TDS will be applicable as PAN is invalid. <br> <br> पार्टी का PAN Aadhar से लिंक नहीं है, इसीलिए Inoperative दिखाया गया है। पार्टी को PAN Aadhar से लिंक करने लिए बोलें अन्यथा 20% TDS कटेगा क्यूंकि PAN Invalid है।", "Information");
                    }
                }
                else if (data.result == false) {
                    DevExpress.ui.dialog.alert(data.message, "Error");
                    document.getElementById('PAN_Name').innerHTML = "";
                    document.getElementById('PAN_Date').innerHTML = "";
                    document.getElementById('PAN_Link').innerHTML = "";
                    document.getElementById('PAN_Specified').innerHTML = "";
                    document.getElementById('lbl_Terms').innerHTML = "";
                    document.getElementById('PAN_Status').innerHTML = "";
                    document.getElementById('lbl_PAN_Specified').innerHTML = "";
                    document.getElementById('lbl_PAN_Link').innerHTML = "PAN - Aadhar Link Status:";
                    document.getElementById('lbl_Rate_Contractor_Value').innerHTML = "";
