@using DevExtreme.AspNet.Mvc;
@{
    var MaxDate = (DateTime)ViewBag.MaxDate;
}
<style>
        .wdfull {
            width: 100%;
        }

        td {
            width: auto;
        }

        .dntnbtn {
            min-width: 68px !important;
            font-size: 12px;
        }

        .fonttwelve {
            font-size: 12px !important;
        }

        .clear {
            clear: both;
        }

        .bortabl {
            border: 1px solid #64CAF1;
            border-collapse: collapse;
            padding-left: 5px;
        }

            .bortabl td {
                border: 1px solid #64CAF1;
                border-collapse: collapse;
            }

        .tabtbl {
            width: 100%;
            margin: 0;
            padding: 0;
        }

            .tabtbl table {
                width: 100%;
            }

            .tabtbl th {
                background: #BDD5ED;
                color: #000;
                font-size: 12px;
                border: 1px solid #000;
                border-collapse: collapse;
                padding-left: 10px;
            }

            .tabtbl td {
                background: #fff;
                color: #000;
                font-size: 12px;
                border: 1px solid #64CAF1;
                border-collapse: collapse;
                padding-left: 10px;
            }

    #PAN_ParentDiv .dx-fileuploader-input-wrapper {
        padding: 7px 0 7px;
        margin-top: -19px;
        margin-left: -3px;
        border: 3px dashed transparent;
    }

        #fileName {
            padding: 0px !important;
        }

        #PAN_ParentDiv .dx-fileuploader-input-label {
            visibility: hidden;
        }

        #PAN_ParentDiv .dx-texteditor-container {
            overflow: visible
        }

        #help_file-uploader {
            margin: -16px;
            margin-top: -1px;
        }

        #Frm_Help_Documents_Popup {
            padding-right: 0px !important;
            padding-left: 0px !important;
        }

    #PAN_ParentDiv .form-field {
        margin: 0px 0px;
        padding: 5px 4px 4px 4px;
        background: #dfebf8;
        background: -webkit-linear-gradient(to bottom, #ffffff 0%, #dfebf8 100%);
        background: -o-linear-gradient(to bottom, #ffffff 0%, #dfebf8 100%);
        background: -moz-linear-gradient(to bottom, #ffffff 0%, #dfebf8 100%);
        background: linear-gradient(to bottom, #ffffff 0%, #dfebf8 100%);
        outline-style: solid;
        outline-width: 1px;
        outline-color: #89b9eb;
    }

        #helpDocument_Save {
            margin-right: 5px;
        }
    #PAN_TextBox, #Txt_Date_Deduction {
        height: 34px;
        font-size: 18px;
        border-radius: 6px;
        max-width: 200px;
        display: inline-block;
    }

        #PAN_TextBox:focus, #Txt_Date_Deduction:focus{background:transparent}
        #Txt_Date_Deduction .dx-placeholder {
            font-size: 16px
        }
        #PAN_TextBox .dx-texteditor-buttons-container {
            position: absolute;
            right: 10px;
            top: 17px;
        }
        #Txt_Date_Deduction .dx-texteditor-buttons-container {
            position: absolute;
            right: 5px;
            top: 15px;
        }

    #contentPANData .dx-datebox-calendar .dx-dropdowneditor-icon:before {
        width: 30px;
        margin-left: -12px;
        background: #fff;
        top: 0;
        padding-top: 2px
    }

        #PAN_TextBox .report_header_div_main {
            padding: 8px 0 5px;
        }
        #PAN_BUT_Show {
            position: relative;
            top: -2px;
            font-size: 16px;
            height: 35px;
            width:70px;
        }

            #PAN_BUT_Show .dx-button-has-text .dx-button-content {
                padding: 6px 8px;
            }
            
    .pan_lbl {
        color: black;
        font-weight: bold;
        font-size: 18px;
    }
    .dx-dropdowneditor.dx-dropdowneditor-active .dx-dropdowneditor-icon, .dx-dropdowneditor.dx-state-hover:not(.dx-custom-button-hovered) .dx-dropdowneditor-icon {
        background: transparent;
    }
    #contentPANData, #PAN_ParentDiv .report_header_div_main {
        overflow: visible
    }
    #contentPANData aside {
        display: inline-block;
        margin-bottom: 6px
    }
    #PAN_ParentDiv .report_header_div_main{border:none !important;}

    .pan-details {
        font-size: 14px;
        margin:100px auto 0;
    }
        .pan-details .form-field{padding-right:0; padding-left:0}
        .pan-details .form-field:hover {
            background: #dfebf8;
        }
    #divDetails {
        display: none;
    }
    #divRates {
        display: none;
    }
    #divTerms{padding-top:20px;}
    .blue-heading {
        background: #1d499a !important;
        border: 1px solid #1d499a;
        color: #fff;
        outline: none;
        margin-left: -0.05em;
        width: calc(100% + 1px);
        font-size: 16px;
    }

    @@media (max-width: 767px) {
        #PAN_TextBox, #Txt_Date_Deduction {max-width:180px}
        #PAN_BUT_Show{width:100%;}
        .pan_lbl {
            font-size: 13px;
            width: 95%;
            margin-bottom: 4px;
        }
        #PAN_TextBox, #Txt_Date_Deduction {
            max-width: 92%;
        }
        #PAN_BUT_Show .dx-button-text {
            font-size: 16px !important
        }
        .pan-details{margin-top:0}
        #divDetails, #divRates, #divTerms{padding:1px; margin-top:10px;}
    }
</style>
