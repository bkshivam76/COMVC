<style>
    @@import url('https://fonts.googleapis.com/css2?family=Open+Sans:wght@500;600&display=swap');
    body {
        font-family: 'Open Sans', sans-serif; color:#414346; font-size:12px; font-weight:500;
    }
    p{margin:0;}
    .bdrB{border-bottom:1px solid #eee;}
    .bdrT{border-top:1px solid #eee;}
    .litClr{color:#8f9197}
    .bluClr{color:#8495bc}
    table{width:100%;}
    table td{padding:2px 5px}
    @*.dxgvDataRow_Aqua{background:#fff !important; color:#414346 !important}*@
    .pdT{padding-top:5px;}.pdB{padding-bottom:5px}
    .tophd{background:#414346; color:#fff; border-radius:10px; padding:5px 9px 3px; font-size:14px; width:max-content;}
    h5{font-weight:bold}
    * {
        box-sizing: border-box;
        /* outline:1px solid ;*/
    }

    body {
        background: #ffffff;
        background: linear-gradient(to bottom, #ffffff 0%,#e1e8ed 100%);
        /*filter: progid:DXImageTransform.Microsoft.gradient( startColorstr='#ffffff', endColorstr='#e1e8ed',GradientType=0 );*/
        height: 100%;
        margin: 0;
        background-repeat: no-repeat;
        background-attachment: fixed;
        font-size: 16px;
    }

    .wrapper-1 {
        width: 100%;
        height: 100vh;
        display: flex;
        flex-direction: column;
    }

    .wrapper-2 {
        max-width: 700px;
        text-align: center;
        border: ridge 2px grey;
        box-shadow: 7px 10px 1px rgba(0,0,0,.1);
        border-radius: 10px;
        margin: 0 auto;
        background: #fff;
        margin-top: 40px;
        padding-bottom: 15px
    }

        .wrapper-2 p {
            margin: 0 15px 15px;
            font-size: 1.2em;
            font-family: 'Source Sans Pro', sans-serif;
        }

        .wrapper-2 img {
            max-width: 100%;
            border-radius: 7px 7px 0 0
        }

            .wrapper-2 img.thankyou {
                max-width: 100%;
                max-width: 400px;
            }

    .btn-txt {
        color: #fff;
        background: #703b99;
        border: none;
        padding: 10px 30px;
        margin: 10px 5px;
        border-radius: 20px;
        text-transform: capitalize;
        box-shadow: 0 6px 10px 1px rgb(112 59 153 / 40%);
        cursor: pointer;
        transition: .5s all;
        font-family: 'Source Sans Pro', sans-serif;
    }

        .btn-txt:hover {
            box-shadow: 0 10px 16px 4px rgb(112 59 153 / 40%);
        }

    .wrapper-2 small {
        font-size: 12px
    }

    .wrapper-2 b {
        margin-top: 10px;
        display: inline-block;
    }
    /*Responsive CSS for Mobile*/
    @@media only screen and (max-device-width:767px) {
        .wrapper-2 {
            margin-top: 0
        }

        .wrapper-1 {
            padding: 10px
        }

        .wrapper-2 img.thankyou {
            max-width: 270px
        }
    }

    .ev-datetime span {
        white-space: nowrap;
    }

    @@media print {
        #section--not-to-print * {
            visibility: hidden;
        }
}
</style>
</head>
@{
    //Layout = "~/Views/Shared/_NoLoginDevExtremeLayout.cshtml";
    var chartInstanceID = ViewBag.ChartInstanceID;
    var cenID = ViewBag.CenID;
}
<body>
    <script src="~/Scripts/jquery-3.4.1.min.js"></script>
    <script src="~/Scripts/bootstrap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.8.0/html2pdf.bundle.min.js" integrity="sha512-w3u9q/DeneCSwUDjhiMNibTRh/1i/gScBVp2imNVAMCt6cUHIw6xzhzcPFIaL3Q1EbI2l+nu17q2aLJJLo4ZYg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/1.3.4/jspdf.min.js"></script>
    <script>

        var Chart_Response_ID = "";
        var Chart_Response_Status = "";
        var Chart_Response_Remarks = "";
        var Chart_Instance_ID = "@chartInstanceID";
        var Cen_ID = "@cenID";
        @*var ServicePath = "@ServicePath";
        var Chart_Approval_Required = "@chartApprovalRequired" == "False" ? false: true;*@
        var UserID = "";
        var UserABID = "xxx";
        function OnChartResponse_SummaryInfoListPreviewClick()
        {
            ShowLoader();
            OpenPopup("ChartResponse_SummaryInfo_modal", "Export Option", "@Url.Action("Frm_Export_Options_Summary", "Chart", new { @area = "Facility" })", "auto",130);
        }
        function closeChartResponse_SummaryInfo()
        {
            $("#Dynamic_Content_popup").dxPopup("hide")
        }
        function ChartEventConfirmationInfoOnInit(s, e) {
            s.ExpandAll();
            ChartResponse_SummaryInfoAdjustSize();
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                ChartResponse_SummaryInfoAdjustSize();
            });
        }
        function ChartResponse_SummaryInfoAdjustSize() {
            var height = (document.documentElement.clientHeight * 90) / 100;
            try {
                EventConfirmationInfoGrid.SetHeight(height);
            }
            catch (err) {
            }
        }

        function OnEventConfirmationInfoGridFocusedRowChanged(s, e) {

        }

        function ChartResponse_SummaryInfo_GetRowData(RowIndex = null) {

            var focusedrow = RowIndex == null ? EventConfirmationInfoGrid.GetFocusedRowIndex() : RowIndex;
            var topindex = EventConfirmationInfoGrid.GetTopVisibleIndex();
            var Index = focusedrow - topindex;
            var ChartResponse_SummaryInfoPageData = EventConfirmationInfoGrid.cpPagedata;
            if (ChartResponse_SummaryInfoPageData != null && ChartResponse_SummaryInfoPageData.length > 0 && Index < ChartResponse_SummaryInfoPageData.length) {
                Chart_Response_ID = ChartResponse_SummaryInfoPageData[Index][0];
                Chart_Response_Status = ChartResponse_SummaryInfoPageData[Index][1];
                Chart_Response_Remarks = ChartResponse_SummaryInfoPageData[Index][2];
                UserID = ChartResponse_SummaryInfoPageData[Index][3];
                UserABID = ChartResponse_SummaryInfoPageData[Index][4];
            }
            else {
                Chart_Response_ID = null;
                Chart_Response_Status = "";
                Chart_Response_Remarks = "";
            }
        }

        function EventConfirmationInfoGrid_BeginCallback(s, e) {

            e.customArgs["command"] = e.command;
            e.customArgs["Chart_Instance_ID"] = Chart_Instance_ID;
            e.customArgs["cenid"] = Cen_ID;
            //e.customArgs["summary_type"] = summary_type;
        }

        var OpenLnikedResponseForm =false;
        function GetConfirmbox(YesMsg, NoMsg) {
            var _confirmbox = DevExpress.ui.dialog.custom({
                title: "Post Form Response...",
                messageHtml: "Do you want to Post Form Repsonse by Self or Share Posting Link with Others ?",
                buttons: [
                    {
                        text: YesMsg,
                        elementAttr:
                        {
                            id: "CustomConfirmDialog_YesButton"
                        },
                        onClick: function () {
                            return true
                        }
                    },
                    {
                        text: NoMsg,
                        elementAttr:
                        {
                            id: "CustomConfirmDialog_NoButton"
                        },
                        onClick: function () {
                            return false
                        }
                    }
                ],
                popupOptions:
                {
                    elementAttr:
                    {
                        id: "CustomConfirmDialog_Popup"
                    },
                    onShown: function (e) {
                        $(".dx-dialog-button:first").focus();
                    },
                    onHidden: function (e) {
                        e.component.dispose();
                        $("#CustomConfirmDialog_Popup").remove();
                    }
                }
            });
            return _confirmbox;
        }

        function ClosePopupPreview_SM() {
            $("#ChartResponse_Preview").dxPopup("hide");
        }
        function printRegistrationSlip() {
            window.print();
        }
        function downloadRegistrationSlip() {
            var pdf_content = document.getElementById("ticketMdl");
            var options = {
                margin: 1,
                filename: 'Event_Confirmation_Ticket.pdf',
                //image: { type: 'png', quality: 0.98 },
                html2canvas: { scale: 2 },
                jsPDF: { unit: 'in', format: 'letter', orientation: 'landscape' }
            };
            html2pdf($("#ticketMdl").html(), options);
        }
    </script>
    <div id="ticketMdl" class="container-fluid" style="width:90%">
        <div class="row">
            <center>
                <h5 class="tophd">CONFIRMATION INFORMATION</h5>
                @*<h5>Reg. No.:-@ViewBag.RegistrationNo</h5>*@
            </center>
            <div class="col-md-8">
                <div class="row bdrB bdrT pdT pdB">
                    <div class="col-md-3">
                        <label>Programme :</label>
                    </div>
                    <div class="col-md-9">
                        <p>@ViewBag.EventName</p>
                        <small>@ViewBag.Period</small>
                    </div>
                </div>
                <div class="row bdrB pdT pdB">
                    <div class="col-md-3">
                        <label>Centre :</label>
                    </div>
                    <div class="col-md-9">
                        <p>@ViewBag.CentreName</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <table class="table-bordered">
                    <tr>
                        <th></th>
                        <th>NBK</th>
                        <th>Sur.</th>
                        <th>Total</th>
                    </tr>
                    <tr>
                        <td>Brother</td>
                        <td>@ViewBag.NBK_Brother</td>
                        <td>@ViewBag.Sur_Brother</td>
                        <td>@ViewBag.Total_Brother</td>
                    </tr>
                    <tr>
                        <td>Sister</td>
                        <td>@ViewBag.NBK_Sister</td>
                        <td>@ViewBag.Sur_Sister</td>
                        <td>@ViewBag.Total_Sister</td>
                    </tr>
                    <tr>
                        <td>Total</td>
                        <td>@ViewBag.NBK_Total</td>
                        <td>@ViewBag.Sur_Total</td>
                        <td>@ViewBag.Total_Total</td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="col-md-12 no-padding" id="TravelSummary_gridDiv">
            <center><h5>List of Participants</h5></center>
            <form>
                <div class="parent_table">
                    @Html.Partial("centerWiseEventConfirmationInformation_Grid")
                </div>
            </form>
        </div>

    </div>
    <div style="text-align:center;padding-top:20px;padding-right:20px" id="section--not-to-print">
        <div class=content id="p">
            <div>
                <div>
                    <button onclick="printRegistrationSlip()" class="btn-txt">Print Report</button>
                    <button onclick="downloadRegistrationSlip()" class="btn-txt">Download Report</button>
                </div>
            </div>
        </div>
    </div>


</body>
</html>