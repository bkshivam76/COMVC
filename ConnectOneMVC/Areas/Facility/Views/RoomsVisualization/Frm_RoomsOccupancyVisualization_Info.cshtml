    <script>
        
        async function Building_RoomsViz_ValueChange(e, FirstCall = false) {
            var value;
            var DG = $("#Building_RoomsViz_datagrid").dxDataGrid("instance");
            if (e) {
                value = e.value;
                if ((e.value == null || e.value.length == 0) && e.previousValue != null) {
                    DG.clearSelection();
                    //checkSwithAndCall(AllRoomsdata)
                    FilterData()
                    return;
                }
            }
            else {
                var bldgid = "";
                var buildingid_array = $("#Building_RoomsViz").dxDropDownBox("option", "value");
                if (buildingid_array != null) { bldgid = buildingid_array[0]; }
                value = bldgid;
            }
            await DG.selectRows(value);
            if (DG.getSelectedRowsData().length > 0) {

                var Bldng_Recid = DG.getSelectedRowsData()[0];
                FilterByBuilding(Bldng_Recid.REC_ID)
            }
        }

        function PrevBuilding_RoomViz() {            
            var max;
            let curr_index; var prev_index;
            var DG = $("#Building_RoomsViz_datagrid").dxDataGrid("instance")
            var ds = DG.getDataSource()
            if ($("#Building_RoomsViz").dxDropDownBox("option", "value") == null || $("#Building_RoomsViz").dxDropDownBox("option", "value").length ==0) {
                prev_index = 0;
            } else {
                
                max = ds._items.length
                for (let i = 0; i < max; i++) {
                    if (ds._items[i].REC_ID === $("#Building_RoomsViz").dxDropDownBox("option", "value")[0]) {
                        curr_index = i; // Arrays are zero-indexed, so add 1 to get the serial number
                    }
                }

                if (curr_index == 0) { prev_index = max - 1; }
                else { prev_index = curr_index - 1 }
            }
                    
            $("#Building_RoomsViz").dxDropDownBox("instance").option("value", ds._items[prev_index]["REC_ID"]);
        }
        function NextBuilding_RoomViz() {            
            var max;
            let curr_index; var next_index;
            var DG = $("#Building_RoomsViz_datagrid").dxDataGrid("instance")
            var ds = DG.getDataSource()
            if ($("#Building_RoomsViz").dxDropDownBox("option", "value") == null || $("#Building_RoomsViz").dxDropDownBox("option", "value").length == 0) {
                next_index = 0;
            } else {
                
                max = ds._items.length
                for (let i = 0; i < max; i++) {
                    if (ds._items[i].REC_ID === $("#Building_RoomsViz").dxDropDownBox("option", "value")[0]) {
                        curr_index = i; // Arrays are zero-indexed, so add 1 to get the serial number
                    }
                }

                if (curr_index == max - 1) { next_index = 0; }
                else { next_index = curr_index + 1 }
            }
                    
            $("#Building_RoomsViz").dxDropDownBox("instance").option("value", ds._items[next_index]["REC_ID"]);
        }

