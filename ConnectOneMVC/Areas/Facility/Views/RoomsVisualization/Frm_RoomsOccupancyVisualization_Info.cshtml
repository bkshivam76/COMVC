                    )
        </div>
        <div style="padding-bottom:3px;">
            <label>To Date</label>
            @(Html.DevExtreme().DateBox().CustomDateBox().ID("todate_RoomViz").Name("todate_RoomViz").ShowClearButton(true).Value(DateTime.Today.AddDays(1))
                        .Type(DateBoxType.Date).Placeholder("To Date").Min(new DateTime(1990, 01, 01)).Max(new DateTime(2038, 12, 31)).OnValueChanged("toDate_RoomsViz_ValueChange")
                        .Placeholder("To Date (dd-mm-yyyy)").Height(35)
