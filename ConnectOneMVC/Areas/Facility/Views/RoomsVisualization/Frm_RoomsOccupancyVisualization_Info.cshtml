        function FilterData() {            
            let bldng_recid = ($("#Building_RoomsViz").dxDropDownBox("option", "value") == null && $("#Building_RoomsViz").dxDropDownBox("option", "value") == undefined) ? null : $("#Building_RoomsViz").dxDropDownBox("option", "value")[0]
            let roomName = $("#RoomNumber_RoomViz").dxTextBox("option", "value");
            let roomCapacity = $("#RoomCapacity_RoomViz").dxTextBox("option", "value");
            let phNum = $("#PhSearch_RoomViz").dxTextBox("option", "value");
            let name = $("#NameSearch_RoomViz").dxTextBox("option", "value");

            let filteredData = AllRoomsdata.filter(function (d) {
                return (bldng_recid === undefined || bldng_recid === null || bldng_recid === "" || d.SP_REC_ID === bldng_recid) &&
                    (roomName === undefined || roomName === null || roomName === "" || d.AL_LOC_NAME.includes(roomName.toUpperCase())) &&
                    (roomCapacity === undefined || roomCapacity === null || roomCapacity === "" || d.AL_MAXCAPACITY == parseInt(roomCapacity));
            });

            if (phNum !== undefined && phNum !== null && phNum !== "" ||
                name !== undefined && name !== null && name !== "") {
                let RoomsFilleddataFiltered = RoomsFilleddata.filter(item =>
                    (phNum === undefined || phNum === null || phNum === "" || item.C_MOB_NO_1.includes(phNum)) &&
                    (name === undefined || name === null || name === "" || item.C_NAME.toLowerCase().includes(name.toLowerCase()))
                );
                let filteredroomsarray = RoomsFilleddataFiltered.map(item => item.ROOM_RECID);
                filteredData = filteredData.filter(function (d) {
                    return filteredroomsarray.includes(d.ALI_REC_ID);
                });
            }

            checkSwithAndCall(filteredData);
        }



