        function RoomDivisionCircles(d, i, n) {
            
            // Get the bounding box of the first element in the 'n' array
            //let bbox = n[i].getBBox();

            //// Extract the height, width, and x, y coordinates from the bounding box
            //let rectHeight = bbox.height;
            //let rectWidth = bbox.width;
            //let rectX = bbox.x;
            //let rectY = bbox.y;

            let h = d.height / d.AL_MAXCAPACITY;
            var filteredPersons = RoomsFilleddata.filter(function (k) {
                return k.ROOM_RECID === d.ALI_REC_ID;
            });
            var totalfilled = RoomsFilleddata.filter(f => f.ROOM_RECID === d.ALI_REC_ID).reduce((a, b) => a + b.FILLEDBEDS, 0);
            let j = 0;
            for (let i = 0; i < d.AL_MAXCAPACITY; i++) {
                d.Roomfill = totalfilled;
                let fill; // Initialize fill color
                let ph, gender, name, formname, arr, dep, regNo, city;

                // Check if the current index is less than the number of filled beds
                if (i < d.Roomfill) {
                    if (j >= filteredPersons.length) { j = 0 }
                    ph = filteredPersons[j].C_MOB_NO_1
                    gender = filteredPersons[j].C_GENDER
                    if (gender == "MALE") { fill = "deepskyblue" }
                    else if (gender == "FEMALE") { fill = "pink" }
                    name = filteredPersons[j].C_NAME
                    formname = filteredPersons[j].CI_CHARTNAME
                    arr = filteredPersons[j].ACCOM_FROM
                    dep = filteredPersons[j].ACCOM_TO
                    regNo = filteredPersons[j].REG_NO
                    city = filteredPersons[j].CI_NAME
                    j = j + 1;
                } else {
                    fill = "white"; // Set fill color to white for empty beds
                }

                (function (ph, gender, name, formname, arr, dep, regNo, city) { // IIFE to create a new scope
                    let radius = 16, gapBtnCircles = 2, circlesPerRow = 5
                    var circle = svg.append('circle')
                        .attr('cx', d.x + ((i % circlesPerRow + 1) * radius) + (i % circlesPerRow * radius) + (i % circlesPerRow * gapBtnCircles) + gapBtnCircles)
                        .attr("cy", d.y + radius + 2 + Math.floor(i / circlesPerRow) * (2 * radius + gapBtnCircles)) //d.y + i * h
                        .attr("r", radius / 3)
                        .style("stroke", "white")
                        .style("fill", fill) // start with white color
                        .style("stroke-width", 0)
                        .on("mouseover", function (event, d) {
                            if (fill === "deepskyblue" || fill === "pink") {
                                tooltip.style("opacity", 1)
                                    .style("left", (event.pageX + 10) + "px")
                                    .style("top", (event.pageY - 10) + "px")
                                    .html(`Name: ${name}<br>Phone #: ${ph}
                                    <br>Registration No: ${regNo}<br>City: ${city}
                                    <br>Form: ${formname}<br>Arrival: ${arr}<br>Departure: ${dep}`);
                            }
                        })
                        .on("mouseout", function () {
                            tooltip.style("opacity", 0);
                        })
                        .transition() // apply a transition
                        .duration(500) // make it last for 1000 milliseconds
                        .ease(d3.easeBounce) // apply bounce easing
                        .attr("r", radius) // change the fill color to lightgreen
                        .transition() // apply a transition
                        .duration(100)
                        .style("stroke-width", 0.4)
                        .style("stroke", "dodgerblue")
                })(ph, gender, name, formname, arr, dep, regNo, city); // Pass the variables to the IIFE
            }
        }


