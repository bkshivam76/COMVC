                                                columns.Add().DataField("BUILDING_NAME").Caption("Building Name");
                                                columns.Add().DataField("REC_ID").Visible(false);
                                            })
                                            .Selection(s => s.Mode(SelectionMode.Single))

                                            )
                                    </text>)
                    .OnValueChanged("Building_RoomsViz_ValueChange")
