<div class="RoomsViz_Facility_ClearReferences" onkeydown="keydown_RoomsViz(event)">
    @using DevExtreme.AspNet.Mvc;
    @using System.Web.Mvc.Html;
    @using System.Data
    @using Newtonsoft.Json;
    @{
        ViewBag.Title = "Frm_RoomsOccupancyVisualization_Info";
        
        var AllRoomsTbl = Model.Tables[0];
        var AllRoomsjson = Newtonsoft.Json.JsonConvert.SerializeObject(AllRoomsTbl);
        var RoomsFilledTbl = Model.Tables[1];
        var RoomsFilledjson = Newtonsoft.Json.JsonConvert.SerializeObject(RoomsFilledTbl);

    }
    <script src="~/Content/js/d3.v7.min.js"></script>
    <style>
        .card {
            border: 1px solid #ccc;
            margin: 5px;
            padding: 5px;
            display: inline-block;
        }
        .totalArea_RoomViz {
            display: flex;
            position: relative
        }
        #topFilters_RoomViz {
            width: 270px;
            padding-right: 10px;
            transition: .3s all;
            position: absolute;
            margin-left: 0;
        }
        #cardGrid_Roomviz {
            width: 100%;
            padding-left: 270px;
            transition: .3s all;
        }
        #cardGrid_Roomviz aside {
            padding:10px 12px;
            border-left: 1px solid #ddd;
        }
        .totalArea_RoomViz.moved #topFilters_RoomViz {
            opacity: 0;
            padding: 2px;
            margin-left: -270px;
            pointer-events: none;
        }
        .totalArea_RoomViz.moved #cardGrid_Roomviz {
            padding-left:0
        }

        #Rect_Circle_RoomViz {
            margin-right: 20px
        }
        #topFilters_RoomViz .dx_switch {
            width: 100px;
        }

        #tooltip {
            position: absolute;
            opacity: 0;
            pointer-events: none;
            background-color: white;
            border: solid 1px black;
            padding: 5px;
            border-radius: 10px;
            box-shadow: 0px 0px 10px rgba(0,0,0,0.5);
            font-family: Arial, sans-serif;
            font-size: 14px;
            line-height: 1.5;
        }

        #tooltip::after {
            content: "";
            position: absolute;
            top: 100%;
            left: 50%;
            margin-left: -5px;
            border-width: 5px;
            border-style: solid;
            border-color: black transparent transparent transparent;
        }

        #tooltip p {
            border-bottom: 1px solid black;
            padding: 2px;
        }

        #tooltip p:last-child {
            border-bottom: none;
        }

        h1 {
            display: flex;
            justify-content: center;
            margin: 0px;
        }

        hr {
            height: 0.5px;
            background-color: blueviolet;
        }

        .headings {
            display: flex;
            justify-content: center;
        }
        .modal-backdrop {
            background-color: rgba(256, 256, 256, .1);
        }
        #Refresh_RoomViz {
            background: #4472C4;
            color: #fff;
            border-color: #2F528F;
            padding: 5px;
            font-size: medium;
            width: 100%;
        }
        .dx-show-clear-button .dx-texteditor-input {
            height: 35px;
        }
        #topFilters_RoomViz .dx-switch-off {
            color: #11203d;
        }
        #Building_RoomsViz{
            font-size: large;
        }
        button.mode-slide {
            position: absolute;
            left: 251px;
            width: 20px;
            margin: auto;
            height: 40px;
            padding: 5px 0 2px 4px;
            line-height: 0;
            top: 13px;
            z-index: 5100;
            background: #ffffff;
            border: 1px solid #ccc;
            border-right-color: #fff;
            border-radius: 4px 0 0 4px;
            color: #a4a6ad;
            cursor: pointer;
            font-size: 19px;
            font-weight: bold;
            transition:.3s left;
        }
        button.mode-slide.moved {
            left: -8px;
            padding:0;
            border-right-color:#ccc;
            border-radius:2px;
            width:16px
        }
        button.mode-slide:hover {
            color: #15297e
        }
        button.mode-slide span {
            display: inline-block;
            transition: .4s all;
            transform: rotate(-180deg)
        }
        button.mode-slide.moved span {
            transform: rotate(0deg);
        }        
        .icon_roomViz:hover {
            cursor: pointer;
        }

        @@keyframes bounce {
            0%, 20%, 50%, 80%, 100% {
                transform: translateY(0);
            }

            40% {
                transform: translateY(-30px);
            }

            60% {
                transform: translateY(-15px);
            }
        }

        .bounce {
            animation: bounce 1s;
        }
    </style>


    @*<h2>Thank you baba.</h2>*@
<div class="totalArea_RoomViz">
    <button class="mode-slide">
        <span>»</span>
    </button>
    <div id="topFilters_RoomViz">
        <br />
        <div class="dx-field">
            <label style="padding: 7px 0px 5px 0px;">Select Mode</label>
            <div class="dx-field-value">
                @(Html.DevExtreme().Switch().ID("Rect_Circle_RoomViz").SwitchedOffText("Rectangles").SwitchedOnText("Circles").Width(100)
                        .Value(true).OnValueChanged("switch_valueChanged")
                    )
            </div>
        </div>
        <script>
            function switch_valueChanged(data) {//true->Circles and false->Rectangles.
                //$("#disabled").dxSwitch("instance").option("value", data.value)
                checkSwithAndCall(AllRoomsdata)
            }
            function checkSwithAndCall(data) {
                if ($("#Rect_Circle_RoomViz").dxSwitch("instance").option("value")) {
                    updateCircles(data)
                } else {
                    updateRectangles(data)
                }
            }
        </script>
        <div style="padding-bottom:8px;">
            <label>From Date</label>
            @(Html.DevExtreme().DateBox().CustomDateBox().Name("fromdate_RoomViz").ID("fromdate_RoomViz").Min(new DateTime(1990,01,01))
