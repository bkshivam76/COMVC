    <script type="text/javascript">
        
            var AllRoomsdata = JSON.parse('@Html.Raw(AllRoomsjson)');
            var RoomsFilleddata = JSON.parse('@Html.Raw(RoomsFilledjson)');
    
        //This is to initialize the svg and tooltip variables as global        
        var svg = d3.select("#cardGrid_Roomviz aside").append("svg")
            .attr("width", 8 * 170 + 7 * 20 + 4)
            .attr("height", 25000);
        var tooltip = d3.select("#tooltip");

        function Refresh_RoomViz_Onclick() {
            
            var _fromdate = $("#fromdate_RoomViz").dxDateBox("instance").option("value");
            var _todate = $("#todate_RoomViz").dxDateBox("instance").option("value");
                
            if (_fromdate == null || _fromdate == '') {
                DevExpress.ui.dialog.alert('From Date should not be null.', "error");
                return;
            }
            if (_todate == null || _todate == '') {
                DevExpress.ui.dialog.alert('To Date should not be null.', "error");
                return;
            }
                
            if (_fromdate > _todate) {
                DevExpress.ui.dialog.alert('From Date should not be greater than to date.', "error");
                return;
            }
                
            ShowLoader();

            $.ajax({
                type: 'Post',
                url: "/Facility/RoomsVisualization/RefreshData",
                cache: false,
                data: {                        
                    fromdate: _fromdate == null ? null : JS_Json_Date_To_ddMMyyyy(_fromdate),
                    todate: _todate == null ? null : JS_Json_Date_To_ddMMyyyy(_todate),                                                
                },
                success: function (data) {
                    HideLoader();                    
                    jsonData = JSON.parse(data)
                    AllRoomsdata = jsonData.Table
                    RoomsFilleddata = jsonData.Table1
                    //updateRectangles(AllRoomsdata)
                    checkSwithAndCall(AllRoomsdata)
                }
            });
        }
    </script>
    <script>
        function updateCircles(data, filteredroomsdata = null) {
            // Remove existing rectangles
            svg.selectAll("rect").remove();
            svg.selectAll("text").remove();
            svg.selectAll("circle").remove();
            svg.selectAll("ellipse").remove();
            svg.selectAll("foreignObject").remove();
            
            let sum = 0;

            // This code is to find the total filled beds count
            data.forEach(room => {
                let matchedRooms = RoomsFilleddata.filter(filledRoom => filledRoom.ROOM_RECID === room.ALI_REC_ID);
                let totalFilledBeds = matchedRooms.reduce((total, room) => total + room.FILLEDBEDS, 0);
                sum += totalFilledBeds;
            });

            //This code is to count the total capacity of all the rooms. that means the sum of all beds of all rooms.
            let TotalCapacity = data.reduce((total, room) => total + room.AL_MAXCAPACITY, 0);
            document.getElementById("filled_Capacity_summary_RoomViz").innerHTML = sum + " / " + TotalCapacity;

            let groupedData = Array.from(d3.group(data, d => d.SP_REC_ID))
            // Sort the grouped data
            groupedData.sort((a, b) => {
                let aName = a[1][0].SP_SERVICE_PLACE_NAME;
                let bName = b[1][0].SP_SERVICE_PLACE_NAME;
                if (aName < bName) {
                    return -1;
                } else if (aName > bName) {
                    return 1;
                } else {
                    return 0;
                }
            });
            // Calculate the y position for each building group
            let buildingY = 20;
            let roomY = 0;
            groupedData.forEach(function (building, k)
            {
                // Calculate the y position for rooms in this building                
                if (k > 0) {
                    
                    buildingY = roomY + 60;
                    roomY = buildingY
                } else {
                    roomY = buildingY + 20
                }
                //let buildingGroup = svg.append("g");
                // Add building name text
                svg.append("text")
                    .attr("x", 2)
                    .attr("y", buildingY)
                    .text(groupedData[k][1][0].SP_SERVICE_PLACE_NAME)
                    .style("font-size", "24px")
                    //.style("font-weight", "bold");
                // Create the refresh ellipse
                if (k == 0) {
                    var refreshEllipse = svg.append("ellipse")
                        .attr("cx", 170 * 6) //after 6 rectangles width
                        .attr("cy", buildingY)
                        .attr("rx", 18)
                        .attr("ry", 18)
                        .attr("fill", "#4472C4")
                        .attr("stroke", "#4472C4")
                        .attr("stroke-width", 1)
                        .on("click", Refresh_RoomViz_Onclick);

                    // Add the refresh icon inside the ellipse
                    svg.append("text")
                        .attr("x", 170 * 6)
                        .attr("y", buildingY+10)
                        .attr("class", "icon_roomViz")
                        .text("⟳")
                        .attr("fill", "white")
                        .style("font-size", 30)
                        .style("text-anchor", "middle")
                        .on("click", Refresh_RoomViz_Onclick)

                    // Create the previous button ellipse
                    var prevEllipse = svg.append("ellipse")
                        .attr("cx", 170 * 7)
                        .attr("cy", buildingY)
                        .attr("rx", 24)
                        .attr("ry", 15)
                        .attr("fill", "#4472C4")
                        .attr("stroke", "#4472C4")                        
                        .attr("stroke-width", 2)
                        .on("click", PrevBuilding_RoomViz);

                    // Add the previous icon inside the ellipse
                    svg.append("text")
                        .attr("x", 170 * 7)
                        .attr("y", buildingY + 8)
                        .attr("class", "icon_roomViz")
                        .style("font-size", 30)
                        .style("text-anchor", "middle")
                        .style("fill", "white")
                        .text("⟵")
                        .on("click", PrevBuilding_RoomViz)

                    // Create the next button ellipse
                    var nextEllipse = svg.append("ellipse")
                        .attr("cx", 170 * 7 + 65)
                        .attr("cy", buildingY )
                        .attr("rx", 24)
                        .attr("ry", 15)
                        .attr("fill", "#4472C4")
                        .attr("stroke", "#4472C4")
                        .attr("stroke-width", 2)
                        .on("click", NextBuilding_RoomViz)

                    // Add the next icon inside the ellipse
                    svg.append("text")
                        .attr("x", 170 * 7 + 65 - 3)
