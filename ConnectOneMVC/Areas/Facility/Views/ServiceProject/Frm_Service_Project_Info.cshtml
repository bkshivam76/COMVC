    <script>
        function ServiceProjectOnInit(s, e)
        {
            ServiceProjectAdjustSize();
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt)
            {
                ServiceProjectAdjustSize();
            });
        }

        function ServiceProjectAdjustSize()
        {
            var height = null;
            if (Screen_ServiceProjectInfo != "" && isDesktop) {
                height = (document.documentElement.clientHeight * 70) / 100;
            }
            else {
                height = (document.documentElement.clientHeight * 90) / 100;
            }
            try {
                ServiceProjectListGrid.SetHeight(height);
            }
            catch (err)
            {
            }
        }

        function ServiceProjectInfo_GetRowData(RowIndex = null)
        {
            var focusedrow = RowIndex == null ? ServiceProjectListGrid.GetFocusedRowIndex() : RowIndex;
            var topindex = ServiceProjectListGrid.GetTopVisibleIndex();
            var Index = focusedrow - topindex;
            var ServiceProjectInfoPageData = ServiceProjectListGrid.cpPagedata;
            console.log(ServiceProjectInfoPageData)
            if (ServiceProjectInfoPageData != null && ServiceProjectInfoPageData.length > 0 && Index < ServiceProjectInfoPageData.length) {
                ServiceProject_ID = ServiceProjectInfoPageData[Index][0];
                ServiceProject_Name = ServiceProjectInfoPageData[Index][1];
                ServiceProject_State = ServiceProjectInfoPageData[Index][2];
                ServiceProject_ProfileCreationLink = ServiceProjectInfoPageData[Index][3];
                ServiceProject_ProfileCreation_CHART_ID = ServiceProjectInfoPageData[Index][4];
                
            }
            else
            {
                ServiceProject_ID = null;
                ServiceProject_Name = null;
                ServiceProject_State = null;
                ServiceProject_ProfileCreationLink = null;
                ServiceProject_ProfileCreation_CHART_ID = null;
            }
        }

        function ServiceProjectListGrid_BeginCallback(s, e)
        {
            e.customArgs["command"] = e.command;
            e.customArgs["ShowHorizontalBar"] = SP_ShowHorizontalBar;
            e.customArgs["Screen"] = Screen_ServiceProjectInfo;            
        }

        function ServiceProjectchangeMode()
        {
            ShowLoader();
            if (SP_ShowHorizontalBar == 0)
            {
                SP_ShowHorizontalBar = 1;
                $("#ServiceProject_ToggleScrollBar").find("span").text("Default Data");
                $("#ServiceProject_ToggleScrollBar").width(110);
            }
            else
            {
                SP_ShowHorizontalBar = 0;
                $("#ServiceProject_ToggleScrollBar").find("span").text("Full Data");
                $("#ServiceProject_ToggleScrollBar").width(90);
            }
            $.ajax({
                url: "/Facility/ServiceProject/Frm_Service_Project_Info_Grid",
                type: "POST",
                data: { ShowHorizontalBar: SP_ShowHorizontalBar},
                success: function (res)
                {
                    //$("#ServiceReportGridPartialView").html(res);
                    //ASPxClientControl.AdjustControls(document.getElementById("ServiceReportGridPartialView"));
                    //$(".ServiceReportListGrid_PreviewRow").hide();
                    //GetSessionStorage("ServiceProjectListGrid");
                    HideLoader();
                }
            });
        }
        function ServiceProjectListGrid_ContextMenuFunction(s, e)
        {
            if (e.item.name == "Close") {
                closeServiceProject();
            }
            if (e.item.name == "AddProject") {
                DataNavigation_ServiceProj("NEW");
            }
            else if (e.item.name == 'EditProject') {
                DataNavigation_ServiceProj("EDIT");
            }
            else if (e.item.name == 'ViewProject') {
                DataNavigation_ServiceProj("VIEW");
            }
            else if (e.item.name == 'DeleteProject') {
                DataNavigation_ServiceProj("DELETE");
            }
            else if (e.item.name == 'CreateForm') {
                DataNavigation_ServiceProj("CREATEFORM");
            }
            else if (e.item.name == 'CreateSubject') {
                DataNavigation_ServiceProj("SUBJECT_PROFILE");
            }
            else if (e.item.name == 'ViewForms') {
                DataNavigation_ServiceProj("VIEWSURVEYFORMS");
            }
            else if (e.item.name == 'MapSubjects') {
                DataNavigation_ServiceProj("MAP_SUBJECTS");
            }
            else if (e.item.name == 'ViewSubjects') {
                DataNavigation_ServiceProj("SUBJECTS");
            }
            else if (e.item.name == 'Export') {
                OnServiceProjectListPreviewClick();
            }
            else if (e.item.name == 'Notification') {
                DataNavigation_ServiceProj("NOTIFICATION"); 
            }
            else if (e.item.name == 'Refresh') {
                ServiceProjectListGrid.Refresh();
            }
            else if (e.item.name == 'CopyBasicDetailFormLink') {
                DataNavigation_ServiceProj("CopyBasicDetailFormLink");
            }
        }
    </script>      
