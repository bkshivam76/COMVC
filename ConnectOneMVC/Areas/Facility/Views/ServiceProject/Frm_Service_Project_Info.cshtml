        function DataNavigation_ServiceProj(Action)
        {
            var focusIndex = ServiceProjectListGrid.GetFocusedRowIndex();
            if (focusIndex < 0 && Action != "NEW")
            {
                DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                return;
            }
            ServiceProjectInfo_GetRowData(focusIndex);

            if (Action == "NEW")
            {
                ShowLoader();
                $.ajax({
                    type: 'GET',
                    url: "/Facility/ServiceProject/Frm_ServiceProject_Window",
                    cache: false,
                    data:
                    {
                        Tag: "_New",
                        Screen: Screen_ServiceProjectInfo
                    },
                    success: function (data)
                    {
                        HideLoader();
                        OpenDynamicPopup("New ~ Service Projects", null, "auto", 650, true, data);
                    },
                    error: function (jqXHR, textStatus, errorThrown)
                    {
                        HideLoader();
                        console.log(jqXHR);
                        console.log(textStatus);
                        console.log(errorThrown);
                        DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
                    }
                });
            }
            else if (Action == "EDIT" || Action == "DELETE" || Action=="VIEW")
            {
                var _tag = Action == "EDIT" ? "Edit" : Action=="DELETE"?"Delete":"View"
                ShowLoader();
                $.ajax({
                    type: 'GET',
                    url: "/Facility/ServiceProject/Frm_ServiceProject_Window",
                    cache: false,
                    data:
                    {
                        Tag: _tag,
                        ProjectID: ServiceProject_ID,
                        Screen: Screen_ServiceProjectInfo
                    },
                    success: function (data)
                    {
                        HideLoader();
                        OpenDynamicPopup(_tag+" ~ Service Projects", null, "auto", 650, true, data);
                    },
                    error: function (jqXHR, textStatus, errorThrown) {
                        HideLoader();
                        console.log(jqXHR);
                        console.log(textStatus);
                        console.log(errorThrown);
                        DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
                    }
                });
            }
            else if (Action == "SUBJECT_PROFILE")
            {
                if (ServiceProject_State == "Inactive")
                {
                    DevExpress.ui.dialog.alert("Cannot Create Subject Profile As The Project Is InActive", "Alert");
                    return
                }
                if (ServiceProject_ProfileCreationLink == null || ServiceProject_ProfileCreationLink.length == 0 || Screen_ServiceProjectInfo.includes("Sparc_"))
                {
                    Creat_Edit_Subject_ServiceProject("_New", "", "", "Create Subject");
                    return
                }
                else {
                    var url = "@servicesPath" + ServiceProject_ProfileCreationLink;
                    $.ajax({
                        type: 'GET',
                        url: "/Facility/Chart/AddGuideSessionID",
                        cache: false,
                        data:
                        {

                        },
                        success: function (data)
                        {
                            GuideSessionID = data.GuideSessionID;
                            url = url+ "/?GuideSessionID=" + GuideSessionID;
                            OpenFormPopup(null, false, url)
                            HideLoader();
                            @*window.onmessage = function (e)
                            {
                                console.log(e)
                                if ("@servicesPath".includes(e.origin))
                                {
                                    if (e.data == 'FormOperationCompleted') {
                                        alert("worked")
                                    }
                                }
                            };*@
                        }
                    });
                }
            }
            else if (Action == "SUBJECTS")

            {
                ShowLoader();

                $.ajax({
                    type: 'GET',
                    url: "/Facility/ServiceProject/Frm_ServiceProject_MappedSubjects",
                    cache: false,
                    data:
                    {
                        ProjectID: ServiceProject_ID,
                        ProjName: ServiceProject_Name,
                        Screen: Screen_ServiceProjectInfo
                    },
                    success: function (data)
                    {
                        HideLoader();
                        OpenDynamicPopup("Mapped Subjects", null, "auto", 1050, true, data);
                    },
                    error: function (jqXHR, textStatus, errorThrown) {
                        HideLoader();
                        console.log(jqXHR);
                        console.log(textStatus);
                        console.log(errorThrown);
                        DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
                    }
                });
            }
            else if (Action == "NOTIFICATION") {
                ShowLoader();
                $.ajax({
                    type: 'GET',
                    url: "/Facility/ServiceProject/Frm_Project_Notification",
                    cache: false,
                    data:
                    {
                        ProjectID: ServiceProject_ID,
                        ProjName: ServiceProject_Name,
                        SendNowOrLater: '@ViewBag.Screen'
                    },
                    success: function (data) {
                        HideLoader();
                        OpenPopup("Project_Notification_popup","Send/Schedule Push Notification", null, "auto", 650, true, data);
                    },
                    error: function (jqXHR, textStatus, errorThrown) {
                        HideLoader();
                        console.log(jqXHR);
                        console.log(textStatus);
                        console.log(errorThrown);
                        DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
                    }
                });
            }
            else if (Action == "CREATEFORM")
            {
                if (ServiceProject_ID == "" || ServiceProject_ID == null || ServiceProject_ID == 'undefined') {
                    DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                    return;
                }
                if (Screen_ServiceProjectInfo == "Sparc_CreateForm") {
                    CreateNewForm("_New", null, null, null, ServiceProject_ID, "Sparc_CreateForm")
                }
                else {
                    CreateNewForm("_New", null, null, null, ServiceProject_ID)
                }
            }
            else if (Action == "VIEWSURVEYFORMS") {
                if (ServiceProject_ID == "" || ServiceProject_ID == null || ServiceProject_ID == 'undefined') {
                    DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                    return;
                }

                if ($("#ChartInfo_ParentDiv").length > 0) {
                    DevExpress.ui.dialog.alert("Cannot Open Service Forms If Already Open In Tab<br>Kindly Close Service Forms In Tab To View Service Forms Related to this Project", "Information..");
                    return;
                }

                var PopUp_Title = "Service Forms - " + ServiceProject_Name;
                if (Screen_ServiceProjectInfo !== null && Screen_ServiceProjectInfo !== undefined && Screen_ServiceProjectInfo !== "") {
                    switch (Screen_ServiceProjectInfo) {
                        case "Sparc_Copy_Chart": PopUp_Title = "Edit >> Form >> Copy >> Project: " + ServiceProject_Name+" >> Select Form: "; break;
                        case "Sparc_Edit_Chart": PopUp_Title = "Edit >> Form >> Modify >> Project: " + ServiceProject_Name+" >> Select Form: "; break;
                        case "Sparc_Share_Chart": PopUp_Title = "Edit >> Form >> Share >> Project: " + ServiceProject_Name+" >> Select Form: "; break;
                        case "Sparc_Download_Chart": PopUp_Title = "Edit >> Form >> Download >> Project: " + ServiceProject_Name+" >> Select Form: "; break;
                        case "Sparc_Delete_Chart": PopUp_Title = "Edit >> Form >> Delete >> Project: " + ServiceProject_Name+" >> Select Form: "; break;
                        case "Sparc_MapForm2Subject": PopUp_Title = "Map/Unmap & Copy >> Subject to Form >> Project: " + ServiceProject_Name+" >> Select Form: "; break;
                    }
                }
                OpenPopup(Screen_ServiceProjectInfo + '_Chart', PopUp_Title, "@Url.Action("Frm_Chart_Info", "Chart", new { @area = "Facility" })" + "?serviceProject_ID=" + ServiceProject_ID + "&screen=" + Screen_ServiceProjectInfo + '_Chart', "auto", 1050);
            }
            else if (Action == "ALL_RESPONSES") {
                if (ServiceProject_ID == "" || ServiceProject_ID == null || ServiceProject_ID == 'undefined') {
                    DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                    return;
                }
                ShowLoader();
                $.ajax({
                    type: 'GET',
                    url: "/Facility/ServiceProject/Frm_All_Responses_Info",
                    cache: false,
                    data:
                    {
                        Project_ID: ServiceProject_ID,
                        Project_Name: ServiceProject_Name,
                        RegChartID: ServiceProject_ProfileCreation_CHART_ID
                    },
                    success: function (data) {
                        HideLoader();
                            OpenPopup("All_Forms_Responses_Modal", "Responses of All Survey Forms", null, "auto", "100%", true, data);
                    },
                    error: function (jqXHR, textStatus, errorThrown) {
                        HideLoader();
                        console.log(jqXHR);
                        console.log(textStatus);
                        console.log(errorThrown);
                        DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
                    }
                });
            }
            else if (Action == "ALL_RESPONSES_TIME") {
                if (ServiceProject_ID == "" || ServiceProject_ID == null || ServiceProject_ID == 'undefined') {
                    DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                    return;
                }
                ShowLoader();
                $.ajax({
                    type: 'GET',
                    url: "/Facility/ServiceProject/Frm_All_Responses_Time_Info",
                    cache: false,
                    data:
                    {
                        Project_ID: ServiceProject_ID,
                        Project_Name: ServiceProject_Name,
                        RegChartID: ServiceProject_ProfileCreation_CHART_ID,
                        Screen: Screen_ServiceProjectInfo
                    },
                    success: function (data) {
                        HideLoader();
                        if (Screen_ServiceProjectInfo === "Sparc_Answer") {
                            OpenPopup("All_Forms_Responses_Time_Modal", "Answers with TimeStamp", null, "auto", "100%", true, data);
                        }
                        else {
                            OpenPopup("All_Forms_Responses_Time_Modal", "Responses(TimeStamp) of All Survey Forms", null, "auto", "100%", true, data);                        
                        }
                    },
                    error: function (jqXHR, textStatus, errorThrown) {
                        HideLoader();
                        console.log(jqXHR);
                        console.log(textStatus);
                        console.log(errorThrown);
                        DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
                    }
                });
            }

            else if (Action == "MAP_SUBJECTS")
            {
                if (ServiceProject_ID == "" || ServiceProject_ID == null || ServiceProject_ID == 'undefined')
                {
                    DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                    return;
                }
                if (ServiceProject_State == "Inactive")
                {
                    DevExpress.ui.dialog.alert("Cannot Map Subjects As The Project Is InActive", "Alert");
                    return
                }
                ShowLoader();
                $.ajax({
                    type: 'GET',
                    url: "/Facility/ServiceProject/Frm_Subject_Mapping_Info",
                    cache: false,
                    data:
                    {
                        Project_ID: ServiceProject_ID,
                            Project_Name: ServiceProject_Name,
                        RegChartID: ServiceProject_ProfileCreation_CHART_ID,
                        Screen: Screen_ServiceProjectInfo
                    },
                    success: function (data)
                    {
                        HideLoader();
                        OpenPopup("Subject_Mapping_Screen_Modal", "Map Subjects To Project", null, "auto", 1050, true, data);
                    },
                    error: function (jqXHR, textStatus, errorThrown)
                    {
                        HideLoader();
                        console.log(jqXHR);
                        console.log(textStatus);
                        console.log(errorThrown);
                        DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
                    }
                });
            }
            else if (Action == "FULL_DELETE") {
                if (ServiceProject_ID == "" || ServiceProject_ID == null || ServiceProject_ID == 'undefined') {
                    DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                    return;
                }

                var deleteConfirmation_1 = DevExpress.ui.dialog.confirm("<div> !!Are You Sure !!  <br> <br> You Want To  <br> <br> <h6 style='color:red'> <b>DELETE THIS PROJECT ?</b><br>" + ServiceProject_Name + "</h6> </div>", "!! Confirm !!");
                deleteConfirmation_1.done(function (confirmResult_1) {
                    if (confirmResult_1) {
                        var deleteConfirmation_2 = DevExpress.ui.dialog.confirm("<div style='text-align: center;'> All the data related to this Project i.e. Forms, Responses, Mappings, Notifications will be deleted and won't be recovered.<br> <br> You want to proceed?</div>", "Information");
                        deleteConfirmation_2.done(function (confirmResult_2) {
                            if (confirmResult_2) {
                                ShowLoader();
                                $.ajax({
                                    type: 'GET',
                                    url: "/Facility/ServiceProject/DeleteFullServiceProject",
                                    cache: false,
                                    data:
                                    {
                                        Project_ID: ServiceProject_ID,
                                        Project_Name: ServiceProject_Name,
                                    },
                                    success: function (data) {
                                        HideLoader();
                                        if (data.jsonParam.result == false) {
                                            DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                                        }
                                        else {
                                            var alertClick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                                            alertClick.done(function (alertResult) {
                                                if (alertResult) {
                                                    ServiceProjectListGrid.Refresh();
                                                }
                                            })
                                        }

                                    }
                                });
                            }
                        })
                    }
                })
            }

            else if (Action == "CopyBasicDetailFormLink") {

                if (ServiceProject_ProfileCreationLink == null || ServiceProject_ProfileCreationLink.length == 0) {
                    DevExpress.ui.dialog.alert("Basic Details form is not available for this Project", "Alert");
                    return
                }
                var URL = ServicePath + ServiceProject_ProfileCreationLink ;
                navigator.clipboard.writeText(URL); DevExpress.ui.notify({ message: 'Link of Basic Detail Form Has Been Copied ! You can paste it as Required...', width: 500, shading: true, position: 'center' }, "success", 1500);
            }
        }

