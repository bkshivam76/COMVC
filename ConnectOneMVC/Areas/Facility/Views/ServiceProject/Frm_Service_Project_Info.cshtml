<div class="ServiceProjectFacility_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    @model System.Data.DataTable
    @{
        string servicesPath = System.Web.Configuration.WebConfigurationManager.AppSettings["Servicespath"].ToString();
    } 
    <div id="ServiceProject_ParentDiv">
        <div id="ServiceProject_content" class="report_header_div_main clearfix">
            <div class="report_header_div">
                <label class="report_header_label">Service Projects</label>
            </div>
            <div class="report_button_div">
                @(Html.DevExtreme().Button().ID("ServiceProject_CreateForm").Text("Create Form").Icon("add").Visible(true).OnClick(@<text> function () { DataNavigation_ServiceProj("CREATEFORM"); } </text>))
                @(Html.DevExtreme().Button().ID("ServiceProject_ViewSurveyForms").Text("View Forms").Icon("add").Visible(true).OnClick(@<text> function () { DataNavigation_ServiceProj("VIEWSURVEYFORMS"); } </text>))
                @(Html.DevExtreme().Button().ID("ServiceProject_AllFormsResponses").Text("All Forms Responses").Icon("doc").Visible(true).OnClick(@<text> function () { DataNavigation_ServiceProj("ALL_RESPONSES"); } </text>))
                @(Html.DevExtreme().Button().ID("ServiceProject_AllFormsResponsesTime").Text("All Forms Responses(TimeStamp)").Icon("doc").Visible(true).OnClick(@<text> function () { DataNavigation_ServiceProj("ALL_RESPONSES_TIME"); } </text>))
                @(Html.DevExtreme().Button().ID("ServiceProject_SubjectProfile").Text("Create Subject Profile").Icon("add").Visible(true).OnClick(@<text> function () { DataNavigation_ServiceProj("SUBJECT_PROFILE"); } </text>))
                @(Html.DevExtreme().Button().ID("ServiceProject_MapSubjects").Text("Map/Un-Map Subjects").Icon("add").Visible(true).OnClick(@<text> function () { DataNavigation_ServiceProj("MAP_SUBJECTS"); } </text>))
                @(Html.DevExtreme().Button().ID("ServiceProject_New").Text("New") .Icon("add").Visible(true).OnClick(@<text> function () { DataNavigation_ServiceProj("NEW"); } </text>))
                @(Html.DevExtreme().Button().ID("ServiceProject_Edit").Text("Edit").Icon("edit").Visible(true).OnClick(@<text> function () { DataNavigation_ServiceProj("EDIT"); } </text>))
                @(Html.DevExtreme().Button().ID("ServiceProject_View").Text("View").Icon("doc").Visible(true).OnClick(@<text> function () { DataNavigation_ServiceProj("VIEW"); } </text>))
                @(Html.DevExtreme().Button().ID("ServiceProject_Delete").Text("Delete").Icon("trash").Visible(true).OnClick(@<text> function () { DataNavigation_ServiceProj("DELETE"); } </text>))
                @(Html.DevExtreme().Button().ID("ServiceProject_FullDelete").Text("Full Delete").Icon("trash").Visible(true).OnClick(@<text> function () { DataNavigation_ServiceProj("FULL_DELETE"); } </text>))
                @(Html.DevExtreme().Button().ID("ServiceProject_MappedSubject").Text("View Mapped Subjects").Icon("doc").Visible(true).OnClick(@<text> function () { DataNavigation_ServiceProj("SUBJECTS"); } </text>))
                @(Html.DevExtreme().Button().ID("ServiceProject_Notification").Text("Send/Schedule Notification").Icon("").Visible(true).OnClick(@<text> function () { DataNavigation_ServiceProj("NOTIFICATION"); } </text>))
                @(Html.DevExtreme().Button().ID("ServiceProject_ToggleScrollBar").Text(ViewBag.ShowHorizontalBar == 1 ? "Default Data" : "Full Data").Width(ViewBag.ShowHorizontalBar == 1 ? 110 : 90).Icon("toolbox").OnClick("ServiceProjectchangeMode").Visible(false) )
                @(Html.DevExtreme().Button().ID("ServiceProject_ModelListPreview").Text("List Preview").Icon("save").OnClick("OnServiceProjectListPreviewClick") )
                @(Html.DevExtreme().Button().ID("ServiceProject_ModelCLOSE").Text("Close").Icon("clear").OnClick("closeServiceProject") )
            </div>
        </div>
        <div class="col-md-12 no-padding" id="ServiceProject_gridDiv">
            <form>
                <div id="ServiceProjectGridPartialView" class="parent_table">
                    @Html.Partial("Frm_Service_Project_Info_Grid", Model)
                </div>
            </form>
        </div>
        <div class="footer-MainBoxdiv" style="display:inline-block;width:100%">
            <div class="setFooterItem">
                <div class="footer-inner">
                    <div class="list_footer_left_margin">
                        <div class="footericon">
                            <i id="ServiceReport_LockICON" style="color:red;font-size:35px;"></i>
                        </div>
                        @*<div class="footer-locktext">
                                <div id="BankLbl_Status" style="font-size:23px" class="left_footertext_top"></div>
                            </div>*@
                        <div class="footer-locktext">
                            <div id="SR_Lbl_ActionOn" class="left_footertext_top"></div>
                            <div id="SR_Lbl_ActionBy" class="left_footertext_bottom"></div>
                        </div>
                    </div>
                    <div class="list_footer_left_margin">
                        <div class="footer-text">
                            <p id="SR_Create" class="right_footertext_top"></p>
                            <p id="SR_Modify" class="right_footertext_bottom"></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

