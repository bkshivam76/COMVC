@using DevExtreme.AspNet.Mvc
<div class="container" id="container">
    <div class="row" style="padding: 10px 5px">
        <div class="col-6">

        </div>
        <div class="col-6 float-right">
            @(Html.DevExtreme().Button().Text("Restore Event") .StylingMode(ButtonStylingMode.Contained).Width(100).OnClick("Cancel_Restore_onclick"))
            @(Html.DevExtreme().Button().Text("Preview") .StylingMode(ButtonStylingMode.Contained).Width(100).OnClick("Cancel_Preview_onclick"))

        </div>

    </div>


    @Html.Action("Frm_Cancelled_Events_Grid") @*new { viewmode = Model.viewmode, wingid = Model.wingid, insid = Model.insid }*@
</div>
