    function Date_EditValueChanged_GSR(e) {
        var FromDate = $("#DE_FR_DT_GSR").dxDateBox("instance").option("value");
        var ToDate = $("#DE_TO_DT_GSR").dxDateBox("instance").option("value");
        var result = "";
        if (isValidDate(FromDate) && isValidDate(ToDate)) {
            var diff = getDifferenceInDays(FromDate, ToDate);
            if (diff >= 0) {
                result = (diff + 1) + " day(s).";
            }
            else {
                result = (diff - 1) + " day(s).";
            }
        }
        else {
            result = "";
        }
        $("#Txt_Period_Date_GSR").dxTextBox("instance").option("value", result);
        if (isValidDate(ToDate) && ToDate > new Date()) {
            $("#lbl_beneficiary_GSR").text("Expected Beneficiaries:");
        }
        else {
            $("#lbl_beneficiary_GSR").text("No. of Beneficiaries:");
        }
    }
    function Time_EditValueChanged_GSR(e) {
        var FrTime = $("#Txt_Fr_Time_GSR").dxDateBox("instance").option("value");
        var ToTime = $("#Txt_To_Time_GSR").dxDateBox("instance").option("value");
        var result = "";
        var hour = "";
        var minutes = "";
        if (FrTime != null && ToTime != null && (ToTime >= FrTime)) {
            var data = getDiffinHrMin(FrTime, ToTime);
            hour = data[0];
            minutes = data[1];
        }
        else {
            FrTime = "";
            ToTime = "";
        }
        if (FrTime.toString().length >= 7 && ToTime.toString().length >= 7) {
            result = (hour != "0" ? hour + (hour != "1" ? " hrs" : " hr") : "") +
                (minutes != "0" ? (hour != "0" ? ", " : "") + minutes + " min" : "") + ".";
        }
        else {
            result = "";
        }
        $("#Txt_Period_Time_GSR").dxTextBox("instance").option("value", result);
    }
