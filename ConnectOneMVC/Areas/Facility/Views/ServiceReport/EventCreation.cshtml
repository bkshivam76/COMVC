                            HideLoader();
                            /*  $("#tabPanel_GSR").dxTabPanel("instance").option("selectedIndex", 3)*/
                            $("#Banner_Pictures_GSR").dxButton("focus");
                        });
                        return;
                    }
                    //if (GSR_Is_Document_Attached == false && IsNullOrWhitespace("Txt_MediaLink_GSR") && Tag_GSR=="_New")
                    //{
                    //    var alertclick = DevExpress.ui.dialog.alert("Either Attach Program Pictures/Videos/Press Release/Banner/Promo<br> Or Mention Media Google Drive / Other Link", "Information");
                    //    alertclick.done(function (alertResult)
