                    //      /*  $("#tabPanel_GSR").dxTabPanel("instance").option("selectedIndex", 3)*/
                    //        $("#Txt_MediaLink_GSR").dxTextBox("focus");
                    //    });
                    //    return;
                    //}
                    $("#Chk_WingBasedFlag_GSR").val("false");
                    var SelectedWingValue = $("#Look_Wings_GSR").dxDropDownBox("instance").option("value");
                    if (SelectedWingValue != null && SelectedWingValue.length > 0)
                    {
                        $("#Chk_WingBasedFlag_GSR").val("true");
                    }
                    //$('.custom-checkbox-list.GSRWing-list .dx-checkbox').each(function (i, item)
                    //{
                    //    var id = $(item).attr("id");
                    //    if ($("#" + id).dxCheckBox("instance").option("value"))
                    //    {
                    //        $("#Chk_WingBasedFlag_GSR").val("true");
                    //        return false;
                    //    }
                    //})
                    var WingCount = parseInt($("#WingListData_Count").val());
                    for (var i = 0; i < WingCount; i++)
                    {
                        var wingID = $("#Wings_List_GSR_" + i + "__ID").val();
                        if (SelectedWingValue.includes(wingID))
                        {
                            $("#Wings_List_GSR_" + i + "__Selected").val("true");
                        }
                    }
                    $("#ProgType_ID_GSR").val(($("#Look_ProgType_GSR").dxDropDownBox("instance").option("value")).join("!["));
                    $("#ProgType_Text_GSR").val($("#Look_ProgType_GSR").dxDropDownBox("instance").option("text"));
                    $("#ProgOccasion_Text_GSR").val($("#Look_ProgOccasion_GSR").dxDropDownBox("instance").option("text"));
                    var TreePlantation_DG = $("#TreePlantation_DG").dxDataGrid("instance");
                    if ($("#SelectedActivities_GSR").val().includes("Tree Plantation"))
                    {
                        if (TreePlantation_DG.hasEditData())
                        {
                            var DataGridRows = $("#TreePlantation_DG .dx-data-row"); //deleting empty rows
                            TreePlantation_DG.beginUpdate();
                            for (var j = 0; j < DataGridRows.length; j++)
                            {
                                var Tree = TreePlantation_DG.cellValue(j, 0);
                                var Count = String(TreePlantation_DG.cellValue(j, 1));
                                if ((Tree == null || Tree.trim().length == 0) && (Count == null || Count.trim().length == 0 || Count == "undefined"))
                                {
                                    TreePlantation_DG.deleteRow(j);
                                }
                            }
                            TreePlantation_DG.endUpdate();
                        }
                        if (TreePlantation_DG.hasEditData())
                        {
                            await TreePlantation_DG.saveEditData();
                            if (TreePlantation_DG.hasEditData())
                            {
                              /*  $("#tabPanel_GSR").dxTabPanel("instance").option("selectedIndex", 0);*/
                                DevExpress.ui.dialog.alert("Highlighted Cells Have Wrong Tree/Plant Plantation Details.", "Information").done(function ()
                                {
                                    if ($("#TreePlantation_DG .dx-datagrid-invalid").length > 0)
                                    {
                                        $("#TreePlantation_DG .dx-datagrid-invalid").eq(0).click();
                                    }
                                });
                                HideLoader();
                            }
                            else
                            {
                               form.submit();
                            }
                        }
                        else
                        {
                            form.submit();
                        }
                    }
                    else
                    {
                        if (TreePlantation_DG.hasEditData())
                        {
                            TreePlantation_DG.cancelEditData();
                        }
                        form.submit();
                    }
                }
            }
            else
            {
                HideLoader();
               // $("#tabPanel_GSR").dxTabPanel("instance").option("selectedIndex", 0)
            }
        }
