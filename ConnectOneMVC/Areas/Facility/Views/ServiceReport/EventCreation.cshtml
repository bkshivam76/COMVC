        function GSR_Attach_UploadError(e)
        {
            HideLoader();
            console.log(e.error);
            console.log(e.event);
            console.log(e.file);
            var message = "";
            if (GSR_Attach_uploadErrorDuetohtml == true) {
                GSR_Attach_uploadErrorDuetohtml = false;
                message = "<b>Html files are not allowed</b><br>";
            }
            if (e.error.statusText.length > 0)
            {
                message = message + e.error.status + ": " + e.error.statusText + "<br>";
            }
            GSR_FilesSelectedCount = GSR_FilesSelectedCount - 1;
            if (GSR_uploadErrorDuetoFileCount == false)
            {
                DevExpress.ui.dialog.alert(message + GSR_Attached_FileName + "<br>Did Not Upload<br>Kindly Check The File", 'Upload Error..');
            }
        }
        function GSR_fileUploader_valueChanged(e)
        {
            var files = e.value;
            GSR_FilesSelectedCount = files.length;
            if (GSR_FilesSelectedCount > 25)
            {
                GSR_uploadErrorDuetoFileCount = true;
                DevExpress.ui.dialog.alert("You Have Selected " + GSR_FilesSelectedCount + " Files To Upload<br><b>More Than 25 Files Cannot Be Uploaded At Once<b>", 'Upload Error..');
                //$.each(files, function (index, value)
                //{
                //    e.element.find(".dx-fileuploader-files-container .dx-fileuploader-cancel-button")
                //        .eq(index)
                //        .trigger("dxclick");
                //});
                return;
            }
            if (files.length > 0)
            {
                var totalContent = 0;        
                var NotAllowedFilePresent = false;
                for (var i = 0; i < files.length; i++)
                {
                    var ErrMsg = PreventFileUpload(files[i])
                    if (ErrMsg != null && ErrMsg.length > 0)
                    {
                        NotAllowedFilePresent = true;
                        DevExpress.ui.dialog.alert(ErrMsg, 'Upload Error..');
                        break;
                    }          
                    else
                    {
                        totalContent = totalContent + files[i].size
                    }
                }
                if (NotAllowedFilePresent == true)
                {
                    $("#GSR_myFile").dxFileUploader("instance").reset();
                    return;
                }
                if (totalContent < 524288000)
                {
                    ShowLoader("Uploading File", false);
                    GSR_FileUploadStart = true;
                    GSR_Attached_FileName = files[0].name;
                    var formdata = new FormData($('#GSR_DirectBrowse_Form').get(0));
                    formdata.append('Help_Document_FileName', GSR_Attached_FileName);
                    formdata.append('Help_Document_NameID', GSR_Attach_DocName_ID);
                    formdata.append('Help_Byte_SessionName', "GsrAttachment");
                    formdata.append('Help_Post_Area_Name', "Help");
                    formdata.append('Help_Post_Controller_Name', "Attachment");
                    formdata.append('Help_REF_REC_ID', GSR_Attach_RefRecId);
                    formdata.append('Help_REF_SCREEN', GSR_Attach_RefScreen);
                    formdata.append('Help_Document_Description', GSR_DocumentDescription);
                    formdata.append('Help_Checked', false);
                    formdata.append('Help_uploadControlName', "GSR_myFile");
                    formdata.append('Help_uploadControlActionMethod', "New");
                    $.ajax({
                        xhr: function ()
                        {
                            var xhr = new window.XMLHttpRequest();

                            // Upload progress
                            xhr.upload.addEventListener("progress", function (evt)
                            {
                                if (evt.lengthComputable)
                                {
                                    var percentComplete = ((evt.loaded / evt.total) * 100).toFixed();
                                    var message = "Uploading File: " + percentComplete + "%";
                                    if (percentComplete == "100")
                                    {
                                        message = "Writing Files To Disk...";
                                    }
                                    ChangeTextOfLoader(message);
                                }
                            }, false);

                            // Download progress
                            //xhr.addEventListener("progress", function (evt) {
                            //    if (evt.lengthComputable) {
                            //        var percentComplete = ((evt.loaded / evt.total) * 100).toFixed(2);
                            //        // Do something with download progress
                            //        console.log(percentComplete);
                            //    }
                            //}, false);

                            return xhr;
                        },
                        type: 'POST',
                        url: "/Help/Attachment/Frm_Attachment_Window",
                        cache: false,
                        data: formdata,
                        processData: false,
                        contentType: false,
                        success: function (data) {
                            HideLoader();
                            if (data.result) {
                                var result = DevExpress.ui.dialog.alert(data.Message, "Success");
                                result.done(function (dialogResult) {
                                    if (dialogResult) {
                                        var spanEle;
                                        switch (GSR_DocumentDescription) {
                                            case "Program Banner":
                                                spanEle = $("#span_Banner_GSR");
                                                break;
                                            case "Program Promo":
                                                spanEle = $("#span_Promo_GSR");
                                                break;
                                            case "Program Pictures":
                                                spanEle = $("#span_Pictures_GSR");
                                                break;
                                            case "Program Videos":
                                                spanEle = $("#span_Videos_GSR");
                                                break;
                                            case "Program Press Release":
                                                spanEle = $("#span_PressRelease_GSR");
                                                break;
                                            case "Program Pictures And Videos":
                                                spanEle = $("#span_Pictures_GSR");
                                                break;

                                        }
                                        var filename = spanEle.text();
                                        if (IsNullOrWhitespace(null, null, data.FileList) == false) {
                                            if (filename.length == 0) {
                                                filename = data.FileList;
                                            }
                                            else {
                                                filename = filename + ", " + data.FileList;
                                            }
                                            GSR_Is_Document_Attached = true;
                                        }
                                        spanEle.text(filename);
                                    }
                                });
                            }
                            else {
                                DevExpress.ui.dialog.alert(data.Message, "Error");
                            }
                            $.ajax({
                                type: 'GET',
                                url: "/Help/Attachment/Sessionclear?ByteSessionVariable=GsrAttachment",
                                cache: false
                            });
                            GSR_FileUploadSuccessCount = 0;
                        },
                        error: function (jqXHR, textStatus, errorThrown)
                        {
                            HideLoader();
                            console.log(jqXHR);
                            console.log(textStatus);
                            console.log(errorThrown);
                            DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
                        }
                    });
                }
                else
                {
                    DevExpress.ui.dialog.alert("You Have In Total Selected <b>" + formatBytes(totalContent) + "</b> To Upload<br><b>Upto 1 GB Can Be Uploaded At Once<b>", 'Upload Error..');
                }
            }
            else
            {
                GSR_Attached_FileName = "";
            }
            GSR_uploadErrorDuetoFileCount = false;
        }
        function GSR_FileUploaded(e)
        {
            GSR_FileUploadSuccessCount++;
        }
</script>
<script>
        function ActivitiesSelectionChange_GSR(e)
        {
            var listBox = $("#ActivitiesList_GSR").dxList("instance");
            var selecteditemkey = listBox.option("selectedItemKeys")
            if (selecteditemkey != null && selecteditemkey.length > 0)
            {
                $("#SelectedActivities_GSR").val(selecteditemkey.join("!["))
                $(".ActivitiesDetail_GSR").show();
                if (selecteditemkey.includes("Deaddiction"))
                {
                    $(".Deaddiction").show();
                }
                else
                {
                    $(".Deaddiction").hide();
                }
                if (selecteditemkey.includes("Tree Plantation"))
                {
                    $(".TreePlantation").show();
                    if (Tag_GSR == "_New") {
                        if ($("#TreePlantation_DG").dxDataGrid("instance").hasEditData() == false) {
                            $("#TreePlantation_DG").dxDataGrid("instance").addRow();
                            $("#TreePlantation_DG").dxDataGrid("instance").addRow();
                            $("#TreePlantation_DG").dxDataGrid("instance").addRow();
                            $("#TreePlantation_DG").dxDataGrid("instance").addRow();
                            $("#TreePlantation_DG").dxDataGrid("instance").addRow();
                            $("#TreePlantation_DG").dxDataGrid("instance").editCell(0, 0);
                        }
                        else {
                            $("#TreePlantation_DG").dxDataGrid("instance").editCell(0, 0);
                        }
                    }
                }
                else
                {
                    $(".TreePlantation").hide();
                }
            }
            else
            {
                $("#SelectedActivities_GSR").val("");
                $(".Activity_GSR").hide();
                $(".ActivitiesDetail_GSR").hide();
            }
        }
        function GetTreeData_GSR(e) { return Trees_GSR; }
        function createCustomStore_GSR()
        {
            return DevExpress.data.AspNet.createStore({
                key: "Srno",
                loadUrl: "/Facility/ServiceReport/GetTreePlantationDetails",
                updateUrl: "/Facility/ServiceReport/UpdateTreePlantationDetails",
                insertUrl: "/Facility/ServiceReport/InsertTreePlantationDetails",
                deleteUrl: "/Facility/ServiceReport/DeleteTreePlantationDetails"
            });
        }
        function TreePlantation_ToolBarPreparing(e)
        {
            var toolbarItems = e.toolbarOptions.items;
          /*  toolbarItems.push({ location: 'before', html: "<h5>Tree/Plant Plantation Details:</h5>" })*/
            var addRowButton = toolbarItems.find(x => x.name === "addRowButton");
            if (addRowButton)
            {
                addRowButton.options.text = "Add Tree Plantation Detail";
                addRowButton.showText = "always";
            }
            var saveButton = toolbarItems.find(x => x.name === "saveButton");
            if (saveButton)
            {
                saveButton.options.text = "Save Tree Plantation Details Changes";
                saveButton.showText = "always";
                saveButton.visible = false;
            }
            var revertButton = toolbarItems.find(x => x.name === "revertButton");
            if (revertButton) {
                revertButton.options.text = "Discard Tree Plantation Details Changes";
                revertButton.showText = "always";
                revertButton.visible = false;
            }
        }
        function TreeTypeValidation(params)
        {
            console.log(params)
            return $.ajax({
            url: '@Url.Action("CheckUniqueTreeType", "ServiceReport")',
            type: "POST",
            dataType: "json",
            contentType: "application/json",
            data: JSON.stringify({
                ID: params.value
            })
            });
        }
        function TreePlantation_EditorPreparing(e)
        {
            if (e.dataField === "TreeMiscID" && e.parentType === "dataRow")
            {
                e.editorOptions.placeholder = "Select Planted Tree/Plant Type...";
            }
            if (e.dataField === "Count" && e.parentType === "dataRow") {
                e.editorOptions.placeholder = "Enter Count Of Trees/Plants Planted...";
            }
        }
</script>
