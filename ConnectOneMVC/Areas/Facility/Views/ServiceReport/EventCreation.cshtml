
@using DevExtreme.AspNet.Mvc;
@model ConnectOneMVC.Areas.Facility.Models.ServiceReport_ViewModel
@{
    Html.EnableClientValidation();
    Html.EnableUnobtrusiveJavaScript();

    Layout = "~/Views/Shared/_NoLoginLayout.cshtml";

    var SessionGUID = Request.QueryString["SessionGUID"];
    var WingList = Model.WingListData;
    List<string> SelectedWing = new List<string>();
    if (Model.Wings_List_GSR != null) { SelectedWing = Model.Wings_List_GSR.Select(y => y.ID).ToList(); }
    if (string.IsNullOrWhiteSpace(Model.PreSelectedWing) == false)
    {
        SelectedWing.Add(Model.PreSelectedWing);
    }
}
<style>
    .spanMediaTab { word-wrap: break-word; }

    .GSRWing-list .dx-checkbox.dx-state-focused { background: #316ac5; color: #FFFFFF; }

    .ListOneRow .dx-scrollable { overflow-y: hidden }

    #TreePlantation_DG .dx-datagrid-total-footer > .dx-datagrid-content { padding-top: 0px; padding-bottom: 0px; }

    #TreePlantation_DG .dx-button-has-icon .dx-button-content { height: 18px; padding-left: 22px; }

    #TreePlantation_DG .dx-button-has-text .dx-button-content { min-width: 26px; padding-right: 5px; }

    #TreePlantation_DG h5 { margin-top: 1px; }

    #TreePlantation_DG .dx-toolbar .dx-toolbar-items-container { height: 20px; }

    #TreePlantation_DG .dx-datagrid-header-panel .dx-toolbar { margin-bottom: 4px; }

    #TreePlantation_DG .dx-row-removed .dx-datagrid-validator { color: grey !important; text-decoration: line-through; }

    #TreePlantation_DG .dx-datagrid-invalid { background-color: lightpink !important; }

    #Txt_Period_Date_GSR.dx-state-readonly, #Txt_Period_Time_GSR.dx-state-readonly, #Txt_TotalProgBeneficiaries_GSR.dx-state-readonly { border: none; background: #ECF3FB; }

    #Txt_Period_Date_GSR input, #Txt_Period_Time_GSR input, #Txt_TotalProgBeneficiaries_GSR input { text-align: center !important; }

    .dx-datagrid-header-panel .dx-toolbar { margin-bottom: 0px; }
    a { cursor: pointer; }
    form.edit_form .form-field.evc_hd { background: #1D499A }
    .evc_hd h5 { font-size: 16px; margin: 5px 2px; color: #fff }
    .prog_img { width: 42px; height: 42px; border: 1px solid #9fcdfc; margin: 5px; object-fit: cover; float: left; }
</style>
<div id="GodlyServiceReportWindow_DIV">
    <form id="ServiceReportForm" class="edit_form form-horizontal">
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.PopupName_GSR)
        @Html.HiddenFor(x => x.ActionMethod)
        @Html.HiddenFor(x => x.Tag)
        @Html.HiddenFor(x => x.Info_LastEditedOn)
        @Html.HiddenFor(x => x.LastEditedOn)
        @Html.HiddenFor(x => x.TitleX_GSR)
        @Html.HiddenFor(x => x.xID_GSR)
        @Html.HiddenFor(x => x.ReporterCenID)
        @Html.HiddenFor(x => x.ReporterEmail)
        @Html.HiddenFor(x => x.ReporterMobile)
        @Html.HiddenFor(x => x.DocumentNameID)
        @Html.HiddenFor(x => x.Chk_WingBasedFlag_GSR)
        @Html.HiddenFor(x => x.SelectedActivities_GSR)
        @Html.HiddenFor(x => x.ProgType_ID_GSR)
        @Html.HiddenFor(x => x.ProgType_Text_GSR)
        @Html.HiddenFor(x => x.ProgOccasion_Text_GSR)

        <div class="container-fluid">
            <div class="full-width-header-bg2">
                <div class="row">
                    <div class="col-sm-8" style="padding: 0 5px;">
                        <h3 class="popuphead"><i class="fas fa-calendar-alt"></i> Create an Event</h3>
                    </div>
                    <div class="col-sm-4 prm">
                        <h5 class="mand-txt-align">
                            <i class="fas fa-info-circle"></i> Red Fields are mandatory
                        </h5>
                    </div>
                    @Html.ValidationSummary(true, "", new { @class = "text-red" })
                </div>
            </div><!--[Header]-->
            <div class="row">
                <div class="col-sm-12">
                    <div class="form-field">

                        <div class="row">
                            <div class="col-sm-12 form-field evc_hd">
                                <h5><i class="fa fa-info-circle"></i> Event General Info</h5>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-4 col-md-4 col-lg-4">
                                <div class="form-field">
                                    <div class="row">
                                        <img src="https://www.yiwubazaar.com/resources/assets/images/default-product.jpg" class="prog_img" />
                                        @Html.Label("Program Banner (बैनर)", htmlAttributes: new { @class = "control-label text-red" })<br />
                                        @(Html.DevExtreme().Button().ID("Banner_Add_GSR").Text("Upload Banner Image").UseSubmitBehavior(false).OnClick("Banner_Add_GSR_Click").Disabled(Model.ActionMethod == "_Delete" || Model.ActionMethod == "_View"))
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-4 col-md-4 col-lg-4 form-field">
                                @Html.Label("Program Date (प्रोग्राम तिथि) ", htmlAttributes: new { @class = "text-red control-label" })
                                <div class="row">
                                    <div class="col-sm-12">
                                        <div class="row">
                                            <div class="col-sm-1">
                                                @Html.Label("From: ", htmlAttributes: new { @class = "control-label" })
                                            </div>
                                            <div class="col-sm-5">
                                                @(Html.DevExtreme().DateBoxFor(x => x.DE_FR_DT_GSR).CustomDateBox().ID("DE_FR_DT_GSR").Name("DE_FR_DT_GSR").OnValueChanged("Date_EditValueChanged_GSR").Min(new DateTime(1900, 01, 01)))
                                            </div>
                                            <!--</div>--><!---[Date From:]--->
                                            <!--<div class="row">-->
                                            <div class="col-sm-1">
                                                @Html.Label("To: ", htmlAttributes: new { @class = "control-label" })
                                            </div>
                                            <div class="col-sm-5">
                                                @(Html.DevExtreme().DateBoxFor(x => x.DE_TO_DT_GSR).CustomDateBox().ID("DE_TO_DT_GSR").Name("DE_TO_DT_GSR").Min(new DateTime(1900, 01, 01)).OnValueChanged("Date_EditValueChanged_GSR") )
                                            </div>
                                        </div><!---[Date To:]--->
                                    </div>
                                </div>
                            </div>
                            <div class="col-sm-4 col-md-4 col-lg-4 form-field">
                                @Html.Label("Program Time (प्रोग्राम का समय)", htmlAttributes: new { @class = "text-red control-label" })
                                <div class="row">
                                    <div class="col-sm-12">
                                        <div class="row">
                                            <div class="col-sm-1">
                                                @Html.Label("From: ", htmlAttributes: new { @class = "control-label" })
                                            </div>
                                            <div class="col-sm-5">
                                                @(Html.DevExtreme().DateBox().Type(DateBoxType.Time).ID("Txt_Fr_Time_GSR").Name("Txt_Fr_Time_GSR").OnValueChanged("Time_EditValueChanged_GSR").Value(Model.Txt_Fr_Time_GSR).DisplayFormat("hh:mm a").UseMaskBehavior(true).Placeholder("hh:mm AM/PM"))
                                            </div>
                                            <!--</div>--><!---[Time From:]--->
                                            <!--<div class="row">-->
                                            <div class="col-sm-1">
                                                @Html.Label("To: ", htmlAttributes: new { @class = "control-label" })
                                            </div>
                                            <div class="col-sm-5">
                                                @(Html.DevExtreme().DateBox().Type(DateBoxType.Time).ID("Txt_To_Time_GSR").Name("Txt_To_Time_GSR").OnValueChanged("Time_EditValueChanged_GSR").Value(Model.Txt_To_Time_GSR).DisplayFormat("hh:mm a").UseMaskBehavior(true).Placeholder("hh:mm AM/PM") )
                                            </div>
                                        </div><!---[Time To:]--->
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-4 col-md-4 col-lg-4">
                                <div class="form-field">
                                    @Html.Label("Venue", htmlAttributes: new { @class = "control-label text-red" })
                                    @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("Look_MasterProject_GSR").Name("Look_MasterProject_GSR").Placeholder("Select Venue").DataSource(Model.MasterProjectNameList, "ID").OnValueChanged("Look_MasterProjList_EditValueChanged_GSR").DisplayExpr("Name").ValueExpr("ID").Value(Model.Look_MasterProject_GSR).ShowClearButton(false).SearchMode(DropDownSearchMode.Contains))
                                </div>
                            </div>

                            <div class="col-sm-4 col-md-4 col-lg-4">
                                <div class="form-field">
                                    @Html.Label("Geeta Pathshala", htmlAttributes: new { @class = "control-label text-red" })
                                    <small class="pull-right">
                                        <a><b>+ Add</b></a> |
                                        <a><b>Manage</b></a>
                                    </small>
                                    @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("GP_GSR").Name("GP_GSR").Placeholder("Select Geeta Pathshala").DataSource(Model.MasterProjectNameList, "ID").OnValueChanged("Look_MasterProjList_EditValueChanged_GSR").DisplayExpr("Name").ValueExpr("ID").Value(Model.Look_MasterProject_GSR).ShowClearButton(false).SearchMode(DropDownSearchMode.Contains))

                                </div>
                            </div>
                            <div class="col-sm-4 col-md-4 col-lg-4">
                                <div class="form-field">
                                    @Html.Label("Venue Coordinates", htmlAttributes: new { @class = "control-label text-red " })
                                    <small class="pull-right"><a><b>Capture Current Coordinates</b></a></small>
                                    @(Html.DevExtreme().TextBox().CustomTextBox(true).ID("Current_Coordinates_GSR").Name("Current_Coordinates_GSR").Value(Model.Txt_ProgName_GSR).Placeholder("Venue Coordinates..."))
                                </div>
                            </div>

                        </div>

                        <div class="row">
                            <div class="col-sm-8 col-md-8 col-lg-8">
                                <div class="form-field">
                                    @Html.Label("Venue Address", htmlAttributes: new { @class = "control-label text-red " })
                                    @(Html.DevExtreme().TextBoxFor(model => model.Txt_ProgVenue_GSR)
                                    .ID("Txt_ProgVenue_GSR")
                                    .Name("Txt_ProgVenue_GSR")
                                    .Placeholder("Type Program Venue (Place of organizing program)...")
                                    .Value(Model.Txt_ProgVenue_GSR)
                                    .ElementAttr(new Dictionary<string, object>() { { "class", "CleanTextForDB" } }))
                                </div>
                            </div>
                           
                            <div class="col-sm-4 col-md-4 col-lg-4">
                                <div class="form-field" style="padding: 16px 10px 11px;">
                                    <div id="DX-Google" class="dx-button dx-button-normal dx-button-mode-contained dx-widget dx-button-has-text" aria-label="Add" tabindex="0" role="button"><div class="dx-button-content"><span class="dx-button-text">View on Google Maps</span></div></div>
                                </div>
                            </div>
                        </div><!---[Event General Info End]--->


                        <div class="row">
                            <div class="col-sm-12 form-field evc_hd">
                                <h5><i class="fa fa-list-alt"></i> Event Details</h5>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-sm-4 col-md-4 col-lg-4">
                                <div class="form-field">
                                    @Html.Label("Program Name (प्रोग्राम का नाम)", htmlAttributes: new { @class = "control-label text-red " })
                                    @(Html.DevExtreme().TextBox().CustomTextBox(true).ID("Txt_ProgName_GSR").Name("Txt_ProgName_GSR").Value(Model.Txt_ProgName_GSR).Placeholder("Type Program Name..."))
                                </div>
                            </div>
                            <div class="col-sm-4 col-md-4 col-lg-4">
                                <div class="form-field">
                                    @Html.Label("Master Project (मुख्य प्रोजैक्ट)", htmlAttributes: new { @class = "control-label text-red" })
                                    @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("Look_MasterProject_GSR").Name("Look_MasterProject_GSR").Placeholder("Select Master Project Name...").DataSource(Model.MasterProjectNameList, "ID").OnValueChanged("Look_MasterProjList_EditValueChanged_GSR").DisplayExpr("Name").ValueExpr("ID").Value(Model.Look_MasterProject_GSR).ShowClearButton(false).SearchMode(DropDownSearchMode.Contains))
                                </div>
                            </div>
                            <div class="col-sm-4 col-md-4 col-lg-4">
                                <div class="form-field">
                                    @Html.Label("Project Name (प्रोजैक्ट का नाम)", htmlAttributes: new { @class = "control-label text-red" })
                                    @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("Look_ProjList_GSR").Name("Look_ProjList_GSR").Placeholder("Select Project Name...").DataSource(Model.ProjectNameList, "ID").OnValueChanged("Look_ProjList_EditValueChanged_GSR").DisplayExpr("Name").ValueExpr("ID").Value(Model.Look_ProjList_GSR).ShowClearButton(false).SearchMode(DropDownSearchMode.Contains))

                                </div>
                            </div>
                        </div>


                        <div class="row">

                            <div class="col-sm-8 col-md-8 col-lg-8">
                                <div class="form-field">
                                    @Html.Label("Expected Guests (with Designation) (अनुमानित अतिथि (पद सहित))", htmlAttributes: new { @class = "control-label", @style = "font-weight:500" })
                                    @(Html.DevExtreme().TextBox()
                                                    .ID("Txt_GuestName_1_GSR")
                                                    .Name("Txt_GuestName_1_GSR")
                                                    .ReadOnly(false)
                                                    .Placeholder("Type Guests Name (comma separated with Designation)...")
                                                    .Value(Model.Txt_GuestName_1_GSR)
                                    .ElementAttr(new Dictionary<string, object>() { { "class", "CleanTextForDB" } })
                    )
                                </div>
                            </div>


                            <div class="col-sm-4 col-md-4 col-lg-4">
                                <div class="form-field">
                                    @Html.Label("Occasion (अवसर)", htmlAttributes: new { @class = "control-label text-red" })
                                    <br /><select style="height:22px"><option>Multiselect dropdown devexpress</option></select>
                                </div>
                            </div>

                            <div class="col-sm-4">
                                <div class="form-field">
                                    @Html.Label("Speaker(s) (वक्ता)", htmlAttributes: new { @class = "control-label", @style = "font-weight:500" })
                                    @(Html.DevExtreme().TextBox()
                                                    .ID("Txt_ProgSpeaker_GSR")
                                                    .Name("Txt_ProgSpeaker_GSR")
                                                    .ReadOnly(false)
                                                    .Placeholder("Type Speaker Details...")
                                                    .Value(Model.Txt_ProgSpeaker_GSR)
                                    .ElementAttr(new Dictionary<string, object>() { { "class", "CleanTextForDB" } })
                    )
                                </div>
                            </div>

                            <div class="col-sm-4 col-md-4 col-lg-4">
                                <div class="form-field">
                                    @Html.Label("Category", htmlAttributes: new { @class = "control-label text-red" })
                                    <br /><select style="height:22px"><option>Multiselect dropdown devexpress</option></select>
                                </div>
                            </div>
                            <div class="col-sm-4 col-md-4 col-lg-4">
                                <div class="form-field">
                                    <label id="lbl_beneficiary_GSR" class="text-red control-label">Expected Beneficiaries Count (अनुमानित लाभ लेने वाले की संख्या)</label>
                                    @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Txt_ProgBeneficiaries_GSR").Name("Txt_ProgBeneficiaries_GSR").Max(999999999).Value(Model.Txt_ProgBeneficiaries_GSR)
                  .OnValueChanged("Txt_ProgBeneficiaries_EditValueChanged_GSR").Format("#").Placeholder("Type No. of Beneficiaries...").OnInput("Txt_ProgBeneficiaries_OnInput") )
                                </div>
                            </div>

                            <div class="col-sm-4 col-md-4 col-lg-4">
                                <div class="form-field">
                                    @Html.Label("Audience Type", htmlAttributes: new { @class = "control-label text-red" })
                                    @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("Audience_Type_GSR").Name("Audience_Type_GSR").Placeholder("Select Audience Type").DataSource(Model.MasterProjectNameList, "ID").OnValueChanged("Look_MasterProjList_EditValueChanged_GSR").DisplayExpr("Name").ValueExpr("ID").Value(Model.Look_MasterProject_GSR).ShowClearButton(false).SearchMode(DropDownSearchMode.Contains))
                                </div>
                            </div>

                            <div class="col-sm-4 col-md-4 col-lg-4">
                                <div class="form-field">
                                    @Html.Label("Event Mode", htmlAttributes: new { @class = "control-label text-red" })
                                    @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("Event_Mode_GSR").Name("Event_Mode_GSR").Placeholder("Select Event Mode").DataSource(Model.MasterProjectNameList, "ID").OnValueChanged("Look_MasterProjList_EditValueChanged_GSR").DisplayExpr("Name").ValueExpr("ID").Value(Model.Look_MasterProject_GSR).ShowClearButton(false).SearchMode(DropDownSearchMode.Contains))
                                </div>
                            </div>

                            <div class="col-sm-4 col-md-4 col-lg-4">
                                <div class="form-field">
                                    @Html.Label("Event Rating", htmlAttributes: new { @class = "control-label text-red" })
                                    <br /><select style="height:22px"><option>Devexpress Rating plugin</option></select>
                                </div>
                            </div>

                            <div class="col-sm-6 col-md-6 col-lg-6">
                                <div class="form-field">
                                    <label class="control-label" style="font-weight:500">Wings Involved (शामिल विंग्स) ** (Please Skip If there is no wing)</label>
                                    @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("Look_Wings_GSR").Name("Look_Wings_GSR").Placeholder("Select Wings...").Value(SelectedWing.ToArray()).DataSource(Model.WingListData, "ID")
.ValueExpr("ID").DisplayExpr("Name").ContentTemplate(@<text>
                    @(Html.DevExtreme().DataGrid().CustomDataGrid().ID("Wings_GSR_datagrid")
                                   .Columns(columns =>
                                   {
                                       columns.Add().DataField("Name").Caption("Wings");
                                       columns.Add().DataField("ID").Caption("ID").Visible(false).SortingMethod("sortWingType_GSR").SortOrder(SortOrder.Asc);
                                   })
                                   .OnRowClick("DG_OnRowClick_GSR")
                                   .Selection(s => s.Mode(SelectionMode.Multiple).ShowCheckBoxesMode(GridSelectionShowCheckBoxesMode.Always).AllowSelectAll(false))
                                   .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys);};}"))
                    </text>).OnValueChanged("Wings_ValueChange_GSR"))
                                    @{
                                        @Html.Hidden("WingListData_Count", WingList.Count)
                                        for (int i = 0; i < WingList.Count; i++)
                                        {
                                            @Html.Hidden("Wings_List_GSR[" + i + "].ID", WingList[i].ID)
                                            @Html.Hidden("Wings_List_GSR[" + i + "].Selected")
                                        }
                                    }
                                </div>
                            </div>

                            <div class="col-sm-6 col-md-6 col-lg-6">
                                <div class="form-field">

                                    @*<label class="control-label pll" style="font-weight: 500; color: #6952C2; padding-top: 5px">   Note: To add new line press "Enter" Key...</label>*@
                                    <div class="row">
                                        <label class="control-label" style="font-weight:500">Live/Recording/Promo/News Link (लाइव/रिकॉर्डिंग/प्रोमो/समाचार लिंक)</label>
                                        @(Html.DevExtreme().TextBox().ID("Txt_NewsLink_GSR").Name("Txt_NewsLink_GSR").Value(Model.Txt_NewsLink_GSR).ElementAttr(new Dictionary<string, object>() { { "class", "CleanTextForDB" } })
                                                                              .Placeholder("Provide YouTube or other link if any...") )
                                    </div>
                                </div>
                            </div>

                                <div class="col-sm-6 col-md-6 col-lg-6">
                                    <div class="form-field">

                                        @Html.Label("Brief of the Program (कार्यक्रम का संक्षिप्त विवरण)", htmlAttributes: new { @class = "control-label", @style = "font-weight:500" })

                                        @(Html.DevExtreme().TextArea()
                                                    .ID("Txt_ProgBrief_GSR")
                                                    .Name("Txt_ProgBrief_GSR")
                                                    .ReadOnly(false)
                                                    //.Height(200)
                                                    .Height(56)
                                                    .Placeholder("Type Brief of the Program...")
                                                    .Value(Model.Txt_ProgBrief_GSR)
                                    .ElementAttr(new Dictionary<string, object>() { { "class", "CleanTextForDB" } })
                    )

                                    </div>
                                </div>

                                <div class="col-sm-6 col-md-6 col-lg-6">

                                    <div class="form-field clearfix">
                                        <div class="pull-left">
                                            @Html.Label("Event Related Folders/Promo/Docs (तस्वीरें/वीडियो)", htmlAttributes: new { @class = "control-label", @style = "font-weight:500" })

                                            @(Html.DevExtreme().Button().ID("Banner_Pictures_GSR").Text("Upload Promo Pics/Videos/Docs").UseSubmitBehavior(false).OnClick("Pictures_Add_GSR_Click").Disabled(Model.ActionMethod=="_Delete"|| Model.ActionMethod == "_View"))
                                            @*@(Html.DevExtreme().Button().ID("Promo_Add_GSR").Text("Upload Promo ").UseSubmitBehavior(false).OnClick("Promo_Add_GSR_Click").Disabled(Model.ActionMethod == "_Delete" || Model.ActionMethod == "_View"))*@
                                            @*@(Html.DevExtreme().Button().ID("PressRelease_Add_GSR").Text("Add").UseSubmitBehavior(false).OnClick("PressRelease_Add_GSR_Click").Disabled(Model.ActionMethod == "_Delete" || Model.ActionMethod == "_View"))*@
                                        </div>
                                        <div class="col-sm-9 spanMediaTab pull-left">
                                            <span id="span_Pictures_GSR">@Model.ProgramPictures_GSR</span>
                                            <img src="https://www.yiwubazaar.com/resources/assets/images/default-product.jpg" class="prog_img">
                                            <img src="https://www.yiwubazaar.com/resources/assets/images/default-product.jpg" class="prog_img">
                                            <img src="https://www.yiwubazaar.com/resources/assets/images/default-product.jpg" class="prog_img">
                                        </div>
                                    </div>
                                </div>

                            </div>

                            <!---[Event Event Details]--->


                            <div class="row">
                                <div class="col-sm-12">
                                    <div class="form-field">

                                        <div class="row">
                                            <div class="col-sm-12 form-field evc_hd">
                                                <h5><i style="transform:rotate(90deg)" class="fa fa-phone-square"></i> Service Contact details</h5>
                                            </div>
                                        </div>
                                        <div class="row">

                                            <div class="col-sm-3 col-md-3 col-lg-3 form-field">
                                                @Html.Label("Service Contact Info (सेवा संपर्क जानकारी) ", htmlAttributes: new { @class = "text-red control-label" })
                                                <br />
                                                <input type="radio" name="sci" /> Centre
                                                &nbsp;
                                                <input type="radio" name="sci" /> Service Responsible Person
                                            </div>

                                            <div class="col-sm-4 col-md-4 col-lg-4 form-field">
                                                @Html.Label("Service Responsible Person (जिम्मेवार सेवाधारी) ", htmlAttributes: new { @class = "text-red control-label" })
                                                <small class="pull-right">
                                                    <a><b>+ Add</b></a> |
                                                    <a><b>Edit</b></a>
                                                </small>
                                                @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("SRP_GSR").Name("SRP_GSR").Placeholder("Select Responsible Person").DataSource(Model.MasterProjectNameList, "ID").OnValueChanged("Look_MasterProjList_EditValueChanged_GSR").DisplayExpr("Name").ValueExpr("ID").Value(Model.Look_MasterProject_GSR).ShowClearButton(false).SearchMode(DropDownSearchMode.Contains))

                                            </div>

                                            <div class="col-sm-2 col-md-2 col-lg-2">
                                                <div class="form-field">
                                                    @Html.Label("Contact Number", htmlAttributes: new { @class = "control-label text-red " })
                                                    @(Html.DevExtreme().TextBox().CustomTextBox(true).ID("Contact_Number_GSR").Name("Contact_Number_GSR").Value(Model.Txt_ProgName_GSR).Placeholder("Responsible Person Contact Number..."))
                                                </div>
                                            </div>

                                            <div class="col-sm-3 col-md-3 col-lg-3">
