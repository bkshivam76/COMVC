@using DevExtreme.AspNet.Mvc;
@model ConnectOneMVC.Areas.Facility.Models.ServiceReport_ViewModel

<div class="row">
    <div class="col-sm-12">
    <div class="form-field">

        @Html.Label("Program Follow Up Information: ", htmlAttributes: new { @class = "control-label", @style = "font-weight:500" })

        @(Html.DevExtreme().TextArea()
                                                    .ID("Txt_ProgFollowUp_GSR")
                                                    .Name("Txt_ProgFollowUp_GSR")
                                                    .ReadOnly(false)
                                                    .Height(200)
                                                    .Placeholder("Type Program Follow Up Information...")
                                                    .Value(Model.Txt_ProgFollowUp_GSR)
                                    .ElementAttr(new Dictionary<string, object>() { { "class", "CleanTextForDB" } })
                    )

    </div>
</div>
</div>
