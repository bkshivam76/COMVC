            //column.FieldName = "SR_PROG_FR_DATE";
            column.Caption = "Date/time";
            column.Visible = true;
            column.MinWidth = 100;
            column.ColumnType = MVCxGridViewColumnType.DateEdit;
            column.PropertiesEdit.DisplayFormatString = "dd-MM-yyyy";
            column.SetDataItemTemplateContent(c =>
            {
                var firstline = Convert.ToDateTime(DataBinder.Eval(c.DataItem, "SR_PROG_FR_DATE")).ToString("dd-MMM-yyyy");
                var timediff = DataBinder.Eval(c.DataItem, "SR_PROG_FR_TIME") + " to " + DataBinder.Eval(c.DataItem, "SR_PROG_TO_TIME");
                if (Convert.ToDateTime(DataBinder.Eval(c.DataItem, "SR_PROG_FR_DATE")).ToString("dd-MMM-yyyy") != Convert.ToDateTime(DataBinder.Eval(c.DataItem, "SR_PROG_TO_DATE")).ToString("dd-MMM-yyyy"))
                {
                    firstline = Convert.ToDateTime(DataBinder.Eval(c.DataItem, "SR_PROG_FR_DATE")).ToString("dd") + " - " + Convert.ToDateTime(DataBinder.Eval(c.DataItem, "SR_PROG_TO_DATE")).ToString("dd-MMM, yyyy");
                }
                ViewContext.Writer.Write(
                    "<p>" + firstline + "</p>" +
                    "<p>" + timediff + "</p>"
                );
            });
        });
