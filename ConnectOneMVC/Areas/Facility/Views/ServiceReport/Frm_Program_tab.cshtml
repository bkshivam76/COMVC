                <div class="col-sm-2">
                    <label class="control-label text-red">Deaddiction Pledge Count:</label>
                </div>
                <div class="col-sm-2">
                    @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Txt_DeaddictionPledgeCount_GSR").Name("Txt_DeaddictionPledgeCount_GSR")
        .Format("#").Placeholder("Count").ReadOnly(false).FocusStateEnabled(true).Value(Model.Txt_DeaddictionPledgeCount_GSR) )
                </div>
                <div>&nbsp;&nbsp;&nbsp;    नशामुक्ति की प्रतिज्ञा करने वालो की संख्या यहाँ लिखें </div>
            </div>
        </div>

        <div class="form-field TreePlantation Activity_GSR" style="display:none">
            @(Html.DevExtreme().DataGrid<ConnectOneMVC.Areas.Facility.Models.TreePlantationDetails>()
        .ID("TreePlantation_DG")
        .ShowBorders(true)
        .ShowRowLines(true)
        .Paging(paging => paging.Enabled(false))
        .Editing(editing =>
        {
            editing.Mode(GridEditMode.Batch);
            editing.AllowAdding(Model.ActionMethod == "_Delete" ? false : true);
            editing.AllowDeleting(Model.ActionMethod == "_Delete" ? false : true);
            editing.AllowUpdating(Model.ActionMethod == "_Delete" ? false : true);
            editing.ConfirmDelete(false);
            editing.SelectTextOnEditStart(true);
            editing.StartEditAction(GridStartEditAction.Click);
        })
        .Columns(columns =>
        {
            columns.AddFor(m => m.TreeMiscID).Lookup(lookup => lookup.DataSource(d => d.Mvc().Controller("ServiceReport").LoadAction("LookUp_Get_TreePlantList").Key("ID").LoadMode(DataSourceLoadMode.Raw)).DisplayExpr("Name").ValueExpr("ID"));
            columns.AddFor(m => m.Count);
            columns.AddFor(m => m.KP_PlantID).Visible(false);
        })
        .OnToolbarPreparing("TreePlantation_ToolBarPreparing")
        .OnEditorPreparing("TreePlantation_EditorPreparing")
        .DataSource(new JS("createCustomStore_GSR()"))
        .Summary(s => s.TotalItems(items => { items.AddFor(m => m.Count).SummaryType(SummaryType.Sum); }).RecalculateWhileEditing(true)))
        </div>
        <div class="form-field BloodDonation Activity_GSR" style="display:none">
            <div class="row">
                <div class="col-sm-2">
                    <label class="control-label text-red">No of Units Blood Donated:</label>
                </div>
                <div class="col-sm-2">
                    @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Txt_BloodDonationUnitsCount_GSR").Name("Txt_BloodDonationUnitsCount_GSR")
        .Format("#").Placeholder("Count").ReadOnly(false).FocusStateEnabled(true).Value(Model.Txt_BloodDonationUnitsCount_GSR) )
                </div>
                <div>&nbsp;&nbsp;&nbsp;  कितना यूनिट्स रक्तदान किया उसका काउंट यहाँ लिखें </div>
            </div>
        </div>
        <div class="form-field AwardsReceived Activity_GSR" style="display:none">
            <div class="row">
                <div class="col-sm-2">
                    <label class="control-label text-red">No of Awards Received To Brahma Kumaris:</label>
                </div>
                <div class="col-sm-2">
                    @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Txt_AwardsReceivedCount_GSR").Name("Txt_AwardsReceivedCount_GSR")
        .Format("#").Placeholder("Count").ReadOnly(false).FocusStateEnabled(true).Value(Model.Txt_AwardsReceivedCount_GSR) )
                </div>
                <div>&nbsp;&nbsp;&nbsp;  ब्रह्मा कुमारिस को मिली हुई अवार्ड के बारे में नीचे संक्षिप्त विवरण में लिखें </div>
            </div>
        </div>

    </div>
</div>
