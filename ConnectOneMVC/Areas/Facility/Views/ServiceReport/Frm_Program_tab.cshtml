@using DevExtreme.AspNet.Mvc;
@model ConnectOneMVC.Areas.Facility.Models.ServiceReport_ViewModel
<div class="row">
    <div class="col-sm-6 col-md-6 col-lg-6" style="display:none">
        <div class="form-field" style="padding-bottom:28px">
            @Html.Label("Master Project (मुख्य प्रोजैक्ट)", htmlAttributes: new { @class = "control-label text-red" })
            @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("Look_MasterProject_GSR").Name("Look_MasterProject_GSR").Placeholder("Select Master Project Name...").DataSource(Model.MasterProjectNameList, "ID").OnValueChanged("Look_MasterProjList_EditValueChanged_GSR").DisplayExpr("Name").ValueExpr("ID").Value(Model.Look_MasterProject_GSR).ShowClearButton(false).SearchMode(DropDownSearchMode.Contains))
        </div>
    </div>@*Hidden Element*@

    <div class="col-sm-6 col-md-6 col-lg-6">
        <div class="row">
            <div class="col-sm-6">
                <div class="form-field" style="padding-bottom:28px">
                    @Html.Label("Program Name (प्रोग्राम का नाम)", htmlAttributes: new { @class = "control-label text-red " })
                    @(Html.DevExtreme().TextBox().CustomTextBox(true).ID("Txt_ProgName_GSR").Name("Txt_ProgName_GSR").Value(Model.Txt_ProgName_GSR).Placeholder("Type Program Name...").MaxLength(59))
                </div>
            </div>
            <div class="col-sm-6">
                <div class="form-field" style="padding-bottom:28px">
                    <label class="control-label text-red">Program Type (प्रोग्राम का प्रकार)</label>
                    @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("Look_ProgType_GSR").Name("Look_ProgType_GSR").Placeholder("Select Type Of Program...").Value(Model.ProgType_ID_GSR.Split(new string[] { "![" }, StringSplitOptions.None)).DataSource(Model.ProgType_Data, "ID")
                        .ValueExpr("ID").DisplayExpr("Name").ContentTemplate(@<text>
                    @(Html.DevExtreme().DataGrid().CustomDataGrid().ID("ProgType_GSR_datagrid")
                        .Columns(columns =>
                        {
                            columns.Add().DataField("Name").Caption("Program Type");
                            columns.Add().DataField("ID").Caption("ID").Visible(false).SortingMethod("sortProgType_GSR").SortOrder(SortOrder.Asc);
                        })
                        .OnRowClick("DG_OnRowClick_GSR")
                        .Selection(s => s.Mode(SelectionMode.Multiple).ShowCheckBoxesMode(GridSelectionShowCheckBoxesMode.Always).AllowSelectAll(false))
                        .FilterRow(s=>s.Visible(false))
                        .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys);};}"))
                    </text>).OnValueChanged("ProgType_ValueChange_GSR"))
            </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-md-6 col-lg-6">
            <div class="form-field" style="padding-bottom:4px">
