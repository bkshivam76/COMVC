    <script>
        function OrganiserNameCustomItemCreating_GSR(e) {
            if (e.text == null || e.text.length == 0) {
                e.customItem = null;
                return;
            }
            var dataSource = e.component.getDataSource();
            var newItem = { CEN_NAME: e.text };
            var result = dataSource.store().insert(newItem);

            result.done(function () {
                dataSource.reload().done(function () {
                    e.component.option("value", e.text);
                    //Vehiclies_Cmd_Make = e.text;
                    ////Get_Vehicle_Model_List();
                });
            })
            e.customItem = result;
        }
        function AddCustomDatatoOrganiserName()
        {
            var OrganizerName_GSR = $("#Txt_Organiser_GSR").dxSelectBox("instance");
            var dataSource = OrganizerName_GSR.getDataSource();
            var dataItems = dataSource.items();
            var flag = false;
            for (var i = 0; dataItems.length > i; i++)
            {
                if (dataItems[i].CEN_NAME == "@Model.Txt_Organiser_GSR")
                {
                    flag = true;
                    break;
                }
            }
            if (flag == true)
            {
                OrganizerName_GSR.option("value", "@Model.Txt_Organiser_GSR");
            }
            else
            {
                var newItem = { CEN_NAME: TransformText("@Model.Txt_Organiser_GSR") } //, ID: TransformText("@Model.Txt_Organiser_GSR") };
                var result = dataSource.store().insert(newItem);
                result.done(function ()
                {
                    dataSource.reload().done(function ()
                    {
                        //OrganizerName_GSR.reset()
                        OrganizerName_GSR.option("value", TransformText("@Model.Txt_Organiser_GSR"));
                    })
                })
            }
        }
    </script>
