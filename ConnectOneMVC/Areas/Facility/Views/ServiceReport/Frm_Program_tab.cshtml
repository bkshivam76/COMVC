            <div class="row">
                <div class="col-sm-12 col-md-12 col-lg-12 ListOneRow radiobtn-outer mrt-4" id="ActivitiesList_GSR_Div" style="height:31px">
                    <div class="dx-texteditor-container">
                        @(Html.DevExtreme().List().CustomList().ID("ActivitiesList_GSR")
            .DataSource(new object[] {
                new { text = "Deaddiction (व्यसन मुक्ति)", value = "Deaddiction", disabled = Model.ActionMethod == "_Delete" ? true : false },
                new { text = "Tree Plantation (वृक्षारोपण)", value = "Tree Plantation", disabled = Model.ActionMethod == "_Delete" ? true : false },
                new { text = "Blood Donation (रक्तदान)", value = "Blood Donation", disabled = Model.ActionMethod == "_Delete" ? true : false },
                new { text = "Awards Received (अवार्डस)", value = "Awards Received", disabled = Model.ActionMethod == "_Delete" ? true : false },
            }, "value")
