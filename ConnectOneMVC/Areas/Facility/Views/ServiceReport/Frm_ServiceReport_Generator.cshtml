                </div>
            </div>
        <div class="col-sm-2" style="margin-top:1px"></div>

    </div>

</div>

<script>
    var fromdate_reportGen = null; var todate_reportGen = null; var locationtype_reportGen = null;
    function fromdate_Valuechanged_ReportGen(e) {
        
        fromdate_reportGen = $("#fromdate_ReportGen").dxDateBox("instance").option("value");
        fromdate_reportGen == null ? null : JS_Json_Date_To_ddMMyyyy(fromdate_reportGen)
    }
    function todate_Valuechanged_ReportGen(e) {
        todate_reportGen = $("#todate_ReportGen").dxDateBox("instance").option("value");
        todate_reportGen == null ? null : JS_Json_Date_To_ddMMyyyy(todate_reportGen)
    }
    function locationtype_reportGen_onValueChanged(e) {
        locationtype_reportGen = $("#LocationType_ReportGen").dxSelectBox("instance").option("value");
    }
    //function generateReport_ReportGen_Onclick() {
    //    fromdate_reportGen = $("#fromdate_ReportGen").dxDateBox("instance").option("value");
    //    todate_reportGen = $("#todate_ReportGen").dxDateBox("instance").option("value");
    //    fromdate_reportGen == null ? null : JS_Json_Date_To_ddMMyyyy(fromdate_reportGen)
    //    todate_reportGen == null ? null : JS_Json_Date_To_ddMMyyyy(todate_reportGen)
    //    locationtype_reportGen = $("#LocationType_ReportGen").dxSelectBox("instance").option("value");
    //    var gridView = $("#GeneratedReport_ReportGen_datagrid").dxDataGrid("instance");
    //    gridView.refresh(true)
    //}
    function generateReport_ReportGen_Onclick() {
        fromdate_reportGen = $("#fromdate_ReportGen").dxDateBox("instance").option("value");
        todate_reportGen = $("#todate_ReportGen").dxDateBox("instance").option("value");
        fromdate_reportGen == null ? null : JS_Json_Date_To_ddMMyyyy(fromdate_reportGen)
        todate_reportGen == null ? null : JS_Json_Date_To_ddMMyyyy(todate_reportGen)
        locationtype_reportGen = $("#LocationType_ReportGen").dxSelectBox("instance").option("value");
        document.getElementById("fromdt_ReportGen").innerHTML = moment(fromdate_reportGen).format("DD MMM YYYY");
        document.getElementById("todt_ReportGen").innerHTML = moment(todate_reportGen).format("DD MMM YYYY");
        $.ajax({
            type: 'GET',
            url: "/Facility/ServiceReport/Generate_ServiceReport_Period",
            cache: false,
            data:
            {
                fromdate: JS_Json_Date_To_ddMMyyyy(fromdate_reportGen),
                todate: JS_Json_Date_To_ddMMyyyy(todate_reportGen),
                locationtype: locationtype_reportGen,
                
            },
            success: function (data) {
                //debugger;
                HideLoader();
                /*jsonData = JSON.parse(data)*/
                var tbody = d3.select("#data-table tbody");
                // Remove all HTML content under the div
                tbody.selectAll('*').remove();
                renderCards(data)
            },
            error: function (jqXHR, textStatus, errorThrown) {
                HideLoader();
                
            }
        });
        
    }

    function renderCards(data) {
        // Select the table body
        var tbody = d3.select("#data-table tbody");

        // Bind JSON data to table rows and cells
        var rows = tbody.selectAll("tr")
            .data(data)
            .enter()
            .append("tr");

        // Add cells for each data point in the rows
        rows.selectAll("td")
            .data(function (d) {
                return [moment(d.SR_PROG_FR_DATE).format("DD MMM YYYY"), moment(d.SR_PROG_TO_DATE).format("DD MMM YYYY"), d.SR_PROG_NAME, d.Beneficiaries];
            })
            .enter()
            .append("td")
            .text(function (d) {
                return d;
            });
    }

</script>

