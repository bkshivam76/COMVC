
@using DevExtreme.AspNet.Mvc;
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.4.0/jspdf.umd.min.js"></script>
<script src="https://d3js.org/d3.v7.min.js"></script>
<style>
    #downloadableDiv_ReportGen table { border-collapse: collapse; border: 1px solid black; width: 100%;  }
    #downloadableDiv_ReportGen th, #downloadableDiv_ReportGen td { border: 1px solid black; padding: 8px; text-align: left;  }
    #downloadableDiv_ReportGen #data-table tr:first-child, #downloadableDiv_ReportGen #data-table tr:nth-child(2), #downloadableDiv_ReportGen #data-table tr:nth-child(4) { height: 15px; }
    #downloadableDiv_ReportGen #data-table tr:not(:first-child):not(:nth-child(2)) { height: 25px; }
    .table-container {
        max-height: 500px; /* Set the maximum height for the container */
        overflow-y: auto; /* Enable vertical scrollbar when content overflows */
        border: 1px solid #ccc; /* Optional: Add a border for styling */
    }
</style>


<div>
    <div class="row">
        <div class="col-md-3 col-sm-3 col-xs-3">
            <div class="form-field">
                <label>From Date:</label>
                @(Html.DevExtreme().DateBox().CustomDateBox().ID("fromdate_ReportGen").Name("fromdate_ReportGen").ShowClearButton(true)@*.Value(Model.fromdate)*@
                            .Type(DateBoxType.Date).Placeholder("From Date").Min(new DateTime(1990, 01, 01)).Max(new DateTime(2038, 12, 31)).OnValueChanged("fromdate_Valuechanged_ReportGen")
                        )
            </div>
        </div>

        <div class="col-md-3 col-sm-3 col-xs-3">
            <div class="form-field">
                <label>To Date:</label>
                @(Html.DevExtreme().DateBox().CustomDateBox().ID("todate_ReportGen").Name("todate_ReportGen").ShowClearButton(true)@*.Value(Model.todate)*@
                                    .Type(DateBoxType.Date).Placeholder("To Date").Min(new DateTime(1990, 01, 01)).Max(new DateTime(2038, 12, 31)).OnValueChanged("todate_Valuechanged_ReportGen")
                                )
            </div>
        </div>
        <div class="col-md-3 col-sm-3 col-xs-3">
            <div class="form-field">
                <label>Location Type:</label>
                @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("LocationType_ReportGen").Name("LocationType_ReportGen").Items(new[] { "all", "inside", "outside" }).Value("all").ShowClearButton(false)
                    .Placeholder("Select Location type").OnValueChanged("locationtype_reportGen_onValueChanged")
                )
            </div>
        </div>
        <div class="col-md-3 col-sm-3 col-xs-3">
            <div class="form-field">
                <label></label>
                @(Html.DevExtreme().Button().ID("generateReport_ReportGen").Text("Generate Report").OnClick("generateReport_ReportGen_Onclick")   )
            </div>
        </div>

    </div>
    <div class="text-right">
        @(Html.DevExtreme().Button().ID("exportButton_ReportGen").Text("Download PDF").OnClick("downloadReport_Onclick"))
    </div>
