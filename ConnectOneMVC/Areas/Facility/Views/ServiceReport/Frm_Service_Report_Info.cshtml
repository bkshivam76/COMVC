    <script>
        $(document).ready(function ()
        {
            if ("@Service_Report_AddRight"=="False")
            {
                $("#GSRNew").hide();
            }
            if ("@Service_Report_UpdateRight"=="False")
            {
                $("#GSREdit").hide();
            }
            if ("@Service_Report_DeleteRight"=="False")
            {
                $("#GSRDelete").hide();
            }
            if ("@Service_Report_ExportRight"=="False")
            {
                $("#ServiceReportModelListPreview").hide();
            }
            $(".ServiceReportListGrid_PreviewRow").hide();
            GetSessionStorage("ServiceReportListGrid");
            if (ServiceReport_SetVouchingModeOn == true)
            {
                $("#ServiceReportViewModeSwitch").dxSwitch("instance").option("value", true);
            }
        });
        function DataNavigation_GSR(Action)
        {
            if (Action == "NEW") {
                if ("@Service_Report_AddRight" == "False") {
                    DevExpress.ui.dialog.alert("Not Allowed", 'No Rights'); return;
                }
                ShowLoader();
                OpenDynamicPopup("New ~ Godly Service Report", "@Url.Action("Frm_Service_Report_Window", "ServiceReport", new { @area = "Facility" })?ActionMethod=_New", "100%", 1265, false, null);
                HideLoader();
            }
            else if (Action == "EDIT" || Action == "DELETE") {
                if (!"@Service_Report_UpdateRight" || !"@Service_Report_DeleteRight") {
                    DevExpress.ui.dialog.alert("Not Allowed", 'No Rights'); return;
                }
                if (ServiceReport_ID == "" || ServiceReport_ID == null || ServiceReport_ID == 'undefined') {
                    DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                    return;
                }
                $.ajax({
                    type: 'GET',
                    async: false,
                    url: "/Facility/ServiceReport/Frm_Service_Report_Window",
                    cache: false,
                    data:
                    {
                        ActionMethod: Action == "EDIT" ? "_Edit" : "_Delete",
                        xID: ServiceReport_ID,
                        Info_LastEditedOn: JS_Json_Date_To_ddMMyyyy(ServiceReport_Edit_Date)
                    },
                    success: function (data) {
                        ShowLoader();
                        OpenPopup("Dynamic_Content_popup", Action == "EDIT" ? "Edit ~ Godly Service Report" : "Delete ~ Godly Service Report", null, "100%", 1265, true, data);
                        HideLoader();
                    }
                });
            }
            else if (Action == "CREATEFORM") {
                if (ServiceReport_ID == "" || ServiceReport_ID == null || ServiceReport_ID == 'undefined') {
                    DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                    return;
                }
                CreateNewForm("_New", ServiceReport_ID)
            }
            else if (Action == "BULK_ALLOTMENT")
            {
                if (ServiceReport_ID == "" || ServiceReport_ID == null || ServiceReport_ID == 'undefined') {
                    DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                    return;
                }
                if (ServiceReport_FORM_INST_ID == null || ServiceReport_FORM_INST_ID == 0)
                {
                    DevExpress.ui.dialog.alert("Selected Service Report Does Not Have Any Registration Form Created", "Alert");
                    return;
                }
                ShowLoader();
                BulkAllotment_Accommodation(ServiceReport_FORM_INST_ID, 0, ServiceReport_ID);
            }
        }
        function AfterWindowClose_GSR(ActionMethod = "", xID = "")
        {
            if (ActionMethod == "_Delete" || ActionMethod == "Delete")
            {
                RefreshGridView("ServiceReportListGrid");
                return;
            }
            if (ActionMethod.includes("New"))
            {
                ServiceReport_MoreEntry = true;
            }
            SR_Select_xid = xID;
            RefreshGridView("ServiceReportListGrid");
        }
        function OnServiceReportListPreviewClick()
        {
            if (!"@Service_Report_ExportRight")
            {
                DevExpress.ui.dialog.alert("Not Allowed", 'No Rights'); return;
            }
            ShowLoader();
            OpenPopup("Service_Report_modal", "Export Option", "@Url.Action("Frm_Export_Options", "ServiceReport", new { @area = "Facility" })", "auto",130);
        }
        function closeServiceReport()
        {
            $(".TabPanalMenu-tabs .active span").click();
        }

        $(".TabPanalMenu-tabs .active span").on("click", function () {
            $.ajax({
                type: 'GET',
                url: "/Facility/ServiceReport/SessionClear",
                cache: false
            });
            CloseRightPane();
            ClearLeftPane();
            CloseLeftPane();
