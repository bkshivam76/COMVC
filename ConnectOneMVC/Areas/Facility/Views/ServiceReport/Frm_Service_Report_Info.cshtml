    <script>
        function ServiceReport_VouchingSwitch_ValueChange(e) {
            ShowLoader();
            ServiceReport_IsVouchingMode = e.value;
            //ServiceReportListGrid.SetFocusedRowIndex(-1);
            if (ServiceReport_SetVouchingModeOn == true) {
                ServiceReport_SetVouchingModeOn = false;
            }
            else {
                ServiceReport_FAB.SetVisible(false);
            }
            if (ServiceReport_IsVouchingMode == true) {
                OpenRightPane();
                ClearLeftPane();
                OpenLeftPane();
            }
            else {
                //ServiceReport_FAB.SetActionContext("AddAttachmentContext", false);
                CloseRightPane();
                ClearLeftPane();
                CloseLeftPane();
            }
            ServiceReportListGrid_CollapseAllDetailRows();
        }
        function ServiceReportListGrid_CollapseAllDetailRows() {
            ShowLoader();
            if (typeof window !== 'undefined') {
                if (typeof window.ServiceReportListGrid !== 'undefined') {
                    if (typeof window.ServiceReportListGrid.CollapseAllDetailRows !== 'undefined') {
                        if (typeof ServiceReportListGrid.CollapseAllDetailRows == 'function') {
                            HideLoader();
                            ServiceReportListGrid.SetFocusedRowIndex(-1);
                            ServiceReportListGrid.CollapseAllDetailRows();
                        }
                        else {
                            alert("CollapseAllDetailRows is not a function");
                        }
                    }
                    else {
                        setTimeout(function () {
                            ServiceReportListGrid_CollapseAllDetailRows();
                        }, Timeout100);
                    }
                }
                else {
                    alert('grid undefined')
                }
            }
            else {
                alert('window undefined')
            }
        }
        function ServiceReport_ViewSwitch_ValueChange(e) {
            ShowLoader();
            ServiceReport_ViewMode = e.value == false ? "Default" : "Compact";
            if (ServiceReport_SetVouchingModeOn == true) {
                $("#ServiceReportVouchingModeSwitch").dxSwitch("instance").option("value", true);
            }
            else {
                //ServiceReportListGrid_CollapseAllDetailRows();
                if (ServiceReport_IsVouchingMode == false) {
                    ServiceReport_FAB.SetVisible(false);
                }
                ServiceReportListGrid.CollapseAllDetailRows();
            }
            HideLoader();
        }

    </script>


    <script>
        function ServiceReportOnInit(s, e) {
            ServiceReportAdjustSize();
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                ServiceReportAdjustSize();
            });
        }
        function ServiceReportAdjustSize() {
            var height = (document.documentElement.clientHeight * 90) / 100;
            try {
                ServiceReportListGrid.SetHeight(height);
            }
            catch (err) {
            }
        }
        function ServiceReportListGrid_BeginCallback(s, e) {
            SRFocusedRowIndexBeforeRefresh = s.GetFocusedRowIndex();
            e.customArgs["command"] = e.command;
            e.customArgs["VouchingMode"] = ServiceReport_IsVouchingMode;
            e.customArgs["ShowHorizontalBar"] = SR_ShowHorizontalBar;
            e.customArgs["ViewMode"] = ServiceReport_ViewMode;
            e.customArgs["ColumnToBeShownIndex"] = SR_ColumnToBeShownIndex;
            e.customArgs["ColumnToBeHidddenIndex"] = SR_ColumnToBeHidddenIndex;
            e.customArgs["RowKeyToFocus"] = SR_Select_xid;
        }
        function OnGridServiceReportListGrid_EndCallback(s, e) {
            SR_ColumnToBeShownIndex = s.cpColumnToBeShownIndex;
            SR_ColumnToBeHidddenIndex = s.cpColumnToBeHidddenIndex;
            ServiceReportGridLayout = s.cpClientLayout;
            $(".ServiceReportListGrid_PreviewRow").hide();
            GetSessionStorage("ServiceReportListGrid");
            SendCustomArgs_FilterControl(s, e);
            if (e.command == "REFRESH") {
                if (SRFocusedRowIndexBeforeRefresh == s.GetFocusedRowIndex()) {
                    s.SetFocusedRowIndex(-1);
                    s.SetFocusedRowIndex(SRFocusedRowIndexBeforeRefresh);
                }
                SR_Select_xid = "";
                if (ServiceReport_MoreEntry == true) {
                    ServiceReport_MoreEntry = false;
                    var confirm = DevExpress.ui.dialog.confirm('Add More Entry...?', "Godly Service Report");
                    confirm.done(function (dialogResult) {
                        if (dialogResult) {
                            DataNavigation_GSR("NEW");
                        }
                    });
                }
            }
        }
        function ServiceReportchangeMode() {
            ShowLoader();
            if (SR_ShowHorizontalBar == 0) {
                SR_ShowHorizontalBar = 1;
                $("#Service_ReportToggleScrollBar").find("span").text("Default Data");
                $("#Service_ReportToggleScrollBar").width(110);
            }
            else {
                SR_ShowHorizontalBar = 0;
                $("#Service_ReportToggleScrollBar").find("span").text("Full Data");
                $("#Service_ReportToggleScrollBar").width(90);
            }
            $.ajax({
                url: "/Facility/ServiceReport/Frm_Service_Report_Info_Grid",
                type: "POST",
                data: { ShowHorizontalBar: SR_ShowHorizontalBar, VouchingMode: ServiceReport_IsVouchingMode, ViewMode: ServiceReport_ViewMode, Layout: ServiceReportGridLayout, ColumnToBeHidddenIndex: SR_ColumnToBeHidddenIndex, ColumnToBeShownIndex: SR_ColumnToBeShownIndex },
                success: function (res) {
                    $("#ServiceReportGridPartialView").html(res);
                    ASPxClientControl.AdjustControls(document.getElementById("ServiceReportGridPartialView"));
                    $(".ServiceReportListGrid_PreviewRow").hide();
                    GetSessionStorage("ServiceReportListGrid");
                    HideLoader();
                }
            });
        }
        function ServiceReportdblclickEdit(s, e) {
            if (ServiceReport_IsVouchingMode == false) {
                DataNavigation_GSR("EDIT");
            }
        }
        function OnServiceReportGridFocusedRowChanged(s, e) {
            var focusIndex = s.GetFocusedRowIndex();
            if (focusIndex > -1) {
                if (ServiceReport_IsVouchingMode) {
                    ServiceReport_FAB.SetVisible(true);
                    ServiceReport_FAB.SetActionContext("VouchingActionContext", true);
                }
                ServiceReport_ID = s.GetRowKey(focusIndex);
                Get_ServiceReport_Row_Data(focusIndex);
                if (ServiceReport_IsVouchingMode == true) {
                    OpenLeftPane();
                    LoadDocumentAndAdditionalInfoInLeftPane("Facility", "ServiceReport", "LeftPaneContent", ServiceReport_ID, ServiceReport_IsVouchingMode, "");
                }
            }
            else {
                ServiceReport_ID = null;
            }
            ServiceReport_UpdateFooterDetail(ServiceReport_ID, ServiceReport_Action_Status, ServiceReport_Add_Date, ServiceReport_Add_By,
                ServiceReport_Action_Date, ServiceReport_Action_By, ServiceReport_Edit_Date, ServiceReport_Edit_By);
        }
        function Get_ServiceReport_Row_Data(RowIndex = null) {
            var focusedrow = RowIndex == null ? ServiceReportListGrid.GetFocusedRowIndex() : RowIndex;
            var topindex = ServiceReportListGrid.GetTopVisibleIndex();
            var Index = focusedrow - topindex;
            ServiceReport_PageData = ServiceReportListGrid.cpPagedata;
            if (ServiceReport_PageData != null && ServiceReport_PageData.length > 0 && Index < ServiceReport_PageData.length) {
                ServiceReport_ID = ServiceReport_PageData[Index][0];
                ServiceReport_Name = ServiceReport_PageData[Index][1];
                ServiceReport_Add_By = ServiceReport_PageData[Index][2];
                ServiceReport_Add_Date = ServiceReport_PageData[Index][3];
                ServiceReport_Edit_By = ServiceReport_PageData[Index][4];
                ServiceReport_Edit_Date = ServiceReport_PageData[Index][5];
                ServiceReport_Action_Status = ServiceReport_PageData[Index][6];
                ServiceReport_Action_By = ServiceReport_PageData[Index][7];
                ServiceReport_Action_Date = ServiceReport_PageData[Index][8];
                ServiceReport_FORM_INST_ID = ServiceReport_PageData[Index][9];
                ServiceReport_FromDate = ServiceReport_PageData[Index][10];
                ServiceReport_ToDate = ServiceReport_PageData[Index][11];
            }
        }
        function ServiceReport_UpdateFooterDetail(ServiceReport_ID, ServiceReport_Action_Status, ServiceReport_Add_Date, ServiceReport_Add_By, ServiceReport_Action_Date, ServiceReport_Action_By, ServiceReport_Edit_Date, ServiceReport_Edit_By) {
            var Status = "";
            var Lbl_Status = "";
            var Lbl_StatusBy = "";
            var Pic_Status = "";
            var Lbl_Create = "";
            var Lbl_Modify = "";
            var Lbl_Status_Color = "";
            var Lbl_ActionOn = "";
            var Lbl_ActionBy = "";
            var StatusStr = "";
            if (ServiceReport_ID != null) {
                ServiceReport_Add_Date = (moment(ServiceReport_Add_Date, "DD/MM/YYYY HH:mm:ss").format("DD/MM/YYYY HH:mm:ss"));
                ServiceReport_Edit_Date = (moment(ServiceReport_Edit_Date, "DD/MM/YYYY HH:mm:ss").format("DD/MM/YYYY HH:mm:ss"));
                ServiceReport_Action_Date = (moment(ServiceReport_Action_Date, "DD/MM/YYYY HH:mm:ss").format("DD/MM/YYYY HH:mm:ss"));
                Status = ServiceReport_Action_Status;
                StatusStr = Status == "Locked" ? "Locked" : Status == null ? null : "UnLocked";
                if (Status && Status.toUpperCase() == "LOCKED") {
                    Lbl_Status = "Completed";
                    Lbl_Status_Color = "blue";
                    Pic_Status = "fa fa-lock";
                }
                else {
                    Pic_Status = "fa fa-unlock";
                    Lbl_Status = Status;
                    if (Status && Status.toUpperCase() == "COMPLETED") {
                        Lbl_Status_Color = "green";
                    }
                    else {
                        Lbl_Status_Color = "red";
                    }
                }
                if (ServiceReport_Action_Date) {
                    Lbl_ActionOn = StatusStr + " On: " + ServiceReport_Action_Date;
                    Lbl_ActionBy = StatusStr + " By: " + ServiceReport_Action_By;
                }

                else {
                    Lbl_ActionOn = "";
                    Lbl_ActionBy = "";
                }
                if (ServiceReport_Add_Date) {
                    Lbl_Create = "Add On: " + ServiceReport_Add_Date + ", By: " + ServiceReport_Add_By;
                }
                else {
                    Lbl_Create = "";
                }

                if (ServiceReport_Edit_Date) {
                    Lbl_Modify = "Edit On: " + ServiceReport_Edit_Date + ", By: " + ServiceReport_Edit_By;
                }
                else {
                    Lbl_Modify = "";
                }
            }
            $('#SR_Status').text(Lbl_Status);
            $('#SR_Lbl_ActionOn').text(Lbl_ActionOn)
            $('#SR_Lbl_ActionBy').text(Lbl_ActionBy);
            $('#SR_Create').text(Lbl_Create);
            $('#SR_Modify').text(Lbl_Modify);
            if (Lbl_Status_Color != "") {
                $('#SR_Status').css('color', Lbl_Status_Color);
            }
            if (Pic_Status == "fa fa-lock") {
                $('#ServiceReport_LockICON').addClass(Pic_Status).removeClass("fa-unlock");
            }
            else if (Pic_Status == "fa fa-unlock") {
                $('#ServiceReport_LockICON').addClass(Pic_Status).removeClass("fa-lock");
            }
            else {
                $('#ServiceReport_LockICON').removeClass("fa");
                $('#ServiceReport_LockICON').removeClass("fa-lock");
                $('#ServiceReport_LockICON').removeClass("fa-unlock");
            }
        }
        function ServiceReportContextMenuFunction(s, e) {
            if (e.item.name == 'New') {
                DataNavigation_GSR("NEW");
            }
            else if (e.item.name == 'Edit') {
                DataNavigation_GSR("EDIT");
            }
            else if (e.item.name == 'Delete') {
                DataNavigation_GSR("DELETE");
            }
            //else if (e.item.name == 'Attachments')
            //{
            //    OnService_ReportMergeClick();
            //}
            else if (e.item.name == 'Manage_Attachments') {
                ManageAttachment(ServiceReport_ID, "Godly Service Report");
            }
            else if (e.item.name == 'ListPreview') {
                OnServiceReportListPreviewClick();
            }
            else if (e.item.name == 'Close') {
                closeServiceReport();
            }
            else if (e.item.name == 'Import') {
                DevExpress.ui.dialog.alert("Coming Soon, Under Construction", "Information");
            }
            else if (e.item.name == 'Export') {
                DevExpress.ui.dialog.alert("Coming Soon, Under Construction", "Information");
            }
            else if (e.item.name == 'Refresh') {
                ServiceReportListGrid.Refresh();
            }
        }
    </script>
    @* Grid Functions *@

<script>
        /*Attachment and Nested Grid code*/
        function On_ServiceReportFacility_FABActionItemClick(s, e)
        {
            var img = document.getElementById('RightPane_Img');
            s.ExpandActionGroupItems();
            if (e.actionName === "add_attach")
            {
                if ("@Help_Attachment_AddRight" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                if (ServiceReportInfo_ParamMandatory == 1)
                {
                    AddAttachment(ServiceReportInfo_MasterRowRecID, "Facility_ServiceReport", ServiceReportInfo_Doc_ID, ServiceReportInfo_Doc_Category, ServiceReportInfo_ParamMandatory, ServiceReportInfo_FromDateLabel, ServiceReportInfo_ToDateLabel, ServiceReportInfo_DescriptionLabel, "ServiceReportFacilityAttachment", null, "ServiceReportListGrid", ServiceReportInfo_NestedGrid_AccessID);
                }
                else
                {
                    Attachment_DirectBrowse(ServiceReportInfo_MasterRowRecID, "Facility_ServiceReport", ServiceReportInfo_Doc_ID, "ServiceReportFacilityAttachment", "ServiceReportListGrid", ServiceReportInfo_NestedGrid_AccessID);
                }
            }
            else if (e.actionName === "edit_attach")
            {
                if ("@Help_Attachment_EditRight" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                if (ServiceReportInfo_Nested_Doc_Status == "NO" || ServiceReportInfo_Nested_Doc_Status == "")
                {
                    DevExpress.ui.dialog.alert("Please Attach document First", "Error");
                    return;
                }
                if (ServiceReportInfo_Attachment_RecStatus.toUpperCase() == "LOCKED")
                {
                    DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                    return;
                }
                EditAttachment(ServiceReportInfo_MasterRowRecID, "Facility_ServiceReport", ServiceReportInfo_AtachmentID, ServiceReportInfo_ParamMandatory, ServiceReportInfo_FromDateLabel, ServiceReportInfo_ToDateLabel, ServiceReportInfo_DescriptionLabel, "ServiceReportFacilityAttachment", null, "ServiceReportListGrid", ServiceReportInfo_NestedGrid_AccessID);
            }
            else if (e.actionName === "delete_attach")
            {
                if ("@Help_Attachment_DeleteRight" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                if (ServiceReportInfo_Nested_Doc_Status == "NO" || ServiceReportInfo_Nested_Doc_Status == "")
                {
                    DevExpress.ui.dialog.alert("Please Attach document First", "Error");
                    return;
                }
                DeleteAttachment(ServiceReportInfo_MasterRowRecID, "Facility_ServiceReport", ServiceReportInfo_AtachmentID, ServiceReportInfo_ParamMandatory, ServiceReportInfo_FromDateLabel, ServiceReportInfo_ToDateLabel, ServiceReportInfo_DescriptionLabel, null, "ServiceReportListGrid", ServiceReportInfo_NestedGrid_AccessID, ServiceReportInfo_Attachment_RecStatus);
            }
            else if (e.actionName === "view_attach")
            {
                if ("@Help_Attachment_ViewRight" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                if (ServiceReportInfo_Nested_Doc_Status == "NO" || ServiceReportInfo_Nested_Doc_Status == "")
                {
                    DevExpress.ui.dialog.alert("Please Attach document First", "Error");
                    return;
                }

                ViewDocument(ServiceReportInfo_AtachmentID, ServiceReportInfo_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
            }
            else if (e.actionName == "Link_Attach")
            {
                LinkAttachment(ServiceReportInfo_MasterRowRecID, "Facility_ServiceReport", "Service Report", "ServiceReportListGrid", ServiceReportInfo_NestedGrid_AccessID);
            }
            else if (e.actionName === "Add_Reason")
            {
                if (ServiceReportInfo_Doc_Category.toLowerCase() == "others")
                {
                    DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
                }
                else
                {
                    AttachmentAddReason(ServiceReportInfo_MasterRowRecID, ServiceReportInfo_NestedRowMapID, "Facility_ServiceReport", "ServiceReportListGrid", ServiceReportInfo_NestedGrid_AccessID);
                }
            }
            else if (e.actionName === "Edit_Reason")
            {
                AttachmentEditReason(ServiceReportInfo_MasterRowRecID, ServiceReportInfo_NestedRowMapID, "Facility_ServiceReport", "ServiceReportListGrid", ServiceReportInfo_NestedGrid_AccessID, ServiceReportInfo_reason);
            }
            else if (e.actionName === "Delete_Reason")
            {
                AttachmentDeleteReason(ServiceReportInfo_MasterRowRecID, ServiceReportInfo_NestedRowMapID, "ServiceReportListGrid", ServiceReportInfo_NestedGrid_AccessID);
            }
            else if (e.actionName === "Rotate")
            {
                ImageRotate(img);
            }
            else if (e.actionName === "ZoomOut")
            {
                ImageZoomOut(img);
            }
            else if (e.actionName === "ZoomIn")
            {
                ImageZoomIn(img);
            }
            else if (e.actionName == "Fit")
            {
                ImageFit(img);
            }
            else if (e.actionName == "Back")
            {
                ImageBack(s.uniqueID, "actionItemContext");
            }
            else if (e.actionName == "AuditAction")
            {
                ServiceReport_FAB.SetActionContext("AuditActionContext", true);
            }
            else if (e.actionName == "BackAudit")
            {
                if (ServiceReportInfo_Nested_Doc_Status == "")
                {
                    ServiceReport_FAB.SetActionContext("actionItemContext", true);
                }
                if (ServiceReportInfo_Nested_Doc_Status == "NO")
                {
                    ServiceReport_FAB.SetActionContext("EditItemContext", true);
                }
                if (ServiceReportInfo_Nested_Doc_Status == "YES")
                {
                    ServiceReport_FAB.SetActionContext("actionItemContext", true);
                }
            }
            else if (e.actionName == "Accept")
            {
                ServiceReportInfo_AcceptwithoutRemarks();
            }
            else if (e.actionName == "Reject")
            {
                ServiceReportInfo_AcceptRejectVoucher("Reject");
            }
            else if (e.actionName == "AcceptWithRemarks")
            {
                ServiceReportInfo_AcceptRejectVoucher("Accept");
            }
            else if (e.actionName == "AcceptDoc")
            {
                OnServiceReportInfo_AcceptDoc();
            }
            else if (e.actionName == "RejectDoc")
            {
                OnServiceReportInfo_RejectDoc();
            }
        }
        function OnServiceReportInfo_RejectDoc()
        {
            if (ServiceReportInfo_AtachmentID == null || ServiceReportInfo_AtachmentID.length == 0)
            {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
            }
            RejectAttachment(ServiceReportInfo_AtachmentID, "ServiceReportListGrid", ServiceReportInfo_NestedGrid_AccessID);
        }
        function OnServiceReportInfo_AcceptDoc()
        {
            if (ServiceReportInfo_AtachmentID == null || ServiceReportInfo_AtachmentID.length == 0)
            {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        AcceptAttachment(ServiceReportInfo_AtachmentID, "ServiceReportListGrid", ServiceReportInfo_NestedGrid_AccessID);
    }
    function ServiceReportInfo_AcceptwithoutRemarks()
    {
        var Recid;
        if (ServiceReportInfo_IsDetailRowExpanded == true || ServiceReport_IsVouchingMode == true)
        {
            if (ServiceReportInfo_MasterRowRecID == null || ServiceReportInfo_MasterRowRecID == "")
            {
                Recid = ServiceReport_ID;
            }
            else
            {
                Recid = ServiceReportInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = ServiceReport_ID;
        }
        Entry_AcceptwithoutRemarks(Recid, "Facility_ServiceReport", "ServiceReportListGrid", ServiceReportInfo_AtachmentID, ServiceReportInfo_NestedRowReasonID, ServiceReportInfo_NestedRowKeyValue);
    }
    function ServiceReportInfo_AcceptRejectVoucher(_actionMethod)
    {
        var Recid;
        if (ServiceReportInfo_IsDetailRowExpanded == true || ServiceReport_IsVouchingMode == true)
        {
            if (ServiceReportInfo_MasterRowRecID == null || ServiceReportInfo_MasterRowRecID == "")
            {
                Recid = ServiceReport_ID;
            }
            else
            {
                Recid = ServiceReportInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = ServiceReport_ID;
        }
        Entry_AcceptReject(_actionMethod, Recid, "Facility_ServiceReport", "ServiceReportListGrid", ServiceReportInfo_AtachmentID, ServiceReportInfo_NestedRowReasonID, ServiceReportInfo_NestedRowKeyValue);
    }
    function OnServiceReportListGridNestedFocusedRowChange(s, e)
    {
        if (ServiceReportInfo_IsDetailRowExpanded == true || ServiceReport_IsVouchingMode == true)
        {
            ServiceReportInfo_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
            if (ServiceReportInfo_NestedRecord_FocusedRowIndex >= 0)
            {
                ShowLoader();
                ServiceReport_FAB.SetVisible(true);
                ServiceReportInfo_NestedGrid_AccessID = s.uniqueID;
                s.GetRowValues(s.GetFocusedRowIndex(), 'Doc_Status;Params_Mandatory;LABEL_FROM_DATE;LABEL_TO_DATE;LABEL_DESCRIPTION;Document_Category;Document_ID;ATTACH_ID;TxnID;TxnMID;MAP_ID;Reason;ATTACH_FILE_NAME;Attachment_Action_Status;UniqueID;ReasonID', OnServiceReportInfo_GetGridRowValues);
            }
            else
            {
                ServiceReport_FAB.SetVisible(false);
            }
        }
    }
    function OnServiceReportInfo_GetGridRowValues(values)
    {
        HideLoader();
        if (values[14] != null)
        {
            ServiceReportInfo_Nested_Doc_Status = values[0];
            ServiceReport_FAB.SetVisible(true);
            if (ServiceReport_IsVouchingMode == true)
            {
                ServiceReport_FAB.SetActionContext("AuditActionContext", true);
            }
            else
            {
                if (ServiceReportInfo_Nested_Doc_Status == "")
                {
                    ServiceReport_FAB.SetActionContext("actionItemContext", true);
                }
                else if (ServiceReportInfo_Nested_Doc_Status == "NO")
                {
                    ServiceReport_FAB.SetActionContext("EditItemContext", true);
                }
                else if (ServiceReportInfo_Nested_Doc_Status == "YES")
                {
                    ServiceReport_FAB.SetActionContext("actionItemContext", true);
                }
            }
           // ServiceReport_FAB.SetActionContext("actionItemContext", true);
            ServiceReportInfo_ParamMandatory = values[1];
            ServiceReportInfo_FromDateLabel = values[2];
            ServiceReportInfo_ToDateLabel = values[3];
            ServiceReportInfo_DescriptionLabel = values[4];
            ServiceReportInfo_Doc_Category = values[5];
            ServiceReportInfo_Doc_ID = values[6];
            ServiceReportInfo_AtachmentID = values[7];
            IndexAttachmentID = ServiceReportInfo_AtachmentID;
            ServiceReportInfo_MasterRowRecID = values[8];
            ServiceReportInfo_MasterRowMID = values[9];
            ServiceReportInfo_NestedRowMapID = values[10];
            ServiceReportInfo_reason = values[11];
            ServiceReportInfo_FileName = values[12];
            ServiceReportInfo_Attachment_RecStatus = values[13];
            ServiceReportInfo_NestedRowKeyValue = values[14];

                if (ServiceReport_IsVouchingMode == true)
                {
                    if (ServiceReportInfo_FileName != null && ServiceReportInfo_FileName.length > 0)
                    {
                        ViewDocument(ServiceReportInfo_AtachmentID, ServiceReportInfo_FileName, "ServiceReport_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                    }
                    else
                    {
                        CloseRightPane();
                        ClearRightPane();
                    }
                }
            }
            ServiceReportInfo_NestedRowReasonID = values[15];
            IndexAttachmentReasonID = ServiceReportInfo_NestedRowReasonID;
        }
        function ServiceReportGrid_Nested_BeginCallBack(s, e)
        {
            e.customArgs["ShowHorizontalBar"] = SR_ShowHorizontalBar;
            e.customArgs["VouchingMode"] = ServiceReport_IsVouchingMode;
            e.customArgs["command"] = e.command;
        }
        function ServiceReportGrid_DetailRowExpanding(s, e)
        {
            ServiceReportInfo_IsDetailRowExpanded = true;
            s.SetFocusedRowIndex(e.visibleIndex);
            var pane = Mainspliter.GetPaneByName('RightPane');
            if (ServiceReport_IsVouchingMode == true)
            {
                pane.Expand();
            }
            else
            {
                pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
        function ServiceReportGrid_DetailRowCollapsing(s, e)
        {
            ServiceReportInfo_IsDetailRowExpanded = false;
            s.SetFocusedRowIndex(e.visibleIndex);
            if (ServiceReport_IsVouchingMode == true)
            {
                if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false)
                {
                    CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
                }
            }
            else
            {
                ServiceReport_FAB.SetVisible(false);
            }
        }


        function onclick_generateServiceReport() {
            ShowLoader();
            OpenPopup("Service_Report_download_modal", "Generate and Download Service Report", "@Url.Action("Frm_ServiceReport_Generator", "ServiceReport", new { @area = "Facility" })", "auto",1250);
        }
    function onclick_getQuizResult() {
        debugger;
        var focusIndex = ServiceReportListGrid.GetFocusedRowIndex();
        if (focusIndex < 0) {
            DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
            return;
        }
        summary_type_ChartInfo = "Quiz Result";
        Get_ServiceReport_Row_Data(focusIndex);
        ShowLoader();
        showQuizResult_ChartReports(ServiceReport_ID, null, summary_type_ChartInfo, null, ServiceReport_Name, (JS_Json_Date_To_ddMMyyyy((ServiceReport_FromDate ?? ""), "DD/MM/YYYY") ?? ""), (JS_Json_Date_To_ddMMyyyy((ServiceReport_ToDate ?? ""), "DD/MM/YYYY") ?? ""));
        HideLoader();
    }
</script>
    @*attachment and nested grid*@
</div>
