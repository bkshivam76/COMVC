                        @(Html.DevExtreme().Button().ID("GSRBulkAllotment").Text("Bulk Allotment").OnClick(@<text> function () { DataNavigation_GSR("BULK_ALLOTMENT"); } </text>))
                        @(Html.DevExtreme().Button().ID("GSRNew").Text("New") .Icon("add").OnClick(@<text> function () { DataNavigation_GSR("NEW"); } </text>))
                        @(Html.DevExtreme().Button().ID("GSREdit").Text("Edit").Icon("edit").OnClick(@<text> function () { DataNavigation_GSR("EDIT"); } </text>))
                        @(Html.DevExtreme().Button().ID("GSRDelete").Text("Delete").Icon("trash").OnClick(@<text> function () { DataNavigation_GSR("DELETE"); } </text>))
