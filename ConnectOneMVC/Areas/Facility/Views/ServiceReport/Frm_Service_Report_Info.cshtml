    <div id="ServiceReport_ParentDiv">
        <div id="ServiceReport_content" class="report_header_div_main">
            <div>
                <div class="report_header_div">
                    <label class="report_header_label">Godly Service Report</label>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12">
                    <div class="report_button_div">
                        @(Html.DevExtreme().Switch().ID("ServiceReportVouchingModeSwitch").SwitchedOnText("Vouching On").SwitchedOffText("Vouching Off").Width(100).OnValueChanged("ServiceReport_VouchingSwitch_ValueChange").Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR") )
