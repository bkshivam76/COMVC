    <script>
        function On_ServiceReportFacility_FABActionItemClick(s, e)
        {
            var img = document.getElementById('RightPane_Img');
            s.ExpandActionGroupItems();
            if (e.actionName === "add_attach")
            {
                if ("@Help_Attachment_AddRight" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                if (ServiceReportInfo_ParamMandatory_dx == 1)
                {
                    AddAttachment(ServiceReportInfo_MasterRowRecID_dx, "Facility_ServiceReport", ServiceReportInfo_Doc_ID_dx, ServiceReportInfo_Doc_Category_dx, ServiceReportInfo_ParamMandatory_dx, ServiceReportInfo_FromDateLabel_dx, ServiceReportInfo_ToDateLabel_dx, ServiceReportInfo_DescriptionLabel_dx, "ServiceReportFacilityAttachment", null, "ServiceReportListGrid_dx", ServiceReportInfo_NestedGrid_AccessID_dx);
                }
                else
                {
                    Attachment_DirectBrowse(ServiceReportInfo_MasterRowRecID_dx, "Facility_ServiceReport", ServiceReportInfo_Doc_ID_dx, "ServiceReportFacilityAttachment", "ServiceReportListGrid_dx", ServiceReportInfo_NestedGrid_AccessID_dx);
                }
            }
            else if (e.actionName === "edit_attach")
            {
                if ("@Help_Attachment_EditRight" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                if (ServiceReportInfo_Nested_Doc_Status_dx == "NO" || ServiceReportInfo_Nested_Doc_Status_dx == "")
                {
                    DevExpress.ui.dialog.alert("Please Attach document First", "Error");
                    return;
                }
                if (ServiceReportInfo_Attachment_RecStatus_dx.toUpperCase() == "LOCKED")
                {
                    DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                    return;
                }
                EditAttachment(ServiceReportInfo_MasterRowRecID_dx, "Facility_ServiceReport", ServiceReportInfo_AtachmentID_dx, ServiceReportInfo_ParamMandatory_dx, ServiceReportInfo_FromDateLabel_dx, ServiceReportInfo_ToDateLabel_dx, ServiceReportInfo_DescriptionLabel_dx, "ServiceReportFacilityAttachment", null, "ServiceReportListGrid_dx", ServiceReportInfo_NestedGrid_AccessID_dx);
            }
            else if (e.actionName === "delete_attach")
            {
                if ("@Help_Attachment_DeleteRight" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                if (ServiceReportInfo_Nested_Doc_Status_dx == "NO" || ServiceReportInfo_Nested_Doc_Status_dx == "")
                {
                    DevExpress.ui.dialog.alert("Please Attach document First", "Error");
                    return;
                }
                DeleteAttachment(ServiceReportInfo_MasterRowRecID_dx, "Facility_ServiceReport", ServiceReportInfo_AtachmentID_dx, ServiceReportInfo_ParamMandatory_dx, ServiceReportInfo_FromDateLabel_dx, ServiceReportInfo_ToDateLabel_dx, ServiceReportInfo_DescriptionLabel_dx, null, "ServiceReportListGrid_dx", ServiceReportInfo_NestedGrid_AccessID_dx, ServiceReportInfo_Attachment_RecStatus_dx);
            }
            else if (e.actionName === "view_attach")
            {
                if ("@Help_Attachment_ViewRight" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                if (ServiceReportInfo_Nested_Doc_Status_dx == "NO" || ServiceReportInfo_Nested_Doc_Status_dx == "")
                {
                    DevExpress.ui.dialog.alert("Please Attach document First", "Error");
                    return;
                }

                ViewDocument(ServiceReportInfo_AtachmentID_dx, ServiceReportInfo_FileName_dx, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
            }
            else if (e.actionName == "Link_Attach")
            {
                LinkAttachment(ServiceReportInfo_MasterRowRecID_dx, "Facility_ServiceReport", "Service Report", "ServiceReportListGrid_dx", ServiceReportInfo_NestedGrid_AccessID_dx);
            }
            else if (e.actionName === "Add_Reason")
            {
                if (ServiceReportInfo_Doc_Category_dx.toLowerCase() == "others")
                {
                    DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
                }
                else
                {
                    AttachmentAddReason(ServiceReportInfo_MasterRowRecID_dx, ServiceReportInfo_NestedRowMapID_dx, "Facility_ServiceReport", "ServiceReportListGrid_dx", ServiceReportInfo_NestedGrid_AccessID_dx);
                }
            }
            else if (e.actionName === "Edit_Reason")
            {
                AttachmentEditReason(ServiceReportInfo_MasterRowRecID_dx, ServiceReportInfo_NestedRowMapID_dx, "Facility_ServiceReport", "ServiceReportListGrid_dx", ServiceReportInfo_NestedGrid_AccessID_dx, ServiceReportInfo_reason_dx);
            }
            else if (e.actionName === "Delete_Reason")
            {
                AttachmentDeleteReason(ServiceReportInfo_MasterRowRecID_dx, ServiceReportInfo_NestedRowMapID_dx, "ServiceReportListGrid_dx", ServiceReportInfo_NestedGrid_AccessID_dx);
            }
            else if (e.actionName === "Rotate")
            {
                ImageRotate(img);
            }
            else if (e.actionName === "ZoomOut")
            {
                ImageZoomOut(img);
            }
            else if (e.actionName === "ZoomIn")
            {
                ImageZoomIn(img);
            }
            else if (e.actionName == "Fit")
            {
                ImageFit(img);
            }
            else if (e.actionName == "Back")
            {
                ImageBack(s.uniqueID, "actionItemContext");
            }
            else if (e.actionName == "AuditAction")
            {
                ServiceReport_FAB_dx.SetActionContext("AuditActionContext", true);
            }
            else if (e.actionName == "BackAudit")
            {
                if (ServiceReportInfo_Nested_Doc_Status_dx == "")
                {
                    ServiceReport_FAB_dx.SetActionContext("actionItemContext", true);
                }
                if (ServiceReportInfo_Nested_Doc_Status_dx == "NO")
                {
                    ServiceReport_FAB_dx.SetActionContext("EditItemContext", true);
                }
                if (ServiceReportInfo_Nested_Doc_Status_dx == "YES")
                {
                    ServiceReport_FAB_dx.SetActionContext("actionItemContext", true);
                }
            }
            else if (e.actionName == "Accept")
            {
                ServiceReportInfo_AcceptwithoutRemarks();
            }
            else if (e.actionName == "Reject")
            {
                ServiceReportInfo_AcceptRejectVoucher("Reject");
            }
            else if (e.actionName == "AcceptWithRemarks")
            {
                ServiceReportInfo_AcceptRejectVoucher("Accept");
            }
            else if (e.actionName == "AcceptDoc")
            {
                OnServiceReportInfo_AcceptDoc();
            }
            else if (e.actionName == "RejectDoc")
            {
                OnServiceReportInfo_RejectDoc();
            }
        }
        function OnServiceReportInfo_RejectDoc()
        {
            if (ServiceReportInfo_AtachmentID_dx == null || ServiceReportInfo_AtachmentID.length_dx == 0)
            {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
            }
            RejectAttachment(ServiceReportInfo_AtachmentID_dx, "ServiceReportListGrid_dx", ServiceReportInfo_NestedGrid_AccessID_dx);
        }
        function OnServiceReportInfo_AcceptDoc()
        {
            if (ServiceReportInfo_AtachmentID_dx == null || ServiceReportInfo_AtachmentID.length_dx == 0)
            {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
            AcceptAttachment(ServiceReportInfo_AtachmentID_dx, "ServiceReportListGrid_dx", ServiceReportInfo_NestedGrid_AccessID_dx);
    }
        function ServiceReportInfo_AcceptwithoutRemarks() {
            var Recid;
            if (ServiceReportInfo_IsDetailRowExpanded_dx == true) {
                if (ServiceReportInfo_MasterRowRecID_dx == null || ServiceReportInfo_MasterRowRecID_dx == "") {
                    Recid = ServiceReport_ID_dx;
                }
                else {
                    Recid = ServiceReportInfo_MasterRowRecID_dx;
                }
            }
            else {
                Recid = ServiceReport_ID_dx;
            }
            Entry_AcceptwithoutRemarks(Recid, "Facility_ServiceReport", "ServiceReportListGrid_dx", ServiceReportInfo_AtachmentID_dx, ServiceReportInfo_NestedRowReasonID_dx, ServiceReportInfo_NestedRowKeyValue_dx);
        }
        function ServiceReportInfo_AcceptRejectVoucher(_actionMethod) {
            var Recid;
            if (ServiceReportInfo_IsDetailRowExpanded_dx == true ) {
                if (ServiceReportInfo_MasterRowRecID_dx == null || ServiceReportInfo_MasterRowRecID_dx == "") {
                    Recid = ServiceReport_ID_dx;
                }
                else {
                    Recid = ServiceReportInfo_MasterRowRecID_dx;
                }
            }
            else {
                Recid = ServiceReport_ID_dx;
            }
            Entry_AcceptReject(_actionMethod, Recid, "Facility_ServiceReport", "ServiceReportListGrid_dx", ServiceReportInfo_AtachmentID_dx, ServiceReportInfo_NestedRowReasonID_dx, ServiceReportInfo_NestedRowKeyValue_dx);
        }
    </script>

    @*Dxdata Grid Functions Start *@
<script>


    function ServiceReport_dx_changeViewMode(e)
    {
        //debugger;
        ServiceReport_ViewMode_dx = e.value == false ? "Default" : "Compact";
        Service_Report_Main_Grid.beginUpdate();
        var columns = Service_Report_Main_Grid.option("columns");
        if (ServiceReport_ViewMode_dx == "Compact") {
            VisibleColumns_ServiceReport_dx = [];
            for (var i = 0; i < columns.length; i++) {
                var name = columns[i].dataField;
                var ColumnVisible = Service_Report_Main_Grid.columnOption(name, "visible");
                if (name == "ServiceReportListGrid_dx_Compact_Column") {
                    Service_Report_Main_Grid.columnOption(name, "visible", true);
                }
                else if (ColumnVisible == true && name != "iIcon") {
                    VisibleColumns_ServiceReport_dx.push(name);
                    Service_Report_Main_Grid.columnOption(name, "visible", false);
                }

            }
            //Service_Report_Main_Grid.option({
            //    summary: {

            //    }
            //});
        }
        else {
            Service_Report_Main_Grid.columnOption("ServiceReportListGrid_dx_Compact_Column", "visible", false);
            for (var i = 0; i < VisibleColumns_ServiceReport_dx.length; i++) {
                Service_Report_Main_Grid.columnOption(VisibleColumns_ServiceReport_dx[i], "visible", true);
            }
            //ChartResponsesInfoGrid_dx.option({
            //    summary: {

            //    }
            //});
        }
        Service_Report_Main_Grid.repaint();
        Service_Report_Main_Grid.endUpdate();

    }
    function CRInfoGrid_dx_Load_Columns(CRInfoGrid_ViewMOde) { }
    function ServiceReport_dxchangeMode() {

        Service_Report_Main_Grid.beginUpdate();
        if (SR_ShowHorizontalBar_dx == 0) {
            SR_ShowHorizontalBar_dx = 1;
            $("#Service_Report_ToggleScrollBar_dx").find("span").text("Default Data");
            $("#Service_Report_ToggleScrollBar_dx").width(110);
            Service_Report_Main_Grid.option("columnHidingEnabled", false);
            Service_Report_Main_Grid.option("allowColumnResizing", true)
        }
        else {
            SR_ShowHorizontalBar_dx = 0;
            $("#Service_Report_ToggleScrollBar_dx").find("span").text("Full Data");
            $("#Service_Report_ToggleScrollBar_dx").width(90);
            Service_Report_Main_Grid.option("columnHidingEnabled", true)
            Service_Report_Main_Grid.option("allowColumnResizing", false)
        }
        Service_Report_Main_Grid.repaint();
        Service_Report_Main_Grid.endUpdate();

    }

    function onclick_generateServiceReport_dx() {
            ShowLoader();
            OpenPopup("Service_Report_download_modal", "Generate and Download Service Report", "@Url.Action("Frm_ServiceReport_Generator", "ServiceReport", new { @area = "Facility" })", "auto",1250);
        }

    function DataNavigation_GSR_dX(Action) {
        //debugger;
            if (Action == "NEW") {
                if ("@Service_Report_AddRight" == "False") {
                    DevExpress.ui.dialog.alert("Not Allowed", 'No Rights'); return;
                }
                ShowLoader();
                OpenDynamicPopup("New ~ Godly Service Report", "@Url.Action("Frm_Service_Report_Window", "ServiceReport", new { @area = "Facility" })?ActionMethod=_New", "100%", 1265, false, null);
                HideLoader();
            }
            else if (Action == "EDIT" || Action == "DELETE") {
                if (!"@Service_Report_UpdateRight" || !"@Service_Report_DeleteRight") {
                    DevExpress.ui.dialog.alert("Not Allowed", 'No Rights'); return;
                }
                if (ServiceReport_ID_dx == "" || ServiceReport_ID_dx == null || ServiceReport_ID_dx == 'undefined') {
                    DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                    return;
                }
                $.ajax({
                    type: 'GET',
                    async: false,
                    url: "/Facility/ServiceReport/Frm_Service_Report_Window",
                    cache: false,
                    data:
                    {
                        ActionMethod: Action == "EDIT" ? "_Edit" : "_Delete",
                        xID: ServiceReport_ID_dx,
                        Info_LastEditedOn: JS_Json_Date_To_ddMMyyyy(ServiceReport_Edit_Date_dx)
                    },
                    success: function (data) {
                        ShowLoader();
                        OpenPopup("Dynamic_Content_popup", Action == "EDIT" ? "Edit ~ Godly Service Report" : "Delete ~ Godly Service Report", null, "100%", 1265, true, data);
                        HideLoader();
                    }
                });
            }
            else if (Action == "CREATEFORM") {
                if (ServiceReport_ID_dx == "" || ServiceReport_ID_dx == null || ServiceReport_ID_dx == 'undefined') {
                    DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                    return;
                }
                CreateNewForm("_New", ServiceReport_ID_dx)
            }
            else if (Action == "BULK_ALLOTMENT") {
                if (ServiceReport_ID_dx == "" || ServiceReport_ID_dx == null || ServiceReport_ID_dx == 'undefined') {
                    DevExpress.ui.dialog.alert("Please Select One Row", "Alert");
                    return;
                }
                if (ServiceReport_FORM_INST_ID_dx == null || ServiceReport_FORM_INST_ID_dx == 0) {
                    DevExpress.ui.dialog.alert("Selected Service Report Does Not Have Any Registration Form Created", "Alert");
                    return;
                }
                ShowLoader();
                BulkAllotment_Accommodation(ServiceReport_FORM_INST_ID_dx, 0, ServiceReport_ID_dx);
            }
        }
    function OnServiceReport_dx_ListPreviewClick() {
            if (!"@Service_Report_ExportRight") {
                DevExpress.ui.dialog.alert("Not Allowed", 'No Rights'); return;
            }
            ShowLoader();
            OpenPopup("Service_Report_dx_modal", "Export Option", "@Url.Action("Frm_Export_Options_Dx", "ServiceReport", new { @area = "Facility" })", "auto", 130);
        }
    function ServiceReport_UpdateFooterDetail_dx(ServiceReport_ID_dx, ServiceReport_Action_Status_dx, ServiceReport_Add_Date_dx, ServiceReport_Add_By_dx, ServiceReport_Action_Date_dx, ServiceReport_Action_By_dx, ServiceReport_Edit_Date_dx, ServiceReport_Edit_By_dx) {
            //debugger;
            var Status = "";
            var Lbl_Status = "";
            var Lbl_StatusBy = "";
            var Pic_Status = "";
            var Lbl_Create = "";
            var Lbl_Modify = "";
            var Lbl_Status_Color = "";
            var Lbl_ActionOn = "";
            var Lbl_ActionBy = "";
            var StatusStr = "";
            if (ServiceReport_ID_dx != null) {
                ServiceReport_Add_Date_dx = (moment(ServiceReport_Add_Date_dx).format("DD/MM/YYYY HH:mm:ss"));
                ServiceReport_Edit_Date_dx = (moment(ServiceReport_Edit_Date_dx).format("DD/MM/YYYY HH:mm:ss"));
                ServiceReport_Action_Date_dx = (moment(ServiceReport_Action_Date_dx).format("DD/MM/YYYY HH:mm:ss"));
                Status = ServiceReport_Action_Status_dx;
                StatusStr = Status == "Locked" ? "Locked" : Status == null ? null : "UnLocked";
                if (Status && Status.toUpperCase() == "LOCKED") {
                    Lbl_Status = "Completed";
                    Lbl_Status_Color = "blue";
                    Pic_Status = "fa fa-lock";
                }
                else {
                    Pic_Status = "fa fa-unlock";
                    Lbl_Status = Status;
                    if (Status && Status.toUpperCase() == "COMPLETED") {
                        Lbl_Status_Color = "green";
                    }
                    else {
                        Lbl_Status_Color = "red";
                    }
                }
                if (ServiceReport_Action_Date_dx) {
                    Lbl_ActionOn = StatusStr + " On: " + ServiceReport_Action_Date_dx;
                    Lbl_ActionBy = StatusStr + " By: " + ServiceReport_Action_By_dx;
                }

                else {
                    Lbl_ActionOn = "";
                    Lbl_ActionBy = "";
                }
                if (ServiceReport_Add_Date_dx) {
                    Lbl_Create = "Add On: " + ServiceReport_Add_Date_dx + ", By: " + ServiceReport_Add_By_dx;
                }
                else {
                    Lbl_Create = "";
                }

                if (ServiceReport_Edit_Date_dx) {
                    Lbl_Modify = "Edit On: " + ServiceReport_Edit_Date_dx + ", By: " + ServiceReport_Edit_By_dx;
                }
                else {
                    Lbl_Modify = "";
                }
            }
            $('#SR_Status_dx').text(Lbl_Status);
            $('#SR_Lbl_ActionOn_dx').text(Lbl_ActionOn)
            $('#SR_Lbl_ActionBy_dx').text(Lbl_ActionBy);
            $('#SR_Create_dx').text(Lbl_Create);
            $('#SR_Modify_dx').text(Lbl_Modify);
            if (Lbl_Status_Color != "") {
                $('#SR_Status_dx').css('color', Lbl_Status_Color);
            }
            if (Pic_Status == "fa fa-lock") {
                $('#ServiceReport_LockICON_dx').addClass(Pic_Status).removeClass("fa-unlock");
            }
            else if (Pic_Status == "fa fa-unlock") {
                $('#ServiceReport_LockICON_dx').addClass(Pic_Status).removeClass("fa-lock");
            }
            else {
                $('#ServiceReport_LockICON_dx').removeClass("fa");
                $('#ServiceReport_LockICON_dx').removeClass("fa-lock");
                $('#ServiceReport_LockICON_dx').removeClass("fa-unlock");
            }
        }
    function AfterWindowClose_GSR_dx(ActionMethod = "", xID = "") {
        //debugger;
        if (ActionMethod == "_Delete" || ActionMethod == "Delete") {
            ServiceReport_ID_dx = "";
            SRGridRefresh();
            return;
        }
        if (ActionMethod.includes("New")) {

            var confirm = DevExpress.ui.dialog.confirm('Add More Entry...?', "Godly Service Report");
            confirm.done(function (dialogResult) {
                if (dialogResult) {
                    DataNavigation_GSR_dX("NEW");
                }
            });
        }
        ServiceReport_ID_dx = xID;
        SRGridRefresh();
    }

