    function ServiceReportListGrid_dx_Compact_Column_CellValue(rowData) {
        var data =
            [
                rowData.MISC_NAME, rowData.SR_PROG_NAME, rowData.SR_DATE, rowData.SR_PERIOD, rowData.SR_TIME,
                rowData.SR_TIME_PER, rowData.SR_BRIEF, rowData.SR_SPEAKER, rowData.SR_SPL,
                rowData.SR_BENEFIT, rowData.SR_FOLLOW, rowData.SR_FEEDBACK, rowData.SR_OrganizedFor,
                rowData.SR_LocationType, rowData.SR_PRogCoordinator1, rowData.SR_PRogCoordinator2,
                rowData.SR_ParticipantCategory, rowData.SR_ParticipantSubCategory, rowData.SR_ProgramType

            ]
        return data.join(" ")
    }
