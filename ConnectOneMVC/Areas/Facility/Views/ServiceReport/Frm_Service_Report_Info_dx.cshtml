    function ServiceReportListGrid_dx_Detail(container, GridName, RecID, AllColumns, MID)
    {
        var url = "/Facility/ServiceReport/Frm_Service_Report_Info_DetailGrid_Load?RecID=" + RecID + "&RecID=" + MID
        var instance = DxGrid_AttachmentGrid_Create(container, GridName, RecID, false, AllColumns, url)
        instance.option("onSelectionChanged", ServiceReportListGrid_dx_Detail_onSelectionChanged);       
    }
    function ServiceReportListGrid_dx_Detail_onSelectionChanged(e) {
        //debugger;
        if (ServiceReport_IsDetailRowExpanded_dx) {

            if (e.selectedRowsData != null && e.selectedRowsData.length > 0) {
                ServiceReportInfo_NestedGrid_AccessID_dx = e.element[0].id;
                ServiceReportListGrid_dx_Detail_SelectedRowData(e.selectedRowsData)
                ServiceReport_FAB_dx.SetVisible(true);

            }
            else {
                ServiceReport_FAB_dx.SetVisible(true);
            }
        }
    }
    function ServiceReportListGrid_dx_Detail_SelectedRowData(selectedData = null) {
        if (selectedData == null) {
            selectedData = $("#" + ServiceReportInfo_NestedGrid_AccessID_dx).dxDataGrid("getSeletedRowsData");
        }
        var values = selectedData[0];
        if (values["UniqueID"] != null) {
            ServiceReport_FAB_dx.SetVisible(true);
            ServiceReportInfo_Nested_Doc_Status_dx = values["Doc_Status"];

            if (ServiceReportInfo_Nested_Doc_Status_dx == "") {
                ServiceReport_FAB_dx.SetActionContext("actionItemContext", true);
            }
            else if (ServiceReportInfo_Nested_Doc_Status_dx == "NO") {
                ServiceReport_FAB_dx.SetActionContext("EditItemContext", true);
            }
            else if (ServiceReportInfo_Nested_Doc_Status_dx == "YES") {
                ServiceReport_FAB_dx.SetActionContext("actionItemContext", true);
            }
            ServiceReportInfo_ParamMandatory_dx = values["Params_Mandatory"];
            ServiceReportInfo_FromDateLabel_dx = values["LABEL_FROM_DATE"];
            ServiceReportInfo_ToDateLabel_dx = values["LABEL_TO_DATE"];
            ServiceReportInfo_DescriptionLabel_dx = values["LABEL_DESCRIPTION"];
            ServiceReportInfo_Doc_Category_dx = values["Document_Category"];
            ServiceReportInfo_Doc_ID_dx = values["Document_ID"];
            ServiceReportInfo_AtachmentID_dx = values["ATTACH_ID"];
            IndexAttachmentID = ServiceReportInfo_AtachmentID_dx;
            ServiceReportInfo_MasterRowRecID_dx = values["TxnID"];
            ServiceReportInfo_MasterRowMID_dx = values["TxnMID"];
            ServiceReportInfo_NestedRowMapID_dx = values["MAP_ID"];
            ServiceReportInfo_reason_dx = values["Reason"];
            ServiceReportInfo_FileName_dx = values["ATTACH_FILE_NAME"];
            ServiceReportInfo_Attachment_RecStatus_dx = values["Attachment_Action_Status"];
            ServiceReportInfo_NestedRowKeyValue_dx = values["UniqueID"];
            //if (AddressBook_IsVouchingMode_dx == true) {
            //    if (AddressBookInfo_FileName_dx != null && AddressBookInfo_FileName_dx.length > 0) {
            //        ViewDocument(AddressBookInfo_AtachmentID_dx, AddressBookInfo_FileName_dx, "AddressBook_FAB_dx", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
            //    }
            //    else {
            //        CloseRightPane();
            //        ClearRightPane();
            //    }
            //}
        }
        ServiceReportInfo_NestedRowReasonID_dx = values["ReasonID"];
        IndexAttachmentReasonID = ServiceReportInfo_NestedRowReasonID_dx;
    }
 
