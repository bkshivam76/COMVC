<script>
    function GSR_Response_AddMoreClick()
    {
        var url = "Frm_Reporter_Window?Mobile=" + "@Mobile" + "&CenID=" + "@cenID" + "&Email=" + "@email" +"&cen_name="+"@cen_name"+"&projId=@projId" +"&wingId=@wingId";
        if ("@Sender".length > 0)
        {
            url = url + "&sender=" + "@Sender";
        }
        window.open(url, "_self");
    }
    function GSR_Show_Report() {
        window.open("https://services.brahmakumaris.com/Events/Events//Frm_Service_Event_Details?RecID="+ "@RecID", "_self");
    }
    function GSR_Edit_Report() {
         window.open("https://services.brahmakumaris.com/EditEvent?RecID="+ "@RecID", "_self");
    }

    $(document).ready(function ()
    {
        $("#Save_Response_GSR").dxButton("focus")
    })
</script>


