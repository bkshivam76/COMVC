@using DevExtreme.AspNet.Mvc;

@{
    Layout = "~/Views/Shared/_NoLoginLayout.cshtml";
    string Sender = (string)ViewBag.sender;
    string RecID = (string)ViewBag.RecID;
    string Mobile = ViewBag.Mobile;
    string cenID=ViewBag.CenID;
    string email = ViewBag.Email;
    string cen_name = ViewBag.cen_name;
    string projId = ViewBag.projId;
    string wingId = ViewBag.wingId;
    string BannerSource = Url.Content("~/Content/image/ServiceReport/" + (Sender.Length > 0 ? Sender : "connectone") + ".jpg");
}


<style>
    .ServiceReport_Form {
        max-width: 500px;
        margin: 0 auto;
        padding: 15px;
        background: rgba(240,240,240,.6);
        border-radius: 6px;
    }

    .amrit-wrap {
        padding: 15px;
    }

    .Response_GSR {
        font-weight: 500;
        color: maroon;
        text-decoration: underline;
        font-size: large;
    }

    #ServiceReporterResponse_Bannerimg {
        object-fit: contain;
    }
</style>
<div class="amrit-wrap mt-3" style="padding-top:30px">
    <form class="ServiceReport_Form">
        <img id="ServiceReporterResponse_Bannerimg" src="@BannerSource" style="width:100%" />
        <div class="mt-3 mb-3" style="text-align: center">
            <br>
            <label class="form-label Response_GSR">Thank You For Submitting The Godly Service Report!!</label>

        </div>
        <div>
            <div style="text-align: center">
                @(Html.DevExtreme().Button().ID("Save_Response_GSR").Text("Add More").UseSubmitBehavior(false).OnClick("GSR_Response_AddMoreClick").ElementAttr(new { @class = "btn btn-primary" }) )
                @(Html.DevExtreme().Button().ID("View_GSR").Text("View Posted Report").UseSubmitBehavior(false).OnClick("GSR_Show_Report").ElementAttr(new { @class = "btn btn-primary" }) )
                @(Html.DevExtreme().Button().ID("Edit_GSR").Text("Edit Posted Report").UseSubmitBehavior(false).OnClick("GSR_Edit_Report").ElementAttr(new { @class = "btn btn-primary" }) )
            </div>
            <div style="text-align: center">
                <label class="control-label text-red">For Any Queries, please email it to </label><a href="mailto:saurabh@bkivv.org"> saurabh@bkivv.org</a>
            </div>
        </div>
    </form>

