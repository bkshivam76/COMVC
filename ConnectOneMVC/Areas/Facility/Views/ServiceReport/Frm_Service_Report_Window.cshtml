        $("#FinalPlantationCoordinates_GSR").val(LocationCoordinate);
        GetLocation_GSR = false;
        Mobile_Verified_GSR = true;
        formdatasubmit_GSR();
    }
    function formdatasubmit_GSR()
        {
            ShowLoader();
            var formdata = new FormData($("#ServiceReportForm").get(0));
            var files = [];
            const inputvalues = document.querySelectorAll('#galleryContainer_sr .newcaption')
            const ratingElements = $("[id$=rating1]");//id="AttachGSR_
            if ($("#ServiceReport_myFile_sr").dxFileUploader("instance")) {
                files = $("#ServiceReport_myFile_sr").dxFileUploader("instance").option("value");
            }

            if (Saved_Attachment_Details_GSR != null && Saved_Attachment_Details_GSR.length > 0) {
                let id = null;
                let element = null;
                for (var i = 0; i < Saved_Attachment_Details_GSR.length; i++) {
                    if ($(ratingElements[i]).attr('edited') !== undefined && $(ratingElements[i]).attr('edited') !== null) {
                        if ($(ratingElements[i]).attr('edited') == "true") {
                            formdata.append("attachment_Window.Help_File_Old_captions[]", inputvalues[i].value);
                            formdata.append("attachment_Window.Help_File_Old_Ratings[]", parseInt($(ratingElements[i]).attr('rating')));
                            id = ratingElements[i].id.replace('rating1', '');
                            element = document.getElementById(id);
                            formdata.append("attachment_Window.Help_File_Old_Attachment_IDs[]", element.getAttribute('data-AttachmentID'));
                        }
                    }
                }
            }
            if (files != null && files.length > 0)
            {
                var i = 0;
                if (Saved_Attachment_Details_GSR != null && Saved_Attachment_Details_GSR.length > 0) {
                    i = Saved_Attachment_Details_GSR.length;
                }
                //GSR_DocumentDescription = "Program Pictures And Videos";
                GSR_DocumentDescription = "";
                for (i; i < inputvalues.length; i++){
                    formdata.append("attachment_Window.Help_File_caption[]", inputvalues[i].value);
                    formdata.append("attachment_Window.Help_File_Ratings[]", parseInt($(ratingElements[i]).attr('rating')));
                }
                GSR_Attached_FileName = files[0].name;
                for (i = 0; i < files.length; i++) //This for loop is important to the whole logic of userButtons and shifting files to fromdata to work as form submit.
                {
                    formdata.append("ServiceReport_myFile_sr", files[i]);
                }
            }
            //formdata.append('attachment_Window.Help_uploadMethod', "fileCollection");
            formdata.append('attachment_Window.Help_Document_FileName', GSR_Attached_FileName??"");
            formdata.append('attachment_Window.Help_Document_NameID', GSR_Attach_DocName_ID);
            formdata.append('attachment_Window.Help_Byte_SessionName', "GsrAttachment");
            formdata.append('attachment_Window.Help_Post_Area_Name', "Help");
            formdata.append('attachment_Window.Help_Post_Controller_Name', "Attachment");
            formdata.append('attachment_Window.Help_REF_REC_ID', GSR_Attach_RefRecId);
            formdata.append('attachment_Window.Help_REF_SCREEN', GSR_Attach_RefScreen);
            formdata.append('attachment_Window.Help_Document_Description', GSR_DocumentDescription);
            formdata.append('attachment_Window.Help_Checked', false);
            formdata.append('attachment_Window.Help_uploadControlName', "ServiceReport_myFile_sr");
            formdata.append('attachment_Window.Help_uploadControlActionMethod', "New");

            formdata.append('InsertAdditonalinfo_GSR', InsertAdditionalInfo())
            //var AdditonalInfoFormData = new FormData($("#Additional_info_form_GSR").get(0));
            //for (var pair of AdditonalInfoFormData.entries()) {
            //    formdata.append(pair[0], pair[1]);
            //}
            $.ajax({
                xhr: function () {
                    var xhr = new window.XMLHttpRequest();

                    // Upload progress
                    xhr.upload.addEventListener("progress", function (evt) {
                        if (evt.lengthComputable) {
                            var percentComplete = ((evt.loaded / evt.total) * 100).toFixed();
                            var message = "Uploading File: " + percentComplete + "%";
                            if (percentComplete == "100") {
                                message = "Writing Files To Disk...";
                            }
                            ChangeTextOfLoader(message);
                        }
                    }, false);

                    // Download progress
                    //xhr.addEventListener("progress", function (evt) {
                    //    if (evt.lengthComputable) {
                    //        var percentComplete = ((evt.loaded / evt.total) * 100).toFixed(2);
                    //        // Do something with download progress
                    //        console.log(percentComplete);
                    //    }
                    //}, false);

                    return xhr;
                },
                url: "/Facility/ServiceReport/Frm_Service_Report_Window",
                type: "post",
                data: formdata,
                contentType: false,
                processData: false,
                success: function (data)
                {
                    Frm_Service_Report_Window_AjaxSuccessForm(data)
                },
                error: function (jqXHR, textStatus, errorThrown)
                {
                    HideLoader();
                    console.log(jqXHR);
                    console.log(textStatus);
                    console.log(errorThrown);
                    DevExpress.ui.dialog.alert((jqXHR.responseText == void 0 ? "Error in ajax call due to attachment upload from cloud drives" : jqXHR.responseText), errorThrown);
                }
            });
        }
