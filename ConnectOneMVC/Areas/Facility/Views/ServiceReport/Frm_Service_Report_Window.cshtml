    function Frm_Service_Report_Window_AjaxSuccessForm(data)
    {
        HideLoader();
        dontaskpopupcloseconfirmation = true;
        if (data.jsonParam.result == false)
        {
            if (data.jsonParam.closeform)
            {
                $("#Dynamic_Content_popup").dxPopup("hide");
            }
            if (data.jsonParam.refreshgrid)
            {
                var GridInstance = $('#ServiceReportListGrid_dx').data("dxDataGrid")
                if (GridInstance !== void 0) {
                    SRGridRefresh();
                }
                else {
                    RefreshGridView("ServiceReportListGrid");
                }
                    
            }
            var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
            alertclick.done(function (alertResult)
            {
                //debugger;
                if (alertResult)
                {
                    if (data.jsonParam.focusid)
                    {
                        var id = "#" + data.jsonParam.focusid;
                        if (data.jsonParam.focusid == "Wings_List_GSR")
                        {
                            /*  $("#tabPanel_GSR").dxTabPanel("instance").option("selectedIndex", 0);*/
                        }
                        else
                        {
                            /* $("#tabPanel_GSR").dxTabPanel("instance").option("selectedIndex", 0);*/
                        }
                        setTimeout(function ()
                        {
                            if (id == "#Txt_ProgVenue_GSR")
                            {
                                $("#Txt_ProgVenue_GSR").dxTextArea("focus");
                            }
                            else if (id == "#TreePlantation_DG")
                            {
                                $("#ActivitiesList_GSR").dxList("focus");
                            }
                            else if (id == "#FileUpload")
                            {
                                $("#Banner_Pictures_GSR").trigger("dxclick");
                                $("#ServiceReport_myFile_sr").dxFileUploader("reset")
                            }
                            else
                            {
                                $(id).find('input').focus();
                            }
                        }, 100);
                    }
                }
            });
        }
        else if (data.jsonParam.result == true)
        {
            var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
            alertclick.done(function ()
            {
                RevokeAllObjectURL_GSR();
                if ("@Model.ReporterCenID".length == 0)
                {
                    if ($(".TabPanalMenu-tabs .active").attr("id") == "contact_Frm_Service_Report_Info") {

                        AfterWindowClose_GSR(Tag_GSR, data.xID);
                    }
                    else if ($(".TabPanalMenu-tabs .active").attr("id") == "contact_Frm_Service_Report_Info_Dx") {
                      
                        AfterWindowClose_GSR_dx(Tag_GSR, data.xID);//BK Soumy
                    }
                    $("#Dynamic_Content_popup").dxPopup("hide");
                }
                else
                {
                    $.ajax({
                        type: 'GET',
                        url: "/Facility/ServiceReport/SessionClear_Window",
                        cache: false
                    });
                    $("#ServiceReportForm .dx-widget.dx-textarea").dxTextArea("option","value",null);
                    if ("@Model.ReporterEmail".length > 0)
                    {
                        window.open("Frm_Service_Report_Response?sender=" + "@Model.Sender" + "&RecID=" + "@Model.xID_GSR" + "&Mobile=" + "@Model.ReporterMobile" + "&Email=" + "@Model.ReporterEmail" + "&CenID=" + "@Model.ReporterCenID" +"&cen_name="+"@cen_name"+"&projId=@projId" +"&wingId=@wingId", "_self");
                    }
                    else
                    {
                        window.open("Frm_Service_Event_Details?RecID="+"@Model.xID_GSR", "_self");
                    }
                }
            })
        }
    }
