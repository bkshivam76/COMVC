<script>
        function AccordionClick_GSR(e) {
            /* Toggle between hiding and showing the active panel */
            var panel = e.nextElementSibling;
            if (panel.style.display === "none")
            {
                panel.style.display = "block";
                ($(e).find('svg')).remove();
                $(e).append('<i class="fa fa-arrow-up"></i>')
                $(e).addClass("active_GSR")
                    $($(e).find('span')).text("Click To Hide Additional Info")
            }
            else {
                panel.style.display = "none";
                ($(e).find('svg')).remove();
                $(e).append('<i class="fa fa-arrow-down"></i>')
                $(e).removeClass("active_GSR")
                $($(e).find('span')).text("Click To Fill Additional Info")
            }
        }
        function ProgramCategoryCustomItemCreating_GSR(e) {
            if (e.text == null || e.text.length == 0) {
                e.customItem = null;
                return;
            }
            var Items = e.component.option("items");
            Items.push(e.text);
            Items.sort(function (a, b) {
                return a.toLowerCase().localeCompare(b.toLowerCase());
            });
            e.component.option("items", Items);
            e.customItem = e.text;
        }
        function AddCustomDataToType_GSR(text) {
            var ProgType = $("#Look_ProgType_GSR").dxSelectBox("instance");
            var Items = ProgType.option("items");
            if (Items.includes(text) == false) {
                Items.push(text);
                Items.sort(function (a, b) {
                    return a.toLowerCase().localeCompare(b.toLowerCase());
                });
                ProgType.option("items", Items);
                ProgType.option("value", text);
            }
        }
        async function ProgType_ValueChange_GSR(e, FirstCall = false) {
            var value;
            var DG = $("#ProgType_GSR_datagrid").dxDataGrid("instance");
            if (e) {
                value = e.value;
                if ((e.value == null || e.value.length == 0) && e.previousValue != null) {
                    DG.clearSelection();
                    DG.refresh();
                    return;
                }
            }
            else {
                value = $("#Look_ProgType_GSR").dxDropDownBox("option", "value");
            }
            await DG.selectRows(value);

            var SelectedRowsKeys = DG.getSelectedRowKeys();
            var SplActivityInstance = $("#ActivitiesList_GSR").dxList("instance");
            var ListDs = SplActivityInstance.getDataSource();
            var store = ListDs.store();
            if (SelectedRowsKeys != null && SelectedRowsKeys.includes("1e6a3cc1-f0cd-49dd-8509-4cd6c974a567")) //blood donation camp
            {
                if (SplActivityInstance.isItemSelected(2) == false) {
                    SplActivityInstance.selectItem(2);
                }
                await store.update("Blood Donation", { disabled: true })
                await ListDs.reload();
            }
            else {
                var project = $("#Look_ProjList_GSR").dxSelectBox("instance").option("value");
                if (project == null || project.length == 0 || project != "2ee9f62f-e1f0-47c9-9cd6-0adfcb6e683c") {
                    await store.update("Blood Donation", { disabled: false })
                    await ListDs.reload();
                }
            }
            DG.refresh();
        }
