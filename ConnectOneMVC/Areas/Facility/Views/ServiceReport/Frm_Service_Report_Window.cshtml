        function CheckIfAllAttachmentLoaded_GSR(PreviewOn)
        {
            var GalleryAttachmentEle = $("#galleryContainer_sr a .AttachmentEle")
            var completeCount = 0;
            var TotalItem = GalleryAttachmentEle.length;
            for (var i = 0; i < TotalItem; i++)
            {
                if (GalleryAttachmentEle[i].tagName == "IMG") {
                    if (GalleryAttachmentEle[i].complete) { completeCount++; }
                }
                else if (GalleryAttachmentEle[i].tagName == "VIDEO")
                {
                    if (PreviewOn) {
                        if (GalleryAttachmentEle[i].readyState == 4) { completeCount++; }
                    }
                    else { completeCount++; }
                }
            }
            var message = "Downloading File: " + ((completeCount / TotalItem) * 100).toFixed() + "%";
            ChangeTextOfLoader(message);        
            if (completeCount == TotalItem) {
                HideLoader();
            }
            else
            {
                setTimeout(function ()
                {
                    CheckIfAllAttachmentLoaded_GSR(PreviewOn)
                },100)
            }
        }
        function AttachmentsOnValueChange_GSR(e)
        {
            //Validations******************************
            if (fromremovefile_sr == false)
            {
                var files = e.value;
                GSR_FilesSelectedCount = files.length;
                if (GSR_FilesSelectedCount > 50)
                {
                    DevExpress.ui.dialog.alert("You Have Selected " + GSR_FilesSelectedCount + " Files To Upload<br><b>More Than 50 Files Cannot Be Uploaded At Once<b>", 'Upload Error..');
                    var fileUploader = $("#ServiceReport_myFile_sr").dxFileUploader("instance");
                    fileUploader.reset();
                    return;
                }
                if (files.length > 0)
                {
                    var totalContent = 0;                
                    var NotAllowedFilePresent = false;
                    var filenames = "";
                    var files_After_removing_unwantedfiles = files;
                    var err_msg = "";
                    for (var i = 0; i < files.length; i++)
                    {
                        var ErrMsg = PreventFileUpload(files[i])
                        if (ErrMsg != null && ErrMsg.length > 0)
                        {
                            NotAllowedFilePresent = true;
                            err_msg = err_msg + ErrMsg;
                            files_After_removing_unwantedfiles = files_After_removing_unwantedfiles.slice(0, i).concat(files_After_removing_unwantedfiles.slice(i + 1));
                            break;
                        }                
                        else
                        {
                            totalContent = totalContent + files[i].size
                            filenames = filenames + files[i].name
                        }
                    }
                    if (totalContent > 524288000)
                    {
                        DevExpress.ui.dialog.alert("You Have In Total Selected <b>" + formatBytes(totalContent) + "</b> To Upload<br><b>Upto 500 MB Can Be Uploaded At Once<b>", 'Upload Error..');
                        totalContent = 0;
                        var fileUploader = $("#ServiceReport_myFile_sr").dxFileUploader("instance");
                        fileUploader.reset();
                        return;
                    }
                    if (NotAllowedFilePresent == true)
                    {
                        DevExpress.ui.dialog.alert(err_msg, 'Upload Error..');
                        $("#ServiceReport_myFile_sr").dxFileUploader("reset");
                        //$("#ServiceReport_myFile_sr").dxFileUploader("option", "value", files_After_removing_unwantedfiles);
                        return;
                    }
                }
                insertImages_GSR(e.value, e.previousValue)
            }
            fromremovefile_sr = false;
        }
        function insertImages_GSR(value=null,prevValue=null,Action="")
        {
            var NewlyaddedFiles = [];
            if (Action == "EditLoad") //Creating Gallery for images coming from db in edit mode
            {
                NewlyaddedFiles = Saved_Attachment_Details_GSR;
                if (NewlyaddedFiles != null) {
                    var i = 0
                    for (i = 0; i < NewlyaddedFiles.length; i++) {
                       // createGallery_GSR(NewlyaddedFiles[i].Attachment_Path, NewlyaddedFiles[i].Attachment_FileName, NewlyaddedFiles[i].Attachment_Type, NewlyaddedFiles[i].Attachment_Description, NewlyaddedFiles[i].Attachment_ID, NewlyaddedFiles[i].Attachment_Rating)
                        createGallery_GSR(getAttachmentSource_GSR(NewlyaddedFiles[i]), NewlyaddedFiles[i].Attachment_FileName, NewlyaddedFiles[i].Attachment_Type, NewlyaddedFiles[i].Attachment_Description, NewlyaddedFiles[i].Attachment_ID, NewlyaddedFiles[i].Attachment_Rating)
                    }
                }

            }
            else
            {
                if (value == null || value.length == 0) //remove all chosen files keeping those coming from db
                {
                    var i = 0;
                    if (Saved_Attachment_Details_GSR != null && Saved_Attachment_Details_GSR.length > 0)
                    {
                        i = Saved_Attachment_Details_GSR.length;
                    }
                    if (i > 0)
                    {
                        ($("#galleryContainer_sr a").eq(i - 1)).nextAll().remove();
                    }
                    else
                    {
                        $("#galleryContainer_sr a").remove();
                    }
                }
                else
                {
                    NewlyaddedFiles = value.filter(function (obj) { return prevValue.indexOf(obj) == -1; });
                    var i = 0
                    for (i = 0; i < NewlyaddedFiles.length; i++)
                    {
                        //createGallery_GSR(window.URL.createObjectURL(NewlyaddedFiles[i]), NewlyaddedFiles[i].name, NewlyaddedFiles[i].type)
                        createGallery_GSR(getAttachmentSource_GSR(NewlyaddedFiles[i]), NewlyaddedFiles[i].name, NewlyaddedFiles[i].type)
                    }
                }
            }
        }
        function createGallery_GSR(fileURL, fname, ftype, fdescription="", AttachmentID="", frating = 0)
        {
            var PreviewOn = $("#ServiceReport_AttachmentPreview_Switch").dxSwitch("option", "value");
            //attach display
            var new_a = document.createElement("a")
            Attachments_Srno_GSR++;
            new_a.id = "AttachGSR_" + Attachments_Srno_GSR;
            new_a.setAttribute("data-FileName", fname);
            if (AttachmentID != null && AttachmentID.length > 0) {
                new_a.setAttribute("data-AttachmentID", AttachmentID);
            }
            var new_img;
            if (ftype.includes("video") || ftype.includes("mp4"))
            {
                new_img = document.createElement("video")
                new_img.src = "";
                new_img.poster = "";
                if (PreviewOn)
                {
                    new_img.src = fileURL;
                }
                else
                {
                    new_img.poster = fileURL;
                }
            }
            else if (ftype.includes("pdf")) {
                new_img = document.createElement("img")
                new_img.src = fileURL;
            }
            else if (ftype.includes("document")) {
                new_img = document.createElement("img")
                new_img.src = fileURL;
            }
            else if (ftype.includes("image") || ftype.includes("jpeg") || ftype.includes("png")) {
                new_img = document.createElement("img")
                new_img.src = fileURL;
            }
            else
            {
                new_img = document.createElement("img")
                new_img.src = fileURL;
            }
            new_img.classList.add("AttachmentEle")      
            new_a.appendChild(new_img)

            //caption
            var new_input = document.createElement("textarea")
            new_input.className = "form-control"
            new_input.classList.add("newcaption");
            new_input.placeholder = "Caption..."
            if (fdescription != null && fdescription.length > 0)
            {
                new_input.value = fdescription
            }
            if (AttachmentID != null && AttachmentID.length > 0) {
                new_input.setAttribute("oninput", "onCaptionValueChange('" + new_a.id + "')")
                //new_input.readOnly = true;
            }
            new_a.appendChild(new_input)

            //delete button
            var new_i = document.createElement("i")
            new_i.className = "bx bxs-trash"
            new_i.role = "button"
            new_i.setAttribute("onclick", "remove_file_GSR('" + new_a.id + "','" + fname + "')")
            new_a.appendChild(new_i)

            //Rating Star
            frating = parseInt(frating)
            var rating = new Array(5);
            for (let i = 0; (i < 5); i++) {
                rating[i] = document.createElement("span")
                rating[i].id = new_a.id + "rating" + (i + 1);
                rating[i].className = "fa fa-star";
                if (frating > i) {
                    $(rating[i]).css('color', 'orange');//Highlight it -- EDIT ONLOAD
                }
                else if ((frating > 0 )&&((i+1) === frating) ) {//For EDIT ONLOAD Last Element
                    rating[i].id = new_a.id + "rating" + (i + 1);
                    $(rating[i]).css('color', 'orange');//Highlight it
                }
                else
                {
                    $(rating[i]).css('color', '#ddd');
                }
                rating[i].setAttribute("onclick", "clickOnRatingStar('" + new_a.id + "'," + (i + 1) + ")")
                rating[i].setAttribute("onmouseenter", "mouseEnterRatingStar('" + new_a.id + "'," + (i + 1) + ")")
                rating[i].setAttribute("onmouseleave", "mouseLeaveRatingStar('" + new_a.id + "'," + (i + 1) + ")")
                new_a.appendChild(rating[i])
            }
            document.getElementById("galleryContainer_sr").appendChild(new_a)
            document.getElementById(new_a.id + "rating" + 1).setAttribute("rating", frating);
            if (AttachmentID != null && AttachmentID.length > 0) {//For setting EDIT Operation
                document.getElementById(new_a.id + "rating" + 1).setAttribute("edited", false );
            }
        }
        function onCaptionValueChange(id) {
            if ($('#' + id + 'rating' + 1).attr('edited') !== undefined && $('#' + id + 'rating' + 1).attr('edited') !== null) {
                if ($('#' + id + 'rating' + 1).attr('edited') == "false"||$('#' + id + 'rating' + 1).attr('edited') == false) {
                    $('#' + id + 'rating' + 1).attr('edited', true);
                }
            }
        }
        function clickOnRatingStar(parentElementId, elementNo)
        {
            for (let i = 1; (i <= 5); i++)
            {
                if (i == elementNo)
                {
                    $('#' + parentElementId + 'rating' + i).css('color', 'orange');
                    document.getElementById(parentElementId + "rating" + 1).setAttribute("rating", elementNo)
                }
            }
            for (let i = 5; i > elementNo; i--) {
                $('#' + parentElementId + "rating" + i).css('color', '#DEDEDE');
            }
            if ($('#' + parentElementId + 'rating' + 1).attr('edited') !== undefined && $('#' + parentElementId + 'rating' + 1).attr('edited') !== null) {//When User Click on Rating During Edit operation
                if ($('#' + parentElementId + 'rating' + 1).attr('edited') == "false"||$('#' + parentElementId + 'rating' + 1).attr('edited') == false) {
                    $('#' + parentElementId + 'rating' + 1).attr('edited', true);
                }
            }
        }
        function mouseEnterRatingStar(parentElementId, elementNo) {
            for (let i = 1; i <= elementNo; i++) {
                $('#' + parentElementId + "rating" + i).css('color', 'orange');
            }
        }
        function mouseLeaveRatingStar(parentElementId, elementNo) {
            let rating = parseInt($('#' + parentElementId + "rating" + 1).attr("rating"));
            if (isNaN(rating)) {
                rating = 0;
            }
            for (let i = 5; i > 0; i--) {
                if (i > rating) {
                    $('#' + parentElementId + "rating" + i).css('color', '#DEDEDE');
                }
            }
        }
        function getAttachmentSource_GSR(file)
        {
            var PreviewOn = $("#ServiceReport_AttachmentPreview_Switch").dxSwitch("option", "value");
            var ftype = "";
            if (file.Attachment_Type)
            {
                ftype = file.Attachment_Type;
            }
            else if (file.type)
            {
                ftype = file.type;
            }
            if (PreviewOn)
            {
                if (file.Attachment_Path)
                {
                    return file.Attachment_Path;
                }
                else
                {
                    if (ftype.includes("pdf"))
                    {
                        return "/Content/Events/images/pdficon.jpg";
                    }
                    else if (ftype.includes("document"))
                    {
                       return "/Content/Events/images/docxicon.png";
                    }
                    else
                    {
                        return window.URL.createObjectURL(file)
                    }
                }
            }
            else
            {
               // return "https://placehold.co/600x400?text=Preview+Off";
                return "/Content/image/PreviewOff.svg";
            }
        }
        function remove_file_GSR(Gallery_id,file_name)
        {
            fromremovefile_sr = true;
            var Gallery_a_element = document.getElementById(Gallery_id);
            var Deletedindex = $("#galleryContainer_sr a").index(Gallery_a_element);
            URL.revokeObjectURL($("#" + Gallery_id +" .AttachmentEle")[0].src);
            if (Gallery_a_element.hasAttribute('data-AttachmentID'))
            {
                var AttachmentID = Gallery_a_element.getAttribute('data-AttachmentID')
                remove_filefromdb_GSR(AttachmentID, "@Model.xID_GSR", file_name, GSR_Attach_RefScreen).done(function (data)
                {
                    if (data.result == true)
                    {
                        Gallery_a_element.remove();
                        Saved_Attachment_Details_GSR.splice(Deletedindex,1)
                    }
                    else
                    {
                        DevExpress.ui.dialog.alert(data.Message,"Information")
                    }
                    fromremovefile_sr = false;
                })
            }
            else
            {
                Gallery_a_element.remove();
                ($("#ServiceReport_myFile_sr .dx-fileuploader-cancel-button").eq(Deletedindex)).click();
            }
        }
        function remove_filefromdb_GSR(_AttachmentID, _RefRecID, _file_name, _RefScreen) {
            return $.ajax({
                url: "/Base/Unlink_OR_Delete_Attachment",
                type: "get",
                data:
                {
                    'AttachmentID': _AttachmentID,
                    'RefRecID': _RefRecID,
                    'file_name': _file_name,
                    'RefScreen': _RefScreen
                }
            });
        }
        function UploadFiles_GSR()
        {
            document.getElementById('ServiceReport_myFile_sr').getElementsByClassName('dx-fileuploader-button')[0].click();
        }
        function UpdateAttachedFileNames_GSR()
        {
            var filename = "";
            var gallery = $("#galleryContainer_sr a")
            for (var i = 0; i < gallery.length; i++) {
                if (i == 0) {
                    filename = $(gallery[i]).data("filename")
                }
                else {
                    filename = filename + ", " + $(gallery[i]).data("filename")
                }
            }
            $("#span_Pictures_GSR").text(filename)
        }
        function RevokeAllObjectURL_GSR()
        {
            var GalleryAttachmentEle = $("#galleryContainer_sr a .AttachmentEle")
            for (var i = 0; i < GalleryAttachmentEle.length; i++)
            {
                URL.revokeObjectURL(GalleryAttachmentEle[i].src);
            }
            GalleryAttachmentEle = null;
        }
    </script>
