    async function GSR_SaveClick(e)
    {
        ShowLoader();
        var form = $("#ServiceReportForm");
        if (ValidateForm(e))
        {
            if (Tag_GSR == "_Delete")
            {
                HideLoader();
                DeleteAfterConfirmation("@Model.TitleX_GSR", "", form);
            }
            else
            {
                var VenueTypes = $("#Look_ProgVenueType_GSR").dxDropDownBox("option", "value");
                if ($("#Look_ProjList_GSR").dxSelectBox("instance").option("value") == "72d964ae-d306-4e69-836f-7ec2c7804adb") {//nasha mukt bharat
                    $('#idVenuType').show();
                    $('#idBeneficiaryBreakUp').show();                  
                    if (IsNullOrWhitespace("Radio_VenueType_GSR", "dxRadioGroup")) {
                        DevExpress.ui.dialog.alert('Choose Venue Type!', "Information...").done(
                            function () { $('#Radio_VenueType_GSR').dxRadioGroup('instance').focus() });
                        HideLoader();
                        return;
                    }
                    if (IsNullOrWhitespace(null, null, VenueTypes)) {
                        DevExpress.ui.dialog.alert('Venue Type is mandatory!', "Information...").done(
                            function () { $("#Look_ProgVenueType_GSR").dxDropDownBox("instance").focus() });
                        HideLoader();
                        return;
                    }
