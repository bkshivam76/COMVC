    function OpenMobileVerification_GSR(VenueTypes, SelectedWingValue)
    {
        VenueTypes = VenueTypes == null ? [] : VenueTypes;
        if (VenueTypes.indexOf('DD49459F-6397-413A-849E-5A42A2BC94A2') > -1) //venue type center    3FEC33F6-7592-49AC-9896-3C3836C6B991 local
        {
            Centre_VenueType_GSR = true;
        }
        if (GetLocation_GSR == true)
        {
            if ("@Model.Cen_Location_Coordinates".length > 0 && Centre_VenueType_GSR==true) 
            {
                GetLocation_GSR = false;
            }
        }
        if ((Mobile_Verified_GSR == false || GetLocation_GSR == true) && SelectedWingValue.indexOf('00015') == -1 && Tag_GSR == "_New" && VenueTypes.length>0)   //rural wing not selected
        {
            $("#MobileVerification_GSR_Popup").dxPopup("show");
        }
        else
        {
            var mob = $("#FinalVerifiedMobNo_GSR").val();
            var coordinate = $("#FinalPlantationCoordinates_GSR").val();
            if (mob == null || mob.length == 0)
            {
                mob="@Model.Txt_MobNoVerification_GSR"
            }
            if (coordinate == null || coordinate.length == 0)
            {
                coordinate = "@Model.Txt_TreeLocation_GSR"
                if (Tag_GSR == "_New" && Centre_VenueType_GSR == true)
                {
                    coordinate = "@Model.Cen_Location_Coordinates";
                }                
            }       
            AfterMobileVerification_GSR(mob, coordinate)
        }
    }
    function AfterMobileVerification_GSR(MobNo, LocationCoordinate)
