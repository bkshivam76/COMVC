@using DevExtreme.AspNet.Mvc;
@model ConnectOneMVC.Areas.Facility.Models.ServiceReport_ViewModel

<div class="row">
    <div class="col-sm-12">
        <div class="form-field">

            @Html.Label("VVIP Testimonial (मुख्य अतिथि द्वारा प्रोत्साहक बोल)", htmlAttributes: new { @class = "control-label", @style = "font-weight:500" })

            @(Html.DevExtreme().TextArea()
                                                    .ID("Txt_VVIPTestimonial_GSR")
                                                    .Name("Txt_VVIPTestimonial_GSR")
                                                    .ReadOnly(false)
                                                    //.Height(100)
                                                    .Height(50)
                                                    .Placeholder("Only Share VVIP Testimonial In Text Format With Proper Name & Designation With Proper Spelling...")
                                                    .Value(Model.Txt_VVIPTestimonial_GSR)
                                    .ElementAttr(new Dictionary<string, object>() { { "class", "CleanTextForDB" } })
                    )

        </div>
    </div>
</div>
