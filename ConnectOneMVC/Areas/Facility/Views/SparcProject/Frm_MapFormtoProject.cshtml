    function Save_SparcFormMapping() {
        var projects = $("#Project_SparcMappingModel_MapForm2Project").dxDropDownBox("option", "value");
        var form = $("#Form_SparcMappingModel_MapForm2Project").dxDropDownBox("option", "value")
        if (form === undefined || form === null || form.length === 0) {
            DevExpress.ui.dialog.alert("Form field is mandatory!", "Invalid input....").done(
                function () { $("#Form_SparcMappingModel_MapForm2Project").dxDropDownBox("instance").focus() });
            HideLoader();
            return;
        }
        if (projects === undefined || projects === null || projects.length === 0) {
            DevExpress.ui.dialog.alert("Project field is mandatory!", "Invalid input....").done(
                function () { $("#Project_SparcMappingModel_MapForm2Project").dxDropDownBox("instance").focus() });
            HideLoader();  
            return;
        }
        console.log("projects: " + projects);
        console.log("Form: " + form);
        var formArr = getGridIdName("Form_SparcMappingModel_datagrid_MapForm2Project", "Form_SparcMappingModel_MapForm2Project")
        var projArr = getGridIdName("Project_SparcMappingModel_datagrid_MapForm2Project", "Project_SparcMappingModel_MapForm2Project")
        var formNameArr = formArr.map(function (item) {
            return item.name;
        });
        var formIdArr = formArr.map(function (item) {
            return item.Id;
        });
        var formProjectIdArr = formArr.map(function (item) {
            return item.ProjectId;
        });
        var projNameArr = projArr.map(function (item) {
            return item.name;
        });
        var projIdArr = projArr.map(function (item) {
            return item.Id;
        });
        $.ajax({
            type: 'POST',
            url: "/Facility/SparcProject/Frm_MapFormToProject",
            cache: false,
            data:
            {
                ProjectIds: projIdArr.toString(),
                FormId: formIdArr.toString(),
                FormName: formNameArr.toString(),
                FormProjectId: formProjectIdArr.toString(),
                ProjectNames: projNameArr.toString()
            },
            success: function (data) {
                HideLoader();
                if (data.jsonParam.result) {
                    // The API returned true
                    HideLoader();
                    DevExpress.ui.dialog.alert(data.jsonParam.message, "Mapping Success...");
                    close_SparcPopup();
                }
                else {
                    DevExpress.ui.dialog.alert(data.jsonParam.message, "Mapping Failure...");
                }
            },
            error: function (jqXHR, textStatus, errorThrown) {
                HideLoader();
                console.log(jqXHR);
                console.log(textStatus);
                console.log(errorThrown);
                DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
            }
        });
    }
    function close_SparcPopup() {
        $("#Dynamic_Content_popup").dxPopup("hide");
    }
</script>