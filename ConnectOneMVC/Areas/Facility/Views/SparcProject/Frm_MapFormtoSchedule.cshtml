    async function Save_SparcScheduleFormMapping() {
        debugger;
        var schedule = $("#Schedule_SparcMappingModel_MapSchedule2Form").dxDropDownBox("option", "value");
        var forms = $("#Form_SparcMappingModel_MapSchedule2Form").dxDropDownBox("option", "value");
        if (schedule === undefined || schedule === null || schedule.length === 0) {
            DevExpress.ui.dialog.alert("Schedule field is mandatory!", "Invalid input....").done(
                function () { $("#Form_SparcMappingModel_MapSchedule2Form").dxDropDownBox("instance").focus() });
            HideLoader();
            return;
        }
        if (forms === undefined || forms === null || forms.length === 0) {
            DevExpress.ui.dialog.alert("Form field is mandatory!", "Invalid input....").done(
                function () { $("#Form_SparcMappingModel_MapSchedule2Form").dxDropDownBox("instance").focus() });
            HideLoader();
            return;
        }
        console.log("Schedule:  "+schedule);
        console.log("Forms:  " + forms);
        var formArr = getGridIdName("Form_SparcMappingModel_datagrid_MapSchedule2Form", "Form_SparcMappingModel_MapSchedule2Form")
        var scheduleArr = getGridIdName("Schedule_SparcMappingModel_datagrid_MapSchedule2Form", "Schedule_SparcMappingModel_MapSchedule2Form")
        let frmArrInstanceCount1 = [];
        let frmArrInstanceCountGT1 = [];
        let frmArrPurposeBasicDetailAndRegistration = [];
        let FrequencyChangeGreaterThan1DisplayText = "";
        let FrequencyChangeEqualTo1DisplayText = "";

        for (var i = 0; i < formArr.length; i++) {
            if (formArr[i].purpose == 'REGISTRATION' || formArr[i].purpose == 'BASIC DETAILS') {
                frmArrPurposeBasicDetailAndRegistration.push(formArr[i].Name)
                
            }
            if (formArr[i].instancesCounts == 1 && formArr[i].responsesCounts > 0) {
                frmArrInstanceCount1.push(formArr[i].Name);
                FrequencyChangeEqualTo1DisplayText = FrequencyChangeEqualTo1DisplayText + "Form: <b>" + frmArrInstanceCount1.toString() + "</b> already has Responses. Changing the Frequency will change the Period for which the Response was posted. Are you sure you want to Change the Frequency?<br>";
            } else if (formArr[i].instancesCounts > 1) {
                frmArrInstanceCountGT1.push(formArr[i].Name);
                FrequencyChangeGreaterThan1DisplayText = FrequencyChangeGreaterThan1DisplayText + " Existing instances of Form: <b>" + frmArrInstanceCountGT1.toString() + "</b> will not be changed as per the new frequency. Remaining instances will be created as per the new frequency. Are you sure you want to change the frequency?";
            }
        }
        debugger;
        if (frmArrPurposeBasicDetailAndRegistration.length > 0) {
            DevExpress.ui.dialog.alert("Form: <b>" + frmArrPurposeBasicDetailAndRegistration.toString() + "</b> cannot be be mapped to Schedule. As Form with purpose:<b>  BASIC DETAIL and REGISTRATION</b>, can only have frequency Once.", "Confirm Action...");
            return;
        }
        let terminateSaveFunctionFlag = false;
        if (frmArrInstanceCount1.length > 0 || frmArrInstanceCountGT1.length > 0) {
            await CreateCustomConfirmDialog("Confirm Action...", FrequencyChangeEqualTo1DisplayText + FrequencyChangeGreaterThan1DisplayText, false).show().done(function (dialogresult) {
                if (!dialogresult) terminateSaveFunctionFlag = true;
            })
        }
        if (terminateSaveFunctionFlag) return;

        var formFrequencyArr = formArr.map(function (item) {
            return item.frequency;
        });
        var formFromDateArr = formArr.map(function (item) {
            return item.fromDate;
        });
        var formEndDateArr = formArr.map(function (item) {
            return item.toDate;
        });
        var formInstancesCountsArr = formArr.map(function (item) {
            return item.instancesCounts;
        });
        var formResponsesCountsArr = formArr.map(function (item) {
            return item.responsesCounts;
        });
        var formIdArr = formArr.map(function (item) {
            return item.Id;
        });
        var scheduleIdArr = scheduleArr.map(function (item) {
            return item.Id;
        });
        $.ajax({
            type: 'POST',
            url: "/Facility/SparcProject/Frm_MapFormtoSchedule",
            cache: false,
            data:
            {
                ScheduleId: scheduleIdArr.toString(),
                FormIds: formIdArr.toString(),
                FormsFrequencysPrevious: formFrequencyArr.toString(),
                FormStartDates: formFromDateArr.toString(),
                FormEndDates: formEndDateArr.toString()
            },
            success: function (data) {
                HideLoader();
                if (data.jsonParam.result) {
                    // The API returned true
                    HideLoader();
                    DevExpress.ui.dialog.alert(data.jsonParam.message, "Mapping Success...");
                    close_SparcPopup();
                }
                else {
                    DevExpress.ui.dialog.alert(data.jsonParam.message, "Mapping Failure...");
                }
            },
            error: function (jqXHR, textStatus, errorThrown) {
                HideLoader();
                console.log(jqXHR);
                console.log(textStatus);
                console.log(errorThrown);
                DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
            }
        });
    }
    function DG_OnRowClick_Sparc(e) {
        if (e.isSelected) {
            e.component.deselectRows(e.key);
        }
        else {
            e.component.selectRows(e.key, true);
        }
    }
    function close_SparcPopup() {
        $("#Dynamic_Content_popup").dxPopup("hide");
    }
</script>
