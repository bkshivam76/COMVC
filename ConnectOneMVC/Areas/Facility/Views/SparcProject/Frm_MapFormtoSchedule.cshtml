@using DevExtreme.AspNet.Mvc;
@model ConnectOneMVC.Areas.Facility.Models.SparcMappingModel
@{
    Layout = null;
}
<div class="full-width-header-bg2">
    <div class="row">
        <div class="col-sm-12">
            <h3 class="popuphead"><b>Map Schedule to Form</b></h3>
        </div>
    </div>
</div>

<form class="Frm_MapScheduletoForm_Div edit_form form-horizontal">
    <div class="row">
        <div class="col-xs-12">
            <div class="form-field">
                @Html.Label("Select Schedule: ", htmlAttributes: new { @class = "control-label text-red" })
                @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("Schedule_SparcMappingModel_MapSchedule2Form").Name("Schedule_SparcMappingModel").Placeholder("Select Schedule...")@*.Value(string.IsNullOrWhiteSpace(InsID)?null: InsID)*@.Value(Model.Schedule_SparcMappingModel)
                                        .DataSource(d => d.Mvc().Controller("SparcProject").LoadAction("GetSchedules").Key("REC_ID").LoadMode(DataSourceLoadMode.Raw)).DisplayExpr("NAME").ValueExpr("REC_ID")
                                        .ReadOnly(false).Visible(true).InputAttr(new Dictionary<string, object>() { { "class", "form-control form-control-sm" } })
                                        .ContentTemplate(@<text>
                    @(Html.DevExtreme().DataGrid().CustomDataGrid().ID("Schedule_SparcMappingModel_datagrid_MapSchedule2Form")
                        .Columns(columns =>
                        {
                            columns.Add().DataField("NAME").Caption("Name");
                            columns.Add().DataField("REC_ID").Caption("ID").Visible(false);
                            columns.Add().DataField("SCHEDULE_TYPE").Caption("Schedule Type");
                            columns.Add().DataField("FROM_TIME_1").Format("hh:mm a").DataType(GridColumnDataType.Date).Caption("From Time");
                        })
                        .Selection(s => s.Mode(SelectionMode.Single))
                        .FilterRow(s=>s.Visible(false))
                        .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);};}"))
                    </text>))
            </div>
            <div class="form-field">
                @Html.Label("Form: ", htmlAttributes: new { @class = "control-label text-red" })
                @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("Form_SparcMappingModel_MapSchedule2Form").Name("Form_SparcMappingModel").Placeholder("Select Form...").Value(Model.Form_SparcMappingModel)
                                        .DataSource(d => d.Mvc().Controller("SparcProject").LoadAction("GetForms").Key("REC_ID").LoadMode(DataSourceLoadMode.Raw)).DisplayExpr("CI_CHARTNAME").ValueExpr("REC_ID")
                                        .ReadOnly(false).Visible(true).InputAttr(new Dictionary<string, object>() { { "class", "form-control form-control-sm" } })
                                        .ContentTemplate(@<text>
                    @(Html.DevExtreme().DataGrid().CustomDataGrid().ID("Form_SparcMappingModel_datagrid_MapSchedule2Form")
                        .Columns(columns =>
                        {
                            columns.Add().DataField("CI_CHARTNAME").Caption("Form");
                            columns.Add().DataField("CI_FREQUENCY").Caption("Frequency");
                            columns.Add().DataField("CI_PURPOSE").Caption("Purpose");
                            columns.Add().DataField("PROJECT").Caption("Project");
                            columns.Add().DataField("CI_FROM_DATE").Caption("Start Date");
                            columns.Add().DataField("CI_TO_DATE").Caption("End Date");
                            columns.Add().DataField("Schedule").Caption("Schedule Name");
                            columns.Add().DataField("ScheduleType").Caption("Schedule Type");
                            columns.Add().DataField("ScheduledForm").Caption("Scheduled From").Visible(false);
                            columns.Add().DataField("ScheduledTo").Caption("Scheduled To").Visible(false);
                            columns.Add().DataField("REC_ID").Caption("REC_ID").Visible(false);
                            columns.Add().DataField("PROJECT_ID").Caption("PROJECT_ID").Visible(false);
                            columns.Add().DataField("Inst_Count").Caption("Inst_Count").Visible(false);
                            columns.Add().DataField("Resp_count").Caption("Resp_count").Visible(false);
                        })
                        .OnRowClick("DG_OnRowClick_Sparc")
                        .Selection(s => s.Mode(SelectionMode.Multiple).ShowCheckBoxesMode(GridSelectionShowCheckBoxesMode.Always).AllowSelectAll(false))
                        .FilterRow(s => s.Visible(false))
                        .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys);};}"))
                    </text>))
            </div>
        </div>
        <div class="col-xs-12">
            <div class="form-field">
                <div class="row">
                    <div class="col-md-12">
                        <div class="styleActionBtn">
                            @(Html.DevExtreme().Button().CustomSaveButton().ID("Save_SparcFormMapping_FormMap").Text("Save").FocusStateEnabled(true).UseSubmitBehavior(false).Visible(true).OnClick("Save_SparcScheduleFormMapping"))
                            @(Html.DevExtreme().Button().CustomCloseButton().ID("close_SparcPopup_FormMap").Text("Close").Visible(true).OnClick(@<text> function () { close_SparcPopup(); } </text>))
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>


