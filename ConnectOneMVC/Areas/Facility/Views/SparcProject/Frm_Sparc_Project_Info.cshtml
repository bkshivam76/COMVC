<script>

    $('.dropdown button').on("click", function (e) {
        if ($(this).hasClass("active")) {
            $(this).removeClass("active");
            $(this).parent().removeClass("open");
        }
        else {
            $('.dropdown button').removeClass("active");
            $(this).addClass("active");
            $('.dropdown').removeClass("open");
            $(this).parent().addClass("open");
            e.stopPropagation();
            e.preventDefault();
        }     
    });

    $('.dropdown-submenu a.test').on("click", function (e) {
        if ($(this).parent().hasClass("active")) {
            $(this).parent().removeClass('active');
            $(this).next('ul').hide('fast');
            e.stopPropagation();
            e.preventDefault();
            $(this)[0].scrollIntoView(false);
        }
        else {
            $('.dropdown-submenu').find('ul').hide('fast');
            $('.dropdown-submenu').removeClass('active');
            $(this).next('ul').show('fast');
            $(this).parent().addClass('active');
            e.stopPropagation();
            e.preventDefault();
            var ele = $(this).next('ul')
            setTimeout(function () { $(ele)[0].scrollIntoView(false); ele = null;},250)
         
        }
       
    });

    function DataNavigation_SparcProj(Action) {
        switch (Action) {
            case "CREATEFORM":
                //CreateNewForm();
                AllOperationsOpenProjectInfoPopup("Sparc_CreateForm");
                break;
            case "CREATEPROJECT":
                    ShowLoader();
                    $.ajax({
                        type: 'GET',
                        url: "/Facility/ServiceProject/Frm_ServiceProject_Window",
                        cache: false,
                        data:
                        {
                            Tag: "_New",
                            screen: "Sparc_Create"
                        },
                        success: function (data) {
                            HideLoader();
                            OpenDynamicPopup("New ~ Service Projects", null, "auto", 650, true, data);
                        },
                        error: function (jqXHR, textStatus, errorThrown) {
                            HideLoader();
                            console.log(jqXHR);
                            console.log(textStatus);
                            console.log(errorThrown);
                            DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
                        }
                    });
                break;
            case "CREATESUBJECT":
                AllOperationsOpenProjectInfoPopup("Sparc_CreateSubject");
                break;
            case "CREATESCHEDULE":
                    ShowLoader();
                OpenDynamicPopup("New ~ Scheduler", "@Url.Action("Frm_Scheduler_Window", "Scheduler", new { @area = "Help" })?ActionMethod=_New&Screen=Sparc_Create_Schedule", "auto", 1050, false, null);
                    HideLoader();
                break;
            case "EDITPROJECT":
                AllOperationsOpenProjectInfoPopup("Sparc_Edit");
                break;
            case "DELETEPROJECT":
                AllOperationsOpenProjectInfoPopup("Sparc_Delete")
                break;
            case "COPYFORM":
                AllOperationsOpenProjectInfoPopup("Sparc_Copy_Chart")
                break;
            case "EDITFORM":
                AllOperationsOpenProjectInfoPopup("Sparc_Edit_Chart");
                break;
            case "SHAREFORM":
                AllOperationsOpenProjectInfoPopup("Sparc_Share_Chart")
                break;
            case "DOWLOADFORM":
                AllOperationsOpenProjectInfoPopup("Sparc_Download_Chart")
                break;
            case "DELETEFORM":
                AllOperationsOpenProjectInfoPopup("Sparc_Delete_Chart");
                break;
            case "EDITSUBJECT":
                AllOperationsOpenProjectInfoPopup("Sparc_EditSubject");
                break;
            case "DELETESUBJECT":
                AllOperationsOpenProjectInfoPopup("Sparc_DeleteSubject");
                break;
            case "EDITSCHEDULE":
                Edit_Delete_Scheduler_Click();
                break;
            case "DELETESCHEDULE":
                Edit_Delete_Scheduler_Click(true);
                break;
            case "MAPFORM":
                Edit_Map_Form_Project_Schedule_Click("Frm_MapFormtoProject");
                break;
            case "MAPFORM2SUBJECT":
                AllOperationsOpenProjectInfoPopup("Sparc_MapForm2Subject");
                break;
            case "MAPPROJECT2SUBJECT":
                AllOperationsOpenProjectInfoPopup("Sparc_MapSubject2Project");
                break;
            case "MAPFORM2SCHEDULE":
                Edit_Map_Form_Project_Schedule_Click("Frm_MapFormtoSchedule");
                break;
            case "VIEWANSWERS":
                Edit_View_Answer_Click();
                break;
            case "VIEWTIMESTAMP":
                break;
            case "SENDNOW":
                AllOperationsOpenProjectInfoPopup("Sparc_SendNow")
                break;
            case "SENDLATER":
                AllOperationsOpenProjectInfoPopup("Sparc_SendLater");
                break;
        }
    }

    function AllOperationsOpenProjectInfoPopup(value) {
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Facility/ServiceProject/Frm_Service_Project_Info",
            cache: false,
            data:
            {
                Screen: value
            },
            success: function (data)
            {
                HideLoader();
                let popUpTitle = null;
                switch (value) {
                    case "Sparc_Edit": popUpTitle = "Edit/View >> Project >> Modify >> Select Project:"
                        break;
                    case "Sparc_Delete": popUpTitle = "Edit/View >> Project >> Delete >> Select Project:"
                        break;
                    case "Sparc_CreateSubject": popUpTitle = "Create >> Subject >> Select Project:"
                        break;
                    case "Sparc_EditSubject": popUpTitle = "Edit/View >> Subject >> Modify >> Select Project:"
                        break;
                    case "Sparc_DeleteSubject": popUpTitle = "Edit/View >> Subject >> Delete >> Select Project:"
                        break;
                    case "Sparc_CreateForm": popUpTitle = "Create >> Form >> Select Project:"
                        break;
                    case "Sparc_Copy_Chart": popUpTitle = "Edit/View >> Form >> Copy >> Select Project:"
                        break;
                    case "Sparc_Edit_Chart": popUpTitle = "Edit/View >> Form >> Modify >> Select Project:"
                        break;
                    case "Sparc_Share_Chart": popUpTitle = "Edit/View >> Form >> Share >> Select Project:"
                        break;
                    case "Sparc_Download_Chart": popUpTitle = "Edit/View >> Form >> Download >> Select Project:"
                        break;
                    case "Sparc_Delete_Chart": popUpTitle = "Edit/View >> Form >> Delete >> Select Project:"
                        break;
                    case "Sparc_MapForm2Subject": popUpTitle = "Map/Unmap & Copy >> Subject to Form >> Select Project:"
                        break;
                    case "Sparc_MapSubject2Project": popUpTitle = "Map/Unmap & Copy >> Copy Subjects >> Select Project:"
                        break;
                    case "Sparc_Answer": popUpTitle = "Responses >> Answers with Timestamp >> Select Project:"
                        break;
                    case "Sparc_SendLater": popUpTitle = "Send >> Later >> Select Project:"
                        break;
                    case "Sparc_SendNow": popUpTitle = "Send >> Now >> Select Project:"
                        break;
                    default:
                        break;
                }
                OpenPopup(value, popUpTitle, null, "auto", 1050, true, data);
            },
            error: function (jqXHR, textStatus, errorThrown)
            {
                HideLoader();
                console.log(jqXHR);
                console.log(textStatus);
                console.log(errorThrown);
                DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
            }
        });
    }
    function Edit_Delete_Scheduler_Click(isDelete = false) {
        ShowLoader();
