    function getGridIdName(ddGridId, ddId) {
        debugger;
        var DG = $("#" + ddGridId).dxDataGrid("instance");
        let arr = [];
        DG.selectRows($("#" + ddId).dxDropDownBox("option", "value"));
        let rows = [];
        rows = DG.getSelectedRowsData();
        if (rows.length > 0) {
            for (var i = 0; i < rows.length; i++) {
                if (ddGridId == 'Form_SparcMappingModel_datagrid_MapForm2Project') {
                    arr.push({ Id: rows[i].REC_ID, name: rows[i].CI_CHARTNAME, ProjectId: rows[i].PROJECT_ID });
                    console.log("Form: " + arr);
                }
                else if (ddGridId == 'Form_SparcMappingModel_datagrid_MapSchedule2Form') {
                    console.log("Instance Count: " + rows[i].Inst_Count)
                    console.log("Response Count: " + rows[i].Resp_count)
                    arr.push({
                            Id: rows[i].REC_ID,
                            Name: rows[i].CI_CHARTNAME,
                            frequency: rows[i].CI_FREQUENCY,
                            fromDate: (rows[i].CI_FROM_DATE !== null && rows[i].CI_FROM_DATE !== undefined && rows[i].CI_FROM_DATE !== "") ? JS_Json_Date_To_ddMMyyyy(rows[i].CI_FROM_DATE) : rows[i].CI_FROM_DATE,
                            toDate: (rows[i].CI_TO_DATE !== null && rows[i].CI_TO_DATE !== undefined && rows[i].CI_TO_DATE !== "") ? JS_Json_Date_To_ddMMyyyy(rows[i].CI_TO_DATE) : rows[i].CI_TO_DATE,
                            instancesCounts: rows[i].Inst_Count,
                            purpose: rows[i].CI_PURPOSE,
                            responsesCounts: rows[i].Resp_count
                        });
                    console.log("Form: " + arr);
                }
                else if (ddGridId.includes('Project_SparcMappingModel_')) {
                    arr.push({ Id: rows[i].ID, name: rows[i].Name });
                    console.log("Project: " + arr);
                }
                else if (ddGridId.includes('Schedule_SparcMappingModel_')) {
                    arr.push({ Id: rows[i].REC_ID, name: rows[i].Name });
                    console.log("Schedule: " + arr);
                }
            }
            return arr;
        }
    }
    function DG_OnRowClick_Sparc(e) {
        if (e.isSelected) {
            e.component.deselectRows(e.key);
        }
        else {
            e.component.selectRows(e.key, true);
        }
    }
</script>