        $.ajax({
            type: 'GET',
            url: "/Help/Scheduler/Frm_Scheduler_Info",
            cache: false,
            data:
            {
                Screen: screen
            },
            success: function (data) {
                HideLoader();
                //OpenDynamicPopup("Schedule Listing", null, "100%", "60%", true, data);

                if (screen == "Sparc_Edit_Schedule") {
                    OpenPopup(screen, "Edit/View >> Schedule >> Modify >> Select Schedule:", null, "auto", 1050, true, data);
                }
                else if (screen == "Sparc_Delete_Schedule") {
                    OpenPopup(screen, "Edit/View >> Schedule >> Delete >> Select Schedule:", null, "auto", 1050, true, data);
                }
            },
            error: function (jqXHR, textStatus, errorThrown) {
                HideLoader();
                console.log(jqXHR);
                console.log(textStatus);
                console.log(errorThrown);
                DevExpress.ui.dialog.alert(jqXHR.responseText, errorThrown);
            }
        });
    }
