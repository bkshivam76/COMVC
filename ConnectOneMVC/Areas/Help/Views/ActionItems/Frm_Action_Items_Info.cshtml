    <style>
        .report_button_div > form { display: inline-block }
    </style>

    <div id="ActionItemsHelp_ParentDiv">
        <div id="content" class="report_header_div_main">
            <div class="report_header_div">
                <label class="report_header_label">Audit Actions <!--<i title="Screen Intro" class="fa fa-question-circle" id="startIntro"></i> <i title="Video Help" onclick="VideosOnClick(this,'https://youtube.com/embed/xszOp16z8KY')" class="fa-brands fa-youtube"></i>--> </label>
            </div>
            @*Buttons*@
            <div class="report_button_div">
                @(Html.DevExtreme().Switch().ID("AuditActionVouchingModeSwitch").SwitchedOnText("Vouching On").SwitchedOffText("Vouching Off").OnValueChanged("AuditAction_VouchingSwitch_ValueChange").Width(100).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
                @(Html.DevExtreme().Switch().ID("ActionItemsViewModeSwitch").SwitchedOnText("Compact").SwitchedOffText("Default").OnValueChanged("ActionItems_ViewSwitch_ValueChange").Width(70).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
                @(Html.DevExtreme().Button().ID("BUT_ActionItem_NEW").Text("New").Icon("add").Disabled((Status == "LOCKED" || ActionItems_Add_Edit_Action == false) ? true : false).OnClick(@<text> function () { OnActionItemsNewClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("BUT_ActionItem_EDIT").Text("Edit").Icon("edit").Disabled((Status == "LOCKED" || ActionItems_Add_Edit_Action == false) ? true : false).OnClick(@<text> function () { OnActionItemsEditClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("BUT_ActionItem_VIEW").Text("View").Icon("doc").OnClick(@<text> function () { OnActionItemsViewClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("ActionItemToggleScrollBar").Text(ViewBag.ShowHorizontalBar == 1 ? "Default Data" : "Full Data").Width(ViewBag.ShowHorizontalBar == 1 ? 110 : 90).Icon("toolbox").OnClick(@<text> function () { ActionItemschangeMode(); } </text>) )
                @(Html.DevExtreme().Button().ID("ActionItemBUT_PRINT").Text("Export").Icon("save").OnClick(@<text> function () { OnActionItemsListPreviewClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("BUT_ActionItem_CEN_REMARKS").Text("Centre Remarks").Icon("doc").OnClick(@<text> function () { OnActionItemsCentreRemarksClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("ActionItemsSampleFormat").Text("Import Excel Format").OnClick(@<text> function (){ImportSampleFormat_Action_items();} </text>))
                <form id="uploadExcel_Action_items">
                    @(Html.DevExtreme().FileUploader().SelectButtonText("Choose File").ID("ExcelUpload_Action_items")
                    .Name("ExcelUpload_Action_items").Multiple(false).Accept("xls/*").UploadMode(FileUploadMode.UseForm)
                    .ShowFileList(true).Visible(false).OnValueChanged("ExcelUpload_valueChange_Action_items"))
                    @*<input type="file" id="ExcelUpload" />*@
                </form>
                @(Html.DevExtreme().Button().ID("UploadData_Action_items").Text("Upload by Excel")
                    .OnClick(@<text> function (){UploadExcelData_Action_items();} </text>))
                @(Html.DevExtreme().Button().ID("ActionItemBUT_CLOSE").Text("Close").Icon("clear").OnClick(@<text> function (){closeActionitem();} </text>) )
            </div>
        </div>
        <div class="col-md-12 no-padding">
            <form>
                <div id="ActionItemsreloadPartialView" class="parent_table">
                    @Html.Partial("Frm_Action_Items_Info_Grid", Model)
