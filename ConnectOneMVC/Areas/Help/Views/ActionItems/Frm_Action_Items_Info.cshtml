    function OnActionItemsCellClick(event, cell,col, row)
    {
        if (UserType_ActionItemsPrf == "AUDITOR" || UserType_ActionItemsPrf == "SUPERUSER")
        {
            if (event.button == 0)
            {
                if (cell.style.backgroundColor.length > 0)
