    <script>
    function On_ActionItemsHelp_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@Help_Attachment_AddRight" == "False")
            {
            DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
            return;
            }
            if (ActionItemsInfo_ParamMandatory == 1)
            {
            AddAttachment(ActionItemsInfo_MasterRowRecID, "Help_Action_Items", ActionItemsInfo_Doc_ID, ActionItemsInfo_Doc_Category, ActionItemsInfo_ParamMandatory, ActionItemsInfo_FromDateLabel, ActionItemsInfo_ToDateLabel, ActionItemsInfo_DescriptionLabel, "ActionItemsHelpAttachment", null, "ActionItemsListGrid", ActionItemsInfo_NestedGrid_AccessID);
            }
            else
            {
            Attachment_DirectBrowse(ActionItemsInfo_MasterRowRecID, "Help_Action_Items", ActionItemsInfo_Doc_ID, "ActionItemsHelpAttachment", "ActionItemsListGrid", ActionItemsInfo_NestedGrid_AccessID);
            }
            }
            else if (e.actionName === "edit_attach")
            {
            if ("@Help_Attachment_EditRight" == "False")
            {
            DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
            return;
            }
            if (ActionItemsInfo_Nested_Doc_Status == "NO" || ActionItemsInfo_Nested_Doc_Status == ""  ) {
                DevExpress.ui.dialog.alert("Please Attach document First", "Error");
                return;
            }
            if (ActionItemsInfo_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
            DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
            return;
            }

            EditAttachment(ActionItemsInfo_MasterRowRecID, "Help_Action_Items", ActionItemsInfo_AtachmentID, ActionItemsInfo_ParamMandatory, ActionItemsInfo_FromDateLabel, ActionItemsInfo_ToDateLabel, ActionItemsInfo_DescriptionLabel, "ActionItemsHelpAttachment", null, "ActionItemsListGrid", ActionItemsInfo_NestedGrid_AccessID);
            }
            else if (e.actionName === "delete_attach")
            {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
            DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
            return;
            }
            if (ActionItemsInfo_Nested_Doc_Status == "NO" || ActionItemsInfo_Nested_Doc_Status == "") {
                DevExpress.ui.dialog.alert("Please Attach document First", "Error");
                return;
            }
            DeleteAttachment(ActionItemsInfo_MasterRowRecID, "Help_Action_Items", ActionItemsInfo_AtachmentID, ActionItemsInfo_ParamMandatory, ActionItemsInfo_FromDateLabel, ActionItemsInfo_ToDateLabel, ActionItemsInfo_DescriptionLabel, null, "ActionItemsListGrid", ActionItemsInfo_NestedGrid_AccessID, ActionItemsInfo_Attachment_RecStatus);
            }
            else if (e.actionName === "view_attach")
            {
            if ("@Help_Attachment_ViewRight" == "False")
            {
            DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
            return;
            }
            if (ActionItemsInfo_Nested_Doc_Status == "NO" || ActionItemsInfo_Nested_Doc_Status == "") {
                DevExpress.ui.dialog.alert("Please Attach document First", "Error");
                return;
            }

            ViewDocument(ActionItemsInfo_AtachmentID, ActionItemsInfo_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
            }
            else if (e.actionName == "Link_Attach")
            {
                LinkAttachment(ActionItemsInfo_MasterRowRecID, "Help_Action_Items", "Audit Actions", "ActionItemsListGrid", ActionItemsInfo_NestedGrid_AccessID);
            }
            else if (e.actionName === "Add_Reason")
            {
            if (ActionItemsInfo_Doc_Category.toLowerCase() == "others") {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else {
                AttachmentAddReason(ActionItemsInfo_MasterRowRecID, ActionItemsInfo_NestedRowMapID, "Help_Action_Items", "ActionItemsListGrid", ActionItemsInfo_NestedGrid_AccessID);
            }
         }
            else if (e.actionName === "Edit_Reason")
            {
            AttachmentEditReason(ActionItemsInfo_MasterRowRecID, ActionItemsInfo_NestedRowMapID, "Help_Action_Items", "ActionItemsListGrid", ActionItemsInfo_NestedGrid_AccessID, ActionItemsInfo_reason);
            }
            else if (e.actionName === "Delete_Reason")
            {
            AttachmentDeleteReason(ActionItemsInfo_MasterRowRecID, ActionItemsInfo_NestedRowMapID, "ActionItemsListGrid", ActionItemsInfo_NestedGrid_AccessID);
            }
            else if (e.actionName === "Rotate")
            {
            ImageRotate(img);
            }
            else if (e.actionName === "ZoomOut")
            {
            ImageZoomOut(img);
            }
            else if (e.actionName === "ZoomIn")
            {
            ImageZoomIn(img);
            }
            else if (e.actionName == "Fit")
            {
            ImageFit(img);
            }
            else if (e.actionName == "Back")
            {
            ImageBack(s.uniqueID, "actionItemContext");
            }
            }
    function OnActionItemsListGridNestedFocusedRowChange(s, e)
            {

        if (ActionItemsInfo_IsDetailRowExpanded) {
            ActionItemsInfo_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
            if (ActionItemsInfo_NestedRecord_FocusedRowIndex >= 0) {

                ShowLoader();
                ActionItemsHelp_FAB.SetVisible(true);
                ActionItemsInfo_NestedGrid_AccessID = s.uniqueID;
                s.GetRowValues(s.GetFocusedRowIndex(), 'Doc_Status;Params_Mandatory;LABEL_FROM_DATE;LABEL_TO_DATE;LABEL_DESCRIPTION;Document_Category;Document_ID;ATTACH_ID;TxnID;TxnMID;MAP_ID;Reason;ATTACH_FILE_NAME;Attachment_Action_Status;UniqueID', OnActionItemsInfo_GetGridRowValues);
            }
            else {
                ActionItemsHelp_FAB.SetVisible(false);
            }
        }
            }
            function OnActionItemsInfo_GetGridRowValues(values)
            {
                HideLoader();
                if (values[14] != null)
                {
                    ActionItemsHelp_FAB.SetVisible(true);
                    ActionItemsInfo_Nested_Doc_Status = values[0];
                    ActionItemsHelp_FAB.SetActionContext("actionItemContext", true);
                    ActionItemsInfo_ParamMandatory = values[1];
                    ActionItemsInfo_FromDateLabel = values[2];
                    ActionItemsInfo_ToDateLabel = values[3];
                    ActionItemsInfo_DescriptionLabel = values[4];
                    ActionItemsInfo_Doc_Category = values[5];
                    ActionItemsInfo_Doc_ID = values[6];
                    ActionItemsInfo_AtachmentID = values[7];
                    ActionItemsInfo_MasterRowRecID = values[8];
                    ActionItemsInfo_MasterRowMID = values[9];
                    ActionItemsInfo_NestedRowMapID = values[10];
                    ActionItemsInfo_reason = values[11];
                    ActionItemsInfo_FileName = values[12];
                    ActionItemsInfo_Attachment_RecStatus = values[13];
                    if (AuditAction_IsVouchingMode == true)
                    {
                        if (ActionItemsInfo_FileName != null && ActionItemsInfo_FileName.length > 0)
                        {
                            ViewDocument(ActionItemsInfo_AtachmentID, ActionItemsInfo_FileName, "ActionItemsHelp_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                        }
                        else
                        {
                            var pane = Mainspliter.GetPaneByName('RightPane');
                            pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
                            document.getElementById('RightPane_div_Iframe').style.display = "none";
                            document.getElementById('RightPane_div_Img').style.display = "none";
                        }
                    }
                }
            }
            function ActionItemsGrid_Nested_BeginCallBack(s, e)
            {
                e.customArgs["ShowHorizontalBar"] = ActionItem_ShowHorizontalBar;
                e.customArgs["VouchingMode"] = AuditAction_IsVouchingMode;
                e.customArgs["command"] = e.command;
            }
            function ActionItemsGrid_DetailRowExpanding(s, e)
            {
                ActionItemsInfo_IsDetailRowExpanded = true;
                s.SetFocusedRowIndex(e.visibleIndex);
                var pane = Mainspliter.GetPaneByName('RightPane');
                if (AuditAction_IsVouchingMode == true)
                {
                    pane.Expand();
                }
                else
                {
                    pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
                }
            }
            function ActionItemsGrid_DetailRowCollapsing(s, e)
            {
                ActionItemsInfo_IsDetailRowExpanded = false;
                s.SetFocusedRowIndex(e.visibleIndex);
                if (AuditAction_IsVouchingMode == true)
                {
                    if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false)
                    {
                        CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
                    }
                }
                else
                {
                    ActionItemsHelp_FAB.SetVisible(false);
                }
            }
    </script>
    @*attachment and nested grid*@
    <script>

        function ActionItemsAdjustSize() {
            var height = (document.documentElement.clientHeight * 90) / 100;
            try { ActionItemsListGrid.SetHeight(height); } catch (err) { }
        }
        function ActionItemsOnInit(s, e) {
            ActionItemsAdjustSize();
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                ActionItemsAdjustSize();
            });
        }
        function ActionItemsGrid_BeginCallBack(s, e) {
            e.customArgs["command"] = e.command;
            e.customArgs["ShowHorizontalBar"] = ActionItem_ShowHorizontalBar;
            e.customArgs["Status"] = AI_RefStatus;
            e.customArgs["RefRecID"] = AI_RefRecID
            e.customArgs["RefTable"] = AI_RefTable;
            e.customArgs["RefScreen"] = AI_RefScreen;
            e.customArgs["VouchingMode"] = AuditAction_IsVouchingMode;
            e.customArgs["ViewMode"] = ActionItems_ViewMode;
            e.customArgs["ColumnToBeShownIndex"] = AuditAction_ColumnToBeShownIndex;
            e.customArgs["ColumnToBeHidddenIndex"] = AuditAction_ColumnToBeHidddenIndex;
        }

        function OnGridActionItemsListGrid_EndCallback(s, e) {
            //ActionItemsAdjustSize();
            ActionItemsGridLayout = s.cpClientLayout;
            AuditAction_ColumnToBeShownIndex = s.cpColumnToBeShownIndex;
            AuditAction_ColumnToBeHidddenIndex = s.cpColumnToBeHidddenIndex;
            $(".ActionItemsListGrid_PreviewRow").hide();
            GetSessionStorage("ActionItemsListGrid");
            SendCustomArgs_FilterControl(s, e);
            if (e.command == "REFRESH") {

                AIFocusedRowIndexBeforeRefresh = s.GetFocusedRowIndex();
                s.SetFocusedRowIndex(-1);
                if (AI_Select_xid.length > 0) {
                    for (var i = 0; i < s.GetVisibleRowsOnPage(); i++) {
                        if (s.GetRowKey(i) == AI_Select_xid) {
                            s.SetFocusedRowIndex(i);
                            break;
                        }
                    }
                }
                else {
                    s.SetFocusedRowIndex(AIFocusedRowIndexBeforeRefresh);
                }
                AI_Select_xid = "";
            }
        }
