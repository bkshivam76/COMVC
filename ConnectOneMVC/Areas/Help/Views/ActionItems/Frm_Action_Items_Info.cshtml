        function OnActionItemsGridFocusedRowChanged(s, e) {
            //ShowLoader();//redmine Bug #133180 fixed
            if (s.GetFocusedRowIndex() > -1) {
                if (!s.IsGroupRow(s.GetFocusedRowIndex())) {
                    s.GetRowValues(s.GetFocusedRowIndex(), 'ID;Edit_Date;Edit_By;Add_Date;Add_By;Action_Date;Action_By;Action_Status;Status', ActionItemsOnGetRowValues);
                }
                else {
                    ActionItemsID = null;
                    AI_UpdateFooterDetail(ActionItemsID, AI_Action_Status, AI_Add_Date, AI_Add_By, AI_Action_Date, AI_Action_By, AI_Edit_Date, AI_Edit_By);
                }
            }
            else {
                ActionItemsID = null;
                AI_UpdateFooterDetail(ActionItemsID, AI_Action_Status, AI_Add_Date, AI_Add_By, AI_Action_Date, AI_Action_By, AI_Edit_Date, AI_Edit_By);
            }
        }
        function ActionItemsOnGetRowValues(values) {
            ActionItemsID = values[0];
            AI_Action_Status = values[7];
            AI_Edit_Date = values[1];
            AI_Add_By = values[4];
            AI_Add_Date = values[3];
            AI_Edit_By = values[2];
            AI_Action_Date = values[5];
            AI_Action_By = values[6];
            AI_Status = values[8];
            AI_UpdateFooterDetail(ActionItemsID, AI_Action_Status, AI_Add_Date, AI_Add_By, AI_Action_Date, AI_Action_By, AI_Edit_Date, AI_Edit_By);
        }
        function AI_UpdateFooterDetail(ActionItemsID, ActionItems_Action_Status, ActionItems_Add_Date, ActionItems_Add_By, ActionItems_Action_Date, ActionItems_Action_By, ActionItems_Edit_Date, ActionItems_Edit_By) {

            HideLoader();//redmine Bug #133180 fixed
            var Status = "";
            var Lbl_Status = "";
            var Lbl_StatusBy = "";
            var Pic_Status = "";
            var Lbl_Create = "";
            var Lbl_Modify = "";
            var Lbl_Status_Color = "";
            var Lbl_ActionOn = "";
            var Lbl_ActionBy = "";
            var StatusStr = "";
            if (ActionItemsID != null) {
                ActionItems_Add_Date = (moment(ActionItems_Add_Date).format("DD/MM/YYYY HH:mm:ss"));
                ActionItems_Edit_Date = (moment(ActionItems_Edit_Date).format("DD/MM/YYYY HH:mm:ss"));
                ActionItems_Action_Date = (moment(ActionItems_Action_Date).format("DD/MM/YYYY HH:mm:ss"));
                Status = ActionItems_Action_Status;
                StatusStr = Status == "Locked" ? "Locked" : Status == null ? null : "UnLocked";

                if (Status && Status.toUpperCase() == "LOCKED") {
                    Lbl_Status = "Completed";
                    Lbl_Status_Color = "blue";
                    Pic_Status = "fa fa-lock";
                }
                else {
                    Pic_Status = "fa fa-unlock";
                    Lbl_Status = Status;
                    if (Status && Status.toUpperCase() == "COMPLETED") {
                        Lbl_Status_Color = "green";
                    }
                    else {
                        Lbl_Status_Color = "red";
                    }
                }
                if (ActionItems_Action_Date) {
                    Lbl_ActionOn = StatusStr + " On: " + ActionItems_Action_Date;
                    Lbl_ActionBy = StatusStr + " By: " + ActionItems_Action_By;
                }
                else {
                    Lbl_ActionOn = "";
                    Lbl_ActionBy = "";
                }
                if (ActionItems_Add_Date) {
                    Lbl_Create = "Add On: " + ActionItems_Add_Date + ", By: " + ActionItems_Add_By;
                }
                else {
                    Lbl_Create = "";
                }
                if (ActionItems_Edit_Date) {
                    Lbl_Modify = "Edit On: " + ActionItems_Edit_Date + ", By: " + ActionItems_Edit_By;
                }
                else {
                    Lbl_Modify = "";
                }
            }
            $('#ActionItem_Status').text(Lbl_Status);
            $('#ActionItem_Lbl_ActionOn').text(Lbl_ActionOn)
            $('#ActionItem_Lbl_ActionBy').text(Lbl_ActionBy);
            $('#ActionItem_Create').text(Lbl_Create);
            $('#ActionItem_Modify').text(Lbl_Modify);
            if (Lbl_Status_Color != "") {
                $('#ActionItem_Status').css('color', Lbl_Status_Color);
            }
            if (Pic_Status == "fa fa-lock") {
                $('#ActionItem_LockICON').addClass(Pic_Status).removeClass("fa-unlock");
            }
            else if (Pic_Status == "fa fa-unlock") {
                $('#ActionItem_LockICON').addClass(Pic_Status).removeClass("fa-lock");
            }
            else {
                $('#ActionItem_LockICON').removeClass("fa");
                $('#ActionItem_LockICON').removeClass("fa-lock");
                $('#ActionItem_LockICON').removeClass("fa-unlock");
            }
        }
        function ActionItemsdblclickEdit(s, e) {
            OnActionItemsEditClick();
        }
        function ActionItemsContextMenuFunction(s, e) {
            ActionMethod = "";
            if (e.item.name == 'New') {
                OnActionItemsNewClick();
            }
            if (e.item.name == 'Close') {
                closeActionitem();//redmine Bug #132876 fixed
            }
            else if (e.item.name == 'Edit') {
                OnActionItemsEditClick();
            }
            else if (e.item.name == 'View') {
                OnActionItemsViewClick();
            }
            else if (e.item.name == 'ListPreview') {
                OnActionItemsListPreviewClick();
            }
            else if (e.item.name == 'CentreRemarks') {
                OnActionItemsCentreRemarksClick();
            }
            else if (e.item.name == 'MarkClosed') {
                AI_MarkCloseClick('MARK-CLOSED');
            }
            else if (e.item.name == 'ReOpen') {
                AI_ReopenClick();
            }
            else if (e.item.name == 'Refresh') {
                ActionItemsListGrid.Refresh();
            }
        }
    </script>
