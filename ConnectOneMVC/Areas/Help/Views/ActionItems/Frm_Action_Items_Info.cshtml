    <script type="text/javascript">

    function AuditActionGrid_CollapseAllDetailRows()
    {
        if (typeof window !== 'undefined') {
            if (typeof window.ActionItemsListGrid !== 'undefined') {
                if (typeof window.ActionItemsListGrid.CollapseAllDetailRows !== 'undefined') {
                    if (typeof ActionItemsListGrid.CollapseAllDetailRows == 'function') {
                        ActionItemsListGrid.CollapseAllDetailRows();
                    }
                    else {
                        alert("CollapseAllDetailRows is not a function");
                    }
                }
                else {
                    ShowLoader();
                    setTimeout(function () {
                        AuditActionGrid_CollapseAllDetailRows();
                        HideLoader();
                    }, Timeout100);
                }
            }
            else {
                alert('grid undefined')
            }
        }
        else {
            alert('window undefined')
        }
    }

    function AuditAction_VouchingSwitch_ValueChange(e)
    {
        AuditAction_IsVouchingMode = e.value;
        AuditActionGrid_CollapseAllDetailRows();
    }
    function ActionItems_ViewSwitch_ValueChange(e)
    {
        ActionItems_ViewMode = e.value == false ? "Default" : "Compact";
        if (ActionItemsInfo_Auto_Vouching_Mode == true)
        {
            ActionItemsInfo_Auto_Vouching_Mode = false;
            $("#AuditActionVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }
        else
        {
            ActionItemsListGrid.CollapseAllDetailRows();
        }
    }
    function closeActionitem()
