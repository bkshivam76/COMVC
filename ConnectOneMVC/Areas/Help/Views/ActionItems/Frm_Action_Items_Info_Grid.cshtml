@{ 
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;
    string ViewMode = ViewBag.ViewMode == null ? "Default" : (string)ViewBag.ViewMode;
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool ActionItems_AddRight = (bool)ViewData["ActionItems_AddRight"];
    bool ActionItems_UpdateRight = (bool)ViewData["ActionItems_UpdateRight"];
    bool ActionItems_DeleteRight = (bool)ViewData["ActionItems_DeleteRight"];
    bool ActionItems_ViewRight = (bool)ViewData["ActionItems_ViewRight"];
    bool ActionItems_ExportRight = (bool)ViewData["ActionItems_ExportRight"];
    bool ActionItems_Add_Edit_Action = (bool)ViewData["ActionItems_Add_Edit_Action"];
    bool ActionItems_Close_Reopen_Actions = (bool)ViewData["ActionItems_Close_Reopen_Actions"];
    var RefScreen = ViewBag.RefScreen;
    var RefTable = ViewBag.RefTable;
    var RefRecID = ViewBag.RefRecID;
    var Status = ViewBag.Status;
    var UserType = ViewBag.UserType;
    List<string> ColumnTobeHidden = new List<string>();
    List<string> ColumnTobeShown = new List<string>();
    string ColumnToBeShowIndex = ViewBag.ColumnToBeShownIndex == null ? "" : (string)ViewBag.ColumnToBeShownIndex;
    string ColumnToBeHideIndex = ViewBag.ColumnToBeHidddenIndex == null ? "" : (string)ViewBag.ColumnToBeHidddenIndex;
    if (ColumnToBeHideIndex.Length > 0)
    {
        ColumnTobeHidden = ColumnToBeHideIndex.Split(',').ToList();
    }
    if (ColumnToBeShowIndex.Length > 0)
    {
        ColumnTobeShown = ColumnToBeShowIndex.Split(',').ToList();
    }
}
@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "ActionItemsListGrid";
        settings.CallbackRouteValues = new
        {
            Controller = "ActionItems",
            Action = "Frm_Action_Items_Info_Grid",
            SessionGUID = SessionGUID
        };

        settings.EnableTheming = true;
        settings.Theme = "Aqua";
        settings.Styles.FocusedRow.BackColor = System.Drawing.Color.FromArgb(0, 114, 198);
        settings.Styles.FocusedRow.ForeColor = System.Drawing.Color.White;

        settings.Settings.ShowPreview = true;
        settings.SetPreviewRowTemplateContent(c =>
        {
            if (VouchingMode == true)
            {
                Html.RenderAction("AuditButtons", "AuditButton", new { Area = "", Grid = settings.Name, KeyValue = c.KeyValue, VisibleIndex = c.VisibleIndex, SessionGUID = SessionGUID });
            }
        });
        settings.HtmlDataCellPrepared = (s, e) =>
        {
            MVCxGridView grid = (MVCxGridView)s;
            string colIdx = e.DataColumn.Index.ToString();
            string rowIdx = e.VisibleIndex.ToString();
            if (VouchingMode == true)
            {

                if (e.DataColumn.FieldName.Length > 0)
                {
                    e.Cell.Attributes.Add("ondblclick", "OnGridCellClick(event,this,'" + colIdx + "', '" + rowIdx + "','" + settings.Name + "','" + e.KeyValue + "','" + e.DataColumn.FieldName + "');");
                }
                if (e.DataColumn.Name == "iIcon")
                {
                    e.Cell.Attributes.Add("onmouseover", "OnGridRowMouseHoverIn(event,this,'" + settings.Name + "','" + e.VisibleIndex + "','" + e.KeyValue + "')");
                    e.Cell.Attributes.Add("onmouseout", "OnGridRowMouseHoverOut(event,this,'" + settings.Name + "','" + e.VisibleIndex + "','" + e.KeyValue + "')");
                }

            }

            e.Cell.CssClass += " col_" + e.DataColumn.FieldName + " row_" + e.KeyValue;
            e.Cell.ID = "Cell_" + e.KeyValue + "|" + e.DataColumn.FieldName;
        };
        settings.HtmlRowCreated = (s, e) =>
        {
            MVCxGridView grid = (MVCxGridView)s;
            if (e.RowType == GridViewRowType.Data)
            {
                //e.Row.Attributes.Add("onmouseover", "OnGridRowMouseHoverIn(event,this,'" + settings.Name + "','" + e.VisibleIndex + "','" + e.KeyValue + "')");
                //e.Row.Attributes.Add("onmouseout", "OnGridRowMouseHoverOut(event,this,'" + settings.Name + "','" + e.VisibleIndex + "','" + e.KeyValue + "')");
                e.Row.CssClass += " " + settings.Name + "_DataRow_" + e.KeyValue;
            }
            else if (e.RowType == GridViewRowType.Preview)
            {
                e.Row.BackColor = System.Drawing.Color.White;
                if (VouchingMode == true)
                {
                    e.Row.Attributes.Add("onmouseover", "OnGridPrevRowMouseHoverIn(event,this,'" + settings.Name + "','" + e.VisibleIndex + "','" + e.KeyValue + "')");
                    e.Row.Attributes.Add("onmouseout", "OnGridPrevRowMouseHoverOut(event,this,'" + settings.Name + "','" + e.VisibleIndex + "','" + e.KeyValue + "')");
                }
                e.Row.CssClass += " " + settings.Name + "_PreviewRow" + " " + settings.Name + "_PreviewRow_" + e.KeyValue;
                //e.Row.ID = "PreviewRow_" + e.KeyValue;
            }

        };
        //nested Grid

        settings.SettingsDetail.ShowDetailRow = true;
        settings.SettingsDetail.AllowOnlyOneMasterRowExpanded = true;
        settings.SettingsDetail.ExportMode = GridViewDetailExportMode.All;
        settings.SetDetailRowTemplateContent(c =>
        {
            Html.RenderAction("Frm_Action_Items_Info_DetailGrid", new { RecID = DataBinder.Eval(c.DataItem, "ID"), VouchingMode = VouchingMode });
        });
        settings.SettingsExport.GetExportDetailGridViews = (s, e) =>
        {
            string RecID = (string)DataBinder.Eval(e.DataItem, "ID");
            GridViewExtension grid = new GridViewExtension(ConnectOneMVC.Areas.Help.Controllers.ActionItemsController.NestedGridExportSettings(RecID));
            grid.Bind(ConnectOneMVC.Areas.Help.Controllers.ActionItemsController.NestedGridExportData(RecID));
            e.DetailGridViews.Add(grid);
        };
        settings.HtmlRowPrepared = (s, e) =>
        {
            MVCxGridView grid = (MVCxGridView)s;
            if (e.RowType == GridViewRowType.Group)
            {
                e.Row.ForeColor = System.Drawing.Color.Blue;
                e.Row.Font.Bold = true;
            }
            else if (e.RowType == GridViewRowType.Data)
            {
                if (e.VisibleIndex % 2 == 0)
                {
                    e.Row.BackColor = System.Drawing.Color.Linen;
                }
                else
                {
                    e.Row.BackColor = System.Drawing.Color.AliceBlue;
                }
                if (e.GetValue("CrossedTimeLimit") != null && (int)e.GetValue("CrossedTimeLimit") > 0)
                {
                    e.Row.BackColor = System.Drawing.Color.MistyRose;
                }

            }
        };
        settings.CustomJSProperties = (s, e) =>
        {
            MVCxGridView gridView = (MVCxGridView)s;

            var lastVisibleColumn = gridView.VisibleColumns.LastOrDefault();
            e.Properties["cpLastVisibleColumnIndex"] = lastVisibleColumn != null ? lastVisibleColumn.Index : 0;
            e.Properties["cpHiddenColumnCaptions"] = gridView.AllColumns.Where(c => !c.Visible).ToDictionary(c => c.ToString(), c => c.Index);
            e.Properties["cpClientLayout"] = gridView.SaveClientLayout();
            string ColumnToBeShownIndex = "";
            string ColumnToBeHidddenIndex = "";
            if (ColumnTobeHidden.Count > 0)
            {
                ColumnToBeHidddenIndex = String.Join(",", ColumnTobeHidden.ToArray());
            }
            if (ColumnTobeShown.Count > 0)
            {
                ColumnToBeShownIndex = String.Join(",", ColumnTobeShown.ToArray());
            }
            e.Properties["cpColumnToBeShownIndex"] = ColumnToBeShownIndex;
            e.Properties["cpColumnToBeHidddenIndex"] = ColumnToBeHidddenIndex;

        };

        settings.SettingsExport.EnableClientSideExportAPI = true;
        settings.SettingsExport.ExcelExportMode = DevExpress.Export.ExportType.DataAware;
        settings.SettingsExport.PageHeader.Center = "Action Items";
        settings.SettingsExport.PageHeader.Left = ViewData["ExportGridHeaderLeft"].ToString();
        settings.SettingsExport.PageHeader.Right = ViewData["ExportGridHeaderRight"].ToString();
        settings.SettingsExport.PageFooter.Right = ViewData["ExportGridFooter"].ToString();
        settings.SettingsExport.PageFooter.Font.Size = 7;
        settings.SettingsExport.PaperKind = System.Drawing.Printing.PaperKind.A4Rotated;
        settings.SettingsExport.TopMargin = 10;
        settings.SettingsExport.LeftMargin = 10;
        settings.SettingsExport.RightMargin = 10;
        settings.SettingsExport.BottomMargin = 10;
        settings.AfterPerformCallback = (s, e) =>
        {
            MVCxGridView gridView = s as MVCxGridView;
            gridView.ScrollToVisibleIndexOnClient = gridView.FocusedRowIndex;
            if (e.CallbackName == "COLUMNMOVE")
            {
                if (e.Args[1] == "-1")
                {
                    if (ColumnTobeShown.Count > 0)
                    {
                        if (ColumnTobeShown.Contains(e.Args[0]))
                        {
                            ColumnTobeShown.Remove(e.Args[0]);
                        }
                    }
                    ColumnTobeHidden.Add(e.Args[0]);
                }
                if (Convert.ToInt32(e.Args[1]) > -1)
                {
                    if (ColumnTobeHidden.Count > 0)
                    {
                        if (ColumnTobeHidden.Contains(e.Args[0]))
                        {
                            ColumnTobeHidden.Remove(e.Args[0]);
                        }
                    }
                    ColumnTobeShown.Add(e.Args[0]);
                }
            }
        };
        settings.BeforeGetCallbackResult = (s, e) =>
        {
            MVCxGridView grid = s as MVCxGridView;
            if (ViewMode == "Compact")
            {
                grid.DataColumns["ActionItems_Compact_Column"].Visible = true;
                grid.DataColumns["Type"].Visible = false;
                grid.DataColumns["Date"].Visible = false;
                grid.DataColumns["Title"].Visible = false;
                grid.DataColumns["Description"].Visible = false;
                grid.DataColumns["Due_On"].Visible = false;
                grid.DataColumns["Centre_Remarks"].Visible = false;
                grid.DataColumns["Close_Remarks"].Visible = false;
                grid.DataColumns["Closed_On"].Visible = false;
                grid.DataColumns["Closed_By"].Visible = false;
                grid.DataColumns["Status"].Visible = false;

                grid.DataColumns["Action_By"].Visible = false;
                grid.DataColumns["Action_Status"].Visible = false;
                grid.DataColumns["Add_By"].Visible = false;
                grid.DataColumns["Add_Date"].Visible = false;
                grid.DataColumns["CrossedTimeLimit"].Visible = false;
                grid.DataColumns["Edit_By"].Visible = false;
                grid.DataColumns["Edit_Date"].Visible = false;
                grid.DataColumns["ID"].Visible = false;
                grid.DataColumns["ID"].Visible = false;
                grid.DataColumns["REJECTED_COUNT"].Visible = false;
                grid.DataColumns["RESPONDED_COUNT"].Visible = false;
                grid.DataColumns["COMPLETE_ATTACH_COUNT"].Visible = false;
                grid.DataColumns["REQ_ATTACH_COUNT"].Visible = false;
                grid.DataColumns["OTHER_ATTACH_CNT"].Visible = false;
                grid.DataColumns["ALL_ATTACH_CNT"].Visible = false;
                grid.DataColumns["Action_Date"].Visible = false;

                //settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Hidden;
            }
            else
            {
                grid.DataColumns["ActionItems_Compact_Column"].Visible = false;
                grid.DataColumns["Type"].Visible = true;
                grid.DataColumns["Date"].Visible = true;
                grid.DataColumns["Title"].Visible = true;
                grid.DataColumns["Description"].Visible = true;
                grid.DataColumns["Due_On"].Visible = true;
                grid.DataColumns["Centre_Remarks"].Visible = true;
                grid.DataColumns["Close_Remarks"].Visible = true;
                grid.DataColumns["Closed_On"].Visible = true;
                grid.DataColumns["Closed_By"].Visible = true;
                grid.DataColumns["Status"].Visible = true;

                grid.DataColumns["Action_By"].Visible = false;
                grid.DataColumns["Action_Status"].Visible = false;
                grid.DataColumns["Add_By"].Visible = false;
                grid.DataColumns["Add_Date"].Visible = false;
                grid.DataColumns["CrossedTimeLimit"].Visible = false;
                grid.DataColumns["Edit_By"].Visible = false;
                grid.DataColumns["Edit_Date"].Visible = false;
                grid.DataColumns["ID"].Visible = false;
                grid.DataColumns["ID"].Visible = false;
                grid.DataColumns["REJECTED_COUNT"].Visible = false;
                grid.DataColumns["RESPONDED_COUNT"].Visible = false;
                grid.DataColumns["COMPLETE_ATTACH_COUNT"].Visible = false;
                grid.DataColumns["REQ_ATTACH_COUNT"].Visible = false;
                grid.DataColumns["OTHER_ATTACH_CNT"].Visible = false;
                grid.DataColumns["ALL_ATTACH_CNT"].Visible = false;
                grid.DataColumns["Action_Date"].Visible = false;
            }
            foreach (GridViewDataColumn column in grid.DataColumns)
            {
                if (ViewMode != "Compact")
                {
                    if (ColumnTobeHidden.Contains(column.Index.ToString()))
                    {
                        column.Visible = false;
                    }
                    if (ColumnTobeShown.Contains(column.Index.ToString()))
                    {
                        column.Visible = true;
                    }
                }
                if (column.Visible)
                    column.Settings.AllowSort = DefaultBoolean.True;
                else
                    column.Settings.AllowSort = DefaultBoolean.False;
            }
        };
        settings.FillContextMenuItems = (sender, e) =>
        {
            if (e.MenuType == GridViewContextMenuType.Rows)
            {
                var Additem = e.CreateItem("New", "New");
                Additem.Image.IconID = "actions_new_16x16gray";
                if (ActionItems_AddRight && ActionItems_Add_Edit_Action) e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Additem);

                var Edititem = e.CreateItem("Edit", "Edit");
                Edititem.Image.IconID = "actions_edit_16x16devav";
                if (ActionItems_UpdateRight && ActionItems_Add_Edit_Action) e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Edititem);

                var Viewitem = e.CreateItem("View", "View");
                Viewitem.Image.IconID = "actions_show_16x16gray";
                if (ActionItems_ViewRight) e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Viewitem);

                var PrintViewitem = e.CreateItem("Export", "ListPreview");
                PrintViewitem.Image.IconID = "actions_hideproduct_16x16devav";
                PrintViewitem.BeginGroup = true;
                if (ActionItems_ExportRight) e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), PrintViewitem);

                var CentreRemarksitem = e.CreateItem("Centre Remarks", "CentreRemarks");
                CentreRemarksitem.Image.IconID = "view_card_16x16devav";
                if (UserType != "Auditor") e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), CentreRemarksitem);

                var MarkCloseditem = e.CreateItem("Mark as Closed", "MarkClosed");
                MarkCloseditem.Image.Url = "~/Icons/FolderClose16x16.png";
                if (ActionItems_Close_Reopen_Actions) e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), MarkCloseditem);

                var Reopenitem = e.CreateItem("Re-Open", "ReOpen");
                Reopenitem.Image.IconID = "actions_opendoc_16x16devav";
                if (Status != "LOCKED" && ActionItems_Close_Reopen_Actions) e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Reopenitem);

                var CloseItem = e.CreateItem("Close", "Close");
                CloseItem.Image.IconID = "actions_close_16x16devav";
                CloseItem.BeginGroup = true;
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), CloseItem);
            }
        };
        settings.SettingsContextMenu.Enabled = true;
        settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;

        settings.PreRender = (sender, e) =>
        {
            MVCxGridView gridView = sender as MVCxGridView;
            if (ViewData["Layout"] != null)
            {
                gridView.LoadClientLayout(ViewData["Layout"].ToString());
            }
        };
        settings.Init = (s, e) =>
        {
            MVCxGridView grid = s as MVCxGridView;
            if (ViewMode == "Compact")
            {
                grid.DataColumns["ActionItems_Compact_Column"].Visible = true;
                grid.DataColumns["Type"].Visible = false;
                grid.DataColumns["Date"].Visible = false;
                grid.DataColumns["Title"].Visible = false;
                grid.DataColumns["Description"].Visible = false;
                grid.DataColumns["Due_On"].Visible = false;
                grid.DataColumns["Centre_Remarks"].Visible = false;
                grid.DataColumns["Close_Remarks"].Visible = false;
                grid.DataColumns["Closed_On"].Visible = false;
                grid.DataColumns["Closed_By"].Visible = false;
                grid.DataColumns["Status"].Visible = false;

                grid.DataColumns["Action_By"].Visible = false;
                grid.DataColumns["Action_Status"].Visible = false;
                grid.DataColumns["Add_By"].Visible = false;
                grid.DataColumns["Add_Date"].Visible = false;
                grid.DataColumns["CrossedTimeLimit"].Visible = false;
                grid.DataColumns["Edit_By"].Visible = false;
                grid.DataColumns["Edit_Date"].Visible = false;
                grid.DataColumns["ID"].Visible = false;
                grid.DataColumns["ID"].Visible = false;
                grid.DataColumns["REJECTED_COUNT"].Visible = false;
                grid.DataColumns["RESPONDED_COUNT"].Visible = false;
                grid.DataColumns["COMPLETE_ATTACH_COUNT"].Visible = false;
                grid.DataColumns["REQ_ATTACH_COUNT"].Visible = false;
                grid.DataColumns["OTHER_ATTACH_CNT"].Visible = false;
                grid.DataColumns["ALL_ATTACH_CNT"].Visible = false;
                grid.DataColumns["Action_Date"].Visible = false;

                //settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Hidden;
            }
            else
            {
                grid.DataColumns["ActionItems_Compact_Column"].Visible = false;
                grid.DataColumns["Type"].Visible = true;
                grid.DataColumns["Date"].Visible = true;
                grid.DataColumns["Title"].Visible = true;
                grid.DataColumns["Description"].Visible = true;
                grid.DataColumns["Due_On"].Visible = true;
                grid.DataColumns["Centre_Remarks"].Visible = true;
                grid.DataColumns["Close_Remarks"].Visible = true;
                grid.DataColumns["Closed_On"].Visible = true;
                grid.DataColumns["Closed_By"].Visible = true;
                grid.DataColumns["Status"].Visible = true;

                grid.DataColumns["Action_By"].Visible = false;
                grid.DataColumns["Action_Status"].Visible = false;
                grid.DataColumns["Add_By"].Visible = false;
                grid.DataColumns["Add_Date"].Visible = false;
                grid.DataColumns["CrossedTimeLimit"].Visible = false;
                grid.DataColumns["Edit_By"].Visible = false;
                grid.DataColumns["Edit_Date"].Visible = false;
                grid.DataColumns["ID"].Visible = false;
                grid.DataColumns["ID"].Visible = false;
                grid.DataColumns["REJECTED_COUNT"].Visible = false;
                grid.DataColumns["RESPONDED_COUNT"].Visible = false;
                grid.DataColumns["COMPLETE_ATTACH_COUNT"].Visible = false;
                grid.DataColumns["REQ_ATTACH_COUNT"].Visible = false;
                grid.DataColumns["OTHER_ATTACH_CNT"].Visible = false;
                grid.DataColumns["ALL_ATTACH_CNT"].Visible = false;
                grid.DataColumns["Action_Date"].Visible = false;
            }
        };
        settings.KeyFieldName = "ID";
        settings.HeaderFilterFillItems = (s, e) =>
        {
            MVCxGridView grid = (MVCxGridView)s;
            if (e.Column.FieldName != "iIcon")
            {
                return;
            }
            e.Values.Clear();
            e.AddShowAll();
            e.AddValue("<img src='../../../../Content/Images/attach_red_2.png' width='20' height='20'</img>", "", "Contains([iIcon], 'RedShield')");//red
            e.AddValue("<img src='../../../../Content/Images/attach_yellow_2.png' width='20' height='20'</img>", "", "Contains([iIcon], 'YellowShield')");//Yellow
            e.AddValue("<img src='../../../../Content/Images/attach_green_2.png' width='20' height='20'</img>", "", "Contains([iIcon], 'GreenShield')");//green
            e.AddValue("<img src='../../../../Content/Images/Completed_With_Remarks.png' width='20' height='20'</img>", "", "Contains([iIcon], 'BlueShield')");//blue
            e.AddValue("<img src='../../../../Content/Images/Rejected_Attachment.png' width='20' height='20'</img>", "", "Contains([iIcon], 'RedFlag')");//reject
            e.AddValue("<img src='../../../../Content/Images/attach_normal.png' width='20' height='20'</img>", "", "Contains([iIcon], 'RequiredAttachment')");//other
            e.AddValue("<img src='../../../../Content/Images/attach_other_plus.png' width='20' height='20'</img>", "", "Contains([iIcon], 'AdditionalAttachment')");//other plus
        };
        settings.Columns.Add(column =>
        {
            column.Name = "iIcon";
            column.Caption = "";
            column.MinWidth = 30;
            column.MaxWidth = 30;
            column.Width = 30;
            column.FieldName = "iIcon";
            column.HeaderStyle.CssClass = "hide-header_iIcon";
            column.CellStyle.Wrap = DefaultBoolean.True;
            column.SetDataItemTemplateContent(c =>
            {
                Int32? REQ_ATTACH_COUNT = (Int32?)c.Grid.GetRowValues(c.VisibleIndex, "REQ_ATTACH_COUNT");
                Int32? COMPLETE_ATTACH_COUNT = (Int32?)c.Grid.GetRowValues(c.VisibleIndex, "COMPLETE_ATTACH_COUNT");
                Int32? RESPONDED_COUNT = (Int32?)c.Grid.GetRowValues(c.VisibleIndex, "RESPONDED_COUNT");
                Int32? REJECTED_COUNT = (Int32?)c.Grid.GetRowValues(c.VisibleIndex, "REJECTED_COUNT");
                Int32? OTHER_ATTACH_CNT = (Int32?)c.Grid.GetRowValues(c.VisibleIndex, "OTHER_ATTACH_CNT");
                Int32? ALL_ATTACH_CNT = (Int32?)c.Grid.GetRowValues(c.VisibleIndex, "ALL_ATTACH_CNT");

                var RedAttach = Html.DevExpress().Image(ImageSettings =>
                {
                    string ID = DataBinder.Eval(c.DataItem, "ID").ToString();
                    ImageSettings.Name = "attachRed" + ID;
                    ImageSettings.ImageUrl = "~/Content/Images/attach_red_2.png";
                    ImageSettings.Properties.ToolTip = "Attachment Status : Pending";
                });
                var BlueAttach = Html.DevExpress().Image(ImageSettings =>
                {
                    string ID = DataBinder.Eval(c.DataItem, "ID").ToString();
                    ImageSettings.Name = "attachBlue" + ID;
                    ImageSettings.ImageUrl = "~/Content/Images/attach_yellow_2.png";
                    ImageSettings.Properties.ToolTip = "Attachment Status : Partial";
                });
                var GreenAttach = Html.DevExpress().Image(ImageSettings =>
                {
                    string ID = DataBinder.Eval(c.DataItem, "ID").ToString();
                    ImageSettings.Name = "attachGreen" + ID;
                    ImageSettings.ImageUrl = "~/Content/Images/attach_green_2.png";
                    ImageSettings.Properties.ToolTip = "Attachment Status : Complete";
                });
                var RemarksAttach = Html.DevExpress().Image(ImageSettings =>
                {
                    string ID = DataBinder.Eval(c.DataItem, "ID").ToString();
                    ImageSettings.Name = "attachExcla" + ID;
                    ImageSettings.ImageUrl = "~/Content/Images/Completed_With_Remarks.png";
                    ImageSettings.Height = 20;
                    ImageSettings.Properties.ToolTip = "Attachment Status : Complete but With Remarks";
                });
                var RejectedAttach = Html.DevExpress().Image(ImageSettings =>
                {
                    string ID = DataBinder.Eval(c.DataItem, "ID").ToString();
                    ImageSettings.Name = "attachReject" + ID;
                    ImageSettings.Height = 20;
                    ImageSettings.ImageUrl = "~/Content/Images/Rejected_Attachment.png";
                    ImageSettings.Properties.ToolTip = "Entry has " + REJECTED_COUNT.ToString() + " Rejected Attachments";
                });
                var attach_image = Html.DevExpress().Image(ImageSettings =>
                {
                    string ID = DataBinder.Eval(c.DataItem, "ID").ToString();
                    ImageSettings.Name = "blueStar" + ID;
                    if (OTHER_ATTACH_CNT == 0)
                        ImageSettings.ImageUrl = "~/Content/Images/attach_normal.png";
                    else
                        ImageSettings.ImageUrl = "~/Content/Images/attach_other_plus.png";
                    ImageSettings.Height = 20;
                    ImageSettings.Properties.ToolTip = "Total Attachments:" + ALL_ATTACH_CNT.ToString() + "\r Non-Recommended Attachments:" + OTHER_ATTACH_CNT.ToString();
                });

                if ((COMPLETE_ATTACH_COUNT + RESPONDED_COUNT == 0) && REQ_ATTACH_COUNT > 0) { RedAttach.Render(); }
                if (((COMPLETE_ATTACH_COUNT + RESPONDED_COUNT) > 0) && (COMPLETE_ATTACH_COUNT + RESPONDED_COUNT) < REQ_ATTACH_COUNT) { BlueAttach.Render(); }
                if ((COMPLETE_ATTACH_COUNT + RESPONDED_COUNT >= REQ_ATTACH_COUNT) && REQ_ATTACH_COUNT > 0 && RESPONDED_COUNT == 0) { GreenAttach.Render(); }
                if ((COMPLETE_ATTACH_COUNT + RESPONDED_COUNT >= REQ_ATTACH_COUNT) && REQ_ATTACH_COUNT > 0 && RESPONDED_COUNT > 0) { RemarksAttach.Render(); }
                if (REJECTED_COUNT > 0) { RejectedAttach.Render(); }
                if (ALL_ATTACH_CNT > 0) { attach_image.Render(); }
                Html.RenderAction("AuditIconAfterClick", "AuditButton", new { Area = "", Grid = settings.Name, KeyValue = c.KeyValue, VisibleIndex = c.VisibleIndex, SessionGUID = SessionGUID });

            });
            //column.SetHeaderTemplateContent(c =>
            //{
            //    var Attach = Html.DevExpress().Image(ImageSettings =>
            //    {
            //        ImageSettings.ImageUrl = "~/Content/FloatingActionButton/Images/pin.png";
            //        ImageSettings.Height = 15;
            //    });
            //    Attach.Render();
            //});
            column.AdaptivePriority = 0;
        });

        settings.Columns.Add(column =>
        {
            column.Name = "ActionItems_Compact_Column";
            column.Width = Unit.Percentage(100);
            column.SetDataItemTemplateContent(c =>
            {
                ViewContext.Writer.Write(
                            "<div style='padding:0px 5px 0px 5px'>" +
                            "<div class='row'>" +
                            "<div class='col-sm-12 col-md-6 col-lg-6'>" +
                            "<div class='form-field'>" +
                            "<div class='container-fluid'>" +
