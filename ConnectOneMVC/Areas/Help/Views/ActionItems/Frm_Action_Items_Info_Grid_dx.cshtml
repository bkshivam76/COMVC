@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;
    int ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;


}
@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar)
                             .ID("ActionItemsListGrid_dx")
                             .DataSource(d => d.Mvc().Controller("ActionItems").LoadAction("Action_Items_Info_Grid_Load").LoadMode(DataSourceLoadMode.Raw).Key("ID"))
                             .Columns(columns =>
                             {
                                 columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);//Bug #137209 Fix

                                 columns.Add().DataField("iIcon").Name("iIcon").Caption("").Visible(true)
                                 .CellTemplate(new JS("ActionItemsListGrid_dx_iIconTemplate")).Width(30)
                                .HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource")).RenderAsync(true);

                                 columns.Add().DataField("ActionItemsListGrid_dx_Compact_Column").Name("ActionItemsListGrid_dx_Compact_Column").Caption("")
                                 .Visible(false).CellTemplate(new JS("ActionItemsListGrid_dx_Compact_Column")).Width("100%").RenderAsync(true)
                                 .CalculateCellValue("ActionItemsListGrid_dx_Compact_Column_CellValue").Width("100%").RenderAsync(true).ShowInColumnChooser(false);

                                 columns.Add().DataField("Type").Caption("Type").Visible(true).MinWidth(95);
                                 columns.Add().DataField("Date").Caption("From Date").Visible(true)
                                 .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy").MinWidth(95);
                                 columns.Add().DataField("Auditor").Caption("Auditor").Visible(true).MinWidth(120);

                                 columns.Add().DataField("Title").Caption("Title").Visible(true).MinWidth(250);
                                 columns.Add().DataField("Description").Caption("Description").Visible(true).MinWidth(250);
                                 columns.Add().DataField("Due_On").Caption("Due On").Visible(true)
                                  .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy").MinWidth(100);

                                 columns.Add().DataField("Centre_Remarks").Caption("Centre Remarks").Visible(true).MinWidth(150);
                                 columns.Add().DataField("Close_Remarks").Caption("Close Remarks").Visible(true).MinWidth(400);

                                 columns.Add().DataField("Closed_On").DataType(GridColumnDataType.Date).Format("dd-MM-yyyy").MinWidth(100);
                                 columns.Add().DataField("Closed_By").Caption("Timing (Per Day)").MinWidth(120);
                                 columns.Add().DataField("Status").Caption("Status").MinWidth(120).GroupIndex(0).SortOrder(SortOrder.Desc);

                                 columns.Add().DataField("Action_By").Caption("Action By").Visible(false);
                                 columns.Add().DataField("Action_Status").Caption("Action Status").Visible(false);

                                 columns.Add().DataField("Add_By").Caption("Add By").Visible(false);
                                 columns.Add().DataField("Add_Date").Caption("Add Date").Visible(false)
                                 .DataType(GridColumnDataType.Date);
                                 columns.Add().DataField("CrossedTimeLimit").Caption("Crossed Time Limit").Visible(false);
                                 columns.Add().DataField("Edit_By").Caption("Edit By").Visible(false);
                                 columns.Add().DataField("Edit_Date").Caption("Edit Date").Visible(false)
                                 .DataType(GridColumnDataType.Date);
                                 columns.Add().DataField("ID").Caption("ID").Visible(false);//.ShowInColumnChooser(false);
                                 columns.Add().DataField("Action_Date").Caption("Action Date").Visible(false)
                                 .DataType(GridColumnDataType.Date);
                                 columns.Add().DataField("REJECTED_COUNT").Caption("iREJECTED_COUNT").Visible(false);
                                 columns.Add().DataField("RESPONDED_COUNT").Caption("iRESPONDED_COUNT").Visible(false);
                                 columns.Add().DataField("COMPLETE_ATTACH_COUNT").Caption("iCOMPLETE_ATTACH_COUNT").Visible(false);
                                 columns.Add().DataField("REQ_ATTACH_COUNT").Caption("iREQ_ATTACH_COUNT").Visible(false);
                                 columns.Add().DataField("OTHER_ATTACH_CNT").Caption("OTHER_ATTACH_CNT").Visible(false);
                                 columns.Add().DataField("ALL_ATTACH_CNT").Caption("ALL_ATTACH_CNT").Visible(false);

                             })                           


//.Summary(s =>
//{
//    s.TotalItems(item => item.Add().Column("SummaryColumn").DisplayFormat(""));
//    s.GroupItems(Gitem => Gitem.Add().Column("SummaryColumn")
//    .ShowInGroupFooter(true).DisplayFormat(""));
//})

.MasterDetail(md =>
{
    md.AutoExpandAll(false);
    md.Enabled(true);
    md.Template(new JS("ActionItemsListGrid_dx_DetailTemplate"));

})
.OnInitialized("ActionItemsListGrid_dx_OnInitialized")
.OnCellPrepared("ActionItemsListGrid_dx_OnCellPrepared")
.OnRowPrepared("ActionItemsListGrid_dx_OnRowPrepared")
.OnContentReady("ActionItemsListGrid_dx_OnContentReady")
.OnCellDblClick("ActionItemsListGrid_dx_OnCellDblClick")
.OnSelectionChanged("ActionItemsListGrid_dx_OnSelectionChanged")
//////.OnFocusedRowChanged("bank_info_main_grid_OnFocusedRowChanged")
.OnRowExpanding("ActionItemsListGrid_dx_OnRowExpanding")
.OnRowCollapsing("ActionItemsListGrid_dx_OnRowCollapsing")
.OnContextMenuPreparing("ActionItemsListGrid_dx_OnContextMenuPreparing")
)


