            @Html.HiddenFor(x => x.MarkClosed)
            @Html.HiddenFor(x => x.RefRecID)
            @Html.HiddenFor(x => x.RefScreen)
            @Html.HiddenFor(x => x.RefTable)
            @Html.HiddenFor(x => x.GridToBeRefreshed)

            var errors = ViewData.ModelState.Where(n => n.Value.Errors.Count > 0).Select(c => c.Value.Errors).ToList();


            using (Html.DevExtreme().ValidationGroup("Audit_Validation"))/*Redmine Bug #133238 fixed*/
