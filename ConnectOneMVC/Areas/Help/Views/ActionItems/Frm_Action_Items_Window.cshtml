                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="form-field">
                        <div class="container-fluid ">
                            <div class="col-sm-2 pll">
                                @Html.LabelFor(model => model.Cmd_Title_AI, htmlAttributes: new { @class = "control-label text-red", @id = "LayoutControlItem15_AI" })
                            </div>
                            <div class="col-sm-10 prm">
                                @(Html.DevExtreme().SelectBox().CustomSelectBox().AcceptCustomValue(true).OnCustomItemCreating("TitleCustomItemCreating").ID("Cmd_Title_AI").Name("Cmd_Title_AI").Placeholder("Enter or Select Title...")
                                        .DataSource(ViewBag.Titledatalist).ValueExpr("Name").DisplayExpr("Name").ReadOnly(IsVisible))@*Redmine Bug #133229 fixed*@

                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-sm-8">
                                <div class="form-field">
                                    <div class="container-fluid">
                                        <div class="row">
                                            <div class="col-sm-12 pll ">
                                                @Html.LabelFor(model => model.Txt_Detail_AI, htmlAttributes: new { @class = "control-label", @id = "LayoutControlItem1_AI" })
                                            </div>
