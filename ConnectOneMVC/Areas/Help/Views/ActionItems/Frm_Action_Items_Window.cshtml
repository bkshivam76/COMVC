<div class="AuditAction_WindowScreen_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    @model ConnectOneMVC.Areas.Help.Models.ActionItems
    <link href="/content/fontawesome/css/fontawesome-all.css" rel="stylesheet">

    @{
        var PopupId = ViewBag.PopupID;
        var PostSuccessFunction = ViewBag.PostSuccessFunction;
        bool IsVisible = Model != null && (Model.ActionMethod.ToString().Trim() == "_View" || Model.ActionMethod.ToString().Trim() == "_Delete") ? true : false;
