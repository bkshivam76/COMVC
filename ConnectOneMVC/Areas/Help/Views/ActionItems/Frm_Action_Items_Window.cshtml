                        </div>
                    </div>
                </div><!--[Row 1]-->
                <div class="row">
                    <div class="col-sm-8">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <div class="col-sm-3 pll">
                                        @Html.LabelFor(model => model.Txt_Status_AI, htmlAttributes: new { @class = "control-label disabletxt" })
                                    </div>
                                    <div class="col-sm-9 prm">
                                        @(Html.DevExtreme().TextBox().CustomTextBox().ID("Txt_Status_AI").Name("Txt_Status_AI").Value("OPEN").ReadOnly(true).Disabled(IsVisible) )

