                                            </div>
                                            <div class="col-sm-12 prm">
                                                @(Html.DevExtreme().DateBox().CustomDateBox().ID("Txt_DueDate_AI").Name("Txt_DueDate_AI").Placeholder("Date").Value(Model.Txt_DueDate_AI).ReadOnly(true) )

