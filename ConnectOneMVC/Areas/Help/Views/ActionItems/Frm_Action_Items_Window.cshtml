                    </div>
                    <div class="col-sm-4">
                        <div class="form-field">
                            <div class="container-fluid ">
                                <div class="row">
                                    <div class="col-sm-3 pll">
                                        @Html.LabelFor(model => model.Cmb_Type_AI, htmlAttributes: new { @class = "control-label  text-red", @id = "LayoutControlItem7_AI" })
                                    </div>
                                    <div class="col-sm-9 prm">
                                        @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("Cmb_Type_AI").Name("Cmb_Type_AI").ShowClearButton(false).DataSource(new[] { "Query", "Center Action" }).Value("Query").ReadOnly(IsVisible).OnValueChanged("Cmb_Type_SelectedIndexChanged_AI") )
