                                            <div class="col-sm-12 prm">
                                                @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("Cmb_Due_On_AI").Name("Cmb_Due_On_AI").DataSource(new[] { "Current Audit", "Next Audit", "Specific Date" }).Value("Current Audit").OnValueChanged("Cmb_Due_On_SelectedIndexChanged_AI").ReadOnly(IsVisible).ShowClearButton(false) )@* redmine bug #133222 fixed  *@

