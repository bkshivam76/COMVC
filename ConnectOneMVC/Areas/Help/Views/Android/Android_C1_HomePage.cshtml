@model ConnectOneMVC.Areas.Help.Models.C1HomePAge
@using System.Data
<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta name="description" content="" />
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="favicon.ico" type="image/x-icon" />
    <link href="@Url.Content("~/Content/dx.common.css")" rel="Stylesheet" />
    <link href="@Url.Content("~/Content/dx.light.css")" rel="Stylesheet" />
    <link rel="stylesheet" href="~/Content/Android/css/bootstrap.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/semantic-ui/2.4.1/semantic.min.css" />
    <link rel="stylesheet" href="~/Content/Android/css/app.css?v=1" />
    <script src="@Url.Content("~/Scripts/jquery-3.6.0.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/dx.all.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/aspnet/dx.aspnet.data.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/aspnet/dx.aspnet.mvc.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Content/Android/js/common.js")" type="text/javascript"></script>
</head>

@{
    Layout = "";
    string androidID = Convert.ToString(ViewBag.androidID);
    string deviceToken = Convert.ToString(ViewBag.deviceToken);
    string Domain = (string)ViewBag.Domain;
    string ActiveUSerNAme = "";
    string ActiveUser_Service_User_ID = "";
    string ActiveUser_REG_REC_ID = "";
    bool IsActiveUser_Default = false;
    string theme = ViewBag.theme;
    if (Model.ActiveUser != null && Model.ActiveUser.Length > 0)
    {
        ActiveUSerNAme = Model.ActiveUser[0]["FULL_NAME"].ToString();
        ActiveUser_Service_User_ID = Model.ActiveUser[0]["SERVICE_USER_ID"].ToString();
        ActiveUser_REG_REC_ID = Model.ActiveUser[0]["REG_REC_ID"].ToString();
        IsActiveUser_Default = Convert.ToBoolean(Model.ActiveUser[0]["DEFAULT_USER"]);
    }
    DataTable distinctProject = new DataTable();
    if (Model.Projects != null && Model.Projects.Rows.Count > 0)
    {
        DataView view = new DataView(Model.Projects);
        distinctProject = view.ToTable(true, "PROJECT_NAME");
    }
}
<body>
    <style>
        .app-control.max-height {
            max-height: none
        }
    </style>
    <!-- Sidebar Menu -->
    <div class="ui vertical wide sidebar left menu">
        @if (string.IsNullOrWhiteSpace(ActiveUser_Service_User_ID) == false)
        {
            <div class="list massive">
                <div class="item">
                    <img class="ui avatar image" src="~/Content/Android/images/user-1.png" />
                    <div class="content">
                        <div class="h4 bold mt-2">@ActiveUSerNAme</div>
                    </div>
                </div>
            </div>
            <div class="ui relaxed divided list">
                <a class="item" onclick="SetDefaultAndroidUser()">
                    <i class="large flag left aligned icon"></i>
                    <div class="content">
                        <div class="header">Set as Default</div>
                    </div>
                </a>
                <a class="item red" onclick="UnregisterAndroidUser()">
                    <i class="large sign out alternate left aligned icon"></i>
                    <div class="content">
                        <div class="header red">Unregister</div>
                    </div>
                </a>
            </div>
            <div class="ui middle aligned divided user list">
                @if (Model.NonActiveUser != null && Model.NonActiveUser.Length > 0)
                {
                    for (int i = 0; i < Model.NonActiveUser.Length; i++)
                    {
                        string img_source = Url.Content("~/Content/Android/images/user-2.png");
                        if (i % 2 != 0)
                        {
                            img_source = Url.Content("~/Content/Android/images/user-3.png");
                        }
                        string username = Model.NonActiveUser[i]["FULL_NAME"].ToString();
                        string User_Service_User_ID = Model.NonActiveUser[i]["SERVICE_USER_ID"].ToString();
                        string User_REG_REC_ID = Model.NonActiveUser[i]["REG_REC_ID"].ToString();
                        <a class="item" onclick="AndroidC1USerClick('@User_Service_User_ID','@User_REG_REC_ID')">
                            <img class="ui avatar image" src="@img_source" />
                            <div class="content">
                                <div class="header">@username</div>
                            </div>
                        </a>
                    }
                }

            </div>}
        <div class="text-center pt-4" onclick="RegisterNewAndriodUser()">
            <a class="ui basic button">Register New User</a>
        </div>
        <div class="sm-info">
            <a class="">Device Token</a>
            <div>@deviceToken</div>
            <a class="">Android ID</a>
            <div>@androidID</div>
            @*<i>App Version v2.0.0 </i>*@
        </div>
    </div>
    <!-- Right Side Menu -->
    @Html.Partial("Android_Theme", androidID)

    <!-- Page Contents -->
    <div class="pusher">
        <div class="ui fixed text ">
            <div class="ui large secondary menu">
                <a class="toc item">
                    <img src="~/Content/Android/images/menu.png" style="height: 17px; width: 24px; margin-right: 4px" />
                    <img src="~/Content/Android/images/c1-logo.png" />
                </a>
                <div class="content">
                    <div class="header">Accounts</div>
                    @*<p> <span>09000</span> / <span>BK/001</span> <span>#PBKIVV</span></p>*@
                </div>
                <a class="ric item">
                    <i class="paint brush icon"></i>
                </a>
            </div>
        </div>

        @*<h4>General Links</h4>*@
        <div class="app-control max-height">
            @{ string C_oneUrl = Domain + "/Start/Login/Frm_COD_Selection?deviceToken=" + deviceToken + "&androidID=" + androidID + "&browser=true";}
            <a class="ui labeled icon button huge fluid active" href="@C_oneUrl">
                <i class="clipboard outline icon"></i>
                <span>Connectone Web Application</span>
            </a>
            <a class="ui labeled icon button huge fluid" href="https://connectone.app/start/home/Circulars?browser=true">
                <i class="tasks icon"></i>
                <span>Circulars from Accounts Dept</span>
            </a>
            <a class="ui labeled icon button huge fluid" href="https://services.brahmakumaris.com/Events/Login/loginpartialview?ChartInstance_ID=66&browser=true">
                <i class="tasks icon"></i>
                <span>RERF Wing Membership</span>
            </a>
            <a class="ui labeled icon button huge fluid active" href="https://connectone.app/facility/servicereport/frm_reporter_window/?browser=true">
                <i class="save icon"></i>
                <span>Post Sewa Report</span>
            </a>
            <a class="ui labeled icon button huge fluid" href="https://services.connectone.app/feedbacks/askquery/askqueryMain_info?QueryFor=connectone">
                <i class="bell icon"></i>
                <span>Suggestions / Tasks for Connectone</span>
            </a>
            <a class="ui labeled icon button huge fluid" href="https://services.connectone.app/feedbacks/askquery/askqueryMain_info?QueryFor=connectone">
                <i class="bell icon"></i>
                <span>Report Bugs for Connectone</span>
            </a>
            <a class="ui labeled icon button huge fluid" href="https://connectone.app/Profile/DetailInfo/CheckAuditStatusPage?browser=true">
                <i class="bell icon"></i>
                <span>Check Audit Status</span>
            </a>
            <a class="ui labeled icon button huge fluid" href="http://accountserver.bkinfo.in/videos.html?browser=true">
                <i class="bell icon"></i>
                <span>Connectone Videos (including Web)</span>
            </a>
            <a class="ui labeled icon button huge fluid" href="http://accountserver.bkinfo.in/connectonesetup.html?browser=true">
                <i class="bell icon"></i>
                <span>Connectone Installer</span>
            </a>
            <a class="ui labeled icon button huge fluid" href="http://centers.bkinfo.in/?browser=true">
                <i class="bell icon"></i>
                <span>Search a Center</span>
            </a>
            <a class="ui labeled icon button huge fluid" href="https://docs.google.com/spreadsheets/u/1/d/e/2PACX-1vQdm0X1MFagNyNqm1Q-s0zQF9W_B-f4Ql6ExUaqs0TAg3TWnH-4gYWpiJuOZNCFx06UXLfQhl6gUUgU/pubhtml?gid=0&single=true&browser=true">
                <i class="bell icon"></i>
                <span>Contact Us</span>
            </a>
            <a class="ui labeled icon button huge fluid" href="http://www.brahmakumaris.com/about-us/?browser=true">
                <i class="bell icon"></i>
                <span>About us</span>
            </a>
        </div>

        @*<h4>My Links</h4>
            <div class="app-control">
                <a class="ui labeled icon button huge fluid">
                    <i class="exchange icon"></i>
                    <span>Pending Internal Transfers</span>
                </a>
                <a class="ui labeled icon button huge fluid">
                    <i class="bell icon"></i>
                    <span>Notifications</span>
                </a>
                <a class="ui labeled icon button huge fluid">
                    <i class="hand pointer outline icon"></i>
                    <span>Open Actions</span>
                </a>
            </div>*@
    </div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/semantic-ui/2.4.1/semantic.min.js"></script>
    <script>
        $('.sm-info a').click(function () { $(this).next().toggle() })
    </script>
    <script>
        $(document)
            .ready(function () {
        setAppliedTheme("@theme")
                // fix menu when passed
                $('.masthead')
                    .visibility({
                        once: false,
                        onBottomPassed: function () {
                            $('.fixed.menu').transition('fade in');
                        },
                        onBottomPassedReverse: function () {
                            $('.fixed.menu').transition('fade out');
                        }
                    })
                    ;

                // create sidebar and attach to menu open
                $('.ui.sidebar.left')
                    .sidebar('attach events', '.toc.item')
                    ;

                $('.ui.sidebar.right')
                    .sidebar('attach events', '.ric.item')
                    ;
            });

        function UnregisterAndroidUser()
        {
            if ("@ActiveUser_REG_REC_ID".length > 0)
            {
                $.ajax({
                    type: "GET",
                    url: "/Help/Android/UnregisterAndroidUser",
                    data:
                    {
                        REGISTRATION_TBL_Rec_ID: "@ActiveUser_REG_REC_ID"
                    },
                    cache: false,
                    success: function (data)
                    {
                        var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                        alertclick.done(function (alertResult)
                        {
                            if (data.jsonParam.result == true)
                            {
                                window.open("/Help/Android/Android_C1_HomePage?androidID=" + "@androidID" + "&deviceToken=" + "@deviceToken", "_self");
                            }
                        });
                    }
                });
            }
        }
        function SetDefaultAndroidUser()
        {
            if ("@ActiveUser_REG_REC_ID".length > 0)
            {
                $.ajax({
                    type: "GET",
                    url: "/Help/Android/SetDefaultAndroidUser",
                    data:
                    {
                        REGISTRATION_TBL_Rec_ID: "@ActiveUser_REG_REC_ID"
                    },
                    cache: false,
                    success: function (data)
                    {
                        var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                        alertclick.done(function (alertResult)
                        {
                            if (data.jsonParam.result == true)
                            {

                            }
                        });
                    }
                });
            }
        }
        function RegisterNewAndriodUser()
        {
            window.open("/Start/Login/Frm_COD_Selection?androidID=" + "@androidID" + "&deviceToken=" + "@deviceToken"+"&RedirectToAndroid=YES","_self")
        }
        function AndroidC1USerClick(userid, User_REGISTRATION_TBL_Rec_ID)
        {
            window.open("/Help/Android/Android_C1_HomePage?androidID=" + "@androidID" + "&deviceToken=" + "@deviceToken"+"&user_id=" + userid, "_self");
        }
    </script>
</body>
</html>