<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta name="description" content="" />
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="favicon.ico" type="image/x-icon" />
    <link href="@Url.Content("~/Content/dx.common.css")" rel="Stylesheet" />
    <link href="@Url.Content("~/Content/dx.light.css")" rel="Stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/semantic-ui/2.2.6/semantic.min.css" />
    <link rel="stylesheet" href="~/Content/Android/css/bootstrap.css" />
    <link rel="stylesheet" href="~/Content/Android/css/app.css?v=1" />
    <script src="@Url.Content("~/Scripts/jquery-3.6.0.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/dx.all.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/aspnet/dx.aspnet.data.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/aspnet/dx.aspnet.mvc.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Content/Android/js/common.js")" type="text/javascript"></script>
</head>

@{
    Layout = "";
    string androidID = Convert.ToString(ViewBag.androidID);
    string deviceToken = Convert.ToString(ViewBag.deviceToken);
    string ServiceMOduleDmain = (string)ViewBag.Service_Module_Domain;
    string Connectone_Domain = (string)ViewBag.Connectone_Domain;
    string theme = ViewBag.theme;
    string GUID = Guid.NewGuid().ToString();
    string URL_C1_HomePage = Connectone_Domain + "/Help/Android/Android_C1_HomePage?androidID=" + androidID + "&deviceToken=" + deviceToken;
    string URL_ServiceModule = Connectone_Domain + "/Help/Android/Android_Services_HomePage?androidID=" + androidID + "&deviceToken=" + deviceToken;
    //string URL_ServiceModule = ServiceMOduleDmain + "?browser=true";
    string URL_WingsModule = ServiceMOduleDmain;
    string URL_Sparc_Projects = Connectone_Domain + "/Help/Android/Android_Sparc_HomePage?androidID=" + androidID + "&deviceToken=" + deviceToken;
    bool showSparcModule = (bool)ViewBag.showSparcModule;
    bool showAccountsModule = (bool)ViewBag.showAccountsModule;
    bool showServiceModule = (bool)ViewBag.showServiceModule;
}

<body>
       <style>html.ios, html.ios body{height: 100% !important;}</style>
    <!-- Right Side Menu -->
    @Html.Partial("Android_Theme", androidID)
    <!-- Page Contents -->
<div class="pusher pt-0">

    <h4>Please select the module you want to access</h4>
    <div class="ui large secondary menu">
        <a class="ric item">
            <i class="paint brush icon"></i>
        </a>
    </div>
    <div class="app-control middle">
        <a class="ui labeled icon button huge fluid" style="display:none" id="AccountsModuleButton_HP" href="#" onclick="AndroidModulesClick('Accounts')">
            <i><img src="~/Content/Android/images/c1-logo.png" /></i>
            <span>Accounts</span>
        </a>

        <a class="ui labeled icon button huge fluid" style="display:none" id="ServiceModuleButton_HP" href="#" onclick="AndroidModulesClick('Services')">
            <i><img src="~/Content/Android/images/bk-logo.png" /></i>
            <span>Services by Brahma Kumaris</span>
        </a>

        @*<a class="ui labeled icon button huge fluid" href=@URL_WingsModule>
                <i><img src="~/Content/Android/images/wings-logo.png" /></i>
                <span>Wings of Brahma Kumaris</span>
            </a>*@

        <a class="ui labeled icon button huge fluid" style="display:none" id="SparcModuleButton_HP" href="#" onclick="AndroidModulesClick('Sparc')">
            <i><img src="~/Content/Android/images/sparc-logo.png" /></i>
            <span>SpARC Projects</span>
        </a>

    </div>
    @*For Testing Purpose Only*@
    @*<div><h6>TESTING PURPOSE ONLY</h6></div>
        <div><a href="https://connectonetestservices.bkinfo.in/form/4028">For Checking Document Browsing</a></div>
        <div><a href="https://connectonetestservices.bkinfo.in/form/4028?browser=true">For Checking Document Browsing [in Browser]</a></div>
        <div><a href="https://connectonedevservices.bkivv.app/form/61">Form 61</a></div>
        <div style="width:300px;word-wrap:break-word">Device Token: @deviceToken</div>
        <div>Android ID: @androidID</div>
        <div><a href="https://connectonedevservices.bkivv.app/form/22?browser=true">form link (with browser)</a></div> 
        <div><a href="https://connectonedevservices.bkivv.app/form/22">form link (without browser)</a></div>*@
    @*For Testing Purpose Only*@
    <script src="https://cdn.jsdelivr.net/semantic-ui/2.2.6/semantic.min.js"></script>
    <script>
            $(document)
                .ready(function ()
                {
                    setAppliedTheme("@theme")
                    // fix menu when passed
                    $('.masthead')
                        .visibility({
                            once: false,
                            onBottomPassed: function () {
                                $('.fixed.menu').transition('fade in');
                            },
                            onBottomPassedReverse: function () {
                                $('.fixed.menu').transition('fade out');
                            }
                        });
                    // create sidebar and attach to menu open
                    $('.ui.sidebar.right')
                        .sidebar('attach events', '.ric.item')
                        ;

                    if ("@showAccountsModule" == "True") { $("#AccountsModuleButton_HP").show(); }

                    if ("@showServiceModule" == "True") { $("#ServiceModuleButton_HP").show(); }

                    if ("@showSparcModule" == "True") {

                        $("#SparcModuleButton_HP").show();

                        if ("@showAccountsModule" == "False" && "@showServiceModule" == "False") {
                            AndroidModulesClick('Sparc');
                        }
                    }

                });
            function AndroidModulesClick(Module)
            {
                var theme = getSelectedTheme();
                var url = "";
                if (Module == "Accounts")
                {
                    url = "@Connectone_Domain" + "/Help/Android/Android_C1_HomePage?androidID=" + "@androidID" + "&deviceToken=" + "@deviceToken" + "&theme=" + theme;
                }
                else if (Module == "Services")
                {
                    url = "@Connectone_Domain" + "/Help/Android/Android_Services_HomePage?androidID=" + "@androidID" + "&deviceToken=" + "@deviceToken" + "&theme=" + theme;
                }
                else if (Module == "Sparc")
                {
                    url = "@Connectone_Domain" + "/Help/Android/Android_Sparc_HomePage?androidID=" + "@androidID" + "&deviceToken=" + "@deviceToken" + "&theme=" + theme;
                }
                if (url.length > 0)
                {
                    window.open(url,"_self")
                }
            }

    </script>
</div>
</body>
</html>