@model ConnectOneMVC.Areas.Help.Models.SparcHomePAge
    @using System.Data
<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Strict//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-strict.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta name="description" content="" />
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="favicon.ico" type="image/x-icon" />
    <link href="@Url.Content("~/Content/dx.common.css")" rel="Stylesheet" />
    <link href="@Url.Content("~/Content/dx.light.css")" rel="Stylesheet" />
    <link rel="stylesheet" href="~/Content/Android/css/bootstrap.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/semantic-ui/2.4.1/semantic.min.css" />
    <link rel="stylesheet" href="~/Content/Android/css/app.css?v=1" />
    <script src="@Url.Content("~/Scripts/jquery-3.6.0.min.js")" type="text/javascript"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/semantic-ui/2.4.1/semantic.min.js"></script>
    <script src="@Url.Content("~/Scripts/dx.all.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/aspnet/dx.aspnet.data.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/aspnet/dx.aspnet.mvc.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Content/Android/js/common.js")" type="text/javascript"></script>

</head>

@{
    Layout = "";
    string androidID = Convert.ToString(ViewBag.androidID);
    string deviceToken = Convert.ToString(ViewBag.deviceToken);
    string Domain = (string)ViewBag.Domain;
    string ActiveUSerNAme = "";
    string ActiveUser_Service_User_ID = "";
    string ActiveUser_REG_REC_ID = "";
    bool IsActiveUser_Default =false;
    string SetDefaultVisibility = "style=display:block";
    string theme = ViewBag.theme;
    if (Model.ActiveUser != null && Model.ActiveUser.Length > 0)
    {
        ActiveUSerNAme = Model.ActiveUser[0]["FULL_NAME"].ToString();
        ActiveUser_Service_User_ID= Model.ActiveUser[0]["SERVICE_USER_ID"].ToString();
        ActiveUser_REG_REC_ID = Model.ActiveUser[0]["REG_REC_ID"].ToString();
        IsActiveUser_Default = Convert.ToBoolean(Model.ActiveUser[0]["DEFAULT_USER"]);
        if (IsActiveUser_Default == true)
        {
            SetDefaultVisibility = "disabled style=display:none";
        }
    }
    DataTable distinctProject = new DataTable();
    if (Model.Projects != null && Model.Projects.Rows.Count > 0)
    {
        DataView view = new DataView(Model.Projects);
        distinctProject = view.ToTable(true, "PROJECT_NAME");
    }
}

<body>
    <style>
        .group-parent span {
            color: white;
        }
    </style>
    <!-- Sidebar Menu -->
    <div class="ui vertical wide sidebar left menu">
        <div class="list massive">
            <div class="item">
                <img class="ui avatar image" src="~/Content/Android/images/user-1.png" />
                <div class="content">
                    <div class="h4 bold mt-2">@ActiveUSerNAme</div>
                </div>
            </div>
        </div>
        <div class="ui relaxed divided list">
            <a class="item" onclick="SetDefaultAndroidUser()" @SetDefaultVisibility= id="SparcHomePage_DefaultUser">
                <i class="large flag left aligned icon"></i>
                <div class="content">
                    <div class="header">Set as Default</div>
                </div>
            </a>
            <a class="item red" onclick="UnregisterAndroidUser()">
                <i class="large sign out alternate left aligned icon"></i>
                <div class="content">
                    <div class="header red">Logout</div> @*//Earlier it was called as Unregister Button*@
                </div>
            </a>
        </div>
        <div class="ui middle aligned divided user list">
            @for (int i = 0; i < Model.NonActiveUser.Length; i++)
            {
                string img_source = Url.Content("~/Content/Android/images/user-2.png");
                if (i % 2 != 0)
                {
                    img_source = Url.Content("~/Content/Android/images/user-3.png");
                }
                string username = Model.NonActiveUser[i]["FULL_NAME"].ToString();
                string User_Service_User_ID = Model.NonActiveUser[i]["SERVICE_USER_ID"].ToString();
                string User_REG_REC_ID = Model.NonActiveUser[i]["REG_REC_ID"].ToString();
                bool IsNonActiveUser_Default = Convert.ToBoolean(Model.NonActiveUser[i]["DEFAULT_USER"]);
                <a class="item" onclick="AndroidSparcUSerClick('@User_Service_User_ID','@User_REG_REC_ID')">
                    <img class="ui avatar image" src="@img_source" />
                    <div class="content">
                        <div class="header">@username</div>
                        @if (IsNonActiveUser_Default == true)
                        {
                            <small id="NonActiveDefault">Default</small>
                        }
                    </div>
                </a>
            }
        </div>
        <div class="text-center pt-4" onclick="RegisterNewAndriodUser()" style="display:none">
            <a class="ui basic button">Register New User</a>
        </div>
        <div class="sm-info">
            <a class="">Device Token</a>
            <div>@deviceToken</div>
            <a class="">Android ID</a>
            <div>@androidID</div>
            @*<i>App Version v2.0.0 </i>*@
        </div>
    </div>
    <!-- Right Side Menu -->
    @Html.Partial("Android_Theme", androidID)
    <!-- Page Contents -->
    <div class="pusher">
        <div class="ui fixed text ">
            <div class="ui large secondary menu">
                <a class="toc item">
                    <img src="~/Content/Android/images/menu.png" style="height: 17px; width: 24px; margin-right: 4px" />
                    <img src="~/Content/Android/images/sparc-logo.png" />
                </a>
                <div class="content oneline">
                    <div class="header">SpARC Projects</div>
                    <label>User: @ActiveUSerNAme</label>
                </div>
                <a class="ric item">
                    <i class="paint brush icon"></i>
                </a>
            </div>
        </div>

        <h4 style="margin-top:10px; padding-top: 30px">My Projects</h4>
        <div class="app-control">
            @for (int i = 0; i < distinctProject.Rows.Count; i++)
            {
                string Project = distinctProject.Rows[i]["PROJECT_NAME"].ToString();
                <div class="grouping">
                    <aside class="group-parent">
                        <i class="list alternate outline icon"></i>
                        <span>@Project</span>
                    </aside>
                    @{
                        DataRow[] Forms = Model.Projects.Select("Project_Name='" + Project + "'");
                        for (int j = 0; j < Forms.Length; j++)
                        {
                            string FormName = Forms[j]["SURVEY_FORM_NAME"].ToString();
                            string formLink = Forms[j]["SURVEY_FORM_Link"].ToString();
                            bool isactive = Convert.ToBoolean(Forms[j]["IS_ACTIVE"]);
                            string inactivemsg = Forms[j]["Msg_inactive"].ToString();
                            if (string.IsNullOrWhiteSpace(FormName) == false)
                            {
                                <a class="ui labeled icon button huge fluid" onclick="SurveyFormClick_Android('@formLink','@isactive','@inactivemsg')">
                                    <div class="lines"></div>
                                    <i class="clipboard check icon"></i>
                                    <span>@FormName</span>
                                </a>
                            }
                        }
                    }
                </div>
            }
        </div>
    </div>
    <script>
        $('.sm-info a').click(function () { $(this).next().toggle() })
    </script>
    <script>
        $(document)
            .ready(function () {
                setAppliedTheme("@theme")
                // fix menu when passed
                $('.masthead')
                    .visibility({
                        once: false,
                        onBottomPassed: function () {
                            $('.fixed.menu').transition('fade in');
                        },
                        onBottomPassedReverse: function () {
                            $('.fixed.menu').transition('fade out');
                        }
                    })
                    ;

                // create sidebar and attach to menu open
                $('.ui.sidebar.left')
                    .sidebar('attach events', '.toc.item')
                    ;

                $('.ui.sidebar.right')
                    .sidebar('attach events', '.ric.item')
                    ;

            });
        function SurveyFormClick_Android(formLink, IsActive, inacTiveMsg) {
            if (inacTiveMsg.length > 0) {
                DevExpress.ui.dialog.alert(inacTiveMsg, "Information");
                return
            }
            if (formLink==null||formLink.length== 0) {
                DevExpress.ui.dialog.alert("This Survey Form Is Not Available Now", "Information");
                return
            }
            formLink = "@Domain" + formLink;
            if (formLink.length > 0) {
                window.open(formLink, "_self")
            }
        }
        function UnregisterAndroidUser()
        {
            if ("@ActiveUser_REG_REC_ID".length > 0) {
                $.ajax({
                    type: "GET",
                    url: "/Help/Android/UnregisterAndroidUser",
                    data:
                    {
                        REGISTRATION_TBL_Rec_ID: "@ActiveUser_REG_REC_ID"
                    },
                    cache: false,
                    success: function (data) {
                        var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                        alertclick.done(function (alertResult) {
                            if (data.jsonParam.result == true) {
                                window.open("/Help/Android/Android_Sparc_HomePage?androidID=" + "@androidID" + "&deviceToken=" + "@deviceToken", "_self");
                            }
                        });
                    }
                });
            }
        }
        function SetDefaultAndroidUser()
        {
            if ("@ActiveUser_REG_REC_ID".length > 0)
            {
                $.ajax({
                    type: "GET",
                    url: "/Help/Android/SetDefaultAndroidUser",
                    data:
                    {
                        REGISTRATION_TBL_Rec_ID: "@ActiveUser_REG_REC_ID"
                    },
                    cache: false,
                    success: function (data)
                    {
                        var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                        alertclick.done(function (alertResult)
                        {
                            if (data.jsonParam.result == true)
                            {
                              $("#SparcHomePage_DefaultUser").hide();
                                $("#NonActiveDefault").hide();
                            }
                        });
                    }
                });
            }
        }
        function RegisterNewAndriodUser()
        {
            var Service_Module_Login_URL = "@Domain"+ "/Events/Login/loginpartialview?firebaseDeviceToken=" + "@deviceToken" + "&androidID=" + "@androidID" + "&androidModule=SPARC";
            window.open(Service_Module_Login_URL,"_self")
        }
        function AndroidSparcUSerClick(userid, User_REGISTRATION_TBL_Rec_ID)
        {
            window.open("/Help/Android/Android_Sparc_HomePage?androidID=" + "@androidID" + "&deviceToken=" + "@deviceToken"+"&user_id=" + userid, "_self");
        }
    </script>
</body>
</html>