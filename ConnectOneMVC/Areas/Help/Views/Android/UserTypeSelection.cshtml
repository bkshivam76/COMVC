    string URL_CO_Auditor = "https://Connectonedev.bkivv.app/Start/Login/Frm_Auditor_Login?deviceToken=" + firebaseDevicetoken;
    string URL_ServiceModule = "http://accountserver-test.bkinfo.in:1010/Events/EventsListing/Frm_EventsListing_Info?SessionGUID=" + GUID + "&firebaseDevicetoken=" + firebaseDevicetoken;
}


