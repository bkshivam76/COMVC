    <script>
        var firebaseDevicetoken = "@Model";
        var GUID = createGuid();

        var URL_CO_Centre = "https://Connectonedev.bkivv.app/Start/Login/Frm_COD_Selection?deviceToken=" + firebaseDevicetoken;
        var URL_CO_Auditor = "https://Connectonedev.bkivv.app/Start/Login/Frm_Auditor_Login?deviceToken=" + firebaseDevicetoken;
        var URL_ServiceModule = "http://accountserver-test.bkinfo.in:1010/Events/EventsListing/Frm_EventsListing_Info?firebaseDeviceToken=" + firebaseDevicetoken + "&SessionGUID=" + GUID ;

        function createGuid() {
            return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function (c) {
                var r = Math.random() * 16 | 0, v = c === 'x' ? r : (r & 0x3 | 0x8);
                return v.toString(16);
            });
        }

