@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
        .ID("LookUp_DocumentNames_List_datagrid")
        .Columns(columns =>
        {

            columns.Add().DataField("Name").Caption("Name");
            columns.Add().DataField("ID").Caption("ID").Visible(false);
            columns.Add().DataField("Category").Caption("Category").Visible(true);
            columns.Add().DataField("From_Date_Label").Caption("From Date Label").Visible(false);
            columns.Add().DataField("To_Date_Label").Caption("To Date Label").Visible(false);
            columns.Add().DataField("Description_Label").Caption("Description Label").Visible(false);
            columns.Add().DataField("Param_Mandatory").Caption("Param_Mandatory").Visible(false);

        })

        .Selection(s => s.Mode(SelectionMode.Single))
            .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}")
)




