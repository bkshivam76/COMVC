<script>
    function On_HelpAttachment_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName == "InitialViewDocumentClick")
        {
            if (helpViewright == false)
            {
                DevExpress.ui.dialog.alert("Not Allowed !!", "No Rights");
                return;
            }
            //if (AttachmentListGrid.GetFocusedRowIndex() < 0)
            //{
            //    DevExpress.ui.dialog.alert("Please Select A Row..!!", "Inform..");
            //    return;
            //}
            if (Help_Rec_ID == null || Help_Rec_ID.length == 0) {
                DevExpress.ui.dialog.alert("No Document Selected To View..", "Information..");
                return;
            }
              var FAB_ID = "@CalledFromOtherScreen" == "UniversalDocumentPopup" ?"UniversalDoc_FAB" : "HelpAttach_FAB";
            if ("@CalledFromOtherScreen".length > 0)
            {

                if ("@CalledFromOtherScreen" == "UniversalDocumentPopup")
                {
                    ViewDocument(Help_Rec_ID, Help_FileName, FAB_ID, "ImageToolBarContext", document.getElementById('BottomRightPane_Iframe'), document.getElementById('BottomRightPane_Img'), document.getElementById('BottomRightPane_div_Iframe'), document.getElementById('BottomRightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                       var popupid = "#" + "@CalledFromOtherScreen";
                    $(popupid).dxPopup("hide");
                }
                else
                {
                    ViewDocument(Help_Rec_ID, Help_FileName, FAB_ID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
            }
            else
            {
                ViewDocument(Help_Rec_ID, Help_FileName, FAB_ID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
            }
        }
        else if (e.actionName === "Rotate") {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut") {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn") {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit") {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "ViewAttachmentContext");
        }
    }
</script>@* FAB *@
<script type="text/javascript">
    var HelpAttachment_ShowHorizontalBar = parseInt("@ViewBag.ShowHorizontalBar");
    var helpnewright;
    var helpeditright;
    var helpDeleteright;
    var helpViewright;
    var helpExportright;
    var helpSuperuser_auditor = false;
    var Help_Rec_ID;
    var Help_Ref_ID;
    var Help_FileName;
    var Help_Checked;
    var Help_AddBy;
    var Help_AddOn;
    var Help_EditBy;
    var Help_Editon;
    var Help_Attach_ActionStatus;
    var Help_CheckingStatus;
    var AttachmentGrid_layout = null;
    var AttachmentFocusRowIndexBeforeRefresh;
    var Attachment_IsVouchingMode=false
    function Attachment_VouchingSwitch_ValueChange(e)
    {
        Attachment_IsVouchingMode = e.value;

        AttachmentListGrid.PerformCallback();

    }
    $(document).ready(function ()
    {
        HideUnreleasedFunctionality('Frm_Attachment_Info');
        if ("@Help_Attachments_AddRight" == "False")
        {
            helpnewright = false;
            $("#Help_BUT_NEW").hide();
        }
        else
        {
            helpnewright = true;
        }
        if ("@Help_Attachments_UpdateRight" == "False")
        {
            helpeditright = false;
            $("#Help_BUT_EDIT").hide();
        }
        else
        {
            helpeditright = true;
        }
        if ("@Help_Attachments_DeleteRight" == "False")
        {
            helpDeleteright = false;
            $("#Help_BUT_Delete").hide();
            $("#Help_BUT_Unlink").hide();
        }
        else
        {
            helpDeleteright = true;
        }
        if ("@Help_Attachments_ViewRight" == "False")
        {
            helpViewright = false;
            HelpAttach_FAB.SetVisible(false);
        }
        else
        {
            helpViewright = true;
        }
        if ("@Help_Attachments_ExportRight" == "False")
        {
            helpExportright = false;
            $("#Help_BUT_PRINT").hide();
        }
        else
        {
            helpExportright = true;
        }
        if ("@HelpSuperuser_Auditor" == "False")
        {
            helpSuperuser_auditor = false;
        }
        else
        {
            helpSuperuser_auditor = true;
        }
        if (Attachment_IsVouchingMode == true) {
            $(".AttachmentListGrid_PreviewRow").hide();
        }
      //  GetSessionStorage("AttachmentListGrid");
        DevExpress.ui.notify({ message: "Click The Show Button To View The Data", width: "auto", shading: true, position: 'center' }, "info", 1500);
    });
    function OnGridAttachmentListGrid_BeginCallback(s, e)
    {
        e.customArgs["command"] = e.command;
        e.customArgs["ShowHorizontalBar"] = HelpAttachment_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = Attachment_IsVouchingMode;
        e.customArgs["RefRecID"] = "@ViewBag.RefRecID";
    }
    function OnGridAttachmentListGrid_EndCallback(s, e)
    {

        Help_AttachmentAdjustSize();
        AttachmentGrid_layout = s.cpClientLayout;
        if (Attachment_IsVouchingMode == true)
        {
            $(".AttachmentListGrid_PreviewRow").hide();
        }
     //   GetSessionStorage("AttachmentListGrid");
        SendCustomArgs_FilterControl(s, e);
        if (e.command == "REFRESH")
        {
            AttachmentFocusRowIndexBeforeRefresh = s.GetFocusedRowIndex();
            s.SetFocusedRowIndex(-1);
            s.SetFocusedRowIndex(AttachmentFocusRowIndexBeforeRefresh);
        }
        //if (e.command != "REFRESH")
        //{
        //    s.SetFocusedRowIndex(-1);
        //}
    }
    function OnAttachmentGridInit(s, e) {
        Help_AttachmentAdjustSize();
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            Help_AttachmentAdjustSize();
        });
        if ("@filter".length > 0)
        {
            AttachmentListGrid.SetFocusedRowIndex(-1);
            AttachmentListGrid.AutoFilterByColumn("Attachment", "@filter");
        }


    }
    function Help_AttachmentAdjustSize() {
        if ("@CalledFromOtherScreen".length > 0) {
            var height = (document.documentElement.clientHeight * 75) / 100;
        }
        else {
            var height = (document.documentElement.clientHeight * 90) / 100;
        }
        try { AttachmentListGrid.SetHeight(height); } catch (err) { }
    }
    function OnAttachmentGridFocusedRowChanged(s, e) {

        if (s.GetFocusedRowIndex() <0)
        {
            Help_Rec_ID = "";
            Help_FileName = "";
        }
        else
        {
            ShowLoader();
            var index = s.GetFocusedRowIndex();
            var key = s.GetRowKey(index);
            //$("#AttachmentListGrid_DXDataRow" + index).css("background-color", "#0072C6");
            s.GetValuesOnCustomCallback({ key: key }, HelpAttachment_OnGetRowValues);
        }
    }
    function HelpAttachment_OnGetRowValues(Data)
    {
        if (Data != null)
        {
            var values = Data.split("![");
            Help_AddBy = values[1];
            Help_AddOn = values[0];
            Help_EditBy = values[2];
            Help_Editon = values[3];
            Help_Ref_ID = values[4];
            Help_Checked = values[5];
            Help_FileName = values[6];
            Help_Attach_ActionStatus = values[7];
            Help_CheckingStatus = values[8];
            Help_Rec_ID = values[9];
            Attachment_UpdateFooterDetail(Help_AddOn, Help_AddBy, Help_Editon, Help_EditBy)
            HelpAttach_FAB.SetActionContext("ViewAttachmentContext", true);        
        }
        HideLoader();
    }
    function Attachment_UpdateFooterDetail(Attachment_Add_Date, Attachment_Add_By, Attachment_Edit_Date, Attachment_Edit_By) {

        var Lbl_Create = "";
        var Lbl_Modify = "";
        var Add_Date = "";
        var Add_By = "";
        var Edit_Date = "";
        var Edit_By = "";
        Edit_Date = Attachment_Edit_Date;
        Edit_By = Attachment_Edit_By;
        Add_Date = Attachment_Add_Date;
        Add_By = Attachment_Add_By;


        if (Add_Date) {
            Lbl_Create = "Add On: " + Add_Date + ", By: " + Add_By;
        }
        else {
            Lbl_Create = "Add On: " + "?, By: " + Add_By;
        }

        if (Edit_Date) {
            Lbl_Modify = "Edit On: " + Edit_Date + ", By: " + Edit_By;
        }
        else {
            Lbl_Modify = "Edit On: " + "?, By: " + Edit_By;
        }

        $('#AttachmentLbl_Create').text(Lbl_Create);
        $('#AttachmentLbl_Modify').text(Lbl_Modify);

    }
    function Help_AttachmentchangeMode()
    {
        ShowLoader();
        if (HelpAttachment_ShowHorizontalBar == 0) {
            HelpAttachment_ShowHorizontalBar = 1;
            $("#Help_BUT_Fulldata").find("span").text("Default Data");
            $("#Help_BUT_Fulldata").width(110);
        }
        else {
            HelpAttachment_ShowHorizontalBar = 0;
            $("#Help_BUT_Fulldata").find("span").text("Full Data");
            $("#Help_BUT_Fulldata").width(90);
        }
                        $.ajax({
                            url: '@Url.Action("Frm_Attachment_Info_Grid", "Attachment")',
                            type: "GET",
                            data:
                            {
                                ShowHorizontalBar: HelpAttachment_ShowHorizontalBar,
                                Layout: AttachmentGrid_layout,
                                VouchingMode: Attachment_IsVouchingMode

                            },
                            success: function (res)
                            {
                                HideLoader();
                                ShowLoader();
                                $("#AttachmentreloadPartialView").html(res);
                                HideLoader();
                                if (Attachment_IsVouchingMode == true) {
                                    $(".AttachmentListGrid_PreviewRow").hide();
                                }
                              //  GetSessionStorage("AttachmentListGrid");
                            }
                        });

    }// Full Data Button Click
</script>@* ready and grid functions *@
<script>
    function OnAttachmentNewClick(_DocumentCategory="", _DocumentName="",_DocumentDescription="")
    {
        if (helpnewright == true)
        {
            $("#ID_Frm_Help_Document_Attach").remove();
            ShowLoader();
            $.ajax({
                type: 'GET',
                cache: false,
                url: "/Help/Attachment/Frm_Attachment_Window",
                data: {
                    AM: "New",
                    DocumentName: _DocumentName,
                    DocumentCategory: _DocumentCategory,
                    DocumentDescription: _DocumentDescription,
                    CallFromHelpAttachment: true
                },
                success: function (data)
                {
                    OpenDynamicPopup("New Attachment", null, "auto", 900, true, data);
                }
            });
        }
        else
        {
            DevExpress.ui.dialog.alert("Not Allowed !!", "No Rights");
        }
    }//New Button Click //Mantis 0000213 bug fixed
    function OnAttachmentRowDblClick(s, e)
    {
        if (Attachment_IsVouchingMode == false)
        {
            ShowLoader();
            OnAttachmentEditClick();
        }
    }
    function OnAttachmentEditClick()
    {
        if (helpeditright == true)
        {
            if (Help_Rec_ID == undefined || Help_Rec_ID == "undefined" || Help_Rec_ID == null || Help_Rec_ID == "")
            {
                DevExpress.ui.dialog.alert("select A row", 'Inform'); return;
            }
            if (Help_Attach_ActionStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Entry Cannot be Edited", "Edit ~ Attachment"); return;
            }
            $.ajax({
                type: 'GET',
                url: "/Help/Attachment/DataNavigation",
                data: {
                    AM: "Edit",
                    ID: Help_Rec_ID,
                    editon: Help_Editon
                },
                cache: false,
                success: function (data)
                {
                    if (data.result == false)
                    {
                        DevExpress.ui.dialog.alert(data.Message, "Error");
                    }
                    else if (data.result == "NoEditRights")
                    {
                        $("#Help_BUT_EDIT").hide();
                        DevExpress.ui.dialog.alert(data.Message, "Warning");
                    }
                    else
                    {
                        $("#ID_Frm_Help_Document_Attach").remove();
                        ShowLoader();
                        $.ajax({
                            type: 'GET',
                            url: "/Help/Attachment/Frm_Attachment_Window",
                            data:
                            {
                                AM: "Edit",
                                ID: Help_Rec_ID
                            },
                            cache: false,
                            success: function (result)
                            {
                                OpenDynamicPopup("Edit Attachment",null, "auto", 900, true, result);
                            }
                        });
                    }
                }
            });
        }
        else
        {
            DevExpress.ui.dialog.alert("Not Allowed !!", "No Rights");
        }
    }//Mantis 0000213 bug fixed
