    function OnAttachmentDeleteClick()
    {
        if (helpDeleteright == true)
        {
            if (Help_Rec_ID == undefined || Help_Rec_ID == "undefined" || Help_Rec_ID == null || Help_Rec_ID == "")
            {
                DevExpress.ui.dialog.alert("select A row", 'Inform'); return;
            }
            if (Help_Attach_ActionStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Entry Cannot be Deleted", "Delete ~ Attachment"); return;
            }
            var result = DevExpress.ui.dialog.confirm("Sure you want to delete?", "Delete ~ Attachment");
            result.done(function (dialogResult) {
                if (dialogResult) {
                    $("#ID_Frm_Help_Document_Attach").remove();
                    ShowLoader();

                    $.ajax({
                        type: 'GET',
                        url: "/Help/Attachment/Frm_Attachment_Window",
                        data: {
                            AM: "Delete",
                            ID: Help_Rec_ID
                        },
                        cache: false,
                        success: function (data)
                        {
                            OpenDynamicPopup("Delete Attachment",null, "auto", 900, true, data);
                        }
                    });
                }
            });
        }
        else {
            DevExpress.ui.dialog.alert("Not Allowed !!", "No Rights");
        }//Mantis 0000213 bug fixed
    }
    var CashbookPeriod_Attachment = null;
    var CashBookFromDate_Attachment = null;
    var CashBookToDate_Attachment = null;
    function OnAttachmentLinkClick()
    {
        if (Help_Rec_ID == undefined || Help_Rec_ID == "undefined" || Help_Rec_ID == null || Help_Rec_ID == "")
        {
            DevExpress.ui.dialog.alert("Select A row", 'Inform'); return;
        }
        if ($("#Cashbook_ParentDiv").length > 0)
        {
            DevExpress.ui.dialog.alert("Cashbook Is Already Open<br>Kindly Close Cashbook To Link The Attachment", 'Inform'); return;
        }
        ShowLoader();
        var _url = "";
        //if ($("div[id = 'CashBookListGrid']").data("dxDataGrid") !== void 0)
        //{
        //    _url = "/Account/Voucher/Frm_Voucher_Info_CB";
        //}
        //else
        //{
            _url = "/Account/Voucher/Frm_Voucher_Info_CB";
        //}
        $.ajax({
            type: 'GET',
            url: _url,
            data: {
                PopupID: "LinkAttachmentToCashbook",
                AttachmentID: Help_Rec_ID,
                Period: CashbookPeriod_Attachment,
                FromDate: CashBookFromDate_Attachment,
                ToDate:CashBookToDate_Attachment
            },
            cache: false,
            success: function (data)
            {
                OpenPopup("LinkAttachmentToCashbook","Link Attachment", null, "auto", "90%", true, data);
            }
        });
    }
    function OnAttachmentUnlinkClick() {
        if (helpDeleteright == true)
        {
            if (Help_Rec_ID == undefined || Help_Rec_ID == "undefined" || Help_Rec_ID == null || Help_Rec_ID == "")
            {
                DevExpress.ui.dialog.alert("Select A row", 'Inform'); return;
            }
            if (Help_Ref_ID == undefined || Help_Ref_ID == "undefined" || Help_Ref_ID == null || Help_Ref_ID == "")
            {
                DevExpress.ui.dialog.alert("Attachment Already Unlinked..!", 'Inform'); return;
            }
            var result = DevExpress.ui.dialog.confirm("Sure you want to Unlink?", "Unlink ~ Attachment");
            result.done(function (dialogResult)
            {
                if (dialogResult) {
                    ShowLoader();

                    $.ajax({
                        type: 'GET',
                        url: "/Help/Attachment/Frm_Attachment_Unlink",
                        data: {
                            ID: Help_Rec_ID,
                            RefId: Help_Ref_ID
                        },
                        cache: false,
                        success: function (data)
                        {
                            if (data.result == false)
                            {
                                DevExpress.ui.dialog.alert(data.Message, "Error");
                            }
                            else if (data.result == "NoDeleteRights")
                            {
                                $("#Help_BUT_Unlink").hide();
                                DevExpress.ui.dialog.alert(data.Message, "Warning");
                                AttachmentListGrid.Refresh();
                                HideLoader();
                            }
                            else
