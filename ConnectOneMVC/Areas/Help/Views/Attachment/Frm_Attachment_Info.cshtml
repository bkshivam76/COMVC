    function OnAttachmentAcceptClick()
    {
        if (helpSuperuser_auditor == true)
        {
            if (Help_Rec_ID == undefined || Help_Rec_ID == "undefined" || Help_Rec_ID == null || Help_Rec_ID == "")
            {
                DevExpress.ui.dialog.alert("Select A row", 'Inform'); return;
            }
            if (Help_CheckingStatus == "ACCEPTED")
            {
                DevExpress.ui.dialog.alert("Attachment Already Accepted..!", 'Inform'); return;
            }
            ShowLoader();

            $.ajax({
                type: 'GET',
                url: "/Help/Attachment/Frm_Attachment_Check",
                data: {
                    ID: Help_Rec_ID,
                },
                cache: false,
                success: function (data) {
                    if (data.result == false) {
                        DevExpress.ui.dialog.alert(data.Message, "Error");
                    }
                    else if (data.result == "NoSuperuser_Auditor_Check_UncheckRights")
                    {
                        $("#Help_BUT_Accept").hide();
                        DevExpress.ui.dialog.alert(data.Message, "Warning");
                    }
                    else
                    {
                        DevExpress.ui.dialog.alert(data.Message, "Success");
                        AttachmentListGrid.Refresh();
                    }
                }
            });
            HideLoader();
        }
        else
        {
            DevExpress.ui.dialog.alert("Not Allowed !!", "No Rights");
        }
    }
    function OnAttachmentRejectClick()
