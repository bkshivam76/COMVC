        @(Html.DevExtreme().Button().ID("Help_BUT_EDIT").Text("Edit").Icon("edit").OnClick(@<text>function (){OnAttachmentEditClick();}</text>))
        @(Html.DevExtreme().Button().ID("Help_BUT_Link").Text("Link").Icon("unpin").OnClick(@<text>function(){OnAttachmentLinkClick();}</text>))
        @(Html.DevExtreme().Button().ID("Help_BUT_Unlink").Text("Unlink").Icon("undo").OnClick(@<text>function(){OnAttachmentUnlinkClick();}</text>))
        @(Html.DevExtreme().Button().ID("Help_BUT_Delete").Text("Delete").Icon("trash").OnClick(@<text>function(){OnAttachmentDeleteClick();}</text>))
        @(Html.DevExtreme().Button().ID("Help_BUT_DeleteByDescription").Text("Delete By Description").Icon("trash").OnClick(@<text>function(){OnAttachmentDeleteClick_Description();}</text>))
        @(Html.DevExtreme().Button().ID("Help_BUT_View").Text("View").Icon("doc").OnClick(@<text>function(){OnAttachmentViewClick();}</text>))
        @(Html.DevExtreme().Button().ID("Help_BUT_PRINT").Text("Export").Icon("save").OnClick(@<text>function(){OnAttachmentListPreviewClick();}</text>))
        @(Html.DevExtreme().Button().ID("Help_BUT_Fulldata").Text(ViewBag.ShowHorizontalBar == 1 ? "Default Data" : "Full Data").Width(ViewBag.ShowHorizontalBar == 1 ? 110 : 90).Icon("toolbox").OnClick(@<text>function(){Help_AttachmentchangeMode();}</text>))
        @(Html.DevExtreme().Button().ID("Help_BUT_CLOSE").Text("Close").Icon("clear").OnClick(@<text>function (){btnCloseClick();}</text>))
        <br>
        @*</div>*@
    </div><!--[Buttons]-->
</div><!--[Header]-->        
