            @* @(Html.DevExtreme().Switch().ID("AttachmentVouchingModeSwitch").SwitchedOnText("Vouching On").SwitchedOffText("Vouching Off").OnValueChanged("Attachment_VouchingSwitch_ValueChange").Width(100))*@
