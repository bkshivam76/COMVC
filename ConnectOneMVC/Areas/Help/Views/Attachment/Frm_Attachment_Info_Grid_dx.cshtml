@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;
    int ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;
}
@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar)
                 .ID("AttachmentListGrid_dx")
                 .DataSource(d => d.Mvc().Controller("Attachment").LoadAction("Frm_Attachment_Info_Grid_dx")
                 .OnBeforeSend("AttachmentListGrid_dx_OnBeforeSend")
                 .LoadMode(DataSourceLoadMode.Raw).Key("UniqueID"))
                 .Columns(columns =>
                 {
                     columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);//Bug #137209 Fix
                     columns.Add().DataField("iIcon").Name("iIcon").Caption("").CellTemplate(new JS("AttachmentListGrid_dx_iIconTemplate")).Width(30)
                     .HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource")).RenderAsync(true);
                     //columns.Add().DataField("BankListGrid_dx_Compact_Column").Name("BankListGrid_dx_Compact_Column").Caption("").Visible(false).CellTemplate(new JS("BankListGrid_dx_Compact_Column_Template"))
                     //.CalculateCellValue("BankListGrid_dx_Compact_Column_CellValue").Width("100%").RenderAsync(true).ShowInColumnChooser(false);
                     columns.Add().DataField("Checking_Status").Caption("Status").MinWidth(75);
                     columns.Add().DataField("Screen").Caption("Screen").MinWidth(90);
                     columns.Add().DataField("Attachment").Caption("Attachment").MinWidth(140);
                     columns.Add().DataField("File_Name").Caption("File Name").MinWidth(138).Width(400);
                     columns.Add().DataField("Description").Caption("Description");
                     columns.Add().DataField("Applicable_From").Caption("Applicable From").MinWidth(140)
                    .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                     columns.Add().DataField("Applicable_To").Caption("Applicable To").MinWidth(140)
                    .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                     columns.Add().DataField("Checked").Caption("Checked").Visible(false);
                     columns.Add().DataField("Action_By").Caption("Action By").Visible(false).MinWidth(120);

                     columns.Add().DataField("Action_Date").Caption("Action Date").Visible(false).MinWidth(120);
                     columns.Add().DataField("Action_Status").Caption("Action Status").Visible(false).MinWidth(120);
                     columns.Add().DataField("Add_By").Caption("Added By").Visible(false).MinWidth(120);
                     columns.Add().DataField("Add_Date").Caption("Added Date").Visible(false).MinWidth(120);
                     columns.Add().DataField("Edit_By").Caption("Edited By").Visible(false).MinWidth(120);
                     columns.Add().DataField("Edit_Date").Caption("Edited Date").Visible(false).MinWidth(120);
                     columns.Add().DataField("ID").Caption("ID").Visible(false).MinWidth(120);
                     columns.Add().DataField("RefID").Caption("RefID").Visible(false).MinWidth(120);
                     columns.Add().DataField("Document_Rejection_Reason").Caption("Document_Rejection_Reason").Visible(false).MinWidth(120);
                     columns.Add().DataField("UniqueID").Caption("UniqueID").Visible(false).MinWidth(120);

                 })          
         .OnInitialized("AttachmentListGrid_dx_OnInitialized")
         .OnCellPrepared("AttachmentListGrid_dx_OnCellPrepared")
         .OnRowPrepared("AttachmentListGrid_dx_OnRowPrepared")
         .OnContentReady("AttachmentListGrid_dx_OnContentReady")
         .OnCellDblClick("AttachmentListGrid_dx_OnCellDblClick")
         .OnSelectionChanged("AttachmentListGrid_dx_OnSelectionChanged")
         //.OnFocusedRowChanged("BankListGrid_dx_OnFocusedRowChanged")
         .OnContextMenuPreparing("AttachmentListGrid_dx_OnContextMenuPreparing")        
)