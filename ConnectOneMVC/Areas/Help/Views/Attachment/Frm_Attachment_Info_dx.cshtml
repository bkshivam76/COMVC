                            AM: "Delete",
                            ID: Help_Rec_ID
                        },
                        cache: false,
                        success: function (data)
                        {
                            OpenDynamicPopup("Delete Attachment",null, "auto", 900, true, data);
                        }
                    });
                }
            });
        }
        else {
            DevExpress.ui.dialog.alert("Not Allowed !!", "No Rights");
        }//Mantis 0000213 bug fixed
    }
