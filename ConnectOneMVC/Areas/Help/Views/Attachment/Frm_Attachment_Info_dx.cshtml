                }
                else
                {
                    ViewDocument(Help_Rec_ID, Help_FileName, FAB_ID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                    //OnAttachmentViewClick();
                }
            }
            else if (e.item.name == 'ListPreview') {
                OnAttachmentListPreviewClick();
            }
            else if (e.item.name == 'Refresh') {
                AttachmentListGrid.Refresh();
            }
            else if (e.item.name == 'Lock')
