    function Attachment_UpdateFooterDetail(Attachment_Add_Date, Attachment_Add_By, Attachment_Edit_Date, Attachment_Edit_By) {

        var Lbl_Create = "";
        var Lbl_Modify = "";
        var Add_Date = "";
        var Add_By = "";
        var Edit_Date = "";
        var Edit_By = "";
        Edit_Date = Attachment_Edit_Date;
        Edit_By = Attachment_Edit_By;
        Add_Date = Attachment_Add_Date;
        Add_By = Attachment_Add_By;


        if (Add_Date) {
            Lbl_Create = "Add On: " + Add_Date + ", By: " + Add_By;
        }
        else {
            Lbl_Create = "Add On: " + "?, By: " + Add_By;
        }

        if (Edit_Date) {
            Lbl_Modify = "Edit On: " + Edit_Date + ", By: " + Edit_By;
        }
        else {
            Lbl_Modify = "Edit On: " + "?, By: " + Edit_By;
        }

        $('#AttachmentLbl_Create').text(Lbl_Create);
        $('#AttachmentLbl_Modify').text(Lbl_Modify);

    }
