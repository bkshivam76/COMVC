        if (Help_Rec_ID == undefined || Help_Rec_ID == "undefined" || Help_Rec_ID == null || Help_Rec_ID == "") {
            DevExpress.ui.dialog.alert("Select A row", 'Inform');
            return;
        }
        if (Help_Attach_ActionStatus.toUpperCase() == "LOCKED") {
            DevExpress.ui.dialog.alert("Document Already Locked..", 'Inform');
            return;
        }

        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Help/Attachment/Frm_Attachment_Lock",
            data:
            {
                ID: Help_Rec_ID,
            },
            cache: false,
            success: function (data)
            {
                if (data.result == false)
                {
                    DevExpress.ui.dialog.alert(data.Message, "Error");
                }
                else
                {
                    DevExpress.ui.dialog.alert(data.Message, "Success");
                    //AttachmentListGrid.Refresh();
                    AttachmentListGrid_dx_Refresh()
                }
            }
        });
        HideLoader();
    }
