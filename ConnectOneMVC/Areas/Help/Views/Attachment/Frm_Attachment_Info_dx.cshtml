        function AttachmentListGrid_dx_OnRowPrepared(e) {
            if (e.rowType == "data") {
                var GridName = e.element[0].id;
                $(e.rowElement).addClass(GridName + "_DataRow_" + e.key)
                if (e.data.Checking_Status != null && e.data.Checking_Status == "REJECTED")
                    $(e.rowElement).css("background-color", "pink");
                if (e.data.Checking_Status != null && e.data.Checking_Status == "ACCEPTED")
                    $(e.rowElement).css("background-color", "green");
                var htmlstring = "";
                var Description = e.data.Description == null ? "" : e.data.Description;
                var Reason = e.data.Document_Rejection_Reason == null ? "" : e.data.Document_Rejection_Reason;
                if (Description.length > 0) {
                    htmlstring+="<div><span style='color: #0000FF'> <i>" + Description + "</i></span></div>";
                }
                if (Reason.length > 0) {
                    if (Description.Length > 0) {
                        htmlstring +="<br><br>";
                    }
                    htmlstring +="<div><span style='color: #FF0000'> <i>" + Reason + "</i></span></div>";
                }
                if ((Description == null || Description.length == 0) && (Reason == null || Reason.length == 0)) {
                    htmlstring = "";
                }

                var PreviewRowContent = htmlstring;//AttachmentListGrid_dx_PreviewRow_Template(e)
                var PreviewRowClass = GridName + "_PreviewRow " + GridName + "_PreviewRow_" + e.key + " DataGridPreviewRow"
                var PreviewRowOptions = "";
                var EmptyTdshtml = "";
                var emptyTd = $(e.rowElement).find('td.dx-datagrid-group-space').length
                for (var i = 0; i < emptyTd; i++) {
                    EmptyTdshtml += "<td></td>"
                }
                ($(e.rowElement).parent()).append("<tr class='" + PreviewRowClass + "' " + PreviewRowOptions + ">" + EmptyTdshtml + "<td colspan='" + (e.columns.length) + "'>" + PreviewRowContent + "</td></tr>")
