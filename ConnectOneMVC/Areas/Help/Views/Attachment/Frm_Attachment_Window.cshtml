       // }, Timeout500);
        HideLoader();       
    });
    function ParamValidations()
    {
        $("#Help_Doc_From_Date").dxDateBox({})
            .dxValidator({
                validationRules: [{
                    type: 'custom',
                    validationCallback: function (options) {
                        var result = true;
                        if ($("#Help_FromDate_Label").val() != null && $("#Help_FromDate_Label").val().length>0)
                        {
                            if ($("#Help_ParamMandatory").val() == "true" || $("#Help_ParamMandatory").val() == "True")
                            {
                                if (options.value == null)
                                {
                                    result = false;
                                }
                            }
                        }
                        return result;
                    },
                    reevaluate: true,
                    message: $("#Help_FromDate_Label").val()+" Cannot Be Blank..!!"
                }],
                validationGroup: "HelpAttachment"
            });
                $("#Help_Doc_To_Date").dxDateBox({})
            .dxValidator({
                validationRules: [{
                    type: 'custom',
                    validationCallback: function (options) {
                        var result = true;
                        if ($("#Help_ToDate_Label").val() != null && $("#Help_ToDate_Label").val().length>0)
                        {
                            if ($("#Help_ParamMandatory").val() == "true" || $("#Help_ParamMandatory").val() == "True")
                            {
                                if (options.value == null)
                                {
                                    result = false;
                                }
                            }
                        }
                        return result;
                    },
                    reevaluate: true,
                    message: $("#Help_ToDate_Label").val()+" Cannot Be Blank..!!"
                }],
                validationGroup: "HelpAttachment"
            });
        $("#Help_Document_Description").dxTextArea({})
            .dxValidator({
                validationRules: [{
                    type: 'custom',
                    validationCallback: function (options) {
                        var result = true;
                        if ($("#Help_Description_Label").val() != null && $("#Help_Description_Label").val().length > 0)
                        {
                            if ($("#Help_ParamMandatory").val() == "true" || $("#Help_ParamMandatory").val() == "True")
                            {
                                if (options.value == null)
                                {
                                    result = false;
                                }
                            }
                        }
                        return result;
                    },
                    reevaluate:true,
                    message: $("#Help_Description_Label").val()+" Cannot Be Blank..!!"
                }],
                validationGroup: "HelpAttachment"
            });
    }
    function Attachment_SetAndValidateFields()
    {
        if ($("#Help_FromDate_Label").val() != null && $("#Help_FromDate_Label").val().length > 0)
        {
            $("#Label_HelpFromDate").text($("#Help_FromDate_Label").val());
        }
        else
        {
            $("#Label_HelpFromDate").text("Applicable From:");
        }
        if ($("#Help_ToDate_Label").val() != null && $("#Help_ToDate_Label").val().length > 0)
        {
            $("#Label_HelpToDate").text($("#Help_ToDate_Label").val());
        }
        else
        {
            $("#Label_HelpToDate").text("Applicable To:");
        }
        if ($("#Help_Description_Label").val() != null && $("#Help_Description_Label").val().length > 0)
        {
            $("#Label_HelpDescription").text($("#Help_Description_Label").val());
            $("#Help_Document_Description").dxTextArea("instance").option("placeholder", "Enter " + $("#Help_Description_Label").val());
        }
        else
        {
            $("#Label_HelpDescription").text("Description:");
            $("#Help_Document_Description").dxTextArea("instance").option("placeholder", "Enter Description");
        }
        if ($("#Help_ParamMandatory").val() == "true" || $("#Help_ParamMandatory").val() == "True")
        {
            if ($("#Help_Description_Label").val() != null && $("#Help_Description_Label").val().length > 0)
            {
                $("#Label_HelpDescription").addClass("text-red");
            }
            else
            {
                $("#Label_HelpDescription").removeClass("text-red");
            }
            if ($("#Help_FromDate_Label").val() != null && $("#Help_FromDate_Label").val().length > 0)
            {
                $("#Label_HelpFromDate").addClass("text-red");
            }
            else
            {
                $("#Label_HelpFromDate").removeClass("text-red");
            }
            if ($("#Help_ToDate_Label").val() != null && $("#Help_ToDate_Label").val().length > 0)
            {
                $("#Label_HelpToDate").addClass("text-red");
            }
            else
            {
                $("#Label_HelpToDate").removeClass("text-red");
            }
        }
        else
        {
            $("#Label_HelpFromDate").removeClass("text-red");
            $("#Label_HelpToDate").removeClass("text-red");
            $("#Label_HelpDescription").removeClass("text-red");
        }
        ParamValidations();
    }
    function Attachment_SaveClick(e)
    {
        var result = e.validationGroup.validate();
        var form = $("#ID_Frm_Help_Document_Attach");
        if (result.isValid)
        {
            if ("@Model.ActionMethod" == "New" || "@Model.ActionMethod" == "Edit")
            {
                if ("@HelpSuperuser_Auditor" == "True" && "@Model.Help_Post_Area_Name" == "Help" && "@Model.Help_Post_Controller_Name" == "Attachment")
                {
                    var Checked_result = DevExpress.ui.dialog.confirm('Do you Want to Mark This Document as "Accepted"...?', "Confirm");
                    Checked_result.done(function (dialogResult)
                    {
                        if (dialogResult)
                        {
                            document.getElementById('Help_Checked').value = true;
                            Help_Attachment_Form_Submit();
                        }
                        else
                        {
                            document.getElementById('Help_Checked').value = false;
                            Help_Attachment_Form_Submit();
                        }
                    });
                }
                else
                {
                    Help_Attachment_Form_Submit();
                }
            }
            else
            {
                Help_Attachment_Form_Submit();
            }
        }
    }
    function Help_Attachment_Form_Submit()
    {
        ShowLoader("Uploading File", false);
        var formdata = new FormData($('#ID_Frm_Help_Document_Attach').get(0));
        formdata.append('Help_uploadControlName', "help_myFile");
        $.ajax({
            xhr: function ()
            {
                var xhr = new window.XMLHttpRequest();

                // Upload progress
                xhr.upload.addEventListener("progress", function (evt)
                {
                    if (evt.lengthComputable) {
                        var percentComplete = ((evt.loaded / evt.total) * 100).toFixed();
                        var message = "Uploading File: " + percentComplete + "%";
                        if (percentComplete == "100") {
                            message = "Writing Files To Disk...";
                        }
                        ChangeTextOfLoader(message);
                    }
                }, false);

                // Download progress
                //xhr.addEventListener("progress", function (evt) {
                //    if (evt.lengthComputable) {
                //        var percentComplete = ((evt.loaded / evt.total) * 100).toFixed(2);
                //        // Do something with download progress
                //        console.log(percentComplete);
                //    }
                //}, false);

                return xhr;
            },
            type: 'POST',
            url: "/Help/Attachment/Frm_Attachment_Window",
            cache: false,
            data: formdata,
            processData: false,
            contentType: false,
            success: function (data)
            {
