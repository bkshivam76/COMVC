    function Frm_Documents_Window_Help_OnSuccess(data)
    {
        HideLoader();
        dontaskpopupcloseconfirmation = true;
        PopupCloseCallFromAttachment = false;
        if (data.result == false)
        {
            DevExpress.ui.dialog.alert(data.Message, "Error");
            if ("@Model.ActionMethod" == "New")
            {
                ShowLoader();
                $.ajax({
                    type: 'GET',
                    url: "/Help/Attachment/Sessionclear_AddMore",
                    cache: false,
                    data: { ByteSessionVariable: "@Model.Help_Byte_SessionName" },
                    success: function ()
                    {
                       HideLoader();
                       $("#Help_Document_FileName").dxTextBox("instance").reset();
                       $("#help_myFile").dxFileUploader("instance").reset();

                       Help_MultipleAttachmentCount = 0;
                       Help_MultipleAttachmentSucessCount = 0;
                   }
                });
            }
        }
        else
        {
            var alert = DevExpress.ui.dialog.alert(data.Message, "Success");
            alert.done(function (alertResult)
            {
                if (alertResult)
                {
                    var GridInstance = $('#CashBookListGrid').data("dxDataGrid")
                    if (GridInstance !== void 0)
                    {
                        RefreshGridView("CashBookListGrid")
                    }
                    else if (typeof CashBookListGrid !== "undefined" && ASPxClientUtils.IsExists(CashBookListGrid) && CashBookListGrid.GetMainElement())
                    {
                        CashBookListGrid.Refresh();
                    }
                    GridInstance = $('#ITR_PostedGrid').data("dxDataGrid")
                    if (GridInstance !== void 0) {
                        RefreshGridView("ITR_PostedGrid")
                        RefreshGridView("ITR_PendingGrid")
                    }
                    else if (typeof ITR_PostedGrid !== "undefined" && ASPxClientUtils.IsExists(ITR_PostedGrid) && ITR_PostedGrid.GetMainElement())
                    {
                        ITR_PostedGrid.Refresh();
                        ITR_PendingGrid.Refresh();
                    }
                    if ("@Model.Help_CallFromHelpAttachment" == "True")
                    {
                        PopupCloseCallFromAttachment = true;
                        if ("@Model.ActionMethod" == "New")
                        {
                            var confirm = DevExpress.ui.dialog.confirm("Add More Attachment?", "Confirm");
                            confirm.done(function (Result)
                            {
                                if (Result)
                                {
                                    ShowLoader();
                                    $.ajax({
                                        type: 'GET',
                                        url: "/Help/Attachment/Sessionclear_AddMore",
                                        cache: false,
                                        data: { ByteSessionVariable:"@Model.Help_Byte_SessionName"},
                                        success: function ()
                                        {
                                            HideLoader();
                                            AttachmentWindowRecurringCount = AttachmentWindowRecurringCount + 1;
                                            $("#help_myFile").dxFileUploader("instance").reset();
                                            $("#Help_Document_FileName").dxTextBox("instance").reset();
                                            document.getElementById('ID_Frm_Help_Document_Attach').getElementsByClassName('dx-fileuploader-button')[0].click();
                                        }
                                    });


                                    //document.getElementById('ID_Frm_Help_Document_Attach').getElementsByClassName('dx-fileuploader-button')[0].click();
                                    //var DocumentCategory = $("#Help_Document_CategoryID").dxDropDownBox("instance").option("value");
                                    //var DocumentName = $("#Help_Document_NameID").dxDropDownBox("instance").option("value");
                                    //var DocumentDescription = $("#Help_Document_Description").dxTextArea("instance").option("value");
                                    //OnAttachmentNewClick(DocumentCategory[0], DocumentName[0], DocumentDescription);
                                }
                                else
                                {
                                    AttachmentWindowRecurringCount = 0;
                                    var GridInstance = $('#AttachmentListGrid_dx').data("dxDataGrid")
                                    if (GridInstance !== void 0) {
                                        AttachmentListGrid_dx_Refresh();
                                    }
                                    if (typeof AttachmentListGrid !== "undefined" && ASPxClientUtils.IsExists(AttachmentListGrid) && AttachmentListGrid.GetMainElement()) {
                                        AttachmentListGrid.Refresh();
                                    }
                                    $("#Dynamic_Content_popup").dxPopup("hide");
                                }
                            })
                        }
                    }
                    else
                    {
                        var GridInstance = $('#AttachmentListGrid_dx').data("dxDataGrid")
                        if (GridInstance !== void 0) {
                            AttachmentListGrid_dx_Refresh();
                        }
                        if (typeof AttachmentListGrid !== "undefined" && ASPxClientUtils.IsExists(AttachmentListGrid) && AttachmentListGrid.GetMainElement())
                        {
                            AttachmentListGrid.Refresh();
                        }
                        $("#Dynamic_Content_popup").dxPopup("hide");
                    }
                }
            });
            if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false)
            {
                CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
    }
