            sessionclearpath = "/Help/Attachment/Sessionclear?ByteSessionVariable="+"@Model.Help_Byte_SessionName";
            dontaskpopupcloseconfirmation = false;
            PopupCloseCallFromAttachment = true;
        }
        if ("@Model.Help_CallFromHelpAttachment" == "True" && "@Model.ActionMethod" == "New")
        {
           $("#help_myFile").dxFileUploader("instance").option("multiple", true);
            //$("#help_myFile").dxFileUploader("instance").option("showFileList", true);
        }
        if ("@Model.ActionMethod" == "Edit")
        {
            //$("#Help_Document_NameID").dxDropDownBox("instance").option("readOnly", true); //redmine Bug #133089 fixed
            //$("#Help_Document_CategoryID").dxDropDownBox("instance").option("readOnly", true);
        }
        if ("@Model.Help_Document_NameID".length == 0)
        {
            Attachment_SetAndValidateFields();
        }
        @*if ("@Model.Help_Document_CategoryID".length > 0)
        {
            var value_Help_Document_CategoryID = "@Model.Help_Document_CategoryID";
