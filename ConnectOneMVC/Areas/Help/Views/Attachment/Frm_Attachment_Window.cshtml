            {
                value_Help_Document_CategoryID = value_Help_Document_CategoryID.replace("&amp;", "&");
            }
            await Help_Document_Category_DG.selectRows(value_Help_Document_CategoryID, false);
          }*@
        if ("@Model.Help_Document_NameID".length > 0)
        {
           await OnDocument_NameChanged(null, true);
            @*await Help_Document_Name_DG.selectRows("@Model.Help_Document_NameID", false);*@
