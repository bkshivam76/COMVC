<script>
    var Help_uploadErrorDuetoFilesize = false;
    var Help_uploadErrorDuetoDots = false;
    var Help_uploadErrorDuetoFileCount = false;
    var Help_uploadErrorDuetoHtml = false;
    var Help_uploadErrorDuetoFilename = false;
    var Help_MultipleAttachmentCount = 0;
    var Help_MultipleAttachmentSucessCount = 0;
    function UploadStarted(e)
    {
        ShowLoader();
        if (Help_uploadErrorDuetoFileCount == true)
        {
            e.request.abort();
        }
        else if ((e.file.type).includes("html"))
        {
            Help_uploadErrorDuetoHtml = true;
            e.request.abort();
        }
        //else if (e.file.size > 20971520) //pritam:remove file size validation
        //{
        //    Help_uploadErrorDuetoFilesize = true;
        //    e.request.abort();          
        //}  
        //else if (Help_FileName.split('.').length > 2)
        //{
        //    Help_uploadErrorDuetoDots = true;
        //    e.request.abort();      
        //}    
        //else if (Help_FileName.length > 0)
        //{
        //    var regEX = /^([a-zA-Z0-9 _.]+)$/;
        //    if (regEX.test(Help_FileName) == false)
        //    {
        //        Help_uploadErrorDuetoFilename = true;
        //        e.request.abort();        
        //    }
        //}        
    }
    function UploadedSuccess(e)
    {
        Help_MultipleAttachmentSucessCount++;
        if (Help_MultipleAttachmentSucessCount == Help_MultipleAttachmentCount)
        {
            HideLoader();
        }
    }
    function Help_Attach_UploadError(e)
    {
        HideLoader();
        console.log(e.error);
        console.log(e.event);
        console.log(e.file);
        var message = "";
       if (Help_uploadErrorDuetoHtml == true)
       {
            Help_uploadErrorDuetoHtml = false;
           message = "<b>Html files are not allowed</b><br>";
       }
        else if (Help_uploadErrorDuetoFilesize == true)
        {
            Help_uploadErrorDuetoFilesize = false;
            message = "<b>Max File Size Allowed is 20MB</b><br>";
        }
        else if (Help_uploadErrorDuetoFilename == true)
        {
            Help_uploadErrorDuetoFilename = false;
            message = "<b>Only alphaNumeric . _ is allowed in File Name</b><br>";
        }
        else if (Help_uploadErrorDuetoDots == true)
        {
            Help_uploadErrorDuetoDots = false;
            message = "<b>File Name Must Not Contain More Than One Dot</b><br>";
        }
        if (e.error.statusText.length > 0)
        {
            message = message + e.error.status + ": " + e.error.statusText + "<br>";
        }
        if (Help_uploadErrorDuetoFileCount == false)
        {
            DevExpress.ui.dialog.alert(message + e.file.name + "<br>Did Not Upload<br>Kindly Check The File", 'Upload Error..');
        }       
        if ("@Model.ActionMethod" == "New")
        {
            if (Help_MultipleAttachmentCount > 0) 
            {
                ShowLoader();              
                $("#Help_Document_FileName").dxTextBox("instance").reset();
                $("#help_myFile").dxFileUploader("instance").reset();
                Help_MultipleAttachmentCount = 0;
                Help_MultipleAttachmentSucessCount = 0;
                $.ajax({
                    type: 'GET',
                    url: "/Help/Attachment/Sessionclear_AddMore",
                    cache: false,
                    data: { ByteSessionVariable: "@Model.Help_Byte_SessionName" },
                    success: function ()
                    {
                        HideLoader();  
                    }
                });
            }
        }
        else
        {
            $("#Help_Document_FileName").dxTextBox("instance").reset();
            $("#help_myFile").dxFileUploader("instance").reset();         
            Help_MultipleAttachmentCount = 0;
            Help_MultipleAttachmentSucessCount = 0;
        } 
    }

    function fileUploader_valueChanged(e)
    {
        Help_MultipleAttachmentCount = 0;        
        var files = e.value;
        var filename = "";        
        Help_MultipleAttachmentCount = files.length;
        if (Help_MultipleAttachmentCount > 25)
        {
            Help_uploadErrorDuetoFileCount = true;
            DevExpress.ui.dialog.alert("You Have Selected " + Help_MultipleAttachmentCount+ " Files To Upload<br><b>More Than 25 Files Cannot Be Uploaded At Once<b>", 'Upload Error..');   
            $("#Help_Document_FileName").dxTextBox("instance").reset();
            $("#help_myFile").dxFileUploader("instance").reset();
            Help_MultipleAttachmentCount = 0;
            Help_MultipleAttachmentSucessCount = 0;
            return;
        }
        if (Help_MultipleAttachmentCount > 0 && Help_MultipleAttachmentCount < 26)
        {
            var NotAllowedFilePresent = false;
            Help_uploadErrorDuetoFileCount = false;
            var totalContent = 0;           
            for (var i = 0; i < Help_MultipleAttachmentCount; i++)
            {
                var ErrMsg = PreventFileUpload(files[i])
                if (ErrMsg != null && ErrMsg.length > 0)
                {
                    NotAllowedFilePresent = true;
                    DevExpress.ui.dialog.alert(ErrMsg, 'Upload Error..');
                    break;
                }       
                else
                {
                    if (i == 0)
                    {
                        filename = files[i].name;
                    }
                    else
                    {
                        filename = filename + "/" + files[i].name;
                    }
                    totalContent = totalContent + files[i].size;
                }
            }
            if (NotAllowedFilePresent == true)
            {
                $("#Help_Document_FileName").dxTextBox("instance").reset();
                $("#help_myFile").dxFileUploader("instance").reset();
                Help_MultipleAttachmentCount = 0;
                Help_MultipleAttachmentSucessCount = 0;
                return;
            }    
            if (totalContent < 524288000)
            {
                Help_FileName = filename;
                $("#Help_Document_FileName").dxTextBox("instance").option("value", filename);           
            }
            else
            {
                DevExpress.ui.dialog.alert("You Have Selected <b>" + formatBytes(totalContent) + "</b> To Upload<br><b>Upto 500 MB Can Be Uploaded At Once<b>", 'Upload Error..');
                $("#Help_Document_FileName").dxTextBox("instance").reset();
                $("#help_myFile").dxFileUploader("instance").reset();
                Help_MultipleAttachmentCount = 0;
                Help_MultipleAttachmentSucessCount = 0;
            }          
        }      
    }
    function OnFilenameChange(e)
    {  
        var textbox = $("#Help_Document_FileName").dxTextBox("instance");
        Help_FileName = textbox.option("value");
    }
    function OnFilenameInit(e)
    {
        var textbox = $("#Help_Document_FileName").dxTextBox("instance");
        Help_FileName = textbox.option("value");
    }
</script>@*File upload Fn*@
