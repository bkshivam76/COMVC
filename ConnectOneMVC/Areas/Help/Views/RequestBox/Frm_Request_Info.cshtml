function RequestAjaxSuccessForm(data) {
        HideLoader();
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.Message, "Error");
            //$("#popup_frm_Bank_Window").dxPopup("hide");
            Request_InfoListGrid.Refresh();
        }
        else {
            IsRequest_InfoSucessPopup = true;
            var RequestSubmitSuccess = DevExpress.ui.dialog.alert(data.Message, "Request Box");
            $("#popup_frm_RequestBox_Window").dxPopup("hide");
            Request_InfoListGrid.Refresh();
            IsRequest_InfoSucessPopup = false;
            RequestSubmitSuccess.done(function (alertResult) {
                if (alertResult) {
                    if (IsRequestNewPopup == true) {
                        var addmorerequestresult = DevExpress.ui.dialog.confirm("Add More Entry...?", "Request Box");
                            addmorerequestresult.done(function (dialogResult) {
                            if (dialogResult) {
                                OnNewClick();
                            }
                        });
                    }
                }
            });
        }
    }
</script>

    <script>
    var RequestInfo_IsDetailRowExpanded = false;
    var RequestInfo_NestedRecord_FocusedRowIndex = -1;
    var RequestInfo_NestedGrid_AccessID;
    var RequestInfo_AtachmentID;
    var RequestInfo_FileName;
    var RequestInfo_ParamMandatory;
    var RequestInfo_FromDateLabel;
    var RequestInfo_ToDateLabel;
    var RequestInfo_DescriptionLabel;
    var RequestInfo_Doc_ID;
    var RequestInfo_Doc_Category;
    var RequestInfo_MasterRowRecID;
    var RequestInfo_MasterRowMID;
    var RequestInfo_NestedRowMapID;
    var RequestInfo_reason;
    var RequestInfo_Attachment_RecStatus;
    var RequestInfo_Nested_Doc_Status;

    function On_RequestFacility_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@Help_Attachment_AddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (RequestInfo_ParamMandatory == 1)
            {
                AddAttachment(RequestInfo_MasterRowRecID, "Help_Request", RequestInfo_Doc_ID, RequestInfo_Doc_Category, RequestInfo_ParamMandatory, RequestInfo_FromDateLabel, RequestInfo_ToDateLabel, RequestInfo_DescriptionLabel, "RequestFacilityAttachment", null, "Request_InfoListGrid", RequestInfo_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(RequestInfo_MasterRowRecID, "Help_Request", RequestInfo_Doc_ID, "RequestFacilityAttachment", "Request_InfoListGrid", RequestInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (RequestInfo_Nested_Doc_Status == "NO" || RequestInfo_Nested_Doc_Status == "") {
                DevExpress.ui.dialog.alert("Please Attach document First", "Error");
                return;
            }
            if (RequestInfo_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(RequestInfo_MasterRowRecID, "Help_Request", RequestInfo_AtachmentID, RequestInfo_ParamMandatory, RequestInfo_FromDateLabel, RequestInfo_ToDateLabel, RequestInfo_DescriptionLabel, "RequestFacilityAttachment", null, "Request_InfoListGrid", RequestInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (RequestInfo_Nested_Doc_Status == "NO" || RequestInfo_Nested_Doc_Status == "") {
                DevExpress.ui.dialog.alert("Please Attach document First", "Error");
                return;
            }
            DeleteAttachment(RequestInfo_MasterRowRecID, "Help_Request", RequestInfo_AtachmentID, RequestInfo_ParamMandatory, RequestInfo_FromDateLabel, RequestInfo_ToDateLabel, RequestInfo_DescriptionLabel, null, "Request_InfoListGrid", RequestInfo_NestedGrid_AccessID, RequestInfo_Attachment_RecStatus);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@Help_Attachment_ViewRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (RequestInfo_Nested_Doc_Status == "NO" || RequestInfo_Nested_Doc_Status == "") {
                DevExpress.ui.dialog.alert("Please Attach document First", "Error");
                return;
            }

            ViewDocument(RequestInfo_AtachmentID, RequestInfo_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(RequestInfo_MasterRowRecID, "Help_Request", "Request Box", "Request_InfoListGrid", RequestInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Add_Reason")
        {
            if (RequestInfo_Doc_Category.toLowerCase() == "others") {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else {
                AttachmentAddReason(RequestInfo_MasterRowRecID, RequestInfo_NestedRowMapID, "Help_Request", "Request_InfoListGrid", RequestInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(RequestInfo_MasterRowRecID, RequestInfo_NestedRowMapID, "Help_Request", "Request_InfoListGrid", RequestInfo_NestedGrid_AccessID, RequestInfo_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(RequestInfo_MasterRowRecID, RequestInfo_NestedRowMapID, "Request_InfoListGrid", RequestInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
    }
    function OnRequestListGridNestedFocusedRowChange(s, e)
    {
        if (RequestInfo_IsDetailRowExpanded)
        {
            RequestInfo_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
            if (RequestInfo_NestedRecord_FocusedRowIndex >= 0)
            {
                ShowLoader();
                Request_FAB.SetVisible(true);
                RequestInfo_NestedGrid_AccessID = s.uniqueID;
                s.GetRowValues(s.GetFocusedRowIndex(), 'Doc_Status;Params_Mandatory;LABEL_FROM_DATE;LABEL_TO_DATE;LABEL_DESCRIPTION;Document_Category;Document_ID;ATTACH_ID;TxnID;TxnMID;MAP_ID;Reason;ATTACH_FILE_NAME;Attachment_Action_Status;UniqueID', OnRequestInfo_GetGridRowValues);
            }
            else
            {
                Request_FAB.SetVisible(false);
            }
        }
    }
    function OnRequestInfo_GetGridRowValues(values)
    {
        HideLoader();
        if (values[14] != null)
        {
            Request_FAB.SetVisible(true);
            RequestInfo_Nested_Doc_Status = values[0];
            Request_FAB.SetActionContext("actionItemContext", true);
            RequestInfo_ParamMandatory = values[1];
            RequestInfo_FromDateLabel = values[2];
            RequestInfo_ToDateLabel = values[3];
            RequestInfo_DescriptionLabel = values[4];
            RequestInfo_Doc_Category = values[5];
            RequestInfo_Doc_ID = values[6];
            RequestInfo_AtachmentID = values[7];
            RequestInfo_MasterRowRecID = values[8];
            RequestInfo_MasterRowMID = values[9];
            RequestInfo_NestedRowMapID = values[10];
            RequestInfo_reason = values[11];
            RequestInfo_FileName = values[12];
            RequestInfo_Attachment_RecStatus = values[13];
            if (RequestB_IsVouchingMode == true)
            {
                if (RequestInfo_FileName != null && RequestInfo_FileName.length > 0)
                {
                    ViewDocument(RequestInfo_AtachmentID, RequestInfo_FileName, "Request_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else
                {
                    var pane = Mainspliter.GetPaneByName('RightPane');
                    pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
                    document.getElementById('RightPane_div_Iframe').style.display = "none";
                    document.getElementById('RightPane_div_Img').style.display = "none";
                }
            }
        }
    }
    function RequestGrid_Nested_BeginCallBack(s, e)
    {
        e.customArgs["ShowHorizontalBar"] = RequestInfo_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = RequestB_IsVouchingMode;
        e.customArgs["command"] = e.command;
    }
    function Request_InfoGrid_DetailRowExpanding(s, e)
    {
        RequestInfo_IsDetailRowExpanded = true;
        s.SetFocusedRowIndex(e.visibleIndex);
        var pane = Mainspliter.GetPaneByName('RightPane');
        if (RequestB_IsVouchingMode == true)
        {
            pane.Expand();
        }
        else
        {
            pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
        }
    }
    function Request_InfoGrid_DetailRowCollapsing(s, e)
    {
        RequestInfo_IsDetailRowExpanded = false;
        s.SetFocusedRowIndex(e.visibleIndex);
        if (RequestB_IsVouchingMode == true)
        {
            if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false)
            {
                CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
        else
        {
            Request_FAB.SetVisible(false);
        }
    }
    </script>
    @*attachment and nested grid*@
</div>

