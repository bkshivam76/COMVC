<div class="Scheduler_Export_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    @using DevExpress.XtraReports.UI;
    <div>
        @(Html.DevExtreme().Button()
                    .ID("Scheduler_ExportGridDatapdf")
                    .Text("Export to PDF")
                    //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                    //.AccessKey("x")
                    .OnClick("ExportPDF")
                    .Visible(true)
                    .Width(120)
        )<br />

        @(Html.DevExtreme().Button()
                    .ID("Scheduler_ExportGridDataxls")
                    .Text("Export to XLS")
                    //.Icon("fa-file-excel-o")
                    //.AccessKey("X")
                    .OnClick("ExportXLS")
                    .Visible(true)
                    .Width(120)
        )<br />
        @(Html.DevExtreme().Button()
                    .ID("Scheduler_ExportGridDataxlsx")
                    .Text("Export to XLSX")
                    //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                    //.AccessKey("L")
                    .OnClick("ExportXLSX")
                    .Visible(true)
                    .Width(120)
        )<br />

        @(Html.DevExtreme().Button()
                    .ID("Scheduler_ExportGridDatadocx")
                    .Text("Export to DOCX")
                    //.Icon("export_exporttodocx_16x16office2013")
                    //.AccessKey("D")
                    .OnClick("ExportDOCX")
                    .Visible(true)
                    .Width(120)
        )<br />

        @(Html.DevExtreme().Button()
                    .ID("Scheduler_ExportGridDatartf")
                    .Text("Export to RTF")
                    //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                    //.AccessKey("R")
                    .OnClick("ExportRTF")
                    .Visible(true)
                    .Width(120)
        )<br />

        @(Html.DevExtreme().Button()
                    .ID("Scheduler_ExportGridDatacsv")
                    .Text("Export to CSV")
                    //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                    //.AccessKey("C")
                    .OnClick("ExportCSV")
                    .Visible(true)
                    .Width(120)
        )
    </div>
    <script>
        function ExportPDF() {
            SchedulerListGrid.ExportTo(ASPxClientGridViewExportFormat.Pdf);
            $("#Scheduler_modal").dxPopup("hide");
        }
        function ExportXLS() {
            SchedulerListGrid.ExportTo(ASPxClientGridViewExportFormat.Xls);
            $("#Scheduler_modal").dxPopup("hide");
        }
        function ExportXLSX() {
            SchedulerListGrid.ExportTo(ASPxClientGridViewExportFormat.Xlsx);
            $("#Scheduler_modal").dxPopup("hide");
        }
        function ExportCSV() {
            SchedulerListGrid.ExportTo(ASPxClientGridViewExportFormat.Csv);
            $("#Scheduler_modal").dxPopup("hide");
        }
        function ExportDOCX() {
            SchedulerListGrid.ExportTo(ASPxClientGridViewExportFormat.Docx);
            $("#Scheduler_modal").dxPopup("hide");
        }
        function ExportRTF() {
            SchedulerListGrid.ExportTo(ASPxClientGridViewExportFormat.Rtf);
            $("#Scheduler_modal").dxPopup("hide");
        }
    </script>
