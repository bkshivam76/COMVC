@using System.Text.RegularExpressions;
@{
    int ShowHorizontalBar = ViewBag.SchedulerInfo_ShowHorizontalBar == null ? 0 : (int)ViewBag.SchedulerInfo_ShowHorizontalBar;
    string REC_ID = ViewBag.SchedulerInfo_REC_ID == null ? "" : (string)ViewBag.SchedulerInfo_REC_ID;
    var SessionGUID = Request.QueryString["SessionGUID"];
}
@Html.DevExpress().GridView(settings =>
{
    settings.Name = "SchedulerListGrid" + REC_ID;
    settings.SettingsDetail.MasterGridName = "SchedulerListGrid";
    settings.CallbackRouteValues = new { Controller = "Scheduler", Action = "Frm_Scheduler_Info_DetailGrid", REC_ID = REC_ID, SessionGUID = SessionGUID };
    settings.EnableTheming = true;
    settings.Theme = "Aqua";
    settings.HtmlRowPrepared = (s, e) =>
    {
        MVCxGridView grid = (MVCxGridView)s;
        if (e.RowType == GridViewRowType.Data)
        {
            if (e.VisibleIndex % 2 == 0)
            {
                e.Row.BackColor = System.Drawing.Color.Linen;
            }
            else
            {
                e.Row.BackColor = System.Drawing.Color.AliceBlue;
            }
        }
        if (e.RowType == GridViewRowType.Preview)
        {
            e.Row.BackColor = System.Drawing.Color.LightGray;
        }

    };
    settings.Styles.FocusedRow.BackColor = System.Drawing.Color.FromArgb(0, 114, 198);
    settings.Styles.FocusedRow.ForeColor = System.Drawing.Color.White;
    settings.HtmlRowCreated = (s, e) =>
    {
        MVCxGridView grid = (MVCxGridView)s;
        if (e.RowType == GridViewRowType.Preview)
        {
            e.Row.BackColor = System.Drawing.Color.LightGray;
        }
    };
    settings.Init = (s, e) =>
    {
        MVCxGridView grid = (MVCxGridView)s;
        grid.FocusedRowIndex = -1;
    };


    settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);

    if (ShowHorizontalBar == 1)
    {
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Visible;
        settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.Off;
        settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.Control;
        settings.SettingsResizing.Visualization = ResizingMode.Postponed;
    }
    else
    {
        settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.HideDataCells;
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Hidden;
        settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.Disabled;
        settings.SettingsAdaptivity.AllowHideDataCellsByColumnMinWidth = true;
    }

    #region Code to Display Columns in a Grid with visibility mode(true/false)
    settings.KeyFieldName = "Job ID";
    settings.Columns.Add(column =>
    {
        column.GroupIndex = 0;
        column.FieldName = "Job Type";
        column.Caption = "Job Type";
        column.Visible = true;
        column.MinWidth = 150;
        column.ExportWidth = 80;
        //column.SortAscending();
    });
    settings.Columns.Add(column =>
    {
        column.FieldName = "Job Name";//Remember these are the column name provided from DB SP method.
        column.Caption = "Job Name";
        column.Visible = true;
        column.MinWidth = 130;
        column.ExportWidth = 100;
        //column.SortAscending();
    });
    settings.Columns.Add(column =>
    {
        column.FieldName = "Start Date";
        column.Caption = "Start Date";
        column.Visible = true;
        column.MinWidth = 130;
        column.ExportWidth = 120;
        //column.SortAscending();
    });
    settings.Columns.Add(column =>
    {
        column.FieldName = "End Date";
        column.Caption = "End Date";
        column.Visible = true;
        column.MinWidth = 130;
        column.ExportWidth = 120;
        //column.SortAscending();
    });
    settings.Columns.Add(column =>
    {
        column.FieldName = "Job ID";
        column.Caption = "Job ID";
        column.Visible = true;
        column.MinWidth = 130;
        column.ExportWidth = 120;
        //column.SortAscending();
    });
    settings.Columns.Add(column =>
    {
        column.FieldName = "Is Active";
        column.Caption = "Is Active";
        column.Visible = true;
        column.MinWidth = 130;
        column.ExportWidth = 120;
        //column.SortAscending();
    });

    settings.Columns.Add(column =>
    {
        column.FieldName = "REC_ADD_ON";
        column.Caption = "REC_ADD_ON";
        column.Visible = false;
        column.MinWidth = 130;
        column.ExportWidth = 120;
        //column.SortAscending();
    });
    settings.Columns.Add(column =>
    {
        column.FieldName = "REC_ADD_BY";
        column.Caption = "REC_ADD_BY";
        column.Visible = false;
        column.MinWidth = 130;
        column.ExportWidth = 120;
        //column.SortAscending();
    });
    settings.Columns.Add(column =>
    {
        column.FieldName = "REC_ID";
        column.Caption = "ID";
        column.Visible = false;
        column.MinWidth = 130;
        column.ExportWidth = 120;
        //column.SortAscending();
    });
    settings.Columns.Add(column =>
    {
        column.FieldName = "REC_EDIT_ON";
        column.Caption = "REC_EDIT_ON";
        column.Visible = false;
        column.MinWidth = 130;
        column.ExportWidth = 120;
        //column.SortAscending();
    });
    settings.Columns.Add(column =>
    {
        column.FieldName = "REC_EDIT_BY";
        column.Caption = "REC_EDIT_BY";
        column.Visible = false;
        column.MinWidth = 130;
        column.ExportWidth = 120;
        //column.SortAscending();
    });
    settings.Columns.Add(column =>
    {
        column.FieldName = "NOTIFICATION_RECIPIENTS";
        column.Caption = "NOTIFICATION_RECIPIENTS";
        column.Visible = false;
        column.MinWidth = 130;
        column.ExportWidth = 120;
        //column.SortAscending();
    });

    #endregion
    settings.ClientSideEvents.FocusedRowChanged = "OnSchedulerListGridNestedFocusedRowChange";
    settings.ClientSideEvents.BeginCallback = "SchedulerGrid_Nested_BeginCallBack";


    settings.Settings.ShowGroupPanel = false;
    settings.Settings.ShowGroupFooter = GridViewGroupFooterMode.Hidden;
    settings.SettingsBehavior.AutoExpandAllGroups = true;
    settings.Styles.GroupRow.ForeColor = System.Drawing.Color.Navy;
    settings.SettingsContextMenu.Enabled = true;
    settings.SettingsContextMenu.EnableGroupFooterMenu = DefaultBoolean.False;
    settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
    settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
    settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;
    settings.Settings.ShowHeaderFilterButton = true;
    settings.KeyboardSupport = true;
    //settings.AccessKey = "G";
    settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
    settings.SettingsBehavior.ProcessColumnMoveOnClient = true;
    settings.SettingsBehavior.ColumnMoveMode = GridColumnMoveMode.AmongSiblings;
    settings.Settings.UseFixedTableLayout = true;
    settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
    settings.SettingsBehavior.AllowSort = true;
    settings.SettingsBehavior.AllowSelectByRowClick = true;
    settings.SettingsBehavior.EnableCustomizationWindow = true;
    settings.SettingsPager.Mode = GridViewPagerMode.ShowAllRecords;
    settings.SettingsSearchPanel.ShowApplyButton = true;
    settings.SettingsSearchPanel.ShowClearButton = true;
    settings.SettingsBehavior.AllowFocusedRow = true;
    // show filter control
    settings.Settings.ShowFilterBar = GridViewStatusBarMode.Visible;
    settings.Settings.ShowFilterRow = false;
    settings.Settings.AutoFilterCondition = AutoFilterCondition.Contains;
    settings.SettingsFilterControl.ViewMode = true ? FilterControlViewMode.VisualAndText : FilterControlViewMode.Visual;
    settings.SettingsFilterControl.AllowHierarchicalColumns = true;// AllowHierarchicalColumns;
    settings.SettingsFilterControl.ShowAllDataSourceColumns = true;//FilterBuilderDemoHelper.Options.ShowAllDataSourceColumns;
    settings.SettingsFilterControl.MaxHierarchyDepth = 1;

    settings.Settings.ShowFooter = false;
    settings.SettingsCustomizationDialog.ShowSortingPage = true;
    settings.SettingsCustomizationDialog.ShowGroupingPage = true;
    settings.SettingsCustomizationDialog.ShowFilteringPage = true;
    settings.SettingsCustomizationDialog.ShowColumnChooserPage = true;


    MyExtensions.GridViewHelper.CustomGridView(settings);


}).Bind(Model).GetHtml()







