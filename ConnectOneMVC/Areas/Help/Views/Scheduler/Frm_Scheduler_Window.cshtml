    <style>
        .scModal .modal-dialog {
            width: 100%;
            max-width: 840px;
            padding-top: 40%
        }

        .scModal .row > div {
            margin-bottom: 15px
        }

        .scModal .row .row > div {
            margin-bottom: 0
        }

        .scModal label small {
            font-size: 11px;
            color: rgba(256,256,256,.6)
        }

        .r-week .col-md-2 {
            margin-right: 8px !important
        }

        .r-week .dx-checkbox {
            margin-right: 5px !important
        }

        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        input[type="file"].form-control {
            padding: 3px;
            font-size: 11px;
            max-width: 300px;
        }

        input[type=number] {
            -moz-appearance: textfield;
        }

        input[type=checkbox], input[type=radio] {
            position: relative;
            top: 2px;
        }

        .groupHd {
            background: #182f85;
            color: #fff;
            padding: 10px 15px 5px;
            margin-left: -15px;
            width: calc(100% + 30px);
            margin-bottom: 18px;
        }

        .scModal .long-row > div {
            margin-bottom: 10px
        }

        .scModal .dx-show-clear-button .dx-texteditor-input {
            padding-right: 2px
        }
        .dx-placeholder:before {
            padding: 2px 5px 2px 2px;
        }
        @@media (min-width:768px) {
            .pl-0 {
                padding-left: 0
            }

            .pt-1 {
                padding-top: 5px
            }

            .pr-0 {
                padding-right: 0
            }

            .pr-2 {
                padding-right: 10px
            }

            .mb-2 {
                margin-bottom: 10px !important
            }
        }

        @@media (max-width:768px) {
            .scModal .modal-dialog {
                padding-top: 1200px
            }
        }
    </style>


    <div id="SchedulerWindow_DIV">
        @using (Ajax.BeginForm("Frm_Scheduler_Window", "Help",//

            new AjaxOptions 
            {
                HttpMethod = "POST",
                UpdateTargetId = "SchedulerWindow",
                InsertionMode = InsertionMode.InsertAfter,
                OnBegin = "AjaxBeginFormPost",//It has all Settings for API call
            OnSuccess = "Frm_Scheduler_Window_AjaxSuccessForm"//Function to receive on Success response from Controller method 'Frm_Scheduler_Window' with HttpPost methos JSON response
        },
            new
            {
                id = "SchedulerForm",
                @class = "edit_form form-horizontal SchedulerForm"
            }))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(x => x.PopupName_Scheduler)
            @Html.HiddenFor(x => x.ActionMethod)
            @Html.HiddenFor(x => x.Tag)
            @Html.HiddenFor(x => x.Info_LastEditedOn)
            @Html.HiddenFor(x => x.TitleX_Scheduler)
            @Html.HiddenFor(x => x.Prev_Name_SchedulerWindow)
            @Html.HiddenFor(x => x.Scheduler_ID)
            using (Html.DevExtreme().ValidationGroup("SchedulerValidator"))
            {
                {
                    <div class="container-fluid">
                        <div class="full-width-header-bg2">
                            <div class="row">
                                <div class="col-sm-8">
                                    <h3 class="popuphead"><i class="far fa-edit"></i> Scheduler</h3>
                                </div>
                                <div class="col-sm-4 prm">
                                    <h5 class="mand-txt-align">
                                        <i class="fas fa-info-circle"></i> Red Fields are mandatory
                                    </h5>
                                </div>
                                @Html.ValidationSummary(true, "", new { @class = "text-red" })
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-3">
                                <div class="form-field">
                                    @Html.Label("Name", htmlAttributes: new { @class = "control-label text-red" })
                                    @(Html.DevExtreme().TextBox().CustomTextBox(true).ID("Name_SchedulerWindow")
                                        .Name("Name_SchedulerWindow").Value(Model.Name_SchedulerWindow)
                                        .Placeholder("Enter Name...").MaxLength(59))
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-field">
                                    @Html.Label("Schedule Type", htmlAttributes: new { @class = "control-label text-red" })
                                    @(Html.DevExtreme().SelectBox().ID("ScheduleType_SchedulerWindow")
                                        .Name("ScheduleType_SchedulerWindow").DataSource(new string[] { "ONCE", "RECURRING" })
                                        .OnValueChanged("ScheduleType_SchedulerWindow_valueChanged")
                                        .Value(Model.ScheduleType_SchedulerWindow).Placeholder("Choose Schedule Type")
                                        .ShowClearButton(false))
                                </div>
                            </div>
                            <div class="col-md-3" style="display:none" id="Universal_SchedulerWindow_Div">
                                <div class="form-field" style="padding:15px 6px 14px">
                                    @(Html.DevExtreme().CheckBox().ID("Universal_SchedulerWindow").Name("Universal_SchedulerWindow")
                                        .Value(Model.Universal_SchedulerWindow).Text("Is it a Universal Schedule ?"))
                                </div>
                            </div>
                            <div id="OneTimeOccuringSchedule_Div" style="display:block;">
                                <div class="col-md-3">
                                    <div class="form-field">
                                        @Html.Label("Time", htmlAttributes: new { @class = "control-label text-red" })
                                        @(Html.DevExtreme().DateBox().CustomDateBox().Type(DateBoxType.Time).ID("Time_SchedulerWindow").DisplayFormat("hh:mm a").ShowClearButton(false)
                                            .Name("Time_SchedulerWindow").Value(Model.Time_SchedulerWindow).Placeholder("hh:mm AM/PM").Min(DateTime.MinValue))
                                    </div>
                                </div>
                            </div>

                            <div id="RecurringSchedule_Div" style="display:none;">
                                <div class="col-md-3">
                                    <div class="form-field">
                                        @Html.Label("Frequency", htmlAttributes: new { @class = "control-label text-red" })
                                        @(Html.DevExtreme().SelectBox().ID("FrequencyType_SchedulerWindow")
                                            .Name("FrequencyType_SchedulerWindow").DataSource(new string[] { "DAILY", "WEEKLY", "MONTHLY" }).
                                            OnValueChanged("FrequencyType_SchedulerWindow_valueChanged")
                                            .Value(Model.FrequencyType_SchedulerWindow).Placeholder("Choose Frequency Type")
                                            .ShowClearButton(false))
                                    </div>
                                </div>

                                <div class="col-md-12" id="FrequencyDaily_Div" style="display:none;">
                                    <div class="form-field">
                                        <b>Frequency- Daily</b>
                                    </div>
                                    <div class="form-field">
                                        @Html.Label("Daily Recurrence Every", htmlAttributes: new { @class = "control-label text-red" })
                                        <div class="row">
                                            <div class="col-md-6 form-field pr-2">
                                                @(Html.DevExtreme().NumberBox().CustomNumberBox().Format("#").ID("DailyRecurrenceEvery_SchedulerWindow")
                                                    .Name("DailyRecurrenceEvery_SchedulerWindow").
                                                    Value(Model.DailyRecurrenceEvery_SchedulerWindow).Min(1).Max(10000).ShowSpinButtons(true))
                                            </div>
                                            <div class="col-md-4 pll" >day(s)</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-12" id="FrequencyWeekly_Div" style="display:none;">
                                    <div class="form-field">
                                        <b>Frequency- Weekly</b>
                                    </div>
                                    <div class="form-field">
                                        @Html.Label("Weekly Recurrence Every", htmlAttributes: new { @class = "control-label text-red" })
                                        <div class="row r-week">
                                            <div class="col-md-3 pr-2">
                                                @(Html.DevExtreme().NumberBox().CustomNumberBox().Format("#").ID("WeeklyRecurrenceEvery_SchedulerWindow").Name("WeeklyRecurrenceEvery_SchedulerWindow")
                                                    .Value(Model.WeeklyRecurrenceEvery_SchedulerWindow).Min(1).Max(10000).ShowSpinButtons(true))
                                            </div>
                                            <div class="col-md-8 pl-0 pt-1" style="margin-left:20px">
                                                @(Html.DevExtreme().CheckBox().ID("Monday_SchedulerWindow").Name("Monday_SchedulerWindow")
                                                    .Value(Model.Monday_SchedulerWindow).Text("Monday"))
                                                @(Html.DevExtreme().CheckBox().ID("Tuesday_SchedulerWindow").Name("Tuesday_SchedulerWindow")
                                                    .Value(Model.Tuesday_SchedulerWindow).Text("Tuesday"))
                                                @(Html.DevExtreme().CheckBox().ID("Wednesday_SchedulerWindow").Name("Wednesday_SchedulerWindow")
                                                    .Value(Model.Wednesday_SchedulerWindow).Text("Wednesday"))
                                                @(Html.DevExtreme().CheckBox().ID("Thursday_SchedulerWindow").Name("Thursday_SchedulerWindow")
                                                    .Value(Model.Thursday_SchedulerWindow).Text("Thursday"))
                                                @(Html.DevExtreme().CheckBox().ID("Friday_SchedulerWindow").Name("Friday_SchedulerWindow")
                                                    .Value(Model.Friday_SchedulerWindow).Text("Friday"))
                                                @(Html.DevExtreme().CheckBox().ID("Saturday_SchedulerWindow").Name("Saturday_SchedulerWindow")
                                                    .Value(Model.Saturday_SchedulerWindow).Text("Saturday"))
                                                @(Html.DevExtreme().CheckBox().ID("Sunday_SchedulerWindow").Name("Sunday_SchedulerWindow")
                                                    .Value(Model.Sunday_SchedulerWindow).Text("Sunday"))
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-12" id="FrequencyMonthly_Div" style="display:none;">
                                    <div class="form-field">
                                        <b>Frequency- Monthly</b>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="form-field">
                                            @Html.Label("Monthly Frequency Type", htmlAttributes: new { @class = "control-label text-red" })
                                            @(Html.DevExtreme().SelectBox().ID("MonthlyFrequencyType_SchedulerWindow")
                                                .Name("MonthlyFrequencyType_SchedulerWindow")
                                                .DataSource(new string[] { "SPECIFIC DATE", "SPECIFIC DAY" })
                                                .Value(Model.MonthlyFrequencyType_SchedulerWindow)
                                                .OnValueChanged("MonthlyFrequencyType_SchedulerWindow_valueChanged")
                                                .Placeholder("Choose Monthly Frequency Type")
                                                .ShowClearButton(false))
                                        </div>
                                    </div>

                                    <div class="col-md-4" id="FrequencyMonthlySpecificDate_Div">
                                        <div class="form-field">
                                            @Html.Label("Date", htmlAttributes: new { @class = "control-label text-red" })
                                            @(Html.DevExtreme().NumberBox().CustomNumberBox().Format("#").ID("MonthlyFrequencyDateSpecific_SchedulerWindow")
                                                .Name("MonthlyFrequencyDateSpecific_SchedulerWindow")
                                                .Value(Model.MonthlyFrequencyDateSpecific_SchedulerWindow).Min(1).Max(31).ShowSpinButtons(true))
                                        </div>
                                    </div>

                                    <div class="col-md-4" id="FrequencyMonthlySpecificDay_Div">
                                        <div class="col-md-6">
                                            <div class="form-field">
                                                @Html.Label("Day No", htmlAttributes: new { @class = "control-label text-red" })
                                                @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("MonthlyFrequencyMultipleDay_SchedulerWindow")
                                                    .Name("MonthlyFrequencyMultipleDay_SchedulerWindow")
                                                    .DataSource(
                                                        new object[] {
                                                            new { text = "1st", value = 1 }, new { text = "2nd ", value = 2 },
                                                            new { text = "3rd", value = 3 }, new { text = "4th", value = 4 },
                                                            new { text = "Last", value = 5 }
                                                        },"value")
                                                    .ValueExpr("value").DisplayExpr("text").Value(Model.MonthlyFrequencyMultipleDay_SchedulerWindow)
                                                        .Placeholder("Choose Day No").ShowClearButton(false))
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-field">
                                                @Html.Label("Day", htmlAttributes: new { @class = "control-label text-red" })
                                                @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("MonthlyFrequencyEveryWeekdaySpecific_SchedulerWindow")
                                                    .Name("MonthlyFrequencyEveryWeekdaySpecific_SchedulerWindow")
                                                    .DataSource(new string[] { "MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY", "SATURDAY", "SUNDAY", "WEEKDAY", "WEEKEND", "DAY"})
                                                    .Value(Model.MonthlyFrequencyEveryWeekdaySpecific_SchedulerWindow)
                                                    .Placeholder("Choose Day").ShowClearButton(false))
                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="form-field">
                                            @Html.Label("of every Month Interval ", htmlAttributes: new { @class = "control-label text-red" })
                                            <div class="row">
                                                <div class="col-md-6 pr-2">
                                                    @(Html.DevExtreme().NumberBox().CustomNumberBox().Format("#").ID("MonthlyFrequencyEveryMonthInterval_SchedulerWindow")
                                                        .Name("MonthlyFrequencyEveryMonthInterval_SchedulerWindow")
                                                        .Value(Model.MonthlyFrequencyEveryMonthInterval_SchedulerWindow).Min(1).Max(10000).ShowSpinButtons(true))
                                                </div>
                                                <div class="col-md-4 pll" >month(s)</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-field">
                                        @Html.Label("Day Frequency Type", htmlAttributes: new { @class = "control-label text-red" })
                                        @(Html.DevExtreme().SelectBox().ID("DayFrequencyType_SchedulerWindow").Name("DayFrequencyType_SchedulerWindow")
                                            .DataSource(new string[] { "ONCE", "RECURRING", "RANDOM" }).Value(Model.DayFrequencyType_SchedulerWindow)
                                            .OnValueChanged("DayFrequencyType_SchedulerWindow_valueChanged").Placeholder("Choose Day").ShowClearButton(false))
                                    </div>
                                </div>
                                <div class="col-md-6" id="DayFrequencyNoOfTimeBands_SchedulerWindow_Div" style="display:none;">
                                    <div class="form-field">
                                        @Html.Label("No of Time Bands", htmlAttributes: new { @class = "control-label text-red" })
                                        @(Html.DevExtreme().NumberBox().CustomNumberBox().Format("#").ID("DayFrequencyNoOfTimeBands_SchedulerWindow")
                                            .Name("DayFrequencyNoOfTimeBands_SchedulerWindow").Placeholder("Enter number of Time Bands")
                                            .Value(Model.DayFrequencyNoOfTimeBands_SchedulerWindow).Min(1).Max(10).ShowSpinButtons(true)
                                            .OnValueChanged("DayFrequencyNoOfTimeBands_SchedulerWindow_valueChanged"))
                                    </div>
                                </div>
                                <div class="col-md-6" id="DayFrequencyOnce_Div" style="display:none;">
                                    <div class="form-field">
                                        @Html.Label("Day Occurrence at", htmlAttributes: new { @class = "control-label text-red" })
                                        @(Html.DevExtreme().DateBox().CustomDateBox().Type(DateBoxType.Time).ShowClearButton(false).DisplayFormat("hh:mm a")
                                            .ID("DayFrequencyOccuranceAt_SchedulerWindow").Name("DayFrequencyOccuranceAt_SchedulerWindow").Placeholder("hh:mm AM/PM")
                                            .Value(Model.DayFrequencyOccuranceAt_SchedulerWindow).Min(DateTime.MinValue))
                                    </div>
                                </div>
                                <div class="col-md-12" id="DayFrequency_Random_Recurring_Div">
                                    <div class="col-md-12" id="DayFrequencyRecurringLbl_Div" style="display:none;">
                                        <div class="form-field">
                                            <label><b>Day Frequency - Recurring</b></label>
                                        </div>
                                    </div>
                                    <div class="col-md-6" id="DayFrequencyRecurringTB_Div">
