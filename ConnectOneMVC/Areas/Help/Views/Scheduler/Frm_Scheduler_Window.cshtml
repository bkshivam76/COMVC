    <script>
    function displayHide_Universal_SchedulerWindow_Div() {
        if ("@Model.Is_Universal_SchedulerWindow_Editable" === "True") {
            document.getElementById('Universal_SchedulerWindow_Div').style.display = 'block';
        }
        else {
            document.getElementById('Universal_SchedulerWindow_Div').style.display = 'none';
        }
    }
    var Screen_SchedulerWin = "@ViewBag.Screen"
    $(document).ready(function ()
    {
        TransformTextForDB("SchedulerForm");
        $("#Summary_SchedulerWindow").dxTextArea("instance").option("focusStateEnabled", false);
        if (Tag === "_New")
        {
            $("#ScheduleType_SchedulerWindow").dxSelectBox("instance").option("value", "ONCE");
            document.getElementById("OneTimeOccuringSchedule_Div").style.display = "block";
            $("#Time_SchedulerWindow").dxDateBox("instance").option("value", new Date('January 1, 1901, 00:00:00'));
            displayHide_Universal_SchedulerWindow_Div();
        }
        else if (Tag === "_Edit" || Tag === "_Delete"|| Tag ==="_View")
        {
            displayHide_Universal_SchedulerWindow_Div();
            var scheduleType = "@Model.ScheduleType_SchedulerWindow";
            if ("@Model.ScheduleType_SchedulerWindow".length > 0)
            {
                ScheduleType_SchedulerWindow_valueChanged(null, true);
            }
            if ("@Model.FrequencyType_SchedulerWindow".length > 0)
            {
                FrequencyType_SchedulerWindow_valueChanged(null, true);
            }
            if ("@Model.MonthlyFrequencyType_SchedulerWindow".length > 0)
            {
                MonthlyFrequencyType_SchedulerWindow_valueChanged(null, true);
            }
            if ("@Model.DayFrequencyType_SchedulerWindow".length > 0)
            {
                DayFrequencyType_SchedulerWindow_valueChanged(null, true);
            }
            if (parseInt("@Model.DayFrequencyNoOfTimeBands_SchedulerWindow") > 0)
            {
                DayFrequencyNoOfTimeBands_SchedulerWindow_valueChanged(null, true);
            }
            if (parseInt("@Model.MappedChartCount_SchedulerWindow") > 0 && "@Model.ScheduleType_SchedulerWindow" == "RECURRING")
            {
                $("#ScheduleType_SchedulerWindow").dxSelectBox("option", "readOnly", true);
                $("#ScheduleType_SchedulerWindow").dxSelectBox("option", "hint", "Forms Have Been Mapped With This Schedule. \nScheduler Type Cannot Be Once If Mapped With Any Form")
            }
        }
        if ("@Model.Summary_SchedulerWindow".length > 0) $("#Summary_SchedulerWindow").dxSelectBox("instance").option("value", "@Model.Summary_SchedulerWindow");
            Set_Form_View_Delete_Mode(null, "SchedulerForm", Tag);
    });

    function DayFrequencyNoOfTimeBands_SchedulerWindow_valueChanged(e, FirstCall = false)
    {
        let value = e ? parseInt(e.value) : $("#DayFrequencyNoOfTimeBands_SchedulerWindow").dxNumberBox("instance").option("value");
        let frequencyType = $("#DayFrequencyType_SchedulerWindow").dxSelectBox("instance").option("value");
        if (frequencyType === "RECURRING") {
            for (var i = 1; i <= value; i++) {
                document.getElementById("DayRecurring" + i + "_Div").style.display = "block";
                if ((e!=null) && (e.previousValue >= i)) {//It will work as Spinlock and will not reset value of field from start until noOfTimeBand is initializing
                    //Skip reset to 12:00 Am  OR 11:59 PM
                }
                else if (FirstCall == false) {
                    $("#DayFrequencyOccuranceEveryTB" + i + "_SchedulerWindow").dxNumberBox("instance").option("value", 1);
                    $("#DayFrequencyStartTimeTB" + i + "_SchedulerWindow").dxDateBox("instance").option("value", new Date('January 1, 1901, 00:00:00'));
                    $("#DayFrequencyEndTimeTB" + i + "_SchedulerWindow").dxDateBox("instance").option("value", new Date('January 1, 1901, 23:59:00'));
                }
                document.getElementById("DayFrequencyStartTimeTB" + i + "_SchedulerWindow_Div").style.display = "block";
                document.getElementById("DayFrequencyRecRandstartTimeEndTime_Div").style.display = "block";
            }
