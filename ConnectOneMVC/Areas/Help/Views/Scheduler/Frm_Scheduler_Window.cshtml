    <script>
        var Tag = "@Model.ActionMethod";

        function Frm_Scheduler_Window_AjaxSuccessForm(data)
        {
            HideLoader();
            dontaskpopupcloseconfirmation = true;

            if (data.jsonParam.result == false)
            {
                if (data.jsonParam.closeform)
                {
                    $("#Dynamic_Content_popup").dxPopup("hide");
                }
                if (data.jsonParam.refreshgrid)
                {
                     RefreshGridView("SchedulerListGrid");
                }
                var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
            }
            else if (data.jsonParam.result == true)
            {
                var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                alertclick.done(function ()
                {
                    debugger
                    if (Screen_SchedulerWin.includes("Sparc_Create")) {
                        AfterWindowClose_Scheduler(Tag, data.xID);
                    }
                    $("#Dynamic_Content_popup").dxPopup("hide");
                })
            }
        }
        function AfterWindowClose_Scheduler(ActionMethod = "", xID = "") {
            if (ActionMethod == "_Delete" || ActionMethod == "Delete") {
                RefreshGridView("SchedulerListGrid");
                return;
            }
            if (ActionMethod.includes("New")) {
                Scheduler_MoreEntry = true;
            }
            Scheduler_Select_xid = xID;
            RefreshGridView("SchedulerListGrid");
        }
        function close_Scheduler() {
            $("#Dynamic_Content_popup").dxPopup("hide");
        }

        async function Scheduler_SaveClick(e)
        {
            ShowLoader();
            var form = $("#SchedulerForm");
            if (Tag == "_Delete") {
                HideLoader();
                DeleteAfterConfirmation("@Model.TitleX_Scheduler", "", form);
            }
            else
            {
                if (Tag == "_New" || Tag == "_Edit") {
                    debugger;
                    var schdulerName = $("#Name_SchedulerWindow").dxTextBox("option", "value");
                    //$("#Name_SchedulerWindow").dxTextBox("instance").option("value"); //--->Above line Sysntax is same as of below
                    $("#Name_SchedulerWindow").dxTextBox("option","value");
                    if (schdulerName === null || schdulerName === undefined || schdulerName.trim() === "") {
                        DevExpress.ui.dialog.alert("Invalid Scheduler Name!", "Invalid input....").done(
                            function () { $("#Name_SchedulerWindow").dxTextBox("instance").focus() });
                        HideLoader();
                        return;
                    }
                    var schdulerType = $("#ScheduleType_SchedulerWindow").dxSelectBox("instance").option("value");
                    if (schdulerType === null || schdulerType === undefined) {
                        DevExpress.ui.dialog.alert("Schedule Type field is mandatory!", "Invalid input....").done(
                            function () { $("#ScheduleType_SchedulerWindow").dxSelectBox("instance").focus() });
                        HideLoader();
                        return;
                    }
                    if (schdulerType === "ONCE") {
                        if (IsNullOrWhitespace("Time_SchedulerWindow", "dxDateBox")) {
                            DevExpress.ui.dialog.alert('Time is mandatory!', "Invalid input....").done(
                                function () { $("#Time_SchedulerWindow").dxDateBox("instance").focus() });
                            HideLoader();
                            return;
                        }
                    }
                    else if (schdulerType === "RECURRING") {
                        var frequencyType = $("#FrequencyType_SchedulerWindow").dxSelectBox("instance").option("value");
                        if (frequencyType === null || frequencyType === undefined) {
                            DevExpress.ui.dialog.alert('Frequency Type field is mandatory!', "Invalid input....").done(
                                function () { $("#FrequencyType_SchedulerWindow").dxSelectBox("instance").focus() });
                            HideLoader();
                            return;
                        }
                        else if (frequencyType === "DAILY") {
                            if (IsNullOrWhitespace("DailyRecurrenceEvery_SchedulerWindow", "dxNumberBox")) {
                                DevExpress.ui.dialog.alert("Daily Reccurence Every field is mandatory!", "Invalid input....").done(
                                    function () { $("#DailyRecurrenceEvery_SchedulerWindow").dxNumberBox("instance").focus() });
                                HideLoader();
                                return;
                            }
                        }
                        else if (frequencyType === "WEEKLY") {
                            if ($("#WeeklyRecurrenceEvery_SchedulerWindow").dxNumberBox("instance").option("value") === null || $("#WeeklyRecurrenceEvery_SchedulerWindow").dxNumberBox("instance").option("value") === undefined) {
                                DevExpress.ui.dialog.alert("Weekly Reccurence Every field is mandatory!", "Invalid input....").done(
                                    function () { $("#WeeklyRecurrenceEvery_SchedulerWindow").dxNumberBox("instance").focus() });
                                HideLoader();
                                return;
                            }
                            const weekDays = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"];
                            let counter = 0;
                            for (var i = 0; i < weekDays.length; i++) {
                                if ($("#" + weekDays[i] + "_SchedulerWindow").dxCheckBox("instance").option("value") === true)
                                    counter++;
                            }
                            if (counter === 0) {
                                DevExpress.ui.dialog.alert("Please select at least a day.", "Invalid input....").done(
                                    function () { $("#Monday_SchedulerWindow").dxCheckBox("instance").focus() });
                                HideLoader();
                                return;
                            }
                        }
                        else if (frequencyType === "MONTHLY") {
                            var monthlyFrequencyType = $("#MonthlyFrequencyType_SchedulerWindow").dxSelectBox("instance").option("value");
                            if (monthlyFrequencyType === undefined || monthlyFrequencyType === null) {
                                DevExpress.ui.dialog.alert("Monthly Frequency Type field is mandatory!", "Invalid input....").done(
                                    function () { $("#MonthlyFrequencyType_SchedulerWindow").dxSelectBox("instance").focus() });
                                HideLoader();
                                return;
                            }
                            else if (monthlyFrequencyType === "SPECIFIC DATE") {
                                if (IsNullOrWhitespace("MonthlyFrequencyDateSpecific_SchedulerWindow", "dxNumberBox")) {
                                    DevExpress.ui.dialog.alert("Monthly Frequency Type section's 'Date' field is mandatory!", "Invalid input....").done(
                                        function () { $("#MonthlyFrequencyDateSpecific_SchedulerWindow").dxNumberBox("instance").focus() });
                                    HideLoader();
                                    return;
                                }
                                if (IsNullOrWhitespace("MonthlyFrequencyEveryMonthInterval_SchedulerWindow", "dxNumberBox")) {
                                    DevExpress.ui.dialog.alert("Monthly Frequency Type section's of 'every Monthly Interval' field is mandatory!", "Invalid input....").done(
                                        function () { $("#MonthlyFrequencyEveryMonthInterval_SchedulerWindow").dxNumberBox("instance").focus() });
                                    HideLoader();
                                    return;
                                }
                            }
                            else if (monthlyFrequencyType === "SPECIFIC DAY") {
                                if (IsNullOrWhitespace("MonthlyFrequencyMultipleDay_SchedulerWindow", "dxSelectBox")) {
                                    DevExpress.ui.dialog.alert("Monthly Frequency Type section's 'Day No.' field is mandatory!", "Invalid input....").done(
                                        function () { $("#MonthlyFrequencyMultipleDay_SchedulerWindow").dxSelectBox("instance").focus() });
                                    HideLoader();
                                    return;
                                }
                                if (IsNullOrWhitespace("MonthlyFrequencyEveryWeekdaySpecific_SchedulerWindow", "dxSelectBox")) {
                                    DevExpress.ui.dialog.alert("Monthly Frequency Type section's 'Day' field is mandatory!", "Invalid input....").done(
                                        function () { $("#MonthlyFrequencyEveryWeekdaySpecific_SchedulerWindow").dxSelectBox("instance").focus() });
                                    HideLoader();
                                    return;
                                }
                                if (IsNullOrWhitespace("MonthlyFrequencyEveryMonthInterval_SchedulerWindow", "dxNumberBox")) {
                                    DevExpress.ui.dialog.alert("Monthly Frequency Type section's of every(Monthly Interval) field is mandatory!", "Invalid input....").done(
                                        function () { $("#MonthlyFrequencyEveryMonthInterval_SchedulerWindow").dxNumberBox("instance").focus() });
                                    HideLoader();
                                    return;
                                }
                            }
                        }
                        var dayFrequencyType = $("#DayFrequencyType_SchedulerWindow").dxSelectBox("instance").option("value");
                        if (dayFrequencyType === null || dayFrequencyType === undefined) {
                            DevExpress.ui.dialog.alert("Day Frequency Type field is mandatory!", "Invalid input....").done(
                                function () { $("#DayFrequencyType_SchedulerWindow").dxSelectBox("instance").focus() });
                            HideLoader();
                            return;
                        }
                        else if (dayFrequencyType === "ONCE") {
                            if (IsNullOrWhitespace("DayFrequencyOccuranceAt_SchedulerWindow", "dxDateBox")) {
                                DevExpress.ui.dialog.alert('Day Occurrence at field is mandatory!', "Invalid input....").done(
                                    function () { $("#DayFrequencyOccuranceAt_SchedulerWindow").dxDateBox("instance").focus() });
                                HideLoader();
                                return;
                            }
                        }
                        else if (dayFrequencyType === "RECURRING") {
                            var noOfTimeBands =$("#DayFrequencyNoOfTimeBands_SchedulerWindow").dxNumberBox("instance").option("value");
                            if (noOfTimeBands === null || noOfTimeBands === undefined || noOfTimeBands === 0) {
                                DevExpress.ui.dialog.alert('No of Time Bands field is mandatory!', "Invalid input....").done(
                                    function () { $("#DayFrequencyNoOfTimeBands_SchedulerWindow").dxNumberBox("instance").focus() });
                                HideLoader();
                                return;
                            }
                            if (noOfTimeBands >= 1) {
                                let start = null;
                                let end = null;
                                let previousEnd = null;
                                let prevEndTime = null;
                                let startTime = null;
                                let endTime = null;
                                for (var i = 1; i <= noOfTimeBands; i++) {
                                    if (IsNullOrWhitespace("DayFrequencyOccuranceEveryTB" + i + "_SchedulerWindow", "dxNumberBox")) {
                                        DevExpress.ui.dialog.alert("Day Occurrence Every (TB-" + i + ") field is mandatory!", "Invalid input....").done(
                                            function () { $("#DayFrequencyOccuranceEveryTB" + i + "_SchedulerWindow").dxNumberBox("instance").focus() });
                                        HideLoader();
                                        return;
                                    }
                                    if (IsNullOrWhitespace("DayFrequencyStartTimeTB" + i + "_SchedulerWindow", "dxDateBox")) {
                                        DevExpress.ui.dialog.alert("Start Time(TB-" + i + ") field is mandatory!", "Invalid input....").done(
                                            function () { $("#DayFrequencyStartTimeTB" + i + "_SchedulerWindow").dxDateBox("instance").focus() });
                                        HideLoader();
                                        return;
                                    }
                                    if (IsNullOrWhitespace("DayFrequencyEndTimeTB" + i + "_SchedulerWindow", "dxDateBox")) {
                                        DevExpress.ui.dialog.alert("End Time(TB-" + i + ") field is mandatory!", "Invalid input....").done(
                                            function () { $("#DayFrequencyEndTimeTB" + i + "_SchedulerWindow").dxDateBox("instance").focus() });
                                        HideLoader();
                                        return;
                                    }
                                    start = $("#DayFrequencyStartTimeTB" + i + "_SchedulerWindow").dxDateBox("option", "value");
                                    startTime = moment(start.toLocaleTimeString(), 'h:mma');
                                    end = $("#DayFrequencyEndTimeTB" + i + "_SchedulerWindow").dxDateBox("option", "value");
                                    endTime = moment(end.toLocaleTimeString(), 'h:mma');
                                    if (startTime > endTime) {
                                        DevExpress.ui.dialog.alert('Start Time should be before or equal to End Time', "Invalid input....").done(
                                            function () { $("#DayFrequencyEndTimeTB" + i + "_SchedulerWindow").dxDateBox("instance").focus() });
                                        HideLoader();
                                        return;
                                    }
                                    if (i > 1) {
                                        previousEnd = $("#DayFrequencyEndTimeTB" + (i - 1) + "_SchedulerWindow").dxDateBox("option", "value");
                                        prevEndTime = moment(previousEnd.toLocaleTimeString(), 'h:mma');
                                        if (startTime<=prevEndTime) {
                                            DevExpress.ui.dialog.alert('Start Time<b>(TB-' + i + ')</b> must be greater than End Time<b>(TB-' + (i - 1) + ')</b>', "Invalid input....").done(
                                                function () { $("#DayFrequencyStartTimeTB" + i + "_SchedulerWindow").dxDateBox("instance").focus() });
                                            HideLoader();
                                            return;
                                        }
                                    }
                                }
                            }
                        }
                        else if (dayFrequencyType === "RANDOM") {
                            var noOfTimeBands = $("#DayFrequencyNoOfTimeBands_SchedulerWindow").dxNumberBox("instance").option("value");
                            if (noOfTimeBands === null || noOfTimeBands === undefined || noOfTimeBands === 0) {
                                DevExpress.ui.dialog.alert('No of Time Bands field is mandatory!', "Invalid input....").done(
                                    function () { $("#DayFrequencyNoOfTimeBands_SchedulerWindow").dxNumberBox("instance").focus() });
                                HideLoader();
                                return;
                            }
                            if (noOfTimeBands >= 1) {
                                let start = null;
                                let previousEnd = null;
                                let prevEndTime = null;
                                let startTime = null;
                                let end = null;
                                let endTime = null;
                                for (var i = 1; i <= noOfTimeBands; i++) {
                                    //This will never be required because min val=1 is preset
                                    if (IsNullOrWhitespace("DayFrequencyRandomOccurenceNoTB" + i + "_SchedulerWindow", "dxNumberBox")) {
                                        DevExpress.ui.dialog.alert("Random Occurrence No. (TB-" + i + ") field is mandatory!", "Invalid input....").done(
                                            function () { $("#DayFrequencyRandomOccurenceNoTB" + i + "_SchedulerWindow").dxNumberBox("instance").focus() });
                                        HideLoader();
                                        return;
                                    }
                                    if (IsNullOrWhitespace("DayFrequencyStartTimeTB" + i + "_SchedulerWindow", "dxDateBox")) {
                                        DevExpress.ui.dialog.alert("Start Time(TB-" + i + ") field is mandatory!", "Invalid input....").done(
                                            function () { $("#DayFrequencyStartTimeTB" + i + "_SchedulerWindow").dxDateBox("instance").focus() });
                                        HideLoader();
                                        return;
                                    }
                                    if (IsNullOrWhitespace("DayFrequencyEndTimeTB" + i + "_SchedulerWindow", "dxDateBox")) {
                                        DevExpress.ui.dialog.alert("End Time(TB-" + i + ") field is mandatory!", "Invalid input....").done(
                                            function () { $("#DayFrequencyEndTimeTB" + i + "_SchedulerWindow").dxDateBox("instance").focus() });
                                        HideLoader();
                                        return;
                                    }
                                    start = $("#DayFrequencyStartTimeTB" + i + "_SchedulerWindow").dxDateBox("option", "value");
                                    startTime = moment(start.toLocaleTimeString(), 'h:mma');
                                    end = $("#DayFrequencyEndTimeTB" + i + "_SchedulerWindow").dxDateBox("option", "value");
                                    endTime = moment(end.toLocaleTimeString(), 'h:mma');
                                    if (startTime >= endTime) {
                                        DevExpress.ui.dialog.alert('Start Time should be before End Time', "Invalid input....").done(
                                            function () { $("#DayFrequencyEndTimeTB" + i + "_SchedulerWindow").dxDateBox("instance").focus() });
                                        HideLoader();
                                        return;
                                    }
                                    var difference = endTime.hours() * 60 + endTime.minutes() - startTime.hours() * 60 - startTime.minutes();
                                    if (difference<15) {
                                        DevExpress.ui.dialog.alert("Difference between End Time(TB-" + i + ") and Start Time(TB-" + i + ") must not be less than 15 minutes!!", "Invalid input....").done(
                                            function () { $("#DayFrequencyEndTimeTB" + i + "_SchedulerWindow").dxDateBox("instance").focus() });
                                        HideLoader();
                                        return;
                                    }
                                    if (i > 1) {
                                        start = $("#DayFrequencyStartTimeTB" + i + "_SchedulerWindow").dxDateBox("option", "value");
                                        previousEnd = $("#DayFrequencyEndTimeTB" + (i - 1) + "_SchedulerWindow").dxDateBox("option", "value");
                                        prevEndTime = moment(previousEnd.toLocaleTimeString(), 'h:mma');
                                        startTime = moment(start.toLocaleTimeString(), 'h:mma');
                                        if (startTime <= prevEndTime) {
                                            DevExpress.ui.dialog.alert('Start Time<b>(TB-' + i + ')</b> must be greater than End Time<b>(TB-' + (i - 1) + ')</b>', "Invalid input....").done(
                                                function () { $("#DayFrequencyStartTimeTB" + i + "_SchedulerWindow").dxDateBox("instance").focus() });
                                            HideLoader();
                                            return;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
                formdatasubmit_Scheduler(Tag);
            }
        }

        function formdatasubmit_Scheduler(Tag) {
            debugger;
            var formdata = new FormData($("#SchedulerForm").get(0));
            formdata.append("ActionMethod", Tag);
            var schdulerType = $("#ScheduleType_SchedulerWindow").dxSelectBox("instance").option("value");
            formdata.append('ScheduleType_SchedulerWindow', schdulerType);
            if (schdulerType === "ONCE") {
                formdata.append('Time_SchedulerWindow', $("#Time_SchedulerWindow").dxDateBox("instance").option("value"));
                formdata.append('Universal_SchedulerWindow', $("#Universal_SchedulerWindow").dxCheckBox("instance").option("value"));
            }
            if (schdulerType === "RECURRING") {
                var frequencyType = $("#FrequencyType_SchedulerWindow").dxSelectBox("instance").option("value");
                if (frequencyType === "DAILY") {
                    formdata.append('FrequencyType_SchedulerWindow', frequencyType);
                    formdata.append('DailyRecurrenceEvery_SchedulerWindow', $("#DailyRecurrenceEvery_SchedulerWindow").dxNumberBox("instance").option("value"));
                }
                else if (frequencyType === "WEEKLY") {
                    formdata.append('FrequencyType_SchedulerWindow', frequencyType);
                    formdata.append('WeeklyRecurrenceEvery_SchedulerWindow', $("#WeeklyRecurrenceEvery_SchedulerWindow").dxNumberBox("instance").option("value"));
                    const weekDays = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"];
                    let counter = 0;
                    for (var i = 0; i < weekDays.length; i++) {
                        if ($("#" + weekDays[i] + "_SchedulerWindow").dxCheckBox("instance").option("value") === true)
                            formdata.append(weekDays[i]+'_SchedulerWindow', true);
                    }
                }
                else if (frequencyType === "MONTHLY") {
                    var monthlyFrequencyType = $("#MonthlyFrequencyType_SchedulerWindow").dxSelectBox("instance").option("value");
                    if (monthlyFrequencyType === "SPECIFIC DATE") {
                        formdata.append('MonthlyFrequencyType_SchedulerWindow', monthlyFrequencyType);
                        formdata.append('MonthlyFrequencyDateSpecific_SchedulerWindow', $("#MonthlyFrequencyDateSpecific_SchedulerWindow").dxNumberBox("instance").option("value"));
                        formdata.append('MonthlyFrequencyEveryMonthInterval_SchedulerWindow', $("#MonthlyFrequencyEveryMonthInterval_SchedulerWindow").dxNumberBox("instance").option("value"));
                    }
                    else if (monthlyFrequencyType === "SPECIFIC DAY") {
                        formdata.append('MonthlyFrequencyType_SchedulerWindow', monthlyFrequencyType);
                        formdata.append('MonthlyFrequencyMultipleDay_SchedulerWindow', $("#MonthlyFrequencyMultipleDay_SchedulerWindow").dxSelectBox("instance").option("value"));
                        formdata.append('MonthlyFrequencyEveryWeekdaySpecific_SchedulerWindow', $("#MonthlyFrequencyEveryWeekdaySpecific_SchedulerWindow").dxSelectBox("instance").option("value"));
                        formdata.append('MonthlyFrequencyEveryMonthInterval_SchedulerWindow', $("#MonthlyFrequencyEveryMonthInterval_SchedulerWindow").dxNumberBox("instance").option("value"));
                    }
                }
                var dayFrequencyType = $("#DayFrequencyType_SchedulerWindow").dxSelectBox("instance").option("value");
                if (dayFrequencyType === "ONCE") {
                    formdata.append('DayFrequencyType_SchedulerWindow', dayFrequencyType);
                    formdata.append('DayFrequencyOccuranceAt_SchedulerWindow', $("#DayFrequencyOccuranceAt_SchedulerWindow").dxDateBox("instance").option("value"));
                }
                else if (dayFrequencyType === "RECURRING") {
                    var noOfTimeBands =$("#DayFrequencyNoOfTimeBands_SchedulerWindow").dxNumberBox("instance").option("value");
                    formdata.append('DayFrequencyType_SchedulerWindow', dayFrequencyType);
                    if (noOfTimeBands >= 1) {
                        for (var i = 1; i <= noOfTimeBands; i++) {
                            formdata.append("DayFrequencyOccuranceEveryTB" + i + "_SchedulerWindow", $("#DayFrequencyOccuranceEveryTB" + i + "_SchedulerWindow").dxNumberBox("instance").option("value"));
                            formdata.append("DayFrequencyStartTimeTB" + i + "_SchedulerWindow", $("#DayFrequencyStartTimeTB" + i + "_SchedulerWindow").dxDateBox("instance").option("value"));
                            formdata.append("DayFrequencyEndTimeTB" + i + "_SchedulerWindow", $("#DayFrequencyEndTimeTB" + i + "_SchedulerWindow").dxDateBox("instance").option("value"));
                        }
                    }
                }
                else if (dayFrequencyType === "RANDOM") {
                    var noOfTimeBands =$("#DayFrequencyNoOfTimeBands_SchedulerWindow").dxNumberBox("instance").option("value");
                    formdata.append("DayFrequencyNoOfTimeBands_SchedulerWindow", noOfTimeBands);
                    if (noOfTimeBands >= 1) {
                        for (var i = 1; i <= noOfTimeBands; i++) {
                            formdata.append("DayFrequencyRandomOccurenceNoTB" + i + "_SchedulerWindow", $("#DayFrequencyRandomOccurenceNoTB" + i + "_SchedulerWindow").dxNumberBox("instance").option("value"));
                            formdata.append("DayFrequencyStartTimeTB" + i + "_SchedulerWindow", $("#DayFrequencyStartTimeTB" + i + "_SchedulerWindow").dxDateBox("instance").option("value"));
                            formdata.append("DayFrequencyEndTimeTB" + i + "_SchedulerWindow", $("#DayFrequencyEndTimeTB" + i + "_SchedulerWindow").dxDateBox("instance").option("value"));
                            }
                        }
                    }
            }

            $.ajax({
                url: "/Help/Scheduler/Frm_Scheduler_Window",
                type: "post",
                data: formdata,
                contentType: false,
                processData: false,
                success: function (data) {
                    Frm_Scheduler_Window_AjaxSuccessForm(data)
                }
            });
        }
        function DayFrequencyRandomOccurenceNoTB_SchedulerWindow_valueChanged(e) {
            var value = null;
            if (e) { value = e.value; }
            if (value != null) {
                if (value > 15) {
                    DevExpress.ui.dialog.alert('Field value cannot be more than 15!', "Invalid input....").done(
                        function () { e.component.focus(); }
                    );
                    e.component.option("value", 15);
                    return;
                }
            }
        }
        function DayFrequencyOccuranceEveryTB_SchedulerWindow_valueChanged(e) {
            var value = null;
            if (e) { value = e.value; }
            if (value != null) {
                if (value > 1439) {
                    DevExpress.ui.dialog.alert('Field value cannot be more than 1439 minutes(23 hours and 59 minutes)!', "Invalid input....").done(
                        function () { e.component.focus(); }
                    );
                    e.component.option("value", 1439);
                    return;
                }
            }
        }
        
    </script>
    </div>