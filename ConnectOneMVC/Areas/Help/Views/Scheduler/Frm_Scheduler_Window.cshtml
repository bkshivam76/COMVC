                                            </div>
                                            <div class="col-xs-5 pl-0">@(Html.DevExtreme().NumberBox().CustomNumberBox().Format("#").ID("DayFrequencyRandomOccurenceNoTB1_SchedulerWindow").Name("DayFrequencyRandomOccurenceNoTB1_SchedulerWindow").Value(Model.DayFrequencyRandomOccurenceNoTB1_SchedulerWindow).OnValueChanged("DayFrequencyRandomOccurenceNoTB_SchedulerWindow_valueChanged").Min(1).ShowSpinButtons(true))</div>
