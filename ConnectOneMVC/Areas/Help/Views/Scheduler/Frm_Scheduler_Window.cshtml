                                            <div class="clearfix">
                                                <div class="form-field clearfix">
                                                    <div class="col-xs-7 pr-2 pt-1">
                                                        @Html.Label("Day Occurrence Every(TB-1): in Minutes  ", htmlAttributes: new { @class = "control-label text-red" })
                                                    </div>
                                                    <div class="col-xs-5 pl-0">
                                                        @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("DayFrequencyOccuranceEveryTB1_SchedulerWindow").Name("DayFrequencyOccuranceEveryTB1_SchedulerWindow")
                                                            .Value(Model.DayFrequencyOccuranceEveryTB1_SchedulerWindow).Min(1).Format("#")
                                                            .OnValueChanged("DayFrequencyOccuranceEveryTB_SchedulerWindow_valueChanged").ShowSpinButtons(true))
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-12" id="DayRecurring2_Div" style="display:none;">
                                            <div class="form-field clearfix">
                                                <div class="col-xs-7 pr-2 pt-1">
                                                    @Html.Label("Day Occurrence Every(TB-2): in Minutes  ", htmlAttributes: new { @class = "control-label text-red" })
                                                </div>
                                                <div class="col-xs-5 pl-0">
                                                    @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("DayFrequencyOccuranceEveryTB2_SchedulerWindow").Name("DayFrequencyOccuranceEveryTB2_SchedulerWindow")
                                                .Value(Model.DayFrequencyOccuranceEveryTB2_SchedulerWindow).Min(1).Format("#").OnValueChanged("DayFrequencyOccuranceEveryTB_SchedulerWindow_valueChanged").ShowSpinButtons(true))
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-12" id="DayRecurring3_Div" style="display:none;">
                                            <div class="form-field clearfix">
                                                <div class="col-xs-7 pr-2 pt-1">
                                                    @Html.Label("Day Occurrence Every(TB-3): in Minutes  ", htmlAttributes: new { @class = "control-label text-red" })
                                                </div>
                                                <div class="col-xs-5 pl-0">
                                                    @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("DayFrequencyOccuranceEveryTB3_SchedulerWindow")
                                                        .Name("DayFrequencyOccuranceEveryTB3_SchedulerWindow").Value(Model.DayFrequencyOccuranceEveryTB3_SchedulerWindow)
                                                        .Min(1).OnValueChanged("DayFrequencyOccuranceEveryTB_SchedulerWindow_valueChanged").Format("#").ShowSpinButtons(true))
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-12" id="DayRecurring4_Div" style="display:none;">
                                            <div class="form-field clearfix">
                                                <div class="col-xs-7 pr-2 pt-1">
                                                    @Html.Label("Day Occurrence Every(TB-4): in Minutes  ", htmlAttributes: new { @class = "control-label text-red" })
                                                </div>
                                                <div class="col-xs-5 pl-0">
                                                    @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("DayFrequencyOccuranceEveryTB4_SchedulerWindow")
                                                        .Name("DayFrequencyOccuranceEveryTB4_SchedulerWindow").Value(Model.DayFrequencyOccuranceEveryTB4_SchedulerWindow)
                                                        .Min(1).OnValueChanged("DayFrequencyOccuranceEveryTB_SchedulerWindow_valueChanged").ShowSpinButtons(true).Format("#")
                                                    )
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-12" id="DayRecurring5_Div" style="display:none;">
                                            <div class="form-field clearfix">
                                                <div class="col-xs-7 pr-2 pt-1">
                                                    @Html.Label("Day Occurrence Every(TB-5): in Minutes  ", htmlAttributes: new { @class = "control-label text-red" })
                                                </div>
                                                <div class="col-xs-5 pl-0">
                                                    @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("DayFrequencyOccuranceEveryTB5_SchedulerWindow")
                                                        .Name("DayFrequencyOccuranceEveryTB5_SchedulerWindow").Value(Model.DayFrequencyOccuranceEveryTB5_SchedulerWindow)
                                                        .Min(1).OnValueChanged("DayFrequencyOccuranceEveryTB_SchedulerWindow_valueChanged").ShowSpinButtons(true).Format("#")
                                                     )
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-12" id="DayRecurring6_Div" style="display:none;">
                                            <div class="form-field clearfix">
                                                <div class="col-xs-7 pr-2 pt-1">
                                                    @Html.Label("Day Occurrence Every(TB-6): in Minutes  ", htmlAttributes: new { @class = "control-label text-red" })
                                                </div>
                                                <div class="col-xs-5 pl-0">
                                                    @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("DayFrequencyOccuranceEveryTB6_SchedulerWindow")
                                                        .Name("DayFrequencyOccuranceEveryTB6_SchedulerWindow").Value(Model.DayFrequencyOccuranceEveryTB6_SchedulerWindow)
                                                        .Min(1).OnValueChanged("DayFrequencyOccuranceEveryTB_SchedulerWindow_valueChanged").ShowSpinButtons(true).Format("#")
                                                     )
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-12" id="DayRecurring7_Div" style="display:none;">
                                            <div class="form-field clearfix">
                                                <div class="col-xs-7 pr-2 pt-1">
                                                    @Html.Label("Day Occurrence Every(TB-7): in Minutes  ", htmlAttributes: new { @class = "control-label text-red" })
                                                </div>
                                                <div class="col-xs-5 pl-0">
                                                    @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("DayFrequencyOccuranceEveryTB7_SchedulerWindow").Name("DayFrequencyOccuranceEveryTB7_SchedulerWindow")
                                                        .Value(Model.DayFrequencyOccuranceEveryTB7_SchedulerWindow).Min(1).OnValueChanged("DayFrequencyOccuranceEveryTB_SchedulerWindow_valueChanged")
                                                        .ShowSpinButtons(true).Format("#")
