    <script src="@Url.Content("~/Scripts/moment.min.js")"></script>

    <script src="~/Content/fontawesome/js/fontawesome_v5_all.js"></script>
    @*<script src="@Url.Content("~/Scripts/site.js")" type="text/javascript"></script>*@
    @*End Scripts*@



    @System.Web.Optimization.Styles.Render("~/Content/DevExtremeBundleReporting")
    @System.Web.Optimization.Scripts.Render("~/Scripts/DevExtremeBundleReporting")
    <link href="@Url.Content("~/Content/CustomeDevextream.css")" rel="stylesheet">
</head>
<body class="report_header_div_main">
    <div class="row" style="padding-top:5%">          
                <div class="form-field">
                    <div class="container-fluid">

                        @(Html.DevExtreme().DataGrid()
                                                                                                                 .ID("ViewFiles_datagrid")
                                                                                                                 .DataSource(Model)

                                                                                                                 .Columns(columns =>
                                                                                                                 {
                                                                                                                     columns.Add().DataField("Name").Caption("Name").Width("40%");
                                                                                                                     columns.Add().DataField("Extension").Width("10%");
                                                                                                                     columns.Add().DataField("Size").Caption("Size(Mb)").Width("10%");
                                                                                                                     columns.Add().DataField("CreationDate").Caption("Creation Date").Width("20%"); ;
                                                                                                                     columns.Add().DataField("ModifyDate").Caption("Modify Date").Width("20%"); ;

                                                                                                                 })
                                                                                                                 .Height(500)
                                                                                                                 .Scrolling(s => s.ShowScrollbar(ShowScrollbarMode.Always).Mode(GridScrollingMode.Infinite))



                        )

                    </div>
                </div>
            </div>
</body>
</html>
