        {
            string ISSUE_MEMBER = (string)DataBinder.Eval(e.DataItem, "ISSUE_MEMBER");
            GridViewExtension grid = new GridViewExtension(ConnectOneMVC.Areas.Magazine.Controllers.MagazineDispatchRegisterController.CreateGeneralDetailGridSettings(ISSUE_MEMBER));
            grid.Bind(ConnectOneMVC.Areas.Magazine.Controllers.MagazineDispatchRegisterController.GetDispatchdetails(ISSUE_MEMBER));
            e.DetailGridViews.Add(grid);
        };
        settings.SettingsDetail.ExportMode = GridViewDetailExportMode.Expanded;
        settings.SettingsDetail.ShowDetailRow = true;
        settings.SetDetailRowTemplateContent(c =>
        {
            //ViewContext.Writer.Write(
            //    "Contact Phone: <b>" +
            //        DataBinder.Eval(c.DataItem, "Membership_No") + "</b>, Fax: <b>" +
