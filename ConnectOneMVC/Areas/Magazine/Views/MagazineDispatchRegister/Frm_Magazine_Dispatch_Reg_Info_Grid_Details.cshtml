@Html.DevExpress().GridView(settings =>
{
    settings.Name = "detailGrid_" + ViewData["ISSUE_MEMBER"];
    settings.SettingsDetail.MasterGridName = "MagaZineDispatchListGrid";
    settings.CallbackRouteValues = new { Controller = "MagazineDispatchRegisterController", Action = "Frm_Magazine_Dispatch_Reg_Info_Grid_Details", ISSUE_MEMBER = ViewData["ISSUE_MEMBER"] };
    settings.Width = Unit.Percentage(100);

    //settings.KeyFieldName = "pKey";
    settings.Columns.Add("ISSUE_MEMBER").Visible = false;
    settings.Columns.Add("Date").PropertiesEdit.DisplayFormatString = "d";
    settings.Columns.Add("Dispatch_Mode");
    settings.Columns.Add("Dispatch_Status");
    settings.Columns.Add("Remarks");
    settings.Columns.Add("Copies");
}).Bind(Model).GetHtml()
