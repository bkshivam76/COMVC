    function OnMagazine_DispatchType_Set_Remove_Default(actionmethod)
    {
        {
            $.ajax({
                type: 'GET',
                url: "/Magazine/MagazineDispatchType/ButtonHide",
                cache: false,
                success: function (ButtonHide_result) {
                    if (ButtonHide_result.dataedit == true) {
                        var msg;
                        if (DispatchType_ID == 'undefined' || DispatchType_ID == undefined || DispatchType_ID == "null") {
                            if (actionmethod == 'Set_Default') {
                                msg = 'Please Select One Dispatch Type To Be Set As Default';
                            }
                            else if (actionmethod == 'Remove_Default') {
                                msg = 'Please Select One Dispatch Type Record'
                            }
                            DevExpress.ui.dialog.alert(msg, 'Alert ');
                            return;
                        }
                        $.ajax(
                            {
                                type: 'GET',
                                url: "/Magazine/MagazineDispatchType/Magazine_DispatchType_Set_Remove_Default",
                                data: { ActionMethod: actionmethod, id: DispatchType_ID },
                                cache: false,
                                success: function (Magazine_DispatchType_Set_Remove_DefaultClick_result) {
                                    if (Magazine_DispatchType_Set_Remove_DefaultClick_result.result == "true" || Magazine_DispatchType_Set_Remove_DefaultClick_result.result == true) {
                                        DevExpress.ui.dialog.alert(Magazine_DispatchType_Set_Remove_DefaultClick_result.Message, Magazine_DispatchType_Set_Remove_DefaultClick_result.data);
                                        DispatchTypeInfoGrid.Refresh();
                                    }
                                    else {
                                        DevExpress.ui.dialog.alert(Magazine_DispatchType_Set_Remove_DefaultClick_result.Message, Magazine_DispatchType_Set_Remove_DefaultClick_result.data);
                                    }
                                }
                            });
                    }
                    else {
                        DevExpress.ui.dialog.alert("Not Allowed!!", "NO Rights");
                    }
                }
            });
        }
           }
    function DispatchType_ContextMenuFunction(s, e) //right-click menu options
    {
        if (e.item.name == 'Remove_Default') {
         OnMagazine_DispatchType_Set_Remove_Default('Remove_Default');
        }
        if (e.item.name == 'Set_Default') {
          OnMagazine_DispatchType_Set_Remove_Default('Set_Default');
        }
        if (e.item.name == 'View') {
            OnViewButtonClick();
        }
        if (e.item.name == 'Delete') {
            OnDeleteButtonClick();
        }
        if (e.item.name == 'Edit') {
            OnEditButtonClick();
        }
        if (e.item.name == 'New') {
            OnNewButtonClick();
        }
        if (e.item.name == 'Clse') {
            btnCloseActiveTab();
        }
        else if (e.item.name == 'ListPreview') {
            OnDispatchTypeListPreviewClick();
        }
        else if (e.item.name == 'Refresh') {
            DispatchTypeInfoGrid.Refresh();
        }
    }
    function CollapseDispatchTypeRow(s, e)
    {
        IsAllDetailExpanded = "false";
        s.SetFocusedRowIndex(index);
                   }
    function ExpandDispatchTypeRow(s, e)
    {
        index =e.visibleIndex;
        s.SetFocusedRowIndex(-1);
        IsAllDetailExpanded = "true";
           }
</script>