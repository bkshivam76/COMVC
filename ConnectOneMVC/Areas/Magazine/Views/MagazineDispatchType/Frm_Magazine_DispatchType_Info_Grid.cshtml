@{
    var SessionGUID = Request.QueryString["SessionGUID"];
}
@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "DispatchTypeInfoGrid";
        settings.CallbackRouteValues = new
        {
            Controller = "MagazineDispatchType",
            Action = "Frm_Magazine_DispatchType_Info_Grid",
            FilterVisible = false,
            SearchVisible = false,
            ShowGroupedColumns = true,
            SessionGUID = SessionGUID
        };
        settings.Settings.VerticalScrollBarMode = ScrollBarMode.Auto;
        settings.SettingsDetail.AllowOnlyOneMasterRowExpanded =true;// set false for simultaneous nested grid
        settings.SettingsDetail.ShowDetailRow = true; //set true gor nested grid
        settings.KeyboardSupport = true;
        //settings.AccessKey = "G";
        settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
        //settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.HideDataCells;
        settings.SettingsBehavior.ProcessColumnMoveOnClient = true;
        settings.SettingsBehavior.ColumnMoveMode = GridColumnMoveMode.AmongSiblings;

        var ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;
        settings.SettingsCookies.Enabled = true;
        if (ShowHorizontalBar == 1)
        {
            settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Visible;
            settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.Off;
            settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.Control;
            settings.SettingsResizing.Visualization = ResizingMode.Postponed;
        }
        else
        {
            settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.HideDataCells;
            settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Hidden;
            settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.Disabled;
            //settings.SettingsAdaptivity.HideDataCellsAtWindowInnerWidth = 500;
        }

        settings.SettingsExport.EnableClientSideExportAPI = true;
        settings.SettingsExport.ExcelExportMode = DevExpress.Export.ExportType.DataAware;
        settings.SettingsExport.PageHeader.Center = "Dispatch Types";
        settings.SettingsExport.PageHeader.Left = Session["ExportGridHeaderLeft"].ToString();
        settings.SettingsExport.PageHeader.Right = Session["ExportGridHeaderRight"].ToString();
        settings.SettingsExport.PageFooter.Right = Session["ExportGridFooter"].ToString();
        //settings.SettingsExport.PageFooter.Left = "#";
        settings.SettingsExport.PageFooter.Font.Size = 7;
        settings.SettingsExport.PaperKind = System.Drawing.Printing.PaperKind.A4Rotated;
        settings.SettingsExport.TopMargin = 10;
        settings.SettingsExport.LeftMargin = 10;
        settings.SettingsExport.RightMargin = 10;
        settings.SettingsExport.BottomMargin = 10;
        settings.Settings.ShowGroupFooter = GridViewGroupFooterMode.VisibleAlways;

        settings.SettingsExport.GetExportDetailGridViews = (s, e) => //bind nested grid
        {
            string DispatchType_ID = (string)DataBinder.Eval(e.DataItem, "DispatchType_ID");
            GridViewExtension griddispatchcharges = new GridViewExtension(ConnectOneMVC.Areas.Magazine.Controllers.MagazineDispatchTypeController.CreateDispatchTypeChargesSettings(DispatchType_ID));
            griddispatchcharges.Bind(ConnectOneMVC.Areas.Magazine.Controllers.MagazineDispatchTypeController.GetDispatchTypeCharges(DispatchType_ID));
            e.DetailGridViews.Add(griddispatchcharges);
        };

        settings.SettingsDetail.ExportMode = GridViewDetailExportMode.Expanded;
        settings.SettingsDetail.ShowDetailRow = true;

        settings.SetDetailRowTemplateContent(c =>
        {
            string name= (string)DataBinder.Eval(c.DataItem, "Name");
            ViewContext.Writer.Write(
               "<b>"+ name+" : "+"Dispatch Charges"+"</b>"+
                "<br />"
            );
            Html.RenderAction("Frm_Magazine_DispatchType_DispatchCharges_Grid", new { DispatchType_ID = DataBinder.Eval(c.DataItem, "DispatchType_ID") });
        });

        settings.PreRender = (sender, e) =>
        {
            //  ((MVCxGridView)sender).DetailRows.ExpandRow(0);
            ((MVCxGridView)sender).FocusedRowIndex = 0;

        };

        // settings.CustomDataActionRouteValues = new { Controller = "DonRegister", Action = "DonRegisterCustomDataAction" };

        settings.CustomJSProperties = (s, e) =>
        {
            MVCxGridView gridView = (MVCxGridView)s;
            var lastVisibleColumn = gridView.VisibleColumns.LastOrDefault();
            e.Properties["cpLastVisibleColumnIndex"] = lastVisibleColumn != null ? lastVisibleColumn.Index : 0;
            e.Properties["cpHiddenColumnCaptions"] = gridView.AllColumns.Where(c => !c.Visible).ToDictionary(c => c.ToString(), c => c.Index);
        };

        settings.SettingsBehavior.AutoExpandAllGroups = true;
        settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
        settings.Settings.UseFixedTableLayout = true;
        settings.SettingsBehavior.AllowSort = true;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.Settings.ShowHeaderFilterButton = true;
        settings.Settings.ShowFilterRow = false;
        settings.Settings.AutoFilterCondition = AutoFilterCondition.Contains;
        settings.SettingsSearchPanel.ShowApplyButton = true;
        settings.SettingsPager.Mode = GridViewPagerMode.ShowAllRecords;
        settings.SettingsSearchPanel.ShowClearButton = true;
        settings.SettingsBehavior.AllowFocusedRow = true;
        settings.Settings.ShowHeaderFilterBlankItems = false;

        settings.BeforeGetCallbackResult = (s, e) =>
        {
            MVCxGridView gridView = s as MVCxGridView;
            foreach (GridViewDataColumn column in gridView.DataColumns)
            {
                if (column.Visible)
                    column.Settings.AllowSort = DefaultBoolean.True;
                else
                    column.Settings.AllowSort = DefaultBoolean.False;
            }
        };

        settings.SettingsContextMenu.Enabled = true;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsContextMenu.EnableGroupFooterMenu = DefaultBoolean.True;
        settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;
        settings.SettingsPager.Mode = GridViewPagerMode.ShowAllRecords;

        settings.FillContextMenuItems = (sender, e) =>   // Create Context Menu here
        {
            if (e.MenuType == GridViewContextMenuType.Rows)
            {

                var Additem = e.CreateItem("New", "New"); //new option
                Additem.BeginGroup = true;
                Additem.Image.IconID = "actions_task_16x16devav";
                Additem.Visible =Convert.ToBoolean(Session["newright"]);
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Additem);

                var Edititem = e.CreateItem("Edit", "Edit");//edit option
                Edititem.BeginGroup = true;
                Edititem.Image.IconID = "actions_print_16x16devav";
                Edititem.Visible = Convert.ToBoolean(Session["editright"]);
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Edititem);

                var Deleteitem = e.CreateItem("Delete", "Delete");//delete option
                Deleteitem.BeginGroup = true;
                Deleteitem.Image.IconID = "actions_delete_16x16devav";
                Deleteitem.Visible = Convert.ToBoolean(Session["editright"]);
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Deleteitem);

                var Setdefault = e.CreateItem("Set As Default", "Set_Default");//Set default
                Setdefault.BeginGroup = true;
                Setdefault.Visible = Convert.ToBoolean(Session["editright"]);
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Setdefault);

                var Removedefault = e.CreateItem("Remove Default(s)", "Remove_Default");//remove default option
                Removedefault.BeginGroup = true;
                Removedefault.Visible = Convert.ToBoolean(Session["editright"]);
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Removedefault);

                var Viewitem = e.CreateItem("View", "View");//view option
                Viewitem.BeginGroup = true;
                Viewitem.Image.IconID = "print_tasklist_16x16devav";
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Viewitem);

                var PrintViewitem = e.CreateItem("List Preview", "ListPreview");//List preview option
                PrintViewitem.Image.IconID = "actions_hideproduct_16x16devav";
                PrintViewitem.BeginGroup = true;
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), PrintViewitem);

                var Closeitem = e.CreateItem("Close", "Clse");//Close option
                Closeitem.Image.IconID = "actions_close_16x16devav";
                Closeitem.BeginGroup = true;
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Closeitem);
            }
        };

        // DXCOMMENT: Specify the grid's key field name and define grid columns in accordance with data model fields

        settings.KeyFieldName = "DispatchType_ID";

        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Name";
                column.Caption = "Name";
                column.Visible = true;
                column.Width = 125;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "DispatchType_ID";
                column.Caption = "ID";
                column.Width = 175;
                column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "DispatchType_Default";
                column.Caption = "Default";
                column.Width =125;
                column.ColumnType = MVCxGridViewColumnType.CheckBox;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "AddBy";
                column.Caption = "Add By";
                column.Width = 100; column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "AddDate";
                column.Caption = "Add Date";
                column.Width = 100;
                column.ColumnType = MVCxGridViewColumnType.DateEdit; column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "EditBy";
                column.Caption = "Edit BY";
                column.Width = 100; column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "EditDate";
                column.Caption = "Edit Date";
                column.ColumnType = MVCxGridViewColumnType.DateEdit;
                column.Width = 100; column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "ActionStatus";
                column.Caption = "Action Status";
                column.Width = 125; column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "ActionBy";
                column.Caption = "Action By";
                column.Width = 100; column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "ActionDate";
                column.Caption = "Action Date";
                column.Width = 100; column.Visible = false;
                column.ColumnType = MVCxGridViewColumnType.DateEdit;
            }
        });

        // show filter control
        settings.Settings.ShowFilterBar = GridViewStatusBarMode.Visible;
        settings.SettingsFilterControl.ViewMode = true ? FilterControlViewMode.VisualAndText : FilterControlViewMode.Visual;
        settings.SettingsFilterControl.AllowHierarchicalColumns = true;// AllowHierarchicalColumns;
        settings.SettingsFilterControl.ShowAllDataSourceColumns = true;//FilterBuilderDemoHelper.Options.ShowAllDataSourceColumns;
        settings.SettingsFilterControl.MaxHierarchyDepth = 1;
        settings.Settings.ShowFooter = true;
        settings.SettingsCustomizationDialog.ShowSortingPage = true;
        settings.SettingsCustomizationDialog.ShowGroupingPage = true;
        settings.SettingsCustomizationDialog.ShowFilteringPage = true;
        settings.SettingsCustomizationDialog.ShowColumnChooserPage = true;

        settings.Settings.ShowGroupedColumns = true;
        settings.ClientSideEvents.Init = "DispatchType_OnInit";
        //settings.ClientSideEvents.CustomizationWindowCloseUp = "DispatchTypegrid_CustomizationWindowCloseUp";
        settings.ClientSideEvents.ContextMenuItemClick = "DispatchType_ContextMenuFunction";
        settings.ClientSideEvents.BeginCallback = "OnDispatchTypeInfoGrid_BeginCallBack";
        settings.ClientSideEvents.FocusedRowChanged = "OnDispatchTypeGridFocusedRowChanged";
        settings.ClientSideEvents.EndCallback = "OnGridDispatchTypeListGrid_EndCallback";
        settings.ClientSideEvents.DetailRowExpanding = "ExpandDispatchTypeRow";
        settings.ClientSideEvents.DetailRowCollapsing = "CollapseDispatchTypeRow";
        settings.ClientSideEvents.RowDblClick= "OnEditButtonClick";

    }).Bind(Model).GetHtml()

