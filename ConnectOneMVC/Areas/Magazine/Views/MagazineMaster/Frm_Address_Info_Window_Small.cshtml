                    $.ajax({
                        type: "GET",
                        url: "/Magazine/MagazineMaster/xPromptWindow",
                        data: {
                            PromptMsg: data.Message,
                            tempActionMethod: data.successParams.tempActionMethod,
                            xID: data.successParams.XID,
                            Org_RegId : data.successParams.Org_RegId,
