                            GLookUp_RStateList: data.successParams.gLookUp_RStateList,
                            GLookUp_RDistrictList:data.successParams.gLookUp_RDistrictList,
                            GLookUp_RCountryList:data.successParams.gLookUp_RCountryList,
                            Txt_R_Pincode:data.successParams.txt_R_Pincode,
                            Txt_Mob_1:data.successParams.txt_Mob_1,
                            Txt_Email1:data.successParams.txt_Email1,
                            Txt_Remark1:data.successParams.txt_Remark1,
                            Txt_Remark2: data.successParams.txt_Remark2,
                            Txt_R_Tel_1: data.successParams.txt_R_Tel_1,
                        },
                        success: function (data1) {
                            //if (typeof (data1) != "string")
                            {
                                $("#Id_DuplicatePopup").dxPopup("show");
                                $("#Id_DuplicatePopup").dxPopup("instance").option("maxHeight", "30%")
                                $("#Id_DuplicatePopup").dxPopup("instance").option("maxWidth", "50%")
                                $("#Id_DuplicatePopupResult").html(data1)
                            }
                        },
                        error: function (e) {
                            debugger
                        }
                    });
                }
            },
            error: function (e) {
                debugger
            }
        });
    }

    $("#Txt_R_Tel_1,#Txt_R_Pincode,#Txt_Mob_1").keypress(function (e) {
        debugger
        if (e.which != 8 && e.which != 0 && (e.which < 48 || e.which > 57)) {

