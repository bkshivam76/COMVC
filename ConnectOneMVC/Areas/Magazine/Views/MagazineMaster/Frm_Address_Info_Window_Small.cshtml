<script>
    var resCountryCode = "";
    var resStateCode = "";
    var CI_REC_ID = "";
    function onInitialized_AddressBook_R(e) {
        e.component.option("dataSource").store.load().done(function (d) {
            if (d.length == 1)
                e.component.option("value", d[0].R_CO_NAME);
        });

        var key = e.component.option("value");
        if(key!=null)
        {
            if (e.component.getDataSource()!=null) {
                e.component.getDataSource().store().byKey(key).done(function (result) {
                    if (result != null && result != undefined && result != "undefined") {

                        resCountryCode = result.R_CO_CODE;
                        resCountryId = result.R_CO_REC_ID;
                        $("#GLookUp_RStateList").dxDropDownBox("instance").repaint();
                        //$("#Res_StateID").dxDropDownBox("instance").reset("",result.R_CO_CODE);
                        resStateCode = "@Model.tempStateCode";
                        $("#Res_DisttID").dxDropDownBox("instance").repaint();
                        $("#Res_cityID").dxDropDownBox("instance").repaint();
                    }
                })
            }
        }
    }
    function ChangeAddressBookCountry_R(e) {
        debugger
        var dropDownBoxonInitialized_AddressBookCountry = $("#GLookUp_RCountryList").dxDropDownBox("instance");
        dropDownBoxonInitialized_AddressBookCountry.close();

        var $dataGrid = $("#CountryList-datagrid_R");

        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(e.value, false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                resCountryCode = item.R_CO_CODE;
                resCountryId = item.R_CO_REC_ID;
                $("#StateList-datagrid_R").dxDataGrid("instance").refresh();
            }
        }
    }
    function ChangeAddressBookState_R(e) {
        var dropDownBox = $("#GLookUp_RStateList").dxDropDownBox("instance");
        dropDownBox.close();

        var $dataGrid = $("#StateList-datagrid-R");

        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(e.value, false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                resStateCode = item.R_ST_CODE;
                if (resStateCode != "" || resCountryCode != "") {
                    $("#GLookUp_RStateList").dxDropDownBox("instance").option("readOnly", false);
                    $("#DistrictList-datagrid_R").dxDataGrid("instance").refresh();
                }
                if (resStateCode != "" || resCountryCode != "" || resCountryId != "") {
                    $("#Res_cityID").dxDropDownBox("instance").option("readOnly", false);
                    $("#CityList-datagrid").dxDataGrid("instance").refresh();
                }
            }
        }
    }
    function onInitialized_AddressBookState_R(e) {
        e.component.option("dataSource").store.load().done(function (d) {
            if (d.length == 1)
                e.component.option("value", d[0].R_ST_NAME);
        });
    }
    function ChangeAddressBookDistrict_R(e) {
        debugger
        var dropDownBox = $("#DistrictList-datagrid_R").dxDropDownBox("instance");
        dropDownBox.close();

        var $dataGrid = $("#DistrictList-datagrid_R");

        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(e.value, false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                resDistrictCode = item.R_DI_CODE;
                if (resStateCode != "" || resCountryCode != "" || resCountryId != "") {
                    //$("#CityList-datagrid").dxDataGrid("instance").refresh();
                }
            }
        }
    }
