    function MappingListdblclickEdit(s,e) {
        debugger
        var temp = e;
        var key = s.GetRowKey(s.GetFocusedRowIndex());
        s.GetRowValues(s.GetFocusedRowIndex(), 'CityName;StateName;City_REC_ID', AddressOnGetRowValues);

    }
    function AddressOnGetRowValues(data) {
        debugger
        var temp = data;
        CI_REC_ID = temp[2];
        $('#PC_City_Name').dxTextBox('instance').option('value', temp[0]);
        $("#ID_City").dxPopup("hide");
    }
    function handleClick(e) {
        debugger
        var elementID = e.id;
        if (elementID == "id_City") {
            $("#id_City").parent(1).removeClass("opacityClass");
            $("#id_OthCity").parent(1).addClass("opacityClass");
            $("#id_CityTxtCButtons").removeClass("opacityClass");
            $("#id_CityTxtCButtons").removeClass("disabledbutton")
            $("#id_Search").children(1).replaceWith('<span onclick="to_Get_MembersList();" class="dx-button-text">Search</span>');
            $("#id_MoreDetails").children(1).replaceWith('<span onclick="to_Get_MembersList()" class="dx-button-text">More Details</span>');
            $("#Txt_R_Other_City").dxTextBox("instance").option("readOnly", true);
            $("#Txt_R_Other_City").dxTextBox("instance").option("value", "");
            $("#PC_City_Name").dxTextBox("instance").option("readOnly", false);

        }
        if (elementID == "id_OthCity") {
            $("#id_City").parent(1).addClass("opacityClass");
            $("#id_OthCity").parent(1).removeClass("opacityClass");
            $("#id_CityTxtCButtons").addClass("opacityClass");
            $("#id_Search").children(1).replaceWith('<span class="dx-button-text">Search</span>');
            $("#id_MoreDetails").children(1).replaceWith('<span class="dx-button-text">More Details</span>');
            $("#PC_City_Name").dxTextBox("instance").option("readOnly", true);
            $("#PC_City_Name").dxTextBox("instance").option("value","");
            $("#Txt_R_Other_City").dxTextBox("instance").option("readOnly", false);
            //$("#id_CityTxtCButtons").addClass("disabledbutton")

        }
    }

    function Frm_Address_Info_Window_Small_Success(data) {
        debugger
        HideLoader();
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.Message, "Error");
        }
        else {

            IsSucessPopup = true;
            var telephoneSubmitSuccess = DevExpress.ui.dialog.alert(data.Message, "Success");
            $("#popup_frm_Telephone_Window").dxPopup("hide");
            TelephoneListGrid.Refresh();
            IsSucessPopup = false;
            telephoneSubmitSuccess.done(function (alertResult) {
                if (alertResult) {
                    if (IsTelephoneNewPopup == true) {
                        var addmoreTelephoneresult = DevExpress.ui.dialog.confirm("Add More Entry...?", "Telephone");
                        addmoreTelephoneresult.done(function (dialogResult) {
                            if (dialogResult) {
                                OnTelephoneNewClick();
                            }
                        });
                    }
                }
            });

        }
    }
    function toEditOrNew(XId, Org_RegId, tempActionMethod) {
