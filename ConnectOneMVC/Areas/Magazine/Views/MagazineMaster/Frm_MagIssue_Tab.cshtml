    // Set as defaults and Remove Defaults

    function MagIssueUpdateFooterDetail(ID, ActionIssues_Status, AddIssues_Date, AddIssues_By, ActionIssues_Date, ActionIssues_By, EditIssues_Date, EditIssues_By) {

        var Status = "";
        var Lbl_Status = "";
        var Lbl_StatusBy = "";
        var Pic_Status = "";
        var Lbl_Create = "";
        var Lbl_Modify = "";
        var Lbl_Status_Color = "";
        var Add_Date = "";
        var Add_By = "";
        var Status_On = "";
        var Status_By = "";
        var StatusStr = "Completed";
        var Lbl_StatusOn = "";
        var Lbl_StatusBy = "";

        Status = Action_Status;

        Add_Date = Add_Date;
        Add_By = Add_By;
        Status_On = Action_Date;
        Status_By = Action_By;

        if (Status_On) {
            Lbl_StatusOn = StatusStr + " On: " + Status_On;
            Lbl_StatusBy = StatusStr + " By: " + Status_By;
        }
        else {
            Lbl_StatusOn = StatusStr + " On: " + "?";
            Lbl_StatusBy = StatusStr + " By: " + Status_By;
        }

        if (Add_Date) {
            Lbl_Create = "Add On: " + Add_Date + ", By: " + Add_By;
        }
        else {
            Lbl_Create = "Add On: " + "?, By: " + Add_By;
        }

        var Edit_Date = "";
        var Edit_By = "";

        Edit_Date = Edit_Date;
        Edit_By = Edit_By;

        if (Edit_Date) {
            Lbl_Modify = "Edit On: " + Edit_Date + ", By: " + Edit_By;
        }
        else {
            Lbl_Modify = "Edit On: " + "?, By: " + Edit_By;
        }
        $('#obI_Lbl_ActionOn').text(Lbl_StatusOn)
        $('#obI_Lbl_ActionBy').text(Lbl_StatusBy);
        $('#obILbl_Create').text(Lbl_Create);
        $('#obILbl_Modify').text(Lbl_Modify);
        if (Lbl_Status_Color != "") {
            $('#obILbl_Status').css('color', Lbl_Status_Color);
        }
        if (Pic_Status != "") {
            $('#obI_LockICON').css('class', Pic_Status);
        }
    }
