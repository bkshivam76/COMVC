    //Create Similar Issues
    // Set as defaults and Remove Defaults
    function OnMagazineDefaultClick() {

        if (IssueID == 'undefined' || IssueID == undefined) {
            DevExpress.ui.dialog.alert('Please Select a valid Issue!!', 'Alert ');
            return;
        }
                $.ajax({
                    type: 'GET',
                    url: "/Magazine/MagazineMaster/SetasDefaultIssue",
                    data: { id: IssueID },
                    cache: false,
                    success: function (Default_Issues_ButtonClick_result) {
                        if (Default_Issues_ButtonClick_result.result == "true" || Default_Issues_ButtonClick_result.result == true) {
                            DevExpress.ui.dialog.alert(Default_Issues_ButtonClick_result.Message, 'Set Issue as Default!');
                            MagIssueGrid.Refresh();
                        }
                        else {
                            DevExpress.ui.dialog.alert(Default_Issues_ButtonClick_result.Message, 'Warning!');
                            MagIssueGrid.Refresh();
                        }
                    }      
        });
    }

    function OnMagazineRemoveDefaultClick() {

        $.ajax({
            type: 'GET',
            url: "/Magazine/MagazineMaster/RemoveDefaultIssue",
            data: { },
            cache: false,
            success: function (RemoveDefault_Issues_ButtonClick_result) {
