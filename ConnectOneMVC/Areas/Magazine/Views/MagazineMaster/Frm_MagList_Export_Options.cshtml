@using DevExtreme.AspNet.Mvc;
<div>
    @(Html.DevExtreme().Button()
                .ID("MagList_ExportGridDatapdf")
                .Text("Export to PDF")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                //.AccessKey("x")
                .OnClick("ExportPDF")
                .Visible(true)
                .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                .ID("MagList_ExportGridDataxls")
                .Text("Export to XLS")
                //.Icon("fa-file-excel-o")
                //.AccessKey("X")
                .OnClick("ExportXLS")
                .Visible(true)
                .Width(120)
    )<br />
    @(Html.DevExtreme().Button()
                .ID("MagList_ExportGridDataxlsx")
                .Text("Export to XLSX")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                //.AccessKey("L")
                .OnClick("ExportXLSX")
                .Visible(true)
                .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                .ID("MagList_ExportGridDatadocx")
                .Text("Export to DOCX")
                //.Icon("export_exporttodocx_16x16office2013")
                //.AccessKey("D")
                .OnClick("ExportDOCX")
                .Visible(true)
                .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                .ID("MagList_ExportGridDatartf")
                .Text("Export to RTF")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                //.AccessKey("R")
                .OnClick("ExportRTF")
                .Visible(true)
                .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                .ID("MagList_ExportGridDatacsv")
                .Text("Export to CSV")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                //.AccessKey("C")
                .OnClick("ExportCSV")
                .Visible(true)
                .Width(120)
    )
</div>
<script>
    function ExportPDF() {
        MagListGrid.ExportTo(ASPxClientGridViewExportFormat.Pdf);
        $("#Magazine_report_modal").dxPopup("hide");
    }
    function ExportXLS() {
        MagListGrid.ExportTo(ASPxClientGridViewExportFormat.Xls);
        $("#Magazine_report_modal").dxPopup("hide");
    }
    function ExportXLSX() {
        MagListGrid.ExportTo(ASPxClientGridViewExportFormat.Xlsx);
        $("#Magazine_report_modal").dxPopup("hide");
    }
    function ExportCSV() {
        MagListGrid.ExportTo(ASPxClientGridViewExportFormat.Csv);
        $("#Magazine_report_modal").dxPopup("hide");
    }
    function ExportDOCX() {
        MagListGrid.ExportTo(ASPxClientGridViewExportFormat.Docx);
        $("#Magazine_report_modal").dxPopup("hide");
    }
    function ExportRTF() {
        MagListGrid.ExportTo(ASPxClientGridViewExportFormat.Rtf);
        $("#Magazine_report_modal").dxPopup("hide");
    }
</script>
