<style>
    .report_button_div .dx-button-has-icon .dx-button-content {
        padding-right: 7px !important;
    }
</style>
<div id="content" class="row col-md-12 report_header_div_main">
    <div class="col-md-4 report_header_div">
        <label class="report_header_label">Magazine Masters</label>
    </div>
    @*Buttons*@
    <div class="report_button_div">
        @(Html.DevExtreme().Button()
                       .ID("MagazineUnlock")
                       .Text("Unlock")
                       .Icon("add")
            .Visible(true)
            .Disabled(false)
        .OnClick(@<text>
            function () {
            OnMagazineUnlockClick();
            }
        </text>)
        )

        @(Html.DevExtreme().Button()
                        .ID("MagazineLock")
                        .Text("Lock")
                        .Icon("add")
            .Visible(true)
            .Disabled(false)
            .OnClick(@<text>
                function () {
                OnMagazineLockClick();
                }
            </text>)
        )
        @(Html.DevExtreme().Button().ID("MagzineNew").Text("New").Icon("add").Visible(true)
