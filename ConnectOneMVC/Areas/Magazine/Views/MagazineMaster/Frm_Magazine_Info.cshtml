<div class="col-md-12">
    @(Html.DevExtreme().TabPanel()
                        .ID("MagtabPanel")
                        .Items(items =>
                        {
                            items.Add().Title("Magazine List").Template(@<text>
                                @MagListView()
                            </text>);
                                    items.Add().Title("Subscription Types").Template(@<text>
                                        @MagSubTypeView()
                                    </text>);
                                items.Add().Title("Subscription Fees").Template(@<text>
                                        @MagSubFeesView()
                                    </text>);
                                            items.Add().Title("Issue Information").Template(@<text>
                                                @MagIssueView()
                                            </text>);
                                        })

                                        .OnSelectionChanged("MagTabPanelSelectionChanged")
    )

    @helper MagListView()
        {
            if (Model.showMagazineList == null)
            {
                Model.showMagazineList = new List<ConnectOneMVC.Areas.Magazine.Models.MagazineList>();
            }
            @Html.Partial("Frm_MagList_Tab", Model.showMagazineList);
      }
    @helper MagSubTypeView()
        {
            if (Model.showMagazineSubType == null)
            {
                Model.showMagazineSubType = new List<ConnectOneMVC.Areas.Magazine.Models.MagazineSubType>();
            }
            @Html.Partial("Frm_MagSubType_Tab", Model.showMagazineSubType);
      }
    @helper MagSubFeesView()
                {
                if (Model.showMagazineSubFees == null)
                {
                    Model.showMagazineSubFees = new List<ConnectOneMVC.Areas.Magazine.Models.MagazineSubFees>();
                }
                    @Html.Partial("Frm_MagSubFees_Tab", Model.showMagazineSubFees);
        }
            @helper MagIssueView()
                {
            if (Model.showMagazineIssues == null)
            {
                Model.showMagazineIssues = new List<ConnectOneMVC.Areas.Magazine.Models.MagazineIssues>();
            }
                    @Html.Partial("Frm_MagIssue_Tab", Model.showMagazineIssues);
        }
</div>

