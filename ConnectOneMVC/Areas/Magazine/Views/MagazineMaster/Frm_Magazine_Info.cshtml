                                                                                                                    OnMagazineEditClick();
                                                                                                                    }
                                                                                                                </text>))

        @(Html.DevExtreme().Button().ID("MagazineDelete").Visible(true).Text("Delete")
                                                                                                                   .OnClick(@<text>
                                                                                                                    function()
                                                                                                                    {OnMagazineDeleteClick();}
                                                                                                                </text>)
        )

        @(Html.DevExtreme().Button()
                                                                                                                            .ID("MagazineView")
                                                                                                                            .Text("View")
                                                                                                                            .Visible(true)
                                                                                                                            .Disabled(false)
