@using DevExtreme.AspNet.Mvc;

@model ConnectOneMVC.Areas.Magazine.Models.MagazineMaster
@{
    /**/

    ViewBag.Title = "Index";
    Layout = null;
}
<script>
    var MagazineTabIndex = 1;
    var MagSubTypeId = 0;
    var IsNewPopup = false;
    var IsSucessPopup = false;
    var IsViewPopup = false;
    $(document).ready(function () {
        //$("#CoreModelListPreview").hide();
    });
    function MagTabPanelSelectionChanged(e) {
        debugger
        if (e.addedItems[0].title == "Magazine List") {
            MagazineTabIndex = 1;
        }
        else if (e.addedItems[0].title == "Subscription Types") {
            MagazineTabIndex = 2;
            MagSubTypeId = 1;
            RebindSubscriptionType();
        }
        else if (e.addedItems[0].title == "Subscription Fees") {
            MagazineTabIndex = 3;
            RebindSubscriptionTypeFees();
        }
        else if (e.addedItems[0].title == "Issue Information") {
            MagazineTabIndex = 4;
        }

    }
    //Rebinding Partial Subscription Type
    function RebindSubscriptionType()
    {
        $.ajax({
            url: '@Url.Action("Frm_MagSubType_Tab_Grid", "MagazineMaster")',
            type: "GET",
            data: { Id: ID },
            success: function (res) {
                $("#PartialViewResult").show();
                $("#PartialViewResult").html("");
                $("#PartialViewResult").html(res);             
            }
        });
    }
    //Rebinding Partial Subscription Type

    //Rebinding Partial Subscription Type Fees
   // MagSubTypeId=0 Means Subscription Type tab not Selected , 1 means Already Tab Selected
    function RebindSubscriptionTypeFees() {
        if (MagSubTypeId == 0 || MagSubTypeId == "0") {
            DevExpress.ui.dialog.alert('Please Select Subscription Types Tab', 'Alert ');
            return;
        }
        $.ajax({
            url: '@Url.Action("Frm_MagSubFees_Tab_Grid", "MagazineMaster")',
            type: "GET",
            data: { Id: SubTypeID },
            success: function (res) {
                $("#PartialViewFees").show();
                $("#PartialViewFees").html("");
                $("#PartialViewFees").html(res);
            }
        });
    }
    //Rebinding Partial Subscription Type Fees

    function OnMagazineNewClick() {
        IsNewPopup = true;
        IsViewPopup = false;
        if (MagazineTabIndex == 1)
        {
            $("#popup_frm_Mag_Window").dxPopup("show");
            $("#popup_frm_Mag_Window").dxPopup("instance").option("title", "New ~ Maglist");
            $("#Magazineviewresult").html('');
            ShowLoader();
            $("#Magazineviewresult").load("@Url.Action("Frm_Magazine_Window", "MagazineMaster", new { @area = "Magazine" })?ActionMethod=New", function () {
                HideLoader();
            });
        }

       else if (MagazineTabIndex == 2)
       {
            $("#popup_frm_Mag_Window").dxPopup("show");
            $("#popup_frm_Mag_Window").dxPopup("instance").option("title", "New ~ Subscription Type");
