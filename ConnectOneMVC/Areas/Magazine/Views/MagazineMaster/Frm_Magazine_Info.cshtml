           $("#popup_frm_Mag_Window").dxPopup("instance").option("title", "New ~ New Magazine Issue");
           $("#Magazineviewresult").html('');
           ShowLoader();
           $("#Magazineviewresult").load("@Url.Action("Frm_Magazine_Issues_Window", "MagazineMaster", new { @area = "Magazine" })?ActionMethod=" + "New" + "&MagListID=" + ID + "&MagazineName=" + Name, function () {
               HideLoader();
           });
       }
    }


