            ShowLoader();
            $("#Magazineviewresult").load("@Url.Action("Frm_Magazine_ST_Window", "MagazineMaster", new { @area = "Magazine" })?ActionMethod=" + "New" + "&MagListID=" + ID, function () {
                HideLoader();
            });
       }
       else if (MagazineTabIndex == 3)
       {
           if (MagSubTypeId == 0 || MagSubTypeId == "0") {
               DevExpress.ui.dialog.alert('Please Select Subscription Types Tab', 'Alert ');
               return;
           }
           $("#popup_frm_Mag_Window").dxPopup("show");
           $("#popup_frm_Mag_Window").dxPopup("instance").option("title", "New ~ Subscription Type Fees");
           $("#Magazineviewresult").html('');
           ShowLoader();
           $("#Magazineviewresult").load("@Url.Action("Frm_Magazine_STF_Window", "MagazineMaster", new { @area = "Magazine" })?ActionMethod=" + "New" + "&SubTypeID=" + SubTypeID, function () {
               HideLoader();
           });
