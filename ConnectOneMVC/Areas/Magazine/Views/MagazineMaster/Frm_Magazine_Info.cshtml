    function MagListAjaxSuccessForm(data) {
        HideLoader();
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.Message, "Error");
            //$("#popup_frm_Bank_Window").dxPopup("hide");
            MagListGrid.Refresh();
        }
        else {
            IsSucessPopup = true;
            var SubmitSuccess = DevExpress.ui.dialog.alert(data.Message, "Magazine List");
            $("#popup_frm_Mag_Window").dxPopup("hide");
            MagListGrid.Refresh();
            IsSucessPopup = false;
            SubmitSuccess.done(function (alertResult) {
                if (alertResult) {
                    if (IsNewPopup == true) {
                        var addmoreOBresult = DevExpress.ui.dialog.confirm("Add More Entry...?", "Magazine List");
                        addmoreOBresult.done(function (dialogResult) {
                            if (dialogResult) {
                                OnMagazineNewClick();
                            }
                        });
                    }
                }
            });
        }
    }

