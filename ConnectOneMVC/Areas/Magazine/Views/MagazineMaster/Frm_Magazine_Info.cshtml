    function OnMagazineUnlockClick()
    {
        if (MagazineTabIndex == 1) {
            DevExpress.ui.dialog.alert('Not Available!!', 'UnLock Magazine ...');
        }
       else if (MagazineTabIndex == 2) {
           DevExpress.ui.dialog.alert('Not Available!!', 'UnLock Magazine Subs type...');
       }
       else if (MagazineTabIndex == 3) {
           DevExpress.ui.dialog.alert('Not Available!!', 'Unlock Magazine Subs type Fee...');
       }
       else if (MagazineTabIndex == 4) {
           DevExpress.ui.dialog.alert('Not Available!!', 'Unlock Magazine Issue...');
       }
    }

