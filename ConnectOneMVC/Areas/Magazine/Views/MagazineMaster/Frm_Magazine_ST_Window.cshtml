                                        <div class="dx-button-content">
                                            <i class="fas fa-times-circle btn-icons crossgrey icon-rgt-space5"></i>
                                            <span class="dx-button-text">Cancel</span>
                                        </div>
                                    </a>
                                </div>

                            </div>

                            <div class="action-btn-sec-wrap">
                                <div class="dx-button dx-button-normal dx-widget dx-button-has-text" role="button" aria-label="Price History" tabindex="0">
                                    <a href="javascript:void(0);" class="link-txt">
                                        <div class="dx-button-content">
                                            <i class="fas fa-check-circle btn-icons checkgreen icon-rgt-space5"></i>
                                            <span class="dx-button-text">Save</span>
                                            <input type="submit" class="dx-button-submit-input">
                                        </div>
                                    </a>
                                </div>

                            </div>*@
                        @if (Model.ActionMethod.ToString().Trim() == "_View")
