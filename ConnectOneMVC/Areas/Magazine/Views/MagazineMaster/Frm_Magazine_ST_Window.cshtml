                                                               UpdateTargetId = "MagSubTypeWindow",
                                                               InsertionMode = InsertionMode.InsertAfter,
                                                               OnBegin = "AjaxBeginFormPost",
                                                               OnSuccess = "MagSubTypeAjaxSuccessForm"
                                                           },
