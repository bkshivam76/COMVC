</div>

<script>
    $(document).ready(function () {
        $("#Maglistvalue").html(Name + ', ' + Language);
    });
    
    $("#MinMonths").keypress(function (e) {
        debugger;
        e = e || window.event;
        key = e.keyCode || e.which;
        //For Firefox
        if (key == 8 || key == 127 || key == 9)
            return true
        var txt = String.fromCharCode(key);
        var reg = /[0-9.]/;
        if (reg.test(txt))
            return true;
        e.preventDefault();
        return false;
        
    });
</script>


