@using DevExtreme.AspNet.Data
@using DevExtreme.AspNet.Mvc
@(Html.DevExtreme().DataGrid()
    .ID("DistrictList-datagrid_R")
    .DataSource(new JS(@"component.option(""dataSource"")"))
    .Columns(columns=>
    {
        columns.Add().DataField("R_DI_NAME").Caption("District");
        columns.Add().DataField("R_DI_CODE").Visible(false);
    })
    .HoverStateEnabled(true)
    .Paging(p=>p.PageSize(10))
    .FilterRow(f=>f.Visible(false))
    .Scrolling(s=>s.Mode(GridScrollingMode.Infinite))
    .Height(260)
    .OnSelectionChanged(@<text> function() { var keys=selectedItems.selectedRowKeys;component.option("value",keys) } </text>))
