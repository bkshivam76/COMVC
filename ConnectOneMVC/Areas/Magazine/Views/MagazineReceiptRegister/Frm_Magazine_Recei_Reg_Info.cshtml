            }
        ShowLoader();
       $.ajax({
            url: '@Url.Action("MagazineReceiptRegister_Print", "MagazineReceiptRegister")',
           type: "GET",
           data: { ID: xtemp_ID },
            success: function (res)
            {
                HideLoader();
                $("#PopUp_GenerateREciept").dxPopup("hide");
                if (res.jsonParam != undefined) {
                    DevExpress.ui.dialog.alert(res.jsonParam.message, res.jsonParam.title);
