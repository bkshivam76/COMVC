    var xtemp_1;
    var xtemp_2;
    var xtemp_3;
    var xtemp_4;
    var xtemp_5;
    var xtemp_6;
    var memDate;
    var vdate;
    var xDate;
    var receiptNo;
    var receipt_ID;
    var Row_Index = 0;
    function MagazineRegGrid_BeginCallBack(s, e) {
        e.customArgs["command"] = e.command;
        Row_Index = MagazineReceiRegListGrid.GetFocusedRowIndex();
        e.customArgs["ShowHorizontalBar"] = MagazineRR_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = MagazineRR_IsVouchingMode;
        e.customArgs["ViewMode"] = MagazineRR_ViewMode;
        e.customArgs["ColumnToBeShownIndex"] = MagazineRR_ColumnToBeShownIndex;
        e.customArgs["ColumnToBeHidddenIndex"] = MagazineRR_ColumnToBeHidddenIndex;
        //e.customArgs["RowKeyToFocus"] = Select_xid;
    }
    function OnMagazineRegGridDBClick(s,e) {
        var key = s.GetRowKey(s.GetFocusedRowIndex());
        MagazineReceiRegListGrid.GetValuesOnCustomCallback({ key: key }, MagRegDbClickOnGetRowValues);
        Row_Index = MagazineReceiRegListGrid.GetFocusedRowIndex();
    }
    function OnMagazineRegGridFocusedRowChanged(s, e) {

        var key = s.GetRowKey(s.GetFocusedRowIndex());
        s.GetRowValues(s.GetFocusedRowIndex(), 'ID;Membership ID;Member Name;MM_MEMBER_ID;Add By;Add Date;Edit By;Edit Date;Action Status;Action By;Action Date;Period;Subs.Type;Total Amount;MM_MEMBER_TYPE;Start Date;Date;Receipt No.;Receipt ID;MS_REC_ID', MagRegOnGetRowValues);
        //MagazineReceiRegListGrid.GetValuesOnCustomCallback({ key: key }, MagRegOnGetRowValues);
        Row_Index = MagazineReceiRegListGrid.GetFocusedRowIndex();
    }
    function MagRegOnGetRowValues(values) {
        debugger;
        //var values = FDData.split("![");
        Reg_ID = values[0];
        Reg_Membership_ID = values[1];
        Reg_Member_Name = values[2];
        Reg_MM_MEMBER_ID = values[3];
        Reg_Add_By = values[4];
        Reg_Add_Date = values[5];
        Reg_Edit_By = values[6];
        Reg_Edit_Date = values[7];
        Reg_Action_Status = values[8];
        Reg_Action_By = values[9];
        Reg_Action_Date = values[10];
        xtemp_ID = values[0];
        xtemp_0 = values[2];
        xtemp_1 = values[1];
        xtemp_2 = values[12];
        xtemp_3 = values[11]
        xtemp_4 = values[13];
        xtemp_5 = values[3];
        xtemp_6 = values[14];
        memDate = values[15];
        vdate = values[16];
        xDate = values[5];
        receiptNo = values[17];
        receipt_ID = values[18];
        MS_REC_ID = values[19];
        Member_Name = values[2];
        MagReg_UpdateFooterDetail(Reg_ID, Reg_Action_Status, Reg_Add_Date, Reg_Add_By,
        Reg_Action_Date, Reg_Action_By, Reg_Edit_Date, Reg_Edit_By);
    }

    function MagRegDbClickOnGetRowValues(FDData) {
        var values = FDData.split("![");
        Reg_ID = values[0];
        Reg_Membership_ID = values[1];
        Reg_Member_Name = values[2];
        Reg_MM_MEMBER_ID = values[3];
        Reg_Add_By = values[4];
        Reg_Add_Date = values[5];
        Reg_Edit_By = values[6];
        Reg_Edit_Date = values[7];
        Reg_Action_Status = values[8];
        Reg_Action_By = values[9];
        Reg_Action_Date = values[10];
        //xtemp_ID = values[0];
        //xtemp_0 = values[2];
        //xtemp_1 = values[1];
        //xtemp_2 = values[12];
        //xtemp_3 = values[11]
        //xtemp_4 = values[13];
        //xtemp_5 = values[3];
        //xtemp_6 = values[14];
        //memDate = values[15];
        //vdate = values[16];
        //xDate = values[17];
        //receiptNo = values[18];
        //receipt_ID = values[19];
        //MS_REC_ID = values[20];
        Member_Name = values[21];
        MagReg_UpdateFooterDetail(Reg_ID, Reg_Action_Status, Reg_Add_Date, Reg_Add_By,
            Reg_Action_Date, Reg_Action_By, Reg_Edit_Date, Reg_Edit_By);
        MagEditData(MS_REC_ID);
    }

    function MagReg_UpdateFooterDetail(Reg_ID, Reg_Action_Status, Reg_Add_Date, Reg_Add_By, Reg_Action_Date, Reg_Action_By, Reg_Edit_Date, Reg_Edit_By) {
        Reg_Action_Date = Reg_Action_Date != "" && Reg_Action_Date != null ? Reg_Action_Date : Reg_Action_Date;
        Reg_Edit_Date = Reg_Edit_Date != "" && Reg_Edit_Date != null ? Reg_Edit_Date : Reg_Edit_Date;
        Reg_Add_Date = Reg_Add_Date != "" && Reg_Add_Date != null ? Reg_Add_Date : Reg_Add_Date;
        $.ajax({
            type: 'GET',
            url: "/Magazine/MagazineReceiptRegister/CreationDetail",
            data: {
                Xrow: Reg_ID, Action_Status: Reg_Action_Status, Add_Date: Reg_Add_Date,
                Add_By: Reg_Add_By, Action_Date: Reg_Action_Date, Action_By: Reg_Action_By, Edit_Date: Reg_Edit_Date, Edit_By: Reg_Edit_By
            },
            cache: false,
            success: function (PropertyLbl_result) {
                $('#Property_Lbl_ActionOn').text(PropertyLbl_result.Lbl_StatusOn);
                $('#Property_Lbl_ActionBy').text(PropertyLbl_result.Lbl_StatusBy);
                $('#PropertyLbl_Status').text(PropertyLbl_result.Lbl_Status);
                $('#PropertyLbl_Create').text(PropertyLbl_result.Lbl_Create);
                $('#PropertyLbl_Modify').text(PropertyLbl_result.Lbl_Modify);
                if (PropertyLbl_result.Lbl_Status_Color != "") {
                    $('#PropertyLbl_Status').css('color', PropertyLbl_result.Lbl_Status_Color);
                }
                if (PropertyLbl_result.Pic_Status != "") {
                    $('#Property_LockICON').css('class', PropertyLbl_result.Pic_Status);
                }
            }
            })

    }
    function MagEditData(MS_REC_ID)
    {
        debugger
        IsPropertyViewPopup = false;
        if (MS_REC_ID == 'undefined' || MS_REC_ID == undefined) {
            //DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            //return;
        }
        $("#PopUp_frm_MagazineRecReg_Window").dxPopup("show");
        $("#PopUp_frm_MagazineRecReg_Window").dxPopup("instance").option("title", "New ~ Magazine Receipt Register");
        $("#MagazineReceiptRegresult").html('');
        ShowLoader();
        $("#MagazineReceiptRegresult").load("@Url.Action("Frm_Magazine_Recei_Reg_Subscribe", "MagazineReceiptRegister", new { @area = "Magazine" })?ActionMethod=" + "Edit" + "&REC_ID=" + encodeURIComponent(MS_REC_ID) + "&Row_Index=" + encodeURIComponent(Row_Index), function () {
            HideLoader();
        });

    }

    // Subscription
    function OnPropertySubscription() {
        IsMagazineRecregViewPopup = true;
        $("#PopUp_frm_MagazineRecReg_Window").dxPopup("show");
        $("#PopUp_frm_MagazineRecReg_Window").dxPopup("instance").option("title", "New ~ Magazine Receipt Register");
        $("#MagazineReceiptRegresult").html('');
        ShowLoader();
        $("#MagazineReceiptRegresult").load("@Url.Action("Frm_Magazine_Recei_Reg_Subscribe", "MagazineReceiptRegister", new { @area = "Magazine" })?ActionMethod=New", function () {
            HideLoader();
        });
    }

