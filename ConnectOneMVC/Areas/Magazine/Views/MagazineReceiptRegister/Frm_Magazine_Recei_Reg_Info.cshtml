    function toApplyForCanceReceipt(xTemp_7) {
        ShowLoader();
       var reason=  $('#IDReason').dxTextBox('instance').option('value');
        $.ajax({
            type: "POST",
            url: "/Magazine/MagazineReceiptRegister/ApplyToCancelReceipt",
            data: {
                ActionMethod:"Edit",
                XTemp_7: xTemp_7,
                Reason: reason
            },
            success: function (result) {
                HideLoader();
                if (result.jsonParam.result == false) {
                    var alertclick = DevExpress.ui.dialog.alert(result.jsonParam.message,result.jsonParam.title);
                    alertclick.done(function (alertResult) {
                        if (alertResult) {
                            if (result.jsonParam.focusid) {
                                var id = "#" + result.jsonParam.focusid;
                                setTimeout(function () {
                                    $(id).find('input').focus();
                                }, Timeout500);
                            }
                        }
                    });
                }
                else {
                    $("#PopUp_CancelReciept").dxPopup("hide");
                    DevExpress.ui.dialog.alert(result.jsonParam.message,result.jsonParam.title);
                    RefreshGridView("MagazineReceiRegListGrid");
                }


            },
            error: function (e) {

            }
        });
    }
    function toCancel() {
        $("#PopUp_CancelReciept").dxPopup("hide");
        $("#PopUp_GenerateREciept").dxPopup("hide");        
    }
