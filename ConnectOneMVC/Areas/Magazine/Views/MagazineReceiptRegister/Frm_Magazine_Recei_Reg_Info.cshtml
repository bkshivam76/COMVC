        MagazineRR_ColumnToBeHidddenIndex = s.cpColumnToBeHidddenIndex;        
        $("#BE_Stats").dxTextBox("instance").option("value", s.cpBE_Stats);
        MagazineRRGridLayout = s.cpClientLayout;
        if (MagazineRR_IsVouchingMode == true) {
            $(".MagazineReceiRegListGrid_PreviewRow").hide();
        }
        else {
            $(".MagazineReceiRegListGrid_PreviewRow").show();
        }
        GetSessionStorage("MagazineReceiRegListGrid");
        SendCustomArgs_FilterControl(s, e);
        console.log(e);

        //if (e.command == "REFRESH") {
        //    if (MembershipRRFocusedRowIndexBeforeRefresh == s.GetFocusedRowIndex()) {
        //        s.SetFocusedRowIndex(-1);
        //        s.SetFocusedRowIndex(MembershipRRFocusedRowIndexBeforeRefresh);
        //    }
        //    Select_xid = "";
        //}
    }
    function MagazineRecRegAdjustSize() {
        var height = (document.documentElement.clientHeight * 90) / 100;
        MagazineReceiRegListGrid.SetHeight(height);
    }

    //Subscribe success function
