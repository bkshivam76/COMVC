        if (result.result == false) {
            DevExpress.ui.dialog.alert(result.Message, "Error");
        }
        else {
            //IsMagazineRecRegSucessPopup = true;
            var lbSubmitSuccess = DevExpress.ui.dialog.alert(result.Message, "Success");
            $("#PopUp_frm_MagazineRecReg_Window").dxPopup("hide");
        }
    }

    //var Reg_ID;
    //var Reg_Membership_ID;
    //var Reg_MM_MEMBER_ID;
    //var Reg_Add_By;
