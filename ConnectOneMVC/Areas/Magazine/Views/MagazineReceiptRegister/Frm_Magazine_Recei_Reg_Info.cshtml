    function GetSelectedFieldValuesCallback(values) {
        SelectedRows.BeginUpdate();
        try {
            SelectedRows.ClearItems();
            for (var i = 0; i < values.length; i++) {
                SelectedRows.AddItem(values[i]);
            }
        } finally {
            SelectedRows.EndUpdate();
        }
        $("#count").html(gvRowSelection.GetSelectedRowCount());

    }

    function MagazineRegContextMenuFunction(s, e) {
        debugger
        var ActionMethod = "";
        if (e.item.name == 'Subscribe') {
            OnPropertySubscription();
        }
        if (e.item.name == 'GenerateReceipt') {
            ActionMethod = "RECEIPT - GENERATE";
            Generate_or_Print_Receipt(ActionMethod);
        }
        else if (e.item.name == 'PrintReceiept') {
            ActionMethod = "RECEIPT - PRINT";
            Generate_or_Print_Receipt(ActionMethod);
        }
        else if (e.item.name == 'ReceiptCancel') {
            ActionMethod = "RECEIPT - CANCELLED";
            Generate_or_Print_Receipt(ActionMethod);
        }
        else if (e.item.name == 'ListPreview') {
            OnMagazineRegListPreviewClick();
        }
        else if (e.item.name == 'Discontinue') {
            OnPropertyDiscontinueClick();
        }
        else if (e.item.name == 'Refresh') {
            MagazineReceiRegListGrid.Refresh();
        }

    }
