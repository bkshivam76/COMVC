    //Change Period Ok Button click function
    function Changeperiod() {
        $("#lblerror").innerText = "";
        $("#lblerror").hide();
        debugger;
        var fromdate = $("#Fromdate").dxDateBox("instance").option("value");
        var todate = $("#Todate").dxDateBox("instance").option("value");
        if (fromdate == null) {
            $("#lblerror").html("Please Select Fromdate");
            $("#lblerror").show();
            return false;
        }
        if (todate == null) {
            $("#lblerror").html("Please Select Todate");
            $("#lblerror").show();
            return false;
        }
        $("#Fromdate").val(fromdate); //Hidden values
        $("#Todate").val(todate);  //Hidden values
        var Fdate = fromdate;
        var Tdate = todate;
        Fdate = new Date(Fdate);
        Tdate = new Date(Tdate);
        if (Fdate > Tdate) {
            $("#lblerror").html("Fromdate cannot be higher than Todate");
            $("#lblerror").show();
            return false;
        }
        $("#popup_changeperiod_Window").dxPopup("hide");
        var FDdate = (Fdate.getDate() < 10 ? "0" + Fdate.getDate() : Fdate.getDate()) + "-" + Fdate.toLocaleString("en-us", { month: "short" }) + ", " + Fdate.getFullYear();
        var TDdate = (Tdate.getDate() < 10 ? "0" + Tdate.getDate() : Tdate.getDate()) + "-" + Tdate.toLocaleString("en-us", { month: "short" }) + ", " + Tdate.getFullYear();
        $("#BE_View_Period").dxTextBox("instance").option("value", "Fr.: " + FDdate + " to  " + TDdate);
        if (fromdate != null && todate != null)
        {
            @*ShowLoader();
            $("#MagazinereloadPartialView").load("@Url.Action("GetGridData", "MagazineReceiptRegister", new { @area = "Magazine" })?FrmDate=" + fromdate + "&Todate=" + todate, function () {
                HideLoader();
            });*@
            RefreshGridView("MagazineReceiRegListGrid");
        }
    }
