    function convertPdf() {
        debugger;
        ShowLoader();
      //  $('#id_PdfContent').replace('<button onclick="convertPdf()">Print</button>', '');
        var content = $('#id_PdfContent').html();
        html2canvas(content, {
            onrendered: function (canvas) {
                var imgWidth = 208;
                var pageHeight = 150;
                var imgHeight = canvas.height * imgWidth / canvas.width;
                var img = canvas.toDataURL("image/png");
                var doc = new jsPDF('p', 'mm', 'a4'); // A4 size page of PDF
                doc.addImage(img, 'PNG', 10, 10, imgWidth, imgHeight);
                doc.save('test.pdf');
            }
        });
        HideLoader();
    }
    function Generate_or_Print_Receipt(ActionMethod)
