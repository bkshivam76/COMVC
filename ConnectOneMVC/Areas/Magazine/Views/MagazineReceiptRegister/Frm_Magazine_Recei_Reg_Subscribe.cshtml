            $("#BUT_EidtAddress").dxButton({ disabled: false });;
            $("#BUT_Manage_Address").dxButton({ disabled: false });
        }
    }
    function OnFrm_Subs_Click() {
        
        if ($("#BE_MagazineName").dxDropDownBox("instance").option('text').length == 0) {
            DevExpress.ui.dialog.alert('M a g a z i n e   n o t   S e l e c t e d . . . !', 'Alert ');
            return false;
        }
        var _SearchText = $("#PC_MemberName").dxTextBox('instance').option('value');
        if (_SearchText == "" || _SearchText == null || _SearchText.length < 3) {
            DevExpress.ui.dialog.alert('Member Name   can not   be   Blank', 'Error ');
            return false;
        }

        var BE_STATUS = $("#BE_STATUS").dxTextBox("instance").option("value");
        var Lbl_ActiveSubsPeriod = $("#Lbl_ActiveSubsPeriod").dxTextBox("instance").option("value");
        var Txt_Date = $("#Txt_MS_Date").dxDateBox("instance").option("value");
        var Txt_MS_Date = formatDate(Txt_Date);
        var Membership = "New";
        var BE_Publish_On = $("#BE_Publish_On").dxTextBox("instance").option("value");
        var BE_MagazineNameId = $("#BE_MagazineName").dxDropDownBox("instance").option("value")[0];
        var RAD_Category = $("#RAD_Category").dxRadioGroup("instance").option("value");
        var iLastDis_Id =Dis_ID;
        var iLastSubs_ID = Subs_ID;
        var SrID = "";
        var Txt_Copies = 0;
        $.ajax({
            type: 'GET',
            url: "/Magazine/MagazineReceiptRegister/SubscriptionDetails",
            data: { Membership: Membership, Txt_MS_Date: Txt_MS_Date, BE_STATUS: BE_STATUS, Lbl_ActiveSubsPeriod: Lbl_ActiveSubsPeriod},
            cache: false,
            success: function (Result) {
                debugger
                if (Result.result == "true" || Result.result == true) {

                $("#Frm_Subs_popup").dxPopup("show");
                $("#Frm_Subs_popup").dxPopup("instance").option("title", "Add ~ Subscription")
                ShowLoader();
                $("#result_Frm_Subs_popup").load("@Url.Action("Frm_Magazine_Subs_Window", "MagazineReceiptRegister", new { @area = "Magazine" })?ActionMethod=" + "_New" + "&SrID=" + SrID + "&MagazineID=" + encodeURIComponent(BE_MagazineNameId) + "&Membership=" + encodeURIComponent(Membership) + "&Txt_Subs_Date=" + encodeURIComponent(Txt_MS_Date) + "&Publish_On=" + encodeURIComponent(BE_Publish_On) + "&iLastSubs_ID=" + encodeURIComponent(iLastSubs_ID) + "&Txt_Copies=" + encodeURIComponent(Txt_Copies) + "&iLastDis_Id=" + encodeURIComponent(iLastDis_Id), function () {
                    HideLoader();
                });
                }
                else {
                    DevExpress.ui.dialog.alert(Result.Message, 'Information!');
                }
            }
        });
    }
    function formatDate(date) {
        var hours = date.getHours();
        var minutes = date.getMinutes();
        var ampm = hours >= 12 ? 'pm' : 'am';
        hours = hours % 12;
        hours = hours ? hours : 12; // the hour '0' should be '12'
        minutes = minutes < 10 ? '0' + minutes : minutes;
        var strTime = hours + ':' + minutes + ' ' + ampm;
        return date.getMonth() + 1 + "/" + date.getDate() + "/" + date.getFullYear() + "  " + strTime;
    }
</script>
