    function OnFrm_btn_AutoRenewal_Click()
    {
        if (mm_AUTO_RENEWAL == "ENABLED" || mm_AUTO_RENEWAL == "DISABLED") {
            $.ajax({
                type: "GET",
                url: "\Magazine\MagazineReceiptRegister\Btn_AutoRenewal",
                data: { MM_AUTO_RENEWAL: mm_AUTO_RENEWAL, MS_RecId: ms_RecId },
                cache: false,
                success: function (result) {
                    if(result.mm_auto_renewel=="ENABLED")
                    {
                        mm_AUTO_RENEWAL = result.mm_auto_renewel;
                        DevExpress.ui.dialog.alert("Membership shall not be considered for Auto-Renewal . . . !", "Information...");
                    }
                    else {
                        mm_AUTO_RENEWAL = result.mm_auto_renewel;
                        DevExpress.ui.dialog.alert("Membership shall be considered for Auto-Renewal . . . !", "Information...");
                    }
                }
            });
        }
