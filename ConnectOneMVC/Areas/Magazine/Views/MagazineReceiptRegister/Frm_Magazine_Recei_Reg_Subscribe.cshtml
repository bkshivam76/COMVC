<script>
    function GLookUp_MagList_ChangeEvent(e) {
        var dropDownBox = $("#BE_MagazineName").dxDropDownBox("instance");
        dropDownBox.close();
        var $dataGrid = $("#Frm_Profile_Win_GLookUp_MagList_datagrid");
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(e.value, false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                $("#BE_Language").dxTextBox("instance").option("value", item["Language"]);
                $("#BE_Publish_On").dxTextBox("instance").option("value", item["Publish_On"]);
                short_Name = item["Short Name"];
            }
        }
    }
    function onInitialized_Magazinelist(e) {
        if (e.component.option("dataSource") != null) {
            e.component.option("dataSource").store.load().done(function (d) {

                if (d.length == 1)
                    e.component.option("value", d[0].name);

            });
        }
    }
    function Chk_ConCenter_CheckedChanged(e) {
        if (e.value) {
            $("#Cmb_CC_MemType").dxSelectBox({ disabled: false });
            $("#Chk_Sponsored").dxCheckBox({ disabled: false });
            $("#BE_CCMemberName").dxDropDownBox({ disabled: false });
            _ccMember = $("#Cmb_CC_MemType").dxSelectBox("getDataSource");
            ccMemberType = _ccMember._store._array[0];
            $("#Cmb_CC_MemType").dxSelectBox("instance").option("value", "");
            $("#Cmb_CC_MemType").dxSelectBox("instance").option("value", ccMemberType);
        }
        else {
            $("#Cmb_CC_MemType").dxSelectBox({ disabled: true });
            $("#Chk_Sponsored").dxCheckBox({ disabled: true });
            $("#BE_CCMemberName").dxDropDownBox({ disabled: true });
        }
        $("#Chk_ConCenter").val(e.value);
        //$("#Cmb_CC_MemType").dxSelectBox({ disabled: false })
    }
    function Cmb_CC_MemType_SelectedIndexChanged(e) {
        if (e.value == "CENTRE / SUB-CENTRE" || e.value == "GEETA PATHASHALA" || e.value == "INDIVIDUAL") {
            var _MemberType = e.value;
            resCmb_CC_MemType = resCmb_CC_MemType;
