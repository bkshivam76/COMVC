        $("#BE_Address_2").dxTextBox("instance").option("value", Data[11]);
        $("#BE_Address_3").dxTextBox("instance").option("value", Data[12]);
        $("#BE_Address_4").dxTextBox("instance").option("value", Data[13]);
        $("#BE_Address_5").dxTextBox("instance").option("value", Data[14]);
        $("#BE_Address_6").dxTextBox("instance").option("value", Data[15]);
        $("#Cmb_MemType").dxSelectBox("instance").option("value", "");
        $("#Cmb_MemType").dxSelectBox("instance").option("value", Data[18]);
        $("#Txt_MS_ID").dxTextBox("instance").option("value", Data[20]);
        $("#Txt_MS_Old_ID").dxTextBox("instance").option("value", Data[21]);
        $("#ME_OtherDetails").dxTextBox("instance").option("value", Data[22]);
        var _txt_MS_ID=$("#Txt_MS_ID").dxTextBox("instance").option("value");
        var MEM_ID = Data[18];
        var Mag_ID = Data[9];
        var _Country = Data[3];
         ms_RecId = Data[23];
        var txt_MS_Date = Data[24];
        var mm_CC_APPLICABL = Data[26];
        var mm_CC_SPONSORED = Data[27];
        var mm_CC_MS_ID = Data[28];
        var cc_MEMBER_TYPE = Data[29];
         mm_AUTO_RENEWAL = Data[25];
        if (txt_MS_Date == "" && txt_MS_Date == null)
        {
            txt_MS_Date = $("#Txt_MS_Date").dxDateBox("instance").option("value");
        }
        else
        {
            $("#Txt_MS_Date").dxDateBox("instance").option("value", Data[24]);
        }
        if (Mag_ID.length > 0 && _txt_MS_ID == null)
        {
            $.ajax({
                type: 'GET',
                url: '/Magazine/MagazineReceiptRegister/GetMagzineData',
                data: { Magzine_ID: Mag_ID, txt_MS_ID: _txt_MS_ID, country: _Country },
                cache: false,
                success: function (result) {
                    $("#Txt_MS_ID").dxTextBox({ value: result.Txt_MS_ID });
                }
            });
        }
        $("#PC_Member_popup").dxPopup("hide");
        var _Status = $("#BE_STATUS").dxTextBox("instance").option("value");
        if (_Status == "DISCONTINUED")
        {
            $("#BE_STATUS").dxTextBox({ readOnly: true });
            $("#btn_Discontinue").dxButton({ disabled: true });
            $("#btn_Continue").dxButton({ disabled: false });
            //btn_Discontinue
        }
        else
        {
            $("#BE_STATUS").dxTextBox({ readOnly: true });
            $("#btn_Discontinue").dxButton({ disabled: false });
            $("#btn_Continue").dxButton({ disabled: true });
        }
        if (mm_CC_APPLICABL == "YES") {
            $("#Chk_ConCenter").dxCheckBox({ value: true });
            if (mm_CC_SPONSORED == "0") {
                $("#Chk_Sponsored").dxCheckBox({ value: false });
            }
            else {
                $("#Chk_Sponsored").dxCheckBox({ value: true });
            }
            if (mm_CC_MS_ID != "" && mm_CC_MS_ID.length > 0) {
                $("#Cmb_CC_MemType").dxSelectBox("instance").option("value", cc_MEMBER_TYPE);
                $("#BE_CCMemberName").dxDropDownBox("instance").option("value", mm_CC_MS_ID);
            }
        }

        if (_Country.toUpperCase() == "INDIA" || _Country.toUpperCase() == "NEPAL") {
           // $("#RAD_Category").dxRadioGroup().option("value", "INDIAN");
        }
        else {
           // $("#RAD_Category").dxRadioGroup().option("value", "FOREIGN");
        }
        var Txt_MS_ID = $("#Txt_MS_ID").dxTextBox("instance").option("value");
        if(Txt_MS_ID ==""|| Txt_MS_ID==null)
        {
            Membership = "New";
            $("#Txt_MS_ID").dxTextBox({ disabled: false });
            $("#Txt_MS_Old_ID").dxTextBox({ disabled: false });
            $("#BE_CCMemberName").dxDropDownBox({ disabled: true });
            $("#lblCurrActivity").dxTextBox("instance").option("value", "New Member");
            $("#lblCurrActivity").css('color', 'green');

        }
        else
        {
            Membership = "Renewal";
            $("#Txt_MS_ID").dxTextBox({ disabled: true });
            $("#Txt_MS_Old_ID").dxTextBox({ disabled: false });
            $("#Cmb_CC_MemType").dxSelectBox({ disabled: true });
            $("#BE_CCMemberName").dxDropDownBox({ disabled: true });
            $("#lblCurrActivity").dxTextBox("instance").option("value", "Existing Member");
            $("#lblCurrActivity").css('color', 'red');
            //$.ajax({
            //    type: 'GET',
            //    url: '/Magazine/MagazineReceiptRegister/ShowOpenings',
            //    data: { Magzine_ID: Mag_ID, MS_RecId: ms_RecId, Txt_MS_Date: txt_MS_Date, membership: Membership, country: _Country },
            //    cache: false,
            //    success: function (result) {
            //        debugger
            //        //$("#Txt_MS_ID").dxTextBox({ value: result.Txt_MS_ID });
            //    }
            //});
        }
        var __MemType = $("#Cmb_MemType").dxSelectBox("instance").option("value");
        if (__MemType == "INDIVIDUAL")
        {
            if(Membership == "Renewal")
            {
                $("#BUT_AddAddress").dxButton({ disabled: true });
            }
            else
            {
                $("#BUT_AddAddress").dxButton({ disabled: false });
            }
        }
        var _status = $("#BE_STATUS").dxTextBox("instance").option("value");
        if (_status.indexOf("dis") == -1)
        {
            HideLoader();
            var result = DevExpress.ui.dialog.confirm("Add   Default   Cash   Subscription...?\n\nThis adds a single copy subscription of first subscription along with cash payment for it.", "Information");
            result.done(function (dialogResult) {
                if (dialogResult) {
                    ShowLoader();
                    $.ajax({
                        type: 'GET',
                        url: '/Magazine/MagazineReceiptRegister/ShowOpenings',
                        data: { Magzine_ID: Mag_ID, MS_RecId: ms_RecId, Txt_MS_Date: txt_MS_Date, membership: Membership, country: _Country },
                        cache: false,
                        success: function (result) {
                            debugger
                            HideLoader();
                            if (result.result == true)
                            {
                                $("#Txt_Nxt_Issue_Date").dxDateBox("instance").option("value", result.Txt_Nxt_Issue_Date);
                                $("#Lbl_ActiveSubsPeriod").dxTextBox("instance").option("value", result.Lbl_ActiveSubsPeriod);
                                $("#Lbl_Other_Total").dxNumberBox("instance").option("value", result.Lbl_Other_Total);
                                $("#Lbl_OtherCurrTxn").dxNumberBox("instance").option("value", result.Lbl_OtherCurrTxn);
                                $("#Lbl_Pmt_Total").dxNumberBox("instance").option("value", result.Lbl_Pmt_Total);
                                $("#Lbl_PmtCurrTxn").dxNumberBox("instance").option("value", result.Lbl_PmtCurrTxn);
                                $("#lblDispatchCount").dxTextBox("instance").option("value", result.lblDispatchCount);
                                $("#Lbl_SubsCurrTxn").dxNumberBox("instance").option("value", result.Lbl_SubsCurrTxn);
                                $("#BE_OpAdvDue").dxNumberBox("instance").option("value", result.BE_OpAdvDue);
                                $("#Lbl_SubsDuringYear").dxNumberBox("instance").option("value", result.Lbl_SubsDuringYear);
                               // $("#result_SubscriptionGridData").html('');
                                $("#result_SubscriptionGridData").html(result.subscriptionGridData);
                                //$("#result_PaymentGridData").html('');
                                $("#result_PaymentGridData").html(result.paymentGridData);
                            }
                            else {
                                DevExpress.ui.dialog.alert(result.message, "Error");
                            }
                        }
                    });
                }
            });

        }

    }



