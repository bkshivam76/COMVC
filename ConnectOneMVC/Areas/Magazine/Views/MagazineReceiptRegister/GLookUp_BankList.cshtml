@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid()
            .ID("Frm_Payment_Win_GLookUp_BankList_datagrid")
            .DataSource(new JS(@"component.option(""dataSource"")"))
            .Columns(columns =>
            {

                columns.Add().DataField("BI_BANK_NAME").Caption("NAME").Width(300);
                columns.Add().DataField("BANK_BRANCH").Caption("Branch").Width(300);
                columns.Add().DataField("BANK_ACC_NO").Caption("ACCOUNT NO").Width(300);
                columns.Add().DataField("BANK_ID").Caption("BANK_ID").Width(0).Visible(false);
                columns.Add().DataField("ID").Caption("ID").Width(0).Visible(false);
})
            .HoverStateEnabled(true)
            .Paging(p => p.PageSize(100))
            //.FilterRow(f => f.Visible(true))
            .Scrolling(s => s.Mode(GridScrollingMode.Infinite))
            .Height(200)
            .Selection(s => s.Mode(SelectionMode.Single))
            .OnSelectionChanged(@<text>
                function(selectedItems) {
                var keys = selectedItems.selectedRowKeys;
                component.option("value", keys);
                }
            </text>)
)
