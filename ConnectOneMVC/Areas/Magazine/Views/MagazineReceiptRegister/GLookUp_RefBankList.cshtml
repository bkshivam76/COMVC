@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid()
            .ID("Frm_Payment_Win_GLookUp_RefBankList_datagrid")
            .DataSource(new JS(@"component.option(""dataSource"")"))
            .Columns(columns =>
            {

                columns.Add().DataField("BI_BANK_NAME").Caption("Name").Width(500);
                columns.Add().DataField("BI_SHORT_NAME").Caption("SHORT NAME").Width(400);
                columns.Add().DataField("BI_ID").Caption("BI_ID").Width(0).Visible(false);
})
            .HoverStateEnabled(true)
            .Paging(p => p.PageSize(100))
            .FilterRow(f => f.Visible(true))
            .Scrolling(s => s.Mode(GridScrollingMode.Infinite))
            .Height(300)
            .Selection(s => s.Mode(SelectionMode.Single))
            .OnSelectionChanged(@<text>
                function(selectedItems) {
                var keys = selectedItems.selectedRowKeys;
                component.option("value", keys);
                }
            </text>)
)
