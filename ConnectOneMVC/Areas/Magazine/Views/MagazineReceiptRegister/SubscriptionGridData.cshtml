@{

}

@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "SubscriptionDetails_Window_Grid";
        settings.CallbackRouteValues = new
        {
            Controller = "MagazineReceiptRegister",
            Action = "SubscriptionGridData",
            ActionMethodName = "_View"
            //FilterVisible = FilterVisible,
            //SearchVisible = SearchVisible,
            //ShowGroupedColumns = ShowGroupedColumns
        };
        settings.Settings.VerticalScrollBarMode = ScrollBarMode.Visible;
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Visible;
        settings.Settings.VerticalScrollableHeight = 100;

        settings.KeyboardSupport = true;
        //settings.AccessKey = "G";
        settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
        //settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.HideDataCells;

        settings.Settings.ShowGroupFooter = GridViewGroupFooterMode.VisibleAlways;

        settings.SettingsBehavior.AutoExpandAllGroups = true;
        settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
        settings.Settings.UseFixedTableLayout = true;
        settings.SettingsBehavior.ColumnMoveMode = GridColumnMoveMode.AmongSiblings;
        settings.SettingsBehavior.AllowSort = true;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.NextColumn;
        settings.SettingsResizing.Visualization = ResizingMode.Live;
        settings.SettingsBehavior.AllowEllipsisInText = true;

        // Filter and serach
        //settings.Settings.ShowFilterRowMenu = true;
        //settings.Settings.ShowFilterBar = GridViewStatusBarMode.Visible;
        //settings.Settings.ShowFilterRow = false;
        //settings.Settings.AutoFilterCondition = AutoFilterCondition.Contains;

        settings.SettingsPager.Mode = GridViewPagerMode.ShowAllRecords;
        settings.SettingsSearchPanel.ShowApplyButton = true;
        settings.SettingsSearchPanel.ShowClearButton = true;

        settings.SettingsBehavior.AllowFocusedRow = true;
        settings.ClientSideEvents.FocusedRowChanged = "OnSubscriptionDetailsGridFocusedRowChanged";
        //settings.ClientSideEvents.EndCallback = "OnGridTelephoneListGrid_EndCallback";

        settings.Settings.ShowHeaderFilterBlankItems = false;

        settings.SettingsContextMenu.Enabled = true;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;
        settings.FillContextMenuItems = (sender, e) =>
        {
            if (e.MenuType == GridViewContextMenuType.Rows)
            {
                var Additem = e.CreateItem("New", "New");
                Additem.Image.IconID = "actions_expandcollapse_16x16devav";
                Additem.BeginGroup = true;
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Additem);
                var Edititem = e.CreateItem("Edit", "Edit");
                Edititem.Image.IconID = "actions_edit_16x16devav";
                Edititem.BeginGroup = true;
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Edititem);
                var GenerateReceiptItem = e.CreateItem("Generate Receipt", "GenerateReceipt");
                GenerateReceiptItem.Image.IconID = "actions_task_16x16devav";
                GenerateReceiptItem.BeginGroup = true;
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), GenerateReceiptItem);
                var PrintReceieptItem = e.CreateItem("Print Receipt", "PrintReceiept");
                PrintReceieptItem.Image.IconID = "actions_print_16x16devav";
                PrintReceieptItem.BeginGroup = true;
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), PrintReceieptItem);
                var ReceiptCancelItem = e.CreateItem("Receipt Cancelled", "ReceiptCancel");
                ReceiptCancelItem.Image.IconID = "actions_delete_16x16devav";
                ReceiptCancelItem.BeginGroup = true;
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), ReceiptCancelItem);
                var Deleteitem = e.CreateItem("Delete", "Delete");
                Deleteitem.Image.IconID = "actions_delete_16x16devav";
                Deleteitem.BeginGroup = true;
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Deleteitem);
                var Viewitem = e.CreateItem("View", "View");
                Viewitem.Image.IconID = "print_tasklist_16x16devav";
                Viewitem.BeginGroup = true;
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Viewitem);
            }
        };
        // settings.ClientSideEvents.ContextMenuItemClick = "Frm_Subscription_Detail_Grid_ContextMenuFunction";
        // DXCOMMENT: Specify the grid's key field name and define grid columns in accordance with data model fields
        settings.KeyFieldName = "ID";

        settings.Columns.Add("Sr").Caption = "Sr.";
        settings.Columns.Add("SubsType").Caption = "Subs. Type";
        //settings.Columns.Add("Subs_ID").Caption = "Subs_ID";
        settings.Columns.Add("SubsDate").Caption = "Subs. Date";
