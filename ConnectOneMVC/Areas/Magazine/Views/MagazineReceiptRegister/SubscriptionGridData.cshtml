        settings.Columns.Add("REC_EDIT_BY").Caption = "REC_EDIT_BY";
        settings.Columns.Add("RECEIPT_NO").Caption = "RECEIPT_NO";
        settings.Columns.Add("RECEIPT_ID").Caption = "RECEIPT_ID";
