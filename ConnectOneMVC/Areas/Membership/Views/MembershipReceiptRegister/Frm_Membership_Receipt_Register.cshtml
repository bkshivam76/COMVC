<script>
    function RcptGenerationConfirmation(actionType)
    {
        if (actionType == "RECEIPT - GENERATE")
        {
            var alertclick=DevExpress.ui.dialog.confirm('Sure you want to Generate Receipt of this Entry...?', 'Confirmation');
            alertclick.done(function (alertResult)
            {
                if (alertResult)
                {
                    OnMembershipReceiptRegisterButtonClick("RECEIPT - GENERATE");
                }
            });
        }
    }

    function OnMembershipReceiptRegisterButtonClick(_ActionType, Voucher_Type = "", Selected_Item_ID = "", Selection_By_Item = false)
    {
        MRR_GetRowData(MembershipReceiptRegisterGrid.GetFocusedRowIndex());
        ShowLoader();
        if ("@MembershipRR_UpdateRight" == "False"||"@MembershipRR_ViewRight" == "False"||"@MembershipRR_DeleteRight"=="False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            HideLoader();
	        return;
        }
        if (MembershipReceiptRegisterID_MRR == 'undefined' || MembershipReceiptRegisterID_MRR == undefined || MembershipReceiptRegisterID_MRR==null)
        {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            HideLoader();
            return;
        }
        if (MRR_Entry_TrCode == 16 && (_ActionType == "EDIT" || _ActionType == "VIEW" || _ActionType == "DELETE"))  //Redmine Bug #135903 fixed
        {
            DevExpress.ui.dialog.alert('Edit, View and Delete of Membership Conversion is not allowed', 'Error!!');
            HideLoader();
            return;
        }

        $.ajax({
            type: 'GET',
            url: "/Membership/MembershipReceiptRegister/DataNavigation",
            data: { ActionMethod: _ActionType, ID: MembershipReceiptRegisterID_MRR, Edit_Date: MRR_EditDate, Selected_Item_ID: Selected_Item_ID },
            cache: false,
            success: function (data)
            {
                HideLoader();
                if (data.jsonParam.result == false)
                {
                    DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                    if (data.jsonParam.refreshgrid)
                    {
