    function OnMRRListPreviewClick(CallingFromGenerate = 'No', GenerateID = "") //Redmine Bug #135459 fixed
    {
        if (CallingFromGenerate == 'Yes') {
            MembershipReceiptRegisterID_MRR = GenerateID;
            MembershipReceiptRegisterGrid.SelectRowsByKey(MembershipReceiptRegisterID_MRR);
        }   //Redmine Bug #135459 fixed
        else
        {
            MRR_GetRowData(MembershipReceiptRegisterGrid.GetFocusedRowIndex());
        }
        if (MembershipReceiptRegisterID_MRR == 'undefined' || MembershipReceiptRegisterID_MRR == undefined || MembershipReceiptRegisterID_MRR == null)
        {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }       
        ShowLoader();
        $.ajax({
           url: '@Url.Action("MembershipReceiptRegister_Print", "MembershipReceiptRegister")',
           type: "GET",
           data: { ID: MembershipReceiptRegisterID_MRR },
           success: function (res)
            {
                HideLoader();
                if (res.jsonParam != undefined)
                {
                    DevExpress.ui.dialog.alert(res.jsonParam.message, res.jsonParam.title);
                }
                else
                {
                    OpenPopup("OpenMRRPopup", "Membership Receipt Register", null, "auto", "100%", true, res);
                }
            }
        });
    }

