<script>
    function Get_Cash_Bank_Balance()
    {
        $("#MRR_PeriodSelection").find('input').blur();
        ShowLoader_Ready();
        $.ajax({
            type: 'GET',
            url: "/Membership/MembershipReceiptRegister/Get_Cash_Bank_Balance",
            data: {},
            cache: false,
            success: function (data)
            {
                if (data.jsonParam.result == false)
                {
                    DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                    if (data.jsonParam.closeform == true)
                    {
                        btnCloseActiveTab();
                    }
                }
                else
                {
                    $("#MRR_BE_Cash_Bank").text(" "+data.BE_Cash_Bank_Text+" ");
                    HideLoader_Ready();
                    RefreshGridView("MembershipReceiptRegisterGrid");
                }
            }
        });
    }

    function PeriodSelectionChange(e)
    {
        e.component.close();
        if (e.value == null || e.value < 0)
        {
            return;
        }
        $("#MRR_btnChangePeriod").dxButton("instance").option("disabled", true);

        if (e.value == 20)
        {
            $("#MRR_btnChangePeriod").dxButton("instance").option("disabled", false);
            AllowDialogBox = false;
            ChangePeriodClick();
            //AllowDialogBox = true;
        }
        else
        {
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Membership/MembershipReceiptRegister/Cmb_View_SelectedIndexChanged",
                data:
                {
                    SelectedIndex: e.value
                },
                cache: false,
                success: function (result)
                {
                    MRR_PeriodSelectionFirstTime = false;
                    $("#MRR_BE_View_Period").dxTextBox("instance").option("value", result.BE_View_Period);
                    $("#MRR_Fr_Date").val(result.FromDate);
                    $("#MRR_To_Date").val(result.ToDate);
                    RefreshGridView("MembershipReceiptRegisterGrid");//Redmine Bug #135960 fixed
                    //Get_Cash_Bank_Balance();
                    //$("#MRR_BE_View_Period").val();
                    //Grid_Display(null, false, true);
                    HideLoader();
                }
            });
        }
    }

    function ChangePeriodClick()
    {
        //if (AllowDialogBox) {
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Membership/MembershipReceiptRegister/frm_MembershipRR_Specific_Period",
            cache: false,
            data: { PeriodSelectionFirstTime: MRR_PeriodSelectionFirstTime },
            success: function (data)
            {
                ShowLoader();
                OpenPopup("PopupMRR_speceficPeriod", "Change Period", false, "auto", 250, true, data);
                HideLoader();
            }
        });
        //}
    }

    function Frm_Change_Period_Success(data)
    {
        HideLoader();
        MRR_PeriodSelectionFirstTime = false;
        if (data.result == false)
        {
            DevExpress.ui.dialog.alert(data.message, 'Error!!');
        }
        else
        {
            $("#PopupMRR_speceficPeriod").dxPopup("hide");
            $("#MRR_BE_View_Period").dxTextBox("instance").option("value", data.BE_View_Period);
            $("#MRR_Fr_Date").val(data.FromDate);
            $("#MRR_To_Date").val(data.ToDate);
            //$("#MRR_BE_Cash_Bank").val(data.BE_Cash_Bank_Text);
            ShowLoader();
            //Get_Cash_Bank_Balance();
            RefreshGridView("MembershipReceiptRegisterGrid");//Redmine Bug #135960 fixed
            HideLoader();
            //Grid_Display(null, false, true);
        }
    }

</script>@*Change Period*@

<script>
    function MembershipRRAdjustSize()
    {
        var height = (document.documentElement.clientHeight * 90) / 100;
        try { MembershipReceiptRegisterGrid.SetHeight(height); } catch (err) { }
    }

    function MembershipRROnInit(s, e)
    {
        MembershipRRAdjustSize();
        //$(".BankPrfPreviewRow").hide();
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt)
        {
            MembershipRRAdjustSize();
        });
    }

    function MembershipRRGrid_BeginCallback(s, e)
    {
        MembershipRRFocusedRowIndexBeforeRefresh = s.GetFocusedRowIndex();
        e.customArgs["command"] = e.command;
        e.customArgs["ShowHorizontalBar"] = MembershipRR_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = MembershipRR_IsVouchingMode;
        e.customArgs["ViewMode"] = MembershipRR_ViewMode;
        e.customArgs["ColumnToBeShownIndex"] = MembershipRR_ColumnToBeShownIndex;
        e.customArgs["ColumnToBeHidddenIndex"] = MembershipRR_ColumnToBeHidddenIndex;
        e.customArgs["RowKeyToFocus"] = Select_xid_MRR;
    }

    function OnGridMembershipRRGrid_EndCallback(s, e)
    {
        //BankAdjustSize();
        ASPxClientControl.AdjustControls(document.getElementById("MembershipRR_ParentDiv"));
        MembershipRR_ColumnToBeShownIndex = s.cpColumnToBeShownIndex;
        MembershipRR_ColumnToBeHidddenIndex = s.cpColumnToBeHidddenIndex;
        MembershipRRGridLayout = s.cpClientLayout;
        $("#MRR_BE_Cash_Bank").text(s.cpCashBankText);//Redmine Bug #135960 fixed
        if (MembershipRR_IsVouchingMode == true)
        {
            $(".MembershipReceiptRegisterGrid_PreviewRow").hide();
        }
        else
        {
            $(".MembershipReceiptRegisterGrid_PreviewRow").show();
        }
        GetSessionStorage("MembershipReceiptRegisterGrid");
        SendCustomArgs_FilterControl(s, e);
        if (e.command == "REFRESH")
        {
            if (MembershipRRFocusedRowIndexBeforeRefresh == s.GetFocusedRowIndex()) {
                s.SetFocusedRowIndex(-1);
                s.SetFocusedRowIndex(MembershipRRFocusedRowIndexBeforeRefresh);
            }
            else
            {
                MRR_GetRowData(s.GetFocusedRowIndex());
            }
            Select_xid_MRR = "";
        }
    }
    function MRR_GetRowData(RowIndex = null)
    {
        var focusedrow = RowIndex == null ? MembershipReceiptRegisterGrid.GetFocusedRowIndex() : RowIndex;
        var topindex = MembershipReceiptRegisterGrid.GetTopVisibleIndex();
        var Index = focusedrow - topindex;
        MRRPageData = MembershipReceiptRegisterGrid.cpPagedata;
        if (MRRPageData != null && MRRPageData.length > 0 && Index < MRRPageData.length && Index > -1) {
            MembershipReceiptRegisterID_MRR = typeof MRRPageData[Index][0] !== "undefined" ? MRRPageData[Index][0] : null;
            MRR_EditDate = typeof MRRPageData[Index][1] !== "undefined" ? MRRPageData[Index][1] : null;
            MRR_EditBy = typeof MRRPageData[Index][2] !== "undefined" ? MRRPageData[Index][2] : null;
            MRR_AddDate = typeof MRRPageData[Index][3] !== "undefined" ? MRRPageData[Index][3] : null;
            MRR_AddBy = typeof MRRPageData[Index][4] !== "undefined" ? MRRPageData[Index][4] : null;
            MRR_ActionDate = typeof MRRPageData[Index][5] !== "undefined" ? MRRPageData[Index][5] : null;
            MRR_ActionBy = typeof MRRPageData[Index][6] !== "undefined" ? MRRPageData[Index][6] : null;
            MRR_ActionStatus = typeof MRRPageData[Index][7] !== "undefined" ? MRRPageData[Index][7] : null;
            MRR_Receipt_No = typeof MRRPageData[Index][8] !== "undefined" ? MRRPageData[Index][8] : null;
            MRR_Entry_TrCode = typeof MRRPageData[Index][9] !== "undefined" ? MRRPageData[Index][9] : null;
        }
        else
        {
            MembershipReceiptRegisterID_MRR = null;
        }
        MRR_UpdateFooterDetail(MembershipReceiptRegisterID_MRR, MRR_ActionStatus, MRR_AddDate, MRR_AddBy, MRR_ActionDate, MRR_ActionBy, MRR_EditDate, MRR_EditBy);
    }

    function MembershipRROnGridFocusedRowChanged(s, e)
    {
        if (s.GetFocusedRowIndex() > -1)
        {
            MRR_GetRowData(s.GetFocusedRowIndex());
            if (!MembershipReceiptRegisterGrid.IsGroupRow(s.GetFocusedRowIndex()))
            {               
                if (MembershipRR_IsVouchingMode)
                {
                    MRRPrf_FAB.SetVisible(true);
                    MRRPrf_FAB.SetActionContext("VouchingActionContext", true);                             
                    OpenLeftPane();
                    LoadDocumentAndAdditionalInfoInLeftPane("Membership", "MembershipReceiptRegister", "LeftPaneContent", MembershipReceiptRegisterID_MRR, MembershipRR_IsVouchingMode, "");                
                }
            }
            else
            {
                MembershipReceiptRegisterID_MRR = null;
            }
        }
        else
        {
            MembershipReceiptRegisterID_MRR = null;
        }       
    }

