    function MembershipRRContextMenuFunction(s, e)
    {
        if (e.item.name == "Close")
        {
            CloseMembershipRR();
        }
        if (e.item.name == "Profile_MembershipRR_New")
        {
            OnMembershipReceiptRegisterNewClick();
        }
        else if (e.item.name == 'Profile_MembershipRR_Edit')
        {
            OnMembershipReceiptRegisterButtonClick("EDIT");
        }
        else if (e.item.name == 'Profile_MembershipRR_Delete')
        {
            OnMembershipReceiptRegisterButtonClick("DELETE");
        }
        else if (e.item.name == 'Profile_MembershipRR_View')
        {
            OnMembershipReceiptRegisterButtonClick("VIEW");
        }
        else if (e.item.name == "Generate")
        {
            RcptGenerationConfirmation("RECEIPT - GENERATE");
        }
        else if (e.item.name == "Print")
        {
            OnMRRListPreviewClick();
        }
        else if (e.item.name == 'ListPreview')
        {
            Membership_Preview();
        }
        else if (e.item.name == 'Receipt Cancelled')
        {
            OnMembershipReceiptRegisterButtonClick('RECEIPT - CANCELLED');
        }
        else if (e.item.name == 'Refresh')
        {
            MembershipReceiptRegisterGrid.Refresh();
        }
    }

