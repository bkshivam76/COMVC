    function AfterVoucherClose_MRR(xEntryDate, ActionMethod = "",EntryID="")
    {
        //MembershipReceiptRegisterGrid.SetFocusedRowIndex(-1);
        if (ActionMethod == "_Delete" || ActionMethod == "Delete")
        {
            RefreshGridView("MembershipReceiptRegisterGrid");
            return;
        }
        if (ActionMethod != "_View" && ActionMethod != "View")
        {
            Select_xid_MRR = EntryID;
            var xFr_Date = new Date($("#MRR_Fr_Date").val());
            var xTo_Date = new Date($("#MRR_To_Date").val());
            xEntryDate = new Date(xEntryDate);
            var xMM = xEntryDate.getMonth() + 1;
            var SelectedIndex = xMM == 4 ? 0 : xMM == 5 ? 1 : xMM == 6 ? 2 : xMM == 7 ? 3 : xMM == 8 ? 4 : xMM == 9 ? 5 : xMM == 10 ? 6 : xMM == 11 ? 7 : xMM == 12 ? 8 : xMM == 1 ? 9 : xMM == 2 ? 10 : xMM == 3 ? 11 : 0;
            if (xFr_Date <= xEntryDate && xTo_Date >= xEntryDate)
            {
                RefreshGridView("MembershipReceiptRegisterGrid");
            }
            else
            {
                $("#MRR_PeriodSelection").dxSelectBox("instance").option("value", SelectedIndex);
            }
        }
    }
