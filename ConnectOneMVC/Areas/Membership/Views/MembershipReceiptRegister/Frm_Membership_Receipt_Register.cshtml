    function OnMembershipReceiptRegisterNewClick()
    {
        if ("@MembershipRR_AddRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Membership/MembershipReceiptRegister/Frm_Voucher_Membership",
            data: { Tag: "_New"},
            cache: false,
            success: function (data)
            {
                OpenDynamicPopup("New ~ Membership", null, "auto", 1000, true, data);
            }
        });
