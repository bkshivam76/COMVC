                    $(".MembershipReceiptRegisterGrid_PreviewRow").hide();
                }
                else
                {
                    $(".MembershipReceiptRegisterGrid_PreviewRow").show();
                }
                GetSessionStorage("MembershipReceiptRegisterGrid");
            }
        });
        HideLoader();
    }

