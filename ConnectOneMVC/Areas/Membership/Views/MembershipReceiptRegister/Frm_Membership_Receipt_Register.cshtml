<script>
    var MRRInfo_IsDetailRowExpanded = false;
    var MRRInfo_NestedRecord_FocusedRowIndex = -1;
    var MRRInfo_ParamMandatory;
    var MRRInfo_MasterRowRecID;
    var MRRInfo_Doc_ID;
    var MRRInfo_Doc_Category;
    var MRRInfo_FromDateLabel;
    var MRRInfo_ToDateLabel;
    var MRRInfo_DescriptionLabel;
    var MRRInfo_NestedGrid_AccessID;
    var MRRInfo_Attachment_RecStatus;
    var MRRInfo_AtachmentID;
    var MRRInfo_FileName;
    var MRRInfo_NestedRowMapID;
    var MRRInfo_reason;
    var MRRInfo_NestedRowReasonID;
    var MRRInfo_NestedRowUniqueID;
    var MRRInfo_MasterRowMID;

    function On_MembershipReceiptRegisterProfile_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@Help_Attachment_AddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (MRRInfo_ParamMandatory == 1)
            {
                AddAttachment(MRRInfo_MasterRowRecID, "Profile_MembershipReceiptRegister", MRRInfo_Doc_ID, BankInfo_Doc_Category, MRRInfo_ParamMandatory, MRRInfo_FromDateLabel, MRRInfo_ToDateLabel, MRRInfo_DescriptionLabel, "MembershipReceiptRegisterProfileAttachment", null, "MembershipReceiptRegisterGrid", MRRInfo_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(MRRInfo_MasterRowRecID, "Profile_MembershipReceiptRegister", MRRInfo_Doc_ID, "MembershipReceiptRegisterProfileAttachment", "MembershipReceiptRegisterGrid", MRRInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (MRRInfo_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(MRRInfo_MasterRowRecID, "Profile_MembershipReceiptRegister", MRRInfo_AtachmentID, MRRInfo_ParamMandatory, MRRInfo_FromDateLabel, MRRInfo_ToDateLabel, MRRInfo_DescriptionLabel, "MembershipReceiptRegisterProfileAttachment", null, "MembershipReceiptRegisterGrid", MRRInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(MRRInfo_MasterRowRecID, "Profile_MembershipReceiptRegister", MRRInfo_AtachmentID, MRRInfo_ParamMandatory, MRRInfo_FromDateLabel, MRRInfo_ToDateLabel, MRRInfo_DescriptionLabel, null, "MembershipReceiptRegisterGrid", MRRInfo_NestedGrid_AccessID, MRRInfo_Attachment_RecStatus);
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(MRRInfo_MasterRowRecID, "Profile_MembershipReceiptRegister", "Membership Receipt Register Information", "MembershipReceiptRegisterGrid", MRRInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@Help_Attachment_ViewRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            ViewDocument(MRRInfo_AtachmentID, MRRInfo_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName === "Add_Reason")
        {
            if (MRRInfo_Doc_Category.toLowerCase() == "others")
            {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else
            {
                AttachmentAddReason(MRRInfo_MasterRowRecID, MRRInfo_NestedRowMapID, "Profile_MembershipReceiptRegister", "MembershipReceiptRegisterGrid", MRRInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(MRRInfo_MasterRowRecID, MRRInfo_NestedRowMapID, "Profile_MembershipReceiptRegister", "MembershipReceiptRegisterGrid", MRRInfo_NestedGrid_AccessID, MRRInfo_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(MRRInfo_MasterRowRecID, MRRInfo_NestedRowMapID, "MembershipReceiptRegisterGrid", MRRInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
        else if (e.actionName == "AuditAction")
        {
            MRRPrf_FAB.SetActionContext("AuditActionContext", true);
        }
        else if (e.actionName == "BackAudit")
        {
            if (MRRInfo_Nested_Doc_Status == "")
            {
                MRRPrf_FAB.SetActionContext("AutoItemContext", true);
            }
            if (MRRInfo_Nested_Doc_Status == "NO")
            {
                MRRPrf_FAB.SetActionContext("EditItemContext", true);
            }
            if (MRRInfo_Nested_Doc_Status == "YES")
            {
                MRRPrf_FAB.SetActionContext("actionItemContext", true);
            }
        }
        else if (e.actionName == "Accept")
        {
            MRRInfo_AcceptwithoutRemarks();
        }
        else if (e.actionName == "Reject")
        {
            MRRInfo_AcceptRejectVoucher("Reject");
        }
        else if (e.actionName == "AcceptWithRemarks")
        {
            MRRInfo_AcceptRejectVoucher("Accept");
        }
        else if (e.actionName == "AcceptDoc")
        {
            OnMRRInfo_AcceptDoc();
        }
        else if (e.actionName == "RejectDoc")
        {
            OnMRRInfo_RejectDoc();
        }
    }

    function MRRInfo_AcceptwithoutRemarks()
    {
        var Recid;
        if (MRRInfo_IsDetailRowExpanded == true || MembershipRR_IsVouchingMode)
        {
            if (MRRInfo_MasterRowRecID == null || MRRInfo_MasterRowRecID == "")
            {
                Recid = MRRID_MRRProfile;
            }
            else
            {
                Recid = MRRInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = MRRID_MRRProfile;
        }
        Entry_AcceptwithoutRemarks(Recid, "Profile_MembershipReceiptRegister", "MembershipReceiptRegisterGrid", MRRInfo_AtachmentID, MRRInfo_NestedRowReasonID, MRRInfo_NestedRowUniqueID);
    }

    function MRRInfo_AcceptRejectVoucher(_actionMethod)
    {
        var Recid;

        if (MRRInfo_IsDetailRowExpanded == true || MembershipRR_IsVouchingMode)
        {
            if (MRRInfo_MasterRowRecID == null || MRRInfo_MasterRowRecID == "")
            {
                Recid = MRRID_MRRProfile;
            }
            else
            {
                Recid = MRRInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = MRRID_MRRProfile;
        }
        Entry_AcceptReject(_actionMethod, Recid, "Profile_MembershipReceiptRegister", "MembershipReceiptRegisterGrid", MRRInfo_AtachmentID, MRRInfo_NestedRowReasonID, MRRInfo_NestedRowUniqueID);
    }

    function OnMRRInfo_RejectDoc()
    {
        if (MRRInfo_AtachmentID == null || MRRInfo_AtachmentID.length == 0)
        {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        RejectAttachment(MRRInfo_AtachmentID, "MembershipReceiptRegisterGrid", MRRInfo_NestedGrid_AccessID);
    }

    function OnMRRInfo_AcceptDoc()
    {
        if (MRRInfo_AtachmentID == null || MRRInfo_AtachmentID.length == 0)
        {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        AcceptAttachment(MRRInfo_AtachmentID, "MembershipReceiptRegisterGrid", MRRInfo_NestedGrid_AccessID);
    }

    function OnMRRListGridNestedFocusedRowChange(s, e)
    {
        if (MRRInfo_IsDetailRowExpanded || MembershipRR_IsVouchingMode)
        {
            MRRInfo_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
            if (MRRInfo_NestedRecord_FocusedRowIndex >= 0)
            {
                ShowLoader();
                MRRInfo_NestedGrid_AccessID = s.uniqueID;
                s.GetRowValues(s.GetFocusedRowIndex(), 'Doc_Status;Params_Mandatory;LABEL_FROM_DATE;LABEL_TO_DATE;LABEL_DESCRIPTION;Document_Category;Document_ID;ATTACH_ID;TxnID;TxnMID;MAP_ID;Reason;ATTACH_FILE_NAME;Attachment_Action_Status;UniqueID;ReasonID', OnMRRInfo_GetGridRowValues);
            }
            else
            {
                MRRPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }

    function OnMRRInfo_GetGridRowValues(values)
    {
        HideLoader();
        MRRInfo_NestedRowUniqueID = values[14];
        if (values[14] != null)
        {
            MRRPrf_FAB.SetVisible(true);
            MRRInfo_Nested_Doc_Status = values[0];

            if (MembershipRR_IsVouchingMode == true)
            {
                MRRPrf_FAB.SetActionContext("AuditActionContext", true);
            }
            else
            {
                if (MRRInfo_Nested_Doc_Status == "")
                {
                    MRRPrf_FAB.SetActionContext("AutoItemContext", true);
                }
                else if (MRRInfo_Nested_Doc_Status == "NO")
                {
                    MRRPrf_FAB.SetActionContext("EditItemContext", true);
                }
                else if (MRRInfo_Nested_Doc_Status == "YES")
                {
                    MRRPrf_FAB.SetActionContext("actionItemContext", true);
                }
            }

            MRRInfo_ParamMandatory = values[1];
            MRRInfo_FromDateLabel = values[2];
            MRRInfo_ToDateLabel = values[3];
            MRRInfo_DescriptionLabel = values[4];
            MRRInfo_Doc_Category = values[5];
            MRRInfo_Doc_ID = values[6];
            MRRInfo_AtachmentID = values[7];
            IndexAttachmentID = MRRInfo_AtachmentID;
            MRRInfo_MasterRowRecID = values[8];
            MRRInfo_MasterRowMID = values[9];
            MRRInfo_NestedRowMapID = values[10];
            MRRInfo_reason = values[11];
            MRRInfo_FileName = values[12];
            MRRInfo_Attachment_RecStatus = values[13];

            if (MembershipRR_IsVouchingMode == true)
            {
                if (MRRInfo_FileName != null && MRRInfo_FileName.length > 0)
                {
                    ViewDocument(MRRInfo_AtachmentID, MRRInfo_FileName, "MRRPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else
                {
                    var pane = Mainspliter.GetPaneByName('RightPane');
                    pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
                    document.getElementById('RightPane_div_Iframe').style.display = "none";
                    document.getElementById('RightPane_div_Img').style.display = "none";
                }
            }
        }

        MRRInfo_NestedRowReasonID = values[15];
        IndexAttachmentReasonID = MRRInfo_NestedRowReasonID;
    }

    function MRRGrid_Nested_BeginCallBack(s, e)
    {
        e.customArgs["command"] = e.command;
        e.customArgs["ShowHorizontalBar"] = MembershipRR_ShowHorizontalBar;
    }

    function MRRGrid_DetailRowExpanding(s, e)
    {
        MRRInfo_IsDetailRowExpanded = true;
        s.SetFocusedRowIndex(e.visibleIndex);
        var pane = Mainspliter.GetPaneByName('RightPane');
        if (MembershipRR_IsVouchingMode == true)
        {
            pane.Expand();
        }
        else
        {
            pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
        }
    }

    function MRRGrid_DetailRowCollapsing(s, e)
    {
        MRRInfo_IsDetailRowExpanded = false;
        s.SetFocusedRowIndex(e.visibleIndex);
        if (MembershipRR_IsVouchingMode == false)
        {
            MRRPrf_FAB.SetVisible(false);
        }
        if (MembershipRR_IsVouchingMode == true)
        {
            if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false)
            {
                CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
    }

