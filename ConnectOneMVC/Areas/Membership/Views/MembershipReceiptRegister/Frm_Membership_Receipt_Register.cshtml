        if (MembershipReceiptRegisterID_MRR != null)
        {
            MRR_Add_Date = (moment(MRR_Add_Date).format("DD/MM/YYYY HH:mm:ss"));
            MRR_Edit_Date = (moment(MRR_Edit_Date).format("DD/MM/YYYY HH:mm:ss"));
            MRR_Action_Date = (moment(MRR_Action_Date).format("DD/MM/YYYY HH:mm:ss"));
            Status = MRR_Action_Status;
            StatusStr = Status == "Locked" ? "Locked" : Status == null ? null : "UnLocked";

            if (Status && Status.toUpperCase() == "LOCKED")
            {
                Lbl_Status = "Completed";
                Lbl_Status_Color = "blue";
                Pic_Status = "fa fa-lock";
            }
            else
            {
                Pic_Status = "fa fa-unlock";
                Lbl_Status = Status;
                if (Status && Status.toUpperCase() == "COMPLETED")
                {
                    Lbl_Status_Color = "green";
                }
                else
                {
                    Lbl_Status_Color = "red";
                }
            }
            if (MRR_Action_Date)
            {
                Lbl_ActionOn = StatusStr + " On: " + MRR_Action_Date;
                Lbl_ActionBy = StatusStr + " By: " + MRR_Action_By.toUpperCase();
            }
            else
            {
                Lbl_ActionOn = "";
                Lbl_ActionBy = "";
            }
            if (MRR_Add_Date)
            {
                Lbl_Create = "Add On: " + MRR_Add_Date + ", By: " + MRR_Add_By.toUpperCase();
            }
            else
            {
                Lbl_Create = "";
            }

            if (MRR_Edit_Date)
            {
                Lbl_Modify = "Edit On: " + MRR_Edit_Date + ", By: " + MRR_Edit_By.toUpperCase();
            }
            else
            {
                Lbl_Modify = "";
            }
        }
        //$('#BankLbl_Status').text(Lbl_Status);
        $('#Lbl_ActionOn_MRR').text(Lbl_ActionOn)
        $('#Lbl_ActionBy_MRR').text(Lbl_ActionBy);
        $('#Lbl_Create_MRR').text(Lbl_Create);
        $('#Lbl_Modify_MRR').text(Lbl_Modify);
        if (Lbl_Status_Color != "")
        {
            $('#BankLbl_Status').css('color', Lbl_Status_Color);
        }
        if (Pic_Status == "fa fa-lock")
        {
            $('#LockICON_MRR').addClass(Pic_Status).removeClass("fa-unlock");
        }
        else if (Pic_Status == "fa fa-unlock")
        {
            $('#LockICON_MRR').addClass(Pic_Status).removeClass("fa-lock");
        }
        else
        {
            $('#LockICON_MRR').removeClass("fa");
            $('#LockICON_MRR').removeClass("fa-lock");
            $('#LockICON_MRR').removeClass("fa-unlock");
        }
    }

    function OnGridMembershipRRListGrid_RowDblClick(s, e)
    {
        if (MembershipRR_IsVouchingMode == false)
        {
            OnMembershipReceiptRegisterButtonClick("EDIT");
        }
        else { e.cancel = true; }
    }

    function MRR_VouchingSwitch_ValueChange(e)
    {
        MembershipRR_IsVouchingMode = e.value;
        if (MRRInfo_SetVouchingModeOn == true)
        {
            MRRInfo_SetVouchingModeOn = false;
        }
        else
        {
            MRRPrf_FAB.SetVisible(false);
        }
        if (MembershipRR_IsVouchingMode == true)
        {
            var Rightpane = Mainspliter.GetPaneByName('RightPane');
            Rightpane.Expand();
            var Leftpane = Mainspliter.GetPaneByName('LeftPane');
            ClearLeftPane();
            if (Leftpane.IsCollapsed() == true)
            {
                Leftpane.Expand();
            }
        }
        else
        {
            var Rightpane = Mainspliter.GetPaneByName('RightPane');
            if (Rightpane.IsCollapsed() == false)
            {
                Rightpane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
            }
            var Leftpane = Mainspliter.GetPaneByName('LeftPane');
            ClearLeftPane();
            if (Leftpane.IsCollapsed() == false)
            {
                Leftpane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
        MRRGrid_CollapseAllDetailRows();
    }

    function MRRGrid_CollapseAllDetailRows()
    {
        if (typeof window !== 'undefined')
        {
            if (typeof window.MembershipReceiptRegisterGrid !== 'undefined')
            {
                if (typeof window.MembershipReceiptRegisterGrid.CollapseAllDetailRows !== 'undefined')
                {
                    if (typeof MembershipReceiptRegisterGrid.CollapseAllDetailRows == 'function')
                    {
                        MembershipReceiptRegisterGrid.SetFocusedRowIndex(-1);
                        MembershipReceiptRegisterGrid.CollapseAllDetailRows();
                    }
                    else
                    {
                        alert("CollapseAllDetailRows is not a function");
                    }
                }
                else
                {
                    ShowLoader();
                    setTimeout(function ()
                    {
                        MRR_CollapseAllDetailRows();
                        HideLoader();
                    }, Timeout500);
                }
            }
            else
            {
                alert('grid undefined')
            }
        }
        else
        {
            alert('window undefined')
        }
    }

    function MRR_ViewSwitch_ValueChange(e)
    {
        MRR_ViewMode = e.value == false ? "Default" : "Compact";
        if (MRRInfo_SetVouchingModeOn == true)
        {
            $("#MembershipRRVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }
        else
        {
            MembershipReceiptRegisterGrid.CollapseAllDetailRows();
        }
    }

