@Html.DevExpress().GridView(
settings =>
{
    settings.Name = "SummaryListGrid";
    settings.CallbackRouteValues = new
    {
        Controller = "MembershipReceiptRegister",
        Action = "Frm_View_SummaryGrid"

    };

    settings.Settings.VerticalScrollBarMode = ScrollBarMode.Hidden;

    if (Request.Browser.IsMobileDevice)
    {
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Visible;
    }

    settings.KeyboardSupport = true;
    //settings.AccessKey = "G";
    settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
    settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.HideDataCells;
    settings.Settings.UseFixedTableLayout = true;
    settings.SettingsBehavior.AllowFocusedRow = false;
    settings.Settings.AutoFilterCondition = AutoFilterCondition.Contains;
    settings.Settings.ShowHeaderFilterBlankItems = false;
    settings.SettingsContextMenu.Enabled = false;
    settings.SettingsBehavior.EnableCustomizationWindow = true;
    settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
    settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
    settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;


    settings.KeyFieldName = "Sr";

    settings.Columns.Add(new MVCxGridViewColumn()
    {
        FieldName = "Title",
        Caption = "Title",
        GroupIndex = 0,
        SortOrder = DevExpress.Data.ColumnSortOrder.Descending,
        Visible = false
    });
    settings.Columns.Add(column =>
    {
        column.FieldName = "Description";
        column.Caption = "Description";
        column.Width = System.Web.UI.WebControls.Unit.Percentage(24);
    });
    settings.Columns.Add(column =>
    {
        column.FieldName = "O_BALANCE";
        column.Caption = "Opening Balance";
        column.PropertiesEdit.DisplayFormatString = "#,0.00";
        column.Width = System.Web.UI.WebControls.Unit.Percentage(19);
    });
    settings.Columns.Add(column =>
    {
        column.FieldName = "R_BALANCE";
        column.Caption = "Total Receipt";
        column.PropertiesEdit.DisplayFormatString = "#,0.00";
        column.Width = System.Web.UI.WebControls.Unit.Percentage(19);
    });
    settings.Columns.Add(column =>
    {
        column.FieldName = "P_BALANCE";
        column.Caption = "Total Payment";
        column.PropertiesEdit.DisplayFormatString = "#,0.00";
        column.Width = System.Web.UI.WebControls.Unit.Percentage(19);
    });
    settings.Columns.Add(column =>
    {
        column.FieldName = "C_BALANCE";
        column.Caption = "Closing Balance";
        column.PropertiesEdit.DisplayFormatString = "#,0.00";
        column.Width = System.Web.UI.WebControls.Unit.Percentage(19);
    });
    settings.Columns.Add(column =>
    {
        column.FieldName = "Sr";
        column.Caption = "Sr";
        column.Visible = false;
        column.SortOrder = DevExpress.Data.ColumnSortOrder.Ascending;
    });

    settings.Settings.ShowGroupFooter = GridViewGroupFooterMode.VisibleAlways;

    settings.GroupSummary.Add(new ASPxSummaryItem() { SummaryType = DevExpress.Data.SummaryItemType.Count, FieldName = "Description", DisplayFormat = "Total :", ShowInGroupFooterColumn = "Description" });
    settings.GroupSummary.Add(new ASPxSummaryItem() { SummaryType = DevExpress.Data.SummaryItemType.Sum, FieldName = "O_BALANCE", DisplayFormat = "{0:#,0.00}", ShowInGroupFooterColumn = "O_BALANCE" });
    settings.GroupSummary.Add(new ASPxSummaryItem() { SummaryType = DevExpress.Data.SummaryItemType.Sum, FieldName = "R_BALANCE", DisplayFormat = "{0:#,0.00}", ShowInGroupFooterColumn = "R_BALANCE" });
    settings.GroupSummary.Add(new ASPxSummaryItem() { SummaryType = DevExpress.Data.SummaryItemType.Sum, FieldName = "P_BALANCE", DisplayFormat = "{0:#,0.00}", ShowInGroupFooterColumn = "P_BALANCE" });
    settings.GroupSummary.Add(new ASPxSummaryItem() { SummaryType = DevExpress.Data.SummaryItemType.Sum, FieldName = "C_BALANCE", DisplayFormat = "{0:#,0.00}", ShowInGroupFooterColumn = "C_BALANCE" });

    settings.Styles.GroupFooter.Font.Bold = true;
    settings.Styles.GroupFooter.HorizontalAlign = System.Web.UI.WebControls.HorizontalAlign.Right;

    settings.Settings.ShowFooter = true;
    settings.TotalSummary.Add(DevExpress.Data.SummaryItemType.Custom, "Description").DisplayFormat = "Grand Total : {0:0}";
    settings.TotalSummary.Add(DevExpress.Data.SummaryItemType.Sum, "O_BALANCE").DisplayFormat = "{0:#,0.00}";
    settings.TotalSummary.Add(DevExpress.Data.SummaryItemType.Sum, "R_BALANCE").DisplayFormat = "{0:#,0.00}";
    settings.TotalSummary.Add(DevExpress.Data.SummaryItemType.Sum, "P_BALANCE").DisplayFormat = "{0:#,0.00}";
    settings.TotalSummary.Add(DevExpress.Data.SummaryItemType.Sum, "C_BALANCE").DisplayFormat = "{0:#,0.00}";

    settings.Styles.Footer.Font.Bold = true;
    settings.Styles.Footer.ForeColor = System.Drawing.Color.Blue;
    settings.Styles.Footer.HorizontalAlign = System.Web.UI.WebControls.HorizontalAlign.Right;

    settings.SettingsBehavior.AutoExpandAllGroups = true;
}).Bind(Model).GetHtml()


