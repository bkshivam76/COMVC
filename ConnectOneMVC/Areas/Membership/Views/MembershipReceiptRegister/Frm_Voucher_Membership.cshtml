<div class="MembershipVoucher_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    @model ConnectOneMVC.Areas.Membership.Models.VoucherMembershipInfo
    @{

        bool MembershipRR_ListAdresBookRight = (bool)ViewData["MembershipRR_ListAdresBookRight"];
        bool MembershipRR_AddAdresBookRight = (bool)ViewData["MembershipRR_AddAdresBookRight"];
        bool MembershipRR_UpdateAdresBookRight = (bool)ViewData["MembershipRR_UpdateAdresBookRight"];
        string Open_Ins_ID = (string)ViewData["Open_Ins_ID"];

        Html.EnableClientValidation();
        Html.EnableUnobtrusiveJavaScript();
        Html.AntiForgeryToken();
    }
    <style>
        .negative .dx-texteditor-input {
            background: lightsalmon;
        }

        .positive .dx-texteditor-input {
            background: aliceblue;
        }
    </style>
    <style>
        .h22 {
            height: 22px !important;
            padding-left: 2px !important;
        }

        .text-blue3 {
            color: #701eff !important;
        }

        #But_Manage_Member_MRR .dx-icon, #But_Add_Member_MRR .dx-icon, #Edit_Member_MRR .dx-icon {
            width: 24px;
            height: 24px;
        }
            #But_Add_Member_MRR .dx-button-text, #But_Manage_Member_MRR .dx-button-text, #Edit_Member_MRR .dx-button-text 
            {    
                white-space: normal !important;   
                vertical-align: top !important;       
            }
        #But_Add_Member_MRR .dx-button-content, #But_Manage_Member_MRR .dx-button-content, #Edit_Member_MRR .dx-button-content 
        {
            height: inherit;
            padding-top: 3px;
            padding-left: 33px;          
        }

        .expire_txt {
            font-style: italic;
            color: blue !important;
        }

        .fee_txt {
            font-style: italic;
            color: gray !important;
        }

        #Txt_Subs_Fee_MRR,
        #Txt_Ent_Fee_MRR {
            color: gray !important;
        }

        #Frm_Voucher_Membership_Window_popup {
            padding: 0px 0px 0px 0px;
        }
        .custom-dropdown-wid > div {
            width: 100%;
            position: relative;
            top: -2px;
            height:24px
        }
        .custom-dropdown-wid .dx-button-content {
            padding: 10px
        }
        .custom-dropdown-wid:before {
            z-index: 1;
            pointer-events: none
        }
    </style>
    <div id="Frm_Voucher_Membership_Window_popup" class="container-fluid">
        @using (Ajax.BeginForm("Frm_Voucher_Membership_Window_BUT_SAVE_Click", "MembershipReceiptRegister",
               new AjaxOptions
               {
                   HttpMethod = "POST",
                   UpdateTargetId = "Frm_Voucher_Membership_Window_popup",
                   InsertionMode = InsertionMode.InsertAfter,
                   OnBegin = "AjaxBeginFormPost",
                   OnSuccess = "Frm_Voucher_Membership_Window_AjaxSuccessForm_MRR"
               },
               new
               {
                   id = "ID_Frm_Voucher_Membership_Window_Form",
                   @class = "edit_form form-horizontal"
               }))
        {
            @Html.HiddenFor(x => x.ActionMethod)
            @Html.HiddenFor(x => x.TitleX_MRR)
            @Html.HiddenFor(x => x.xMID_MRR)
            @Html.HiddenFor(x => x.xID_MRR)
            @Html.HiddenFor(x => x.iTrans_Type_MRR)
            @Html.HiddenFor(x => x.iLed_ID_MRR)
            @Html.HiddenFor(x => x.iVoucher_Type_MRR)
            @Html.HiddenFor(x => x.iProfile_MRR)
            @Html.HiddenFor(x => x.xWing_Short_MRR)
            @Html.HiddenFor(x => x.iSpecific_ItemID)
            @Html.HiddenFor(x => x.Cnt_BankAccount)
            @Html.HiddenFor(x => x.Tag)
            @*@Html.HiddenFor(x=>x.Edit_MEM_OLD_NO_MRR)*@
            @Html.HiddenFor(x => x.Edit_REC_ID_MRR)
            @Html.HiddenFor(x => x.GLookUp_SubList_Tag)
            @Html.HiddenFor(x => x.Membership_Last_Edit_Time)
            @Html.HiddenFor(x => x.Last_Edit_Time_MRR)
            @*@Html.HiddenFor(x=>x.Add_Time_MRR)*@
            @Html.HiddenFor(x => x.Subs_Category_MRR)
            @Html.HiddenFor(x => x.Subs_Start_Month_MRR)
            @Html.HiddenFor(x => x.Subs_Total_Month_MRR)
            @Html.HiddenFor(x => x.Info_LastEditedOn_MRR)
            @Html.HiddenFor(x => x.Cmb_Period_SelectedIndexChanged)
            @Html.HiddenFor(x => x.Add_Time)
            @Html.HiddenFor(x => x.GridToRefresh)
            @Html.HiddenFor(x => x.GLookUp_SubList_Text_MRR)//Redmine Bug #135455 fixed
            @Html.HiddenFor(x => x.WingListEnabled)
            @Html.HiddenFor(x => x.Edit_WING_ID)
            @Html.HiddenFor(x => x.Edit_AB_ID)
            @Html.HiddenFor(x => x.MemberDD_Data)
            @Html.HiddenFor(x => x.DocumentGettingReady)
            @Html.HiddenFor(x => x.PC_MemberName_MRR)

            using (Html.DevExtreme().ValidationGroup("MembershipReceiptRegister_Profile"))
            {
                <div class="full-width-header-bg4">
                    <div class="row">
                        <div class="col-sm-8 pll">
                            <h3 class="popuphead"><i class="far fa-edit"></i>Membership</h3>
                        </div>
                        <div class="col-sm-4 prm">
                            <h5 class="mand-txt-align"><i class="fas fa-info-circle"></i> Red Fields are mandatory</h5>
                        </div>
                    </div>
                </div><!--[Header]-->
                <div class="row">
                    <div class="col-sm-4 col-md-4 col-lg-4">
                        <div class="form-field">
                            <div class="row">
                                <div class="col-sm-4 col-md-4 col-lg-4 pll">
                                    @Html.Label("Voucher Date:", htmlAttributes: new { @class = "control-label text-red" })
                                </div>
                                <div class="col-sm-8 col-md-8 col-lg-8 prm">
                                    @(Html.DevExtreme().DateBox().CustomDateBox().ID("Txt_V_Date_MRR").Name("Txt_V_Date_MRR").Value(Model.Txt_V_Date_MRR).OnValueChanged("Txt_V_Date_EditValueChanged_MRR"))@*//Redmine Bug #135465 fixed*@
                                </div>
                            </div>
                        </div>
                    </div><!--[Voucher Date]-->
                    <div class="col-sm-8 col-md-8 col-lg-8">
                        <div class="form-field">
                            <div class="row">
                                <div class="col-sm-2 col-md-2 col-lg-2 pll">
                                    @Html.Label("Item Name:", htmlAttributes: new { @class = "control-label text-red", @id = "lbl_itemName_MRR" })
                                </div>
                                <div class="col-sm-10 col-md-10 col-lg-10 prm">
                                    @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_ItemList_MRR").Name("GLookUp_ItemList_MRR").ValueExpr("ITEMID").DisplayExpr("ITEMNAME").Placeholder("Select Item...").Value(Model.GLookUp_ItemList_MRR)
                                .DataSource(Model.ItemDD_Data,"ITEMID").ReadOnly(true).OnValueChanged("GLookUp_ItemList_EditValueChanged_MRR").ContentTemplate(@<text> @Html.Partial("MembershipRR_LookUp_GetItemList") </text>).FocusStateEnabled(false) )
                                </div>
                            </div>
                        </div>
                    </div><!--[Item Name]-->
                </div><!--[Row 1]-->
                <div class="row">
                    <div class="col-sm-4 col-md-4 col-lg-4">
                        <div class="form-field">
                            <div class="row">
                                <div class="col-sm-4 col-md-4 col-lg-4 pll">
                                    @Html.Label("Voucher No:", htmlAttributes: new { @class = "control-label disabletxt" })
                                </div>
                                <div class="col-sm-8 col-md-8 col-lg-8 prm">
                                    @(Html.DevExtreme().TextBox().CustomTextBox().ID("Txt_V_No_MRR").Name("Txt_V_No_MRR").MaxLength(100).Value(Model.Txt_V_No_MRR).FocusStateEnabled(false) .ReadOnly(true) )
                                </div>
                            </div>
                        </div>
                    </div><!--[V No]-->
                    <div class="col-sm-8 col-md-8 col-lg-8">
                        <div class="form-field">
                            <div class="row">
                                <div class="col-sm-2 col-md-2 col-lg-2 pll">
                                    @Html.Label("Head:", htmlAttributes: new { @class = "control-label disabletxt" })
                                </div>
                                <div class="col-sm-10 col-md-10 col-lg-10 prm">
                                    @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_Item_Head_MRR") .Name("BE_Item_Head_MRR") .ReadOnly(true).FocusStateEnabled(false).MaxLength(50) )
                                </div>
                            </div>
                        </div>
                    </div><!--[Head]-->
                </div><!--[Row 2]-->
                <div class="row">
                    <div class="col-sm-12 col-md-12 ">
                        <div class="form-field">
                            <fieldset class="default-fieldset">
                                @*<legend class="custom-legend mlm"><label>Member Detail:</label></legend>*@
                                <label class="custom-legend mlm">Member Detail:</label>
                                <div class="row">
                                    <div class="col-sm-8">
                                        <div class="row">
                                            <div class="col-sm-2 col-md-2 col-lg-2 pll">
                                                @Html.Label("Member Name:", htmlAttributes: new { @class = "control-label text-red" })
                                            </div>
                                            <div class="col-sm-8 col-md-8 col-lg-8">
                                                @*@(Html.DevExtreme().DropDownBox().CustomDropDown().ID("PC_MemberName_MRR").Name("PC_MemberName_MRR").ValueExpr("C_ORG_ID").DisplayExpr("C_NAME").Value(Model.PC_MemberName_MRR)
        .DataSource(Model.MemberDD_Data,"C_ORG_ID").OnValueChanged("PC_MemberName_ButtonClick_MRR").ContentTemplate(@<text> @Html.Partial("Get_MemberList")</text>))*@@*//Redmine Bug #135465 fixed*@
                                            @(Html.DevExtreme().TextBox().CustomTextBox(true,true) .ID("PC_MemberName_Textbox_MRR") .Name("PC_MemberName_Textbox_MRR")@*.OnValueChanged("PC_MemberName_OnValueChange_MRR")*@.OnKeyDown("PC_MemberName_Textbox_OnKeyDown").ShowClearButton(false).FocusStateEnabled(true).ReadOnly(false) )  @*//Redmine Bug #135940 fixed*@
                                            </div>
                                            <div class="col-sm-2 col-md-2 col-lg-2" style="width: 12%;">
                                                @(Html.DevExtreme().Button() .ID("But_Select_MRR") .Text("Search").Disabled(Model.TempActionMethod !="_New") .FocusStateEnabled(false) .OnClick("But_Search_Click") )
                                            </div>
                                            <div class="col-sm-1 col-md-1 col-lg-1 dx-dropdowneditor-icon custom-dropdown-wid" style="width: 4.5%;">
                                                @(Html.DevExtreme().Button() .ID("Search_Down_MRR") .Text("").Disabled(Model.TempActionMethod != "_New") .FocusStateEnabled(false) .OnClick("But_Search_Down_Click") )

                                            </div>
                                        </div><!--[Member Name]-->
                                        <div class="row">
                                            <div class="col-sm-2">
                                                <div class="pll">
                                                    @Html.Label("Address:", htmlAttributes: new { @class = "control-label" })
                                                </div>
                                                <div class="row">
                                                    <div class="col-sm-12">
                                                        @(Html.DevExtreme().Button() .ID("But_Add_Member_MRR") .Text("Add Member").Height(45).Width("100%") .Icon(Url.Content("../../../../Icons/add user.png")) .Disabled(Model.TempActionMethod=="_Delete"|| Model.TempActionMethod == "_View") .FocusStateEnabled(false) .OnClick("But_MemAdd_Click") )@*//Redmine Bug #135465 fixed*@
                                                        @(Html.DevExtreme().Button() .ID("Edit_Member_MRR") .Text("Edit Member").Height(45).Width("100%").Icon(Url.Content("../../../../Icons/manage user.png")) .Disabled(Model.TempActionMethod == "_Delete" || Model.TempActionMethod == "_View") .FocusStateEnabled(false) .OnClick("But_MemEdit_Click") )@*//Redmine Bug #135465 fixed*@
                                                        @(Html.DevExtreme().Button() .ID("But_Manage_Member_MRR") .Text("Manage Member").Height(45).Width("100%").Icon(Url.Content("../../../../Icons/manage user.png")) .Disabled(Model.TempActionMethod == "_Delete" || Model.TempActionMethod == "_View") .FocusStateEnabled(false) .OnClick("But_MemManage_Click") )@*//Redmine Bug #135465 fixed*@
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-sm-10">
                                                @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Add1_MRR").ID("BE_Add1_MRR").ReadOnly(true).FocusStateEnabled(false))
                                                @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Add2_MRR").ID("BE_Add2_MRR").ReadOnly(true).FocusStateEnabled(false))
                                                @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Add3_MRR").ID("BE_Add3_MRR").ReadOnly(true).FocusStateEnabled(false))
                                                @(Html.DevExtreme().TextBox().CustomTextBox().Name("BE_Add4_MRR").ID("BE_Add4_MRR").ReadOnly(true).FocusStateEnabled(false))
                                                <div class="row">
                                                    <div class="col-sm-2 col-md-2 col-lg-2 brd-div h22">
                                                        @Html.Label("City:", htmlAttributes: new { @class = "control-label" })
                                                    </div>
                                                    <div class="col-sm-10 col-md-10 col-lg-10">
                                                        @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_City_MRR") .Name("BE_City_MRR") .FocusStateEnabled(false) .ReadOnly(true) )
                                                    </div>
                                                </div><!--[City]-->
                                                <div class="row">
                                                    <div class="col-sm-2 brd-div h22">
                                                        @Html.Label("PinCode:", htmlAttributes: new { @class = "control-label" })
                                                    </div>
                                                    <div class="col-sm-4">
                                                        @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_Pincode_MRR") .Name("BE_Pincode_MRR") .FocusStateEnabled(false) .ReadOnly(true) )
                                                    </div><!--[Pincode]-->
                                                    <div class="col-sm-2 brd-div h22">
                                                        @Html.Label("District:", htmlAttributes: new { @class = "control-label" })
                                                    </div>
                                                    <div class="col-sm-4">
                                                        @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_District_MRR") .Name("BE_District_MRR") .FocusStateEnabled(false) .ReadOnly(true) )
                                                    </div><!--[District]-->
                                                </div>
                                                <div class="row">
                                                    <div class="col-sm-2 brd-div h22">
                                                        @Html.Label("State:", htmlAttributes: new { @class = "control-label" })
                                                    </div>
                                                    <div class="col-sm-4">
                                                        @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_State_MRR") .Name("BE_State_MRR") .FocusStateEnabled(false) .ReadOnly(true) )
                                                    </div><!--[State]-->
                                                    <div class="col-sm-2 brd-div h22">
                                                        @Html.Label("Country:", htmlAttributes: new { @class = "control-label" })
                                                    </div>
                                                    <div class="col-sm-4">
                                                        @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_Country_MRR") .Name("BE_Country_MRR") .FocusStateEnabled(false) .ReadOnly(true) )
                                                    </div><!--[Country]-->
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-sm-2 pll">
                                                @Html.Label("Centre Name:", htmlAttributes: new { @class = "control-label text-red" })
                                            </div>
                                            <div class="col-sm-10">
                                                @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_Cen_Name_MRR") .Name("BE_Cen_Name_MRR") .FocusStateEnabled(false) .ReadOnly(true) )
                                            </div>
                                        </div><!--[Centre Name]-->
                                    </div><!--[Left Part]-->
                                    <div class="col-sm-4">
                                        <div class="row">
                                            <div class="col-sm-4 col-md-4 col-lg-4 brd-div h22">
                                                @Html.Label("Membership No:", htmlAttributes: new { @class = "control-label text-blue3" })
                                            </div>
                                            <div class="col-sm-8 col-md-8 col-lg-8">
                                                @(Html.DevExtreme().TextBox().CustomTextBox(true) .ID("Txt_Mem_No_MRR") .Name("Txt_Mem_No_MRR") .MaxLength(100) .FocusStateEnabled(false) .ReadOnly(true).Value(Model.Txt_Mem_No_MRR) )
                                            </div>
                                        </div><!--[Mem No]-->
                                        <div class="row">
                                            <div class="col-sm-4 col-md-4 col-lg-4 brd-div h22">
                                                @Html.Label("Tel No(s):", htmlAttributes: new { @class = "control-label" })
                                            </div>
                                            <div class="col-sm-8 col-md-8 col-lg-8">
                                                @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_Tel_Nos_MRR") .Name("BE_Tel_Nos_MRR") .MaxLength(100) .FocusStateEnabled(false) .ReadOnly(true) )
                                            </div>
                                        </div><!--[Tel No]-->
                                        <div class="row">
                                            <div class="col-sm-4 col-md-4 col-lg-4 brd-div h22">
                                                @Html.Label("Mobile No(s):", htmlAttributes: new { @class = "control-label" })
                                            </div>
                                            <div class="col-sm-8 col-md-8 col-lg-8">
                                                @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_Mob_No_MRR") .Name("BE_Mob_No_MRR") .FocusStateEnabled(false) .MaxLength(100) .ReadOnly(true) )
                                            </div>
                                        </div><!--[Mob No]-->
                                        <div class="row">
                                            <div class="col-sm-4 col-md-4 col-lg-4 brd-div h22">
                                                @Html.Label("Email(s):", htmlAttributes: new { @class = "control-label" })
                                            </div>
                                            <div class="col-sm-8 col-md-8 col-lg-8">
                                                @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_Email_No_MRR") .Name("BE_Email_No_MRR") .MaxLength(100) .ReadOnly(true) .FocusStateEnabled(false) )
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-sm-4 col-md-4 col-lg-4 brd-div h22">
                                                @Html.Label("Qualification:", htmlAttributes: new { @class = "control-label" })
                                            </div>
                                            <div class="col-sm-8 col-md-8 col-lg-8">
                                                @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_Qual_MRR") .Name("BE_Qual_MRR") .FocusStateEnabled(false) .ReadOnly(true) )
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-sm-4 col-md-4 col-lg-4 brd-div h22">
                                                @Html.Label("Occupation:", htmlAttributes: new { @class = "control-label" })
                                            </div>
                                            <div class="col-sm-8 col-md-8 col-lg-8">
                                                @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_Occupation_MRR") .Name("BE_Occupation_MRR") .FocusStateEnabled(false) .ReadOnly(true) )
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-sm-4 col-md-4 col-lg-4 brd-div h22">
                                                @Html.Label("Birth-Date:", htmlAttributes: new { @class = "control-label" })
                                            </div>
                                            <div class="col-sm-8 col-md-8 col-lg-8">
                                                @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_DOB_MRR") .Name("BE_DOB_MRR") .FocusStateEnabled(false) .ReadOnly(true))@*//Redmine Bug #135444 fixed*@
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-sm-4 col-md-4 col-lg-4 brd-div h22">
                                                @Html.Label("Age:", htmlAttributes: new { @class = "control-label" })
                                            </div>
                                            <div class="col-sm-8 col-md-8 col-lg-8">
                                                @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_AGE_MRR") .Name("BE_AGE_MRR") .FocusStateEnabled(false) .ReadOnly(true) )
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-sm-4 col-md-4 col-lg-4 brd-div h22">
                                                @Html.Label("Centre UID:", htmlAttributes: new { @class = "control-label text-blue3" })
                                            </div>
                                            <div class="col-sm-8 col-md-8 col-lg-8">
                                                @(Html.DevExtreme().TextBox().CustomTextBox() .ID("BE_Cen_UID_MRR") .Name("BE_Cen_UID_MRR") .FocusStateEnabled(false) .ReadOnly(true) )
                                            </div>
                                        </div>
                                    </div><!--[Right Part]-->
                                </div>
                            </fieldset>
                        </div>
                    </div>
                </div>
                <!-- Subscription Detail -->
                <div class="row">
                    <div class="col-sm-12 col-md-12 ">
                        <div class="form-field">
                            <fieldset class="default-fieldset">
                                <div class="row">
                                    <div class="col-sm-3">
                                        <label class="custom-legend mlm">Subscription Detail:</label>
                                    </div>
                                    <div class="col-sm-4"><label id="lbl_Expire" class="expire_txt">@Model.lbl_Expire_Text</label></div>
                                    <div class="col-sm-5"><label id="lbl_FeeEff" class="fee_txt">@Model.lbl_FeeEff_Text</label></div>
                                </div>
                                <div class="row">
                                    <div class="col-sm-4">
                                        <div class="row">
                                            <div class="col-sm-4 pll">
                                                @Html.Label("Start Date:", htmlAttributes: new { @class = "control-label text-red" })
                                            </div>
                                            <div class="col-sm-8 col-md-8 col-lg-8 prm">
                                                @(Html.DevExtreme().DateBox().CustomDateBox().ID("Txt_S_Date_MRR").Name("Txt_S_Date_MRR").Value(Model.Txt_S_Date_MRR).OnValueChanged("Txt_S_Date_EditValueChanged_MRR").Min(new DateTime(1990,01,01))  )@*//Redmine Bug #135465 fixed*@
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-sm-4 pll">
                                                @Html.Label("Membership:", htmlAttributes: new { @class = "control-label text-red" })
                                            </div>
                                            <div class="col-sm-8 prm">
                                                @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("GLookUp_SubList_MRR").Name("GLookUp_SubList_MRR").ValueExpr("SI_REC_ID").DisplayExpr("SI_NAME").Placeholder("Select Subscription...").Value(Model.GLookUp_SubList_MRR)
                                                  .DataSource(Model.SubscriptionListDD_Data,"SI_REC_ID").OnValueChanged("GLookUp_SubList_EditValueChanged_MRR").ReadOnly(true).FocusStateEnabled(false).ContentTemplate(@<text> @Html.Partial("MembershipRR_GLookUp_SubList") </text>) )@*//Redmine Bug #135465 fixed*@
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-sm-4 pll">
                                                @Html.Label("Period Till:", htmlAttributes: new { @class = "control-label text-red" })
                                            </div>
                                            <div class="col-sm-8 prm">
                                                @*//Redmine Bug #135448 fixed*@
                                                @(Html.DevExtreme().SelectBox().CustomSelectBox() .ID("Cmb_Period_MRR") .Name("Cmb_Period_MRR") .DataSource(Model.Cmb_Period_Data,"SelectedIndex_MRR") .DisplayExpr("Period_MRR").ValueExpr("SelectedIndex_MRR").OnValueChanged("Cmb_Period_SelectedIndexChanged_MRR").Placeholder("Select Period...").Value(Model.Cmb_Period_SelectedIndexChanged).ShowClearButton(false))@*//Redmine Bug #135465 fixed*@
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-sm-8">
                                        <div class="row">
                                            <div class="col-sm-3 pll">
                                                @Html.Label("Subscription Fee:", htmlAttributes: new { @class = "control-label text-red" })
                                            </div>
                                            <div class="col-sm-3 prm">
                                                @(Html.DevExtreme().NumberBox().CustomNumberBox() .ID("Txt_Subs_Fee_MRR") .Name("Txt_Subs_Fee_MRR") .Format("#0.00") .ReadOnly(true) .FocusStateEnabled(false).Value(Model.Txt_Subs_Fee_MRR) )
                                            </div>
                                            <div class="col-sm-2 pll">
                                                @Html.Label("Entrance Fee:", htmlAttributes: new { @class = "control-label text-red" })
                                            </div>
