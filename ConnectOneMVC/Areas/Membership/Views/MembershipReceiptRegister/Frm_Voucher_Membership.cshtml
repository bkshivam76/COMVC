    async function GLookUp_SubList_EditValueChanged_MRR(e, FirstCall = false)
    {
        if (e)
        {
            sublist_Tag_MRR = e.value;
            if ((e.value == null || e.value.length == 0) && e.previousValue != null)
            {
                SubsList_MRR_DG.clearSelection();
                return;
            }
        }
        else
        {
            sublist_Tag_MRR = $("#GLookUp_SubList_MRR").dxDropDownBox("option", "value");
        }
        await SubsList_MRR_DG.selectRows(sublist_Tag_MRR);
        if (SubsList_MRR_DG.getSelectedRowsData().length > 0)
        {
            var item_MRR = SubsList_MRR_DG.getSelectedRowsData()[0];
            SubList_MRR = item_MRR["SI_NAME"];
            Subs_Catg_MRR = item_MRR["SI_CATEGORY"];
            Subs_Strt_Mth_MRR = item_MRR["SI_START_MONTH"];
            Subs_Ttl_Mth_MRR = item_MRR["SI_TOTAL_MONTH"];
            $("#GLookUp_SubList_Text_MRR").val(SubList_MRR);
            $("#Subs_Category_MRR").val(item_MRR["SI_CATEGORY"]);
            $("#Subs_Start_Month_MRR").val(item_MRR["SI_START_MONTH"]);
            $("#Subs_Total_Month_MRR").val(item_MRR["SI_TOTAL_MONTH"]);
            var Txt_S_Date = $("#Txt_S_Date_MRR").dxDateBox("instance").option("value");
            Strt_Date_MRR = JS_Json_Date_To_ddMMyyyy(Txt_S_Date);
            if (FirstCall == false)
            {
                if (isValidDate(Txt_S_Date))
                {
                    $.ajax({
                        type: 'GET',
                        url: "/Membership/MembershipReceiptRegister/GetSubscriptionFee",
                        cache: false,
                        data:
                        {
                            S_date_MRR: Strt_Date_MRR,
                            GLookUp_SubList_Tag: sublist_Tag_MRR,
                            Subs_Cat: Subs_Catg_MRR,
                            Subs_Start_M: Subs_Strt_Mth_MRR,
                            Subs_Total_M: Subs_Ttl_Mth_MRR
                        },
                        success: function (data)
                        {
                            if (data.jsonParam.result == false)
                            {
                                DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                            }
                            else
                            {
                                dataSource_Period_MRR = new DevExpress.data.DataSource({ // need to dispose it in in clearreference
                                    store:
                                    {
                                        type: "array",
                                        key: "SelectedIndex_MRR",
                                        data: data.Period_Data_MRR
                                    }
                                });
                                $("#Cmb_Period_MRR").dxSelectBox("instance").option("dataSource", dataSource_Period_MRR);
                                $("#Cmb_Period_MRR").dxSelectBox("reset");
                                Control_SetReadOnly("Cmb_Period_MRR", "dxSelectBox", false);
                                $("#Cmb_Period_MRR").dxSelectBox("instance").option("value", 0);
                                $("#lbl_FeeEff").text(data.lbl_FeeEff_Text);
                            }
                        }
                    });
                }
                else
                {
                    DevExpress.ui.dialog.alert("Start Date Incorrect/Blank...", "Information")
                }
            }
        }
    }
