    <script>

    $(document).ready(async function ()
    {
        ShowLoader_Ready();
        TransformTextForDB("ID_Frm_Voucher_Membership_Window_Form");
        $("#Txt_Mem_Old_No_MRR").find('input').addClass('OnlyDigit');
        if ("@MembershipRR_ListAdresBookRight" == "False")
        {
            $("#But_Add_Member_MRR").hide();
        }
        BUT_CANCEL_Click_ForDocumentReady_MRR();
        InitAllDropdownDatagrid_MRR();
        await Promise.all([LookUp_GetItemList_MRR(true), LookUp_GetSubscriptionList_MRR(true), LookUp_GetWingList_MRR(true), LookUp_GetPurposeList_MRR(true)]);
        if (Tag_MRR == "_New" || Tag_MRR == "_New_From_Selection")
        {
            $("#Txt_V_No_MRR").dxTextBox("instance").reset();
        }
        if (Tag_MRR == "_New_From_Selection")
        {
            await GLookUp_ItemList_EditValueChanged_MRR(null, true);
            Control_SetReadOnly("GLookUp_ItemList_MRR", "dxDropDownBox", true, "#696969");
            $("#lbl_itemName_MRR").removeClass("text-red").addClass("disabletxt");
        }
        else if (Tag_MRR == "_Edit" || Tag_MRR == "_View" || Tag_MRR == "_Delete")
        {
            Control_SetReadOnly("PC_MemberName_Textbox_MRR", "dxTextBox", true);
            await GLookUp_ItemList_EditValueChanged_MRR(null, true);
            Control_SetReadOnly("GLookUp_ItemList_MRR", "dxDropDownBox", false);
            await Member_OnSelectionChanged_MRR(null, true);
            await GLookUp_SubList_EditValueChanged_MRR(null, true);
            Control_SetReadOnly("GLookUp_SubList_MRR", "dxDropDownBox", false);
            await Cmb_Period_SelectedIndexChanged_MRR(null, true);
            await GLookUp_WingList_EditValueChanged_MRR(null, true);
            WingDDReadOnly_MRR = false;
            Control_SetReadOnly("GLookUp_WingList_MRR", "dxDropDownBox", (WingDDEnabled_MRR == true && WingDDReadOnly_MRR == false) ? false : true);//Redmine Bug #135968 fixed
            Control_SetReadOnly("GLookUp_PurList_MRR", "dxSelectBox", false);
