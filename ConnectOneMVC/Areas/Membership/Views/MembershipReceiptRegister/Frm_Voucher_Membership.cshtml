        function MemberName_validations(Mem_Value)
        {
            debugger;
            $("#PC_MemberName_Textbox_MRR").dxTextBox({})
                .dxValidator
                ({
                    validationRules:
                        [{
                            type: 'custom',
                            reevaluate: true,
                            validationCallback: function (options)
                            {
                                if (Mem_Value.length < 3 || (options.value == null || options.value == ""))
                                {
                                    return false;                                 
                                }
                                return true;
                            },
                            message: "Text cannot be Blank / Minimum 3 Characters required. . . !"
                        }],
                    validationGroup: "MembershipReceiptRegister_Profile"
                });
        }
