        function Txt_S_Date_EditValueChanged_MRR() {
            $("#GLookUp_SubList_MRR").dxDropDownBox("instance").reset();
            $("#Cmb_Period_MRR").dxSelectBox("instance").reset();

            //Instead of clearing the items in selectbox set as readonly mode
            Control_SetReadOnly("Cmb_Period_MRR", "dxSelectBox", true);

            $("#lbl_FeeEff").text("");
            $("#lbl_Expire").text("");
        }
        async function Cmb_Period_SelectedIndexChanged_MRR(e, FirstCall = false) {
            if (e) {
                cmb_SelectedIndex_MRR = e.value;
            }
            else {
                cmb_SelectedIndex_MRR = $("#Cmb_Period_MRR").dxSelectBox("option", "value");
            }
            $("#Cmb_Period_SelectedIndexChanged").val(cmb_SelectedIndex_MRR);
            if (cmb_SelectedIndex_MRR != null && FirstCall == false) {
                $.ajax({
                    type: 'GET',
                    url: "/Membership/MembershipReceiptRegister/Sub_Amt_Calculation",
                    cache: false,
                    //  async: false,   //Redmine Bug #135450 fixed
                    data:
                    {
                        Subs_Cat: Subs_Catg_MRR,
                        Subs_Start_Month: Subs_Strt_Mth_MRR,
                        Txt_S_Date_Text: Strt_Date_MRR,
                        GLookUp_SubList_Text: SubList_MRR,
                        Cmb_Period_SelectedIndex: cmb_SelectedIndex_MRR
                    },
                    success: function (data) {
                        if (data.result == true) {
                            $("#Txt_Ent_Fee_MRR").dxNumberBox("instance").option("value", data.Ent_Fee_MRR);
                            $("#Txt_Subs_Fee_MRR").dxNumberBox("instance").option("value", data.Subs_Fee_MRR);
                            $("#Txt_Adv_Fee_MRR").dxNumberBox("instance").option("value", data.Txt_Adv_Fee_MRR);
                            $("#Txt_SubTotal_MRR").dxNumberBox("instance").option("value", data.Txt_SubTotal_MRR);
                            $("#Txt_CashAmt_MRR").dxNumberBox("instance").option("value", data.Txt_CashAmt_MRR);
                            $("#lbl_Expire").text(data.lbl_Expire_Text);
                        }
                    }
                });
            }
        }
        function Txt_CashAmt_EditValueChanged_MRR() {
            var Txt_SubTotal = $("#Txt_SubTotal_MRR").dxNumberBox("instance").option("value");
            var Txt_CashAmt = $("#Txt_CashAmt_MRR").dxNumberBox("instance").option("value");
            var Txt_BankAmt = $("#Txt_BankAmt_MRR").dxNumberBox("instance").option("value");
            var Txt_DiffAmt = Txt_SubTotal - (Txt_CashAmt + Txt_BankAmt);
            $("#Txt_DiffAmt_MRR").dxNumberBox("instance").option("value", parseFloat(Txt_DiffAmt.toFixed(2)));
            //Calculation_Check_MRR();
        }
        function Calculation_Check_MRR(e) {
            var value = $("#Txt_DiffAmt_MRR").dxNumberBox("instance").option("value");
            if (Tag_MRR != "_Delete") {
                if (value != 0) {
                    $("#Frm_MRR_Window_Ok").dxButton("instance").option("disabled", true);
                }
                else {
                    $("#Frm_MRR_Window_Ok").dxButton("instance").option("disabled", false);
                }
            }
            $("#Txt_DiffAmt_MRR").toggleClass('negative', value != 0);
            $("#Txt_DiffAmt_MRR").toggleClass('positive', value == 0);
        }
        function MemberPopupOnShown(e)
        {
            $("#MRR_MembershipNamesList_datagrid .dx-texteditor-input").focus();     
        }//Redmine Bug #135922 fixed
        async function DataGrid_keyDown_MRR(e)
        {
            var dataGrid = e.component;
            var dataGrid_ID = e.element[0].id;
            if (e.event.key == "Enter")
            {
                e.event.stopImmediatePropagation();
                var focusedElement = $("#" + dataGrid_ID + " .dx-focused").parent()[0];
                if ($(focusedElement).attr('aria-selected') == "true")
                {                   
                    $("#PC_MemberName_Textbox_MRR").dxTextBox('focus');
                    $("#Search_Down_MRR_report_modal").dxPopup("instance").hide();                    
                }
                else
                {
                    var rowCount = dataGrid.totalCount();
                    for (i = 0; i < rowCount; i++)
                    {
                        if (focusedElement === dataGrid.getRowElement(i)[0])
                        {
                            $("#PC_MemberName_Textbox_MRR").dxTextBox('focus');
                            $("#Search_Down_MRR_report_modal").dxPopup("instance").hide();
                            await dataGrid.selectRows([dataGrid.getKeyByRowIndex(i)], false);
                            break;
                        }
                    }
                }
            }
        }//Redmine Bug #135922 fixed
        function DataGrid_OnEditorPreparing_MRR(e)
        {
            if (e.parentType !== "searchPanel" && e.parentType !== "filterRow")
            {
                return;
            }
            var dataGrid = e.component;
            if (e.parentType == "searchPanel")
            {
                dataGrid.clearFilter("search");
                e.updateValueTimeout = 10;
                e.editorOptions.onKeyDown = e =>
                {
                    if (e.event.keyCode === 40) //down arrow
                    {
                        dataGrid.focus(dataGrid.getCellElement(0, 0));
                        e.event.preventDefault();
                    }
                    if (e.event.key == "Enter")
                    {
                        e.event.stopImmediatePropagation();
                        $("#PC_MemberName_Textbox_MRR").dxTextBox('focus');
                        $("#Search_Down_MRR_report_modal").dxPopup("instance").hide();
                        if (dataGrid.getVisibleRows().length > 0)
                        {
                            dataGrid.selectRows([dataGrid.getKeyByRowIndex(0)], false);
                        }
                        e.event.preventDefault();
                    }
                }
            }
            else if (e.parentType == "filterRow")
            {
                e.editorOptions.onKeyDown = e =>
                {
                    if (e.event.keyCode === 40) //down arrow
                    {
                        dataGrid.focus(dataGrid.getCellElement(0, 0));
                        e.event.preventDefault();
                    }
                }
            }
        }//Redmine Bug #135922 fixed
        function DataGrid_OnRowClick_MRR(e)
        {
            if (e.isSelected)
            {
                $("#PC_MemberName_Textbox_MRR").dxTextBox('focus');
                $("#Search_Down_MRR_report_modal").dxPopup("instance").hide();
            }
        }//Redmine Bug #135922 fixed
    </script> @* other value change *@
