<script>
    function Membership_RR_BankSaveClick(e)
    {
        var result = e.validationGroup.validate();
        if (result.isValid)
        {
            if (Tag_Bank_MRR == "_Delete")
            {
                CreateCustomConfirmDialog("Bank Payment", "", true).show().done(function (dialogResult)
                {
                    if (dialogResult)
                    {
                        $("#ID_Frm_Voucher_Membership_Bank_Window").submit();
                    }
                });
            }
            else
            {
                $("#ID_Frm_Voucher_Membership_Bank_Window").submit();              
            }
        }
    }//Redmine Bug #135443 fixed
    
    function cmdmode_validations(cmd_mode)
    {
        $("#Txt_Ref_Date_MRR").dxDateBox({}).dxValidator({
            validationRules: [{
                type: 'custom',
                validationCallback: function (options)
                {
                    var result = true;
                    if (cmd_mode != "BANK ACCOUNT")
                    {
                        if (options.value == "" || options.value == null)
                        {
                            result = false;
                        }
                    }
                    return result;
                },
                reevaluate: true,
                message: "Date is required..!!"
            }],
            validationGroup: "membershipReceiptRegister_BankDetail"
        });

        $("#Txt_Ref_Branch_MRR").dxTextBox({})
            .dxValidator
            ({
                validationRules:
                    [{
                        type: 'custom',
                        reevaluate: true,
                        validationCallback: function (options)
                        {
                            if (cmd_mode == "CHEQUE" || cmd_mode == "DD" || cmd_mode == "CBS" || cmd_mode == "RTGS" || cmd_mode == "NEFT" || cmd_mode == "ECS")
                            {
                                if (options.value == null || options.value == "")
                                {
                                    return false;
                                }
                            }
                            return true;
                        },
                        message: "Branch Name Not Specified"
                    }],
                validationGroup: "membershipReceiptRegister_BankDetail"
            });

        $("#Txt_Ref_No_MRR").dxTextBox({})
            .dxValidator({
                validationRules: [{
                    type: 'custom',
                    validationCallback: function (options)
                    {
                        var result = true;
                        if (cmd_mode != "BANK ACCOUNT")
                        {
                            if (options.value == "" || options.value == null)
                            {
                                result = false;
                            }
                        }
                        return result;
                    },
                    reevaluate:true,
                    message: "Cannot Be Blank..!!"
                }//,
                //{
                //    type: 'custom',
                //    validationCallback: function (options)
                //    {
                //        var result = true;
                //        if (cmd_mode == "CHEQUE" || cmd_mode == "DD")
                //        {
                //            var reg = /^[0-9]{6,8}$/;
                //            if (!(reg.test(options.value)))
                //            {
                //                result = false
                //            }
                //        }
                //        return result;
                //    },
                //    reevaluate: true,
                //    message: 'Invalid Format(Min 6 Digits Max 8 Digits)'
                //}
                ],
                validationGroup: "membershipReceiptRegister_BankDetail"
            });

        $("#GLookUp_RefBankList_MRR").dxDropDownBox({})
            .dxValidator({
                validationRules: [{
                    type: 'custom',
                    validationCallback: function (options)
                    {
                        var result = true;
                        if (cmd_mode == "CHEQUE" || cmd_mode == "DD" || cmd_mode == "CBS" || cmd_mode == "RTGS" || cmd_mode == "NEFT" || cmd_mode == "ECS") //Redmine Bug #135451 fixed
                        {
                            if (options.value == "" || options.value == null)
                            {
                                result = false;
                            }
                        }
                        return result;
                    },
                    reevaluate: true,
                    message: "Bank not Selected...!"    //Redmine Bug #135451 fixed
                }
                ],
                validationGroup: "membershipReceiptRegister_BankDetail"
            });
    }
