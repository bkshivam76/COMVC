<script>
    $(document).ready(async function ()
    {
        ShowLoader_Ready();
        TransformTextForDB("ID_Frm_Voucher_Membership_Bank_Window");
        Init_DropDown_bank_MRR();
        await Promise.all([LookUp_GetBankList_MRR(true), LookUp_GetRefBankList_MRR(true)]);
        Cmd_Mode_SelectedIndexChanged_MRR(null, true);
        if (Tag_Bank_MRR == "_Edit" || Tag_Bank_MRR == "_View" ||Tag_Bank_MRR == "_Delete")
        {
            await GLookUp_BankList_EditValueChanged_MRR(null, true);
            Control_SetReadOnly("GLookUp_BankList_MRR", "dxDropDownBox", false);
            if ("@Model.iRef_BANK_ID".length > 0)
            {
                await GLookUp_RefBankList_EditValueChanged_MRR(null, true);
            }
            Control_SetReadOnly("GLookUp_RefBankList_MRR", "dxDropDownBox", false);
        }
        Set_Form_View_Delete_Mode(null, "ID_Frm_Voucher_Membership_Bank_Window", Tag_Bank_MRR);
        Focus_FirstEditable_Field("ID_Frm_Voucher_Membership_Bank_Window");
        HideLoader_Ready();
    });


</script>@* document.ready *@

<script>


    function Dep_Detail(status)
    {
        Control_SetReadOnly("GLookUp_BankList_MRR", "dxDropDownBox", !status);
        //Control_SetReadOnly("BE_Bank_Branch_MRR", "dxTextBox", !status);
        //Control_SetReadOnly("BE_Bank_Acc_No_MRR", "dxTextBox", !status);
    }
    function Ref_Detail(status)
    {
        Control_SetDisable("GLookUp_RefBankList_MRR", "dxDropDownBox", !status);
        Control_SetReadOnly("Txt_Ref_Branch_MRR", "dxTextBox", !status);
        Control_SetReadOnly("Txt_Ref_No_MRR", "dxTextBox", !status);
        Control_SetReadOnly("Txt_Ref_Date_MRR", "dxDateBox", !status);
        Control_SetReadOnly("Txt_Ref_CDate_MRR", "dxDateBox",!status);
    }
    function Cmd_Mode_SelectedIndexChanged_MRR(e,FirstCall=false)
    {
        if (e)
        {
            if (e.value == null)
            {
                return;
            }
        }
        var mode = $("#Cmd_Mode_MRR").dxSelectBox('instance').option('value');
        if (mode.toUpperCase() == "BANK ACCOUNT")
        {
            Dep_Detail(true);
            Ref_Detail(false);
            if (Cnt_BankAccount_MRR > 1)
            {
                if (FirstCall == false)
                {
                    $("#GLookUp_BankList_MRR").dxDropDownBox("instance").reset();
                    $("#BE_Bank_Branch_MRR").dxTextBox("instance").reset();
                    $("#BE_Bank_Acc_No_MRR").dxTextBox("instance").reset();
                }
            }
            else
            {
                $("#GLookUp_BankList_MRR").find('input').css('color', '#000080');
                $("#BE_Bank_Branch_MRR").find('input').css('color', '#000080');
                $("#BE_Bank_Acc_No_MRR").find('input').css('color', '#000080');
            }
            if (FirstCall == false) {
                $("#GLookUp_RefBankList_MRR").dxDropDownBox("instance").reset();
                $("#Txt_Ref_Branch_MRR").dxTextBox("instance").reset();
                $("#Txt_Ref_No_MRR").dxTextBox("instance").reset();
                $("#Txt_Ref_Date_MRR").dxDateBox("instance").reset();
                $("#Txt_Ref_CDate_MRR").dxDateBox("instance").reset();
            }
            $("#lbl_Bank_Title_MRR").removeClass("disabletxt").removeClass("text-red");
            $("#lbl_Bank_Name_MRR").removeClass("disabletxt").addClass("text-red");
            $("#lbl_Branch_Name_MRR").removeClass("disabletxt").removeClass("text-red");
            $("#lbl_Acc_No_MRR").removeClass("disabletxt").removeClass("text-red");

            $("#lbl_Ref_Bank_MRR").removeClass("text-red").addClass("disabletxt");
            $("#lbl_Ref_Branch_MRR").removeClass("text-red").addClass("disabletxt");
            $("#lbl_Ref_Title_MRR").addClass("disabletxt").removeClass("text-red");
            $("#lbl_Ref_no_MRR").removeClass("text-red").addClass("disabletxt");
            $("#lbl_Ref_Date_MRR").removeClass("text-red").addClass("disabletxt");
            $("#lbl_Ref_Cdate_MRR").removeClass("text-red").addClass("disabletxt");

            $("#lbl_Ref_Title_MRR").text("Reference Detail:");
            $("#lbl_Ref_no_MRR").text("Ref. No.:");
            $("#Txt_Ref_No_MRR").dxTextBox("instance").option("placeholder", "Type No...");
            $("#lbl_Ref_Date_MRR").text("Date:");
            $("#lbl_Ref_Cdate_MRR").text("Clearing Date:");
        }
        else
        {
            Dep_Detail(true);
            Ref_Detail(true);
            if (Cnt_BankAccount_MRR > 1)
            {
                if (FirstCall == false) {
                    $("#GLookUp_BankList_MRR").dxDropDownBox("instance").reset();
                    $("#BE_Bank_Branch_MRR").dxTextBox("instance").reset();
                    $("#BE_Bank_Acc_No_MRR").dxTextBox("instance").reset();
                }
            }
            else
            {
                $("#GLookUp_BankList_MRR").find('input').css('color', '#000080');
                $("#BE_Bank_Branch_MRR").find('input').css('color', '#000080');
                $("#BE_Bank_Acc_No_MRR").find('input').css('color', '#000080');
            }
            if (FirstCall == false) {
                $("#GLookUp_RefBankList_MRR").dxDropDownBox("instance").reset();
                $("#Txt_Ref_Branch_MRR").dxTextBox("instance").reset();
                $("#Txt_Ref_No_MRR").dxTextBox("instance").reset();
                $("#Txt_Ref_Date_MRR").dxDateBox("instance").reset();
                $("#Txt_Ref_CDate_MRR").dxDateBox("instance").reset();
            }
            $("#lbl_Bank_Title_MRR").removeClass("disabletxt").removeClass("text-red");
            $("#lbl_Bank_Name_MRR").removeClass("disabletxt").addClass("text-red");
            $("#lbl_Branch_Name_MRR").removeClass("disabletxt").removeClass("text-red");
            $("#lbl_Acc_No_MRR").removeClass("disabletxt").removeClass("text-red");

            $("#lbl_Ref_Bank_MRR").addClass("text-red").removeClass("disabletxt");
            $("#lbl_Ref_Branch_MRR").addClass("text-red").removeClass("disabletxt");
            $("#lbl_Ref_Title_MRR").removeClass("disabletxt").removeClass("text-red");
            $("#lbl_Ref_no_MRR").addClass("text-red").removeClass("disabletxt");
            $("#lbl_Ref_Date_MRR").addClass("text-red").removeClass("disabletxt");
            $("#lbl_Ref_Cdate_MRR").removeClass("text-red").removeClass("disabletxt");
        }
        if (mode.toUpperCase() == "CHEQUE")
        {
            $("#lbl_Ref_Title_MRR").text("Cheque Detail:");
            $("#lbl_Ref_no_MRR").text("Cheque No.:");
            $("#Txt_Ref_No_MRR").dxTextBox("instance").option("placeholder", "Type Cheque No...");
            $("#lbl_Ref_Date_MRR").text("Cheque Date:");
        }
        if (mode.toUpperCase() == "DD")
        {
            $("#lbl_Ref_Title_MRR").text("D.D. Detail:")
            $("#lbl_Ref_no_MRR").text("D.D. No.:");
            $("#Txt_Ref_No_MRR").dxTextBox("instance").option("placeholder", "Type D.D. No...");
            $("#lbl_Ref_Date_MRR").text("D.D. Date:");
        }
        if (mode.toUpperCase() == "BANK ACCOUNT") {
            $("#lbl_Ref_Title_MRR").text("Reference Detail:")
            $("#lbl_Ref_no_MRR").text("Ref. No.:");
            $("#Txt_Ref_No_MRR").dxTextBox("instance").option("placeholder", "Type Ref. No...");
            $("#lbl_Ref_Date_MRR").text("Date:");
        }
        if (mode.toUpperCase() == "CBS" || mode.toUpperCase() == "RTGS" || mode.toUpperCase() == "NEFT" || mode.toUpperCase() == "ECS" )
        {
            $("#lbl_Ref_Title_MRR").text(mode.toUpperCase() + " Detail:");
            $("#lbl_Ref_no_MRR").text("Ref. No.:");
            $("#Txt_Ref_No_MRR").dxTextBox("instance").option("placeholder", "Type Ref. No...");
            $("#lbl_Ref_Date_MRR").text("Date:");
        }
        if (mode.toUpperCase() == "CBS" && (Tag_Bank_MRR == "_New" || Tag_Bank_MRR == "_New_From_Selection"))
        {
            RefBank_DG_MRR.selectRows(lbl_Trf_ANo_Tag_MRR, false);
            $("#Cmd_Mode_MRR").dxSelectBox("instance").focus();
        }
        cmdmode_validations(mode.toUpperCase());
    }
</script>@* Value Change *@

<script> 
    var Bank_DG_MRR;
    var RefBank_DG_MRR;
    var Cnt_BankAccount_MRR = null;
    var Tag_Bank_MRR = "@Model.ActionMethod";
    var lbl_Trf_ANo_Tag_MRR = "";   //Redmine Bug #135835 fixed
    function Init_DropDown_bank_MRR()
    {
        var $Bank_DG_MRR = $("#Frm_Voucher_Membership_Bank_GLookUp_BankList_datagrid");
        if ($Bank_DG_MRR.length) {
            Bank_DG_MRR = $Bank_DG_MRR.dxDataGrid("instance");
        }
        var $RefBank_DG_MRR = $("#Frm_Voucher_Membership_Bank_GLookUp_RefBankList_datagrid");
        if ($RefBank_DG_MRR.length) {
            RefBank_DG_MRR = $RefBank_DG_MRR.dxDataGrid("instance");
        }
    }
    async function LookUp_GetBankList_MRR(FirstCall = false)
    {
        var DG_items = GetDataSourceItems("GLookUp_BankList_MRR", "dxDropDownBox");
        Cnt_BankAccount_MRR = DG_items.length;
        if (Cnt_BankAccount_MRR < 1)
        {
            Control_SetReadOnly("Cmd_Mode_MRR", "dxSelectBox", true);
        }
        if (Cnt_BankAccount_MRR == 1)
        {
            $("#GLookUp_BankList_MRR").find("input").css('color', "#696969");
            $("#BE_Bank_Branch_MRR").find("input").css('color', "#696969");
            $("#BE_Bank_Acc_No_MRR").find("input").css('color', "#696969");
            if (Tag_Bank_MRR == "_New" || Tag_Bank_MRR == "_New_From_Selection")
            {
                if (FirstCall === true)
                {
                    await GLookUp_BankList_EditValueChanged_MRR(null, false);
                }
                Control_SetReadOnly("GLookUp_BankList_MRR", "dxDropDownBox", true);
            }
        }
        else if (Cnt_BankAccount > 1)
        {
              if (Tag_Bank_MRR == "_New" || Tag_Bank_MRR == "_New_From_Selection")
              {
                  Control_SetReadOnly("GLookUp_BankList_MRR", "dxDropDownBox", false);
              }
        }
    }
    async function LookUp_GetRefBankList_MRR(FirstCall = false)
    {
        if (Tag_Bank_MRR == "_New" || Tag_Bank_MRR == "_New_From_Selection")
        {
            Control_SetReadOnly("GLookUp_RefBankList_MRR", "dxDropDownBox", false);
        }
    }
    async function GLookUp_RefBankList_EditValueChanged_MRR(e, FirstCall=false)
    {
        var refbank;
        if (e)
        {
            refbank = e.value;
            if (e.value == null && e.previousValue != null)
            {
                RefBank_DG_MRR.clearSelection();
                $("#REF_BANK_NAME").val(null);
                return;
            }
        }
        else
        {
            refbank = $("#GLookUp_RefBankList_MRR").dxDropDownBox("option", "value");
        }
        await RefBank_DG_MRR.selectRows(refbank);  
        if (RefBank_DG_MRR.getSelectedRowsData().length > 0)
        {
            var item = RefBank_DG_MRR.getSelectedRowsData()[0];
            $("#REF_BANK_NAME").val(item["BI_BANK_NAME"]);
        }
    }
    async function GLookUp_BankList_EditValueChanged_MRR(e, FirstCall = false)
    {
        var BankID;
        if (e)
        {
            BankID = e.value;
            if (e.value == null && e.previousValue != null)
            {
                Bank_DG_MRR.clearSelection();
                return;
            }
        }
        else
        {
            BankID = $("#GLookUp_BankList_MRR").dxDropDownBox("option", "value");
        }
        await Bank_DG_MRR.selectRows(BankID)
        if (Bank_DG_MRR.getSelectedRowsData().length > 0)
        {
            var item = Bank_DG_MRR.getSelectedRowsData()[0];
            $("#DEP_BANK_NAME").val(item["BANK_NAME"]);
            $("#BE_Bank_Branch_MRR").dxTextBox("instance").option("value", item["BANK_BRANCH"]);
            $("#BE_Bank_Acc_No_MRR").dxTextBox("instance").option("value", item["BANK_ACC_NO"]);
            $("#Bank_Last_Edit_On").val(JS_Json_Date_To_ddMMyyyy(item["REC_EDIT_ON"]));//Redmine Bug #135437 fixed
            lbl_Trf_ANo_Tag_MRR = item["BANK_ID"];      
        }
    }
</script>@* DD init *@
