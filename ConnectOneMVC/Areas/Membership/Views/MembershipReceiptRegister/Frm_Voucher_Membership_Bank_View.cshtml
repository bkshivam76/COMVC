    function Frm_Voucher_Membership_Grid_Init(s, e)
    {
        
    }
    function Frm_Voucher_Membership_Grid_DblClick(s, e)
    {
        OnFrm_Voucher_Membership_Bank_EditClick();
    }
    function OnFrm_Voucher_Membership_Bank_NewClick()
    {
        if ("@IsDisabled" == "False")
        {
            var Url = "@Url.Action("Frm_Voucher_Membership_Bank", "MembershipReceiptRegister", new { @area = "Membership" })?ActionMethod=New";
            ShowLoader();
            OpenPopup("Frm_Voucher_Membership_popup", "New ~ Bank Payment", Url, "auto", 600, false, null);
        }
    }
    function OnFrm_Voucher_Membership_Bank_EditClick()
    {
        if ("@IsDisabled" == "False")
        {
            if (Frm_Voucher_Membership_Bank_Grid.GetFocusedRowIndex()<0)
            {
                DevExpress.ui.dialog.alert('Select A Row...!', "Error");
                return;
            }
            else
            {
                Payment_BankGrid_Data = Frm_Voucher_Membership_Bank_Grid.cpPagedata;
                BankPayment_Sr = Payment_BankGrid_Data[Frm_Voucher_Membership_Bank_Grid.GetFocusedRowIndex() - Frm_Voucher_Membership_Bank_Grid.GetTopVisibleIndex()];
                var Url = "@Url.Action("Frm_Voucher_Membership_Bank", "MembershipReceiptRegister", new { @area = "Membership" })?ActionMethod=Edit&SrID=" + BankPayment_Sr;
                ShowLoader();
                OpenPopup("Frm_Voucher_Membership_popup", "Edit ~ Bank Payment", Url, "auto", 600, false, null);
            }
        }
    }
