@using DevExtreme.AspNet.Mvc;
@model ConnectOneMVC.Areas.Membership.Models.VoucherMembershipInfo
@{
    bool IsVisible = (Model != null && Model.TempActionMethod == "_Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.TempActionMethod == "_View" || Model.TempActionMethod == "_Delete") ? true : false;
}
<div id="Frm_Voucher_Membership_Bank_PartialView">
    <div class="row">
        <div class="col-sm-12">
            @Html.Action("Frm_Voucher_Membership_Bank_Grid", "MembershipReceiptRegister")
        </div>
        <div class="col-sm-12">@*Redmine Bug #135833 fixed*@
            @(Html.DevExtreme().Button().ID("BankPaymentNew_MRR").Text("New").Icon("add").FocusStateEnabled(false).OnClick(@<text> function () { OnFrm_Voucher_Membership_Bank_NewClick(); } </text>).Disabled(IsDisabled))
            @(Html.DevExtreme().Button().ID("BankPaymentEdit_MRR").Text("Edit").Icon("edit").FocusStateEnabled(false).OnClick(@<text> function () { OnFrm_Voucher_Membership_Bank_EditClick(); } </text>).Disabled(IsDisabled))
            @(Html.DevExtreme().Button().ID("BankPaymentDelete_MRR").Text("Delete").Icon("trash").FocusStateEnabled(false).OnClick(@<text> function () { OnFrm_Voucher_Membership_Bank_DeleteClick(); } </text>).Disabled(IsDisabled))
            @(Html.DevExtreme().Button().ID("BankPaymentView_MRR").Text("View").Icon("doc").FocusStateEnabled(false).OnClick(@<text> function () { OnFrm_Voucher_Membership_Bank_ViewClick(); } </text>).Disabled(IsVisible))
        </div>@*//Redmine Bug #135465 fixed*@
    </div>
</div>
<script>
    var BankPayment_Sr;
    var Payment_BankGrid_Data;
    function OnBankPaymentGridFocusedRowChanged_MRR(s, e)
    {
        s.Focus();       
    }
    function OnBankPaymentGetRowValues(values)
