                            //    {
                            //        if (data.result == "true" || data.result == true)
                            //        {
                                        $("#Txt_DiffAmt_MRR").dxNumberBox("instance").option("value", data.Txt_DiffAmt);
                                        $("#Txt_BankAmt_MRR").dxNumberBox("instance").option("value", data.Txt_BankAmt);
                                        $("#Txt_CashAmt_MRR").dxNumberBox("instance").option("value", data.Txt_CashAmt);
                            //Frm_Voucher_Membership_Bank_Grid.SetFocusedRowIndex(-1);
                            PerformCallbackGridView("Frm_Voucher_Membership_Bank_Grid");
