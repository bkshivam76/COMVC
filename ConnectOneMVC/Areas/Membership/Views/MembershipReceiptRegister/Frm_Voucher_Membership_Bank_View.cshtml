        {
            if (Frm_Voucher_Membership_Bank_Grid.GetFocusedRowIndex() >= 0)
            {
                Payment_BankGrid_Data = Frm_Voucher_Membership_Bank_Grid.cpPagedata;
                BankPayment_Sr = Payment_BankGrid_Data[Frm_Voucher_Membership_Bank_Grid.GetFocusedRowIndex() - Frm_Voucher_Membership_Bank_Grid.GetTopVisibleIndex()];
                $.ajax({
                    type: 'GET',
                    url: "/Membership/MembershipReceiptRegister/Frm_Voucher_Membership_Bank",
                    data: { ActionMethod: "Delete", SrID: BankPayment_Sr },
