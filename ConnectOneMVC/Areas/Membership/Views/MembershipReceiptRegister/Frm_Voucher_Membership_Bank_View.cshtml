                            //});
                        }
                    }
                });
            }
            else
            {
                DevExpress.ui.dialog.alert('Select A Row...!', "Error");
                return;
            }
        }
    }
    function OnFrm_Voucher_Membership_Bank_ViewClick()
    {
        if ("@IsVisible" == "False")
        {
            if (Frm_Voucher_Membership_Bank_Grid.GetFocusedRowIndex() >= 0)
            {
                Payment_BankGrid_Data = Frm_Voucher_Membership_Bank_Grid.cpPagedata;
                BankPayment_Sr = Payment_BankGrid_Data[Frm_Voucher_Membership_Bank_Grid.GetFocusedRowIndex() - Frm_Voucher_Membership_Bank_Grid.GetTopVisibleIndex()];
                var Url = "@Url.Action("Frm_Voucher_Membership_Bank", "MembershipReceiptRegister", new { @area = "Membership" })?ActionMethod=View&SrID=" + BankPayment_Sr;
                ShowLoader();
                OpenPopup("Frm_Voucher_Membership_popup", "View ~ Bank Payment", Url, "auto", 600, false, null);
            }
            else
            {
                DevExpress.ui.dialog.alert('Select A Row...!', "Error");
                return;
            }
        }
    }
    function Frm_Voucher_Membership_ContextMenuFunction(s, e)
    {
        if (e.item.name == 'New')
        {
            OnFrm_Voucher_Membership_Bank_NewClick();
        }
        else if (e.item.name == 'Edit')
        {
            OnFrm_Voucher_Membership_Bank_EditClick();
        }
        else if (e.item.name == 'Delete')
        {
            OnFrm_Voucher_Membership_Bank_DeleteClick();
        }
        else if (e.item.name == 'View')
        {
            OnFrm_Voucher_Membership_Bank_ViewClick();
        }
