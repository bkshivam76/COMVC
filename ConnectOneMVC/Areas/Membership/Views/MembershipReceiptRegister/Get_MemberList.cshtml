@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid()
    .ID("MRR_MembershipNamesList_datagrid")

    .ElementAttr(new { @class = "DropDownDataGrid" })
    .Paging(p => p.PageSize(100))
    .HoverStateEnabled(true)

    .SearchPanel
    (s => s
      .Visible(true)
      .HighlightSearchText(true)
      .SearchVisibleColumnsOnly(true)
      .Placeholder(" ")
    )

    .Scrolling
    (s => s.Mode(GridScrollingMode.Infinite)
    .UseNative(false)
    .ScrollByThumb(true)
    .ScrollByContent(true)
    .ShowScrollbar(ShowScrollbarMode.OnHover)
    )
    .Grouping(g => g.AllowCollapsing(false))
    .AllowColumnResizing(true)
    .ColumnResizingMode(ColumnResizingMode.Widget)
    .ColumnAutoWidth(true)
    .Height(315)
    .ShowColumnLines(true)
    .ShowRowLines(true)
    .RowAlternationEnabled(true)
    .ShowBorders(true)
    .WordWrapEnabled(true)

    .Columns(columns =>
    {
        columns.Add().DataField("C_NAME").Caption("Name");
        columns.Add().DataField("CEN_NAME").Caption("Centre Name");
        columns.Add().DataField("CEN_UID").Caption("Centre UID");
        columns.Add().DataField("C_R_ADD1").Caption("C_R_ADD1").Visible(false);
        columns.Add().DataField("C_R_ADD2").Caption("C_R_ADD2").Visible(false);
        columns.Add().DataField("C_R_ADD3").Caption("C_R_ADD3").Visible(false);
        columns.Add().DataField("C_R_ADD4").Caption("C_R_ADD4").Visible(false);
        columns.Add().DataField("C_R_PINCODE").Caption("C_R_PINCODE").Visible(false);
        columns.Add().DataField("CI_NAME").Caption("City");
        columns.Add().DataField("ST_NAME").Caption("ST_NAME").Visible(false);
        columns.Add().DataField("DI_NAME").Caption("DI_NAME").Visible(false);
        columns.Add().DataField("CO_NAME").Caption("Country");
        columns.Add().DataField("C_EDUCATION").Caption("C_EDUCATION").Visible(false);
        columns.Add().DataField("C_OCCUPATION").Caption("C_OCCUPATION").Visible(false);
        columns.Add().DataField("C_DOB").Caption("C_DOB").Visible(false);
        columns.Add().DataField("C_AGE").Caption("C_AGE").Visible(false);
        columns.Add().DataField("EMAILS").Caption("EMAILS").Visible(false);
        columns.Add().DataField("TEL_NOS").Caption("TEL_NOS").Visible(false);
        columns.Add().DataField("MOB_NOS").Caption("MOB_NOS").Visible(false);
        columns.Add().DataField("C_CEN_CATEGORY").Caption("C_CEN_CATEGORY").Visible(false);
        columns.Add().DataField("C_CLASS_CEN_ID").Caption("C_CLASS_CEN_ID").Visible(false);
        columns.Add().DataField("C_ID").Caption("C_ID").Visible(false);
        columns.Add().DataField("C_ORG_ID").Caption("C_ORG_ID").Visible(false);
        columns.Add().DataField("C_REC_EDIT_ON").Caption("C_REC_EDIT_ON").Visible(false);
    })

    .Selection(s => s.Mode(SelectionMode.Single))
    .DataSource(Model.MemberDD_Data, "C_ORG_ID")
    .OnSelectionChanged("Member_OnSelectionChanged_MRR")
    .SelectedRowKeys(Model.PC_MemberName_MRR)
    .OnKeyDown("DataGrid_keyDown_MRR")  //Redmine Bug #135922 fixed
    .OnEditorPreparing("DataGrid_OnEditorPreparing_MRR")    //Redmine Bug #135922 fixed
    .OnRowClick("DataGrid_OnRowClick_MRR")  //Redmine Bug #135922 fixed
                                            //.OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}")
)
