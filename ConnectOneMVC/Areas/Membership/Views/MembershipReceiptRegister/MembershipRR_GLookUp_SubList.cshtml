@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("MRR_GLookUp_SubsList_datagrid")

    .Columns(columns =>
    {
        columns.Add().DataField("SI_NAME").Caption("Name");
        columns.Add().DataField("SI_CATEGORY").Caption("SI_CATEGORY").Visible(false);
        columns.Add().DataField("SI_START_MONTH").Caption("SI_START_MONTH").Visible(false);
        columns.Add().DataField("SI_TOTAL_MONTH").Caption("SI_TOTAL_MONTH").Visible(false);        

    })
    .Height(200)        //Redmine Bug #135942 fixed
       .Selection(s => s.Mode(SelectionMode.Single))
       .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}")
)
