@{
    Layout = null;
}
<!DOCTYPE html>

<html>
<head>
    <title></title>
    <meta charset="utf-8" />
    <meta content="width=device-width" name="viewport" />
    <style>

        body {
            background-color: transparent;
            color: #000;
            font-family: Arial, Helvetica Neue, Helvetica, sans-serif
        }

        * {
            box-sizing: border-box
        }

        body,
        h3,
        p {
            margin: 0
        }

        .rerf-row-content {
            max-width: 1280px;
            margin: 0 auto;
            display: flex
        }

            .rerf-row-content .rerf-col-w12 {
                flex-basis: 100%
            }

        .rerf-image .rerf-center {
            margin: 0 auto
        }

        .rerf-icon .rerf-content {
            display: flex;
            align-items: center
        }

        .rerf-image img {
            display: block;
            width: 100%
        }


        .rerf-row-1 .rerf-col-1,
        .rerf-row-2 .rerf-col-1,
        .rerf-row-3 .rerf-col-1 {
            padding-bottom: 5px;
            padding-top: 15px
        }

            .rerf-row-1 .rerf-col-1 .rerf-block-2 {
                width: 100%;
                text-align: center;
                padding-bottom: 10px
            }

            .rerf-row-3 .rerf-col-1 .rerf-block-1 {
                color: #9d9d9d;
                font-family: inherit;
                font-size: 15px;
                padding-bottom: 5px;
                padding-top: 5px;
                text-align: center
            }

                .rerf-row-3 .rerf-col-1 .rerf-block-1 .rerf-icon-image {
                    padding: 5px 6px 5px 5px
                }


            .rerf-row-2 .rerf-col-1 .rerf-block-1 {
                color: #101112;
                font-size: 22px;
                font-family: Georgia, Times, "Times New Roman", serif;
                font-weight: 700;
                line-height: 150%;
                text-align: center;
                direction: ltr;
                letter-spacing: 0
            }

                .rerf-row-2 .rerf-col-1 .rerf-block-1 p:not(:last-child) {
                    margin-bottom: 6px
                }

        hr {
            opacity: .3
        }
    </style>
</head>
<body>
    <div class="rerf-page-container">
        <div class="rerf-row rerf-row-1">
            <div class="rerf-row-content">
                <div class="rerf-col rerf-col-1 rerf-col-w12">
                    <div class="rerf-block rerf-block-1 rerf-image"><img alt="" class="rerf-center rerf-autowidth" src="https://connectone.app/content/images/logos/ins_00003.jpg" style="max-width:260px;" /></div>
                    <div class="rerf-block rerf-block-2 rerf-heading">
                        <h3 style="color:#000000;font-size:24px;font-family:Arial, Helvetica Neue, Helvetica, sans-serif;line-height:120%;text-align:center;direction:ltr;font-weight:700;letter-spacing:normal;margin-top:0;margin-bottom:0;"><span class="tinyMce-placeholder">RAJYOGA EDUCATION AND RESEARCH FOUNDATION</span> </h3>
                    </div>
                </div>
            </div>
        </div>
        <hr>
        <div class="rerf-row rerf-row-2">
            <div class="rerf-row-content">
                <div class="rerf-col rerf-col-1 rerf-col-w12">
                    <div class="rerf-block rerf-block-1 rerf-paragraph">
                        <p><em>Thanks for attending RERF Wing Membership Form Approval Request. </em></p>
                        <p><em>We shall be taking required Action henceforth !!</em></p>
                        You may please close this Window now !!
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>