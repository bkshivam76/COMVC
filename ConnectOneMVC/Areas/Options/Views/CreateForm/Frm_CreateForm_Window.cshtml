                                @(Html.DevExtreme().CheckBox().ID("IsWhatsappNotification_createForm").Name("IsWhatsappNotification_createForm").Value(Model.Tag == "_New" ? true : Model.IsWhatsappNotification_createForm).Text("Whatsapp").OnValueChanged("IsWhatsappNotification_createForm_valueChange"))
