    function SetSMSContent_createForm(e, FirstCall = false)
    {
        var purpose = $("#Purpose_createForm").dxSelectBox("option", "value");
        var genRegNo = $("#GenerateReg_createForm").dxRadioGroup("option", "value");
        var genRegNoApp = $("#GenerateRegApproval_createForm").dxRadioGroup("option", "value");
        var ApproveReq = $("#ApprovalReq_createForm").dxRadioGroup("option", "value")
        var confirmSMS = "";
        var ApproveSMS = "";
        var RejectSMS = "Sorry, your application for #EVENT#.. is not approved. INFOBK";
        if (genRegNo == false)
        {
            if (purpose == "FEEDBACK")
            {
                confirmSMS = "Thanks for posting the feedback for #EVENT# INFOBK";
            }
            else
            {
                if (ApproveReq)
                {
                    confirmSMS = "Dear Applicant, Thank you for Registering for #EVENT#.Please wait for Approval Message. PBKIVV";
                }
                else
                {
                    confirmSMS = "Thank you for Registering for #EVENT#. Your Registration has been confirmed. INFOBK";
                }
            }
        }
        if (genRegNo == true)
        {
            if (purpose == "FEEDBACK") {
                confirmSMS = "Thanks for posting the feedback for #FORMNAME# INFOBK"
            }
            else
            {
                confirmSMS = "Thank you for Registering for #FORMNAME#... Your Registration No. is #REGNO#. INFOBK";
            }
        }
        $("#ConfirmSMS_createForm").dxTextBox("option", "value", confirmSMS);
        if (genRegNo == false && genRegNoApp == false)
        {
            ApproveSMS = "Your application for #EVENT# is approved. Please check your email for next step. INFOBK";
        }
        if (genRegNo || genRegNoApp)
        {
            ApproveSMS = "Your application for #EVENT#.. is approved. Your Registration No. is #REGNO#. INFOBK";
        }
        $("#ApprovalSMS_createForm").dxTextBox("option", "value", ApproveSMS);
        $("#RejectionSMS_createForm").dxTextBox("option", "value", RejectSMS);
    }
