    function UpdateColumnSpan(RowNo)
    {
        var count = 0;
        var allRowNos = $('.RowNoClass_createForm')
        for (var i = 0; i < allRowNos.length; i++)
        {
            var value = $(allRowNos[i]).dxNumberBox("option", "value");
            if (value == RowNo)
            {
                count++;
            }
        }
        var columnspan = parseInt(12 / count);
        for (var i = 0; i < allRowNos.length; i++)
        {
            var value = $(allRowNos[i]).dxNumberBox("option", "value");
            if (value == RowNo)
            {
                var _secno = parseInt(allRowNos[i].id.split(/[\[\]]/)[1]);
                $("div[id='Section[" + _secno + "].ColumnSpan']").dxNumberBox("option", "value", columnspan);
            }
        }
    }
