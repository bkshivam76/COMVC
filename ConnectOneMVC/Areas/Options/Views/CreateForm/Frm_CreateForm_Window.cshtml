    string[] ProfileFileds = new string[] { "FULL NAME", "MOBILE NUMBER","EMAIL ID","PROFILE PICTURE","GENDER","AGE","DOB","COUNTRY",
                                               "STATE","CITY","PINCODE","ADDRESS","MEDITATION COURSE","DATE OF COURSE","CURRENT CENTRE",
                                               "BK TITLE","EDUCATION","OCCUPATION","SPECIALITIES","ID PROOF","ID NUMBER"};
    bool Ismobile = Request.Browser.IsMobileDevice;

    List<string> PurposeItemList = new List<string>();
    string[] editorIds = new string[6] { "ConfirmMsg_createForm", "ApprovalMsg_createForm", "RejectionMsg_createForm", "ConfirmWhatsapp_createForm", "ApprovalWhatsapp_createForm", "RejectionWhatsapp_createForm" };
    if (ViewBag.Purpose_CHART == true) { PurposeItemList.Add("CHART"); }
    if (ViewBag.Purpose_REGISTRATION == true) { PurposeItemList.Add("REGISTRATION"); }
    if (ViewBag.Purpose_FORM == true) { PurposeItemList.Add("FORM"); }
    if (ViewBag.Purpose_FEEDBACK == true) { PurposeItemList.Add("FEEDBACK"); }
    if (ViewBag.Purpose_TRAVEL_DETAIL == true) { PurposeItemList.Add("TRAVEL DETAIL"); }
    if (ViewBag.Purpose_ACCOMMODATION == true) { PurposeItemList.Add("ACCOMMODATION"); }
    if (ViewBag.Purpose_EVENT_REQUEST == true) { PurposeItemList.Add("EVENT REQUEST"); }
    if (ViewBag.Purpose_TASK == true) { PurposeItemList.Add("TASK"); }
    if (ViewBag.Purpose_BASIC_DETAILS == true) { PurposeItemList.Add("BASIC DETAILS"); }
    if (ViewBag.Purpose_SURVEY_FORMS == true) { PurposeItemList.Add("SURVEY FORMS"); }
    if (ViewBag.Purpose_QUIZ == true) { PurposeItemList.Add("QUIZ"); }
    if (ViewBag.Purpose_SEVADHARI == true) { PurposeItemList.Add("SEVADHARI"); }

    string[] PurposeItemArray = PurposeItemList.ToArray();
    string DefaultWhatsAppNo = System.Configuration.ConfigurationManager.AppSettings["DefaultWhatsAppSender"];
    string DefaultEmailFrom = System.Configuration.ConfigurationManager.AppSettings["SenderId"];

}
