    function AccordionClick_createForm(e)
    {
        /* Toggle between hiding and showing the active panel */
        var panel = e.nextElementSibling;
        if (panel.style.display === "none")
        {
            panel.style.display = "block";
            ($(e).find('svg')).remove();
            $(e).append('<i class="fa fa-arrow-up"></i>')
            $(e).addClass("full-width-header-bg2")
        }
        else
        {
            panel.style.display = "none";
            ($(e).find('svg')).remove();
            $(e).append('<i class="fa fa-arrow-down"></i>')
            $(e).removeClass("full-width-header-bg2")
        }
    }
