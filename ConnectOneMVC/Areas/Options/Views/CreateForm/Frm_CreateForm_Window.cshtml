    function setGroupTitleHoverSettings(BGColor, ForeColor)
    {
        var GroupTitleBGColor_hover = tinycolor(BGColor).isDark() ? tinycolor(BGColor).lighten(10).setAlpha(1).toString() : tinycolor(BGColor).darken(10).setAlpha(1).toString();
        var GroupTitleForeColor_hover = tinycolor(GroupTitleBGColor_hover).isDark() ? tinycolor.mix(ForeColor, "#ffffff", amount = 80) : tinycolor.mix(ForeColor, "#000000", amount = 50);
        $("div[id='GroupPanelDiv']").hover(function (e)
        {
            $(this).find('.panel-heading').css("background-color", e.type === "mouseenter" ? GroupTitleBGColor_hover : BGColor)
            $(this).find('h4').css("color", e.type === "mouseenter" ? GroupTitleForeColor_hover : ForeColor)
            $(this).find('a > label').css("color", e.type === "mouseenter" ? GroupTitleForeColor_hover : ForeColor)
        })
    }
