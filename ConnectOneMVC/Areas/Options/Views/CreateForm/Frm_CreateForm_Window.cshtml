    function ProfileSetting_Mandatory_SelectionChanged(e) {
        var ID = e.element[0].id;
        var Visible_ID = "div[id='" + (ID.split('.')[0]) + ".Visible'" + "]";
        var Enable_ID = "div[id='" + (ID.split('.')[0]) + ".Enable'" + "]";
        var FieldNo = parseInt(ID.split(/[\[\]]/)[1]);
        var FieldID = "div[id='" + (ID.split('.')[0]) + ".Field'" + "]";
        var ProfileType = ID.split(/[\[\]]/)[0];
        if (e.selectedItem.value == true)
        {
            $(Visible_ID).dxSelectBox("instance").option("value", true);
            $(Enable_ID).dxSelectBox("instance").option("value", true);
            $(Visible_ID).dxSelectBox("instance").option("readOnly", true);
            $(Enable_ID).dxSelectBox("instance").option("readOnly", true);
        }
        else
        {
            if (ProfileType == "ProfileSettings") {
                var UserProfileVisibility = $("#UserProfileVisibility_createForm").dxSwitch("option", "value");
                if (UserProfileVisibility == true) {
                    $(Visible_ID).dxSelectBox("instance").option("readOnly", false);
                    $(Enable_ID).dxSelectBox("instance").option("readOnly", false);
                }
            }
            else {
                var GroupRegCount = $("#Max_GroupRegistrations_Allowed_createForm").dxNumberBox("option", "value");
                if (GroupRegCount > 0) {
                    $(Visible_ID).dxSelectBox("instance").option("readOnly", false);
                    $(Enable_ID).dxSelectBox("instance").option("readOnly", false);
                }
            }
        }

        if ($(FieldID).dxTextBox("instance").option("value") == "ID NUMBER")
        {
            var IDProofMandatoryID = "div[id='" +ProfileType+"[" + (FieldNo - 1) + "].Mandatory'" + "]";
            if (e.selectedItem.value == true)
            {
                $(IDProofMandatoryID).dxSelectBox("instance").option("value", true);
            }
            //$(IDProofMandatoryID).dxSelectBox("instance").option("readOnly", e.selectedItem.value);
        }
    }
    function ProfileSetting_Visible_SelectionChanged(e)
    {
        var ID = e.element[0].id;
        var FieldNo = parseInt(ID.split(/[\[\]]/)[1]);
        var FieldID = "div[id='" + (ID.split('.')[0]) + ".Field'" + "]";
        var MadatoryID = "div[id='" + (ID.split('.')[0]) + ".Mandatory'" + "]";
        var EnableID = "div[id='" + (ID.split('.')[0]) + ".Enable'" + "]";
        var VisibleID = "div[id='" + (ID.split('.')[0]) + ".Visible'" + "]";
        var ProfileType = ID.split(/[\[\]]/)[0];
        if ($(FieldID).dxTextBox("instance").option("value") == "CITY")
        {
            var StateVisibleID = "div[id='" +ProfileType+"[" + (FieldNo - 1) + "].Visible'" + "]";
            if (e.selectedItem.value == true)
            {
                $(StateVisibleID).dxSelectBox("instance").option("value", true);
            }
            //$(StateVisibleID).dxSelectBox("instance").option("readOnly", e.selectedItem.value);
        }
        if ($(FieldID).dxTextBox("instance").option("value") == "ID NUMBER")
        {
            var IDProofVisibleID = "div[id='" + ProfileType + "[" + (FieldNo - 1) + "].Visible'" + "]";
            if (e.selectedItem.value == true)
            {
                $(IDProofVisibleID).dxSelectBox("instance").option("value", true);
            }
            //$(IDProofVisibleID).dxSelectBox("instance").option("readOnly", e.selectedItem.value);
