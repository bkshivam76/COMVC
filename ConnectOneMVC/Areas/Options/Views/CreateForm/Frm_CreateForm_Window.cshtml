    function appendMultipleOption_createForm(htmldata, SecNo, OptionCount, OptionData = null)
    {
        $("#MultiOptAppendDivID_" + SecNo + "_createForm").append(htmldata);
        $(".AnsOptionAddMoreClass_" + SecNo + "_createForm").hide();        //hide all add more option button
        $("#AnsOptionAddMore_" + SecNo + "_" + OptionCount + "_createForm").show(); //show add more button in the added option
        var index = SecNosandOptions.findIndex(x => x.secno == SecNo);
        if (index > -1)
        {
            SecNosandOptions[index].options.push(OptionCount);
        }
        setTimeout(function ()
        {
            if (OptionData != null) {
                $("div[id='Section[" + SecNo + "].Options[" + OptionCount+"].Options']").dxTextBox("option", "value", OptionData.Options);
                $("#Section_" + SecNo + "__Options_" + OptionCount + "__Rec_ID").val(OptionData.Rec_ID);
                RefreshDependentQuestionData(false, false)
                if (OptionData.DependentQuestion != null && OptionData.DependentQuestion.length > 0)
                {
                    $("div[id='DependentQuestion_" + SecNo + "_" + OptionCount + "_datagrid']").dxDataGrid("instance").selectRows(OptionData.DependentQuestion.split(',').map((i) => Number(i) - 1));
                    $("div[id='Section[" + SecNo + "].Options[" + OptionCount + "].DependentQuestionVisibility']").dxSelectBox("option", "value", OptionData.DependentQuestionVisibility);
                }
                $("div[id='Section[" + SecNo + "].Options[" + OptionCount + "].Points']").dxNumberBox("option", "value", OptionData.Points);
                if (OptionData.optionImagePath != null && OptionData.optionImagePath.length > 0) {
                    ImageSettings_createForm("Option", OptionData.optionImagePath, null, null, SecNo, OptionCount);
                    $("#Section_" + SecNo + "__Options_" + OptionCount+"__OptionImageFileName").val(OptionData.OptionImageFileName);
                }
            }
            else {
                RefreshDependentQuestionData()
                $("div[id='Section[" + SecNo + "].Options[" + OptionCount +"].Options']").find('input').focus();
            }
            TransformTextForDB("form_createForm");
        }, 100)
    }
    function MultipleOption_CancelClick_createForm(e, _Mode, _SecNo)
    {
        var AnsOptCancelID = e.id;
        var SecNo = parseInt(_SecNo);
        var optionCount = parseInt(AnsOptCancelID.split('_')[2]);
        var MultiOptFormGroupID = "MultiOptFormGroupID_" + SecNo + "_" + optionCount + "_createForm";
        var MultiOptAppendDivID = "MultiOptAppendDivID_" + SecNo + "_createForm";
        var AnsOptionAddMoreID = "AnsOptionAddMore_" + SecNo + "_" + optionCount + "_createForm";
        var OptionRecID = $("#Section_" + SecNo + "__Options_" + optionCount + "__Rec_ID").val();
        if ($("#" + AnsOptionAddMoreID).length > 0 && $("#" + AnsOptionAddMoreID).is(":visible") == true) // check if canceled option has add more button
        {
            ($("#" + MultiOptFormGroupID).prevAll('div:first')).find(".AnsOptionAddMoreClass_" + SecNo + "_createForm").show(); //go to prev sibling and show its add more option button
        }
        ($("#" + MultiOptFormGroupID).prevAll('div:first')).find(".MultipleOption_createForm").focus();
        $("#" + MultiOptAppendDivID).children("#" + MultiOptFormGroupID).remove(); //remove the cancelled option
        var index = SecNosandOptions.findIndex(x => x.secno == SecNo);
        if (index > -1)
        {
            const optIndex = SecNosandOptions[index].options.indexOf(optionCount);
            if (optIndex > -1)
            {
                SecNosandOptions[index].options.splice(optIndex, 1)
            }

            if (OptionRecID != null && OptionRecID.length > 0)
            {
                Deleted_Ques_option_RecIDs[0].DeleteOptionRecID.push(OptionRecID)
            }
        }
    }
    function ReorderOptions_createForm(e)
    {
        var MovingOptionID = e.itemElement[0].id;
        var SecNo = parseInt(MovingOptionID.split('_')[1]);
        var AnsOptionCancelClass = "AnsOptionCancelClass_" + SecNo + "_createForm";
        var AnsOptionAddMoreClass = "AnsOptionAddMoreClass_" + SecNo + "_createForm";
        $("." + AnsOptionCancelClass).show(); //show all option remove button
        $(e.element[0]).children('div').first().find("." + AnsOptionCancelClass).hide(); //hide remove option button of first option
        $("." + AnsOptionAddMoreClass).hide(); //hide all option add button
        $(e.element[0]).children('div').last().find("." + AnsOptionAddMoreClass).show(); //show add option button of last option
        var index = SecNosandOptions.findIndex(x => x.secno == SecNo);
        if (index > -1) {
            SecNosandOptions[index].options.move(e.fromIndex, e.toIndex);
        }
    }
    function ChangeAccordionTitle(accSpanEle, Qno, Qtext)
    {
        var exisitingTitle = $(accSpanEle).text();
        if (Qno == null)
        {
            if (Qtext == null || Qtext.length == 0)
            {
                $(accSpanEle).text((exisitingTitle.split(':')[0]));
            }
            else
            {
                $(accSpanEle).text((exisitingTitle.split(':')[0]) + " : " + Qtext);
            }
        }
        else
        {
            var _split = exisitingTitle.split(':');
            if (_split.length > 1)
            {
                $(accSpanEle).text("Question " + Qno + " : " + (_split[1]));
            }
            else
            {
                $(accSpanEle).text("Question " + Qno);
            }
        }
    }
    function RefreshDependentQuestionData(DeleteSelection=false,NewQues=true,ReorderQues=false)
    {
        var DependentQuestion_items = [];
        if (NewQues == true)
        {
            for (var i = 0; i < SecNosandOptions.length; i++)
            {
                var secNo = SecNosandOptions[i].secno;
                var Q_Data =
                {
                    "SrNo": i + 1, "Question": $("div[id='Section[" + secNo + "].Question']").dxTextArea("option", "value"), "secno": secNo
                }
                DependentQuestion_items.push(Q_Data);
            }
        }
        else
        {
            for (var i = 0; i < QuestionData_createForm.length; i++)
            {
                var Q_Data =
                {
                    "SrNo": i + 1, "Question": QuestionData_createForm[i].Question, "secno": i
                }
                DependentQuestion_items.push(Q_Data);
            }
        }
        var dataSource_DependentQuestion = new DevExpress.data.DataSource({ // need to dispose it in in clearreference
            store:
            {
                type: "array",
                key: "secno",
                data: DependentQuestion_items
            }
        });
        $(".DependentQuestion").dxDropDownBox("option", "dataSource", dataSource_DependentQuestion);
        $(".DependentQuestion_DG").dxDataGrid("option", "dataSource", dataSource_DependentQuestion);
        dataSource_DependentQuestion.load().done(function ()
        {
            if (DeleteSelection || ReorderQues)
            {
                var DependentQuestion = $(".DependentQuestion");
                var DependentQuestionVisibility = $(".DependentQuestionVisibility");
                for (var i = 0; i < DependentQuestion.length; i++)
                {
                    var value = $(DependentQuestion[i]).dxDropDownBox("option", "value");
                    if (value != null && value.length > 0)
                    {
                        var dependentQuestionVisibility_value = $(DependentQuestionVisibility[i]).dxSelectBox("option","value");
                        $(DependentQuestion[i]).dxDropDownBox("reset");
                        $(DependentQuestion[i]).dxDropDownBox("option", "value", value);
                        $(DependentQuestionVisibility[i]).dxSelectBox("option", "value", dependentQuestionVisibility_value)

                    }
                }
            }
        });
    }
    function sortDependentQuestion_createForm(value1, value2, GridID)
    {
        var grid = $("#" + GridID).dxDataGrid("instance");
        var isSelected1 = grid.isRowSelected(value1),
            isSelected2 = grid.isRowSelected(value2);

        if (isSelected1 && !isSelected2) return -1;
        if (!isSelected1 && isSelected2) return 1;

        return 0;
    }
    function DG_OnRowClick_createForm(e) {
        if (e.isSelected) {
            e.component.deselectRows(e.key);
        }
        else {
            e.component.selectRows(e.key, true);
        }
    }
    async function DependentQuestion_ValueChange_createForm(e, FirstCall = false, DG_ID = null)
    {
        var value;
        var DG = $("#" + DG_ID).dxDataGrid("instance");
        var secNo = parseInt(DG_ID.split('_')[1])
        var optNo = parseInt(DG_ID.split('_')[2])
        if (e)
        {
            value = e.value;
            if ((e.value == null || e.value.length == 0) && e.previousValue != null)
            {
                DG.clearSelection();
                $("div[id='Section[" + secNo + "].Options[" + optNo + "].DependentQuestionVisibility']").dxSelectBox("reset");
                $("div[id='Section[" + secNo + "].Options[" + optNo + "].DependentQuestionVisibility']").dxSelectBox("option", "readOnly", true);
                //DG.refresh();
                return;
            }
        }
        else
        {
            value = $("div[id='Section[" + secNo + "].Options[" + optNo + "].DependentQuestion']").dxDropDownBox("option", "value");
        }
        if (value != null && value.length > 0)
        {
            var index = value.indexOf(secNo);
            if (index > -1) {
                value.splice(index, 1);
            }
        }
        await DG.selectRows(value);
        if (value != null && value.length > 0)
        {
            $("div[id='Section[" + secNo + "].Options[" + optNo + "].DependentQuestionVisibility']").dxSelectBox("option", "readOnly", false);
        }
      //  DG.refresh();
    }
</script>
