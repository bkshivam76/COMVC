                @Html.HiddenFor(x => x.CreatedInstanceCount_createForm)*@
            <div id="Header_createForm" class="section_createForm">
                <div class="accordion_createForm collapsable full-width-header-bg2" id="FormSettingAccordion" onclick="AccordionClick_createForm(this)"><span>Form Settings</span><i class="fa fa-arrow-up"></i></div>
                <div id="FormSettings_createForm" class="AccordionPanel_createForm">
                    <div class="row">
                        <div class="col-sm-4">
                            <div class="form-field">
                                <label>Form Name</label>
                                @(Html.DevExtreme().TextBox().CustomTextBox(true).Name("FormName_createForm").ID("FormName_createForm").Placeholder("Form Name").Value(Model.FormName_createForm).MaxLength(255))
                            </div>

                            <div class="form-field">
                                <label>Start Date</label>
                                @(Html.DevExtreme().DateBox().CustomDateBox().Name("StartDate_createForm").ID("StartDate_createForm").Min(new DateTime(1990,01,01)).Value(Model.StartDate_createForm).OnValueChanged("StartDate_createForm_ValueChange"))
                            </div>
                            <div class="form-field">
                                <label>End Date</label>
                                @(Html.DevExtreme().DateBox().CustomDateBox().Name("EndDate_createForm").ID("EndDate_createForm").Min(new DateTime(1990,01,01)).Value(Model.EndDate_createForm).OnValueChanged("EndDate_createForm_ValueChange"))
                            </div>
                            <div class="form-field">
                                <label>Max. Entries Allowed</label>
                                @(Html.DevExtreme().NumberBox().CustomNumberBox().Name("MaxEntriesAllowed_createForm").ID("MaxEntriesAllowed_createForm").Value(Model.MaxEntriesAllowed_createForm).Format("#").Min(0).Max(Int32.MaxValue).Placeholder("Maximum Entries Allowed").Value(Model.MaxEntriesAllowed_createForm))
                            </div>
                        </div>

                        <div class="col-sm-4">
                            <div class="form-field">
                                <label>Form Title</label>
                                @(Html.DevExtreme().HtmlEditor().CustomHtmlEditor().Name("FormTitle_createForm").ID("FormTitle_createForm").Placeholder("Form Title").Value(Model.FormTitle_createForm).Height(172))
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-field">
                                <label>Form Description</label>
                                @(Html.DevExtreme().HtmlEditor().CustomHtmlEditor().Name("FormDescription_createForm").ID("FormDescription_createForm").Placeholder("Form Description").Value(Model.FormDescription_createForm).Height(172))
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-4">
                            <div class="form-field">
                                <label>Service Report/Event</label>
                                @(Html.DevExtreme().DropDownBox().CustomDropDown().Value(Model.Sr_Event_createForm).Name("Sr_Event_createForm").ID("Sr_Event_createForm").Placeholder("Choose..").DisplayExpr("Name").ValueExpr("ID")
                                   .DataSource(d => d.Mvc().Controller("CreateForm").LoadAction("LookUp_Get_ServiceReport_Event").Key("ID").LoadMode(DataSourceLoadMode.Raw))
                            .ContentTemplate(@<text>
                                @(Html.DevExtreme().DataGrid().CustomDataGrid().ID("Sr_Event_createForm_datagrid")
                        .Columns(columns =>
                        {
                            columns.Add().DataField("Name").Caption("Name");
                            columns.Add().DataField("FromDate").Caption("From").DataType(GridColumnDataType.Date).Format("dd/MM/yyyy");
                            columns.Add().DataField("ToDate").Caption("To").DataType(GridColumnDataType.Date).Format("dd/MM/yyyy");
                            columns.Add().DataField("Venue").Caption("Venue");
                            columns.Add().DataField("Cen_Name").Caption("Centre");
                            columns.Add().DataField("ID").Visible(false);
                            columns.Add().DataField("ProjID").Visible(false);
                            columns.Add().DataField("Type").Visible(false);
                            columns.Add().DataField("Cen_ID").Visible(false);
                        })
                        .Selection(s => s.Mode(SelectionMode.Single))
                        .FilterRow(s=>s.Visible(false))
                        .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}"))
                            </text>).OnValueChanged("Sr_Event_createForm_ValueChange"))
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-field">
                                <label>Project</label>
                                @(Html.DevExtreme().SelectBox().CustomSelectBox().Value(Model.ProjectID_createForm).DataSource(d => d.Mvc().Controller("CreateForm").LoadAction("LookUp_Get_ProjectList").Key("ID").LoadMode(DataSourceLoadMode.Raw)).DisplayExpr("Name").ValueExpr("ID").Name("ProjectID_createForm").ID("ProjectID_createForm").Placeholder("Choose Project"))
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-field">
                                <label>Pre Required Form Instance</label>
                                @(Html.DevExtreme().DropDownBox().CustomDropDown().Value(Model.PreRequiredChartSrID_createForm).Name("PreRequiredChartSrID_createForm").ID("PreRequiredChartSrID_createForm").Placeholder("Choose..").DisplayExpr("ChartName").ValueExpr("SrNO")
                                   .DataSource(d => d.Mvc().Controller("CreateForm").LoadAction("LookUp_Get_ChartInstance").Key("SrNO").LoadMode(DataSourceLoadMode.Raw).LoadParams(new { ChartID = Model.FormID,ServiceReportID= new JS("function() {return $('#SR_ID').val();}"),EventID= new JS("function() {return $('#Event_ID').val();}")}))
                            .ContentTemplate(@<text>
                                @(Html.DevExtreme().DataGrid().CustomDataGrid().ID("PreReq_createForm_datagrid")
                        .Columns(columns =>
                        {
                            columns.Add().DataField("ChartName").Caption("Name");
                            columns.Add().DataField("SrNO").Caption("Serial No");
                        })
                        .Selection(s => s.Mode(SelectionMode.Single))
                        .FilterRow(s=>s.Visible(false))
                        .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}"))
                            </text>).OnValueChanged("PreRequiredChartSrID_createForm_ValueChange"))
                            </div>
                        </div>
                        @*</div>*@
                        @*<div class="row" id="Div_purpose_createForm">*@
                        <div class="col-sm-4">
                            <div class="form-field">
                                <label>Purpose</label>
                                @*@(Html.DevExtreme().SelectBox().CustomSelectBox().Value(Model.Purpose_createForm??"REGISTRATION").ShowClearButton(false).Items(new string[] { "CHART","REGISTRATION","FORM", "FEEDBACK","TRAVEL DETAIL","ACCOMMODATION","EVENT REQUEST","TASK","BASIC DETAILS","SURVEY FORMS"  }).Name("Purpose_createForm").ID("Purpose_createForm").Placeholder("Choose Purpose").OnValueChanged("Purpose_createForm_ValueChange"))*@
                                @(Html.DevExtreme().SelectBox().CustomSelectBox().Value(Model.Purpose_createForm??"REGISTRATION").ShowClearButton(false).Items(PurposeItemArray).Name("Purpose_createForm").ID("Purpose_createForm").Placeholder("Choose Purpose").OnValueChanged("Purpose_createForm_ValueChange"))
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="form-field">
                                <label>Login Mode</label>
                                @(Html.DevExtreme().SelectBox().CustomSelectBox().Value(Model.FormLoginRequired_createForm??"MOBILE").ShowClearButton(false).Items(new string[] { "MOBILE","EMAIL","MOBILE OR EMAIL","NONE"}).Name("FormLoginRequired_createForm").ID("FormLoginRequired_createForm").Placeholder("Choose Login mode").OnValueChanged("FormLoginRequired_createForm_ValueChange"))
                            </div>
                        </div>
                        <div class="col-sm-2">
                            <div class="form-field">
                                <label>Allow Resubmission</label>
                                @(Html.DevExtreme().RadioGroup().Value(Model.AllowResubmission_createForm).DataSource(new object[] { new { text = "YES", value = true }, new { text = "NO", value=false } }).Name("AllowResubmission_createForm").ID("AllowResubmission_createForm").ValueExpr("value").DisplayExpr("text").Layout(Orientation.Horizontal))
                            </div>
