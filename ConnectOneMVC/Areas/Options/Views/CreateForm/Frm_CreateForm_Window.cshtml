    function ShowHideNotificationMessagesBlock_createForm(FirstCall=false)
    {
        var EmailSelected = $("#IsEmailNotification_createForm").dxCheckBox("instance").option("value");
        var WhatsAppSelected = $("#IsWhatsappNotification_createForm").dxCheckBox("instance").option("value");
        var SmsSelected = $("#IsSMSNotification_createForm").dxCheckBox("instance").option("value");
        var ApprovalRequired = $("#ApprovalReq_createForm").dxRadioGroup("instance").option("value");
        if (EmailSelected)
        {
            $("#Confirm_Msg_Div_id").show();
            if (ApprovalRequired)
            {
                $("#App_Rej_Msg_Div_id").show();
            }
            else
            {
                $("#App_Rej_Msg_Div_id").hide();
            }
        }
        else
        {
            $("#Confirm_Msg_Div_id").hide();
            $("#App_Rej_Msg_Div_id").hide();
        }
        if (WhatsAppSelected)
        {
            $("#Confirm_WhatsAppMsg_Div_id").show();
            if (ApprovalRequired)
            {
                $("#App_Rej_Whatsapp_Div_id").show();
            }
            else
            {
                $("#App_Rej_Whatsapp_Div_id").hide();
            }
        }
        else
        {
            $("#Confirm_WhatsAppMsg_Div_id").hide();
            $("#App_Rej_Whatsapp_Div_id").hide();
        }
        if (SmsSelected)
        {
            $("#Confirm_SmsMsg_Div_id").show();
            if (ApprovalRequired)
            {
                $("#App_Rej_SMS_Div_id").show();
            }
            else
            {
                $("#App_Rej_SMS_Div_id").hide();
            }
        }
        else
        {
            $("#Confirm_SmsMsg_Div_id").hide();
            $("#App_Rej_SMS_Div_id").hide();
        }
        if (EmailSelected || WhatsAppSelected || SmsSelected)
        {
            $("#ShowNotificationAccordion").show();
            var panel = $("#ShowNotificationAccordion")[0].nextElementSibling;
            if (panel.style.display === "none")
            {
                $("#ShowNotificationAccordion").click();
            }
        }
        else
        {
            $("#ShowNotificationAccordion").hide();
        }
        if (FirstCall == false)
        {
            $("#IsEmailAcceptEnabled_createForm").dxCheckBox("option", "value", (ApprovalRequired && EmailSelected))
            $("#IsEmailRejectEnabled_createForm").dxCheckBox("option", "value", (ApprovalRequired && EmailSelected))
            $("#IsWhatsappAcceptEnabled_createForm").dxCheckBox("option", "value", (ApprovalRequired && WhatsAppSelected))
            $("#IsWhatsappRejectEnabled_createForm").dxCheckBox("option", "value", (ApprovalRequired && WhatsAppSelected))
            $("#IsSMSAcceptEnabled_createForm").dxCheckBox("option", "value", (ApprovalRequired && SmsSelected))
            $("#IsSMSRejectEnabled_createForm").dxCheckBox("option", "value", (ApprovalRequired && SmsSelected))
        }
    }
