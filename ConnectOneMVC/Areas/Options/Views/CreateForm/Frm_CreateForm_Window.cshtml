    async function multipleOptionAjaxCall_createForm(_secNo, _Mode,OptionCount,_Purpose)
    {
        return $.ajax({
            type: 'GET',
            url: "/Options/createForm/MultipleOption",
            cache: false,
            //async:false,
            data:
            {
                Mode: _Mode,
                Secno: _secNo,
                optCount: OptionCount,
