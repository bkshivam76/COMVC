            ImageParentDiv = "#FormMobileImageDiv_createForm";
            Imagetag = "FormMobileImage_createForm";
            Imagehref = "FormMobileImageHref_createForm";
            defaultWidth = 500;
        }
        else if (type == "Question") {
            ImageParentDiv = "#QuestionImageDiv_" + SecNo + "_createForm";
            Imagetag = "QuestionImage_" + SecNo + "_createForm";
            Imagehref = "QuestionImageHref_" + SecNo + "_createForm";
            ImageWidthControl = "div[id='Section[" + SecNo + "].QuestionImageWidth']";
            ImageHeightControl = "div[id='Section[" + SecNo + "].QuestionImageHeight']";
            defaultWidth = 740;
        }
        else if (type == "Option") {
            ImageParentDiv = "#MultipleOptionImageDiv_" + SecNo + "_" + optNo + "_createForm";
            Imagetag = "MultipleOptionImage_" + SecNo + "_" + optNo + "_createForm";
            Imagehref = "MultipleOptionImageHref_" + SecNo + "_" + optNo + "_createForm";
           $("#" + Imagetag).addClass("imgThumbnail");
        }
        var img = document.getElementById(Imagetag)
        img.src = path;
        $(ImageParentDiv).show();
        document.getElementById(Imagehref).href = path;
        img.onload = function (event)
        {
            if (ImageWidthControl.length > 0)
            {
                $(ImageWidthControl).dxNumberBox("instance").option("value", width == null ? defaultWidth : width)
            }
            if (ImageHeightControl.length > 0)
            {
                $(ImageHeightControl).dxNumberBox("instance").option("value", Math.round( height == null ? (defaultWidth / (img.naturalWidth / img.naturalHeight)) : height))
            }
        }
    }
