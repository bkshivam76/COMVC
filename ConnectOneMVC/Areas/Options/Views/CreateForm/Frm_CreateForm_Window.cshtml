                                @(Html.DevExtreme().DropDownButton().ID("Btn_Notification_Setting_CreateForm").Text("Setting").Icon("save").OnItemClick("NotificationSetting_Click_CreateForm").DataSource(new[] {"Add Notification Setting"@*,"Edit Default Settings","Existing Notification Setting", "Form Notification Queue", "Form Notification Delivery Log"*@ }))
                            </div>
                        </div>
                        <div class="col-sm-2">
                            <div class="form-field">
