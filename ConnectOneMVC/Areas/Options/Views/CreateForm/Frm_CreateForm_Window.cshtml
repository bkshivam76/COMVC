                            </div>
                        </div>
                        @*</div>*@
                        @*<div class="row" id="Div_notification_createForm">*@
                        <div class="col-sm-4">
                            <div class="form-field">
                                <label>Generate Registration No. On Approval</label>
                                @(Html.DevExtreme().RadioGroup().Value(Model.GenerateRegApproval_createForm).DataSource(new object[] { new { text = "YES", value = true }, new { text = "NO", value = false } }).Name("GenerateRegApproval_createForm").ID("GenerateRegApproval_createForm").ValueExpr("value").DisplayExpr("text").Layout(Orientation.Horizontal).ReadOnly(Model.GenerateReg_createForm).OnValueChanged("GenerateRegApproval_createForm_valueChange"))
