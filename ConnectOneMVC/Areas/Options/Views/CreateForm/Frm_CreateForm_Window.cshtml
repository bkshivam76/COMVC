    async function Template_CreateForm_ValueChange(e, FirstCall=false, id=null) {
        let idPlaceholder = null;
        let value = null;
        let paramData = '';
        if (FirstCall) {
            idPlaceholder = id;
            idPlaceholder = idPlaceholder.replace("Template_DD", "");
        }
        if (e && e.element[0].id) {
            idPlaceholder = e.element[0].id;
            idPlaceholder = idPlaceholder.replace("Template_DD", "");
        }
        var dataDD = $("#Template_DD" + idPlaceholder).dxDropDownBox("instance");
        var dataGrid = $("#Template_DG" + idPlaceholder).dxDataGrid("instance");
        if (e) {
            value = e.value;
            if ((e.value == void 0 || e.value == '' || e.value == null || e.value.length == 0) && e.previousValue != null) {
                await dataGrid.clearSelection();
                document.getElementById("header" + idPlaceholder).innerHTML = ""
                document.getElementById("body" + idPlaceholder).innerHTML = ""
                document.getElementById("buttons" + idPlaceholder).innerHTML = ""
                document.getElementById("footer" + idPlaceholder).innerHTML = ""
                if (idPlaceholder.toLowerCase().includes("confirm")) {
                    $("#ConfirmWhatsapp_createForm").val(null);
                    $("#ConfirmWhatsapp_Template_Language_createForm").val(null);
                }
                else if (idPlaceholder.toLowerCase().includes("approval")) {
                    $("#ApprovalWhatsapp_createForm").val(null);
                    $("#ApprovalWhatsapp_Template_Language_createForm").val(null);
                }
                else if (idPlaceholder.toLowerCase().includes("reject")) {
                    $("#RejectionWhatsapp_createForm").val(null);
                    $("#RejectionWhatsapp_Template_Language_createForm").val(null);
                }
                return;
            }
        }
        else {
            if (dataDD) {
                value = dataDD.option("value");
            }            
        }
        if (dataGrid) { await dataGrid.selectRows(value); }
        document.getElementById("header" + idPlaceholder).innerHTML = ""
        document.getElementById("body" + idPlaceholder).innerHTML = ""
        document.getElementById("buttons" + idPlaceholder).innerHTML = ""
        document.getElementById("footer" + idPlaceholder).innerHTML = ""
        if (value == null || value == void 0 || value == '') return;
        //$("#Country_DG_" + cellInfo.key).dxDataGrid("instance").selectRows(e.value);
        var selectedTemplateData = await dataGrid.getSelectedRowsData()
        if (selectedTemplateData && selectedTemplateData.length > 0 && selectedTemplateData[0].components.length > 0) {
            debugger;
            for (var i = 0; i < selectedTemplateData[0].components.length; i++) {
                switch (selectedTemplateData[0].components[i].type) {
                    case "HEADER":
                        if (selectedTemplateData[0].components[i].format == "IMAGE") {
                            //document.getElementById("totalImageDiv_whatsappPaid").style.display = "block"
                            document.getElementById("header" + idPlaceholder).innerHTML +=
                                "<a href='" + selectedTemplateData[0].components[i].example["header_handle"][0] + "' target='_blank'>" +
                                    "<img src='" + selectedTemplateData[0].components[i].example["header_handle"][0] + "' alt='Image' style='max-width:100%; height:auto;' />" +
                                "</a>"
                            IsFormConfirmationTemplateImageExists_createForm = true;
                        }
                        else if (selectedTemplateData[0].components[i].format == "DOCUMENT") {
                            //document.getElementById("totalImageDiv_whatsappPaid").style.display = "block"
                            document.getElementById("header" + idPlaceholder).innerHTML +=
                                "<a href='" + selectedTemplateData[0].components[i].example["header_handle"][0] + "' target='_blank' class='preview - container' title='Open PDF Document'>" +
                                    "<img src='" + selectedTemplateData[0].components[i].example["header_handle"][0] + "' alt='PDF Preview' class='pdf-preview' style='max-width:100%; height:auto;' />" +
                                    "<div class='caption'>Document</div>"
                                "</a>"
                            IsFormConfirmationTemplateImageExists_createForm = true;
                        }
                        else if (selectedTemplateData[0].components[i].format == "VIDEO") {
                            //document.getElementById("totalImageDiv_whatsappPaid").style.display = "block"
                            document.getElementById("header" + idPlaceholder).innerHTML +=
                                "<a href='" + selectedTemplateData[0].components[i].example["header_handle"][0] + "' target='_blank'>"+
                                    "<video controls style='max-width:100%; height:auto;'>" +
                                        "<source src='" + selectedTemplateData[0].components[i].example["header_handle"][0] + "' type='video/mp4' />" +
                                    "</video>"+
                                "</a>"
                                
                            IsFormConfirmationTemplateImageExists_createForm = true;
                        }
                        else if (selectedTemplateData[0].components[i].format == "LOCATION") {
                            //document.getElementById("totalImageDiv_whatsappPaid").style.display = "block"
                            document.getElementById("header" + idPlaceholder).innerHTML +=
                                "<a href='" + selectedTemplateData[0].components[i].example["header_handle"][0] + "' target='_blank'>" +
                                    Location
                                "</a>"
                            IsFormConfirmationTemplateImageExists_createForm = false;
                        }
                        else if (selectedTemplateData[0].components[i].format == "TEXT") {
                            //document.getElementById("totalImageDiv_whatsappPaid").style.display = "none"
                            //FileDeleteImageClick_WhatsappPaid()
                            document.getElementById("header" + idPlaceholder).innerHTML +=
                                "<p class='.headertext_TemplatePreview_CreateForm'>" + selectedTemplateData[0].components[i].text + "</p>"
                            IsFormConfirmationTemplateImageExists_createForm = false;
                        }
                        break;
                    case "BODY":
                        document.getElementById("body" + idPlaceholder).innerHTML +=
                            "<p>" + selectedTemplateData[0].components[i].text + "</p>"
                        if (selectedTemplateData[0].components[i].example && selectedTemplateData[0].components[i].example.body_text_named_params && selectedTemplateData[0].components[i].example.body_text_named_params.length > 0) {
                            for (var j = 0; j < selectedTemplateData[0].components[i].example.body_text_named_params.length; j++) {
                                //donation_amount~21000.00|institute~Rajyoga Education And Research Foundation|phone_number~9414144036
                                if (j > 0) {
                                    paramData = paramData + '|';
                                }
                                if (selectedTemplateData[0].components[i].example.body_text_named_params[j].param_name == "reg_slip_link") {
                                    paramData = paramData + 'reg_slip_link~#REG-SLIP-LINK#';
                                }
                                else {
                                    paramData = paramData + selectedTemplateData[0].components[i].example.body_text_named_params[j].param_name + '~' + '#' + selectedTemplateData[0].components[i].example.body_text_named_params[j].param_name.toUpperCase() + '#';
                                }
                            }
                            if (IsNullOrWhitespace(null, null, paramData)) {
                                paramData = "empty";
                            }
                        }                     
                        break;
                    case "BUTTONS":
                        debugger;                        
                        if (selectedTemplateData[0].components[i].buttons.length >= 1) {
                            for (var j = 0; j < selectedTemplateData[0].components[i].buttons.length; j++) {
                                //donation_amount~21000.00|institute~Rajyoga Education And Research Foundation|phone_number~9414144036
                                document.getElementById("buttons" + idPlaceholder).innerHTML +=
                                    "<button disabled class = '.buttonstyle_TemplatePreview_CreateForm' style='margin:5px;' >" + selectedTemplateData[0].components[i].buttons[j].text + "</button>"
                                if (selectedTemplateData[0].components[i].buttons[j].url.includes("{{1}}")) {
                                    var regex = /\^.+$/;
                                    if (paramData.length > 0 && paramData.includes('^')==false) {
                                        paramData = paramData + '^';
                                    }
                                    if (regex.test(paramData)) {//Check whether there are still character after '^' symbol or not
                                        paramData = paramData + '|';
                                    }
                                    if (selectedTemplateData[0].components[i].buttons[j].text == "Google Map") {
                                        paramData = paramData + '1~' + '#MAP#';
                                    }
                                    if (selectedTemplateData[0].components[i].buttons[j].text == "Ask Query") {
                                        paramData = paramData + '1~' + '#H_CONTACT1#';
                                    }
                                }
                            }
                        }
                        break;
                    case "FOOTER":
                        document.getElementById("buttons" + idPlaceholder).innerHTML += "<p style='color:lightgray;'>" + selectedTemplateData[0].components[i].text + "</p>"
                        break;
                }                
            }
            if (IsNullOrWhitespace(null, null, paramData)) {
                paramData = "empty";
            }
            if (idPlaceholder.toLowerCase().includes("confirm")) {
                $("#ConfirmWhatsapp_createForm").val(paramData);
                $("#ConfirmWhatsapp_Template_Language_createForm").val(selectedTemplateData[0]["language"]);
            }
            else if (idPlaceholder.toLowerCase().includes("approval")) {
                $("#ApprovalWhatsapp_createForm").val(paramData);
                $("#ApprovalWhatsapp_Template_Language_createForm").val(selectedTemplateData[0]["language"]);
            }
            else if (idPlaceholder.toLowerCase().includes("reject")) {
                $("#RejectionWhatsapp_createForm").val(paramData);
                $("#RejectionWhatsapp_Template_Language_createForm").val(selectedTemplateData[0]["language"])
            }
        }
    }
