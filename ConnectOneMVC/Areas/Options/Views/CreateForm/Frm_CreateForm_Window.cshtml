    function appendAnswers_createForm(htmldata, SecNo,Mode, QuestionData=null,Purpose="")
    {
        $("#Answers_" + SecNo + "_createForm").html(htmldata);
        var index = SecNosandOptions.findIndex(x => x.secno == SecNo);
        if (index > -1)
        {
            SecNosandOptions[index].options = [];
            SecNosandOptions[index].options.push(0);
        }
        setTimeout(async function ()
        {
            if (Mode == "CheckBox" || Mode == "DropDown" || Mode == "RadioButton" || Mode == "Formula" || Mode == "Label")
            {
                if (QuestionData != null)
                {
                    if (Mode == "Formula")
                    {
                        $("div[id='Section[" + SecNo + "].Options[0].Options']").dxTextBox("option", "value", QuestionData.QuestionFormula);
                    }
                    else if (Mode == "Label")
                    {
                        $("div[id='Section[" + SecNo + "].Options[0].Options']").dxTextArea("option", "value", QuestionData.DefaultValue);
                    }
                    else
                    {
                        $("div[id='Section[" + SecNo + "].IsOptionsPredefined']").dxRadioGroup("option", "value", QuestionData.IsOptionsPredefined);
                        if (QuestionData.Options != null && QuestionData.Options.length > 0)
                        {
                            $("div[id='Section[" + SecNo + "].Options[0].Options']").dxTextBox("option", "value", QuestionData.Options[0].Options);
                            $("#Section_" + SecNo + "__Options_0__Rec_ID").val(QuestionData.Options[0].Rec_ID)
                            if (QuestionData.Options[0].optionImagePath != null && QuestionData.Options[0].optionImagePath.length > 0)
                            {
                                ImageSettings_createForm("Option", QuestionData.Options[0].optionImagePath, null, null, SecNo, 0);
                                $("#Section_" + SecNo + "__Options_0__OptionImageFileName").val(QuestionData.Options[0].OptionImageFileName);
                            }
                            RefreshDependentQuestionData(false, false)
                            if (QuestionData.Options[0].DependentQuestion != null && QuestionData.Options[0].DependentQuestion.length > 0) {
                                $("div[id='DependentQuestion_" + SecNo + "_0_datagrid']").dxDataGrid("instance").selectRows(QuestionData.Options[0].DependentQuestion.split(',').map((i) => Number(i) - 1));
                                $("div[id='Section[" + SecNo + "].Options[0].DependentQuestionVisibility']").dxSelectBox("option", "value", QuestionData.Options[0].DependentQuestionVisibility);
                            }
                            $("div[id='Section[" + SecNo + "].Options[0].Points']").dxNumberBox("option", "value", QuestionData.Options[0].Points);
                            if (QuestionData.Options.length > 1) {
                                for (var i = 1; i < QuestionData.Options.length; i++) {
                                    var MultiOptionhtmlData = await multipleOptionAjaxCall_createForm(SecNo, Mode, (i), Purpose);
                                    appendMultipleOption_createForm(MultiOptionhtmlData, SecNo, (i), QuestionData.Options[i]);
                                }
                            }
                        }
                        if (QuestionData.IsOptionsPredefined == true)
                        {
                            $("div[id='Section[" + SecNo + "].OptionPredefinedMiscID']").dxSelectBox("instance").option("value", QuestionData.OptionPredefinedMiscID);
                        }
                    }
                }
                else
                {
                    RefreshDependentQuestionData();
                    $("div[id='Section[" + SecNo + "].Options[0].Options']").find('input').focus();
                }
            }
            else if (QuestionData != null)
            {
                if (Mode == "Number") {
                    $("div[id='Section[" + SecNo + "].Type']").dxSelectBox("option", "value", QuestionData.Type);
                    $("div[id='Section[" + SecNo + "].Min']").dxNumberBox("option", "value", QuestionData.Min);
                    $("div[id='Section[" + SecNo + "].Max']").dxNumberBox("option", "value", QuestionData.Max);
                }
                else if (Mode == "Slider")
                {
                    $("div[id='Section[" + SecNo + "].Min']").dxNumberBox("option", "value", QuestionData.Min);
                    $("div[id='Section[" + SecNo + "].Max']").dxNumberBox("option", "value", QuestionData.Max);
                }
                else if (Mode == "Date" || Mode == "Time") {
                    if (QuestionData.MaxDateTime!=null && QuestionData.MaxDateTime.length > 0) {
                        var ticks = QuestionData.MaxDateTime.split(/[()]/)[1];
                        var dt = JS_Json_DateToMomentDate(parseInt(ticks));
                        $("div[id='Section[" + SecNo + "].MaxDateTime']").dxDateBox("option", "value", dt);
                    }
                    if (QuestionData.MinDateTime != null && QuestionData.MinDateTime.length > 0) {
                        var ticks = QuestionData.MinDateTime.split(/[()]/)[1];
                        var dt = JS_Json_DateToMomentDate(parseInt(ticks));
                        $("div[id='Section[" + SecNo + "].MinDateTime']").dxDateBox("option", "value", dt);
                    }
                }
                else if (Mode == "Paragraph" || Mode == "Short Answer") {

                    $("div[id='Section[" + SecNo + "].MaxLength']").dxNumberBox("option", "value", QuestionData.MaxLength);
                }
                else if (Mode == "Attachment")
                {
                    $("div[id='Section[" + SecNo + "].Type']").dxSelectBox("option", "value", QuestionData.Type);
                }
            }
            else
            {
                $("div[id='Section[" + SecNo + "].Question']").find('input').focus();
            }
            TransformTextForDB("form_createForm");
        }, 100)
    }
