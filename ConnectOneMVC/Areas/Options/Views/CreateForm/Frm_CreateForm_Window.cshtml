    function Fill_AddNotificationData_createForm()
    {
        if (AddNotificationData_createForm == null && NotificationSetting_createForm != null)
        {
            AddNotificationData_createForm = new FormData();
            for (var key in NotificationSetting_createForm)
            {
                if (NotificationSetting_createForm[key] != null)
                {
                    AddNotificationData_createForm.append("NotificationSetting." + key, NotificationSetting_createForm[key]);
                }
            }
            if (AddNotificationData_createForm.has("NotificationSetting.Categories_Notification_Setting_CreateForm") == false)
            {
                AddNotificationData_createForm.append("NotificationSetting.Categories_Notification_Setting_CreateForm", "None");
            }
            if (AddNotificationData_createForm.has("NotificationSetting.AdminEmail_Notification_Setting_CreateForm") == false)
            {
                AddNotificationData_createForm.append("NotificationSetting.AdminEmail_Notification_Setting_CreateForm", "@Model.DefaultAdminEmail_createForm");
