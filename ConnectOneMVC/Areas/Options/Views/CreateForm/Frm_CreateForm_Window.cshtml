        }
        else
        {
            var PreQuesRowNoEle = PrevQues.find(".RowNoClass_createForm");
            if (PreQuesRowNoEle.length > 0)
            {
                var PreQuesRowNo = $(PreQuesRowNoEle[0]).dxNumberBox("option", "value");
                return PreQuesRowNo;
            }
        }
