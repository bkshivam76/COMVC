    function GetNotificationSettingForEdit_createForm()
    {
        if (AddNotificationData_createForm != null)
        {
            var object = {};
            AddNotificationData_createForm.forEach(function (value, key)
            {
                var modifiedKey = key;
                if (key.includes("."))
                {
                    modifiedKey=key.split(".")[1]
                }
                object[modifiedKey] = value;
            });
            return JSON.stringify(object);
        }
        else if (NotificationSetting_createForm != null && Tag_createForm!="_New")
        {
          return JSON.stringify(NotificationSetting_createForm)
        }
        return "";
    }
    function OnlyPlainTextinHtmlEditor_createForm(e)
    {
        //e.clipboard.matchers.push([Node.ELEMENT_NODE, function (node, delta)
        //{
        //    var plaintext = $(node).text();
        //    delta.ops = delta.ops.map(op => {
        //    if (op.insert && typeof op.insert === 'string') {
        //            return {
        //                insert: op.insert
        //            }
        //    }
        //    })
        //    return delta
        //}])
        e.component.getQuillInstance().clipboard.addMatcher(Node.ELEMENT_NODE, (node, delta) => {
            let ops = []
            delta.ops.forEach(op => {
                if (op.insert && typeof op.insert === 'string') {
                    ops.push({
                        insert: op.insert
                    })
                }
            })
            delta.ops = ops
            return delta
        })
    }
    function HtmlEditorActualValue_createForm(htmlEditorID) {
        var htmlValue = $("#" + htmlEditorID).dxHtmlEditor("option", "value")
        return ReplaceVariableHtmlEditor_createForm(htmlValue, VariablesMap_createForm)
    }
    function ReplaceVariableHtmlEditor_createForm(value, variablesMap) {
        if (value == null || value.length == 0)
        {
            return "";
        }
        const DX_VARIABLE_CLASS = 'dx-variable';
        const DATA_VAR_VALUE_ATTR = 'data-var-value';
        const parser = new DOMParser();
        const doc = parser.parseFromString(value, 'text/html');
        const variables = doc.querySelectorAll(`.${DX_VARIABLE_CLASS}`);

        variables.forEach(variable => {
            const variableValue = variablesMap[variable.getAttribute(DATA_VAR_VALUE_ATTR)];
            variable.outerHTML = variableValue;
        });

        let modifedHtml = doc.body.innerHTML.toString();
        for (var key in variablesMap)
        {
            var toReplace = "#" + key + "#";
            modifedHtml = modifedHtml.replaceAll(toReplace, variablesMap[key])
        }
        return modifedHtml;
    }
