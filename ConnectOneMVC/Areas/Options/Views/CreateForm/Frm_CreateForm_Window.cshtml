    function appendQuestion_createForm(htmldata, _secNo, QuestionData=null,Purpose="")
    {
        $('#Section_Sortable_createForm').append(htmldata);
        if ($('#Body_createForm').hasClass("section_createForm") == false)
        {
            $('#Body_createForm').addClass("section_createForm");
        }
        var secNoandoption =
        {
            "secno": _secNo, "options": []
        }
        SecNosandOptions.push(secNoandoption);
        $("#AccDivId_" + _secNo + "_createForm").find('span').text("Question " + (SecNosandOptions.length));
        setTimeout(async function ()
        {
            if (QuestionData != null)
            {
                $("div[id='Section[" + _secNo + "].Question']").dxTextArea("option", "value", QuestionData.Question);
                if (QuestionData.QuestionImagePath != null && QuestionData.QuestionImagePath.length > 0)
                {
                    ImageSettings_createForm("Question", QuestionData.QuestionImagePath, QuestionData.QuestionImageWidth, QuestionData.QuestionImageHeight, _secNo);
                    $("#Section_" + _secNo + "__QuestionImageFileName").val(QuestionData.QuestionImageFileName);
                }
                $("div[id='Section[" + _secNo + "].Description']").dxTextArea("option", "value", QuestionData.Description);
                $("div[id='Section[" + _secNo + "].Required']").dxSwitch("option", "value", QuestionData.Required);
                $("div[id='Section[" + _secNo + "].DefaultVisibility']").dxSwitch("option", "value", QuestionData.DefaultVisibility);
                $("#Section_" + _secNo + "__Rec_ID").val(QuestionData.Rec_ID);
                $("div[id='Section[" + _secNo + "].GroupHeading']").dxSelectBox("option", "items", GroupItems_ceateForm);
                $("div[id='Section[" + _secNo + "].GroupHeading']").dxSelectBox("option", "value", QuestionData.GroupHeading);
                $("div[id='Section[" + _secNo + "].Tag']").dxSelectBox("option", "items", QuestionTags_createForm);
                //$("div[id='Section[" + _secNo + "].Tag']").dxSelectBox("option","valueExpr", "ID");
                //$("div[id='Section[" + _secNo + "].Tag']").dxSelectBox("option","displayExpr", "NAME");
                $("div[id='Section[" + _secNo + "].Tag']").dxSelectBox("option", "value", QuestionData.Tag);
                var AnshtmlData = await appendAnswersAjaxCall_createForm(_secNo, QuestionData.Mode, Purpose);
                appendAnswers_createForm(AnshtmlData, _secNo, QuestionData.Mode, QuestionData,Purpose);
            }
            else
            {
                $("div[id='Section[" + _secNo + "].RowNo']").dxNumberBox("option", "value", (CalculatePrevQuesRowNo(_secNo) + 1));
                $("div[id='Section[" + _secNo + "].GroupHeading']").dxSelectBox("option", "items", GroupItems_ceateForm);
                $("div[id='Section[" + _secNo + "].Tag']").dxSelectBox("option", "items", QuestionTags_createForm);
                //$("div[id='Section[" + _secNo + "].Tag']").dxSelectBox("option","valueExpr", "ID");
                //$("div[id='Section[" + _secNo + "].Tag']").dxSelectBox("option","displayExpr", "NAME");
                RefreshDependentQuestionData()
                document.getElementById("SaveBtn_createForm").scrollIntoView(false);
            }
            TransformTextForDB("form_createForm");
        }, 100)
    }
