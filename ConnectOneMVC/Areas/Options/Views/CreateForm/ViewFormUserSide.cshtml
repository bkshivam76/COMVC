@using DevExtreme.AspNet.Mvc;
@using System.Web.Configuration;
@model ConnectOneMVC.Areas.Options.Models.FormResponses
@{
    string Servicespath = WebConfigurationManager.AppSettings["Servicespath"];
    bool For_C_One_user = (bool)ViewBag.For_C_One_user;
    string url = (string)ViewBag.FormUrl;
    string PopupID = (string)ViewBag.PopupID;
    if (string.IsNullOrWhiteSpace(url))
    {
        url = Servicespath + "form/" + Model.FormInstanceID;
        if (For_C_One_user == true)
        {
            url = url + "?Cone_UserID=" + Model.Connectone_UserID + "&Cone_CenID=" + Model.Connectone_CenID;
        }
    }
}
<style>
    #scrollView_ViewFormUserSidePopup .dx-scrollable-scrollbar {
        display: none
    }

    #scrollView_ViewFormUserSidePopup .dx-scrollable-scrollbars-alwaysvisible.dx-scrollable-vertical > .dx-scrollable-wrapper > .dx-scrollable-container > .dx-scrollable-content {
        padding-right: 0 !important;
    }
</style>
<iframe style="width:100%;height:calc(100vh - 110px)" frameborder="0" allow="geolocation *" id="ViewFormUserSide_iframe"></iframe>
<script>
$(function()
{
      $("#"+"@PopupID").dxPopup({
          onHiding: function (e)
          {
              $("#ViewFormUserSide_iframe").attr('src', "");
              $("#ViewFormUserSide_iframe").remove();
              if ("@Model.ActionMethod" != "_View") {
                  var _ActiveTab_ID = $(".TabPanalMenu-tabs .active").attr("id");
                  if (_ActiveTab_ID == "contact_Frm_Chart_Info") {
                      RefreshGridView("ChartInfoGrid")
                      if ($("#ChartResponsesInfoGrid").length > 0)
                      {
                          RefreshGridView("ChartResponsesInfoGrid")
                      }
                  }
                  if (_ActiveTab_ID == "contact_Frm_Service_Project_Info") {
                      RefreshGridView("ServiceProjectListGrid")
                  }
              }
              if ($("#ServiceProjectMappedSubjectListGrid").length > 0) {
                  RefreshGridView("ServiceProjectMappedSubjectListGrid")
              }
          }
      });
    var iframeSrc = "@url".replace(/\&amp;/gi, '&');
    $("#ViewFormUserSide_iframe").attr('src',iframeSrc);
})

</script>