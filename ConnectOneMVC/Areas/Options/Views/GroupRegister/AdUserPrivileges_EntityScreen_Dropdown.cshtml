@using DevExtreme.AspNet.Mvc;
@{ 

}
@(Html.DevExtreme().DataGrid().CustomDataGrid()
            .ID("AdUserPrivileges_EntityScreen_DataGrid")

            .Columns(columns =>
            {
                columns.Add().DataField("TaskName").Caption("Task Enum Name").Visible(false);
                columns.Add().DataField("TaskDisplayName").Caption("Task Name").Visible(true);
                columns.Add().DataField("TaskID").Caption("ID").Visible(false);
            })

            .Selection(s => s.Mode(Model == "New" ? SelectionMode.Multiple : SelectionMode.Single))
)
