    @*Dev Extreme*@
    @*variables*@
    <script>
        var GroupRegister_ManagPrivileges_Grid_dx = null;
    </script>
    @*General fns*@
    <script>     
        function ManagPrivileges_UpdateFooterDetail(AddedBy, addedOn, ScreenID, editedOn, EditedBy) {
            debugger;
            var AddedOn = new Date(addedOn); var EditedOn = new Date(editedOn);
            var addedonmonth = AddedOn.getMonth();
            addedonmonth = addedonmonth + 1;
            var editedonmonth = EditedOn.getMonth();
            editedonmonth = editedonmonth + 1;
            AddedOn = AddedOn.getDate() + "-" + addedonmonth + "-" + AddedOn.getFullYear() + " " + AddedOn.getHours() + ":" + AddedOn.getMinutes() + ":" + AddedOn.getSeconds();
            EditedOn = EditedOn.getDate() + "-" + editedonmonth + "-" + EditedOn.getFullYear() + " " + EditedOn.getHours() + ":" + EditedOn.getMinutes() + ":" + EditedOn.getSeconds();
            var Lbl_Create = "";
            var Lbl_Modify = "";

            if (AddedOn) {
                Lbl_Create = "Add On: " + AddedOn + ", Add By: " + AddedBy;
            }
            else {
                Lbl_Create = "Add On: " + "?, Add By: " + AddedBy;
            }

            if (EditedOn) {
                Lbl_Modify = "Edit On: " + EditedOn + ", Edit By: " + EditedBy;
            }
            else {
                Lbl_Modify = "Edit On: " + "?, Edit By: " + EditedBy;
            }

            $('#ManagPrivilegesLbl_Add').text(Lbl_Create);
            $('#ManagPrivilegesLbl_Edit').text(Lbl_Modify);
        }
</script>
    @*grid fns*@
<script>

        function GroupRegister_ManagPrivileges_Grid_dx_OnInitialized(e) {
            DxGrid_AdjustSize(e.component, $("#Frm_ManagPrivileges_Window_Content .report_button_div"))
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                DxGrid_AdjustSize(e.component, $("#Frm_ManagPrivileges_Window_Content .report_button_div"), "", evt)
            });
            GroupRegister_ManagPrivileges_Grid_dx = e.component;
        }
        function GroupRegister_ManagPrivileges_Grid_dx_OnContentReady(e) {
            DxGrid_OnContentReady(e);
        }
    function GroupRegister_ManagPrivileges_Grid_dx_OnCellDblClick(e) {
        if (e.rowType == "data") {
            if (e.rowType == "data") {
                if (ManPriScreenID) {
                    ManagPrivilegesEditClick();
                }
                else {
                    DevExpress.ui.dialog.alert('Please Select One Row', 'Alert');
                }
            }
        }
        }
        function GroupRegister_ManagPrivileges_Grid_dx_OnSelectionChanged(e) {
            var selectedRowKeys = e.selectedRowKeys;
            if (selectedRowKeys != null && selectedRowKeys.length > 0) {
                GroupRegister_ManagPrivileges_Grid_dx_SelectedRowData(e.selectedRowsData);
            }
            else {
                ManPriPrivilegeID = null;
                ManagPrivileges_UpdateFooterDetail(ManPriAddedBy, ManPriAddedOn, ManPriScreenID, ManPriEditedOn, ManPriEditedBy);
            }

        }
        function GroupRegister_ManagPrivileges_Grid_dx_SelectedRowData(selectedData = null) {
            if (selectedData == null) {
                selectedData = UserRegisterListGrid_dx.getSelectedRowsData();
            }
            if (selectedData != null && selectedData.length > 0) {
                var values = selectedData[0]
                ManPriUserName = values["UserName"];
                ManPriGroupName = values["GroupName"];
                ManPriEntityName = values["EntityName"];
                ManPriPrivilegesGiven = values["PrivilegesGiven"];
                ManPriPrivilegeID = values["PrivilegeID"];
                ManPriAddedBy = values["AddedBy"];
