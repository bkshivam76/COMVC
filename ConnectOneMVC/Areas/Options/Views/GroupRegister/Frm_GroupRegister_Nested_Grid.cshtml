@{ 
    var SessionGUID = Request.QueryString["SessionGUID"];
}
@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "GroupRegisterNestedGrid" + ViewData["Datafor_ID"];
        settings.SettingsDetail.MasterGridName = "GroupRegisterListGrid";
        settings.CallbackRouteValues = new
        {
            Controller = "GroupRegister",
            Action = "Frm_GroupRegister_Nested_Grid",
            ID = ViewData["GroupRegister_ExpandedGroupID"],
            SessionGUID = SessionGUID
        };

        settings.KeyFieldName = "ID";

        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "UserName";
                column.Caption = "User Name";
                //column.Width = 300;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Personnel_Name";
                column.Caption = "Personnel Name";
                //column.Width = 300;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Sewa_Dept";
                column.Caption = "Sewa Dept";
                //column.Width = 300;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "SkillTypes";
                column.Caption = "Skill Type";
                //column.Width = 300;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "UserType";
                column.Caption = "User Type";//Mantis bug 0001088 fixed
                //column.Width = 300;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "ID";
                column.Caption = "ID";
                //column.Width = 300;
                column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "GroupID";
                column.Caption = "GroupID";
                //column.Width = 100;
                column.Visible = false;
            }
        });
        //This is called when the detail grid opens. 
        settings.Init = (s, e) =>
        {
            MVCxGridView grid = (MVCxGridView)s;
            grid.FocusedRowIndex = -1; // setting -1 means no row is focused in the detail grid.
        };
        settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
        settings.SettingsResizing.ColumnResizeMode = DevExpress.Web.ColumnResizeMode.Control;
        settings.SettingsResizing.Visualization = DevExpress.Web.ResizingMode.Live;
        settings.SettingsBehavior.AllowSelectSingleRowOnly = false;
        settings.SettingsBehavior.AllowFocusedRow = true;
        settings.SettingsCustomizationDialog.ShowColumnChooserPage = true;
        settings.ClientSideEvents.FocusedRowChanged = "GroupRegisterNestedGridFocusedRowChanged";
        settings.ClientSideEvents.BeginCallback = "GroupRegisterNestedGrid_BeginCallBack";
        settings.CustomDataActionRouteValues = new { Controller = "GroupRegister", Action = "GroupRegisterNestedCustomDataAction" };
        MyExtensions.GridViewHelper.CustomGridView(settings);

    }).Bind(Model).GetHtml()
