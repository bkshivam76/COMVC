@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];

}
@(Html.DevExtreme().DataGrid().CustomDataGridListing(0)
                 .ID("GroupRegister_ManagPrivileges_Grid_dx")
                 .DataSource(d => d.Mvc().Controller("GroupRegister")
                 .LoadAction("Frm_ManagPrivileges_Grid_dx").LoadMode(DataSourceLoadMode.Raw)
                 .OnBeforeSend("GroupRegister_ManagPrivileges_Grid_dx_OnBeforeSend").Key("PrivilegeID"))
                 .Columns(columns =>
                 {
                     columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);//Bug #137209 Fix

                     columns.Add().DataField("UserName").Caption("UserName").MinWidth(300);
                     columns.Add().DataField("GroupName").Caption("Group Name").MinWidth(300);
                     columns.Add().DataField("EntityName").Caption("Entity/Screen").MinWidth(300);
                     columns.Add().DataField("PrivilegesGiven").Caption("Privileges").MinWidth(300);

                     columns.Add().DataField("AddedBy").Caption("Add By").Visible(false).MinWidth(120);
                     columns.Add().DataField("AddedOn").Caption("Add On").Visible(false).MinWidth(120);
                     columns.Add().DataField("EditedBy").Caption("Edit By").Visible(false).MinWidth(120);
                     columns.Add().DataField("EditedOn").Caption("Edit Date").Visible(false).MinWidth(120);
                     columns.Add().DataField("ScreenID").Caption("ScreenID").Visible(false).MinWidth(120);
                     columns.Add().DataField("PrivilegeID").Caption("PrivilegeID").Visible(false).MinWidth(100);
                     columns.Add().DataField("GrpID").Caption("GroupID").Visible(false).MinWidth(100);

                 })              
.OnInitialized("GroupRegister_ManagPrivileges_Grid_dx_OnInitialized")
.OnContentReady("GroupRegister_ManagPrivileges_Grid_dx_OnContentReady")
.OnCellDblClick("GroupRegister_ManagPrivileges_Grid_dx_OnCellDblClick")
.OnSelectionChanged("GroupRegister_ManagPrivileges_Grid_dx_OnSelectionChanged")
.OnContextMenuPreparing("GroupRegister_ManagPrivileges_Grid_dx_OnContextMenuPreparing")
)