@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
            .ID("User_DataGrid")           
            .Columns(columns =>
            {
                columns.Add().DataField("UserName").Caption("User Name");
                columns.Add().DataField("PersonnelName").Caption("Name");
                columns.Add().DataField("SewaDept").Caption("Sewa Dept");
                columns.Add().DataField("SkillTypes").Caption("Skill");
                columns.Add().DataField("UserType").Caption("UserType").Visible(true);
                columns.Add().DataField("ID").Caption("ID").Visible(false);
            })
          
            .Selection(s => s.Mode(SelectionMode.Single))
          
)
