@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                .ID("ManPri_User_DataGrid")              
                .Columns(columns =>
                {
                    columns.Add().DataField("UserName").Caption("User Name");
                    columns.Add().DataField("PersonnelName").Caption("Name");
                    columns.Add().DataField("SewaDept").Caption("Dept");
                    columns.Add().DataField("UserSkills").Caption("Skill").Visible(true);
                    columns.Add().DataField("UserType").Caption("UserType");                    
                    columns.Add().DataField("ID").Caption("ID").Visible(false);
                })

           
                .Selection(s => s.Mode(SelectionMode.Single))
                
)
