    <form class="edit_form form-horizontal">
        <div class="report_header_div_main">
            <div id="UserPreferences_content" class="col-md-12 report_header_div_main">
                <div class="col-md-4 padd report_header_div">
                    <label class="report_header_label">User Preferences</label>
                </div>
                <div class="report_button_div">
                    @(Html.DevExtreme().Button().CustomSaveButton().ID("UserPreferences_Save").Text("Save").OnClick(@<text> function () { SubmitUserPreferences(); } </text>) )
                    @(Html.DevExtreme().Button().CustomCloseButton().ID("UserPreferences_Close").Text("Cancel").OnClick(@<text> function (){CloseUserPreferences();} </text>) )
                </div>
            </div>
        </div>@*Header*@
        <div class="row">
            @(Html.DevExtreme().TabPanel().ID("UserPreferences_Gridpanel").Items(items =>
        {
            items.Add().Title("Login").Template(@<text> @LoginView() </text>);
            items.Add().Title("Accounting").Template(@<text> @AccountingView() </text>);
            items.Add().Title("Data View").Template(@<text> @DataView_View() </text>);
            }).DeferRendering(false))
            @helper LoginView()
            {
                @Html.Partial("Frm_SelectScreen");
            }
            @helper AccountingView()
            {
                <div class="row">
                    <div class="col-md-12">
                        <div class="form-field">
                            <div class="container-fluid">
                                @Html.Label("Display Party Type:", htmlAttributes: new { @class = "control-label" })
                                @(Html.DevExtreme().RadioGroup().ID("Rad_Acc_Party_UserPreferences").Name("Rad_Acc_Party_UserPreferences").DisplayExpr("text").Layout(DevExtreme.AspNet.Mvc.Orientation.Horizontal).ValueExpr("value").DataSource(new object[] { new { text = "Accounting", value = 0 }, new { text = "Non-Accounting", value = 1},new {text="All",value=2 } }).Value((int)ViewBag.Rad_Acc_Party) )
                            </div>
                        </div>
                        <div class="form-field">
                            <div class="container-fluid">
                                @Html.Label("Show Vouching Indicators:", htmlAttributes: new { @class = "control-label" })
                                @(Html.DevExtreme().RadioGroup().ID("Rad_VouchingIndicator_UserPreferences").Name("Rad_VouchingIndicator_UserPreferences").DisplayExpr("text").Layout(DevExtreme.AspNet.Mvc.Orientation.Horizontal).ValueExpr("value").DataSource(new object[] { new { text = "Yes", value = true }, new { text = "No", value = false}}).Value((bool)ViewBag.Rad_VouchingIndicator) )
                            </div>
                        </div>
                        <div class="form-field">
                            <div class="container-fluid">
                                @Html.Label("Show Attachment Indicators:", htmlAttributes: new { @class = "control-label" })
                                @(Html.DevExtreme().RadioGroup().ID("Rad_AttachmentIndicator_UserPreferences").Name("Rad_AttachmentIndicator_UserPreferences").DisplayExpr("text").Layout(DevExtreme.AspNet.Mvc.Orientation.Horizontal).ValueExpr("value").DataSource(new object[] { new { text = "Yes", value = true }, new { text = "No", value = false} }).Value((bool)ViewBag.Rad_AttachmentIndicator) )
                            </div>
                        </div>
                    </div>
                </div>
            }
            @helper DataView_View()
            {
                @Html.Partial("Frm_Select_DataView_Screen");// change partial view
            }
        </div>@*Tabs*@
    </form>

