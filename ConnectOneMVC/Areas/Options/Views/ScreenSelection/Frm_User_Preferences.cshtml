    <script>
        var ScreenIds_UserPreferences = [];
        function SubmitUserPreferences() {
            ShowLoader();
            var Rad_Acc_Party = $("#Rad_Acc_Party_UserPreferences").dxRadioGroup("instance").option("value");
            var Rad_VouchingIndicator = $("#Rad_VouchingIndicator_UserPreferences").dxRadioGroup("instance").option("value");
            var Rad_AttachmentIndicator = $("#Rad_AttachmentIndicator_UserPreferences").dxRadioGroup("instance").option("value");
            var Rad_DeviceType = $("#Rad_DeviceType_DataView").dxRadioGroup("instance").option("value");
            CalculateScreenIDs_UserPreference();
            $.ajax({
                type: 'POST',
                url: "/Options/ScreenSelection/But_Save_Click",
                data:
                {
                    Rad_Acc_Party: Rad_Acc_Party,
                    VouchingIndicator: Rad_VouchingIndicator,
                    AttachmentIndicator: Rad_AttachmentIndicator,
                    ScreenIDs: ScreenIds_UserPreferences,
                    DeviceType: Rad_DeviceType,
                    ScreenIDs_Mobile: ChosenScreenDataSource_Mobile,
                    ScreenIDs_Desktop: ChosenScreenDataSource_Desktop
                },
                cache: false,
                success: function (data) {
                    dontaskpopupcloseconfirmation = true;
                    HideLoader();
                    if (data.jsonParam.result == false) {
                        if (data.jsonParam.closeform) {
                            $("#Dynamic_Content_popup").dxPopup("hide");
                        }
                        var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                        alertclick.done(function (alertResult) {
                            if (alertResult) {
                                if (data.jsonParam.focusid) {
                                    var id = "#" + data.jsonParam.focusid;
                                    setTimeout(function () {
                                        $(id).find('input').focus();
                                    }, Timeout100);
                                }
                            }
                        });
                    }
                    else if (data.jsonParam.result == true) {
                        var saveAlertClick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                        $("#Dynamic_Content_popup").dxPopup("hide");
                    }
                }
            });
        }
        function CloseUserPreferences() {
            HidePopup("Dynamic_Content_popup");
        }
        function CalculateScreenIDs_UserPreference() {
            ScreenIds_UserPreferences = [];
            if (ChosenScreenDataSource_UserPreference != null && ChosenScreenDataSource_UserPreference.length > 0) {
                for (var i = 0; i < ChosenScreenDataSource_UserPreference.length; i++) {
                    ScreenIds_UserPreferences.push(ChosenScreenDataSource_UserPreference[i].ScreenID);
                }
            }
        }
    </script> @*Save_Function*@

    <script>
    $(document).ready(function ()
    {
        ShowLoader();
        dontaskpopupcloseconfirmation = false;

        var ScreenIDs = @Html.Raw(Json.Encode(AutoOpenScreenIDs));
        if (ScreenIDs != null && ScreenIDs.length > 0)
        {
            for (var i = 0; i < ScreenIDs.length; i++)
            {
                if (ScreenIDs[i] != null && ScreenIDs[i].length > 0)
                {
                    let data = AvailScreenDataSource_UserPreference.find(x => x.ScreenID === ScreenIDs[i]);
                    var index = AvailScreenDataSource_UserPreference.findIndex(x => x.ScreenID === ScreenIDs[i]);
                    if (index > -1) {
                        ChosenScreenDataSource_UserPreference.push(data);
                        AvailScreenDataSource_UserPreference.splice(index, 1);
                    }
                }
            }
        }
        createList("#AvailableScreenList", AvailScreenDataSource_UserPreference);
        createList("#ChosenScreenList", ChosenScreenDataSource_UserPreference);

        // Array Initialization for DataSource

        AvailScreenDataSource_Desktop = @Html.Raw(Json.Encode(Model.AllVisibleScreensList));
        AvailScreenDataSource_Mobile = @Html.Raw(Json.Encode(Model.AllVisibleScreensList));
        ChosenScreenDataSource_Desktop = @Html.Raw(Json.Encode(Model.SelectedScreensList_Desktop));
        ChosenScreenDataSource_Mobile = @Html.Raw(Json.Encode(Model.SelectedScreensList_Mobile));

        // Remove Selected screens from Available Screens [Desktop]

        if (ChosenScreenDataSource_Desktop != null && ChosenScreenDataSource_Desktop.length > 0) {
            for (var i = 0; i < ChosenScreenDataSource_Desktop.length; i++) {
                if (ChosenScreenDataSource_Desktop[i].ScreenID != null && ChosenScreenDataSource_Desktop[i].ScreenID.length > 0) {
                    var index = AvailScreenDataSource_Desktop.findIndex(x => x.ScreenID === ChosenScreenDataSource_Desktop[i].ScreenID);
                    AvailScreenDataSource_Desktop.splice(index, 1);
                }
            }
        }

        // Remove Selected screens from Available Screens [Mobile]

        if (ChosenScreenDataSource_Mobile != null && ChosenScreenDataSource_Mobile.length > 0) {
            for (var i = 0; i < ChosenScreenDataSource_Mobile.length; i++) {
                if (ChosenScreenDataSource_Mobile[i].ScreenID != null && ChosenScreenDataSource_Mobile[i].ScreenID.length > 0) {
                    var index = AvailScreenDataSource_Mobile.findIndex(x => x.ScreenID === ChosenScreenDataSource_Mobile[i].ScreenID);
                    AvailScreenDataSource_Mobile.splice(index, 1);
                }
            }
        }

        console.log(AvailScreenDataSource_UserPreference);
        console.log(AvailScreenDataSource_Desktop);
        console.log(AvailScreenDataSource_Mobile);
        console.log(ChosenScreenDataSource_Desktop);
        console.log(ChosenScreenDataSource_Mobile);

        $("#Rad_DeviceType_DataView").dxRadioGroup("instance").option("value","Desktop_Tablet");

        createList_DataView("#AvailableScreenList_Desktop", AvailScreenDataSource_Desktop);
        createList_DataView("#ChosenScreenList_Desktop", ChosenScreenDataSource_Desktop);

        createList_DataView("#AvailableScreenList_Mobile", AvailScreenDataSource_Mobile);
        createList_DataView("#ChosenScreenList_Mobile", ChosenScreenDataSource_Mobile);

        HideLoader();
    });

    </script> @*Document_Ready*@

    <script>
        function createList(selector, tasks) {
            var list = $(selector).dxList({
                dataSource: tasks,
                //repaintChangesOnly: true,
                keyExpr: "id",
                itemTemplate: function (data, _, element) {
                    element.append(
                        $("<p>").text(data.name).css("margin", 0)
                    )
                },
                searchEnabled: true,
                searchExpr: "name",
                scrollingEnabled: true,
                pageLoadMode: "scrollBottom",
                showScrollbar: "onHover",
                height: 450,
                selectionMode: "all",
                showSelectionControls: true,
                selectAllMode: "allPages",
                itemDragging: {
                    allowReordering: selector == "#ChosenScreenList" ? true : false,
                    handle: ".dx-item.dx-list-item",
                    group: "tasks",
                    onDragStart: function (e) {
                        e.itemData = tasks[e.fromIndex];
                    },
                    onAdd: function (e) {
                        tasks.splice(e.toIndex, 0, e.itemData);
                        list.option("dataSource", tasks);

                    },
                    onRemove: function (e) {
                        tasks.splice(e.fromIndex, 1);
                        list.option("dataSource", tasks);

                    }
                }
            }).dxList("instance");
        }
    </script> @*Create_List_Auto_Open_Screens*@

    <script>
        function createList_DataView(selector, tasks) {
            
            var list = $(selector).dxList({
                dataSource: tasks,
                //repaintChangesOnly: true,
                displayExpr: "DisplayName",
                keyExpr: "ScreenID",
                itemTemplate: function (data, _, element) {
                    element.append(
                        $("<p>").text(data.DisplayName).css("margin", 0)
                    )
                },
                searchEnabled: true,
                searchExpr: "DisplayName",
                scrollingEnabled: true,
                pageLoadMode: "scrollBottom",
                showScrollbar: "onHover",
                height: 450,
                selectionMode: "all",
                showSelectionControls: true,
                selectAllMode: "allPages",
                itemDragging: {
                    allowReordering: selector == "#ChosenScreenList_FullDataView" ? true : false,
                    handle: ".dx-item.dx-list-item",
                    group: "tasks",
                    onDragStart: function (e) {
                        e.itemData = tasks[e.fromIndex];
                    },
                    onAdd: function (e) {
                        tasks.splice(e.toIndex, 0, e.itemData);
                        list.option("dataSource", tasks);

                    },
                    onRemove: function (e) {
                        tasks.splice(e.fromIndex, 1);
                        list.option("dataSource", tasks);

                    }
                }
            }).dxList("instance");
        }
    </script> @*Create_List_DataView*@

    <script>
        function MoveToChosenClick() {
            var SelectedFromAvailable = $("#AvailableScreenList").dxList("instance").option("selectedItemKeys");
            if (SelectedFromAvailable == null || SelectedFromAvailable.length == 0) {
                DevExpress.ui.dialog.alert("No Screen Selected From Available Screen List To Move To Chosen Screen List..", "Info..");
                return;
            }
            ShowLoader();
            for (var i = 0; i < SelectedFromAvailable.length; i++) {
                if (SelectedFromAvailable[i] != null) {
                    let data = AvailScreenDataSource_UserPreference.find(x => x.id === SelectedFromAvailable[i]);
                    var index = AvailScreenDataSource_UserPreference.findIndex(x => x.id === SelectedFromAvailable[i]);
                    if (index > -1) {
                        ChosenScreenDataSource_UserPreference.push(data);
                        AvailScreenDataSource_UserPreference.splice(index, 1);
                    }
                }
            }
            Promise.all([$("#ChosenScreenList").dxList("instance").reload(), $("#AvailableScreenList").dxList("instance").reload()]).then((r) => {
                HideLoader();
            });
        }
        function MoveToAvailableClick() {
            var SelectedFromChosen = $("#ChosenScreenList").dxList("instance").option("selectedItemKeys");
            if (SelectedFromChosen == null || SelectedFromChosen.length == 0) {
                DevExpress.ui.dialog.alert("No Screen Selected From Chosen Screen List To Move To Available Screen List..", "Info..");
                return;
            }
            ShowLoader();
            for (var i = 0; i < SelectedFromChosen.length; i++) {
                if (SelectedFromChosen[i] != null) {
                    let data = ChosenScreenDataSource_UserPreference.find(x => x.id === SelectedFromChosen[i]);
                    var index = ChosenScreenDataSource_UserPreference.findIndex(x => x.id === SelectedFromChosen[i]);
                    if (index > -1) {
                        AvailScreenDataSource_UserPreference.push(data);
                        ChosenScreenDataSource_UserPreference.splice(index, 1);

                    }
                }
            }
            AvailScreenDataSource_UserPreference.sort(function (a, b) { return a.id - b.id });
            Promise.all([$("#ChosenScreenList").dxList("instance").reload(), $("#AvailableScreenList").dxList("instance").reload()]).then((r) => {
                HideLoader();
            });

        }

    </script> @*Button_Functions_For_Auto_Open_Screens*@

