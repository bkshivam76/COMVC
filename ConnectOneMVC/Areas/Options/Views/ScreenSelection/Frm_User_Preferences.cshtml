    <script>
        function DeviceType_ValueChange(e) {

            if (e.value == "Desktop_Tablet") {

                $("#AvailableScreenList_Mobile").hide();
                $("#ChosenScreenList_Mobile").hide();
                $("#Btn_MovetoAvailable_Mobile").dxButton("instance").option("visible", false);
                $("#Btn_MovetoChosen_Mobile").dxButton("instance").option("visible", false);
                $("#AvailableScreenList_Desktop").show();
                $("#ChosenScreenList_Desktop").show();
                $("#Btn_MovetoAvailable_Desktop").dxButton("instance").option("visible", true);
                $("#Btn_MovetoChosen_Desktop").dxButton("instance").option("visible", true);

            }
            if (e.value == "Mobile") {

                $("#AvailableScreenList_Desktop").hide();
                $("#ChosenScreenList_Desktop").hide();
                $("#Btn_MovetoAvailable_Desktop").dxButton("instance").option("visible", false);
                $("#Btn_MovetoChosen_Desktop").dxButton("instance").option("visible", false);
                $("#AvailableScreenList_Mobile").show();
                $("#ChosenScreenList_Mobile").show();
                $("#Btn_MovetoAvailable_Mobile").dxButton("instance").option("visible", true);
                $("#Btn_MovetoChosen_Mobile").dxButton("instance").option("visible", true);
            }
        }
