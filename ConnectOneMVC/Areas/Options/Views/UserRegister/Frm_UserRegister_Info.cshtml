<script type="text/javascript">
    var UserRegister_ShowHorizontalBar = 0;
    var UserRegisterEditright;
    var UserRegisterNewright;
    var UserRegisterDeleteright;
    var UserRegisterViewright;
    var UserRegisterExportright;
    var Groupsusagecountcheck;
    var PersonnelNewright;
    var GroupRegisterNewright;
    var UserGridFocusedIndex;
    var isUserregisterGridRefresh = false;

    $(document).ready(function () {

        IsSucessPopup = false;
        IsViewPopup = false;
        IsSucesscPopup = false;
        IsViewcPopup = false;

        UserRegisterNewright = "@UserReg_AddRight" == "True" ? true : false;
        UserRegisterEditright = "@UserReg_UpdateRight" == "True" ? true : false;
        UserRegisterViewright = "@UserReg_ViewRight" == "True" ? true : false;
        UserRegisterDeleteright = "@UserReg_DeleteRight" == "True" ? true : false;
        UserRegisterExportright = "@UserReg_ExportRight" == "True" ? true : false;
        PersonnelNewright = "@UserReg_AddPersonnelRight" == "True" ? true : false;
        GroupRegisterNewright = "@UserReg_AddGroupRight" == "True" ? true : false;

        if (UserRegisterNewright != true)
        {
            $("#UserRegisterNew").hide();
        }
        if (UserRegisterEditright != true)
        {
            $("#UserRegisterEdit").hide();
            $("#UserRegisterChangepw").hide();
            $("#UserRegisterAdUsrGrp").hide();

        }
        if ("@UserReg_MngPrivilegeRight" == "False") {
            $("#UserRegisterManagPrivileges").hide();
        }
        if ("@UserReg_AddPrivilegeRight" == "False") {
            $("#UserRegisterAddPrivileges").hide();
        }

        if (UserRegisterViewright != true)
        {
            $("#UserRegisterView").hide();
        }
        if (UserRegisterDeleteright != true)
        {
            $("#UserRegisterDelete").hide();
        }
        if (UserRegisterExportright != true)
        {
            $("#UserRegisterListPreview").hide();
        }
    });

    $(".TabPanalMenu-tabs .active span").on("click", function () {
        $.ajax({
            type: 'GET',
            url: "/Options/UserRegister/SessionClear",
            cache: false
        });
        ClearAllReferences_UserRegisterOptions();

    });
        function ClearAllReferences_UserRegisterOptions() {
            Groupsusagecountcheck = null;
            PersonnelNewright = null;
            GroupRegisterNewright = null;
            UserGridFocusedIndex = null;
            isUserregisterGridRefresh = null;
            UserName = null;
            PersonnelName = null;
            SewaDept = null;
            ContactNo = null;
            EmailID = null;
            Groups = null;
            Is_Admin = null;
            AddedBy = null;
            AddedOn = null;
            EditedBy = null;
            EditedOn = null;
            UserID = null;
            UserRegister_Privileg_GroupID = null;

            ClearAllReferences("UserRegisterOptions_ClearReferences");
        }

    function UserRegister_ChangePassword() {
        if (!UserRegisterEditright) { DevExpress.ui.dialog.alert('Not Allowed', 'No Rights'); return; }
        if (!UserID) { DevExpress.ui.dialog.alert('Please Select any user', 'Alert'); return; }
        if ($("#ChangePasswordvalidationForm").length > 0) {
            $("#ChangePasswordvalidationForm").remove();
        }
        ShowLoader();
        OpenDynamicPopup("Change Password", "@Url.Action("Frm_Chg_Password", "ChangePassword", new { @area = "Options" })?User_Name=" + encodeURI(UserName), "auto", "500", false, null);
        HideLoader();
    }//Change Password button

    function UserRegister_ResetPassword() {

        if (!UserRegisterEditright) {
            DevExpress.ui.dialog.alert('Not Allowed', 'No Rights');
            return;
        }
        ShowLoader();
        if (!UserID) {
            DevExpress.ui.dialog.alert('Please Select any user', 'Alert');
            HideLoader();
            return;
        }
        else {
            var result;
            result = DevExpress.ui.dialog.confirm('Are you sure you want to Reset Password of this User?', "Confirm");
           result.done(function (dialogResult) {
               if (dialogResult) {

                    $.ajax({
                        type: 'GET',
                        url: "/Options/UserRegister/ResetPassword",
                        data: { userid: UserID, user_name: UserName},
                        cache: false,
                        success: function (PasswordReset_result)
                        {
                            /*$('#UserRegisterResetpw').hide();*/
                            DevExpress.ui.dialog.alert(PasswordReset_result.message, 'Reset Password');
                            HideLoader();
                        }
                    });
                }
                else {

                }
            });
        }

        HideLoader();
    }//Reset Password button

    function UserRegisterOnInit(s, e) {
        UserRegister_MasterAdjustSize(s, e);
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            UserRegister_MasterAdjustSize(s, e);
        });
        s.SetFocusedRowIndex(-1);
    }

    function UserRegisterGrid_EndCallback(s, e) {
        //UserRegister_MasterAdjustSize(s, e);
        SendCustomArgs_FilterControl(s, e);
        if (isUserregisterGridRefresh)
        {
            isUserregisterGridRefresh = false;
            s.SetFocusedRowIndex(-1);
            s.SetFocusedRowIndex(UserGridFocusedIndex);
        }
    }

    function UserRegister_MasterAdjustSize(s, e) {
        var height = (document.documentElement.clientHeight * 90) / 100;
        s.SetHeight(height);
    }

    function UserRegisterGridFocusedRowChanged(s, e) {

        if (s.GetFocusedRowIndex() == -1) {
            UserID = null;

        }
        else {
            var key = s.GetRowKey(s.GetFocusedRowIndex());
               s.GetValuesOnCustomCallback({ key: key }, UserRegisterOnGetRowValues);

        }

    }

   var UserName;
   var PersonnelName;
   var SewaDept;
   var ContactNo;
   var EmailID;
   var Groups;
   var Is_Admin;
   var AddedBy;
   var AddedOn;
   var EditedBy;
   var EditedOn;
   var UserID ;
    function UserRegisterOnGetRowValues(FDData) {

        FullData = FDData;

        var values = FDData.split("![");
        UserName = values[0];
        PersonnelName = values[1];
        SewaDept = values[2];
        ContactNo = values[3];
        EmailID = values[4];
        Groups = values[5];
        Is_Admin = values[6];
        AddedBy = values[7];
        AddedOn = values[8];
        EditedBy = values[9];
        EditedOn = values[10];
        UserID = values[11];
        UserRegister_UpdateFooterDetail(AddedBy, AddedOn, UserID, EditedOn, EditedBy);
    }


    function UserRegister_UpdateFooterDetail(AddedBy, AddedOn, ID, EditedOn, EditedBy) {
        var Lbl_Create = "";
        var Lbl_Modify = "";

        if (AddedOn) {
            Lbl_Create = "Add On: " + AddedOn + ", Add By: " + AddedBy;
        }
        else {
            Lbl_Create = "Add On: " + "?, Add By: " + AddedBy;
        }

        if (EditedOn) {
            Lbl_Modify = "Edit On: " + EditedOn + ", Edit By: " + EditedBy;
        }
        else {
            Lbl_Modify = "Edit On: " + "?, Edit By: " + EditedBy;
        }

        $('#UserRegisterLbl_Create').text(Lbl_Create);
        $('#UserRegisterLbl_Modify').text(Lbl_Modify);
    }


    function UserRegisterdblclickEdit(s, e) {
        if (UserID) {
            OnUserRegisterEditClick();
        }
        else {
            DevExpress.ui.dialog.alert('Please Select any user', 'Alert');
        }
    }
    function UserRegisterContextMenuFunction(s, e) {
        if (e.item.name == 'New') {
            UserRegister_NEW()
        }
        if (e.item.name == 'Close') {
            btnCloseActiveTab();
        }
        else if (e.item.name == 'Edit') {
            OnUserRegisterEditClick();
        }
        else if (e.item.name == 'Delete') {
            OnUserRegisterDeleteClick();
        }
        else if (e.item.name == 'View') {
            OnUserRegisterViewClick();
        }
        else if (e.item.name == 'ListPreview') {
            UserRegister_Preview();
        }
        else if (e.item.name == 'Refresh') {
            UserRegisterListGrid.Refresh();
        }
        else if (e.item.name == 'resetpwd') {
            UserRegister_ResetPassword();
        }
        else if (e.item.name == 'changepwd') {
            UserRegister_ChangePassword();
        }
        else if (e.item.name == 'adusrtogrup') {
            UserRegister_AdUsrtoGrp();
        }
        else if (e.item.name == 'AddPrivileg') {
            ManagPrivileges_AddPriv();
        }
        else if (e.item.name == 'ManagPrivileg') {
            UserRegister_ManagPrivileges();
        }
    }
    function UserRegisterGrid_BeginCallBack(s, e) {
        e.customArgs["command"] = e.command;
        if (e.command == "REFRESH") {
            isUserregisterGridRefresh = true;
            UserGridFocusedIndex = s.GetFocusedRowIndex();
        }
        e.customArgs["ShowHorizontalBar"] = UserRegister_ShowHorizontalBar;
    }


    //Nested Grid related Function
    function OnUserRegisterListGridNestedFocusedRowChange(s,e) {
        s.SetFocusedRowIndex(-1);
    }

    //Nested Grid Related Function
    function UserRegister_Grid_Nested_BeginCallBack(s, e) {

        //e.customArgs["ShowHorizontalBar"] = MembershipWow_ShowHorizontalBar;
        //e.customArgs["VouchingMode"] = MembershipWow_IsVouchingMode;
        e.customArgs["command"] = e.command;
        /*e.customArgs["RecID"] = UserID; */
       @*e.customArgs["RecID"] = "@ViewBag.UserRegisterInfo_RecID";*@
    }

    function onInitialized_LookUp_GetPersonnelName(e) {
        if (e.component.option("dataSource") != null) {
            e.component.option("dataSource").option.load.done(function (d) {

                if (d.length == 1)
                    e.component.option("value", d[0].PersonnelName);
            });
        }
    }

    function UserRegisterchangeMode()
    {
        ShowLoader();
        if (UserRegister_ShowHorizontalBar == 0) {
            UserRegister_ShowHorizontalBar = 1;
            $("#UserRegisterToggleScrollBar").find("span").text("Default Data");
            $("#UserRegisterToggleScrollBar").width(110);
        }
        else {
            UserRegister_ShowHorizontalBar = 0;
            $("#UserRegisterToggleScrollBar").find("span").text("Full Data");
            $("#UserRegisterToggleScrollBar").width(90);
        }
        $.ajax({
            url: '@Url.Action("Frm_UserRegister_Info_Grid", "UserRegister")',
            type: "GET",
            data: { ShowHorizontalBar: UserRegister_ShowHorizontalBar },
            success: function (res) {
                $("#UserRegisterreloadPartialView").html(res);
            }
        });
        HideLoader();
    }// full data button click

    function UserRegisterAjaxSuccessForm(data) {
        HideLoader();
        //dontaskpopupcloseconfirmation = true;
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.Message, "Error");
        }
        else {
            DevExpress.ui.dialog.alert(data.Message, "Success");
            $("#Dynamic_Content_popup").dxPopup("hide");
            UserRegisterListGrid.SetFocusedRowIndex(-1);
            UserRegisterListGrid.Refresh();
            HideLoader();
        }
    }

    function UserRegister_NEW()
    {
        $("UserRegistervalidationForm").remove();
        if (!UserRegisterNewright){ DevExpress.ui.dialog.alert('Not Allowed', 'No Rights'); return; }
        ShowLoader();
        OpenDynamicPopup("New ~ Create User","@Url.Action("Frm_UserRegister_Window", "UserRegister",new { @area = "Options" })?ActionMethod=New", "auto", 900, false, null);
        HideLoader();
    } //new click

