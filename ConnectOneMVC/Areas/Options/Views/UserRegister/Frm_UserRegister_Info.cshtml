    <div id="UserReg_ParentDiv">
        <div id="contentUserReg" class="report_header_div_main clearfix">

            <div class="report_header_div">
                <label class="report_header_label">User Register Screen <!--<i title="Screen Intro" class="fa fa-question-circle" id="userRegIntro"></i>--></label>
            </div>
            <div class="report_button_div">
                @(Html.DevExtreme().Button().ID("UserRegisterChangepw").Text("Change Password")
        .Visible(true).Disabled(false).OnClick(@<Text> function () {UserRegister_ChangePassword(); } </Text>)
        )
                @(Html.DevExtreme().Button().ID("UserRegisterResetpw").Text("Reset Password")
        .Visible(true).Disabled(false)
        .OnClick(@<Text> function () {UserRegister_ResetPassword(); } </Text>)
        )
                @(Html.DevExtreme().Button()
            .ID("UserRegisterAddPrivileges")
            .Text("Add Privileges")
            .Visible(true).Disabled(false)
            //.AccessKey("M")22
            .OnClick("ManagPrivileges_AddPriv")
        )
                @(Html.DevExtreme().Button().ID("UserRegisterManagPrivileges").Text("Manage Privileges").Visible(true).Disabled(false).OnClick(@<Text> function () { UserRegister_ManagPrivileges(); } </Text>))
                @(Html.DevExtreme().Button().ID("UserRegisterAdUsrGrp").Text("Add to Group").Visible(true).Disabled(false).OnClick(@<Text> function () { UserRegister_AdUsrtoGrp(); } </Text>))
                @(Html.DevExtreme().Button().ID("UserRegisterNew").Text("New").Icon("add").Visible(true).Disabled(false).OnClick(@<Text> function () { UserRegister_NEW(); } </Text>))
                @(Html.DevExtreme().Button()
            .ID("UserRegisterEdit")
            .Text("Edit")
            .Icon("edit").Visible(true)
            .Disabled(false)
            //.AccessKey("X")
            .OnClick("OnUserRegisterEditClick")
        )
                @(Html.DevExtreme().Button().ID("UserRegisterDelete").Text("Delete").Icon("trash").Visible(true).Disabled(false).OnClick(@<text> function () { OnUserRegisterDeleteClick(); } </text>))
                @(Html.DevExtreme().Button().ID("UserRegisterView").Text("View").Icon(IconID.ViewCustomers16x16devav).Icon("doc").Visible(true).Disabled(false).OnClick(@<text> function () {OnUserRegisterViewClick(); } </text>))
                @(Html.DevExtreme().Button().ID("UserRegisterToggleScrollBar").Text("Full Data").Icon("toolbox").OnClick(@<text> function () { UserRegisterchangeMode(); } </text>))
                @(Html.DevExtreme().Button().ID("UserRegisterListPreview").Text("List Export").Icon("save").OnClick(@<text> function () { UserRegister_Preview(); } </text>))
                @(Html.DevExtreme().Button().ID("UserRegisterCLOSE").Text("Close").Icon("clear").OnClick(@<text> function (){$(".TabPanalMenu-tabs .active span").click()} </text>))
            </div><!--[Buttons]-->
        </div>
        <div class="col-md-12 no-padding">
            <form>
                <div id="UserRegisterreloadPartialView" class="parent_table">
                    @Html.Partial("Frm_UserRegister_Info_Grid", Model)
                </div>
            </form>
        </div><!--[Grid]-->

        <div class="footer-MainBoxdiv full-width-footer margin4-0">
            <div class="col-md-10">
                <p id="UserRegisterLbl_Create" style="margin:0px" class="left_footertext_top"></p>
                <p id="UserRegisterLbl_Modify" style="margin:0px" class="left_footertext_bottom"></p>
            </div><!--[Footer]-->
        </div>
    </div>
    @(Html.DevExtreme().Popup().CustomPopup().ID("UserRegister_report_modal").Title("UserRegister List Preview").FullScreen(false).MaxWidth(250).Height("auto").ShowCloseButton(true).ContentTemplate(@<text> <div id='UserRegister_report_modal_result'> </div> </text>))@*Mantis bug 0001023 fixed*@
    @(Html.DevExtreme().Popup().CustomPopup().ID("UserRegister_AddPersonnel_report_modal").Title("UserRegister List Preview").FullScreen(false).Height("auto").ShowCloseButton(true).ContentTemplate(@<text> <div id='UserRegister_AddPersonnel_report_modal_result'> </div> </text>))
