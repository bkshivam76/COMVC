    function OnUserRegisterViewClick()
    {
        $("UserRegistervalidationForm").remove();
        if (!UserRegisterViewright) { DevExpress.ui.dialog.alert('Not Allowed', 'No Rights'); return; }
        if (!UserID) { DevExpress.ui.dialog.alert('Please Select any user', 'Alert '); return; }
        ShowLoader();
        OpenDynamicPopup("View ~ Create User", "@Url.Action("Frm_UserRegister_Window", "UserRegister", new { @area = "Options" })?ActionMethod=View&ID=" + encodeURI(UserID), "auto", 900, false, null);
        HideLoader();
    }//view click

        function OnUserRegisterDeleteClick()
        {
            $("UserRegistervalidationForm").remove();
            if (!UserRegisterDeleteright) { DevExpress.ui.dialog.alert('Not Allowed', 'No Rights'); return; }
            if (!UserID) { DevExpress.ui.dialog.alert('Please Select any user', 'Alert '); return; }
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Options/UserRegister/DataNavigation",
                data: { ActionMethod: "Delete", UserID: UserName },
                cache: false,
                success: function (UserRegisterDelete_ButtonClick_result)
                {
                    if (UserRegisterDelete_ButtonClick_result.result == true)
                    {
                        HideLoader();
                        ShowLoader();
                        OpenDynamicPopup("Delete ~ Create User", "@Url.Action("Frm_UserRegister_Window", "UserRegister", new { @area = "Options" })?ActionMethod=Delete&ID=" + encodeURI(UserID), "auto", 900, false, null);
                        HideLoader();
                    }
                    else if (UserRegisterDelete_ButtonClick_result.result == "NoDeleteRights")
                    {
                        $('#UserRegisterDelete').hide();
                        DevExpress.ui.dialog.alert(UserRegisterDelete_ButtonClick_result.message, 'Warning!');
                        HideLoader();
                    }
                    else
                    {
                        HideLoader();
                        DevExpress.ui.dialog.alert(UserRegisterDelete_ButtonClick_result.message, 'Warning!');
                    }
                }
            });
     }//delete click //0000177 bug fixed


