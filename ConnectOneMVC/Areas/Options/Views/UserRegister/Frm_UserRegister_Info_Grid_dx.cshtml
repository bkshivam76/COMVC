@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool DBData = ViewBag.DBData == null ? true : ViewBag.DBData;
    int ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;

}
@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar)
                 .ID("UserRegisterListGrid_dx")
                 .DataSource(d => d.Mvc().Controller("UserRegister").LoadAction("Frm_UserRegister_Info_Grid_dx").LoadMode(DataSourceLoadMode.Raw).Key("ID"))
                 .Columns(columns =>
                 {
                     columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);//Bug #137209 Fix

                     columns.Add().DataField("UserName").Caption("UserName").MinWidth(260);
                     columns.Add().DataField("PersonnelName").Caption("Name").MinWidth(175);
                     columns.Add().DataField("SewaDept").Caption("Sewa Department").MinWidth(25);
                     columns.Add().DataField("ContactNo").Caption("Mobile No.").MinWidth(100);
                     columns.Add().DataField("EmailID").Caption("Email Id").MinWidth(100);
                     columns.Add().DataField("Is_Admin").Caption("Is Admin").MinWidth(100).ShowEditorAlways(false);
                     columns.Add().DataField("SELFPOSTED").Caption("Show Self Entries Only").MinWidth(150).ShowEditorAlways(false);
                     columns.Add().DataField("Groups").Caption("Groups").MinWidth(300);
                     columns.Add().DataField("AddedBy").Caption("Add By").Visible(false).MinWidth(120);
                     columns.Add().DataField("AddedOn").Caption("Add Date").Visible(false).MinWidth(120);
                     columns.Add().DataField("EditedBy").Caption("Edit By").Visible(false).MinWidth(120);
                     columns.Add().DataField("EditedOn").Caption("Edit Date").Visible(false).MinWidth(120);
                     columns.Add().DataField("ID").Caption("ID").Visible(false).MinWidth(120).SortOrder(SortOrder.Asc);
                 })   
         .MasterDetail(md =>
         {
             md.AutoExpandAll(false);
             md.Enabled(true);
             md.Template(new JS("UserRegisterListGrid_dx_DetailTemplate"));
         })
         .OnInitialized("UserRegisterListGrid_dx_OnInitialized")
         //         .OnCellPrepared("UserRegisterListGrid_dx_OnCellPrepared")
         //         .OnRowPrepared("UserRegisterListGrid_dx_OnRowPrepared")
         .OnContentReady("UserRegisterListGrid_dx_OnContentReady")
         .OnCellDblClick("UserRegisterListGrid_dx_OnCellDblClick")
         .OnSelectionChanged("UserRegisterListGrid_dx_OnSelectionChanged")
         //         //.OnFocusedRowChanged("BankListGrid_dx_OnFocusedRowChanged")
         .OnRowExpanding("UserRegisterListGrid_dx_OnRowExpanding")
         .OnRowCollapsing("UserRegisterListGrid_dx_OnRowCollapsing")
         .OnContextMenuPreparing("UserRegisterListGrid_dx_OnContextMenuPreparing")
////.OnEditorPreparing("BankListGrid_dx_OnEditorPreparing")
)