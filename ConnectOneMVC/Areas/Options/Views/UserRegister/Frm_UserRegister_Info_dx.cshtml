    $(".TabPanalMenu-tabs .active span").on("click", function () {
        $.ajax({
            type: 'GET',
            url: "/Options/UserRegister/SessionClear",
            cache: false
        });
        ClearAllReferences_UserRegisterOptions();

    });
        function ClearAllReferences_UserRegisterOptions() {
            Groupsusagecountcheck = null;
            PersonnelNewright = null;
            GroupRegisterNewright = null;
            UserGridFocusedIndex = null;
            isUserregisterGridRefresh = null;
            UserName = null;
            PersonnelName = null;
            SewaDept = null;
            ContactNo = null;
            EmailID = null;
            Groups = null;
            Is_Admin = null;
            AddedBy = null;
            AddedOn = null;
            EditedBy = null;
            EditedOn = null;
            UserID = null;
            UserRegister_Privileg_GroupID = null;

            ClearAllReferences("UserRegisterOptions_ClearReferences");
        }

    function UserRegister_ChangePassword() {
        if (!UserRegisterEditright) { DevExpress.ui.dialog.alert('Not Allowed', 'No Rights'); return; }
        if (!UserID) { DevExpress.ui.dialog.alert('Please Select any user', 'Alert'); return; }
        if ($("#ChangePasswordvalidationForm").length > 0) {
            $("#ChangePasswordvalidationForm").remove();
        }
        ShowLoader();
        OpenDynamicPopup("Change Password", "@Url.Action("Frm_Chg_Password", "ChangePassword", new { @area = "Options" })?User_Name=" + encodeURI(UserName), "auto", "500", false, null);
        HideLoader();
    }//Change Password button

    function UserRegister_ResetPassword() {

        if (!UserRegisterEditright) {
            DevExpress.ui.dialog.alert('Not Allowed', 'No Rights');
            return;
        }
        ShowLoader();
        if (!UserID) {
            DevExpress.ui.dialog.alert('Please Select any user', 'Alert');
            HideLoader();
            return;
        }
        else {
            var result;
            result = DevExpress.ui.dialog.confirm('Are you sure you want to Reset Password of this User?', "Confirm");
           result.done(function (dialogResult) {
               if (dialogResult) {

                    $.ajax({
                        type: 'GET',
                        url: "/Options/UserRegister/ResetPassword",
                        data: { userid: UserID, user_name: UserName},
                        cache: false,
                        success: function (PasswordReset_result)
                        {
                            /*$('#UserRegisterResetpw').hide();*/
                            DevExpress.ui.dialog.alert(PasswordReset_result.message, 'Reset Password');
                            HideLoader();
                        }
                    });
                }
                else {

                }
            });
        }

        HideLoader();
    }//Reset Password button

    function UserRegisterOnInit(s, e) {
        UserRegister_MasterAdjustSize(s, e);
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            UserRegister_MasterAdjustSize(s, e);
        });
        s.SetFocusedRowIndex(-1);
    }

    function UserRegisterGrid_EndCallback(s, e) {
        //UserRegister_MasterAdjustSize(s, e);
        SendCustomArgs_FilterControl(s, e);
        if (isUserregisterGridRefresh)
        {
            isUserregisterGridRefresh = false;
            s.SetFocusedRowIndex(-1);
            s.SetFocusedRowIndex(UserGridFocusedIndex);
        }
    }

    function UserRegister_MasterAdjustSize(s, e) {
        var height = (document.documentElement.clientHeight * 90) / 100;
        s.SetHeight(height);
    }

    function UserRegisterGridFocusedRowChanged(s, e) {

        if (s.GetFocusedRowIndex() == -1) {
            UserID = null;

        }
        else {
            var key = s.GetRowKey(s.GetFocusedRowIndex());
               s.GetValuesOnCustomCallback({ key: key }, UserRegisterOnGetRowValues);

        }

    }

   var UserName;
   var PersonnelName;
   var SewaDept;
   var ContactNo;
   var EmailID;
   var Groups;
   var Is_Admin;
   var AddedBy;
   var AddedOn;
   var EditedBy;
   var EditedOn;
   var UserID ;
    function UserRegisterOnGetRowValues(FDData) {

        FullData = FDData;

        var values = FDData.split("![");
        UserName = values[0];
        PersonnelName = values[1];
        SewaDept = values[2];
        ContactNo = values[3];
        EmailID = values[4];
        Groups = values[5];
        Is_Admin = values[6];
        AddedBy = values[7];
        AddedOn = values[8];
        EditedBy = values[9];
        EditedOn = values[10];
        UserID = values[11];
        UserRegister_UpdateFooterDetail(AddedBy, AddedOn, UserID, EditedOn, EditedBy);
    }


    function UserRegister_UpdateFooterDetail(AddedBy, AddedOn, ID, EditedOn, EditedBy) {
        var Lbl_Create = "";
        var Lbl_Modify = "";

        if (AddedOn) {
            Lbl_Create = "Add On: " + AddedOn + ", Add By: " + AddedBy;
        }
        else {
            Lbl_Create = "Add On: " + "?, Add By: " + AddedBy;
        }

        if (EditedOn) {
            Lbl_Modify = "Edit On: " + EditedOn + ", Edit By: " + EditedBy;
        }
        else {
            Lbl_Modify = "Edit On: " + "?, Edit By: " + EditedBy;
        }

        $('#UserRegisterLbl_Create').text(Lbl_Create);
        $('#UserRegisterLbl_Modify').text(Lbl_Modify);
    }


    function UserRegisterdblclickEdit(s, e) {
        if (UserID) {
            OnUserRegisterEditClick();
        }
        else {
            DevExpress.ui.dialog.alert('Please Select any user', 'Alert');
        }
    }
    function UserRegisterContextMenuFunction(s, e) {
        if (e.item.name == 'New') {
            UserRegister_NEW()
        }
        if (e.item.name == 'Close') {
            btnCloseActiveTab();
        }
        else if (e.item.name == 'Edit') {
            OnUserRegisterEditClick();
        }
        else if (e.item.name == 'Delete') {
            OnUserRegisterDeleteClick();
        }
        else if (e.item.name == 'View') {
            OnUserRegisterViewClick();
        }
        else if (e.item.name == 'ListPreview') {
            UserRegister_Preview();
        }
        else if (e.item.name == 'Refresh') {
            UserRegisterListGrid.Refresh();
        }
        else if (e.item.name == 'resetpwd') {
            UserRegister_ResetPassword();
        }
        else if (e.item.name == 'changepwd') {
            UserRegister_ChangePassword();
        }
        else if (e.item.name == 'adusrtogrup') {
            UserRegister_AdUsrtoGrp();
        }
        else if (e.item.name == 'AddPrivileg') {
            ManagPrivileges_AddPriv();
        }
        else if (e.item.name == 'ManagPrivileg') {
            UserRegister_ManagPrivileges();
        }
    }
    function UserRegisterGrid_BeginCallBack(s, e) {
        e.customArgs["command"] = e.command;
        if (e.command == "REFRESH") {
            isUserregisterGridRefresh = true;
            UserGridFocusedIndex = s.GetFocusedRowIndex();
        }
        e.customArgs["ShowHorizontalBar"] = UserRegister_ShowHorizontalBar;
    }


    //Nested Grid related Function
    function OnUserRegisterListGridNestedFocusedRowChange(s,e) {
        s.SetFocusedRowIndex(-1);
