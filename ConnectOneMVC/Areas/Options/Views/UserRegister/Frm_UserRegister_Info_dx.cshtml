    @*variable*@
    <script>
        var UserRegisterListGrid_dx = null;
        var UserRegister_IsDetailRowExpanded_dx = false;
        var Expanded_Row_Key_UserRegister = null;
    </script>
    @*Buttons Fns*@
    <script>
    function UserRegisterchangeMode()
    {
        UserRegisterListGrid_dx.beginUpdate();
        if (UserRegister_ShowHorizontalBar == 0) {
            UserRegister_ShowHorizontalBar = 1;
            $("#UserRegisterToggleScrollBar").find("span").text("Default Data");
            $("#UserRegisterToggleScrollBar").width(110);
            UserRegisterListGrid_dx.option("columnHidingEnabled", false);
            UserRegisterListGrid_dx.option("allowColumnResizing", true)
        }
        else {
            UserRegister_ShowHorizontalBar = 0;
            $("#UserRegisterToggleScrollBar").find("span").text("Full Data");
            $("#UserRegisterToggleScrollBar").width(90);
            UserRegisterListGrid_dx.option("columnHidingEnabled", true)
            UserRegisterListGrid_dx.option("allowColumnResizing", false)
        }
        UserRegisterListGrid_dx.endUpdate();
    }// full data button click
    </script>
    @*Grid fns*@
<script>
    function UserRegisterListGrid_dx_OnInitialized(e) {
            DxGrid_AdjustSize(e.component, $("#UserReg_ParentDiv .report_button_div"))
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                DxGrid_AdjustSize(e.component, $("#UserReg_ParentDiv .report_button_div"), "", evt)
            });
            UserRegisterListGrid_dx = e.component;
        }
    function UserRegisterListGrid_dx_OnContentReady(e) {
            DxGrid_OnContentReady(e, UserRegister_ShowHorizontalBar);
        }
    function UserRegisterListGrid_dx_OnSelectionChanged(e) {
            var selectedRowKeys = e.selectedRowKeys;
            if (selectedRowKeys != null && selectedRowKeys.length > 0) {
               UserRegisterListGrid_dx_SelectedRowData(e.selectedRowsData);
            }
            else {
                UserID = null;
                UserRegister_UpdateFooterDetail(AddedBy, AddedOn, UserID, EditedOn, EditedBy);
            }

        }
    function UserRegisterListGrid_dx_SelectedRowData(selectedData = null) {
            if (selectedData == null) {
                selectedData = UserRegisterListGrid_dx.getSelectedRowsData();
            }
            if (selectedData != null && selectedData.length > 0) {
                var values = selectedData[0]
                UserName = values["UserName"]
                PersonnelName = values["PersonnelName"];
                SewaDept = values["SewaDept"];
                ContactNo = values["ContactNo"];
                EmailID = values["EmailID"];
                Groups = values["Groups"];
                Is_Admin = values["Is_Admin"];
                AddedBy = values["AddedBy"];
                AddedOn = values["AddedOn"];
                EditedBy = values["EditedBy"];
                EditedOn = values["EditedOn"];
                UserID = values["ID"];
                UserRegister_UpdateFooterDetail(AddedBy, AddedOn, UserID, EditedOn, EditedBy);
            }
            else {
                UserID = null;
            }
        }
    function UserRegisterListGrid_dx_OnCellDblClick(e) {      
                if (e.rowType == "data")
                    OnUserRegisterEditClick();

    }
    function UserRegisterListGrid_dx_OnRowExpanding(e) {
        if (Array.isArray(e.key) == false) //not group row
        {
            e.component.collapseRow(Expanded_Row_Key_UserRegister)
            e.component.selectRows(e.key);
            Expanded_Row_Key_UserRegister = e.key;
            UserRegister_IsDetailRowExpanded_dx = true;
            var DetailGridID = e.element[0].id + e.key;
            var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
            if (instance != void 0) {
                instance.state(null) // grid maintains its state after collapsing so resetting the state when expands again as per old grid
            }
            //e.component.collapseAll(-1);           
        }
        else {
            e.component.option("CustomProp.groupRowExpanded", true);
        }
    }
    function UserRegisterListGrid_dx_OnRowCollapsing(e) {
        if (Array.isArray(e.key) == false) //not group row
        {
            var DetailGridID = e.element[0].id + e.key;
            sessionStorage.removeItem(DetailGridID + "_DetailGridState") //removing grid state from session storage on collapse
            UserRegister_IsDetailRowExpanded_dx = false;
            e.component.selectRows(e.key);
            
            var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
            if (instance != void 0) {
                instance.clearSelection();
            }
        }
        else {
            e.component.option("CustomProp.groupRowCollapsed", true);
        }
    }

    function UserRegisterListGrid_dx_OnContextMenuPreparing(e) {
        if (!e.items) e.items = [];
        if (e.target == "header") {

            DxGrid_HeaderContextMenu(e)
        }
        else if ((e.target == "content" && e.row && e.row.rowType == "groupFooter") || e.target == "footer") {

                DxGrid_FooterContextMenu(e);
        }
        else if (e.target == "content" && e.row && (e.row.rowType == "data" || e.row.rowType == "detailAdaptive")) {
            var key = e.component.getKeyByRowIndex(e.row.rowIndex);
            e.component.selectRows(key);
            var expanded = e.component.isRowExpanded(key);
            e.items = [
                {
                    text: "Expand Detail",
                    icon: "fa-solid fa-arrow-down-wide-short " + (expanded ? "text-muted" : "text-info"),
                    disabled: expanded,
                    visible: true,
                    onItemClick: function () {
                        if (expanded) {
                        }
                        else {
                            e.component.expandRow(key);
                        }
                    }
                }, {
                    text: "Collapse Detail",
                    icon: "fa-solid fa-arrow-up-wide-short " + (!expanded ? "text-muted" : "text-info"),
                    disabled: !expanded,
                    visible: true,
                    onItemClick: function () {
                        if (expanded) {
                            e.component.collapseRow(key);
                        }
                        else {
                        }
                    }
                },
                {
                    text: "New",
                    icon: "fa-solid fa-plus text-success",
                    beginGroup: true,
                    visible: "@UserReg_AddRight" == "True",
                    onItemClick: function () {
                        UserRegister_NEW();
                    }
                },
                {
                    text: "Edit",
                    icon: "fa-solid fa-pen text-info",
                    visible: "@UserReg_UpdateRight" == "True",
                    onItemClick: function () {
                        OnUserRegisterEditClick();
                    }
                },
                {
                    text: "Delete",
                    icon: "fa-solid fa-trash",
                    visible: "@UserReg_DeleteRight" == "True",
                    onItemClick: function () {
                        OnUserRegisterDeleteClick();
                    }
                },
                {
                    text: "View",
                    icon: "fa-regular fa-eye",
                    visible: "@UserReg_ViewRight" == "True",
                    onItemClick: function () {

                        OnUserRegisterViewClick();
                    }
                },

                {
                    text: "Change Password",
                    icon: "fa-regular fa-key",
                    visible: "@UserReg_ViewRight" == "True",
                    onItemClick: function () {

                        UserRegister_ChangePassword();
                    }
                },
                {
                    text: "Reset Password",
                    icon: "fa-regular fa-unlock",
                    visible: "@UserReg_ViewRight" == "True",
                    onItemClick: function () {

                        UserRegister_ResetPassword();
                    }
                },
                {
                    text: "Add Selected Users to Group",
                    icon: "fa-regular fa-users",
                    visible: "@UserReg_ViewRight" == "True",
                    onItemClick: function () {

                        UserRegister_AdUsrtoGrp();
                    }
                },
                {
                    text: "Add Privileges",
                    icon: "fa-regular fa-plus",
                    visible: "@UserReg_ViewRight" == "True",
                    onItemClick: function () {

                        UserRegisteManagPrivileges_AddPrivr_AdUsrtoGrp();
                    }
                },

                {
                    text: "Manage Privileges",
                    icon: "fa-regular fa-bars",
                    visible: "@UserReg_ViewRight" == "True",
                    onItemClick: function () {

                        UserRegister_ManagPrivileges();
                    }
                },
                {
                    text: "Export",
                    icon: "fa-solid fa-file-export text-warning",
                    visible: "@UserReg_ExportRight" == "True",
                    beginGroup: true,
                    onItemClick: function () {
                        UserRegister_Preview();
                    }
                },

                {
                    text: "Close",
                    icon: "fa-solid fa-rectangle-xmark text-danger",
                    beginGroup: true,
                    onItemClick: function () {
                        btnCloseActiveTab();
                    }
                },
                {
                    text: "Refresh",
                    icon: "fa-solid fa-arrow-rotate-right text-success",
                    beginGroup: true,
                    onItemClick: function () {
                        UserRegisterListGrid_dx_Refresh();
                    }
                }]
        }
    }


    function UserRegisterListGrid_dx_DetailTemplate(container, templateData) {
        var GridName = templateData.component.element()[0].id
        var RecID = templateData.data.ID;
        UserRegisterListGrid_dx_Detail(container, GridName, RecID,UserRegister_ShowHorizontalBar);
    }
    function UserRegisterListGrid_dx_Detail(container, GridName, RecID, AllColumns) {
        var DetailGridID = GridName + RecID;
        $(container).append("<div id='" + DetailGridID + "' class='DG_DetailGrid DataGridListing'></div>");
        $("div[id='" + DetailGridID + "']").dxDataGrid({
            dataSource:
                new DevExpress.data.CustomStore({//DevExpress.data.AspNet.createStore({
                    key: "UserID",
                    loadMode: "raw",
                    load: function () {
                        return $.getJSON("/Options/UserRegister/Frm_UserRegister_Info_DetailGrid_dx?RecID=" + RecID );
                    }
                }),
            width: "100%",
            sorting: {
                mode: 'multiple',
            },
            wordWrapEnabled: true,
            columns:
                [
                    {
                        dataField: "AddedOn", caption: "Added On", width: 90, format: "dd-MM-yyyy", dataType: "date", visible: false
                    },
                    {
                        dataField: "AddedBy", caption: "Added By", width: 70, visible: false
                    },
                    {
                        dataField: "EditedBy", caption: "Edited By", width: 70, visible: false
                    },
                    {
                        dataField: "EditedOn", caption: "Edited On", width: 90, format: "dd-MM-yyyy", dataType: "date", visible: false
                    },
                    {
                        dataField: "GroupName", caption: "Group Name", width: 200, sortOrder: 'asc'
                    },
                    {
                        dataField: "EntityName", caption: "Entity/Screen", width: 250
                    },
                    {
                        dataField: "GroupNameV", caption: "Group NameV", width: 100, visible: false
                    },
                    {
                        dataField: "GrpID", caption: "Grp ID", width: 100, visible: false
                    },
                    {
                        dataField: "PrivilegeID", caption: "Privilege ID", width: 100, visible: false
                    },
                    {
                        dataField: "ScreenID", caption: "Screen ID", width: 100, visible: false
                    },
                    {
                        dataField: "PrivilegesGiven", caption: "PrivilegesD"
                    },
                    {
                        dataField: "UserID", caption: "User ID", width: 70, visible: false
                    },
                    {
                        dataField: "UserName", caption: "User Name", width: 70, visible: false
                    }
      ],
           // onRowPrepared: function (e) { UserRegisterListGrid_dx_Detail_onRowPrepared(e) },
            onContentReady: function (e) { UserRegisterListGrid_dx_Detail_onContentReady(e) },
           // onSelectionChanged: function (e) { UserRegisterListGrid_dx_Detail_onSelectionChanged(e) },
            onContextMenuPreparing: function (e) { UserRegisterListGrid_dx_Detail_onContextMenuPreparing(e) }
        });
        var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance");
        DxGrid_CustomDataGridListing(DetailGridID, AllColumns, instance)

       
        instance.option("filterRow.visible", false);
        instance.option("paging.enabled", false);
    }
    function UserRegisterListGrid_dx_Detail_onContentReady(e) {
        DxGrid_SetGridUIinColHiding(e.element[0].id, UserRegister_ShowHorizontalBar, true)
        DxGrid_GetFIlterBuilderDataSource(e)
    }
    function UserRegisterListGrid_dx_Detail_onContextMenuPreparing(e) {
        if (!e.items) e.items = [];
        if (e.target == "header") {
            DxGrid_HeaderContextMenu(e)
        }
        else if ((e.target == "content" && e.row && e.row.rowType == "groupFooter") || e.target == "footer") {
           
                DxGrid_FooterContextMenu(e);
        }
        else if (e.target == "content" && e.row && e.row.rowType == "data") {
            e.items = [{
                text: "Refresh",
                icon: "fa-solid fa-arrow-rotate-right text-success",
                onItemClick: function () {
                    e.component.refresh();
                }
            }]
        }
    }


</script>
    @*Grid Related Fns*@
    <script>
        function UserRegisterListGrid_dx_Refresh() {
            UserRegisterListGrid_dx.refresh().done(function () { ActionAfterDataGridRefresh_UserRegisterListGrid() })
        }
        async function ActionAfterDataGridRefresh_UserRegisterListGrid() {
            var selectedRowKeys = UserRegisterListGrid_dx.getSelectedRowKeys()
                if (selectedRowKeys != null && selectedRowKeys.length > 0) {
                    UserRegisterListGrid_dx.clearSelection()
                    UserRegisterListGrid_dx.selectRows(selectedRowKeys)
                }
            
        }

    </script>
</div>