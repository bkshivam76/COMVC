        }
        if ("@UserReg_AddPrivilegeRight" == "False") {
            $("#UserRegisterAddPrivileges").hide();
        }

        if (UserRegisterViewright != true)
        {
            $("#UserRegisterView").hide();
        }
        if (UserRegisterDeleteright != true)
        {
            $("#UserRegisterDelete").hide();
        }
        if (UserRegisterExportright != true)
        {
            $("#UserRegisterListPreview").hide();
        }
