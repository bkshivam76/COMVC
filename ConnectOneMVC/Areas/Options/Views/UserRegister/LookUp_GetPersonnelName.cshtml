@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
        .ID("Frm_UserRegister_GetLookUp_PersonnelName_datagrid")

        .Columns(columns =>
        {

            columns.Add().DataField("Name").Caption("Name");
            columns.Add().DataField("Type").Caption("Personnel Type").Visible(false);
            columns.Add().DataField("Skill_Type").Caption("Skill Type");
            columns.Add().DataField("Designation").Caption("Designation").Visible(false);
            columns.Add().DataField("Main_Dept").Caption("Main Department").Visible(true);

            columns.Add().DataField("Sub_Dept").Caption("Sub Dept");

            columns.Add().DataField("ID").Caption("ID").Visible(false);
            columns.Add().DataField("Mobile_No").Caption("MobileNo").Visible(false);
            columns.Add().DataField("EmailID").Caption("EmailID").Visible(false);
        })

        .Selection(s => s.Mode(SelectionMode.Single))

)@*Mantis bug 0001089 fixed*@
