    function OnAdvancesCellClick(event, cell,col, row)
    {
        if (UserType_AdvancesPrf == "AUDITOR" || UserType_AdvancesPrf == "SUPERUSER")
        {
            if (event.button == 0)
            {
                if (cell.style.backgroundColor.length > 0)
                {
                    cell.style.backgroundColor = "";
                }
                else
                {
                    cell.style.backgroundColor = 'skyblue';
                }
            }
        }
    }

    function Advances_VouchingSwitch_ValueChange(e)
    {
        Advances_IsVouchingMode = e.value;
        if (AdvancesInfo_SetVouchingModeOn == true) {
            AdvancesInfo_SetVouchingModeOn = false;
        }
        else {
            AdvancesPrf_FAB.SetVisible(false);
        }
        if (Advances_IsVouchingMode == true) {
            OpenRightPane();
            ClearLeftPane();
            OpenLeftPane();
        }
        else {
            AdvancesPrf_FAB.SetActionContext("AddAttachmentContext", false);
            CloseRightPane();
            ClearLeftPane();
            CloseLeftPane();
        }
        AdvancesListGrid_CollapseAllDetailRows();
    }
    function AdvancesListGrid_CollapseAllDetailRows()
    {
        if (typeof window !== 'undefined')
        {
            if (typeof window.AdvancesListGrid !== 'undefined')
            {
                if (typeof window.AdvancesListGrid.CollapseAllDetailRows !== 'undefined')
                {
                    if (typeof AdvancesListGrid.CollapseAllDetailRows == 'function')
                    {
                        AdvancesListGrid.SetFocusedRowIndex(-1);
                        AdvancesListGrid.CollapseAllDetailRows();
                    }
                    else
                    {
                        alert("CollapseAllDetailRows is not a function");
                    }
                }
                else
                {
                    ShowLoader();
                    setTimeout(function ()
                    {
                        AdvancesListGrid_CollapseAllDetailRows();
                        HideLoader();
                    }, 100);
                }
            }
            else
            {
                alert('grid undefined')
            }
        }
        else
        {
            alert('window undefined')
        }
    }
    function Advances_ViewSwitch_ValueChange(e)
    {
        Advances_ViewMode = e.value == false ? "Default" : "Compact";
        if (AdvancesInfo_SetVouchingModeOn == true)
        {
            $("#AdvancesVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }
        else
        {
            AdvancesListGrid.CollapseAllDetailRows();
        }
    }

        function AdvancesOnInit(s, e) {
            AdvancesAdjustSize();
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                AdvancesAdjustSize();
            });
    }

    var Advances_ColumnToBeShownIndex = "";
    var Advances_ColumnToBeHidddenIndex = "";
    function OnGridAdvancesListGrid_EndCallback(s, e)
    {
            //AdvancesAdjustSize();
            AdvancesGridLayout = s.cpClientLayout;
            Advances_ColumnToBeShownIndex = s.cpColumnToBeShownIndex;
            Advances_ColumnToBeHidddenIndex = s.cpColumnToBeHidddenIndex;
       $(".AdvancesListGrid_PreviewRow").hide();
        GetSessionStorage("AdvancesListGrid");
        SendCustomArgs_FilterControl(s, e);
        if (e.command == "REFRESH" && Advances_IsVouchingMode == true) {
            s.SetFocusedRowIndex(-1);
            s.SetFocusedRowIndex(Advances_FocusedRowBeforeRefresh);
        }
    }

        function AdvancesAdjustSize() {
            var height = (document.documentElement.clientHeight * 90) / 100;
            try { AdvancesListGrid.SetHeight(height); } catch (err) { }
        }
        function AdvanceschangeMode() {
            ShowLoader();
            if (Advances_ShowHorizontalBar == 0) {
                Advances_ShowHorizontalBar = 1;
                $("#AdvancesToggleScrollBar").find("span").text("Default Data");
                $("#AdvancesToggleScrollBar").width(110);
            }
            else {
                Advances_ShowHorizontalBar = 0;
                $("#AdvancesToggleScrollBar").find("span").text("Full Data");
                $("#AdvancesToggleScrollBar").width(90);
            }
            $.ajax({
                url: '@Url.Action("Frm_Advances_Info_Grid", "Advances")',
                type: "GET",
                data: { ShowHorizontalBar: Advances_ShowHorizontalBar, VouchingMode: Advances_IsVouchingMode, ViewMode: Advances_ViewMode, ColumnToBeHidddenIndex: Advances_ColumnToBeHidddenIndex, ColumnToBeShownIndex: Advances_ColumnToBeShownIndex  },
                success: function (res) {
                    $("#AdvancesreloadPartialView").html(res);
                    $(".AdvancesListGrid_PreviewRow").hide();
                    GetSessionStorage("AdvancesListGrid");
                }
            });
            HideLoader();
        }
        function AdvancesAjaxSuccessForm(data) {
            HideLoader();
            if (data.result == false) {
                DevExpress.ui.dialog.alert(data.Message, "Error");
            }
            else {
                IsAdvancesSucessPopup = true;
                var advancesSubmitSuccess = DevExpress.ui.dialog.alert(data.Message, "Success");
                $("#popup_frm_Advances_Window").dxPopup("hide");
                AdvancesListGrid.Refresh();
                IsAdvancesSucessPopup = false;
                advancesSubmitSuccess.done(function (alertResult) {
                    if (alertResult) {
                        if (IsAdvancesNewPopup == true) {
                            var addmoreresult = DevExpress.ui.dialog.confirm("Add More Entry...?", "Advances");
                            addmoreresult.done(function (dialogResult) {
                                if (dialogResult) {
                                    OnAdvancesNewClick();
                                }
                            });
                        }
                        if (IsAdvancesEditPopup == true) {
                            var lockresult = DevExpress.ui.dialog.confirm("Do you want to Lock this Entry...?", "Confirmation");
                            lockresult.done(function (dialogResult) {
                                if (dialogResult) {
                                    AdvancesOnLockClick();
                                }
                            });
                        }
                    }
                });
            }
        }


