    <script>
        function AdvancesShown() {
            setTimeout(function () {
                $('#Amount input, #AdvanceDate input').keydown(function (e) {
                    if (e.key == "[") {

                        $(this).val($(this).val() + "(");
                        e.preventDefault();
                    }
                    if (e.key == "]") {

                        $(this).val($(this).val() + ")");
                        e.preventDefault();
                    }
                    if (e.key == "'") {

                        $(this).val($(this).val() + "`");
                        e.preventDefault();
                    }
                });
            }, 2000);//Redmine Bug #129765 fixed
        }
    </script>
