@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool IsAuditor = ViewBag.IsAuditor == null ? false : ViewBag.IsAuditor;
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;
    int ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;

}

@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar)
                 .ID("AdvancesListGrid_dx")
                 .DataSource(d => d.Mvc().Controller("Advances").LoadAction("Frm_Advances_Info_Grid_dx").LoadMode(DataSourceLoadMode.Raw).Key("ID"))
                 .Columns(columns =>
                 {
                     columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);//Bug #137209 Fix
                     columns.Add().DataField("iIcon").Name("iIcon").Caption("").CellTemplate(new JS("AdvancesListGrid_dx_iIconTemplate")).Width(30)
                     .HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource")).RenderAsync(true);
                     columns.Add().DataField("AdvancesListGrid_dx_Compact_Column").Name("AdvancesListGrid_dx_Compact_Column").Caption("").Visible(false).CellTemplate(new JS("AdvancesListGrid_dx_Compact_Column_Template"))
                     .CalculateCellValue("AdvancesListGrid_dx_Compact_Column_CellValue").Width("100%").RenderAsync(true).ShowInColumnChooser(false);

                     if (IsAuditor == true)
                     {
                         columns.Add().DataField("Type").Caption("Type").MinWidth(100).GroupIndex(0).GroupCellTemplate(new JS("AdvancesListGrid_dx_GroupCell_Template"));
                         columns.Add().DataField("ActionStatus").Caption("Action Status").MinWidth(100).GroupIndex(1).GroupCellTemplate(new JS("AdvancesListGrid_dx_GroupCell_Template"));
                     }
                     else
                     {
                         columns.Add().DataField("Type").Caption("Type").MinWidth(135);
                         columns.Add().DataField("ActionStatus").Caption("Action Status").MinWidth(160).Visible(false);
                     }
                     columns.Add().DataField("ITEM_NAME").Caption("Item Name").MinWidth(50);
                     columns.Add().DataField("PARTY_NAME").Caption("PARTY NAME").MinWidth(70);
                     columns.Add().DataField("AI_ADV_DATE").Caption("Given Date").MinWidth(50)
                     .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                     columns.Add().DataField("Advance").Caption("Advance").MinWidth(50);
                     columns.Add().DataField("Addition").Caption("Addition").MinWidth(50)
                     .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("Adjusted").Caption("Adjusted").MinWidth(50)
                     .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("Refund").Caption("Refund").MinWidth(50)
                     .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("OutStanding").Caption("Out Standing").MinWidth(50)
                     .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("Reason").Caption("Reason").MinWidth(60);
                     columns.Add().DataField("AI_OTHER_DETAIL").Caption("Other Detail").MinWidth(60);
                     columns.Add().DataField("Special_Ref").Caption("Reference").MinWidth(50);
                     columns.Add().DataField("YearID").Caption("YearID").Visible(false).MinWidth(125);
                     columns.Add().DataField("AddBy").Caption("Added By").Visible(false).MinWidth(125);
                     columns.Add().DataField("AddDate").Caption("Added Date").Visible(false).MinWidth(125);
                     columns.Add().DataField("EditBy").Caption("Edited By").Visible(false).MinWidth(125);
                     columns.Add().DataField("EditDate").Caption("Edited Date").Visible(false).MinWidth(125);
                     columns.Add().DataField("ActionBy").Caption("Action By").Visible(false).MinWidth(125);
                     columns.Add().DataField("ActionDate").Caption("Action Date").Visible(false).MinWidth(125);
                     columns.Add().DataField("ID").Caption("ID").Visible(false).MinWidth(125).SortOrder(SortOrder.Asc);
                     columns.Add().DataField("TR_ID").Caption("Tr.ID").Visible(false).MinWidth(125).SortOrder(SortOrder.Asc);
                     columns.Add().DataField("RemarkCount").Caption("RemarkCount").Visible(false).MinWidth(125);
                     columns.Add().DataField("RemarkStatus").Caption("RemarkStatus").Visible(false).MinWidth(125);
                     columns.Add().DataField("Remarks").Caption("Remarks").Visible(false).MinWidth(125);
                     columns.Add().DataField("OpenActions").Caption("OpenActions").Visible(false).MinWidth(125);
                     columns.Add().DataField("CrossedTimeLimit").Caption("CrossedTimeLimit").Visible(false).MinWidth(125);
                     columns.Add().DataField("REJECTED_COUNT").Caption("iREJECTED_COUNT").Visible(false).MinWidth(125);
                     columns.Add().DataField("RESPONDED_COUNT").Caption("iRESPONDED_COUNT").Visible(false).MinWidth(125);
                     columns.Add().DataField("COMPLETE_ATTACH_COUNT").Caption("iCOMPLETE_ATTACH_COUNT").Visible(false).MinWidth(125);
                     columns.Add().DataField("REQ_ATTACH_COUNT").Caption("iREQ_ATTACH_COUNT").Visible(false).MinWidth(125);
                     columns.Add().DataField("OTHER_ATTACH_CNT").Caption("OTHER_ATTACH_CNT").Visible(false).MinWidth(125);
                     columns.Add().DataField("ALL_ATTACH_CNT").Caption("ALL_ATTACH_CNT").Visible(false).MinWidth(125);

                 })            
                 .Summary(s =>

                 {

                     s.TotalItems(item => item.Add().Name("Advance_Advance_sum").SummaryType(SummaryType.Sum).Column("Advance").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}")));
                     s.TotalItems(item => item.Add().Name("Refund_Refund_sum").SummaryType(SummaryType.Sum).Column("Refund").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}")));
                     s.TotalItems(item => item.Add().Name("Adjusted_Adjusted_sum").SummaryType(SummaryType.Sum).Column("Adjusted").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}")));

                     s.TotalItems(item => item.Add().Name("OutStanding_OutStanding_sum").SummaryType(SummaryType.Sum).Column("OutStanding").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}")));

                     s.RecalculateWhileEditing(true);
                 })
         .MasterDetail(md =>
         {
             md.AutoExpandAll(false);
             md.Enabled(!VouchingMode);
             md.Template(new JS("AdvancesListGrid_dx_DetailTemplate"));
         })
         .OnInitialized("AdvancesListGrid_dx_OnInitialized")
         .OnCellPrepared("AdvancesListGrid_dx_OnCellPrepared")
         .OnRowPrepared("AdvancesListGrid_dx_OnRowPrepared")
         .OnContentReady("AdvancesListGrid_dx_OnContentReady")
         .OnCellDblClick("AdvancesListGrid_dx_OnCellDblClick")
         .OnSelectionChanged("AdvancesListGrid_dx_OnSelectionChanged")
         .OnRowExpanding("AdvancesListGrid_dx_OnRowExpanding")
         .OnRowCollapsing("AdvancesListGrid_dx_OnRowCollapsing")
         .OnContextMenuPreparing("AdvancesListGrid_dx_OnContextMenuPreparing")        
 )