            });*@
            OpenPopup("Advances_report_modal", "Export Option", "@Url.Action("Frm_Export_Options_dx", "Advances", new { @area = "Profile" })", "auto", 125, false, null);
        }
        function Advances_UpdateFooterDetail(Advances_ID, Advances_Action_Status, Advances_Add_Date, Advances_Add_By, Advances_Action_Date, Advances_Action_By, Advances_Edit_Date, Advances_Edit_By) {

            var Status = "";
            var Lbl_Status = "";
            var Lbl_StatusBy = "";
            var Pic_Status = "";
            var Lbl_Create = "";
            var Lbl_Modify = "";
            var Lbl_Status_Color = "";
            var Lbl_ActionOn = "";
            var Lbl_ActionBy = "";

            Status = Advances_Action_Status;

            if (Status && Status.toUpperCase() == "LOCKED") {
                Lbl_Status = "Completed";
                Lbl_Status_Color = "blue";
                Pic_Status = "Fa Fa-Lock";
            }
            else {
                Pic_Status = "Fa Fa-UnLock";
                Lbl_Status = Status;
                if (Status && Status.toUpperCase() == "COMPLETED")
                    Lbl_Status_Color = "green";
                else
                    Lbl_Status_Color = "red";
            }

            if (Advances_Add_Date) {
                Lbl_Create = "Add On: " + Advances_Add_Date + ", By: " + Advances_Add_By;
            }
            else {
                Lbl_Create = "Add On: " + "?, By: " + Advances_Add_By;
            }
            if (Advances_Edit_Date) {
                Lbl_Modify = "Edit On: " + Advances_Edit_Date + ", By: " + Advances_Edit_By;
            }
            else {
                Lbl_Modify = "Edit On: " + "?, By: " + Advances_Edit_By;
            }
            if (Advances_Action_Date) {
                Lbl_ActionOn = "UnLocked On: " + Advances_Action_Date;
            }
            else {
                Lbl_ActionOn = "UnLocked On: " + "?";
            }

            Lbl_ActionBy = "UnLocked By: " + Advances_Action_By;

            $('#Advances_Lbl_Status').text(Lbl_Status);
            $('#Advances_Lbl_Create').text(Lbl_Create);
            $('#Advances_Lbl_ActionOn').text(Lbl_ActionOn);
            $('#Advances_Lbl_ActionBy').text(Lbl_ActionBy);
            $('#Advances_Lbl_Modify').text(Lbl_Modify);
            if (Lbl_Status_Color != "") {
                $('#Advances_Lbl_Status').css('color', Lbl_Status_Color);
            }
            if (Pic_Status != "") {
                $('#Advances_LockICON').css('class', Pic_Status);
            }
        }
        function closeProfile_Advances() {
            $(".TabPanalMenu-tabs .active span").click();

        }

    </script>
    <script>
        function AdvancesListGrid_dx_OnInitialized(e) {
            DxGrid_AdjustSize(e.component, $("#AdvancesProfile_ParentDiv .report_button_div"))
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                DxGrid_AdjustSize(e.component, $("#AdvancesProfile_ParentDiv .report_button_div"), "", evt)
            });
            AdvancesListGrid_dx = e.component;
        }
        function AdvancesListGrid_dx_OnCellPrepared(e) {
            if (e.rowType == "data") {
                if (Advances_IsVouchingMode == true) {
                    if (e.column.dataField === "iIcon") {
                        $(e.cellElement).attr("onmouseover", "OnGridRowMouseHoverIn(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.key + "')");
                        $(e.cellElement).attr("onmouseout", "OnGridRowMouseHoverOut(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.key + "')");
                    }
                }
                $(e.cellElement).attr("id", e.element[0].id + "_Cell_" + e.key + "|" + e.column.dataField);
                if (e.column.dataField === "OutStanding") {
                    if (e.data.OutStanding > 0.00)
                        e.cellElement.css({ "background-color": "lightpink" });
                    //e.cellElement.addClass("BalanceBgColour");
                }
            }
        }
        function AdvancesListGrid_dx_OnRowPrepared(e) {
            if (e.rowType == "data") {
                var GridName = e.element[0].id;
                $(e.rowElement).addClass(GridName + "_DataRow_" + e.key)
                if (e.data.RemarkStatus != null && e.data.RemarkStatus == "OPEN" || e.data.RemarkStatus == "REOPENED") {
                    $(e.rowElement).css("background-color", "gold");
                }
                if (e.data.RemarkStatus == null && e.data.Remarks != null && e.data.Remarks == true && e.data.CrossedTimeLimit != null && e.data.CrossedTimeLimit == 0) {
                    $(e.rowElement).css("background-color", "lightgreen");
                }
                if (e.data.CrossedTimeLimit != null && e.data.CrossedTimeLimit > 0) {
                    $(e.rowElement).css("background-color", "mistyrose");
                }
                DxGrid_CreatePreviewRow(e, Advances_IsVouchingMode, "Master")
            }
            else if (e.rowType == "detailAdaptive")
            {
                DxGrid_MovePreviewRowAfterAdaptiveRow(e)
            }
        }
        function AdvancesListGrid_dx_OnContentReady(e) {
            DxGrid_OnContentReady(e, Advances_ShowHorizontalBar);
        }
        function AdvancesListGrid_dx_OnCellDblClick(e) {
            if (e.rowType == "data") {
                if (Advances_IsVouchingMode == true && Advances_ViewMode == "Default") {
                    OnGridCellClick(e.event, e.cellElement[0], e.columnIndex, e.rowIndex, e.element[0].id, e.key, e.column.dataField)
                }
                else if (Advances_IsVouchingMode == false) {
                    //if (e.rowType == "data")
                    //BankProfile_OnEditClick_dx();
                }
            }
        }
        function AdvancesListGrid_dx_OnSelectionChanged(e) {
            var selectedRowKeys = e.selectedRowKeys;
            if (selectedRowKeys != null && selectedRowKeys.length > 0) {
                if (Advances_IsVouchingMode) {
                    AdvancesPrf_FAB.SetVisible(true);
                    AdvancesPrf_FAB.SetActionContext("AddAttachmentContext", false);
                }
                AdvancesListGrid_dx_SelectedRowData(e.selectedRowsData);
            }
            else {
                AdvancesID = null;
                Advances_UpdateFooterDetail(AdvancesID, Advances_ActionStatus, Advances_AddDate, Advances_AddBy,
                    Advances_ActionDate, Advances_ActionBy, Advances_EditDate, Advances_EditBy);
            }
        }
        function AdvancesListGrid_dx_SelectedRowData(selectedData = null) {
            if (selectedData == null) {
                selectedData = AdvancesListGrid_dx.getSelectedRowsData();
            }
            if (selectedData != null && selectedData.length > 0) {
                var values = selectedData[0]

                AdvancesID = values["ID"];
                ITEM_NAME = values["ITEM_NAME"];
                PARTY_NAME = values["PARTY_NAME"];
                AI_ADV_DATE = values["AI_ADV_DATE"];
                AI_OTHER_DETAIL = values["AI_OTHER_DETAIL"];
                Advance = values["Advance"];
                Advances_EditDate = values["EditDate"];
                YearId = values["YearId"];
                TR_ID = values["TR_ID"];
                AI_PARTY_ID = values["AI_PARTY_ID"];
                Advances_AddDate = values["AddDate"];
                Advances_AddBy = values["AddBy"];
                Advances_EditBy = values["EditBy"];
                Advances_ActionStatus = values["ActionStatus"];
                Advances_ActionDate = values["ActionDate"];
                Advances_ActionBy = values["ActionBy"];
                Advances_Type = values["Type"];
                Advances_UpdateFooterDetail(AdvancesID, Advances_ActionStatus, Advances_AddDate, Advances_AddBy,
                    Advances_ActionDate, Advances_ActionBy, Advances_EditDate, Advances_EditBy);
                if (Advances_IsVouchingMode == true) {
                    OpenLeftPane();
                    LeftPaneContent_Advances_dx("AdvancesListGrid_dx", AdvancesID, Advances_IsVouchingMode)
                }
            }
            else {
                AdvancesID = null;
            }
        }
        function AdvancesListGrid_dx_OnRowExpanding(e) {
            if (Array.isArray(e.key) == false) //not group row
            {
                e.component.collapseRow(Expanded_Row_Key_Advances_dx)
                e.component.selectRows(e.key);
                Expanded_Row_Key_Advances_dx = e.key;
                AdvancesInfo_IsDetailRowExpanded = true;
                var DetailGridID = e.element[0].id + e.key;
                var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
                if (instance != void 0) {
                    instance.state(null) // grid maintains its state after collapsing so resetting the state when expands again as per old grid
                }
                //e.component.collapseAll(-1);
            }
            else {
                e.component.option("CustomProp.groupRowExpanded", true);
            }
        }
        function AdvancesListGrid_dx_OnRowCollapsing(e) {
            if (Array.isArray(e.key) == false) //not group row
            {
                var DetailGridID = e.element[0].id + e.key;
                sessionStorage.removeItem(DetailGridID + "_DetailGridState") //removing grid state from session storage on collapse
                AdvancesInfo_IsDetailRowExpanded = false;
                e.component.selectRows(e.key);
                if (Advances_IsVouchingMode == false) {
                    AdvancesPrf_FAB.SetVisible(false);
                }
                var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
                if (instance != void 0) {
                    instance.clearSelection();
                }
            }
            else {
                e.component.option("CustomProp.groupRowCollapsed", true);
            }
        }
        function AdvancesListGrid_dx_OnContextMenuPreparing(e) {
            if (!e.items) e.items = [];
            if (e.target == "header") {

                DxGrid_HeaderContextMenu(e)
            }
            else if ((e.target == "content" && e.row && e.row.rowType == "groupFooter") || e.target == "footer") {
                if (Advances_ViewMode == "Compact")
                    DxGrid_FooterContextMenu(e, true);
                else
                    DxGrid_FooterContextMenu(e);
            }
            else if (e.target == "content" && e.row && (e.row.rowType == "data" || e.row.rowType == "detailAdaptive")) {
                var key = e.component.getKeyByRowIndex(e.row.rowIndex);
                e.component.selectRows(key);
                var expanded = e.component.isRowExpanded(key);
                e.items = [
                    {
                        text: "Expand Detail",
                        icon: "fa-solid fa-arrow-down-wide-short " + (expanded ? "text-muted" : "text-info"),
                        disabled: expanded,
                        visible: !Advances_IsVouchingMode,
                        onItemClick: function () {
                            if (expanded) {
                            }
                            else {
                                e.component.expandRow(key);
                            }
                        }
                    }, {
                        text: "Collapse Detail",
                        icon: "fa-solid fa-arrow-up-wide-short " + (!expanded ? "text-muted" : "text-info"),
                        disabled: !expanded,
                        visible: !Advances_IsVouchingMode,
                        onItemClick: function () {
                            if (expanded) {
                                e.component.collapseRow(key);
                            }
                            else {
                            }
                        }
                    },
                    {
                        text: "Export",
                        icon: "fa-solid fa-file-export text-warning",
                        visible: "@Advances_ExportRight" == "True",
                        beginGroup: true,
                        onItemClick: function () {
                            OnAdvancesListPreviewClick();
                        }
                    },
                    {
                        text: "Close",
                        icon: "fa-solid fa-rectangle-xmark text-danger",
                        beginGroup: true,
                        onItemClick: function () {
                            closeProfile_Advances();
                        }
                    },
                    {
                        text: "Refresh",
                        icon: "fa-solid fa-arrow-rotate-right text-success",
                        beginGroup: true,
                        onItemClick: function () {
                            AdvancesListGrid_dx_Refresh();
                        }
                    }]
            }
        }


        function  AdvancesListGrid_dx_DetailTemplate(container, templateData) {
            var GridName = templateData.component.element()[0].id
            var RecID = templateData.data.ID;
            AdvancesListGrid_dx_Detail(container, GridName, RecID, Advances_IsVouchingMode, Advances_ShowHorizontalBar);
        }
        function AdvancesListGrid_dx_Detail(container, GridName, RecID, vouchingMode, AllColumns)
        {
            var url = "/Profile/Advances/Frm_Advances_Info_DetailGrid_dx?VouchingMode=" + vouchingMode + "&RecID=" + RecID
            var instance = DxGrid_AttachmentGrid_Create(container, GridName, RecID, vouchingMode, AllColumns, url)
            instance.option("onSelectionChanged", AdvancesListGrid_dx_Detail_onSelectionChanged);
        }   
        function AdvancesListGrid_dx_Detail_onSelectionChanged(e) {
            if (AdvancesInfo_IsDetailRowExpanded || Advances_IsVouchingMode) {
                if (e.selectedRowsData != null && e.selectedRowsData.length > 0) {
                    AdvancesInfo_NestedGrid_AccessID = e.element[0].id;
                    AdvancesListGrid_dx_Detail_SelectedRowData(e.selectedRowsData)
                }
                else {
                    AdvancesPrf_FAB.SetActionContext("AddAttachmentContext", false);
                }
            }
        }
        function AdvancesListGrid_dx_Detail_SelectedRowData(selectedData = null) {
            if (selectedData == null) {
                selectedData = $("#" + AdvancesInfo_NestedGrid_AccessID).dxDataGrid("getSeletedRowsData");
            }
            var values = selectedData[0];
            AdvancesInfo_NestedRowKeyValue  = values["UniqueID"];
            if (values["UniqueID"] != null) {
                AdvancesPrf_FAB.SetVisible(true);
                AdvancesInfo_Nested_Doc_Status = values["Doc_Status"];

                if (Advances_IsVouchingMode == true) {
                    AdvancesPrf_FAB.SetActionContext("AuditActionContext", true);
                }
                else {
                    if (AdvancesInfo_Nested_Doc_Status == "") {
                        AdvancesPrf_FAB.SetActionContext("AutoItemContext", true);
                    }
                    else if (AdvancesInfo_Nested_Doc_Status == "NO") {
                        AdvancesPrf_FAB.SetActionContext("EditItemContext", true);
                    }
                    else if (AdvancesInfo_Nested_Doc_Status == "YES") {
                        AdvancesPrf_FAB.SetActionContext("actionItemContext", true);
                    }
                }
                AdvancesInfo_ParamMandatory  = values["Params_Mandatory"];
                AdvancesInfo_FromDateLabel  = values["LABEL_FROM_DATE"];
                AdvancesInfo_ToDateLabel  = values["LABEL_TO_DATE"];
                AdvancesInfo_DescriptionLabel  = values["LABEL_DESCRIPTION"];
                AdvancesInfo_Doc_Category  = values["Document_Category"];
                AdvancesInfo_Doc_ID = values["Document_ID"];
                AdvancesInfo_AtachmentID = values["ATTACH_ID"];
                IndexAttachmentID = AdvancesInfo_AtachmentID;
                AdvancesInfo_MasterRowRecID = values["TxnID"];
                AdvancesInfo_MasterRowMID = values["TxnMID"];
                AdvancesInfo_NestedRowMapID = values["MAP_ID"];
                AdvancesInfo_reason = values["Reason"];
                AdvancesInfo_FileName = values["ATTACH_FILE_NAME"];
                AdvancesInfo_Attachment_RecStatus = values["Attachment_Action_Status"];
                if (Advances_IsVouchingMode == true) {
                    if (AdvancesInfo_FileName != null && AdvancesInfo_FileName.length > 0) {
                        ViewDocument(AdvancesInfo_AtachmentID, AdvancesInfo_FileName, "AdvancesPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                    }
                    else {
                        CloseRightPane();
                        ClearRightPane();
                    }
                }
            }
            AdvancesInfo_NestedRowReasonID = values["ReasonID"];
            IndexAttachmentReasonID = AdvancesInfo_NestedRowReasonID;
        }
    </script>
