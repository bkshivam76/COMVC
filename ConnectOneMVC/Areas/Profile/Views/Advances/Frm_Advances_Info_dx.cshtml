    function On_AdvancesProfile_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@Help_Attachment_AddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (AdvancesInfo_ParamMandatory == 1)
            {
                AddAttachment(AdvancesInfo_MasterRowRecID, "Profile_Advances", AdvancesInfo_Doc_ID, AdvancesInfo_Doc_Category, AdvancesInfo_ParamMandatory, AdvancesInfo_FromDateLabel, AdvancesInfo_ToDateLabel, AdvancesInfo_DescriptionLabel, "AdvancesProfileAttachment", null, "AdvancesListGrid_dx", AdvancesInfo_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(AdvancesInfo_MasterRowRecID, "Profile_Advances", AdvancesInfo_Doc_ID, "AdvancesProfileAttachment", "AdvancesListGrid_dx", AdvancesInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (AdvancesInfo_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(AdvancesInfo_MasterRowRecID, "Profile_Advances", AdvancesInfo_AtachmentID, AdvancesInfo_ParamMandatory, AdvancesInfo_FromDateLabel, AdvancesInfo_ToDateLabel, AdvancesInfo_DescriptionLabel, "AdvancesProfileAttachment", null, "AdvancesListGrid_dx", AdvancesInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(AdvancesInfo_MasterRowRecID, "Profile_Advances", AdvancesInfo_AtachmentID, AdvancesInfo_ParamMandatory, AdvancesInfo_FromDateLabel, AdvancesInfo_ToDateLabel, AdvancesInfo_DescriptionLabel, null, "AdvancesListGrid_dx", AdvancesInfo_NestedGrid_AccessID, AdvancesInfo_Attachment_RecStatus);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@Help_Attachment_ViewRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            ViewDocument(AdvancesInfo_AtachmentID, AdvancesInfo_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(AdvancesInfo_MasterRowRecID, "Profile_Advances", "Advances Information", "AdvancesListGrid_dx", AdvancesInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Add_Reason")
        {
            if (AdvancesInfo_Doc_Category.toLowerCase() == "others")
            {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else
            {
                AttachmentAddReason(AdvancesInfo_MasterRowRecID, AdvancesInfo_NestedRowMapID, "Profile_Advances", "AdvancesListGrid_dx", AdvancesInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(AdvancesInfo_MasterRowRecID, AdvancesInfo_NestedRowMapID, "Profile_Advances", "AdvancesListGrid_dx", AdvancesInfo_NestedGrid_AccessID, AdvancesInfo_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(AdvancesInfo_MasterRowRecID, AdvancesInfo_NestedRowMapID, "AdvancesListGrid_dx", AdvancesInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
        else if (e.actionName == "AuditAction")
        {
            AdvancesPrf_FAB.SetActionContext("AuditActionContext", true);
        }
        else if (e.actionName == "BackAudit")
        {
            if (AdvancesInfo_Nested_Doc_Status == "")
            {
                AdvancesPrf_FAB.SetActionContext("AutoItemContext", true);
            }
            if (AdvancesInfo_Nested_Doc_Status == "NO")
            {
                AdvancesPrf_FAB.SetActionContext("EditItemContext", true);
            }
            if (AdvancesInfo_Nested_Doc_Status == "YES")
            {
                AdvancesPrf_FAB.SetActionContext("actionItemContext", true);
            }
        }
        else if (e.actionName == "Accept")
        {
            AdvancesInfo_AcceptwithoutRemarks();
        }
        else if (e.actionName == "Reject")
        {
            AdvancesInfo_AcceptRejectVoucher("Reject");
        }
        else if (e.actionName == "AcceptWithRemarks")
        {
            AdvancesInfo_AcceptRejectVoucher("Accept");
        }
        else if (e.actionName == "AcceptDoc") {

            OnAdvancesInfo_AcceptDoc();
        }
        else if (e.actionName == "RejectDoc") {

            OnAdvancesInfo_RejectDoc();
        }
    }
    function OnAdvancesInfo_RejectDoc() {
        if (AdvancesInfo_AtachmentID == null || AdvancesInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        RejectAttachment(AdvancesInfo_AtachmentID, "AdvancesListGrid_dx", AdvancesInfo_NestedGrid_AccessID);
    }
    function OnAdvancesInfo_AcceptDoc() {
        if (AdvancesInfo_AtachmentID == null || AdvancesInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        AcceptAttachment(AdvancesInfo_AtachmentID, "AdvancesListGrid_dx", AdvancesInfo_NestedGrid_AccessID);
    }
    function AdvancesInfo_AcceptwithoutRemarks()
    {
        var Recid;
        if (AdvancesInfo_IsDetailRowExpanded == true || Advances_IsVouchingMode == true)
        {
            if (AdvancesInfo_MasterRowRecID == null || AdvancesInfo_MasterRowRecID == "")
            {
                Recid = AdvancesID;
            }
            else
            {
                Recid = AdvancesInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = AdvancesID;
        }
        Entry_AcceptwithoutRemarks(Recid, "Profile_Advances", "AdvancesListGrid_dx", AdvancesInfo_AtachmentID, AdvancesInfo_NestedRowReasonID, AdvancesInfo_NestedRowKeyValue );
    }
    function AdvancesInfo_AcceptRejectVoucher(_actionMethod)
    {
        var Recid;
        if (AdvancesInfo_IsDetailRowExpanded == true || Advances_IsVouchingMode == true)
        {
            if (AdvancesInfo_MasterRowRecID == null || AdvancesInfo_MasterRowRecID == "")
            {
                Recid = AdvancesID;
            }
            else
            {
                Recid = AdvancesInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = AdvancesID;
        }
        Entry_AcceptReject(_actionMethod, Recid, "Profile_Advances", "AdvancesListGrid_dx", AdvancesInfo_AtachmentID, AdvancesInfo_NestedRowReasonID, AdvancesInfo_NestedRowKeyValue);
    }
    function OnAdvancesListGridNestedFocusedRowChange(s, e)
    {
        if (AdvancesInfo_IsDetailRowExpanded ==true || Advances_IsVouchingMode == true)
        {
            AdvancesInfo_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
            if (AdvancesInfo_NestedRecord_FocusedRowIndex >= 0)
            {
                ShowLoader();
                AdvancesInfo_NestedGrid_AccessID = s.uniqueID;
                s.GetRowValues(s.GetFocusedRowIndex(), 'Doc_Status;Params_Mandatory;LABEL_FROM_DATE;LABEL_TO_DATE;LABEL_DESCRIPTION;Document_Category;Document_ID;ATTACH_ID;TxnID;TxnMID;MAP_ID;Reason;ATTACH_FILE_NAME;Attachment_Action_Status;UniqueID;ReasonID', OnAdvancesInfo_GetGridRowValues);
            }
            else
            {
                AdvancesPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }
    function OnAdvancesInfo_GetGridRowValues(values)
    {
        HideLoader();
        if (values[14] != null)
        {
            AdvancesPrf_FAB.SetVisible(true);
            AdvancesInfo_Nested_Doc_Status = values[0];
            if (Advances_IsVouchingMode == true)
            {
                AdvancesPrf_FAB.SetActionContext("AuditActionContext", true);
            }
            else
            {
                if (AdvancesInfo_Nested_Doc_Status == "")
                {
                    AdvancesPrf_FAB.SetActionContext("AutoItemContext", true);
                }
                else if (AdvancesInfo_Nested_Doc_Status == "NO")
                {
                    AdvancesPrf_FAB.SetActionContext("EditItemContext", true);
                }
                else if (AdvancesInfo_Nested_Doc_Status == "YES")
                {
                    AdvancesPrf_FAB.SetActionContext("actionItemContext", true);
                }
            }
            AdvancesInfo_ParamMandatory = values[1];
            AdvancesInfo_FromDateLabel = values[2];
            AdvancesInfo_ToDateLabel = values[3];
            AdvancesInfo_DescriptionLabel = values[4];
            AdvancesInfo_Doc_Category = values[5];
            AdvancesInfo_Doc_ID = values[6];
            AdvancesInfo_AtachmentID = values[7];
            IndexAttachmentID = AdvancesInfo_AtachmentID;
            AdvancesInfo_MasterRowRecID = values[8];
            AdvancesInfo_MasterRowMID = values[9];
            AdvancesInfo_NestedRowMapID = values[10];
            AdvancesInfo_reason = values[11];
            AdvancesInfo_FileName = values[12];
            AdvancesInfo_Attachment_RecStatus = values[13];
            AdvancesInfo_NestedRowKeyValue = values[14];
            if (Advances_IsVouchingMode == true)
            {
                if (AdvancesInfo_FileName != null && AdvancesInfo_FileName.length > 0)
                {
                    ViewDocument(AdvancesInfo_AtachmentID, AdvancesInfo_FileName, "AdvancesPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else
                {
                    CloseRightPane();
                    ClearRightPane();
                }
            }
        }
        AdvancesInfo_NestedRowReasonID = values[15];
        IndexAttachmentReasonID = AdvancesInfo_NestedRowReasonID;
    }
    function AdvancesGrid_Nested_BeginCallBack(s, e)
    {
        e.customArgs["ShowHorizontalBar"] = Advances_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = Advances_IsVouchingMode;
        e.customArgs["command"] = e.command;
    }
    function AdvancesGrid_DetailRowExpanding(s, e)
    {
        AdvancesInfo_IsDetailRowExpanded = true;
        s.SetFocusedRowIndex(e.visibleIndex);
        var pane = Mainspliter.GetPaneByName('RightPane');
        if (Advances_IsVouchingMode == true)
        {
            pane.Expand();
        }
        else
        {
            pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
        }
    }
    function AdvancesGrid_DetailRowCollapsing(s, e)
    {
        AdvancesInfo_IsDetailRowExpanded = false;
        s.SetFocusedRowIndex(e.visibleIndex);
        if (Advances_IsVouchingMode == true)
        {
            if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false)
            {
                CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
        else
        {
            AdvancesPrf_FAB.SetVisible(false);
        }
    }
