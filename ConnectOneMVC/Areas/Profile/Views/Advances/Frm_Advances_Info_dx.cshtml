        function AdvancesIsDate(val) {
            var d = new Date(val);
            return !isNaN(d.valueOf());
        }

        function AdvancesOnUnLockClick() {
            if ("@Advances_LockUnlockRight" == "False")
            {
	            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	            return;
            }
            if (AdvancesID == 'undefined' || AdvancesID == undefined) {
                DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
                return;
            }
            $.ajax({
                type: 'GET',
                url: "/Profile/Advances/DataNavigation",
                data: { ActionMethod: "UNLOCKED", id: AdvancesID, TR_ID: TR_ID, YearID: YearId, AI_PARTY_ID: AI_PARTY_ID, ActionStatus: Advances_ActionStatus, EditDate: Advances_EditDate, Type: Advances_Type },
                cache: false,
                success: function (Advances_UNLOCKED_Get_DataNavigation_result) {
                    if (Advances_UNLOCKED_Get_DataNavigation_result.result == "NoUnLockRights") {
                        DevExpress.ui.dialog.alert(Advances_UNLOCKED_Get_DataNavigation_result.Message,"Locked..");
                    }
                    else {
                        DevExpress.ui.dialog.alert(Advances_UNLOCKED_Get_DataNavigation_result.Message);
                    }
                }
            });
        }

        function AdvancesOnLockClick() {
            if ("@Advances_LockUnlockRight" == "False")
            {
	            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	            return;
            }
            if (AdvancesID == 'undefined' || AdvancesID == undefined) {
                DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
                return;
            }
            $.ajax({
                type: 'GET',
                url: "/Profile/Advances/DataNavigation",
                data: { ActionMethod: "LOCKED", id: AdvancesID, TR_ID: TR_ID, YearID: YearId, AI_PARTY_ID: AI_PARTY_ID, ActionStatus: Advances_ActionStatus, EditDate: Advances_EditDate, Type: Advances_Type },
                cache: false,
                success: function (Advances_LOCKED_Get_DataNavigation_result) {
                    if (Advances_UNLOCKED_Get_DataNavigation_result.result == "NoLockRights") {
                        DevExpress.ui.dialog.alert(Advances_UNLOCKED_Get_DataNavigation_result.Message, "Locked..");
                    }
                    else {
                        DevExpress.ui.dialog.alert(Advances_LOCKED_Get_DataNavigation_result.Message);
                    }
                }
            });
        }

        function OnAdvancesNewClick() {
            if ("@Advances_AddRight" == "False")
            {
	            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	            return;
            }
            IsAdvancesNewPopup = true;
            IsAdvancesViewPopup = false;
            IsAdvancesEditPopup = false;
            $("#popup_frm_Advances_Window").dxPopup("show");
            $("#popup_frm_Advances_Window").dxPopup("instance").option("title", "New ~ Advances");
            $("#Advancesresult").html('');
            ShowLoader();
            $("#Advancesresult").load("@Url.Action("frm_Advances_window", "Advances", new { @area = "Profile" })?ActionMethod=New", function () {
                HideLoader();
                $("#ItemID").dxSelectBox('instance').focus();
            });
        }

        function OnAdvancesEditClick() {
            if ("@Advances_UpdateRight" == "False")
            {
	            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	            return;
            }
            IsAdvancesNewPopup = false;
            IsAdvancesEditPopup = true;
            if (AdvancesID == 'undefined' || AdvancesID == undefined) {
                DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
                return;
            }
            $.ajax({
                type: 'GET',
                url: "/Profile/Advances/DataNavigation",
                data: { ActionMethod: "Edit", id: AdvancesID, TR_ID: TR_ID, YearID: YearId, AI_PARTY_ID: AI_PARTY_ID, ActionStatus: Advances_ActionStatus, EditDate: Advances_EditDate },
                cache: false,
                async: true,
                success: function (Advances_Edit_ButtonClick_result) {
                    if (Advances_Edit_ButtonClick_result.result == "true" || Advances_Edit_ButtonClick_result.result == true) {
                        $("#popup_frm_Advances_Window").dxPopup("show");
                        $("#popup_frm_Advances_Window").dxPopup("instance").option("title", "Edit ~ Advances");
                        $("#Advancesresult").html('');
                        ShowLoader();
                        $("#Advancesresult").load('@Url.Action("frm_Advances_window", "Advances", new { @area = "Profile" })?ActionMethod=Edit&ID=' + AdvancesID + '&EditedOn=' + encodeURIComponent(Advances_EditDate), function () {
                            HideLoader();
                            $("#ItemID").dxSelectBox('instance').focus();
                        });
                    }
                    else {
                        DevExpress.ui.dialog.alert(Advances_Edit_ButtonClick_result.Message);
                        AdvancesListGrid.Refresh();
                    }
                }
            });
        }

        function OnAdvancesViewClick() {
            if ("@Advances_ViewRight" == "False")
            {
	            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	            return;
            }
            IsAdvancesNewPopup = false;
            IsAdvancesEditPopup = false;
            IsAdvancesViewPopup = true;
            if (AdvancesID == 'undefined' || AdvancesID == undefined) {
                DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
                return;
            }
            $.ajax({
                type: 'GET',
                url: "/Profile/Advances/DataNavigation",
                data: { ActionMethod: "View", id: AdvancesID, TR_ID: TR_ID, YearID: YearId, AI_PARTY_ID: AI_PARTY_ID, ActionStatus: Advances_ActionStatus, EditDate: Advances_EditDate },
                cache: false,
                success: function (Advances_View_ButtonClick_result) {
                    if (Advances_View_ButtonClick_result.result == "true" || Advances_View_ButtonClick_result.result == true) {
                        $("#popup_frm_Advances_Window").dxPopup("show");
                        $("#popup_frm_Advances_Window").dxPopup("instance").option("title", "View ~ Advances");
                        $("#Advancesresult").html('');
                        ShowLoader();
                        $("#Advancesresult").load("@Url.Action("frm_Advances_window", "Advances", new { @area = "Profile" })?ActionMethod=" + "View" + "&ID=" + AdvancesID + "&EditedOn=" + encodeURIComponent(Advances_EditDate), function () {
                            HideLoader();
                        });
                    }
                    else {
                        DevExpress.ui.dialog.alert(Advances_View_ButtonClick_result.Message);
                        AdvancesListGrid.Refresh();
                    }
                }
            });
        }

        function OnAdvancesDeleteClick() {
            if ("@Advances_DeleteRight" == "False")
            {
	            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	            return;
            }
            IsAdvancesNewPopup = false;
            IsAdvancesEditPopup = false;
            IsAdvancesViewPopup = false;
            if (AdvancesID == 'undefined' || AdvancesID == undefined) {
                DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
                return;
            }
            var result = DevExpress.ui.dialog.confirm("Sure you want to delete?", "Confirm changes");
            result.done(function (dialogResult) {
                if (dialogResult) {
                    $("#popup_frm_Advances_Window_Close").dxPopup("hide");

                    $.ajax({
                        type: 'GET',
                        url: "/Profile/Advances/DataNavigation",
                        data: { ActionMethod: "Delete", id: AdvancesID, TR_ID: TR_ID, YearID: YearId, AI_PARTY_ID: AI_PARTY_ID, ActionStatus: Advances_ActionStatus, EditDate: Advances_EditDate },
                        cache: false,
                        success: function (Advances_Delete_ButtonClick_result) {
                            if (Advances_Delete_ButtonClick_result.result == "true" || Advances_Delete_ButtonClick_result.result == true) {
                                $("#popup_frm_Advances_Window").dxPopup("show");
                                $("#popup_frm_Advances_Window").dxPopup("instance").option("title", "Delete ~ Advances");
                                $("#Advancesresult").load("@Url.Action("frm_Advances_window", "Advances", new { @area = "Profile" })?ActionMethod=" + "Delete" + "&ID=" + AdvancesID + "&EditedOn=" + encodeURIComponent(Advances_EditDate), function () {
                                    HideLoader();
                                    $("#AdvancesDelete").dxButton('instance').focus();
                                });
                            }
                            else {
                                DevExpress.ui.dialog.alert(Advances_Delete_ButtonClick_result.Message);
                                AdvancesListGrid.Refresh();
                            }
                        }
                    });
                }
            });
        }



        function AdvancesContextMenuFunction(s, e) {
            if (e.item.name == 'New') {
                OnAdvancesNewClick();
            }
            if (e.item.name == 'Close') {
                closeProfile_Advances();
            }
            else if (e.item.name == 'Edit') {
                OnAdvancesEditClick();
            }
            else if (e.item.name == 'Delete') {
                OnAdvancesDeleteClick();
            }
            else if (e.iIsAuditoruditoruditorem.name == 'View') {
                OnAdvancesViewClick();
            }
            else if (e.item.name == 'ListPreview') {
                OnAdvancesListPreviewClick();
            }
            else if (e.item.name == 'AuditActions') {
                OnAdvancesAuditActionsClick();
            }
            else if (e.item.name == 'Unlock') {
                AdvancesOnUnLockClick();
            }
            else if (e.item.name == 'Lock') {
                AdvancesOnLockClick();
            }
            else if (e.item.name == 'Refresh') {
                AdvancesListGrid.Refresh();
