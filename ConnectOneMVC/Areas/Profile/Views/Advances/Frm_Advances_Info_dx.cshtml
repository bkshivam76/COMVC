    function OnAdvancesCellClick(event, cell,col, row)
    {
        if (UserType_AdvancesPrf == "AUDITOR" || UserType_AdvancesPrf == "SUPERUSER")
        {
            if (event.button == 0)
            {
                if (cell.style.backgroundColor.length > 0)
                {
                    cell.style.backgroundColor = "";
                }
                else
                {
                    cell.style.backgroundColor = 'skyblue';
                }
            }
        }
    }
        function AdvancesAjaxSuccessForm(data) {
            HideLoader();
            if (data.result == false) {
                DevExpress.ui.dialog.alert(data.Message, "Error");
            }
            else {
                IsAdvancesSucessPopup = true;
                var advancesSubmitSuccess = DevExpress.ui.dialog.alert(data.Message, "Success");
                $("#popup_frm_Advances_Window").dxPopup("hide");
                AdvancesListGrid.Refresh();
                IsAdvancesSucessPopup = false;
                advancesSubmitSuccess.done(function (alertResult) {
                    if (alertResult) {
                        if (IsAdvancesNewPopup == true) {
                            var addmoreresult = DevExpress.ui.dialog.confirm("Add More Entry...?", "Advances");
                            addmoreresult.done(function (dialogResult) {
                                if (dialogResult) {
                                    OnAdvancesNewClick();
                                }
                            });
                        }
                        if (IsAdvancesEditPopup == true) {
                            var lockresult = DevExpress.ui.dialog.confirm("Do you want to Lock this Entry...?", "Confirmation");
                            lockresult.done(function (dialogResult) {
                                if (dialogResult) {
                                    AdvancesOnLockClick();
                                }
                            });
                        }
                    }
                });
            }
        }


