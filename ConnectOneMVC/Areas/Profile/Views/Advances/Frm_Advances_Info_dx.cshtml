    <script>
        function Advances_VouchingSwitch_ValueChange(e) {
            Advances_IsVouchingMode = e.value;
            if (AdvancesInfo_SetVouchingModeOn == true) {
                AdvancesInfo_SetVouchingModeOn = false;
            }
            else {
                AdvancesPrf_FAB.SetVisible(false);
            }
            if (Advances_IsVouchingMode == true) {
                OpenRightPane();
                ClearLeftPane();
                OpenLeftPane();
            }
            else {
                CloseRightPane();
                ClearLeftPane();
                CloseLeftPane();
            }
            AdvancesListGrid_dx.clearSelection();
            AdvancesListGrid_dx.option("masterDetail.enabled", !Advances_IsVouchingMode)
            AdvancesListGrid_dx.repaint();
        }
        function Advances_ViewSwitch_ValueChange(e) {
            Advances_ViewMode = e.value == false ? "Default" : "Compact";
            if (AdvancesInfo_SetVouchingModeOn == true) {
                $("#AdvancesVouchingModeSwitch").dxSwitch("instance").option("value", true);
            }
            AdvancesListGrid_dx.beginUpdate();
            var columns = AdvancesListGrid_dx.option("columns");
            if (Advances_ViewMode == "Compact") {
                VisibleColumns_AdvancesListGrid_dx = [];
                for (var i = 0; i < columns.length; i++) {
                    var name = columns[i].dataField;
                    var ColumnVisible = AdvancesListGrid_dx.columnOption(name, "visible");
                    if (name == "AdvancesListGrid_dx_Compact_Column") {
                        AdvancesListGrid_dx.columnOption(name, "visible", true);
                    }
                    else if (ColumnVisible == true && name != "iIcon") {
                        VisibleColumns_AdvancesListGrid_dx.push(name);
                        AdvancesListGrid_dx.columnOption(name, "visible", false);
                    }
                }
            }
            else {
                AdvancesListGrid_dx.columnOption("AdvancesListGrid_dx_Compact_Column", "visible", false);
                for (var i = 0; i < VisibleColumns_AdvancesListGrid_dx.length; i++) {
                    AdvancesListGrid_dx.columnOption(VisibleColumns_AdvancesListGrid_dx[i], "visible", true);
                }
            }
            AdvancesListGrid_dx.repaint();
            AdvancesListGrid_dx.endUpdate();
        }
        function AdvanceschangeMode() {
            AdvancesListGrid_dx.beginUpdate();
            if (Advances_ShowHorizontalBar == 0) {
                Advances_ShowHorizontalBar = 1;
                $("#Advances_ShowHorizontalBar").find("span").text("Default Data");
                $("#Advances_ShowHorizontalBar").width(110);
                AdvancesListGrid_dx.option("columnHidingEnabled", false);
                AdvancesListGrid_dx.option("allowColumnResizing", true)
            }
            else {
                Advances_ShowHorizontalBar = 0;
                $("#Advances_ShowHorizontalBar").find("span").text("Full Data");
                $("#Advances_ShowHorizontalBar").width(90);
                AdvancesListGrid_dx.option("columnHidingEnabled", true)
                AdvancesListGrid_dx.option("allowColumnResizing", false)
            }
            AdvancesListGrid_dx.endUpdate();
        }

        function OnAdvancesListPreviewClick() {
            if ("@Advances_ExportRight" == "False") {
                DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
                return;
            }
            @*$("#Advances_report_modal").dxPopup("show");
            $("#Advances_report_modal").dxPopup("instance").option("title", "Export Option");
            $("#Advances_report_modal").html('');
            ShowLoader();
            $("#Advances_report_modal_result").load("@Url.Action("Frm_Export_Options", "Advances", new { @area = "Profile" })", function () {
