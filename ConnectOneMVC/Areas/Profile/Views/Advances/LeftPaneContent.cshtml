@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    var ID = (string)ViewBag.ID;
    var VouchingMode = (bool)ViewBag.VouchingMode;
    var MID = (string)ViewBag.MID;
}
<div class="col-md-12">
    <label>Documents Attached:</label>
    <div class="row">
        <div class="col-md-12" id="DailyBalanceAuditNestedGrid_Div">
            <form>
                @Html.Action("Frm_Advances_Info_DetailGrid", "Advances", new { RecID = ID, MID = MID, VouchingMode = VouchingMode,command="REFRESH",SessionGUID = SessionGUID})
            </form>
        </div>
    </div>
    <label>Additional Info:</label>
    <div class="row">
        <div class="col-md-12" id="DailyBalanceAuditAdditionalInfo_Div">
            <form>
                @Html.Action("AdditionalInfo_Grid", "Advances", new { SessionGUID = SessionGUID })
            </form>
        </div>
    </div>
</div>

