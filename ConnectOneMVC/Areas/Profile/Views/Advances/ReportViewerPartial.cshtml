@using DevExpress.XtraReports.UI;

@Html.DevExpress().DocumentViewer(
            settings =>
            {
                settings.Name = "AdvancesReportViewer";
                settings.Report = (XtraReport)Session["Advancesreport"];                
                settings.CallbackRouteValues = new { Controller = "Advances", Action = "ReportViewerPartial" };
                settings.ExportRouteValues = new { Controller = "Advances", Action = "ReportViewerExportTo" };
            }).GetHtml()