@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool CheckActionRights = ViewBag.CheckActionRights == null ? false : ViewBag.CheckActionRights;

    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;
    string ViewMode = ViewBag.ViewMode == null ? "Default" : (string)ViewBag.ViewMode;
    int ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;
}
@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar)
                 .ID("AssetListGrid_dx")
                 .DataSource(d => d.Mvc().Controller("Asset").LoadAction("Frm_Asset_Info_Grid_dx").LoadMode(DataSourceLoadMode.Raw).Key("ID"))
                 .Columns(columns =>
                 {
                     columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);//Bug #137209 Fix
                     columns.Add().DataField("iIcon").Name("iIcon").Caption("").CellTemplate(new JS("AssetListGrid_dx_iIconTemplate")).Width(30)
                     .HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource")).RenderAsync(true);
                     columns.Add().DataField("AssetListGrid_dx_Compact_Column").Name("AssetListGrid_dx_Compact_Column").Caption("").Visible(false).CellTemplate(new JS("AssetListGrid_dx_Compact_Column_Template"))
                     .CalculateCellValue("AssetListGrid_dx_Compact_Column_CellValue").Width("100%").RenderAsync(true).ShowInColumnChooser(false);
                     columns.Add().DataField("ITEM_NAME").Caption("Item").MinWidth(135);
                     columns.Add().DataField("Make").Caption("Make").MinWidth(125);
                     columns.Add().DataField("Model").Caption("Model").MinWidth(125);
                     columns.Add().DataField("AI_PUR_DATE").Caption("Purchase/Creation Date").MinWidth(140)
                     .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                     columns.Add().DataField("AI_AMT_FOR_INS").Caption("Opening Insurance Amount").MinWidth(125)
                     .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("AI_CLOSE_FOR_INS").Caption("Closing Insurance Amount").MinWidth(125)
                     .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("AI_PUR_AMT").Caption("Opening Value").MinWidth(125)
                     .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("Curr_Value").Caption("Curr. Value").MinWidth(125)
                     .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("Special_Ref").Caption("Reference").MinWidth(30).Width(125);
                     columns.Add().DataField("sale_quantity").Caption("Sale Qty").MinWidth(125)
                     .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("Quantity").Caption("Quantity").MinWidth(120).DataType(GridColumnDataType.Number);
                     columns.Add().DataField("Curr_Qty").Caption("Curr Qty").MinWidth(120).DataType(GridColumnDataType.Number);
                     columns.Add().DataField("Rate").Caption("Rate").MinWidth(125)
                     .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("AL_LOC_NAME").Caption("Location").MinWidth(240);
                     columns.Add().DataField("AI_OTHER_DETAIL").Caption("Other Detail").MinWidth(125);
                     columns.Add().DataField("Sale_Status").Caption("Sale Status").MinWidth(125);
                     columns.Add().DataField("ASSET_TYPE").Caption("ASSET TYPE").MinWidth(125);
                     columns.Add().DataField("BA_TAN_NO").Caption("TAN. No.").MinWidth(120);
                     columns.Add().DataField("BA_TEL_NOS").Caption("Tel. No.").MinWidth(120);
                     columns.Add().DataField("BA_EMAIL_ID").Caption("Email ID").MinWidth(120);
                     if (CheckActionRights)
                     {
                         columns.Add().DataField("Entry_Type").Caption("Entry Type").MinWidth(125).GroupIndex(1).GroupCellTemplate(new JS("AssetListGrid_dx_GroupCell_Template"));
                         columns.Add().DataField("Action_Status").Caption("Action Status").MinWidth(125).GroupIndex(2).GroupCellTemplate(new JS("AssetListGrid_dx_GroupCell_Template"));
                         columns.Add().DataField("Head").Caption("Head").MinWidth(125).GroupIndex(3).GroupCellTemplate(new JS("AssetListGrid_dx_GroupCell_Template"));
                     }
                     else
                     {
                         columns.Add().DataField("Action_Status").Caption("Action Status").MinWidth(125).GroupIndex(2).Visible(false).GroupCellTemplate(new JS("AssetListGrid_dx_GroupCell_Template"));
                         columns.Add().DataField("Head").Caption("Head").MinWidth(125).GroupIndex(3).Visible(false).GroupCellTemplate(new JS("AssetListGrid_dx_GroupCell_Template"));
                     }
                     columns.Add().DataField("Action_By").Caption("Action By").Visible(false).MinWidth(120);
                     columns.Add().DataField("Action_Date").Caption("Action Date").Visible(false).MinWidth(120);
                     columns.Add().DataField("Add_By").Caption("Added By").Visible(false).MinWidth(120);
                     columns.Add().DataField("Add_Date").Caption("Added Date").Visible(false).MinWidth(120);
                     columns.Add().DataField("AI_ADJ_FOR_INS").Caption("Adjust Insurance Amount").Visible(false).MinWidth(125);
                     columns.Add().DataField("AI_LOC_AL_ID").Caption("AI_LOC_AL_ID").Visible(false).MinWidth(125);
                     columns.Add().DataField("Crossed_Time_Limit").Caption("CrossedTimeLimit").Visible(false).MinWidth(125);
                     columns.Add().DataField("Edit_By").Caption("Edited By").Visible(false).MinWidth(120);
                     columns.Add().DataField("Edit_Date").Caption("Edited Date").Visible(false).MinWidth(120);
                     columns.Add().DataField("ID").Caption("ID").Visible(false).MinWidth(120).SortOrder(SortOrder.Asc);
                     columns.Add().DataField("AI_ITEM_ID").Caption("ITEM ID").Visible(false).MinWidth(125);
                     columns.Add().DataField("ITEM_LED_ID").Caption("ITEM_LED_ID").Visible(false).MinWidth(125);
                     columns.Add().DataField("Open_Actions").Caption("OpenActions").Visible(false).MinWidth(125);
                     columns.Add().DataField("QR_Code_ID").Caption("QRCodeID").Visible(false).MinWidth(125);
                     columns.Add().DataField("Remark_Count").Caption("RemarkCount").Visible(false).MinWidth(125);
                     columns.Add().DataField("Remarks").Caption("Remarks").Visible(false).MinWidth(125);
                     columns.Add().DataField("RemarkStatus").Caption("Remark Status").Visible(false).MinWidth(120);
                     columns.Add().DataField("AI_SERIAL_NO").Caption("Serial No.").Visible(false).MinWidth(120);
                     columns.Add().DataField("TR_ID").Caption("TR. ID").Visible(false).MinWidth(120);
                     columns.Add().DataField("Warranty").Caption("Warranty").Visible(false).MinWidth(120);
                     columns.Add().DataField("YearID").Caption("Year ID").Visible(false).MinWidth(120);
                     columns.Add().DataField("REJECTED_COUNT").Caption("iREJECTED_COUNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("RESPONDED_COUNT").Caption("iRESPONDED_COUNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("COMPLETE_ATTACH_COUNT").Caption("iCOMPLETE_ATTACH_COUNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("REQ_ATTACH_COUNT").Caption("iREQ_ATTACH_COUNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("OTHER_ATTACH_CNT").Caption("OTHER_ATTACH_CNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("ALL_ATTACH_CNT").Caption("ALL_ATTACH_CNT").Visible(false).MinWidth(120);

                 })    
                 .Summary(s =>

                 {

                     s.TotalItems(item => item.Add().Name("AI_PUR_AMT_sum").SummaryType(SummaryType.Sum).Column("AI_PUR_AMT").DisplayFormat("Grand Total= {0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}")));
                     s.RecalculateWhileEditing(true);
                 })
         .MasterDetail(md =>
         {
             md.AutoExpandAll(false);
             md.Enabled(!VouchingMode);
             md.Template(new JS("AssetListGrid_dx_DetailTemplate"));
         })
         .OnInitialized("AssetListGrid_dx_OnInitialized")
         .OnCellPrepared("AssetListGrid_dx_OnCellPrepared")
         .OnRowPrepared("AssetListGrid_dx_OnRowPrepared")
         .OnContentReady("AssetListGrid_dx_OnContentReady")
         .OnCellDblClick("AssetListGrid_dx_OnCellDblClick")
         .OnSelectionChanged("AssetListGrid_dx_OnSelectionChanged")
         //.OnFocusedRowChanged("AssetListGrid_dx_OnFocusedRowChanged")
         .OnRowExpanding("AssetListGrid_dx_OnRowExpanding")
         .OnRowCollapsing("AssetListGrid_dx_OnRowCollapsing")
         .OnContextMenuPreparing("AssetListGrid_dx_OnContextMenuPreparing")
//.OnEditorPreparing("AssetListGrid_dx_OnEditorPreparing")

)