        function AssetListGrid_dx_Compact_Column_CellValue(rowData) {
            var data =
                [
                    rowData.Item, rowData.Make, rowData.Model, rowData.AI_PUR_DATE, rowData.AI_AMT_FOR_INS, rowData.AI_CLOSE_FOR_INS, rowData.AI_PUR_AMT,
                    rowData.Curr_Value, rowData.sale_quantity, rowData.Quantity, rowData.Curr_Qty, rowData.Rate, rowData.Location,
                    rowData.AI_OTHER_DETAIL, rowData.Sale_Status, rowData.ASSET_TYPE, rowData.Entry_Type, rowData.Action_Status, rowData.Head, rowData.Special_Ref

                ]
            return data.join(" ")
        }
