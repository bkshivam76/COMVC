    <script>
        var AssetListGrid_dx = null;
        var VisibleColumns_AssetListGrid_dx = [];
        var Expanded_Row_Key_Asset_dx = null;
    </script>
    <script>
        function closeProfile_Asset() {
            DxGrid_EventsOnScreenClose(AssetListGrid_dx)
            $(".TabPanalMenu-tabs .active span").click();
        }
        function Asset_UpdateFooterDetail(AssetID, Asset_Action_Status, Asset_Add_Date, Asset_Add_By, Asset_Action_Date, Asset_Action_By, Asset_Edit_Date, Asset_Edit_By) {
            Asset_Action_Date = Asset_Action_Date != "" && Asset_Action_Date != null ? Asset_Action_Date : Asset_Action_Date;
            Asset_Edit_Date = Asset_Edit_Date != "" && Asset_Edit_Date != null ? Asset_Edit_Date : Asset_Edit_Date;
            Asset_Add_Date = Asset_Add_Date != "" && Asset_Add_Date != null ? Asset_Add_Date : Asset_Add_Date;
            $.ajax({
                type: 'GET',
                url: "/Profile/Asset/CreationDetail",
                data: {
                    Xrow: AssetID, Action_Status: Asset_Action_Status, Add_Date: Asset_Add_Date,
                    Add_By: Asset_Add_By, Action_Date: Asset_Action_Date, Action_By: Asset_Action_By, Edit_Date: Asset_Edit_Date, Edit_By: Asset_Edit_By
                },
                cache: false,
                success: function (AssetLbl_result) {
                    $('#Asset_Lbl_ActionOn').text(AssetLbl_result.Lbl_StatusOn);
                    $('#Asset_Lbl_ActionBy').text(AssetLbl_result.Lbl_StatusBy);
                    $('#AssetLbl_Status').text(AssetLbl_result.Lbl_Status);
                    $('#AssetLbl_Create').text(AssetLbl_result.Lbl_Create);
                    $('#AssetLbl_Modify').text(AssetLbl_result.Lbl_Modify);
                    if (AssetLbl_result.Lbl_Status_Color != "") {
                        $('#AssetLbl_Status').css('color', AssetLbl_result.Lbl_Status_Color);
                    }
                    if (AssetLbl_result.Pic_Status != "") {
                        $('#Asset_LockICON').css('class', AssetLbl_result.Pic_Status);
                    }

                }
            });
        }
        function Asset_VouchingSwitch_ValueChange(e) {
            Asset_IsVouchingMode = e.value;
            if (AssetInfo_SetVouchingModeOn == true) {
                AssetInfo_SetVouchingModeOn = false;
            }
            else {
                AssetPrf_FAB.SetVisible(false);
            }
            if (Asset_IsVouchingMode == true) {
                OpenRightPane();
                ClearLeftPane();
                OpenLeftPane();
            }
            else {
                CloseRightPane();
                ClearLeftPane();
                CloseLeftPane();
            }
            AssetListGrid_dx.clearSelection();
            AssetListGrid_dx.option("masterDetail.enabled", !Asset_IsVouchingMode)
            AssetListGrid_dx.repaint();
        }
        function AssetchangeMode() {
            AssetListGrid_dx.beginUpdate();
            if (Asset_ShowHorizontalBar == 0) {
                Asset_ShowHorizontalBar = 1;
                $("#AssetToggleScrollBar").find("span").text("Default Data");
                $("#AssetToggleScrollBar").width(110);
                AssetListGrid_dx.option("columnHidingEnabled", false);
                AssetListGrid_dx.option("allowColumnResizing", true)
            }
            else {
                Asset_ShowHorizontalBar = 0;
                $("#AssetToggleScrollBar").find("span").text("Full Data");
                $("#AssetToggleScrollBar").width(90);
                AssetListGrid_dx.option("columnHidingEnabled", true)
                AssetListGrid_dx.option("allowColumnResizing", false)
            }
            AssetListGrid_dx.endUpdate();
        }
        function Asset_ViewSwitch_ValueChange(e) {
            Asset_ViewMode = e.value == false ? "Default" : "Compact";
            if (AssetInfo_SetVouchingModeOn == true) {
                $("#AssetViewModeSwitch").dxSwitch("instance").option("value", true);
            }
            AssetListGrid_dx.beginUpdate();
            var columns = AssetListGrid_dx.option("columns");
            if (Asset_ViewMode == "Compact") {
                VisibleColumns_AssetListGrid_dx = [];
                for (var i = 0; i < columns.length; i++) {
                    var name = columns[i].dataField;
                    var ColumnVisible = AssetListGrid_dx.columnOption(name, "visible");
                    if (name == "AssetListGrid_dx_Compact_Column") {
                        AssetListGrid_dx.columnOption(name, "visible", true);
                    }
                    else if (ColumnVisible == true && name != "iIcon") {
                        VisibleColumns_AssetListGrid_dx.push(name);
                        AssetListGrid_dx.columnOption(name, "visible", false);
                    }
                }
            }
            else {
                AssetListGrid_dx.columnOption("AssetListGrid_dx_Compact_Column", "visible", false);
                for (var i = 0; i < VisibleColumns_AssetListGrid_dx.length; i++) {
                    AssetListGrid_dx.columnOption(VisibleColumns_AssetListGrid_dx[i], "visible", true);
                }
            }
            AssetListGrid_dx.repaint();
            AssetListGrid_dx.endUpdate();
        }

    </script>
    <script>

        function AssetListGrid_dx_OnInitialized(e) {
            DxGrid_AdjustSize(e.component, $("#Asset_ParentDiv .report_button_div"))
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                DxGrid_AdjustSize(e.component, $("#Asset_ParentDiv .report_button_div"), "", evt)
            });
            AssetListGrid_dx = e.component;
        }
        function AssetListGrid_dx_OnCellPrepared(e) {
            if (e.rowType == "data") {
                if (Asset_IsVouchingMode == true) {
                    if (e.column.dataField === "iIcon") {
                        $(e.cellElement).attr("onmouseover", "OnGridRowMouseHoverIn(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.key + "')");
                        $(e.cellElement).attr("onmouseout", "OnGridRowMouseHoverOut(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.key + "')");
                    }
                }
                $(e.cellElement).attr("id", e.element[0].id + "_Cell_" + e.key + "|" + e.column.dataField);
            }
        }
        function AssetListGrid_dx_OnRowPrepared(e) {
            if (e.rowType == "data") {
                var GridName = e.element[0].id;
                $(e.rowElement).addClass(GridName + "_DataRow_" + e.key)
                if (e.data.RemarkStatus != null && e.data.RemarkStatus == "OPEN" || e.data.RemarkStatus == "REOPENED") {
                    $(e.rowElement).css("background-color", "gold");
                }
                if (e.data.RemarkStatus == null && e.data.Remarks != null && e.data.Remarks == true && e.data.CrossedTimeLimit != null && e.data.CrossedTimeLimit == 0) {
                    $(e.rowElement).css("background-color", "lightgreen");
                }
                if (e.data.CrossedTimeLimit != null && e.data.CrossedTimeLimit > 0) {
                    $(e.rowElement).css("background-color", "mistyrose");
                }
                DxGrid_CreatePreviewRow(e, Asset_IsVouchingMode, "Master")
            }
            else if (e.rowType == "detailAdaptive") {
                DxGrid_MovePreviewRowAfterAdaptiveRow(e)
            }
        }
        function AssetListGrid_dx_OnContentReady(e) {
            DxGrid_OnContentReady(e, Asset_ShowHorizontalBar);
        }
        function AssetListGrid_dx_OnCellDblClick(e) {
            if (e.rowType == "data") {
                if (Asset_IsVouchingMode == true && Asset_ViewMode == "Default") {
                    OnGridCellClick(e.event, e.cellElement[0], e.columnIndex, e.rowIndex, e.element[0].id, e.key, e.column.dataField)
                }
                else if (Asset_IsVouchingMode == false) {
                    //if (e.rowType == "data")
                    //BankProfile_OnEditClick_dx();
                }
            }
        }
        function AssetListGrid_dx_OnSelectionChanged(e) {
            var selectedRowKeys = e.selectedRowKeys;
            if (selectedRowKeys != null && selectedRowKeys.length > 0) {
                if (Asset_IsVouchingMode) {
                    AssetPrf_FAB.SetVisible(true);
                    AssetPrf_FAB.SetActionContext("AddAttachmentContext", false);
                }
                AssetListGrid_dx_SelectedRowData(e.selectedRowsData);
            }
            else {
                AssetID = null;
                Asset_UpdateFooterDetail(AssetID, Asset_ActionStatus, Asset_AddDate, Asset_AddBy,
                    Asset_ActionDate, Asset_ActionBy, Asset_EditDate, Asset_EditBy);
            }
        }
        function AssetListGrid_dx_SelectedRowData(selectedData = null) {
            if (selectedData == null) {
                selectedData = AssetListGrid_dx.getSelectedRowsData();
            }
            if (selectedData != null && selectedData.length > 0) {
                var values = selectedData[0]
                AssetID = values["ID"]
                Asset_EditDate = values["Edit_Date"];
                Asset_EditBy = values["Edit_By"];
                Asset_AddDate = values["Add_Date"];
                Asset_AddBy = values["Add_By"];
                Asset_ActionDate = values["Action_Date"];
                Asset_ActionBy = values["Action_By"];
                Asset_ActionStatus = values["Action_Status"];
                Asset_UpdateFooterDetail(AssetID, Asset_ActionStatus, Asset_AddDate, Asset_AddBy,
                    Asset_ActionDate, Asset_ActionBy, Asset_EditDate, Asset_EditBy);
                if (Asset_IsVouchingMode == true) {
                    OpenLeftPane();
                    LeftPaneContent_Asset_dx("AssetListGrid_dx", AssetID, Asset_IsVouchingMode)
                }
            }
            else {
                AssetID = null;
            }
        }
        function AssetListGrid_dx_OnRowExpanding(e) {
            if (Array.isArray(e.key) == false) //not group row
            {
                e.component.collapseRow(Expanded_Row_Key_Asset_dx)
                e.component.selectRows(e.key);
                Expanded_Row_Key_Asset_dx = e.key;
                AssetInfo_IsDetailRowExpanded = true;
                var DetailGridID = e.element[0].id + e.key;
                var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
                if (instance != void 0) {
                    instance.state(null) // grid maintains its state after collapsing so resetting the state when expands again as per old grid
                }
                //e.component.collapseAll(-1);
            }
            else {
                e.component.option("CustomProp.groupRowExpanded", true);
            }
        }
        function AssetListGrid_dx_OnRowCollapsing(e) {
            if (Array.isArray(e.key) == false) //not group row
            {
                var DetailGridID = e.element[0].id + e.key;
                sessionStorage.removeItem(DetailGridID + "_DetailGridState") //removing grid state from session storage on collapse
                AssetInfo_IsDetailRowExpanded = false;
                e.component.selectRows(e.key);
                if (Asset_IsVouchingMode == false) {
                    AssetPrf_FAB.SetVisible(false);
                }
                var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
                if (instance != void 0) {
                    instance.clearSelection();
                }
            }
            else {
                e.component.option("CustomProp.groupRowCollapsed", true);
            }
        }
        function AssetListGrid_dx_OnContextMenuPreparing(e) {
            if (!e.items) e.items = [];
            if (e.target == "header") {

                DxGrid_HeaderContextMenu(e)
            }
            else if ((e.target == "content" && e.row && e.row.rowType == "groupFooter") || e.target == "footer") {
                if (Asset_ViewMode == "Compact")
                    DxGrid_FooterContextMenu(e, true);
                else
                    DxGrid_FooterContextMenu(e);
            }
            else if (e.target == "content" && e.row && (e.row.rowType == "data" || e.row.rowType == "detailAdaptive")) {
                var key = e.component.getKeyByRowIndex(e.row.rowIndex);
                e.component.selectRows(key);
                var expanded = e.component.isRowExpanded(key);
                e.items = [
                    {
                        text: "Expand Detail",
                        icon: "fa-solid fa-arrow-down-wide-short " + (expanded ? "text-muted" : "text-info"),
                        disabled: expanded,
                        visible: !Asset_IsVouchingMode,
                        onItemClick: function () {
                            if (expanded) {
                            }
                            else {
                                e.component.expandRow(key);
                            }
                        }
                    }, {
                        text: "Collapse Detail",
                        icon: "fa-solid fa-arrow-up-wide-short " + (!expanded ? "text-muted" : "text-info"),
                        disabled: !expanded,
                        visible: !Asset_IsVouchingMode,
                        onItemClick: function () {
                            if (expanded) {
                                e.component.collapseRow(key);
                            }
                            else {
                            }
                        }
                    },
                    {
                        text: "Export",
                        icon: "fa-solid fa-file-export text-warning",
                        visible: "@MovAsset_ExportRight" == "True",
                        beginGroup: true,
                        onItemClick: function () {
                            OnAssetListPreviewClick();
                        }
                    },
                    {
                        text: "Close",
                        icon: "fa-solid fa-rectangle-xmark text-danger",
                        beginGroup: true,
                        onItemClick: function () {
                            closeProfile_Asset();
                        }
                    },
                    {
                        text: "Refresh",
                        icon: "fa-solid fa-arrow-rotate-right text-success",
                        beginGroup: true,
                        onItemClick: function () {
                            AssetListGrid_dx_Refresh()
                        }
                    }]
            }
        }

        function AssetListGrid_dx_DetailTemplate(container, templateData) {
            var GridName = templateData.component.element()[0].id
            var RecID = templateData.data.ID;
            AssetListGrid_dx_Detail(container, GridName, RecID, Asset_IsVouchingMode, Asset_ShowHorizontalBar);
        }
        function AssetListGrid_dx_Detail(container, GridName, RecID, vouchingMode, AllColumns)
        {
            var url = "/Profile/Asset/Frm_Asset_Info_DetailGrid_dx?VouchingMode=" + vouchingMode + "&RecID=" + RecID
            var instance = DxGrid_AttachmentGrid_Create(container, GridName, RecID, vouchingMode, AllColumns, url)
            instance.option("onSelectionChanged", AssetListGrid_dx_Detail_onSelectionChanged);            
        }    
        function AssetListGrid_dx_Detail_onSelectionChanged(e) {
            if (AssetInfo_IsDetailRowExpanded || Asset_IsVouchingMode) {
                if (e.selectedRowsData != null && e.selectedRowsData.length > 0) {
                    AssetInfo_NestedGrid_AccessID = e.element[0].id;
                    AssetListGrid_dx_Detail_SelectedRowData(e.selectedRowsData)
                }
                else {
                    AssetPrf_FAB.SetActionContext("AddAttachmentContext", false);
                }
            }
        }
        function AssetListGrid_dx_Detail_SelectedRowData(selectedData = null) {
            if (selectedData == null) {
                selectedData = $("#" + AssetInfo_NestedGrid_AccessID).dxDataGrid("getSeletedRowsData");
            }
            var values = selectedData[0];
            AssetInfo_NestedRowKeyValue  = values["UniqueID"];
            if (values["UniqueID"] != null) {
                AssetPrf_FAB.SetVisible(true);
                AssetInfo_Nested_Doc_Status = values["Doc_Status"];

                if (Asset_IsVouchingMode == true) {
                    AssetPrf_FAB.SetActionContext("AuditActionContext", true);
                }
                else {
                    if (AssetInfo_Nested_Doc_Status == "") {
                        AssetPrf_FAB.SetActionContext("AutoItemContext", true);
                    }
                    else if (AssetInfo_Nested_Doc_Status == "NO") {
                        AssetPrf_FAB.SetActionContext("EditItemContext", true);
                    }
                    else if (AssetInfo_Nested_Doc_Status == "YES") {
                        AssetPrf_FAB.SetActionContext("actionItemContext", true);
                    }
                }
                AssetInfo_ParamMandatory  = values["Params_Mandatory"];
                AssetInfo_FromDateLabel  = values["LABEL_FROM_DATE"];
                AssetInfo_ToDateLabel  = values["LABEL_TO_DATE"];
                AssetInfo_DescriptionLabel  = values["LABEL_DESCRIPTION"];
                AssetInfo_Doc_Category  = values["Document_Category"];
                AssetInfo_Doc_ID  = values["Document_ID"];
                AssetInfo_AtachmentID  = values["ATTACH_ID"];
                IndexAttachmentID  = AssetInfo_AtachmentID ;
                AssetInfo_MasterRowRecID  = values["TxnID"];
                AssetInfo_MasterRowMID  = values["TxnMID"];
                AssetInfo_NestedRowMapID  = values["MAP_ID"];
                AssetInfo_reason  = values["Reason"];
                AssetInfo_FileName  = values["ATTACH_FILE_NAME"];
                AssetInfo_Attachment_RecStatus  = values["Attachment_Action_Status"];
                if (Asset_IsVouchingMode == true) {
                    if (AssetInfo_FileName != null && AssetInfo_FileName .length > 0) {
                        ViewDocument(AssetInfo_AtachmentID, AssetInfo_FileName, "DepositsPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                    }
                    else {
                        CloseRightPane();
                        ClearRightPane();
                    }
                }
            }
            AssetInfo_NestedRowReasonID  = values["ReasonID"];
            IndexAttachmentReasonID = AssetInfo_NestedRowReasonID;
        }       
    </script>
