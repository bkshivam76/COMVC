    <script class="BankProfile_Scripts">
        var Bank_IsVouchingMode = false;
    var Bank_ViewMode = "Default";
    function BankGrid_CollapseAllDetailRows()
    {
            if (typeof window !== 'undefined')
            {
                if (typeof window.BankListGrid !== 'undefined')
                {
                    if (typeof window.BankListGrid.CollapseAllDetailRows !== 'undefined')
                    {
                        if (typeof BankListGrid.CollapseAllDetailRows == 'function')
                        {
                            BankListGrid.SetFocusedRowIndex(-1);
                            BankListGrid.CollapseAllDetailRows();
                        }
                        else
                        {
                            alert("CollapseAllDetailRows is not a function");
                        }
                    }
                    else
                    {
                        ShowLoader();
                        setTimeout(function ()
                        {
                            BankGrid_CollapseAllDetailRows();
                            HideLoader();
                        }, Timeout100);
                    }
                }
                else
                {
                    alert('grid undefined')
                }
            }
            else
            {
                alert('window undefined')
            }
    }

        function Bank_VouchingSwitch_ValueChange(e)
        {
            Bank_IsVouchingMode = e.value;
            if (BankInfo_SetVouchingModeOn == true) {
                BankInfo_SetVouchingModeOn = false;
            }
            else
            {
                BankPrf_FAB.SetVisible(false);
            }
            if (Bank_IsVouchingMode == true)
            {
                var Rightpane = Mainspliter.GetPaneByName('RightPane');
                Rightpane.Expand();
                var Leftpane = Mainspliter.GetPaneByName('LeftPane');
                ClearLeftPane();
                if (Leftpane.IsCollapsed() == true)
                {
                    Leftpane.Expand();
                }
            }
            else
            {
                var Rightpane = Mainspliter.GetPaneByName('RightPane');
                if (Rightpane.IsCollapsed() == false)
                {
                    Rightpane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
                }
                var Leftpane = Mainspliter.GetPaneByName('LeftPane');
                ClearLeftPane();
                if (Leftpane.IsCollapsed() == false)
                {
                    Leftpane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
                }
            }
            BankGrid_CollapseAllDetailRows();
        }
        function Bank_ViewSwitch_ValueChange(e)
        {
            Bank_ViewMode = e.value == false ? "Default" : "Compact";
            if (BankInfo_SetVouchingModeOn == true)
            {
                $("#BankVouchingModeSwitch").dxSwitch("instance").option("value", true);
            }
            else
            {
                BankListGrid.CollapseAllDetailRows();
            }
        }

    function BankProfile_OnNewClick()
    {
        if ("@Bank_AddRight" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        ShowLoader();
        OpenPopup("popup_frm_Bank_Window", "New ~ Bank Account", "@Url.Action("frm_Bank_window", "Bank", new { @area = "Profile" })?ActionMethod=New", "auto", "1080px", false, null);
    }
     function BankProfile_OnEditClick()
     {
        if ("@Bank_UpdateRight" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        if (BankID_BankProfile == null)
        {
            DevExpress.ui.dialog.alert('Please Select one Bank row', 'Alert ');
            return;
         }
         ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Profile/Bank/Check_Frm_Bank_Window",
            data: { ActionMethod: "Edit", id: BankID_BankProfile},
            cache: false,
            success: function (data)
            {
                HideLoader();
                if (data.jsonParam.result==true)
                {
                    OpenBankWindowEditMode()
                }
                else
                {
                    if (data.jsonParam.isconfirm == true)
                    {
                        var confirmation = DevExpress.ui.dialog.confirm(data.jsonParam.message, data.jsonParam.title);
                        confirmation.done(function (result)
                        {
                            if (result)
                            {
                                OpenBankWindowEditMode();
                            }
                            else if (data.jsonParam.refreshgrid)
                            {
                                BankListGrid.Refresh();
                            }
                        });
                    }
                    else
                    {
                        DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                        if (data.jsonParam.refreshgrid)
