    function BankContextMenuFunction(s, e)
    {
        if (e.item.name == "Close")
        {
            closeProfile_Bank();
        }
        if (e.item.name == "Profile_Bank_New")
        {
            BankProfile_OnNewClick();
        }//Redmine bug 132497 fixed
        else if (e.item.name == 'Profile_Bank_Edit')
        {
            BankProfile_OnEditClick();
        }//Redmine bug 132497 fixed
        else if (e.item.name == 'Profile_Bank_Delete')
        {
            BankProfile_OnDeleteClick();
        }//Redmine bug 132497 fixed
        else if (e.item.name == 'Profile_Bank_View')
        {
            BankProfile_OnViewClick();
        }//Redmine bug 132497 fixed
        else if (e.item.name == 'ListPreview')
        {
            OnBankListPreviewClick();
        }
        else if (e.item.name == 'Lock') {
            BankOnLockClick();
        }
        else if (e.item.name == 'Unlock') {
            BankOnUnLockClick();
        }
        else if (e.item.name == 'New') {
            AuditActionNew();
        }
        else if (e.item.name == 'CloseAccount') {
            OnAccountCloseAndReOpenClick('ACCOUNT-CLOSE');
        }
        else if (e.item.name == 'ReOpenAccount') {
            OnAccountCloseAndReOpenClick('ACCOUNT-REOPEN');
        }
        else if (e.item.name == 'Refresh') {
            BankListGrid.Refresh();
        }
        else if (e.item.name == 'New_Audit')
        {
            OnBankAuditClick("ADD_REMARKS");
        }
        else if (e.item.name == 'View_Audit')
        {
            OnBankAuditClick("REMARKS");
        }
    }
