<div class="BankProfile_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    @model IEnumerable<dynamic>
    @{
        ViewBag.Title = "Index";
        Layout = null;
        var CalledFromOtherScreen = ViewBag.PopupID;
        string UserType = (string)ViewBag.UserType;
        bool Bank_AddRight = (bool)ViewData["Bank_AddRight"];
        bool Bank_UpdateRight = (bool)ViewData["Bank_UpdateRight"];
        bool Bank_ViewRight = (bool)ViewData["Bank_ViewRight"];
        bool Bank_DeleteRight = (bool)ViewData["Bank_DeleteRight"];
        bool Bank_ExportRight = (bool)ViewData["Bank_ExportRight"];
        bool Bank_ListAdresBookRight = (bool)ViewData["Bank_ListAdresBookRight"];
        bool Bank_LockUnlockRight = (bool)ViewData["Bank_LockUnlockRight"];
        bool Help_Attachment_AddRight = (bool)ViewData["Help_Attachment_AddRight"];//attachment
        bool Help_Attachment_EditRight = (bool)ViewData["Help_Attachment_EditRight"];//attachment
        bool Help_Attachment_ViewRight = (bool)ViewData["Help_Attachment_ViewRight"];//attachment
        bool Help_Attachment_DeleteRight = (bool)ViewData["Help_Attachment_DeleteRight"];//attachment
        bool BankInfo_Auto_Vouching_Mode = (bool)ViewData["BankInfo_Auto_Vouching_Mode"];
    }

    <style>
        .GridrowMouseHover {
            box-shadow: inset 0px 0px 5px 0px rgb(0, 114, 198);
        }

        .GridFloatDiv {
            position: relative;
            z-index: 2;
            box-shadow: 2px 2px 2px 2px #888888;
            background-color: white;
        }

        .hideHeader {
            display: none;
        }
        #BankListGrid { width: 100% !important; max-width: 100% !important }
        .dxgvDetailRow_Aqua td.dxgvDetailCell_Aqua{padding:18px 0}
    </style>
    <div id="BankProfile_ParentDiv">
        @*<div class="report_header_div_main">*@
        <div id="contentBankProfile" class="col-md-12  report_header_div_main">
            <div class="col-md-12 report_header_div">
                <label class="report_header_label">Bank Account Information</label>
            </div>
            @*Buttons*@
            <div class="report_button_div">
                @(Html.DevExtreme().Switch().ID("BankVouchingModeSwitch").SwitchedOnText("Vouching On").SwitchedOffText("Vouching Off").OnValueChanged("Bank_VouchingSwitch_ValueChange").Width(100).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
                @(Html.DevExtreme().Switch().ID("BankViewModeSwitch").SwitchedOnText("Compact").SwitchedOffText("Default").OnValueChanged("Bank_ViewSwitch_ValueChange").Width(70).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
                @if (ViewBag.LockUnlock != false)
                {
                    @(Html.DevExtreme().Button().ID("BankModelUnlock").Text("Unlock").Icon("add").Visible(true).OnClick(@<text> function () { BankOnUnLockClick(); } </text>) )

                    @(Html.DevExtreme().Button().ID("BankModelLock").Text("Lock").Icon("add").Visible(true).OnClick(@<text> function () { BankOnLockClick(); } </text>) )
                }
                @(Html.DevExtreme().Button().ID("BankModelNew").Text("New").Icon("add").Visible(true).OnClick(@<text> function () { BankProfile_OnNewClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("BankModelEdit").Text("Edit").Visible(true).Icon("edit").OnClick(@<text> function () { BankProfile_OnEditClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("BankModelDelete").Text("Delete").Icon("trash").Visible(true).OnClick(@<text> function () { BankProfile_OnDeleteClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("BankModelView").Text("View").Icon(IconID.ViewCustomers16x16devav).Icon("doc").Visible(true).OnClick(@<text> function () { BankProfile_OnViewClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("BankToggleScrollBar").Text(ViewBag.ShowHorizontalBar == 1 ? "Default Data" : "Full Data").Width(ViewBag.ShowHorizontalBar == 1 ? 110 : 90).Icon("toolbox").OnClick(@<text> function () { BankchangeMode(); } </text>) )
                @(Html.DevExtreme().Button().ID("BankModelListPreview").Text("Export").Icon("save").Width(80).OnClick(@<text> function () { OnBankListPreviewClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("BankModelCLOSE").Text("Close").Icon("clear").OnClick(@<text> function (){ closeProfile_Bank(); } </text>) )

            </div>
            @*</div>*@
        </div>
        <div class="col-md-12 no-padding" id="BankProfile_grid_DIV">
            <form>
                <div id="bankReloadPartialView" class="parent_table">
                    @Html.Partial("Frm_Bank_Info_Grid", Model)
                </div>
            </form>

        </div>
        <div class="footer-MainBoxdiv" style="display:inline-block;width:100%">
            <div class="setFooterItem">
                <div class="footer-inner">
                    <div class="list_footer_left_margin">
                        <div class="footericon">
                            <i id="Bank_LockICON" style="color:red;font-size:35px;"></i>
                        </div>
                        @*<div class="footer-locktext">
                                <div id="BankLbl_Status" style="font-size:23px" class="left_footertext_top"></div>
                            </div>*@
                        <div class="footer-locktext">
                            <div id="Bank_Lbl_ActionOn" class="left_footertext_top"></div>
                            <div id="Bank_Lbl_ActionBy" class="left_footertext_bottom"></div>
                        </div>
                    </div>
                    <div class="list_footer_left_margin">
                        <div class="footer-text">
                            <p id="BankLbl_Create" class="right_footertext_top"></p>
                            <p id="BankLbl_Modify" class="right_footertext_bottom"></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>




    </div>
    <div id="BankProfile_FabAndPopups">
        @Html.Partial("AttachmentFAB", "BankPrf_FAB,BankProfile_ParentDiv,Type1,BankProfile," + UserType) @*fab buttons*@
        @(Html.DevExtreme().Popup().CustomPopup().ID("Bank_report_modal").OnShowing("PopupOnShowing").Title("Bank List Preview").FullScreen(false).MaxWidth(125).Height("auto").ShowCloseButton(true).ContentTemplate(@<text> <div id='Bank_report_modal_result'> </div> </text>) )
        @(Html.DevExtreme().Popup().CustomPopup().ID("popup_frm_Bank_Window_Close").OnShowing("PopupOnShowing").Title("Bank").Height("auto").MaxWidth(750).ContentTemplate( @<text> <div id='popup_frm_Bank_Window_Close_result'> </div> </text>) )
        @(Html.DevExtreme().Popup().CustomPopup().ID("popup_frm_Bank_Window").Title("Bank").DragEnabled(true).Height("auto").Width(850).OnShowing("PopupOnShowing").ShowCloseButton(true).ContentTemplate(@<text> <div id='popup_frm_Bank_Window_result'> </div> </text>) )
    </div>
    <script class="BankProfile_Scripts">
      var BankInfo_IsDetailRowExpanded = false;
    var BankInfo_NestedRecord_FocusedRowIndex = -1;
    var BankInfo_NestedGrid_AccessID = null;
    var BankInfo_AtachmentID = null;
    var BankInfo_FileName = null;
    var BankInfo_ParamMandatory = null;
    var BankInfo_FromDateLabel = null;
    var BankInfo_ToDateLabel = null;
    var BankInfo_DescriptionLabel = null;
    var BankInfo_Doc_ID = null;
    var BankInfo_Doc_Category = null;
    var BankInfo_MasterRowRecID = null;
    var BankInfo_MasterRowMID = null;
    var BankInfo_NestedRowMapID = null;
    var BankInfo_NestedRowUniqueID = null;
    var BankInfo_reason = null;
    var BankInfo_Attachment_RecStatus = null;
    var BankInfo_SetVouchingModeOn = "@BankInfo_Auto_Vouching_Mode" == "True" ? true : false;
    var BankInfo_NestedRowReasonID = null;

    function On_BankProfile_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach") {
            if ("@Help_Attachment_AddRight" == "False") {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (BankInfo_ParamMandatory == 1) {
                AddAttachment(BankInfo_MasterRowRecID, "Profile_BankAccounts", BankInfo_Doc_ID, BankInfo_Doc_Category, BankInfo_ParamMandatory, BankInfo_FromDateLabel, BankInfo_ToDateLabel, BankInfo_DescriptionLabel, "BankProfileAttachment", null, "BankListGrid", BankInfo_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(BankInfo_MasterRowRecID, "Profile_BankAccounts", BankInfo_Doc_ID, "BankProfileAttachment", "BankListGrid", BankInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach") {
            if ("@Help_Attachment_EditRight" == "False") {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (BankInfo_Attachment_RecStatus.toUpperCase() == "LOCKED") {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(BankInfo_MasterRowRecID, "Profile_BankAccounts", BankInfo_AtachmentID, BankInfo_ParamMandatory, BankInfo_FromDateLabel, BankInfo_ToDateLabel, BankInfo_DescriptionLabel, "BankProfileAttachment", null, "BankListGrid", BankInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(BankInfo_MasterRowRecID, "Profile_BankAccounts", BankInfo_AtachmentID, BankInfo_ParamMandatory, BankInfo_FromDateLabel, BankInfo_ToDateLabel, BankInfo_DescriptionLabel, null, "BankListGrid", BankInfo_NestedGrid_AccessID, BankInfo_Attachment_RecStatus);
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(BankInfo_MasterRowRecID, "Profile_BankAccounts", "Bank Account Information", "BankListGrid", BankInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "view_attach") {
            if ("@Help_Attachment_ViewRight" == "False") {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            ViewDocument(BankInfo_AtachmentID, BankInfo_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName === "Add_Reason") {
            if (BankInfo_Doc_Category.toLowerCase() == "others") {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else {

                AttachmentAddReason(BankInfo_MasterRowRecID, BankInfo_NestedRowMapID, "Profile_BankAccounts", "BankListGrid", BankInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(BankInfo_MasterRowRecID, BankInfo_NestedRowMapID, "Profile_BankAccounts", "BankListGrid", BankInfo_NestedGrid_AccessID, BankInfo_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(BankInfo_MasterRowRecID, BankInfo_NestedRowMapID, "BankListGrid", BankInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
        else if (e.actionName == "AuditAction") {
            BankPrf_FAB.SetActionContext("AuditActionContext", true);
        }
        else if (e.actionName == "BackAudit") {
            if (BankInfo_Nested_Doc_Status == "") {
                BankPrf_FAB.SetActionContext("AutoItemContext", true);
            }
            if (BankInfo_Nested_Doc_Status == "NO") {
                BankPrf_FAB.SetActionContext("EditItemContext", true);
            }
            if (BankInfo_Nested_Doc_Status == "YES") {
                BankPrf_FAB.SetActionContext("actionItemContext", true);
            }
        }
        else if (e.actionName == "Accept") {
            BankInfo_AcceptwithoutRemarks();
        }
        else if (e.actionName == "Reject") {
            BankInfo_AcceptRejectVoucher("Reject");
        }
        else if (e.actionName == "AcceptWithRemarks") {
            BankInfo_AcceptRejectVoucher("Accept");
        }
        else if (e.actionName == "AcceptDoc") {

            OnBankInfo_AcceptDoc();
        }
        else if (e.actionName == "RejectDoc") {

            OnBankInfo_RejectDoc();
        }
    }
    function OnBankInfo_RejectDoc() {
        if (BankInfo_AtachmentID == null || BankInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        RejectAttachment(BankInfo_AtachmentID, "BankListGrid", BankInfo_NestedGrid_AccessID);
    }
    function OnBankInfo_AcceptDoc() {
        if (BankInfo_AtachmentID == null || BankInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        AcceptAttachment(BankInfo_AtachmentID, "BankListGrid", BankInfo_NestedGrid_AccessID);
    }
    function BankInfo_AcceptwithoutRemarks()
    {
        var Recid;
        if (BankInfo_IsDetailRowExpanded == true || Bank_IsVouchingMode)
        {
            if (BankInfo_MasterRowRecID == null || BankInfo_MasterRowRecID == "")
            {
                Recid = BankID_BankProfile;
            }
            else
            {
                Recid = BankInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = BankID_BankProfile;
        }
        Entry_AcceptwithoutRemarks(Recid, "Profile_BankAccounts", "BankListGrid", BankInfo_AtachmentID, BankInfo_NestedRowReasonID, BankInfo_NestedRowUniqueID);
    }
    function BankInfo_AcceptRejectVoucher(_actionMethod)
    {
        var Recid;

        if (BankInfo_IsDetailRowExpanded == true || Bank_IsVouchingMode)
        {
            if (BankInfo_MasterRowRecID == null || BankInfo_MasterRowRecID == "")
            {
                Recid = BankID_BankProfile;
            }
            else
            {
                Recid = BankInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = BankID_BankProfile;
        }
        Entry_AcceptReject(_actionMethod, Recid, "Profile_BankAccounts", "BankListGrid", BankInfo_AtachmentID, BankInfo_NestedRowReasonID, BankInfo_NestedRowUniqueID);
    }
    function OnBankListGridNestedFocusedRowChange(s, e)
    {
        if (BankInfo_IsDetailRowExpanded || Bank_IsVouchingMode)
        {
            BankInfo_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
            if (BankInfo_NestedRecord_FocusedRowIndex >= 0)
            {
                ShowLoader();
                BankInfo_NestedGrid_AccessID = s.uniqueID;
                s.GetRowValues(s.GetFocusedRowIndex(), 'Doc_Status;Params_Mandatory;LABEL_FROM_DATE;LABEL_TO_DATE;LABEL_DESCRIPTION;Document_Category;Document_ID;ATTACH_ID;TxnID;TxnMID;MAP_ID;Reason;ATTACH_FILE_NAME;Attachment_Action_Status;UniqueID;ReasonID', OnBankInfo_GetGridRowValues);
            }
            else
            {
                BankPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }
    function OnBankInfo_GetGridRowValues(values)
    {
        HideLoader();
        BankInfo_NestedRowUniqueID = values[14];
        if (values[14] != null )
        {
            BankPrf_FAB.SetVisible(true);
            BankInfo_Nested_Doc_Status = values[0];

            if (Bank_IsVouchingMode == true) {
                BankPrf_FAB.SetActionContext("AuditActionContext", true);
            }
            else {
                if (BankInfo_Nested_Doc_Status == "") {
                    BankPrf_FAB.SetActionContext("AutoItemContext", true);
                }
                else if (BankInfo_Nested_Doc_Status == "NO") {
                    BankPrf_FAB.SetActionContext("EditItemContext", true);
                }
                else if (BankInfo_Nested_Doc_Status == "YES") {
                    BankPrf_FAB.SetActionContext("actionItemContext", true);
                }
            }
            BankInfo_ParamMandatory = values[1];
            BankInfo_FromDateLabel = values[2];
            BankInfo_ToDateLabel = values[3];
            BankInfo_DescriptionLabel = values[4];
            BankInfo_Doc_Category = values[5];
            BankInfo_Doc_ID = values[6];
            BankInfo_AtachmentID = values[7];
            IndexAttachmentID = BankInfo_AtachmentID;
            BankInfo_MasterRowRecID = values[8];
            BankInfo_MasterRowMID = values[9];
            BankInfo_NestedRowMapID = values[10];
            BankInfo_reason = values[11];
            BankInfo_FileName = values[12];
            BankInfo_Attachment_RecStatus = values[13];
            if (Bank_IsVouchingMode == true) {
                if (BankInfo_FileName != null && BankInfo_FileName.length > 0) {
                    ViewDocument(BankInfo_AtachmentID, BankInfo_FileName, "BankPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else {
                    var pane = Mainspliter.GetPaneByName('RightPane');
                    pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
                    document.getElementById('RightPane_div_Iframe').style.display = "none";
                    document.getElementById('RightPane_div_Img').style.display = "none";
                }
            }
        }
        BankInfo_NestedRowReasonID = values[15];
        IndexAttachmentReasonID = BankInfo_NestedRowReasonID;
    }
    function BankGrid_Nested_BeginCallBack(s, e)
    {
        e.customArgs["command"] = e.command;
        e.customArgs["ShowHorizontalBar"] = Bank_ShowHorizontalBar;
    }
    function BankGrid_DetailRowExpanding(s, e)
    {
        BankInfo_IsDetailRowExpanded = true;
        s.SetFocusedRowIndex(e.visibleIndex);
        var pane = Mainspliter.GetPaneByName('RightPane');
        if (Bank_IsVouchingMode == true)
        {
            pane.Expand();
        }
        else
        {
            pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
        }
    }
    function BankGrid_DetailRowCollapsing(s, e)
    {
        BankInfo_IsDetailRowExpanded = false;
        s.SetFocusedRowIndex(e.visibleIndex);
        if (Bank_IsVouchingMode == false)
        {
            BankPrf_FAB.SetVisible(false);
        }
        if (Bank_IsVouchingMode == true)
        {
            if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false)
            {
                CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
    }
    </script>
