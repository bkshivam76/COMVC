@using DevExtreme.AspNet.Mvc;
@{

    var SessionGUID = Request.QueryString["SessionGUID"];
    bool SpecialGroupings = (bool)ViewBag.SpecialGroupings;
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;  
    int ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;

}

@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar)
                 .ID("BankListGrid_dx")
                 .DataSource(d => d.Mvc().Controller("Bank").LoadAction("Frm_Bank_Info_GridData_dx").LoadMode(DataSourceLoadMode.Raw).Key("ID"))
                 .Columns(columns =>
                 {
                     columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);//Bug #137209 Fix
                     columns.Add().DataField("iIcon").Name("iIcon").Caption("").CellTemplate(new JS("BankListGrid_dx_iIconTemplate")).Width(30)
                     .HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource")).RenderAsync(true);
                     columns.Add().DataField("BankListGrid_dx_Compact_Column").Name("BankListGrid_dx_Compact_Column").Caption("").Visible(false).CellTemplate(new JS("BankListGrid_dx_Compact_Column_Template"))
                     .CalculateCellValue("BankListGrid_dx_Compact_Column_CellValue").Width("100%").RenderAsync(true).ShowInColumnChooser(false);
                     columns.Add().DataField("Name").Caption("Name").MinWidth(150);
                     columns.Add().DataField("Branch").Caption("Branch").MinWidth(150);
                     columns.Add().DataField("BA_ACCOUNT_NO").Caption("Account No.").MinWidth(135);
                     columns.Add().DataField("Special_Ref").Caption("Reference").MinWidth(30).Width(100);
                     columns.Add().DataField("BA_CUST_NO").Caption("Customer No.").MinWidth(120);
                     columns.Add().DataField("OP_AMOUNT").Caption("Opening balance").MinWidth(120)
                     .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     //.CustomizeText("function(cellInfo){return DxGrid_FormatNumber(cellInfo.value)}");
                     columns.Add().DataField("CL_AMOUNT").Caption("Closing balance").MinWidth(120)
                     .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     //.CustomizeText("function(cellInfo){return DxGrid_FormatNumber(cellInfo.value)}");
                     columns.Add().DataField("BA_OTHER_DETAIL").Caption("Other Details").MinWidth(120);
                     columns.Add().DataField("BB_IFSC_CODE").Caption("IFSC Code").MinWidth(120);
                     columns.Add().DataField("BB_MICR_CODE").Caption("MICR Code").MinWidth(120);
                     columns.Add().DataField("BI_BANK_PAN_NO").Caption("PAN. No.").MinWidth(120);
                     columns.Add().DataField("BA_TAN_NO").Caption("TAN. No.").MinWidth(120);
                     columns.Add().DataField("BA_TEL_NOS").Caption("Tel. No.").MinWidth(120);
                     columns.Add().DataField("BA_EMAIL_ID").Caption("Email ID").MinWidth(120);

                     columns.Add().DataField("BA_OPEN_DATE").Caption("A/c. Open date").MinWidth(140)
                      .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                     columns.Add().DataField("BA_CLOSE_DATE").Caption("A/c. Closed date").MinWidth(140)
                      .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                     columns.Add().DataField("BA_ACCOUNT_TYPE").Caption("Account Type").MinWidth(120).GroupIndex(0).SortOrder(SortOrder.Desc).GroupCellTemplate(new JS("BankListGrid_dx_GroupCell_Template"));
                     if (SpecialGroupings == true)
                     {
                         columns.Add().DataField("Action_Status").Caption("Status").MinWidth(100).GroupIndex(1).GroupCellTemplate(new JS("BankListGrid_dx_GroupCell_Template"));
                         columns.Add().DataField("BA_ACCOUNT_NEW").Caption("New A/c.").MinWidth(100).GroupIndex(2).GroupCellTemplate(new JS("BankListGrid_dx_GroupCell_Template"));
                     }
                     else
                     {
                         columns.Add().DataField("Action_Status").Caption("Status").Visible(false);
                         columns.Add().DataField("BA_ACCOUNT_NEW").Caption("New A/c.").Visible(false);
                     }
                     columns.Add().DataField("Action_Date").Caption("Action Date").Visible(false).MinWidth(120);
                     columns.Add().DataField("Action_By").Caption("Action By").Visible(false).MinWidth(120);
                     columns.Add().DataField("Add_By").Caption("Added By").Visible(false).MinWidth(120);
                     columns.Add().DataField("Add_Date").Caption("Added Date").Visible(false).MinWidth(120);
                     columns.Add().DataField("CrossedTimeLimit").Caption("Crossed Time Limit").Visible(false).MinWidth(120);
                     columns.Add().DataField("Edit_By").Caption("Edited By").Visible(false).MinWidth(120);
                     columns.Add().DataField("Edit_Date").Caption("Edited Date").Visible(false).MinWidth(120);
                     columns.Add().DataField("ID").Caption("ID").Visible(false).MinWidth(120).SortOrder(SortOrder.Asc);
                     columns.Add().DataField("OpenActions").Caption("Open Actions").Visible(false).MinWidth(120);
                     columns.Add().DataField("RemarkStatus").Caption("Remark Status").Visible(false).MinWidth(120);
                     columns.Add().DataField("Remarks").Caption("Remarks").Visible(false).MinWidth(120);
                     columns.Add().DataField("YearID").Caption("Year ID").Visible(false).MinWidth(120);
                     columns.Add().DataField("iREJECTED_COUNT").Caption("iREJECTED_COUNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("BA_FCRA_UTIL").Caption("BA_FCRA_UTIL").Visible(false).MinWidth(120);
                     columns.Add().DataField("iRESPONDED_COUNT").Caption("iRESPONDED_COUNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("iCOMPLETE_ATTACH_COUNT").Caption("iCOMPLETE_ATTACH_COUNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("iREQ_ATTACH_COUNT").Caption("iREQ_ATTACH_COUNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("iOTHER_ATTACH_CNT").Caption("iOTHER_ATTACH_CNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("iALL_ATTACH_CNT").Caption("iALL_ATTACH_CNT").Visible(false).MinWidth(120);

                 })           
                 .Summary(s =>

                 {

                     s.TotalItems(item => item.Add().Name("OP_AMOUNT_OP_AMOUNT_sum").SummaryType(SummaryType.Sum).Column("OP_AMOUNT").DisplayFormat("Grand Total= {0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}")));
                  
                     if (SpecialGroupings == false)
                     {
                         
                         s.GroupItems(item => item.Add().Name("OP_AMOUNT_OP_AMOUNT_sum").SummaryType(SummaryType.Sum).Column("OP_AMOUNT").ShowInGroupFooter(true).DisplayFormat("Total: {0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}")));
                         
                     }s.RecalculateWhileEditing(true);
                 })
                 .MasterDetail(md =>
                 {
                     md.AutoExpandAll(false);
                     md.Enabled(!VouchingMode);
                     md.Template(new JS("BankListGrid_dx_DetailTemplate"));
                 })
         .OnInitialized("BankListGrid_dx_OnInitialized")
         .OnCellPrepared("BankListGrid_dx_OnCellPrepared")
         .OnRowPrepared("BankListGrid_dx_OnRowPrepared")
         .OnContentReady("BankListGrid_dx_OnContentReady")
         .OnCellDblClick("BankListGrid_dx_OnCellDblClick")
         .OnSelectionChanged("BankListGrid_dx_OnSelectionChanged")    
         .OnRowExpanding("BankListGrid_dx_OnRowExpanding")
         .OnRowCollapsing("BankListGrid_dx_OnRowCollapsing")
         .OnContextMenuPreparing("BankListGrid_dx_OnContextMenuPreparing")
)