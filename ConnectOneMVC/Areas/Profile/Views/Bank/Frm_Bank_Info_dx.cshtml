    <style>
        .GridrowMouseHover {
            box-shadow: inset 0px 0px 5px 0px rgb(0, 114, 198);
        }

        .GridFloatDiv {
            position: relative;
            z-index: 2;
            box-shadow: 2px 2px 2px 2px #888888;
            background-color: white;
        }

        .hideHeader {
            display: none;
        }

        #BankListGrid {
            width: 100% !important;
            max-width: 100% !important
        }

        .dxgvDetailRow_Aqua td.dxgvDetailCell_Aqua {
            padding: 18px 0
        }
    </style>
    <div id="BankProfile_ParentDiv_dx">
        @*<div class="report_header_div_main">*@
        <div id="contentBankProfile_dx" class="report_header_div_main clearfix">
            <div class="report_header_div">
                <label class="report_header_label">Bank Account Information</label>
            </div>
            @*Buttons*@
            <div class="report_button_div">
                @(Html.DevExtreme().Switch().ID("BankVouchingModeSwitch_dx").SwitchedOnText("Vouching On").SwitchedOffText("Vouching Off").OnValueChanged("Bank_VouchingSwitch_ValueChange_dx").Width(100).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
                @(Html.DevExtreme().Switch().ID("BankViewModeSwitch_dx").SwitchedOnText("Compact").SwitchedOffText("Default").OnValueChanged("Bank_ViewSwitch_ValueChange_dx").Width(70).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
                @if (ViewBag.LockUnlock != false)
                {
                    @(Html.DevExtreme().Button().ID("BankModelUnlock_dx").Text("Unlock").Icon("add").Visible(true).OnClick(@<text> function () { BankOnUnLockClick_dx(); } </text>) )

                    @(Html.DevExtreme().Button().ID("BankModelLock_dx").Text("Lock").Icon("add").Visible(true).OnClick(@<text> function () { BankOnLockClick_dx(); } </text>) )
                }
                @(Html.DevExtreme().Button().ID("GetBankStatement_BankAcc_Profile").Text("Bank Statement").Visible(true).OnClick("getBankstatement_BankAcc_Onclick") )
                @(Html.DevExtreme().Button().ID("BankModelNew_dx").Text("New").Icon("add").Visible(true).OnClick(@<text> function () { BankProfile_OnNewClick_dx(); } </text>) )
                @(Html.DevExtreme().Button().ID("BankModelEdit_dx").Text("Edit").Visible(true).Icon("edit").OnClick(@<text> function () { BankProfile_OnEditClick_dx(); } </text>) )
                @(Html.DevExtreme().Button().ID("BankModelDelete_dx").Text("Delete").Icon("trash").Visible(true).OnClick(@<text> function () { BankProfile_OnDeleteClick_dx(); } </text>) )
                @(Html.DevExtreme().Button().ID("BankModelView_dx").Text("View").Icon(IconID.ViewCustomers16x16devav).Icon("doc").Visible(true).OnClick(@<text> function () { BankProfile_OnViewClick_dx(); } </text>) )
                @(Html.DevExtreme().Button().ID("BankToggleScrollBar_dx").Text(ViewBag.ShowHorizontalBar == 1 ? "Default Data" : "Full Data").Width(ViewBag.ShowHorizontalBar == 1 ? 110 : 90).Icon("toolbox").OnClick(@<text> function () { BankchangeMode_dx(); } </text>) )
                @(Html.DevExtreme().Button().ID("BankModelListPreview_dx").Text("Export").Icon("save").Width(80).OnClick(@<text> function () { OnBankListPreviewClick_dx(); } </text>) )
                @(Html.DevExtreme().Button().ID("BankModelCLOSE_dx").Text("Close").Icon("clear").OnClick(@<text> function (){ closeProfile_Bank_dx(); } </text>) )

            </div>
            @*</div>*@
        </div>
        <div class="col-md-12 no-padding" id="BankProfile_grid_DIV_dx">
            <form>
                <div id="bankReloadPartialView_dx" class="parent_table">
                    @Html.Partial("Frm_Bank_Info_Grid_dx")
                </div>
            </form>

        </div>
        <div class="footer-MainBoxdiv" style="display:inline-block;width:100%">
            <div class="setFooterItem">
                <div class="footer-inner">
                    <div class="list_footer_left_margin">
                        <div class="footericon">
                            <i id="Bank_LockICON_dx" style="color:red;font-size:35px;"></i>
                        </div>
                        @*<div class="footer-locktext">
                                <div id="BankLbl_Status_dx" style="font-size:23px" class="left_footertext_top"></div>
                            </div>*@
                        <div class="footer-locktext">
                            <div id="Bank_Lbl_ActionOn_dx" class="left_footertext_top"></div>
                            <div id="Bank_Lbl_ActionBy_dx" class="left_footertext_bottom"></div>
                        </div>
                    </div>
                    <div class="list_footer_left_margin">
                        <div class="footer-text">
                            <p id="BankLbl_Create_dx" class="right_footertext_top"></p>
                            <p id="BankLbl_Modify_dx" class="right_footertext_bottom"></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
