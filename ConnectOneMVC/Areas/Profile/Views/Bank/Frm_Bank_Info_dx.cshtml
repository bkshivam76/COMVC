    function Bank_VouchingSwitch_ValueChange_dx(e)
    {
        Bank_IsVouchingMode_dx = e.value;
        if (BankInfo_SetVouchingModeOn_dx == true)
        {
            BankInfo_SetVouchingModeOn_dx = false;
        }
        else
        {
            BankPrf_FAB_dx.SetVisible(false);
        }
        if (Bank_IsVouchingMode_dx == true)
        {
            OpenRightPane();
            ClearLeftPane();
            OpenLeftPane();
        }
        else
        {
            CloseRightPane();
            ClearLeftPane();
            CloseLeftPane();
        }
        BankListGrid_dx.clearSelection();
        BankListGrid_dx.option("masterDetail.enabled", !Bank_IsVouchingMode_dx)
        BankListGrid_dx.repaint();
    }
    function Bank_ViewSwitch_ValueChange_dx(e)
    {
        Bank_ViewMode_dx = e.value == false ? "Default" : "Compact";
        if (BankInfo_SetVouchingModeOn_dx == true)
        {
            $("#BankVouchingModeSwitch_dx").dxSwitch("instance").option("value", true);
        }
        BankListGrid_dx.beginUpdate();
        var columns = BankListGrid_dx.option("columns");
        if (Bank_ViewMode_dx == "Compact")
        {
            VisibleColumns_BankListGrid_dx = [];
            for (var i = 0; i < columns.length; i++)
            {
                var name = columns[i].dataField;
                var ColumnVisible = BankListGrid_dx.columnOption(name, "visible");
                if (name == "BankListGrid_dx_Compact_Column") {
                    BankListGrid_dx.columnOption(name, "visible", true);
                }
                else if (ColumnVisible == true && name != "iIcon")
                {
                    VisibleColumns_BankListGrid_dx.push(name);
                    BankListGrid_dx.columnOption(name, "visible", false);
                }
            }
        }
        else
        {
            BankListGrid_dx.columnOption("BankListGrid_dx_Compact_Column", "visible", false);
            for (var i = 0; i < VisibleColumns_BankListGrid_dx.length; i++) {
                BankListGrid_dx.columnOption(VisibleColumns_BankListGrid_dx[i], "visible", true);
            }
        }
        BankListGrid_dx.repaint();
        BankListGrid_dx.endUpdate();
    }
    function BankchangeMode_dx()
    {
        BankListGrid_dx.beginUpdate();
        if (Bank_ShowHorizontalBar_dx == 0)
        {
            Bank_ShowHorizontalBar_dx = 1;
            $("#BankToggleScrollBar_dx").find("span").text("Default Data");
            $("#BankToggleScrollBar_dx").width(110);
            BankListGrid_dx.option("columnHidingEnabled", false);
            BankListGrid_dx.option("allowColumnResizing", true)
        }
        else
        {
            Bank_ShowHorizontalBar_dx = 0;
            $("#BankToggleScrollBar_dx").find("span").text("Full Data");
            $("#BankToggleScrollBar_dx").width(90);
            BankListGrid_dx.option("columnHidingEnabled", true)
            BankListGrid_dx.option("allowColumnResizing", false)
        }
        BankListGrid_dx.endUpdate();
    }
    function OnBankListPreviewClick_dx()
    {
        if ("@Bank_ExportRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        OpenPopup("Bank_report_modal", "Export Option", "@Url.Action("Frm_Export_Options_dx", "Bank", new { @area = "Profile" })", "auto", 125);
    }
    function Bank_UpdateFooterDetail_dx(BankID_BankProfile, Bank_Action_Status, Bank_Add_Date, Bank_Add_By, Bank_Action_Date, Bank_Action_By, Bank_Edit_Date, Bank_Edit_By)
    {
        var Status = "";
        var Lbl_Status = "";
        var Lbl_StatusBy = "";
        var Pic_Status = "";
        var Lbl_Create = "";
        var Lbl_Modify = "";
        var Lbl_Status_Color = "";
        var Lbl_ActionOn = "";
        var Lbl_ActionBy = "";
        var StatusStr = "";
        if (BankID_BankProfile != null)
        {
            Bank_Add_Date = (moment(Bank_Add_Date).format("DD/MM/YYYY HH:mm:ss"));
            Bank_Edit_Date = (moment(Bank_Edit_Date).format("DD/MM/YYYY HH:mm:ss"));
            Bank_Action_Date = (moment(Bank_Action_Date).format("DD/MM/YYYY HH:mm:ss"));
            Status = Bank_Action_Status;
            StatusStr = Status == "Locked" ? "Locked" : Status == null ? null : "UnLocked";

            if (Status && Status.toUpperCase() == "LOCKED") {
                Lbl_Status = "Completed";
                Lbl_Status_Color = "blue";
                Pic_Status = "fa fa-lock";
            }
            else {
                Pic_Status = "fa fa-unlock";
                Lbl_Status = Status;
                if (Status && Status.toUpperCase() == "COMPLETED") {
                    Lbl_Status_Color = "green";
                }
                else {
                    Lbl_Status_Color = "red";
                }
            }
            if (Bank_Action_Date) {
                Lbl_ActionOn = StatusStr + " On: " + Bank_Action_Date;
                Lbl_ActionBy = StatusStr + " By: " + Bank_Action_By;
            }

            else {
                Lbl_ActionOn = "";
                Lbl_ActionBy = "";
            }
            if (Bank_Add_Date) {
                Lbl_Create = "Add On: " + Bank_Add_Date + ", By: " + Bank_Add_By;
            }
            else {
                Lbl_Create = "";
            }

            if (Bank_Edit_Date) {
                Lbl_Modify = "Edit On: " + Bank_Edit_Date + ", By: " + Bank_Edit_By;
            }
            else {
                Lbl_Modify = "";
            }
        }
        $('#BankLbl_Status_dx').text(Lbl_Status);
        $('#Bank_Lbl_ActionOn_dx').text(Lbl_ActionOn)
        $('#Bank_Lbl_ActionBy_dx').text(Lbl_ActionBy);
        $('#BankLbl_Create_dx').text(Lbl_Create);
        $('#BankLbl_Modify_dx').text(Lbl_Modify);
        if (Lbl_Status_Color != "") {
            $('#BankLbl_Status_dx').css('color', Lbl_Status_Color);
        }
        if (Pic_Status == "fa fa-lock") {
            $('#Bank_LockICON_dx').addClass(Pic_Status).removeClass("fa-unlock");
        }
        else if (Pic_Status == "fa fa-unlock") {
            $('#Bank_LockICON_dx').addClass(Pic_Status).removeClass("fa-lock");
        }
        else {
            $('#Bank_LockICON_dx').removeClass("fa");
            $('#Bank_LockICON_dx').removeClass("fa-lock");
            $('#Bank_LockICON_dx').removeClass("fa-unlock");
        }
    }

