    function BankListGrid_dx_OnCellPrepared(e)
    {
        if (e.rowType == "data") {
            if (Bank_IsVouchingMode_dx == true) {
                if (e.column.dataField === "iIcon") {
                    $(e.cellElement).attr("onmouseover", "OnGridRowMouseHoverIn(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.key + "')");
                    $(e.cellElement).attr("onmouseout", "OnGridRowMouseHoverOut(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.key + "')");
                }
            }
            $(e.cellElement).attr("id", e.element[0].id + "_Cell_" + e.key + "|" + e.column.dataField);
            /*$(e.cellElement).addClass("col_" + e.column.dataField + " row_" + e.key);*/
        }
    }
    function BankListGrid_dx_OnRowPrepared(e)
    {
        if (e.rowType == "data")
        {
            var GridName = e.element[0].id;
            $(e.rowElement).addClass(GridName + "_DataRow_" + e.key)
            if (e.data.RemarkStatus != null && e.data.RemarkStatus == "OPEN" || e.data.RemarkStatus == "REOPENED") {
                $(e.rowElement).css("background-color", "gold");
            }
            if (e.data.RemarkStatus == null && e.data.Remarks != null && e.data.Remarks == true && e.data.CrossedTimeLimit != null && e.data.CrossedTimeLimit == 0) {
                $(e.rowElement).css("background-color", "lightgreen");
            }
            if (e.data.CrossedTimeLimit != null && e.data.CrossedTimeLimit > 0) {
                $(e.rowElement).css("background-color", "mistyrose");
            }
            DxGrid_CreatePreviewRow(e, Bank_IsVouchingMode_dx, "Master")
        }
        else if (e.rowType == "detailAdaptive") {
            DxGrid_MovePreviewRowAfterAdaptiveRow(e)
        }
    }
    function BankListGrid_dx_OnContentReady(e)
    {
        DxGrid_RowSelectionTobeCheckedAfterAnyAction(e, Expanded_Row_Key_Bank_dx, Select_xid_bank_dx)
        Select_xid_bank_dx = null;
        DxGrid_OnContentReady(e, Bank_ShowHorizontalBar_dx);
    }
    function BankListGrid_dx_OnCellDblClick(e)
    {
        if (e.rowType == "data") {
            if (Bank_IsVouchingMode_dx == true && Bank_ViewMode_dx == "Default") {
                OnGridCellClick(e.event, e.cellElement[0], e.columnIndex, e.rowIndex, e.element[0].id, e.key, e.column.dataField)
            }
            else if (Bank_IsVouchingMode_dx == false) {
                if (e.rowType == "data")
                    BankProfile_OnEditClick_dx();
            }
        }
    }
    function BankListGrid_dx_OnSelectionChanged(e)
    {
        var selectedRowKeys = e.selectedRowKeys;
        if (selectedRowKeys != null && selectedRowKeys.length > 0) {
            if (Bank_IsVouchingMode_dx) {
                BankPrf_FAB_dx.SetVisible(true);
                BankPrf_FAB_dx.SetActionContext("AddAttachmentContext", false);
            }
            BankListGrid_dx_SelectedRowData(e.selectedRowsData);
        }
        else
        {
            BankID_BankProfile_dx= null;
            Bank_UpdateFooterDetail_dx(BankID_BankProfile_dx, Bank_ActionStatus_dx, Bank_AddDate_dx, Bank_AddBy_dx, Bank_ActionDate_dx, Bank_ActionBy_dx, Bank_EditDate_dx, Bank_EditBy_dx);
        }
    }
    function BankListGrid_dx_SelectedRowData(selectedData = null)
    {
        if (selectedData == null)
        {
            selectedData = BankListGrid_dx.getSelectedRowsData();
        }
        if (selectedData != null && selectedData.length > 0)
        {
            var values = selectedData[0]
            BankID_BankProfile_dx = values["ID"]
            Bank_EditDate_dx = values["Edit_Date"];
            Bank_EditBy_dx = values["Edit_By"];
            Bank_AddDate_dx = values["Add_Date"];
            Bank_AddBy_dx = values["Add_By"];
            Bank_ActionDate_dx = values["Action_Date"];
            Bank_ActionBy_dx = values["Action_By"];
            Bank_ActionStatus_dx = values["Action_Status"];
            Bank_UpdateFooterDetail_dx(BankID_BankProfile_dx, Bank_ActionStatus_dx, Bank_AddDate_dx, Bank_AddBy_dx, Bank_ActionDate_dx, Bank_ActionBy_dx, Bank_EditDate_dx, Bank_EditBy_dx);
            if (Bank_IsVouchingMode_dx == true)
            {
                OpenLeftPane();
                LeftPaneContent_Bank_dx("BankListGrid_dx", BankID_BankProfile_dx, Bank_IsVouchingMode_dx)
            }
        }
        else
        {
            BankID_BankProfile_dx = null;
        }
    }
    function BankListGrid_dx_OnRowExpanding(e)
    {
        if (Array.isArray(e.key) == false) //not group row
        {
            e.component.collapseRow(Expanded_Row_Key_Bank_dx)
            e.component.selectRows(e.key);
            Expanded_Row_Key_Bank_dx = e.key;
            BankInfo_IsDetailRowExpanded_dx = true;
            var DetailGridID = e.element[0].id + e.key;
            var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
            if (instance != void 0)
            {
                instance.state(null) // grid maintains its state after collapsing so resetting the state when expands again as per old grid
            }
            //e.component.collapseAll(-1);
        }
        else {
            e.component.option("CustomProp.groupRowExpanded", true);
        }
    }
    function BankListGrid_dx_OnRowCollapsing(e)
    {
        if (Array.isArray(e.key) == false) //not group row
        {
            var DetailGridID = e.element[0].id + e.key;
            sessionStorage.removeItem(DetailGridID + "_DetailGridState") //removing grid state from session storage on collapse
            BankInfo_IsDetailRowExpanded_dx = false;
            e.component.selectRows(e.key);
            if (Bank_IsVouchingMode_dx == false) {
                BankPrf_FAB_dx.SetVisible(false);
            }
            var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
            if (instance != void 0) {
                instance.clearSelection();
            }
        }
        else {
            e.component.option("CustomProp.groupRowCollapsed", true);
        }
    }
    function BankListGrid_dx_OnContextMenuPreparing(e)
    {            if (!e.items) e.items = [];
        if (e.target == "header") {

            DxGrid_HeaderContextMenu(e, "@SpecialGroupings")
            }
            else if ((e.target == "content" && e.row && e.row.rowType == "groupFooter") || e.target == "footer")
            {
                if (Bank_ViewMode_dx == "Compact")
                    DxGrid_FooterContextMenu(e, true);
                else
                    DxGrid_FooterContextMenu(e);
            }
            else if (e.target == "content" && e.row && (e.row.rowType == "data" || e.row.rowType =="detailAdaptive"))
            {
                var key = e.component.getKeyByRowIndex(e.row.rowIndex);
                e.component.selectRows(key);
                var expanded = e.component.isRowExpanded(key);
                e.items = [
                    {
                        text: "Expand Detail",
                        icon: "fa-solid fa-arrow-down-wide-short " + (expanded ? "text-muted" : "text-info"),
                        disabled: expanded,
                        visible: !Bank_IsVouchingMode_dx,
                        onItemClick: function ()
                        {
                            if (expanded)
                            {
                            }
                            else
                            {
                                e.component.expandRow(key);
                            }
                        }
                    }, {
                        text: "Collapse Detail",
                        icon: "fa-solid fa-arrow-up-wide-short " + (!expanded ? "text-muted" : "text-info"),
                        disabled: !expanded,
                        visible: !Bank_IsVouchingMode_dx,
                        onItemClick: function () {
                            if (expanded) {
                                e.component.collapseRow(key);
                            }
                            else {
                            }
                        }
                    },
                   {
                        text: "New",
                        icon: "fa-solid fa-plus text-success",
                        beginGroup: true,
                        visible: "@Bank_AddRight"=="True",
                        onItemClick: function ()
                        {
                            BankProfile_OnNewClick_dx();
                        }
                    },
                    {
                        text: "Edit",
                        icon: "fa-solid fa-pen text-info",
                        visible: "@Bank_UpdateRight"=="True",
                        onItemClick: function ()
                        {
                            BankProfile_OnEditClick_dx();
                        }
                    },
                    {
                        text: "Delete",
                        icon: "fa-solid fa-trash",
                        visible: "@Bank_DeleteRight" == "True",
                        onItemClick: function () {
                            BankProfile_OnDeleteClick_dx();
                        }
                    },
                    {
                        text: "View",
                        icon:"fa-regular fa-eye",
                        visible: "@Bank_ViewRight"=="True",
                        onItemClick: function () {

                            BankProfile_OnViewClick_dx();
                        }
                    },
                    {
                        text: "Export",
                        icon: "fa-solid fa-file-export text-warning",
                        visible: "@Bank_ExportRight" == "True",
                        beginGroup: true,
                        onItemClick: function () {
                            OnBankListPreviewClick_dx();
                        }
