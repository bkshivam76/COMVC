    <script>
    function On_BankProfile_dx_FABActionItemClick(s, e)
{
    var img = document.getElementById('RightPane_Img');
    s.ExpandActionGroupItems();
    if (e.actionName === "add_attach") {
        if ("@Help_Attachment_AddRight" == "False") {
            DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
            return;
        }
        if (BankInfo_ParamMandatory_dx == 1) {
            AddAttachment(BankInfo_MasterRowRecID_dx, "Profile_BankAccounts", BankInfo_Doc_ID_dx, BankInfo_Doc_Category_dx, BankInfo_ParamMandatory_dx, BankInfo_FromDateLabel_dx, BankInfo_ToDateLabel_dx, BankInfo_DescriptionLabel_dx, "BankProfileAttachment", null, "BankListGrid_dx", BankInfo_NestedGrid_AccessID_dx);
        }
        else
        {
            Attachment_DirectBrowse(BankInfo_MasterRowRecID_dx, "Profile_BankAccounts", BankInfo_Doc_ID_dx, "BankProfileAttachment", "BankListGrid_dx", BankInfo_NestedGrid_AccessID_dx);
        }
    }
    else if (e.actionName === "edit_attach") {
        if ("@Help_Attachment_EditRight" == "False") {
            DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
            return;
        }
        if (BankInfo_Attachment_RecStatus_dx.toUpperCase() == "LOCKED") {
            DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
            return;
        }
        EditAttachment(BankInfo_MasterRowRecID_dx, "Profile_BankAccounts", BankInfo_AtachmentID_dx, BankInfo_ParamMandatory_dx, BankInfo_FromDateLabel_dx, BankInfo_ToDateLabel_dx, BankInfo_DescriptionLabel_dx, "BankProfileAttachment", null, "BankListGrid_dx", BankInfo_NestedGrid_AccessID_dx);
    }
    else if (e.actionName === "delete_attach")
    {
        if ("@Help_Attachment_DeleteRight" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
            return;
        }
        DeleteAttachment(BankInfo_MasterRowRecID_dx, "Profile_BankAccounts", BankInfo_AtachmentID_dx, BankInfo_ParamMandatory_dx, BankInfo_FromDateLabel_dx, BankInfo_ToDateLabel_dx, BankInfo_DescriptionLabel_dx, null, "BankListGrid_dx", BankInfo_NestedGrid_AccessID_dx, BankInfo_Attachment_RecStatus_dx);
    }
    else if (e.actionName == "Link_Attach")
    {
        LinkAttachment(BankInfo_MasterRowRecID_dx, "Profile_BankAccounts", "Bank Account Information", "BankListGrid_dx", BankInfo_NestedGrid_AccessID_dx);
    }
    else if (e.actionName === "view_attach") {
        if ("@Help_Attachment_ViewRight" == "False") {
            DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
            return;
        }
        ViewDocument(BankInfo_AtachmentID_dx, BankInfo_FileName_dx, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
    }
    else if (e.actionName === "Add_Reason") {
        if (BankInfo_Doc_Category_dx.toLowerCase() == "others") {
            DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
        }
        else {

            AttachmentAddReason(BankInfo_MasterRowRecID_dx, BankInfo_NestedRowMapID_dx, "Profile_BankAccounts", "BankListGrid_dx", BankInfo_NestedGrid_AccessID_dx);
        }
    }
    else if (e.actionName === "Edit_Reason")
    {
        AttachmentEditReason(BankInfo_MasterRowRecID_dx, BankInfo_NestedRowMapID_dx, "Profile_BankAccounts", "BankListGrid_dx", BankInfo_NestedGrid_AccessID_dx, BankInfo_reason_dx);
    }
    else if (e.actionName === "Delete_Reason")
    {
        AttachmentDeleteReason(BankInfo_MasterRowRecID_dx, BankInfo_NestedRowMapID_dx, "BankListGrid_dx", BankInfo_NestedGrid_AccessID_dx);
    }
    else if (e.actionName === "Rotate")
    {
        ImageRotate(img);
    }
    else if (e.actionName === "ZoomOut")
    {
        ImageZoomOut(img);
    }
    else if (e.actionName === "ZoomIn")
    {
        ImageZoomIn(img);
    }
    else if (e.actionName == "Fit")
    {
        ImageFit(img);
    }
    else if (e.actionName == "Back")
    {
        ImageBack(s.uniqueID, "actionItemContext");
    }
    else if (e.actionName == "AuditAction") {
        BankPrf_FAB_dx.SetActionContext("AuditActionContext", true);
    }
    else if (e.actionName == "BackAudit") {
        if (BankInfo_Nested_Doc_Status_dx == "") {
            BankPrf_FAB_dx.SetActionContext("AutoItemContext", true);
        }
        if (BankInfo_Nested_Doc_Status_dx == "NO") {
            BankPrf_FAB_dx.SetActionContext("EditItemContext", true);
        }
        if (BankInfo_Nested_Doc_Status_dx == "YES") {
            BankPrf_FAB_dx.SetActionContext("actionItemContext", true);
        }
    }
    else if (e.actionName == "Accept") {
        BankInfo_AcceptwithoutRemarks_dx();
    }
    else if (e.actionName == "Reject") {
        BankInfo_AcceptRejectVoucher_dx("Reject");
    }
    else if (e.actionName == "AcceptWithRemarks") {
        BankInfo_AcceptRejectVoucher_dx("Accept");
    }
    else if (e.actionName == "AcceptDoc") {

        OnBankInfo_AcceptDoc_dx();
    }
    else if (e.actionName == "RejectDoc") {

        OnBankInfo_RejectDoc_dx();
    }
}
    function OnBankInfo_RejectDoc_dx() {
    if (BankInfo_AtachmentID_dx == null || BankInfo_AtachmentID_dx.length == 0) {
    DevExpress.ui.dialog.alert("No Document Attached..", "Error");
    return;
}
    RejectAttachment(BankInfo_AtachmentID_dx, "BankListGrid_dx", BankInfo_NestedGrid_AccessID_dx);
}
    function OnBankInfo_AcceptDoc_dx() {
        if (BankInfo_AtachmentID_dx == null || BankInfo_AtachmentID_dx.length == 0) {
        DevExpress.ui.dialog.alert("No Document Attached..", "Error");
        return;
    }
        AcceptAttachment(BankInfo_AtachmentID_dx, "BankListGrid_dx", BankInfo_NestedGrid_AccessID_dx);
}
    function BankInfo_AcceptwithoutRemarks_dx() {
        var Recid;
        if (BankInfo_IsDetailRowExpanded_dx == true || Bank_IsVouchingMode_dx) {
            if (BankInfo_MasterRowRecID_dx == null || BankInfo_MasterRowRecID_dx == "") {
                Recid = BankID_BankProfile_dx;
            }
            else {
                Recid = BankInfo_MasterRowRecID_dx;
            }
        }
        else {
            Recid = BankID_BankProfile_dx;
        }
        Entry_AcceptwithoutRemarks(Recid, "Profile_BankAccounts", "BankListGrid_dx", BankInfo_AtachmentID_dx, BankInfo_NestedRowReasonID_dx, BankInfo_NestedRowUniqueID_dx);
    }
    function BankInfo_AcceptRejectVoucher_dx(_actionMethod)
    {
        var Recid;
        if (BankInfo_IsDetailRowExpanded_dx == true || Bank_IsVouchingMode_dx)
        {
            if (BankInfo_MasterRowRecID_dx == null || BankInfo_MasterRowRecID_dx == "")
            {
                Recid = BankID_BankProfile_dx;
            }
            else
            {
                Recid = BankInfo_MasterRowRecID_dx;
            }
        }
        else
        {
            Recid = BankID_BankProfile_dx;
        }
        Entry_AcceptReject(_actionMethod, Recid, "Profile_BankAccounts", "BankListGrid_dx", BankInfo_AtachmentID_dx, BankInfo_NestedRowReasonID_dx, BankInfo_NestedRowUniqueID_dx);
    }
    </script>
