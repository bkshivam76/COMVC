    function BankListGrid_dx_Detail(container, GridName, RecID, vouchingMode, AllColumns)
    {
        var url = "/Profile/Bank/Frm_Bank_Info_GridData_detail_dx?VouchingMode=" + vouchingMode + "&RecID=" + RecID
        var instance = DxGrid_AttachmentGrid_Create(container, GridName, RecID, vouchingMode, AllColumns, url)
        instance.option("onSelectionChanged", BankListGrid_dx_Detail_onSelectionChanged);        
    }          
    function BankListGrid_dx_Detail_onSelectionChanged(e)
    {
        if (BankInfo_IsDetailRowExpanded_dx || Bank_IsVouchingMode_dx)
        {
            if (e.selectedRowsData != null && e.selectedRowsData.length > 0)
            {
                BankInfo_NestedGrid_AccessID_dx = e.element[0].id;
                BankListGrid_dx_Detail_SelectedRowData(e.selectedRowsData)
            }
            else
            {
                BankPrf_FAB_dx.SetActionContext("AddAttachmentContext", false);
            }
        }
    }
    function BankListGrid_dx_Detail_SelectedRowData(selectedData = null)
    {
        if (selectedData == null)
        {
            selectedData = $("#" + BankInfo_NestedGrid_AccessID_dx).dxDataGrid("getSeletedRowsData");
        }
        var values = selectedData[0];
        BankInfo_NestedRowUniqueID_dx = values["UniqueID"];
        if (values["UniqueID"] != null)
        {
            BankPrf_FAB_dx.SetVisible(true);
            BankInfo_Nested_Doc_Status_dx = values["Doc_Status"];

            if (Bank_IsVouchingMode_dx == true) {
                BankPrf_FAB_dx.SetActionContext("AuditActionContext", true);
            }
            else {
                if (BankInfo_Nested_Doc_Status_dx == "") {
                    BankPrf_FAB_dx.SetActionContext("AutoItemContext", true);
                }
                else if (BankInfo_Nested_Doc_Status_dx == "NO") {
                    BankPrf_FAB_dx.SetActionContext("EditItemContext", true);
                }
                else if (BankInfo_Nested_Doc_Status_dx == "YES") {
                    BankPrf_FAB_dx.SetActionContext("actionItemContext", true);
                }
            }
            BankInfo_ParamMandatory_dx = values["Params_Mandatory"];
            BankInfo_FromDateLabel_dx = values["LABEL_FROM_DATE"];
            BankInfo_ToDateLabel_dx = values["LABEL_TO_DATE"];
            BankInfo_DescriptionLabel_dx = values["LABEL_DESCRIPTION"];
            BankInfo_Doc_Category_dx = values["Document_Category"];
            BankInfo_Doc_ID_dx = values["Document_ID"];
            BankInfo_AtachmentID_dx = values["ATTACH_ID"];
            IndexAttachmentID = BankInfo_AtachmentID_dx;
            BankInfo_MasterRowRecID_dx = values["TxnID"];
            BankInfo_MasterRowMID_dx = values["TxnMID"];
            BankInfo_NestedRowMapID_dx = values["MAP_ID"];
            BankInfo_reason_dx = values["Reason"];
            BankInfo_FileName_dx = values["ATTACH_FILE_NAME"];
            BankInfo_Attachment_RecStatus_dx = values["Attachment_Action_Status"];
            if (Bank_IsVouchingMode_dx == true) {
                if (BankInfo_FileName_dx != null && BankInfo_FileName_dx.length > 0) {
                    ViewDocument(BankInfo_AtachmentID_dx, BankInfo_FileName_dx, "BankPrf_FAB_dx", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else {
                    CloseRightPane();
                    ClearRightPane();
                }
            }
        }
        BankInfo_NestedRowReasonID_dx = values["ReasonID"];
        IndexAttachmentReasonID = BankInfo_NestedRowReasonID_dx;
    }     
  
