                    <script>
    var Bank_DG_BankPrf;
    var Branch_DG_BankPrf;
    var SignList1_DG_BankPrf;
    var SignList2_DG_BankPrf;
    var SignList3_DG_BankPrf;
    var ActionMethod_Bank = "@Model.ActionMethod";
    var BankWindow_TakeCloseConfirmation = false;
    async function LookUp_GetBankList_Bank()
    {        
        var $Bank_DG_BankPrf = $("#Frm_Profile_Win_Bank_GLookUp_BankList_datagrid");
        if ($Bank_DG_BankPrf.length)
        {
            Bank_DG_BankPrf = $Bank_DG_BankPrf.dxDataGrid("instance");
            var ddRefresh = false;
            $.ajax({
                type: 'GET',
                url: "/Profile/Bank/RefreshBankList",
                cache: false,
                async: false,
                success: function (data)
                {
                    ddRefresh = data.result;
                    if (data.result == false)
                    {
                        DevExpress.ui.dialog.alert(data.message, "Error..");
                    }
                }
            });
            if (ddRefresh)
            {
                if (ActionMethod_Bank == "_New") {
                    Control_SetReadOnly("GLookUp_BankList_Bank", "dxDropDownBox", false);
                }
                await Bank_DG_BankPrf.refresh();             
            }
        }
    }
    async function LookUp_GetBranchList_Bank()
    {
        var $Branch_DG_BankPrf = $("#Frm_Profile_Win_Bank_GLookUp_BranchList_datagrid");
        if ($Branch_DG_BankPrf.length)
        {
            Branch_DG_BankPrf = $Branch_DG_BankPrf.dxDataGrid("instance");
            var ddRefresh = false;
            $.ajax({
                type: 'GET',
                url: "/Profile/Bank/RefreshBranchList",
                cache: false,
                async: false,
                data: { bankID: bankData},
                success: function (data)
                {
                    ddRefresh = data.result;
                    if (data.result == false)
                    {
                        DevExpress.ui.dialog.alert(data.message, "Error..");
                    }
                }
            });
            if (ddRefresh)
            {
                if (ActionMethod_Bank == "_New") {
                    Control_SetReadOnly("GLookUp_BranchList_Bank", "dxDropDownBox", false);
                }
                await Branch_DG_BankPrf.refresh();            
            }
        }
    }
    async function LookUp_SignList_Bank()
    {        
        var $SignList1_DG_BankPrf = $("#Sign1-datagrid");
        var $SignList2_DG_BankPrf = $("#Sign2-datagrid");
        var $SignList3_DG_BankPrf = $("#Sign3-datagrid");
        if ($SignList1_DG_BankPrf.length)
        {
            SignList1_DG_BankPrf = $SignList1_DG_BankPrf.dxDataGrid("instance");
        }
        if ($SignList2_DG_BankPrf.length)
        {
            SignList2_DG_BankPrf = $SignList2_DG_BankPrf.dxDataGrid("instance");
        }
        if ($SignList3_DG_BankPrf.length)
        {
            SignList3_DG_BankPrf = $SignList3_DG_BankPrf.dxDataGrid("instance");
        }
        var ddRefresh = false;
        $.ajax({
            type: 'GET',
            url: "/Profile/Bank/RefreshSignList",
            cache: false,
            async: false,
            success: function (data) {
                ddRefresh = data.result;
                if (data.result == false) {
                    DevExpress.ui.dialog.alert(data.message, "Error..");
                }
            }
        });
        if (ddRefresh)
        {
            await Promise.all([SignList1_DG_BankPrf.refresh(), SignList2_DG_BankPrf.refresh(), SignList3_DG_BankPrf.refresh()]);
        }
    }
                    </script>@* DD init *@
                    <script>
                        var bankData = "";
                        var Bank_DD_ValueChange_Complete = false;
                        function GLookUp_BankList_EditValueChanged_Bank(e) {
                            Bank_DD_ValueChange_Complete = false;
                            e.component.close();
                            if (e.value == null && e.previousValue != null) {
                                Bank_DG_BankPrf.clearSelection();
                                Branch_DG_BankPrf.clearSelection();
                                Bank_DD_ValueChange_Complete = true;
                                return;
                            }
                            if (Bank_DG_BankPrf.getSelectedRowsData().length > 0) {
                                ShowLoader();
                                var item = Bank_DG_BankPrf.getSelectedRowsData()[0];
                                bankData = item.REC_ID;
                                $("#Txt_PAN_Bank").dxTextBox("instance").option("value", item["BI_BANK_PAN_NO"]);
                                LookUp_GetBranchList_Bank().then((r) => { Bank_DD_ValueChange_Complete = true; HideLoader(); });
                            }
                        }
                        function GLookUp_BranchList_EditValueChanged_Bank(e) {
                            e.component.close();
                            if (e.value == null && e.previousValue != null) {
                                Branch_DG_BankPrf.clearSelection();
                                return;
                            }
                            if (Branch_DG_BankPrf.getSelectedRowsData().length > 0) {
                                var item = Branch_DG_BankPrf.getSelectedRowsData()[0];
                                $("#Txt_IFSC_Bank").dxTextBox("instance").option("value", item["BB_IFSC_CODE"]);
                                $("#Txt_MICR_Bank").dxTextBox("instance").option("value", item["BB_MICR_CODE"]);
                            }
                        }
                        function Look_SignList1_EditValueChanged(e) {
                            e.component.close();
                            if (e.value == null && e.previousValue != null) {
                                SignList1_DG_BankPrf.clearSelection();
                                return;
                            }
