                    <script>
    function bankPRf_SaveClick(e)
    {
        if (ActionMethod_Bank == "_Delete") {
            var confirm = DevExpress.ui.dialog.confirm("Sure You Want To Delete This Entry...?", "Confirm");
            confirm.done(function (result) {
                if (result) {
                    $("#BankPrfForm").submit();
                }
            });
        }
        else
        {
            var check = e.validationGroup.validate();
            if (check.isValid)
            {
                $("#BankPrfForm").submit();
            }
        }
    }
    function BankAjaxSuccessForm(data)
    {
        BankWindow_TakeCloseConfirmation = false;
        HideLoader();    
        if (data.jsonParam.result == false)
        {
            if (data.jsonParam.refreshgrid)
            {
                var GridInstance = $('#BankListGrid_dx').data("dxDataGrid")
                if (GridInstance !== void 0) {
                    BankListGrid_dx_Refresh();
                }
                else {
                    BankListGrid.Refresh();
                }           
            }
            var alert = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
            alert.done(function (dialogResult)
            {
                if (data.jsonParam.focusid != null)
                {
                    if (dialogResult)
                    {
                        var id = "#" + data.jsonParam.focusid;
                        setTimeout(function ()
                        {
                            $(id).find('input').focus();
                        }, Timeout100);
                    }
                }
            });
            if (data.jsonParam.closeform == true)
            {
                $("#popup_frm_Bank_Window").dxPopup("hide");
            }
        }
        else
        {
            var GridInstance = $('#BankListGrid_dx').data("dxDataGrid")
            if (GridInstance !== void 0)
            {
                if (data.xid != null)
                {
                    Select_xid_bank_dx = data.xid;
                }
                BankListGrid_dx_Refresh();
            }
            else if (typeof BankListGrid !== 'undefined')
            {            
                if (data.xid != null)
                {
                    Select_xid = data.xid;
                }
                BankListGrid.Refresh();
            }     
            var check = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
            check.done(function (dialogResult)
            {
                if (dialogResult)
                {
                    if (typeof BankListGrid !== 'undefined' || GridInstance !== void 0)
                    {
                        if (ActionMethod_Bank == "_New")
                        {
                            var confirm = DevExpress.ui.dialog.confirm('Add More Entry...?', "New ~ Bank Account");
                            confirm.done(function (Result)
                            {
                                if (Result)
                                {
                                    if (GridInstance !== void 0)
                                    {
                                        BankProfile_OnNewClick_dx()
                                    }
                                    else
                                    {
                                        BankProfile_OnNewClick();
                                    }                                    
                                }
                            });
                        }
                        else if (ActionMethod_Bank == "_Edit")
                        {
                            if ("@Bank_LockUnlockRight" == "True")
                            {
                                var confirm = DevExpress.ui.dialog.confirm('Do you want to <font color=red>Lock</font> this Entry...?', "Confirmation");
                                confirm.done(function (Result)
                                {
                                    if (Result)
                                    {
                                        if (GridInstance !== void 0)
                                        {
                                            BankOnLockClick_dx();
                                        }
                                        else
                                        {
                                            BankOnLockClick();
                                        }
                                    }
                                });
                            }
                        }
                    }
                }
                if (data.jsonParam.closeform == true)
                {
                    $("#popup_frm_Bank_Window").dxPopup("hide");
                }
            });
        }
    }
