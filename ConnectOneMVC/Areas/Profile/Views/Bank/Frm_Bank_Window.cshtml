                    {
                        BankWindow_TakeCloseConfirmation = !dialogResult;
                        if (dialogResult)
                        {
                            $("#popup_frm_Bank_Window").dxPopup("hide");
                        }
                    });
                }
            }
        });
    });
                        function SetValidation_BankProfile()
                        {
                            var Txt_TAN_Bank = $("#Txt_TAN_Bank").dxTextBox("instance");
                            Txt_TAN_Bank.option
                                ({
                                    "mask": 'AAAANNNNNA',
                                    "maskRules":
                                    {
                                        'A': /[A-Za-z]/,
                                        'N': /[0-9]/
                                    },
                                    "maskInvalidMessage": "* Invalid TAN No..."
                                });
                            Txt_TAN_Bank.option("isValid", true);
                            $("#Txt_TAN_Bank").dxTextBox({})
                                .dxValidator({
                                    validationRules: [{
                                        type: 'custom',
                                        validationCallback: function (options) {
                                            var result = Txt_TAN_Bank.option("isValid");
                                            return result;
                                        },
                                        reevaluate: true,
                                        message: '* Invalid TAN No.'
                                    }],
                                    validationGroup: "BankProfileValidator"
                                });
                            $("#Txt_Date_Bank").dxDateBox({})
                                .dxValidator({
                                    validationRules: [{
                                        type: 'custom',
                                        validationCallback: function (options) {
                                            var result = $("#Txt_Date_Bank").dxDateBox("instance").option("isValid");
                                            return result;
                                        },
                                        reevaluate: true,
                                        message: 'Cannot Be Less Than 01-01-1900'
                                    }],
                                    validationGroup: "BankProfileValidator"
                                });
                        }
