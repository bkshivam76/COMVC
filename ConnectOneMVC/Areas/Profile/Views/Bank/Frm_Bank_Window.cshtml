<script>
    $(document).ready(function ()
    {
        if (ActionMethod_Bank != "_View") {
            BankWindow_TakeCloseConfirmation = true;
        }
        ShowLoader_Ready();
        TransformTextForDB("BankPrfForm");//Redmine Bug #132560 resolved
        var form = "BankPrfForm";
        AssignIDtoLabel(form, "BankPrf");
        Promise.all([LookUp_GetBankList_Bank(), LookUp_SignList_Bank()]).then((r) =>
       {
            $("#Rad_AccKind_Bank").dxRadioGroup("instance").option("value", "EXISTING");
            if (ActionMethod_Bank == "_Edit" || ActionMethod_Bank == "_Delete" || ActionMethod_Bank == "_View") {
                Data_Binding_Bank();                
                if ("@Model.chk_Corpus_Bank" == "True") {
                    $("#chk_Corpus_Bank").dxCheckBox("instance").option("value", true);
                } else {
                    $("#chk_Corpus_Bank").dxCheckBox("instance").option("value", false);
                }                
                
            }
            else
            {
                $("#Rad_AccType_Bank").dxRadioGroup("instance").option("value", "@Model.Rad_AccType_Bank");
                if ("@Model.Rad_AccKind_Bank".length > 0)
                {
                    $("#Rad_AccKind_Bank").dxRadioGroup("instance").option("value", "@Model.Rad_AccKind_Bank");
                }
            }
            if ("@Model.Rad_AccType_readonly" == "True")
            {
                $("#Rad_AccType_Bank").dxRadioGroup("instance").option("readOnly", true);
            }
            if ("@Model.Rad_AccKind_readonly" == "True")
            {
                $("#Rad_AccKind_Bank").dxRadioGroup("instance").option("readOnly", true);
            }
            if ("@Model.GLookUp_BankList_readonly" == "True")
            {
                Control_SetReadOnly("GLookUp_BankList_Bank", "dxDropDownBox", true);
            }
            if ("@Model.GLookUp_BranchList_readonly" == "True")
            {
                Control_SetReadOnly("GLookUp_BranchList_Bank", "dxDropDownBox", true);
            }
            if ("@Model.Txt_Amount_readonly" == "True")
            {
                $("#Txt_Amount_Bank").dxNumberBox("instance").option("readOnly", true);
            }
            if ("@Model.Fera_Visibility" == "False")
            {
                $("#Fera_Acc_Div").hide();
                $("#AccountNo_Div").removeClass("col-md-8").addClass("col-md-12");
            }
            SetValidation_BankProfile(); 
            setTimeout(function () {
                Set_Form_View_Delete_Mode(null, form, ActionMethod_Bank);
                //Focus_FirstEditable_Field(form, ActionMethod_Bank);
                if (ActionMethod_Bank == "_New" || ActionMethod_Bank == "_Edit")
                {
                    $("#Rad_AccType_Bank").dxRadioGroup("instance").focus();
                }
                HideLoader_Ready();
            }, Timeout500);
        });
    });
    function Data_Binding_Bank()
    {
        Bank_DG_BankPrf.selectRows("@Model.GLookUp_BankList_Bank", false).then((r) =>
        {
            if ("@Model.GLookUp_BankList_readonly" != "True") {
                Control_SetReadOnly("GLookUp_BankList_Bank", "dxDropDownBox", false);
            }
            waitForBankValueChangeToGetOver();
            function waitForBankValueChangeToGetOver()
            {
                if (Bank_DD_ValueChange_Complete == true)
                {
                    Branch_DG_BankPrf.selectRows("@Model.GLookUp_BranchList_Bank", false);
                    if (ActionMethod_Bank != "_Delete" && ActionMethod_Bank != "_View" &&"@Model.GLookUp_BranchList_readonly"!="True")
                    {
                        Control_SetReadOnly("GLookUp_BranchList_Bank", "dxDropDownBox", false);
                    }//Redmine Bug #133248 fixed
                }
                else
                {
                    setTimeout(function ()
                    {
                        waitForBankValueChangeToGetOver();
                    }, Timeout100);
                }
            }
        });
        $("#Rad_AccType_Bank").dxRadioGroup("instance").option("value", "@Model.Rad_AccType_Bank");
        $("#Txt_No_Bank").dxTextBox("instance").option("value", TransformText("@Model.Txt_No_Bank"));
        $("#Rad_AccKind_Bank").dxRadioGroup("instance").option("value", "@Model.Rad_AccKind_Bank");
        $("#Txt_CustNo_Bank").dxTextBox("instance").option("value", TransformText("@Model.Txt_CustNo_Bank"));
        SignList1_DG_BankPrf.selectRows("@Model.Look_SignList1_Bank", false);
        if ("@Model.Look_SignList2_Bank".length > 0)
        {
            SignList2_DG_BankPrf.selectRows("@Model.Look_SignList2_Bank", false);
        }
        if ("@Model.Look_SignList3_Bank".length > 0)
        {
            SignList3_DG_BankPrf.selectRows("@Model.Look_SignList3_Bank", false);
        }
        if ("@Model.Txt_Amount_Bank".length > 0)
        {
            $("#Txt_Amount_Bank").dxNumberBox("instance").option("value", parseFloat("@Model.Txt_Amount_Bank"));
        }
        if ("@Model.Chk_FERA_Bank" == "True")
        {
            $("#Chk_FERA_Bank").dxCheckBox("instance").option("value", true);
        }
        else
        {
            $("#Chk_FERA_Bank").dxCheckBox("instance").option("value", false);
        }
    }
    $(function ()
    {
        $("#popup_frm_Bank_Window").dxPopup({

            onHiding: function (e)
            {
                if (BankWindow_TakeCloseConfirmation == false)
                {
                    $.ajax({
                        type: 'GET',
                        url: "/Profile/Bank/SessionClear_Window",
                        cache: false
                    });
                }
                else
                {
                    e.cancel = true;
