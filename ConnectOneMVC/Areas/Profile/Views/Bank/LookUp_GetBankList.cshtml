

@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("Frm_Profile_Win_Bank_GLookUp_BankList_datagrid")
    .DataSource(new JS(@"component.option(""dataSource"")"))
    .Columns(columns =>
    {

        columns.Add().DataField("BI_BANK_NAME").Caption("Bank Name");
        columns.Add().DataField("BI_BANK_PAN_NO").Caption("PAN No.");
        columns.Add().DataField("REC_ID").Caption("REC_ID").Visible(false);
      

    })
  
    .Selection(s => s.Mode(SelectionMode.Single))
  
)




