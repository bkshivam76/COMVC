
@using DevExtreme.AspNet.Data;
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("Frm_Profile_Win_Bank_GLookUp_BranchList_datagrid")  
    .Columns(columns =>
    {

        columns.Add().DataField("BB_BRANCH_NAME").Caption("Branch Name");
        columns.Add().DataField("BB_IFSC_CODE").Caption("IFSC code");
        columns.Add().DataField("BB_MICR_CODE").Caption("MICR CODE");
        columns.Add().DataField("BB_ID").Caption("BB_ID").Visible(false);
      
    })
   
    .Selection(s => s.Mode(SelectionMode.Single))

)


