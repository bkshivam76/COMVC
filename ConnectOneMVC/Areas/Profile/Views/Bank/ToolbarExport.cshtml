@*@using DevExpress.Web.Mvc;*@
@*@using DevExpress.Web.Demos;*@
@*@using DevExpress.Web;*@
@*@model dynamic*@
@*@model IEnumerable<dynamic>*@

<script type="text/javascript">
    function ToolbarItemClick(s, e) { 
        var input=$('input[name=ExportFormat]');
        input.attr('value', e.item.name);
        input.closest('form').submit();
    }
</script>

@Html.DevExpress().Menu(settings => {
    settings.Name = "ToolbarExportButtons";
    settings.ShowAsToolbar = true;

    settings.ClientSideEvents.ItemClick = "ToolbarItemClick";

    settings.Items.Add(i => {
        i.Name = "ToolbarCaption";
        i.SetTemplateContent("<div class=\"exportToolbarCaption\"><span>Export type:</span></div>");
    });
    //settings.Items.Add(new MVCxMenuItem(string.Empty, "mnuPrint", "~/Content/ChartIcons/BtnPrint.png")
    //{
    //    ToolTip = "Print the chart"
    //});
    var exportFormats = Model != null ? (IEnumerable<ConnectOneMVC.Helper.GridViewExportFormat>)Model : ConnectOneMVC.Helper.GridViewExportDemoHelper.ExportFormatsInfo.Keys;

    foreach (var format in exportFormats) {
        settings.Items.Add(i => {
            var formatName = format.ToString();
            i.Name = formatName;
            i.ToolTip = "Export to " + format;
            i.Image.IconID = string.Format("export_exportto{0}_32x32", formatName.ToLowerInvariant());
        });
    }

}).GetHtml()
<input type="hidden" name="ExportFormat" style="display: none;" />
