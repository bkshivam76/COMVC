    function getStoredData_bankStatement(fromdt, todt, bankShort)
    {
        ShowLoader();
        $.ajax({
            type: 'POST',
            url: '/Profile/BankAPI/Frm_BankStatement_StoredData',
            cache: false,
            data:
            {
                date_from: fromdt,
                date_to: todt,
                accno: Accno_bnkStatement,
                account_ID: account_ID_bnkStatement
            },
            success: function (data)
            {
                if (bankShort == "sbi")
                {
                    plotStatementGrid_SBI([], "BankStatementStoredDataGrid")
                }
                else
                {
                    plotStatementGrid_BOB([], "BankStatementStoredDataGrid")
                }
                HideLoader();
                if (data.jsonParam.result == false)
                {
                    DevExpress.ui.dialog.alert(data.jsonParam.message, "Information")
                }
                else
                {
                    if (data.MaxDate == null || data.MaxDate.length == 0)
                    {
                        DevExpress.ui.dialog.alert("Transactions have not been downloaded for the account yet<br> Or Your Bank Account is not yet Activated for this facility. Please contact Madhuban", "Information")
                    }
                    else if (DateStringToJsDate(todt) > DateStringToJsDate(data.MaxDate))
                    {
                        DevExpress.ui.dialog.alert("Transactions for the account have only been downloaded till " + data.MaxDate + "<br> To Date cannot be more than " + data.MaxDate, "Information")
                    }
                    else if (data.jsonParam.responseData != null && data.jsonParam.responseData.length > 0)
                    {
                        if (bankShort == "sbi")
                        {
                            plotStatementGrid_SBI(data.jsonParam.responseData, "BankStatementStoredDataGrid")
                        }
                        else
                        {
                            plotStatementGrid_BOB(JSON.parse(data.jsonParam.responseData), "BankStatementStoredDataGrid")
                        }                      
                    }
                    else
                    {
                        DevExpress.ui.dialog.alert("There are no transactions for the selected period.", "Information")
                    }
                }
            }
        });
    }
</script>