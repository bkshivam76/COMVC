<div class="BankStatmentExport_ClearReferences">
@using DevExtreme.AspNet.Mvc;
    @{ 
        string GridID = ViewBag.GridID;
        string AccNo = ViewBag.AccNo;
        string FromDate = ViewBag.FromDate;
        string Todate = ViewBag.Todate;
    }
    <div>
        @(Html.DevExtreme().Button()
            .ID("Bankstatment_ExportGridDataxlsx_dx")
            .Text("Export to XLSX")
            //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
            //.AccessKey("L")
            .OnClick("ExportXLSX_dx")
            .Visible(true)
            .Width(120)
        )
    </div>
    <script>    
        function ExportXLSX_dx()
        {
            var FileName = "@AccNo" + "_" + "@FromDate" + "_" + "@Todate" +".xlsx"
            const workbook = new ExcelJS.Workbook();
            const worksheet = workbook.addWorksheet('Sheet');
            DevExpress.excelExporter.exportDataGrid({
                worksheet: worksheet,
                component: $("#" + "@GridID").dxDataGrid("instance"),
                autoFilterEnabled: true,
                customizeCell({ excelCell, gridCell })
                {              
                }
            }).then(function (exportRange) {
                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: 'application/octet-stream' }), FileName);
                });
            });
            $("#Bank_statement_export_modal").dxPopup("hide");
        }
    </script>
</div>