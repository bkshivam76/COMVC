@using DevExtreme.AspNet.Mvc

@{
    int ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;

}


@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar).ID("CoreInstituteListGrid").DataSource(d => d.Mvc().Controller("Core").LoadAction("Frm_Core_Info_InstituteAccount_Grid_dx").LoadMode(DataSourceLoadMode.Raw).Key("ID"))

        .Columns(columns =>
        {
            columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);
            columns.Add().DataField("iIcon").Name("iIcon").Caption("").CellTemplate(new JS("CoreInstituteListGrid_dx_iIconTemplate")).Width(30).HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource")).RenderAsync(true);
            columns.Add().DataField("CoreInstituteListGrid_dx_Compact_column").Name("CoreInstitute_dx_Compact_column").Caption("").Visible(false).CellTemplate(new JS("CoreInstituteListGrid_dx_Compact_Column_Template")).CalculateCellValue("CoreInstituteListGrid_dx_Compact_column_CellValue").Width("100%").RenderAsync(true).ShowInColumnChooser(false);
            columns.Add().DataField("INS_NAME").Caption("Institute Name").MinWidth(120);
            columns.Add().DataField("CEN_NAME").Caption("Name").MinWidth(120);
            columns.Add().DataField("CEN_UID").Caption("U.I.D").MinWidth(120);
            columns.Add().DataField("CEN_INCHARGE").Caption("Incharge Name").MinWidth(120);
            columns.Add().DataField("ID").Caption("ID").Visible(false).SortOrder(SortOrder.Asc).MinWidth(120);
        })
    
        .OnInitialized("CoreInstituteListGrid_dx_OnInitialized")
        .OnCellPrepared("CoreInstituteListGrid_dx_OnCellPrepared")
        .OnRowPrepared("CoreInstituteListGrid_dx_OnRowPrepared")
        .OnContentReady("CoreInstituteListGrid_dx_OnContentReady")
        .OnSelectionChanged("CoreInstituteListGrid_dx_OnSelectionChanged")
        .OnRowExpanding("CoreInstituteListGrid_dx_OnRowExpanding")
        .OnRowCollapsing("CoreInstituteListGrid_dx_OnRowCollapsing")
        .OnContextMenuPreparing("CoreInsttContextMenuFunction")
        .OnCellDblClick("CoreInstituteListGrid_dx_OnCellDblClick")       
)