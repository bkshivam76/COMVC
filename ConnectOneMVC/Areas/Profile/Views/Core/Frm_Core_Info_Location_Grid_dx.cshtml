@using DevExtreme.AspNet.Mvc
@{
    int ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;
}

@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar).ID("CoreLocationListGrid").DataSource(d => d.Mvc().Controller("Core").LoadAction("Frm_Core_Info_Location_Grid_dx").LoadMode(DataSourceLoadMode.Raw).Key("ID"))
             .Columns(columns=> {
                 columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);
                 columns.Add().DataField("iIcon").Name("iIcon").Caption("").CellTemplate(new JS("CoreLocationListGrid_dx_iIconTemplate")).Width(30).HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource")).RenderAsync(true);
                 columns.Add().DataField("CoreLocationListGrid_dx_Compact_column").Name("CoreLocationListGrid_dx_Compact_Column_Template").Caption("").Visible(false).CellTemplate(new JS("CoreLocationListGrid_dx_Compact_Column_Template")).CalculateCellValue("CoreLocationListGrid_dx_Compact_column_CellValue").Width("100%").RenderAsync(true).ShowInColumnChooser(false);
                 columns.Add().DataField("Location_Name").Caption("Location Name").MinWidth(120);
                 columns.Add().DataField("Other_Detail").Caption("Other Detail").MinWidth(120);
                 columns.Add().DataField("Matched_Type").Caption("Matched Type").MinWidth(120);
                 columns.Add().DataField("Matched_Name").Caption("Matched Name").MinWidth(120);
                 columns.Add().DataField("Matched_Instt").Caption("Matched Instt").MinWidth(120);
                 columns.Add().DataField("Capacity").Caption("Capacity").MinWidth(120);
                 columns.Add().DataField("Ac_nonAc").Caption("Ac or Non-Ac").MinWidth(120);
                 columns.Add().DataField("Category").Caption("Category").MinWidth(120);
                 columns.Add().DataField("roomfloor").Caption("Floor").MinWidth(120);
             })            
             .OnInitialized("CoreLocationListGrid_dx_OnInitialized")
             .OnCellPrepared("CoreLocationListGrid_dx_OnCellPrepared")
             .OnRowPrepared("CoreLocationListGrid_dx_OnRowPrepared")
             .OnContentReady("CoreLocationListGrid_dx_OnContentReady")
             .OnSelectionChanged("CoreLocationListGrid_dx_OnSelectionChanged")
             .OnRowExpanding("CoreLocationListGrid_dx_OnRowExpanding")
             .OnRowCollapsing("CoreLocationListGrid_dx_OnRowCollapsing")
             .OnCellDblClick("CoreLocationListGrid_dx_OnCellDblClick")
             .OnContextMenuPreparing("CoreLocationContextMenuFunction")          
)