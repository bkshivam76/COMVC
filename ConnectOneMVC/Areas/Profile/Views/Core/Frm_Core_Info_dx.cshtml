    function AdjustGridHeights() {
        var height = (document.documentElement.clientHeight * 90) / 100;

        try {
            var $locationGridEl = $("#CoreLocationListGrid");
            var locationGrid = $locationGridEl.dxDataGrid("instance");
            if (locationGrid && $locationGridEl.is(":visible")) {
                locationGrid.option("height", height);
                locationGrid.repaint();
            }

            var $instituteGridEl = $("#CoreInstituteListGrid");
            var instituteGrid = $instituteGridEl.dxDataGrid("instance");
            if (instituteGrid && $instituteGridEl.is(":visible")) {
                instituteGrid.option("height", height);
                instituteGrid.repaint();
            }
        } catch (err) {
            console.error("Error adjusting grid heights:", err);
            console.log("Inside the AdjustGridHeights")
        }
    }


    function Core_VouchingSwitch_ValueChange(e)
    {
        CoreInstitut_IsVouchingMode = e.value;
        CoreLocation_IsVouchingMode = e.value;
        //CoreInstituteListGrid_PerformCallBack();
        //CoreLocationListGrid_PerformCallBack();

        refreshCoreInstituteGrid();
        refreshCoreLocationGrid();

        CoreInstituteListGrid.repaint();
        CoreLocationListGrid.repaint();
    }

    function CoreInstituteListGrid_PerformCallBack() {
        $.ajax({
            type: 'GET',
            url: '/Profile/Core/Frm_Core_Info_InstituteAccount_Grid_dx',
            data: {
                VouchingMode: CoreInstitut_IsVouchingMode,
                ViewMode: Core_ViewMode
            },
            success: function (data) {
                $("#CoreInstituteListGrid").dxDataGrid("instance").option("dataSource", data);
            },
            error: function () {
                alert("Error loading data for Institute Accounts.");
            }
        });
    }

    function CoreLocationListGrid_PerformCallBack() {
        $.ajax({
            type: 'GET',
            url: '/Profile/Core/Frm_Core_Info_Location_Grid_dx',
            data: {
                VouchingMode: CoreLocation_IsVouchingMode,
                ViewMode: Core_ViewMode
            },
            success: function (data) {

                $("#CoreLocationListGrid").dxDataGrid("instance").option("dataSource", data);
            },
            error: function () {
                alert("Error loading data for Locations.");
            }
        });
    }

    function Core_ViewSwitch_ValueChange(e) {
        Core_ViewMode = e.value == false ? "Default" : "Compact";

        if (Core_SetVouchingModeOn === true) {
            Core_SetVouchingModeOn = false;
            $("#CoreVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }

         const grids = [
             { id: "CoreLocationListGrid", compactColumn: "CoreLocationListGrid_dx_Compact_column", visibleColumnsArray: VisibleColumns_CoreLocationListGrid },
             { id: "CoreInstituteListGrid", compactColumn: "CoreInstituteListGrid_dx_Compact_column", visibleColumnsArray: VisibleColumns_CoreInstituteListGrid }
         ];

         grids.forEach(gridInfo => {
             const gridInstance = $("#" + gridInfo.id).dxDataGrid("instance");

             if (!gridInstance) return;

             gridInstance.beginUpdate();

             const columns = gridInstance.option("columns");

             if (Core_ViewMode == "Compact") {

                 gridInfo.visibleColumnsArray.length = 0;

                 columns.forEach(col => {
                     const name = col.dataField;
                     if (!name) return;

                     const isVisible = gridInstance.columnOption(name, "visible");

                     if (name === gridInfo.compactColumn) {
                         gridInstance.columnOption(name, "visible", true);
                     } else if (isVisible && name !== "iIcon") {
                         gridInfo.visibleColumnsArray.push(name);
                         gridInstance.columnOption(name, "visible", false);
                     }
                 });
             } else {
                 gridInstance.columnOption(gridInfo.compactColumn, "visible", false);

                 gridInfo.visibleColumnsArray.forEach(name => {
                     gridInstance.columnOption(name, "visible", true);
                 });
             }

             gridInstance.repaint();
             gridInstance.endUpdate();
         });
    }

    function refreshCoreInstituteGrid() {
        const grid = $("#CoreInstituteListGrid_dx").dxDataGrid("instance");
        if (grid) {
            grid.refresh().done(function () {
                grid.clearSelection();
            })
        }
    }

    function refreshCoreLocationGrid() {
        const grid = $("#CoreLocationListGrid_dx").dxDataGrid("instance");
        if (grid) {
            grid.refresh().done(function () {
                grid.clearSelection();
            });
        }
    }


    $(document).ready(function () {
        HideLoader();
        var tabpanel = $("#tabPanel").dxTabPanel("instance");
        tabpanel.option("items[4].visible", false);
        if (Profile_CoreNewright == false)
        {
            $("#CoreModelNew").hide();
            $("#LocationModelNew").hide();
        }
        if (Profile_CoreEditright == false)
        {
            $("#CoreModelEdit").hide();
            $("#LocationModelEdit").hide();
