    function CoreInstituteListGrid_dx_OnRowExpanding(e) {
         if (!Array.isArray(e.key)) {
             e.component.collapseRow(Expanded_Row_Key_CoreInstitute_dx); // collapse previous row
             e.component.selectRows(e.key); // highlight current row
             Expanded_Row_Key_CoreInstitute_dx = e.key; // update last expanded row key
             CoreInstitute_IsDetailRowExpanded = true;

             var DetailGridID = e.element[0].id + e.key;
             var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance");
             if (instance !== undefined) {
                 instance.state(null); // reset detail grid state
             }
        }
         else {
             e.component.option("CustomProp.groupRowExpanded", true);
         }
    }

    function CoreInstituteListGrid_dx_OnRowCollapsing(e) {
         if (!Array.isArray(e.key)) {
             var DetailGridID = e.element[0].id + e.key;
             sessionStorage.removeItem(DetailGridID + "_DetailGridState"); // clear saved state
             CoreInstitute_IsDetailRowExpanded = false;

             e.component.selectRows(e.key); // reselect row

             var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance");
             if (instance !== undefined) {
                 instance.clearSelection(); // clear child grid selection
             }
        }
         else {
