    function CoreInstituteListGrid_dx_OnCellPrepared(e) {
         if (e.rowType === "data") {
             let keyvalue;

             if (typeof e.key === "string") {
                 // Replace non-alphanumeric characters with "_"
                 keyvalue = e.key.replace(/[^0-9A-Za-z]/g, "_");
             } else if (typeof e.key === "number") {
                 keyvalue = "_" + e.key.toString();
             } else if (typeof e.key === "object" && e.key !== null) {
                 // Composite key: convert to string and clean
                 const keyString = Object.values(e.key).join("_");
                 keyvalue = keyString.replace(/[^0-9A-Za-z]/g, "_");
             } else {
                 keyvalue = "Null" + e.rowIndex;
             }

             if (CoreInstitut_IsVouchingMode == true && e.column.dataField === "iIcon") {
                 $(e.cellElement).attr("onmouseover", "OnGridRowMouseHoverIn(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + keyvalue + "')");
                 $(e.cellElement).attr("onmouseout", "OnGridRowMouseHoverOut(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + keyvalue + "')");
             }

             $(e.cellElement).attr("id", e.element[0].id + "_Cell_" + keyvalue + "|" + e.column.dataField);

         }
     }

    function CoreInstituteListGrid_dx_OnRowPrepared(e) {
         if (e.rowType === "data") {
             var GridName = e.element[0].id;
             var keyvalue = e.key != null ? e.key.replace(/^0-9A-Za-z/gi, "_") : "Null" + e.rowIndex;

             $(e.rowElement).addClass(GridName + "_DataRow_" + keyvalue);


            var PreviewRowContent = CoreInstituteListGrid_dx_PreviewRow_Template(e)
            var PreviewRowClass = GridName + "_PreviewRow " + GridName + "_PreviewRow_" + keyvalue + " DataGridPreviewRow"
            var PreviewRowOptions = "";
            if (CoreInstitut_IsVouchingMode == true) {
                PreviewRowOptions = "style='display:none' onmouseover=OnGridPrevRowMouseHoverIn(event,this,'" + GridName + "','" + e.rowIndex + "','" + keyvalue + "') onmouseout=OnGridPrevRowMouseHoverOut(event,this,'" + GridName + "','" + e.rowIndex + "','" + keyvalue + "')"
            }
            var EmptyTdshtml = "";
            var emptyTd = $(e.rowElement).find('td.dx-datagrid-group-space').length
            for (var i = 0; i < emptyTd; i++) {
                EmptyTdshtml += "<td></td>"
            }
            ($(e.rowElement).parent()).append("<tr class='" + PreviewRowClass + "' " + PreviewRowOptions + ">" + EmptyTdshtml + "<td colspan='" + (e.columns.length) + "'>" + PreviewRowContent + "</td></tr>")
        }
    }

    function CoreInstituteListGrid_dx_PreviewRow_Template(e) {
        if (CoreInstitut_IsVouchingMode == true) {
            return DxGrid_AuditButtons(e.element[0].id, e.key, e.rowIndex);
        }
        else {
            return ""
        }
    }

