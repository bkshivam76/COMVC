            SelectedRows_CoreLocation = [];

            CoreLocationID = null;
            CoreLocation_UpdateFooterDetail_dx(
                CoreLocationID,
                CoreLocation_ActionStatus,
                CoreLocation_AddDate,
                CoreLocation_AddBy,
                CoreLocation_ActionDate,
                CoreLocation_ActionBy,
                CoreLocation_EditDate,
                CoreLocation_EditBy
            );
        }
    }

    function CoreLocationListGrid_dx_SelectedRowData(selectedData = null) {
        const gridInstance = $("#CoreLocationListGrid").dxDataGrid("instance");
        if (selectedData == null && gridInstance) {
            selectedData = gridInstance.getSelectedRowsData();
        }

        if (selectedData != null && selectedData.length>0) {

            var values = selectedData[0]

            CoreLocationID = values["ID"];
            CoreLocation_EditDate = values["Edit_Date"];
            CoreLocation_AddDate = values["Add_Date"];
            CoreLocation_AddBy = values["Add_By"];
            CoreLocation_EditBy = values["Edit_By"];
            CoreLocation_ActionStatus = values["Action_Status"];
            CoreLocation_ActionDate = values["Action_Date"];
            CoreLocation_ActionBy = values["Action_By"];
            CoreLocation_UpdateFooterDetail_dx(CoreLocationID, CoreLocation_ActionStatus, CoreLocation_AddDate, CoreLocation_AddBy,
                CoreLocation_ActionDate, CoreLocation_ActionBy, CoreLocation_EditDate, CoreLocation_EditBy);
        }
    }

    function CoreLocationListGrid_dx_OnRowExpanding(e) {
        if (!Array.isArray(e.key)) {
            e.component.collapseRow(Expanded_Row_Key_CoreLocation_dx); // collapse previous row
            e.component.selectRows(e.key); // highlight current row
            Expanded_Row_Key_CoreLocation_dx = e.key; // update last expanded row key
            CoreLocation_IsDetailRowExpanded = true;

            var DetailGridID = e.element[0].id + e.key;
            var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance");
            if (instance !== undefined) {
                instance.state(null); // reset detail grid state
            }
        }
        else {
            e.component.option("CustomProp.groupRowExpanded", true);
        }
    }

    function CoreLocationListGrid_dx_OnRowCollapsing(e) {
        if (!Array.isArray(e.key)) {
            var DetailGridID = e.element[0].id + e.key;
            sessionStorage.removeItem(DetailGridID + "_DetailGridState"); // clear saved state
            CoreLocation_IsDetailRowExpanded = false;

            e.component.selectRows(e.key); // reselect row

            var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance");
            if (instance !== undefined) {
                instance.clearSelection(); // clear child grid selection
            }
        }
        else {
            e.component.option("CustomProp.groupRowCollapsed", true);
        }
    }

    function CoreLocation_UpdateFooterDetail_dx(CoreLocationID, CoreLocation_ActionStatus, CoreLocation_AddDate, CoreLocation_AddBy, CoreLocation_Action_Date, CoreLocation_Action_By, CoreLocation_EditDate, CoreLocation_EditBy) {

        var Status = "";
        var Lbl_Status = "";
        var Lbl_StatusBy = "";
        var Pic_Status = "";
        var Lbl_Create = "";
        var Lbl_Modify = "";
        var Lbl_Status_Color = "";
        var Lbl_ActionOn = "";
        var Lbl_ActionBy = "";

        Status = CoreLocation_ActionStatus;

        if (Status && Status.toUpperCase() == "LOCKED") {
            Lbl_Status = "Completed";
            Lbl_Status_Color = "blue";
            Pic_Status = "Fa Fa-Lock";
        }
        else {
            Pic_Status = "Fa Fa-UnLock";
            Lbl_Status = Status;
            if (Status && Status.toUpperCase() == "COMPLETED")
                Lbl_Status_Color = "green";
            else
                Lbl_Status_Color = "red";
        }

        if (CoreLocation_AddDate) {
            Lbl_Create = "Add On: " + FormatDateTime_ddMMyyyy_HHmmss(CoreLocation_AddDate) + ", By: " + CoreLocation_AddBy;
        }
        else {
            Lbl_Create = "Add On: " + "?, By: " + CoreLocation_AddBy;
        }
        if (CoreLocation_EditDate) {
            Lbl_Modify = "Edit On: " + FormatDateTime_ddMMyyyy_HHmmss(CoreLocation_EditDate) + ", By: " + CoreLocation_EditBy;
        }
        else {
            Lbl_Modify = "Edit On: " + "?, By: " + CoreLocation_EditBy;
        }
        if (CoreLocation_Action_Date) {
            Lbl_ActionOn = "UnLocked On: " + FormatDateTime_ddMMyyyy_HHmmss(CoreLocation_Action_Date);
        }
        else {
            Lbl_ActionOn = "UnLocked On: " + "?";
        }

        Lbl_ActionBy = "UnLocked By: " + CoreLocation_Action_By;

        $('#CoreLocationLbl_Status').text(Lbl_Status);
        $('#CoreLocationLbl_Create').text(Lbl_Create);
        $('#CoreLocation_Lbl_ActionOn').text(Lbl_ActionOn);
        $('#CoreLocation_Lbl_ActionBy').text(Lbl_ActionBy);
        $('#CoreLocationLbl_Modify').text(Lbl_Modify);
        if (Lbl_Status_Color != "") {
            $('#CoreLocationLbl_Status').css('color', Lbl_Status_Color);
        }
        if (Pic_Status != "") {
            $('#CoreLocation_LockICON').css('class', Pic_Status);
        }
    }

    function FormatDateTime_ddMMyyyy_HHmmss(date) {
            return moment(date).format("DD-MM-YYYY HH:mm:ss");
    }

    </script>

</div>
