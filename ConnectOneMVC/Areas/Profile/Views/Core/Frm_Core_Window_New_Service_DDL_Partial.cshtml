@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                .ID("Frm_Profile_Core_New_Service_Grid")//.WordWrapEnabled(true)
                .DataSource(new JS(@"component.option(""dataSource"")"))
                .Columns(columns =>
                {
                    columns.Add().DataField("Institute").Caption("Institute");//.Width(350);
                    columns.Add().DataField("Centre_No").Caption("Centre_No");//.Width(350);
                    columns.Add().DataField("UID").Caption("UID");//.Width(400);
                    columns.Add().DataField("No").Caption("No");//.Width(400);
                    columns.Add().DataField("Service_Place_Name").Caption("ServicePlaceName");//.Width(100);
                    columns.Add().DataField("Place_Type").Caption("PlaceType");//.Width(100);
                    columns.Add().DataField("SP_ID").Caption("SP_ID").Visible(false);//.Width(100);
                })
                .HoverStateEnabled(true)
                .Paging(p => p.PageSize(100))
                .FilterRow(f => f.Visible(true))
                .Scrolling(s => s.Mode(GridScrollingMode.Infinite))
                .Height(300)
                .Selection(s => s.Mode(SelectionMode.Single))
                .OnSelectionChanged(@<text>
                    function(selectedItems) {

                    var keys = selectedItems.selectedRowKeys;                
                    component.option("value", keys);
                    }
                </text>)
)
