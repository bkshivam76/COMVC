@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
        .ID("From_Profile_Core_Property")//.WordWrapEnabled(true)
        .DataSource(new JS(@"component.option(""dataSource"")"))
        .Columns(columns =>
        {
            columns.Add().DataField("Institute").Caption("Institute");//.Width(350);
            columns.Add().DataField("TYPE").Caption("Type");//.Width(400);
            columns.Add().DataField("PROP_NAME").Caption("PropName");//.Width(100);
            columns.Add().DataField("CATEGORY").Caption("Category");//.Width(350);
            columns.Add().DataField("OWNERSHIP").Caption("OwnerShip");//.Width(400);
            columns.Add().DataField("USE_OF_PROPERTY").Caption("UseOf");//.Width(100);
            columns.Add().DataField("LB_ID").Caption("LB_ID").Width(0).Visible(false);

        })
        .HoverStateEnabled(true)
        .Paging(p => p.PageSize(100))
        .FilterRow(f => f.Visible(true))
        .Scrolling(s => s.Mode(GridScrollingMode.Infinite))
        .Height(300)
        .Selection(s => s.Mode(SelectionMode.Single))
        .OnSelectionChanged(@<text>
            function(selectedItems) {

            var keys = selectedItems.selectedRowKeys;
            component.option("value", keys);
            }
        </text>)
)
