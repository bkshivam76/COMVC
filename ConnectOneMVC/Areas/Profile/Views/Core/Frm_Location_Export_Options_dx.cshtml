<div class="CoreLocation_Export_ClearReferences">
@using DevExtreme.AspNet.Mvc;
<div>
    @(Html.DevExtreme().Button()
                .ID("CoreLocation_ExportGridDatapdf")
                .Text("Export to XLSX")
                .OnClick("ExportXLSXLocation")
                .Visible(true)
                .Width(120)
    )
</div>
<script>
    function ExportXLSXLocation() {
        const workbook = new ExcelJS.Workbook();
        const worksheet = workbook.addWorksheet('Sheet');

        DevExpress.excelExporter.exportDataGrid({
            worksheet: worksheet,
            component: $("#CoreLocationListGrid").dxDataGrid("instance"),
            autoFilterEnabled: true,
            customizeCell({ excelCell, gridCell }) {
                if (gridCell.rowType === 'header') {
                    const columnDataField = gridCell.column.dataField;
                    if (columnDataField === 'iIcon') {
                        const Column = worksheet.getColumn(excelCell.col);
                        Column.width = 20;
                    }
                }
            }
        }).then(function (exportRange) {
            workbook.xlsx.writeBuffer().then(function (buffer) {
                saveAs(new Blob([buffer], { type: 'application/octet-stream' }), 'CoreLocation.xlsx');
            });
        });
        $("#CoreLocation_report_modal").dxPopup("hide");
    }
</script>

</div>