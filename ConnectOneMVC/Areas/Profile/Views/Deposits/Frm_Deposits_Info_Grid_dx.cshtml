@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool DBData = ViewBag.DBData == null ? true : ViewBag.DBData;
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;
    string ViewMode = ViewBag.ViewMode == null ? "Default" : (string)ViewBag.ViewMode;
    int ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;

}
@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar)
                         .ID("DepositsListGrid_dx")
                         .DataSource(d => d.Mvc().Controller("Deposits").LoadAction("Frm_Deposits_Info_Grid_dx").LoadMode(DataSourceLoadMode.Raw).Key("ID"))
                         .Columns(columns =>
                         {
                             columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);//Bug #137209 Fix
                             columns.Add().DataField("iIcon").Name("iIcon").Caption("").CellTemplate(new JS("DepositsListGrid_dx_iIconTemplate")).Width(30)
                             .HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource")).RenderAsync(true);
                             columns.Add().DataField("DepositsListGrid_dx_Compact_Column").Name("DepositsListGrid_dx_Compact_Column").Caption("").Visible(false).CellTemplate(new JS("DepositsListGrid_dx_Compact_Column_Template"))
                             .CalculateCellValue("DepositsListGrid_dx_Compact_Column_CellValue").Width("100%").RenderAsync(true).ShowInColumnChooser(false);
                             columns.Add().DataField("ITEM_NAME").Caption("Item Name").MinWidth(280);
                             columns.Add().DataField("DI_AGAINST_INSURANCE").Caption("Against Insurance").MinWidth(180);
                             columns.Add().DataField("PARTY_NAME").Caption("PARTY NAME").MinWidth(180);
                             columns.Add().DataField("DI_DEP_DATE").Caption("Deposit Date").MinWidth(200)
                             .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                             columns.Add().DataField("DI_DEP_PERIOD").Caption("Period (Days)").MinWidth(140)
                             .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                             columns.Add().DataField("DI_INT_RATE").Caption("Interest Rate (%)").MinWidth(165)
                             .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                             columns.Add().DataField("DI_MAT_DATE").Caption("Maturity Date").MinWidth(165)
                             .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                             columns.Add().DataField("Deposit").Caption("Deposit").MinWidth(140)
                             .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                             columns.Add().DataField("Addition").Caption("Addition").MinWidth(140)
                             .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                             columns.Add().DataField("Adjusted").Caption("Adjusted").MinWidth(140)
                             .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                             columns.Add().DataField("Refund").Caption("Refund").MinWidth(140)
                             .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                             columns.Add().DataField("Out_Standing").Caption("Out-Standing").MinWidth(150)
                             .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                             columns.Add().DataField("Reason").Caption("Reason").MinWidth(150);
                             columns.Add().DataField("Special_Ref").Caption("Reference").MinWidth(190);
                             columns.Add().DataField("DI_OTHER_DETAIL").Caption("Other Detail").MinWidth(160);
                             columns.Add().DataField("Type").Caption("Type").MinWidth(120);
                             columns.Add().DataField("Action_Status").Caption("Action_Status").MinWidth(120).Visible(false).GroupIndex(1).GroupCellTemplate(new JS("DepositsListGrid_dx_GroupCell_Template"));
                             columns.Add().DataField("Action_By").Caption("Action By").Visible(false).MinWidth(120);
                             columns.Add().DataField("Action_Date").Caption("Action Date").Visible(false).MinWidth(120);
                             columns.Add().DataField("Add_By").Caption("Added By").Visible(false).MinWidth(120);
                             columns.Add().DataField("Add_Date").Caption("Added Date").Visible(false).MinWidth(120);
                             columns.Add().DataField("Crossed_Time_Limit").Caption("CrossedTimeLimit").Visible(false).MinWidth(125);
                             columns.Add().DataField("Edit_By").Caption("Edited By").Visible(false).MinWidth(120);
                             columns.Add().DataField("Edit_Date").Caption("Edited Date").Visible(false).MinWidth(120);
                             columns.Add().DataField("ID").Caption("ID").Visible(false).MinWidth(120).SortOrder(SortOrder.Asc);
                             columns.Add().DataField("Open_Actions").Caption("OpenActions").Visible(false).MinWidth(125);
                             columns.Add().DataField("Remark_Count").Caption("RemarkCount").Visible(false).MinWidth(125);
                             columns.Add().DataField("RemarkStatus").Caption("Remark Status").Visible(false).MinWidth(120);
                             columns.Add().DataField("Remarks").Caption("Remarks").Visible(false).MinWidth(125);
                             columns.Add().DataField("TR_ID").Caption("TR. ID").Visible(false).MinWidth(120);
                             columns.Add().DataField("YEAR_ID").Caption("Year ID").Visible(false).MinWidth(120);

                             columns.Add().DataField("REJECTED_COUNT").Caption("iREJECTED_COUNT").Visible(false).MinWidth(120);
                             columns.Add().DataField("RESPONDED_COUNT").Caption("iRESPONDED_COUNT").Visible(false).MinWidth(120);
                             columns.Add().DataField("COMPLETE_ATTACH_COUNT").Caption("iCOMPLETE_ATTACH_COUNT").Visible(false).MinWidth(120);
                             columns.Add().DataField("REQ_ATTACH_COUNT").Caption("iREQ_ATTACH_COUNT").Visible(false).MinWidth(120);
                             columns.Add().DataField("OTHER_ATTACH_CNT").Caption("OTHER_ATTACH_CNT").Visible(false).MinWidth(120);
                             columns.Add().DataField("ALL_ATTACH_CNT").Caption("ALL_ATTACH_CNT").Visible(false).MinWidth(120);

                         })                  
                         .Summary(s =>

                         {

                             s.TotalItems(item => item.Add().Name("Deposit_Deposit_sum").SummaryType(SummaryType.Sum).Column("Deposit").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}")));
                             s.TotalItems(item => item.Add().Name("Refund_Refund_sum").SummaryType(SummaryType.Sum).Column("Refund").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}")));
                             s.TotalItems(item => item.Add().Name("Adjusted_Adjusted_sum").SummaryType(SummaryType.Sum).Column("Adjusted").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}")));
                             s.TotalItems(item => item.Add().Name("Out_Standing_Out_Standing_sum").SummaryType(SummaryType.Sum).Column("Out_Standing").DisplayFormat("{0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}")));

                             s.RecalculateWhileEditing(true);
                         })
        .MasterDetail(md =>
        {
            md.AutoExpandAll(false);
            md.Enabled(!VouchingMode);
            md.Template(new JS("DepositsListGrid_dx_DetailTemplate"));
        })
        .OnInitialized("DepositsListGrid_dx_OnInitialized")
        .OnCellPrepared("DepositsListGrid_dx_OnCellPrepared")
        .OnRowPrepared("DepositsListGrid_dx_OnRowPrepared")
        .OnContentReady("DepositsListGrid_dx_OnContentReady")
        .OnCellDblClick("DepositsListGrid_dx_OnCellDblClick")
        .OnSelectionChanged("DepositsListGrid_dx_OnSelectionChanged")
        .OnRowExpanding("DepositsListGrid_dx_OnRowExpanding")
        .OnRowCollapsing("DepositsListGrid_dx_OnRowCollapsing")
        .OnContextMenuPreparing("DepositsListGrid_dx_OnContextMenuPreparing")    
)