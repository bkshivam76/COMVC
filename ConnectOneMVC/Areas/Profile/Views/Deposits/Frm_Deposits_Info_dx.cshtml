<div class="DepositsProfile_ClearReferences">
    @using DevExtreme.AspNet.Mvc;

    @model IEnumerable<dynamic>
    @{
        ViewBag.Title = "Index";
        Layout = null;
        string UserType = (string)ViewBag.UserType;
        bool Deposits_AddRight = (bool)ViewData["Deposits_AddRight"];
        bool Deposits_UpdateRight = (bool)ViewData["Deposits_UpdateRight"];
        bool Deposits_ViewRight = (bool)ViewData["Deposits_ViewRight"];
        bool Deposits_DeleteRight = (bool)ViewData["Deposits_DeleteRight"];
        bool Deposits_ExportRight = (bool)ViewData["Deposits_ExportRight"];

        bool Help_Attachment_AddRight = (bool)ViewData["Help_Attachment_AddRight"];//attachment
        bool Help_Attachment_EditRight = (bool)ViewData["Help_Attachment_EditRight"];//attachment
        bool Help_Attachment_ViewRight = (bool)ViewData["Help_Attachment_ViewRight"];//attachment
        bool Help_Attachment_DeleteRight = (bool)ViewData["Help_Attachment_DeleteRight"];//attachment
        bool Deposits_Auto_Vouching_Mode = (bool)ViewData["Deposits_Auto_Vouching_Mode"];
    }
    <div id="DepositsProfile_ParentDiv">
        <div id="content" class="col-md-12 report_header_div_main">
            <div class="col-md-4 report_header_div">
                <label class="report_header_label">Deposits Information</label>
            </div>
            @*Buttons*@
            <div class="report_button_div">
                @(Html.DevExtreme().Switch().ID("OthrDepositVouchingModeSwitch").SwitchedOnText("Vouching On").SwitchedOffText("Vouching Off").OnValueChanged("OthrDeposit_VouchingSwitch_ValueChange").Width(100).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
                @(Html.DevExtreme().Switch().ID("DepositsViewModeSwitch").SwitchedOnText("Compact").SwitchedOffText("Default").OnValueChanged("Deposits_ViewSwitch_ValueChange").Width(70).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
                @(Html.DevExtreme().Button()
                                                                                                    .ID("DepositsModelNew")
                                                                                                    .Text("New")
                                                                                                    .Icon("add")
                                                                                                    .Visible(false)
                                                                                                    .Disabled(true)
                                                                                                    .OnClick(@<text>
                                                                                                        function () {
                                                                                                        OnDepositsNewClick();
                                                                                                        }
                                                                                                    </text>)
            )
                @(Html.DevExtreme().Button()
                                                                                                    .ID("DepositsModelEdit")
                                                                                                    .Text("Edit")
                                                                                                     .Icon("edit")
                                                                                                     .Visible(false)
                                                                                                     .Disabled(true)
                                                                                                     .OnClick(@<text>
                                                                                                        function () {
                                                                                                        OnDepositsEditClick();
                                                                                                        }
                                                                                                    </text>)
            )
                @(Html.DevExtreme().Button()
                                                                                                    .ID("DepositsModelDelete")
                                                                                                    .Text("Delete")
                                                                                                    .Icon("trash")
                                                                                                    .Visible(false)
                                                                                                    .Disabled(true)
                                                                                                    .OnClick(@<text>
                                                                                                        function () {
                                                                                                        OnDepositsDeleteClick();
                                                                                                        }
                                                                                                    </text>)
            )
                @(Html.DevExtreme().Button()
                                                                                                    .ID("DepositsModelView")
                                                                                                    .Text("View")
                                                                                                    .Icon(IconID.ViewCustomers16x16devav)
                                                                                                    .Icon("doc")
                                                                                                    .Visible(false)
                                                                                                    .Disabled(true)
                                                                                                    .OnClick(@<text>
                                                                                                        function () {
                                                                                                        OnDepositsViewClick();
                                                                                                        }
                                                                                                    </text>)
            )
                @(Html.DevExtreme().Button()
                                                                                                    .ID("DepositsToggleScrollBar")
                                                                                                    .Text(ViewBag.ShowHorizontalBar == 1 ? "Default Data" : "Full Data")
                                                                                                    .Width(ViewBag.ShowHorizontalBar == 1 ? 110 : 90)
                                                                                                    .Icon("toolbox")
                                                                                                    .OnClick(@<text>
                                                                                                        function () {
                                                                                                        DepositschangeMode();
                                                                                                        }
                                                                                                    </text>)
            )
                @(Html.DevExtreme().Button()
                                                                                                    .ID("DepositsModelListPreview")
                                                                                                    .Text("Export")
                                                                                                    .Icon("save")
                                                                                                    .Width(80)
                                                                                                    .OnClick(@<text>
                                                                                                        function () {
                                                                                                        OnDepositsListPreviewClick();
                                                                                                        }
                                                                                                    </text>)
            )
                @(Html.DevExtreme().Button()
                                                                                                    .ID("DepositsModelCLOSE")
                                                                                                    .Text("Close")
                                                                                                    .Icon("clear")
                                                                                                    .OnClick(@<text>
                                                                                                        function (){closeProfile_Deposits();}
                                                                                                    </text>)

            )
            </div>

        </div>
        <div class="col-md-12 no-padding">
            <form>
                <div id="DepositsreloadPartialView" class="parent_table">
                    @Html.Partial("Frm_Deposits_Info_Grid_dx")
                </div>
            </form>
        </div>
        <div class="footer-MainBoxdiv full-width-footer">
            @*<div class="col-lg-8 report_footer_small_buttons_div" id="DepositsFooterItem">*@
            <div class="list_footer_left_margin col-md-10">
                <div>
                    @*class="footer_new_left"*@
                    <div>
                        <div class="list_footer_left_margin">
                            <div class="footer-locktext">
                                <div id="Deposits_Lbl_ActionOn" class="left_footertext_top"></div>
                                <div id="Deposits_Lbl_ActionBy" class="left_footertext_bottom"></div>
                            </div>
                            @*<div class="footer-locktext">
                                    <div id="DepositsLbl_Status" style="font-size:23px" class="left_footertext_top"></div>
                                </div>*@
                        </div>
                        <div class="list_footer_left_margin">
                            <p id="DepositsLbl_Create" style="margin:0px" class="left_footertext_top"></p>
                            <p id="DepositsLbl_Modify" style="margin:0px" class="left_footertext_bottom"></p>
                        </div>

                    </div>
                </div>
            </div>
            <div class="list_footer_right_margin_consistent col-md-1">
                @*<i id="Deposits_LockICON" class="fa fa-lock lock_symbol"></i>*@
            </div>
            @*</div>
                <div class="col-lg-4 listing_footer_filter_buttons_div">
                </div>*@
        </div>

        @Html.Partial("AttachmentFAB", "DepositsPrf_FAB,DepositsProfile_grid_DIV,Type1,DepositsProfile," + UserType) @*fab buttons*@

        <div class="col-md-12">
            @*Add/Edit Popup*@
            @(Html.DevExtreme().Popup().CustomPopup()
                                                    .ID("Deposits_report_modal")
                                                    .OnShowing("PopupOnShowing")
                                                    .Title("Deposits List Preview")
                                                    .FullScreen(false)
                                                    .MaxWidth(125)
                                                    .Height("auto")
                                                    .ShowCloseButton(true)
                                                    .ContentTemplate(@<text>
                                                        <div id="Deposits_report_modal_result">
                                                        </div>
                                                    </text>)
        )
            @(Html.DevExtreme().Popup().CustomPopup()
                                                    .ID("popup_frm_Deposits_Window")
                                                    .Title("Deposits")
                                                    .OnShowing("PopupOnShowing")
                                                    .ShowCloseButton(true)
                                                    .ContentTemplate(@<text>
                                                        <div id="Depositsresult">
                                                        </div>
                                                    </text>)
                                                                            .OnHiding(@<text>
                                                                                function () {
                                                                                if(IsSucessPopup == false && IsViewPopup == false)
                                                                                {
                                                                                var result = DevExpress.ui.dialog.confirm("Are you sure to cancel this entry...?", "Confirm changes");
                                                                                result.done(function (dialogResult) {
                                                                                if(dialogResult){
                                                                                $("#popup_frm_Deposits_Window").dxPopup("hide");
                                                                                }else
                                                                                {
                                                                                $("#popup_frm_Deposits_Window").dxPopup("show");
                                                                                }
                                                                                });
                                                                                }
                                                                                }
                                                                            </text>)
        )
        </div>
    </div>
    @*Javascript Events*@
    <script type="text/javascript">
    //var IsSucessPopup = false;
    //var IsViewPopup = false;
    var Deposits_ShowHorizontalBar = parseInt("@ViewBag.ShowHorizontalBar");
    var Deposits_SetVouchingModeOn = "@Deposits_Auto_Vouching_Mode" == "True" ? true : false;
    var UserType_DepositsPrf = "@UserType".toUpperCase();
    var OthrDeposit_IsVouchingMode = false;
    var OthrDeposit_FocusedRowBeforeRefresh;
    var DepositsID;
    var Deposits_EditDate;
    var Deposits_AddDate;
    var Deposits_AddBy;
    var Deposits_EditBy;
    var Deposits_ActionStatus;
    var Deposits_ActionDate;
    var Deposits_ActionBy;
    var Deposits_ViewMode = "Default";
    $(document).ready(function () {
        if ("@Deposits_AddRight" == "False")
        {
	        $("#DepositsModelNew").hide();
        }
        if ("@Deposits_UpdateRight" == "False")
        {
            $("#DepositsModelEdit").hide();
        }
        if ("@Deposits_ViewRight" == "False")
        {
            $("#DepositsModelView").hide();
        }
        if ("@Deposits_DeleteRight" == "False")
        {
            $("#DepositsModelDelete").hide();
        }
        if ("@Deposits_ExportRight" == "False")
        {
            $("#DepositsModelListPreview").hide();
        }
        ////IsSucessPopup = false;
        //IsViewPopup = false;
        //SetDepositsGroupPanelFooterVisible();
        //SetDepositsFooterVisible();
        $("#DepositsListGrid").hover(function () {
            DepositsListGrid.Focus()
        });
        HideUnreleasedFunctionality('Deposits_frm_Deposits_Info');
        $(".DepositsListGrid_PreviewRow").hide();
        GetSessionStorage("DepositsListGrid");
        if (Deposits_SetVouchingModeOn == true)
        {
            $("#DepositsViewModeSwitch").dxSwitch("instance").option("value", true);
        }
    });
        $(".TabPanalMenu-tabs .active span").on("click", function () {
            DxGrid_EventsOnScreenClose(DepositsListGrid_dx)

        $.ajax({
            type: 'GET',
            url: "/Profile/Deposits/SessionClear",
            cache: false
        });
        CloseRightPane();
        ClearLeftPane();
        CloseLeftPane();
        ClearAllReferences_DepositsProfile();
    });
        function ClearAllReferences_DepositsProfile() {
            Deposits_ShowHorizontalBar = null;
            Deposits_SetVouchingModeOn = null;
            UserType_DepositsPrf = null;
            OthrDeposit_IsVouchingMode = null;
            OthrDeposit_FocusedRowBeforeRefresh = null;
            DepositsID = null;
            Deposits_EditDate = null;
            Deposits_AddDate = null;
            Deposits_AddBy = null;
            Deposits_EditBy = null;
            Deposits_ActionStatus = null;
            Deposits_ActionDate = null;
            Deposits_ActionBy = null;
            Deposits_ViewMode = null;
            DepositsInfo_IsDetailRowExpanded = null;
            DepositsInfo_NestedRecord_FocusedRowIndex = null;
            DepositsInfo_NestedGrid_AccessID = null;
            DepositsInfo_AtachmentID = null;
            DepositsInfo_FileName = null;
            DepositsInfo_ParamMandatory = null;
            DepositsInfo_FromDateLabel = null;
            DepositsInfo_ToDateLabel = null;
            DepositsInfo_DescriptionLabel = null;
            DepositsInfo_Doc_ID = null;
            DepositsInfo_Doc_Category = null;
            DepositsInfo_MasterRowRecID = null;
            DepositsInfo_MasterRowMID = null;
            DepositsInfo_NestedRowMapID = null;
            DepositsInfo_reason = null;
            DepositsInfo_Attachment_RecStatus = null;
            DepositsInfo_NestedRowReasonID = null;
            DepositsInfo_NestedRowKeyValue = null;
            DepositsListGrid_dx = null;
            VisibleColumns_DepositsListGrid_dx =null;
            Expanded_Row_Key_Deposits_dx = null;
            ClearAllReferences("DepositsProfile_ClearReferences");
        }



    function DepositsAjaxSuccessForm(data) {
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.Message, "Error");
        }
        else {
            //IsSucessPopup = true;
            DevExpress.ui.dialog.alert(data.Message, "Success");
            $("#popup_frm_Deposits_Window").dxPopup("hide");
            DepositsListGrid.Refresh();
            //IsSucessPopup = false;
        }
    }
    function OnDepositsNewClick() {
        if ("@Deposits_AddRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        IsViewPopup = false;
        //  OpenDynamicPopup("New ~ other Deposits", "", "680", "460")
        $("#popup_frm_Deposits_Window").dxPopup("show");
        $("#popup_frm_Deposits_Window").dxPopup("instance").option("title", "New ~ Deposits");
        $("#Depositsresult").html('');
        ShowLoader();
        $("#Depositsresult").load("@Url.Action("Frm_Deposits_Window", "Deposits", new { @area = "Profile" })?ActionMethod=New", function () {
            HideLoader();
        });
    }

    function OnDepositsEditClick() {
        if ("@Deposits_UpdateRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        //IsViewPopup = false;
        if (DepositsID == 'undefined' || DepositsID == undefined) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        $.ajax({
            type: 'GET',
            url: "/Profile/Deposits/DataNavigation",
            data: { ActionMethod: "Edit", id: DepositsID, Edit_Date: encodeURIComponent(Deposits_EditDate) },
            cache: false,
            success: function (Deposits_Edit_ButtonClick_result) {
                if (Deposits_Edit_ButtonClick_result.result == "true" || Deposits_Edit_ButtonClick_result.result == true) {
                    $("#popup_frm_Deposits_Window").dxPopup("show");
                    $("#popup_frm_Deposits_Window").dxPopup("instance").option("title", "Edit ~ Deposits");
                    $("#Depositsresult").html('');
                    ShowLoader();
                    $("#Depositsresult").load("@Url.Action("Frm_Deposits_window", "Deposits", new { @area = "Profile" })?ActionMethod=" + "Edit" + "&ID=" + DepositsID + "&EditedOn=" + encodeURIComponent(Deposits_EditDate), function () {
                        HideLoader();
                    });
                }
                else {
                    DevExpress.ui.dialog.alert(Deposits_Edit_ButtonClick_result.Message);
                    DepositsListGrid.Refresh();
                }
            }
        });
    }

    function OnDepositsViewClick() {
        if ("@Deposits_ViewRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        if (DepositsID == 'undefined' || DepositsID == undefined) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        $.ajax({
            type: 'GET',
            url: "/Profile/Deposits/DataNavigation",
            data: { ActionMethod: "View", id: DepositsID, Edit_Date: Deposits_EditDate.toISOString() },
            cache: false,
            success: function (Deposits_View_ButtonClick_result) {
                if (Deposits_View_ButtonClick_result.result == "true" || Deposits_View_ButtonClick_result.result == true) {
                    //IsViewPopup = true;
                    $("#popup_frm_Deposits_Window").dxPopup("show");
                    $("#popup_frm_Deposits_Window").dxPopup("instance").option("title", "View ~ Deposits");
                    $("#Depositsresult").html('');
                    ShowLoader();
                    $("#Depositsresult").load("@Url.Action("Frm_Deposits_window", "Deposits", new { @area = "Profile" })?ActionMethod=" + "View" + "&ID=" + DepositsID + "&EditedOn=" + encodeURIComponent(Deposits_EditDate), function () {
                        HideLoader();
                    });
                }
                else {
                    DevExpress.ui.dialog.alert(Deposits_View_ButtonClick_result.Message);
                    DepositsListGrid.Refresh();
                }
            }
        });
    }

    function OnDepositsDeleteClick() {
        if ("@Deposits_DeleteRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        //IsViewPopup = true;
        if (DepositsID == 'undefined' || DepositsID == undefined) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        var result = DevExpress.ui.dialog.confirm("Sure you want to delete?", "Confirm changes");
        result.done(function (dialogResult) {
            if (dialogResult) {
                $("#popup_frm_Deposits_Window_Close").dxPopup("hide");

                $.ajax({
                    type: 'GET',
                    url: "/Profile/Deposits/DataNavigation",
                    data: { ActionMethod: "Delete", id: DepositsID, Edit_Date: Deposits_EditDate.toISOString() },
                    cache: false,
                    success: function (Deposits_Delete_ButtonClick_result) {
                        if (Deposits_Delete_ButtonClick_result.result == "true" || Deposits_Delete_ButtonClick_result.result == true) {
                            $("#popup_frm_Deposits_Window").dxPopup("show");
                            $("#popup_frm_Deposits_Window").dxPopup("instance").option("title", "Delete ~ Deposits");
                            ShowLoader();
                            $("#Depositsresult").load("@Url.Action("Frm_Deposits_window", "Deposits", new { @area = "Profile" })?ActionMethod=" + "Delete" + "&ID=" + DepositsID + "&EditedOn=" + encodeURIComponent(Deposits_EditDate), function () {
                                HideLoader();
                            });
                        }
                        else {
                            DevExpress.ui.dialog.alert(Deposits_Delete_ButtonClick_result.Message);
                            DepositsListGrid.Refresh();
                        }
                    }
                });
            }
        });
    }
    </script>

    <script>
    var DepositsInfo_IsDetailRowExpanded = false;
    var DepositsInfo_NestedRecord_FocusedRowIndex = -1;
    var DepositsInfo_NestedGrid_AccessID;
    var DepositsInfo_AtachmentID;
    var DepositsInfo_FileName;
    var DepositsInfo_ParamMandatory;
    var DepositsInfo_FromDateLabel;
    var DepositsInfo_ToDateLabel;
    var DepositsInfo_DescriptionLabel;
    var DepositsInfo_Doc_ID;
    var DepositsInfo_Doc_Category;
    var DepositsInfo_MasterRowRecID;
    var DepositsInfo_MasterRowMID;
    var DepositsInfo_NestedRowMapID;
    var DepositsInfo_reason;
    var DepositsInfo_Attachment_RecStatus;
    var DepositsInfo_NestedRowReasonID;
    var DepositsInfo_NestedRowKeyValue;

    function On_DepositsProfile_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@Help_Attachment_AddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (DepositsInfo_ParamMandatory == 1)
            {
                AddAttachment(DepositsInfo_MasterRowRecID, "Profile_Deposit", DepositsInfo_Doc_ID, DepositsInfo_Doc_Category, DepositsInfo_ParamMandatory, DepositsInfo_FromDateLabel, DepositsInfo_ToDateLabel, DepositsInfo_DescriptionLabel, "DepositsProfileAttachment", null, "DepositsListGrid_dx", DepositsInfo_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(DepositsInfo_MasterRowRecID, "Profile_Deposit", DepositsInfo_Doc_ID, "DepositsProfileAttachment", "DepositsListGrid_dx", DepositsInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (DepositsInfo_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(DepositsInfo_MasterRowRecID, "Profile_Deposit", DepositsInfo_AtachmentID, DepositsInfo_ParamMandatory, DepositsInfo_FromDateLabel, DepositsInfo_ToDateLabel, DepositsInfo_DescriptionLabel, "DepositsProfileAttachment", null, "DepositsListGrid_dx", DepositsInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(DepositsInfo_MasterRowRecID, "Profile_Deposit", DepositsInfo_AtachmentID, DepositsInfo_ParamMandatory, DepositsInfo_FromDateLabel, DepositsInfo_ToDateLabel, DepositsInfo_DescriptionLabel, null, "DepositsListGrid_dx", DepositsInfo_NestedGrid_AccessID, DepositsInfo_Attachment_RecStatus);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@Help_Attachment_ViewRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            ViewDocument(DepositsInfo_AtachmentID, DepositsInfo_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(DepositsInfo_MasterRowRecID, "Profile_Deposit", "Deposits Information", "DepositsListGrid_dx", DepositsInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Add_Reason")
        {
            if (DepositsInfo_Doc_Category.toLowerCase() == "others")
            {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else
            {
                AttachmentAddReason(DepositsInfo_MasterRowRecID, DepositsInfo_NestedRowMapID, "Profile_Deposit", "DepositsListGrid_dx", DepositsInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(DepositsInfo_MasterRowRecID, DepositsInfo_NestedRowMapID, "Profile_Deposit", "DepositsListGrid_dx", DepositsInfo_NestedGrid_AccessID, DepositsInfo_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(DepositsInfo_MasterRowRecID, DepositsInfo_NestedRowMapID, "DepositsListGrid_dx", DepositsInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
        else if (e.actionName == "AuditAction")
        {
            DepositsPrf_FAB.SetActionContext("AuditActionContext", true);
        }
        else if (e.actionName == "BackAudit")
        {
            if (DepositsInfo_Nested_Doc_Status == "")
            {
                DepositsPrf_FAB.SetActionContext("AutoItemContext", true);
            }
            if (DepositsInfo_Nested_Doc_Status == "NO")
            {
                DepositsPrf_FAB.SetActionContext("EditItemContext", true);
            }
            if (DepositsInfo_Nested_Doc_Status == "YES")
            {
                DepositsPrf_FAB.SetActionContext("actionItemContext", true);
            }
        }
        else if (e.actionName == "Accept")
        {
            DepositsInfo_AcceptwithoutRemarks();
        }
        else if (e.actionName == "Reject")
        {
            DepositsInfo_AcceptRejectVoucher("Reject");
        }
        else if (e.actionName == "AcceptWithRemarks")
        {
            DepositsInfo_AcceptRejectVoucher("Accept");
        }
        else if (e.actionName == "AcceptDoc") {

            OnDepositsInfo_AcceptDoc();
        }
        else if (e.actionName == "RejectDoc") {

            OnDepositsInfo_RejectDoc();
        }
    }
    function OnDepositsInfo_RejectDoc() {
        if (DepositsInfo_AtachmentID == null || DepositsInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        RejectAttachment(DepositsInfo_AtachmentID, "DepositsListGrid_dx", DepositsInfo_NestedGrid_AccessID);
    }
    function OnDepositsInfo_AcceptDoc() {
