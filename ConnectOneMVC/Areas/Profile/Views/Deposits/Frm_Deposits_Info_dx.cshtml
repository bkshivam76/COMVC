        function Deposits_UpdateFooterDetail(DepositsID, Deposits_Action_Status, Deposits_Add_Date, Deposits_Add_By, Deposits_Action_Date, Deposits_Action_By, Deposits_Edit_Date, Deposits_Edit_By) {
            Deposits_Action_Date = Deposits_Action_Date != "" && Deposits_Action_Date != null ? Deposits_Action_Date : Deposits_Action_Date;
            Deposits_Edit_Date = Deposits_Edit_Date != "" && Deposits_Edit_Date != null ? Deposits_Edit_Date : Deposits_Edit_Date;
            Deposits_Add_Date = Deposits_Add_Date != "" && Deposits_Add_Date != null ? Deposits_Add_Date : Deposits_Add_Date;
            $.ajax({
                type: 'GET',
                url: "/Profile/Deposits/CreationDetail",
                data: {
                    Xrow: DepositsID, Action_Status: Deposits_Action_Status, Add_Date: Deposits_Add_Date,
                    Add_By: Deposits_Add_By, Action_Date: Deposits_Action_Date, Action_By: Deposits_Action_By, Edit_Date: Deposits_Edit_Date, Edit_By: Deposits_Edit_By
                },
                cache: false,
                success: function (DepositsLbl_result) {
                    $('#Deposits_Lbl_ActionOn').text(DepositsLbl_result.Lbl_StatusOn);
                    $('#Deposits_Lbl_ActionBy').text(DepositsLbl_result.Lbl_StatusBy);
                    $('#DepositsLbl_Status').text(DepositsLbl_result.Lbl_Status);
                    $('#DepositsLbl_Create').text(DepositsLbl_result.Lbl_Create);
                    $('#DepositsLbl_Modify').text(DepositsLbl_result.Lbl_Modify);
                    if (DepositsLbl_result.Lbl_Status_Color != "") {
                        $('#DepositsLbl_Status').css('color', DepositsLbl_result.Lbl_Status_Color);
                    }
                    if (DepositsLbl_result.Pic_Status != "") {
                        $('#Deposits_LockICON').css('class', DepositsLbl_result.Pic_Status);
                    }

                }
            });
        }

    </script>
    <script>
        function DepositsListGrid_dx_OnInitialized(e) {
            DxGrid_AdjustSize(e.component, $("#DepositsProfile_ParentDiv .report_button_div"))
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                DxGrid_AdjustSize(e.component, $("#DepositsProfile_ParentDiv .report_button_div"), "", evt)
            });
            DepositsListGrid_dx = e.component;
        }
        function DepositsListGrid_dx_OnCellPrepared(e) {
            if (e.rowType == "data") {
                if (OthrDeposit_IsVouchingMode == true) {
                    if (e.column.dataField === "iIcon") {
                        $(e.cellElement).attr("onmouseover", "OnGridRowMouseHoverIn(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.key + "')");
                        $(e.cellElement).attr("onmouseout", "OnGridRowMouseHoverOut(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.key + "')");
                    }
                }
                $(e.cellElement).attr("id", e.element[0].id + "_Cell_" + e.key + "|" + e.column.dataField);
            }
            if (e.rowType === "data") {
                if (e.column.dataField === "Out_Standing") {
                    if (e.data.Out_Standing > 0.00)
                        e.cellElement.css({ "background-color": "lightpink" });
                    //e.cellElement.addClass("BalanceBgColour");
                }
            }
        }
        function DepositsListGrid_dx_OnRowPrepared(e) {
            if (e.rowType == "data") {
                var GridName = e.element[0].id;
                $(e.rowElement).addClass(GridName + "_DataRow_" + e.key)
                if (e.data.RemarkStatus != null && e.data.RemarkStatus == "OPEN" || e.data.RemarkStatus == "REOPENED") {
                    $(e.rowElement).css("background-color", "gold");
                }
                if (e.data.RemarkStatus == null && e.data.Remarks != null && e.data.Remarks == true && e.data.CrossedTimeLimit != null && e.data.CrossedTimeLimit == 0) {
                    $(e.rowElement).css("background-color", "lightgreen");
                }
                if (e.data.CrossedTimeLimit != null && e.data.CrossedTimeLimit > 0) {
                    $(e.rowElement).css("background-color", "mistyrose");
                }
                DxGrid_CreatePreviewRow(e, OthrDeposit_IsVouchingMode, "Master")
            }
            else if (e.rowType == "detailAdaptive")
            {
                DxGrid_MovePreviewRowAfterAdaptiveRow(e)
            }
        }
        function DepositsListGrid_dx_OnContentReady(e) {
            DxGrid_OnContentReady(e, Deposits_ShowHorizontalBar);
        }
        function DepositsListGrid_dx_OnCellDblClick(e) {
            if (e.rowType == "data") {
                if (OthrDeposit_IsVouchingMode == true && Deposits_ViewMode == "Default") {
                    OnGridCellClick(e.event, e.cellElement[0], e.columnIndex, e.rowIndex, e.element[0].id, e.key, e.column.dataField)
                }
            }
        }
        function DepositsListGrid_dx_OnSelectionChanged(e) {
            var selectedRowKeys = e.selectedRowKeys;
            if (selectedRowKeys != null && selectedRowKeys.length > 0) {
                if (OthrDeposit_IsVouchingMode) {
                    DepositsPrf_FAB.SetVisible(true);
                    DepositsPrf_FAB.SetActionContext("AddAttachmentContext", false);
                }
                DepositsListGrid_dx_SelectedRowData(e.selectedRowsData);
            }
            else {
                DepositsID = null;
                Deposits_UpdateFooterDetail(DepositsID, Deposits_ActionStatus, Deposits_AddDate, Deposits_AddBy,
                    Deposits_ActionDate, Deposits_ActionBy, Deposits_EditDate, Deposits_EditBy);
            }
        }
        function DepositsListGrid_dx_SelectedRowData(selectedData = null) {
            if (selectedData == null) {
                selectedData = DepositsListGrid_dx.getSelectedRowsData();
            }
            if (selectedData != null && selectedData.length > 0) {
                var values = selectedData[0]
                DepositsID = values["ID"]
                Deposits_EditDate = values["Edit_Date"];
                Deposits_EditBy = values["Edit_By"];
                Deposits_AddDate = values["Add_Date"];
                Deposits_AddBy = values["Add_By"];
                Deposits_ActionDate = values["Action_Date"];
                Deposits_ActionBy = values["Action_By"];
                Deposits_ActionStatus = values["Action_Status"];
                Deposits_UpdateFooterDetail(DepositsID, Deposits_ActionStatus, Deposits_AddDate, Deposits_AddBy,
                    Deposits_ActionDate, Deposits_ActionBy, Deposits_EditDate, Deposits_EditBy);
                if (OthrDeposit_IsVouchingMode == true) {
                    OpenLeftPane();
                    LeftPaneContent_Deposits_dx("DepositsListGrid_dx", DepositsID, OthrDeposit_IsVouchingMode)
                }
            }
            else {
                DepositsID = null;
            }
        }
        function DepositsListGrid_dx_OnRowExpanding(e) {
            if (Array.isArray(e.key) == false) //not group row
            {
                e.component.collapseRow(Expanded_Row_Key_Deposits_dx)
                e.component.selectRows(e.key);
                Expanded_Row_Key_Deposits_dx = e.key;
                DepositsInfo_IsDetailRowExpanded = true;
                var DetailGridID = e.element[0].id + e.key;
                var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
                if (instance != void 0) {
                    instance.state(null) // grid maintains its state after collapsing so resetting the state when expands again as per old grid
                }
                //e.component.collapseAll(-1);
            }
            else {
                e.component.option("CustomProp.groupRowExpanded", true);
            }
        }
        function DepositsListGrid_dx_OnRowCollapsing(e) {
            if (Array.isArray(e.key) == false) //not group row
            {
                var DetailGridID = e.element[0].id + e.key;
                sessionStorage.removeItem(DetailGridID + "_DetailGridState") //removing grid state from session storage on collapse
                DepositsInfo_IsDetailRowExpanded = false;
                e.component.selectRows(e.key);
                if (OthrDeposit_IsVouchingMode == false) {
                    DepositsPrf_FAB.SetVisible(false);
                }
                var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
                if (instance != void 0) {
                    instance.clearSelection();
                }
            }
            else {
                e.component.option("CustomProp.groupRowCollapsed", true);
            }
        }
        function DepositsListGrid_dx_OnContextMenuPreparing(e) {
            if (!e.items) e.items = [];
            if (e.target == "header") {

                DxGrid_HeaderContextMenu(e)
            }
            else if ((e.target == "content" && e.row && e.row.rowType == "groupFooter") || e.target == "footer") {
                if (Deposits_ViewMode == "Compact")
                    DxGrid_FooterContextMenu(e, true);
                else
                    DxGrid_FooterContextMenu(e);
            }
            else if (e.target == "content" && e.row && (e.row.rowType == "data" || e.row.rowType == "detailAdaptive")) {
                var key = e.component.getKeyByRowIndex(e.row.rowIndex);
                e.component.selectRows(key);
                var expanded = e.component.isRowExpanded(key);
                e.items = [
                    {
                        text: "Expand Detail",
                        icon: "fa-solid fa-arrow-down-wide-short " + (expanded ? "text-muted" : "text-info"),
                        disabled: expanded,
                        visible: !OthrDeposit_IsVouchingMode,
                        onItemClick: function () {
                            if (expanded) {
                            }
                            else {
                                e.component.expandRow(key);
                            }
                        }
                    }, {
                        text: "Collapse Detail",
                        icon: "fa-solid fa-arrow-up-wide-short " + (!expanded ? "text-muted" : "text-info"),
                        disabled: !expanded,
                        visible: !OthrDeposit_IsVouchingMode,
                        onItemClick: function () {
                            if (expanded) {
                                e.component.collapseRow(key);
                            }
                            else {
                            }
                        }
                    },
                    {
                        text: "Export",
                        icon: "fa-solid fa-file-export text-warning",
                        visible: "@Deposits_ExportRight" == "True",
                        beginGroup: true,
                        onItemClick: function () {
                            OnDepositsListPreviewClick();
                        }
                    },
                    {
                        text: "Close",
                        icon: "fa-solid fa-rectangle-xmark text-danger",
                        beginGroup: true,
                        onItemClick: function () {
                            closeProfile_Deposits()();
                        }
                    },
                    {
                        text: "Refresh",
                        icon: "fa-solid fa-arrow-rotate-right text-success",
                        beginGroup: true,
                        onItemClick: function () {
                            DepositsListGrid_dx_Refresh()
                        }
                    }]
            }
        }


        function DepositsListGrid_dx_DetailTemplate(container, templateData) {
            var GridName = templateData.component.element()[0].id
            var RecID = templateData.data.ID;
            DepositsListGrid_dx_Detail(container, GridName, RecID, OthrDeposit_IsVouchingMode, Deposits_ShowHorizontalBar);
        }
        function DepositsListGrid_dx_Detail(container, GridName, RecID, vouchingMode, AllColumns)
        {
            var url = "/Profile/Deposits/Frm_Deposits_Info_DetailGrid_dx?VouchingMode=" + vouchingMode + "&RecID=" + RecID
            var instance = DxGrid_AttachmentGrid_Create(container, GridName, RecID, vouchingMode, AllColumns, url)
            instance.option("onSelectionChanged", DepositsListGrid_dx_Detail_onSelectionChanged);            
        }        
        function DepositsListGrid_dx_Detail_onSelectionChanged(e) {
            if (DepositsInfo_IsDetailRowExpanded || OthrDeposit_IsVouchingMode) {
                if (e.selectedRowsData != null && e.selectedRowsData.length > 0) {
                    DepositsInfo_NestedGrid_AccessID = e.element[0].id;
                    DepositsListGrid_dx_Detail_SelectedRowData(e.selectedRowsData)
                }
                else {
                    DepositsPrf_FAB.SetActionContext("AddAttachmentContext", false);
                }
            }
        }
        function DepositsListGrid_dx_Detail_SelectedRowData(selectedData = null) {
            if (selectedData == null) {
                selectedData = $("#" + DepositsInfo_NestedGrid_AccessID).dxDataGrid("getSeletedRowsData");
            }
            var values = selectedData[0];
            DepositsInfo_NestedRowKeyValue = values["UniqueID"];
            if (values["UniqueID"] != null) {
                DepositsPrf_FAB.SetVisible(true);
                DepositsInfo_Nested_Doc_Status = values["Doc_Status"];

                if (OthrDeposit_IsVouchingMode == true) {
                    DepositsPrf_FAB.SetActionContext("AuditActionContext", true);
                }
                else {
                    if (DepositsInfo_Nested_Doc_Status == "") {
                        DepositsPrf_FAB.SetActionContext("AutoItemContext", true);
                    }
                    else if (DepositsInfo_Nested_Doc_Status == "NO") {
                        DepositsPrf_FAB.SetActionContext("EditItemContext", true);
                    }
                    else if (DepositsInfo_Nested_Doc_Status == "YES") {
                        DepositsPrf_FAB.SetActionContext("actionItemContext", true);
                    }
                }
                DepositsInfo_ParamMandatory = values["Params_Mandatory"];
                DepositsInfo_FromDateLabel = values["LABEL_FROM_DATE"];
                DepositsInfo_ToDateLabel = values["LABEL_TO_DATE"];
                DepositsInfo_DescriptionLabel = values["LABEL_DESCRIPTION"];
                DepositsInfo_Doc_Category = values["Document_Category"];
                DepositsInfo_Doc_ID = values["Document_ID"];
                DepositsInfo_AtachmentID = values["ATTACH_ID"];
                IndexAttachmentID = DepositsInfo_AtachmentID;
                DepositsInfo_MasterRowRecID = values["TxnID"];
                DepositsInfo_MasterRowMID = values["TxnMID"];
                DepositsInfo_NestedRowMapID = values["MAP_ID"];
                DepositsInfo_reason = values["Reason"];
                DepositsInfo_FileName = values["ATTACH_FILE_NAME"];
                DepositsInfo_Attachment_RecStatus = values["Attachment_Action_Status"];
                if (OthrDeposit_IsVouchingMode == true) {
                    if (DepositsInfo_FileName != null && DepositsInfo_FileName.length > 0) {
                        ViewDocument(DepositsInfo_AtachmentID, DepositsInfo_FileName, "DepositsPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                    }
                    else {
                        CloseRightPane();
                        ClearRightPane();
                    }
                }
            }
            DepositsInfo_NestedRowReasonID = values["ReasonID"];
            IndexAttachmentReasonID = DepositsInfo_NestedRowReasonID;
        }      

    </script>
