        function DepositsListGrid_dx_Compact_Column_CellValue(rowData) {
            var data =
                [
                    rowData.ITEM_NAME, rowData.DI_AGAINST_INSURANCE, rowData.PARTY_NAME, rowData.DI_DEP_DATE, rowData.DI_DEP_PERIOD, rowData.DI_INT_RATE, rowData.DI_MAT_DATE,
                    rowData.Deposit, rowData.Addition, rowData.Adjusted, rowData.Refund, rowData.Out_Standing, rowData.Reason,
                    rowData.DI_OTHER_DETAIL, rowData.Type,rowData.Special_Ref

                ]
            return data.join(" ")
        }
