    <script>
        function OthrDeposit_VouchingSwitch_ValueChange(e) {
            OthrDeposit_IsVouchingMode = e.value;
            if (Deposits_SetVouchingModeOn == true) {
                Deposits_SetVouchingModeOn = false;
            }
            else {
                DepositsPrf_FAB.SetVisible(false);
            }
            if (OthrDeposit_IsVouchingMode == true) {
                OpenRightPane();
                ClearLeftPane();
                OpenLeftPane();
            }
            else {
                CloseRightPane();
                ClearLeftPane();
                CloseLeftPane();
            }
            DepositsListGrid_dx.clearSelection();
            DepositsListGrid_dx.option("masterDetail.enabled", !OthrDeposit_IsVouchingMode)
            DepositsListGrid_dx.repaint();
        }
        function Deposits_ViewSwitch_ValueChange(e) {

            Deposits_ViewMode = e.value == false ? "Default" : "Compact";
            if (Deposits_SetVouchingModeOn == true) {
                $("#OthrDepositVouchingModeSwitch").dxSwitch("instance").option("value", true);
            }
            DepositsListGrid_dx.beginUpdate();
            var columns = DepositsListGrid_dx.option("columns");
            if (Deposits_ViewMode == "Compact") {
                VisibleColumns_DepositsListGrid_dx = [];
                for (var i = 0; i < columns.length; i++) {
                    var name = columns[i].dataField;
                    var ColumnVisible = DepositsListGrid_dx.columnOption(name, "visible");
                    if (name == "DepositsListGrid_dx_Compact_Column") {
                        DepositsListGrid_dx.columnOption(name, "visible", true);
                    }
                    else if (ColumnVisible == true && name != "iIcon") {
                        VisibleColumns_DepositsListGrid_dx.push(name);
                        DepositsListGrid_dx.columnOption(name, "visible", false);
                    }
                }
            }
            else {
                DepositsListGrid_dx.columnOption("DepositsListGrid_dx_Compact_Column", "visible", false);
                for (var i = 0; i < VisibleColumns_DepositsListGrid_dx.length; i++) {
                    DepositsListGrid_dx.columnOption(VisibleColumns_DepositsListGrid_dx[i], "visible", true);
                }
            }
            DepositsListGrid_dx.repaint();
            DepositsListGrid_dx.endUpdate();
        }
        function DepositschangeMode() {
            DepositsListGrid_dx.beginUpdate();
            if (Deposits_ShowHorizontalBar == 0) {
                Deposits_ShowHorizontalBar = 1;
                $("#DepositsToggleScrollBar").find("span").text("Default Data");
                $("#DepositsToggleScrollBar").width(110);
                DepositsListGrid_dx.option("columnHidingEnabled", false);
                DepositsListGrid_dx.option("allowColumnResizing", true)
            }
            else {
                Deposits_ShowHorizontalBar = 0;
                $("#DepositsToggleScrollBar").find("span").text("Full Data");
                $("#DepositsToggleScrollBar").width(90);
                DepositsListGrid_dx.option("columnHidingEnabled", true)
                DepositsListGrid_dx.option("allowColumnResizing", false)
            }
            DepositsListGrid_dx.endUpdate();
        }
        function closeProfile_Deposits() {
            DxGrid_EventsOnScreenClose(DepositsListGrid_dx)
            $(".TabPanalMenu-tabs .active span").click();
        }
