@using DevExtreme.AspNet.Mvc;
@{
   
  
}
<!DOCTYPE html>
<style>
    .dx-header-row {
        color: black;
        font-weight: bolder;
    }
    /*.dx-datagrid-borders .dx-datagrid-rowsview 
    {
        border-color:black;
    }*/
 
</style>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Detail Information</title>




    @*Start StyleSheets*@
    @Html.DevExpress().GetStyleSheets(
            new StyleSheet { ExtensionSuite = ExtensionSuite.GridView, Theme = "MetropolisBlue" },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Editors, Theme = "MetropolisBlue" },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Report, Theme = "MetropolisBlue" },
            new StyleSheet { ExtensionSuite = ExtensionSuite.NavigationAndLayout, Theme = "MetropolisBlue" },
            new StyleSheet { ExtensionSuite = ExtensionSuite.Icons, Theme = "MetropolisBlue" },
            new StyleSheet { ExtensionSuite = ExtensionSuite.HtmlEditor, Theme = "MetropolisBlue" }
            //new StyleSheet { ExtensionSuite = ExtensionSuite. All, Theme = "MetropolisBlue" }
    )
    <link href="@Url.Content("~/Content/css/base.css")" rel="stylesheet">
    <link href="@Url.Content("~/Content/site.css")" rel="stylesheet">
    <link href="~/Content/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Content/css/responsive-tablet-big.css" rel="stylesheet" />
    <link href="~/Content/css/responsive.css" rel="stylesheet" />
    <link href="~/Content/css/font-awesome.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/css/dx.icons.css" rel="stylesheet" type="text/css" />
    <link href="~/Content/css/custom.css" rel="stylesheet" type="text/css" />


    @*End StyleSheets*@

    @*Start Scripts*@

    @*<script src="@Url.Content("~/Scripts/jquery-1.11.3.min.js")" type="text/javascript"></script>
        <script src="@Url.Content("~/Scripts/jquery.validate.min.js")" type="text/javascript"></script>
        <script src="@Url.Content("~/Scripts/jquery.validate.unobtrusive.min.js")" type="text/javascript"></script>
        <script src="@Url.Content("~/Scripts/jquery.unobtrusive-ajax.min.js")" type="text/javascript"></script>*@


    @Html.DevExpress().GetScripts(
        new Script { ExtensionSuite = ExtensionSuite.NavigationAndLayout },
        new Script { ExtensionSuite = ExtensionSuite.Editors },
        new Script { ExtensionSuite = ExtensionSuite.GridView },
        new Script { ExtensionSuite = ExtensionSuite.Icons },
        new Script { ExtensionSuite = ExtensionSuite.HtmlEditor },
        //new Script { ExtensionSuite = ExtensionSuite.All }
        new Script { ExtensionSuite = ExtensionSuite.Report }
    )
    <script src="@Url.Content("~/Scripts/bootstrap.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Content/js/jquery.slimscroll.min.js")"></script>
    <script src="@Url.Content("~/Scripts/moment.min.js")"></script>

    <script src="~/Content/fontawesome/js/fontawesome_v5_all.js"></script>
    @*<script src="@Url.Content("~/Scripts/site.js")" type="text/javascript"></script>*@
    @*End Scripts*@

    <script src="@Url.Content("~/Scripts/bootstrap.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Content/js/jquery.slimscroll.min.js")"></script>
    <script src="@Url.Content("~/Scripts/moment.min.js")"></script>

    <script src="~/Content/fontawesome/js/fontawesome_v5_all.js"></script>
    @*<script src="@Url.Content("~/Scripts/site.js")" type="text/javascript"></script>*@
    @*End Scripts*@



    @System.Web.Optimization.Styles.Render("~/Content/DevExtremeBundleReporting")
    @System.Web.Optimization.Scripts.Render("~/Scripts/DevExtremeBundleReporting")
    <link href="@Url.Content("~/Content/CustomeDevextream.css")" rel="stylesheet">
</head>
<body class="report_header_div_main">

    <div class="row" style="padding-top:2%">

        <div class="col-md-2">
        </div>
        <div class="col-md-8">
            <div class="row">
                <div class="form-field">
                    <div class="container-fluid">
                        <div class="col-sm-2 pll">
                            <label style="color:red;font-weight:bold">Cert. No :</label>
                        </div>
                        <div class="col-sm-8 prm">
                            @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("CenterPadNo1").Name("CenterPadNo1").Placeholder("").OnValueChanged("CenterPadNo_ValueChange").ShowSpinButtons(false).Format("#").Min(0).Height(20))
                        </div>
                        <div class="col-sm-2 pll">
                            @(Html.DevExtreme().Button().ID("CenterPadNo_Show1").Text("Show").OnClick("CenterPadNo_Show_Click"))
                        </div>
                    </div>
                </div>
            </div>
            <br>
            <div class="row">
                <div class="form-field">
                    <div class="container-fluid">

                        @(Html.DevExtreme().DataGrid()
                            .ID("CenterDetail_datagrid1")
                            .DataSource(d => d.Mvc().Area("Profile").Controller("DetailInfo").LoadAction("LookUp_Get_Details")
                                            .LoadParams(new { padno = new JS("function (){ return Center_Pad_No;}") }))
                            .Columns(columns =>
                            {
                                columns.Add().DataField("Details").Caption("Details");
                                columns.Add().DataField("Name").Caption("Name");
                                columns.Add().DataField("Contact1").Caption("Contact 1");
                                columns.Add().DataField("Contact2").Caption("Contact 2");
                                columns.Add().DataField("Contact3").Caption("Contact 3");
                                columns.Add().DataField("Contact4").Caption("Contact 4");

                            })
                            .ShowBorders(true)
                            .ShowRowLines(true)
                            .Height(450)
                            .Scrolling(s => s.ShowScrollbar(ShowScrollbarMode.Always))
                            .Visible(false)
                            .ColumnAutoWidth(true)                                                                                                                         
                            .Width("100%")

                        )

                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
        </div>
    </div>
    </body>
</html>
    <script>
        var Center_Pad_No;
        function CenterPadNo_Show_Click(e)
        {           
            $("#CenterDetail_datagrid1").dxDataGrid("instance").refresh().then((r) =>
            {
                $("#CenterDetail_datagrid1").dxDataGrid("instance").option("visible", true);              
            });
        }

        function CenterPadNo_ValueChange(e)
        {           
            if (e.value)
            {               
                Center_Pad_No = e.value;            
            }
            else
            {
                Center_Pad_No = 0;
                $("#CenterDetail_datagrid1").dxDataGrid("instance").option("visible", false);
            }
        }

    </script>

