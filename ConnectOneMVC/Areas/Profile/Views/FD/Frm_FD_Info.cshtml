    function FDOnGridFocusedRowChanged(s, e)
    {
        if (s.GetFocusedRowIndex() >= 0)
        {
            if (!s.IsGroupRow(s.GetFocusedRowIndex()))
            {
                if (FD_IsVouchingMode)
                {
                    FDPrf_FAB.SetVisible(true);
                    FDPrf_FAB.SetActionContext("VouchingActionContext", true);
                }
                ID = s.GetRowKey(s.GetFocusedRowIndex());
                ShowLoader_GridView();
                FDListGrid.GetValuesOnCustomCallback({ key: ID }, FDOnGetRowValues);
            }
            else
            {
                ID = null;
            }
        }
        else
        {
            ID = null;
        }
    }

        function FDOnGetRowValues(FDData) {
            var values = FDData.split('![');
            BI_BANK_NAME = values[0];
            BB_BRANCH_NAME = values[1];
            FD_NO = values[2];
            FD_DATE = values[3];
            FD_AS_DATE = values[4];
            FD_AMOUNT = values[5];
            FD_INT_RATE = values[6];
            FD_INT_PAY_COND = values[7];
            FD_MAT_DATE = values[8];
            FD_MAT_AMT = values[9];
            BA_CUST_NO = values[10];
            Add_By = values[11];
            Add_Date = values[12];
            Edit_By = values[13];
            Edit_Date = values[14];
            Action_Status = values[15];
            Action_By = values[16];
            Action_Date = values[17];
            TR_ID = values[18];
            ID = values[19];
            FD_Status = values[20];
            CLOSE_DATE = values[21];
            Entry_Type = values[22];
            Interest_Recd = values[23];
            TDS_Paid = values[24];
            Nett_Interest = values[25];
            Other_Detail = values[26];
            FD_Less_Maturity = values[27];
            Remarks = values[28];
            RemarkStatus = values[29];
            OpenActions = values[30];
            CrossedTimeLimit = values[31];
            YearID = values[32];

            FDProf_UpdateFooterDetail(ID, Action_Status, Add_Date, Add_By,
                Action_Date, Action_By, Edit_Date, Edit_By);

            var Leftpane = Mainspliter.GetPaneByName('LeftPane');
            if (FD_IsVouchingMode == true)
            {
                if (Leftpane.IsCollapsed() == true)
                {
                    Leftpane.Expand();
                }
                ShowLoader();
                $("#LeftPane_Div_Content").html(null);
                var LoadURL = StandardizeCallURL("@Url.Action("LeftPaneContent", "FD", new { @area = "Profile" })?ID=" + ID + "&VouchingMode=" + FD_IsVouchingMode);
                $("#LeftPane_Div_Content").load(LoadURL, function ()
                {
                    HideLoader();
                });
            }
            HideLoader_GridView();
        }

