    function FD_VouchingSwitch_ValueChange(e)
    {
        FD_IsVouchingMode = e.value;
        if (FDList_Auto_Vouching_Mode == true)
        {
            FDList_Auto_Vouching_Mode = false;
        }
        else
        {
            FDPrf_FAB.SetVisible(false);
        }
        if (FD_IsVouchingMode == true) {
            var Rightpane = Mainspliter.GetPaneByName('RightPane');
            Rightpane.Expand();
            var Leftpane = Mainspliter.GetPaneByName('LeftPane');
            ClearLeftPane();
            if (Leftpane.IsCollapsed() == true) {
                Leftpane.Expand();
            }
        }
        else {
            var Rightpane = Mainspliter.GetPaneByName('RightPane');
            if (Rightpane.IsCollapsed() == false) {
                Rightpane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
            }
            var Leftpane = Mainspliter.GetPaneByName('LeftPane');
            ClearLeftPane();
            if (Leftpane.IsCollapsed() == false) {
                Leftpane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
        FDListGrid_CollapseAllDetailRows();
    }
    function FDListGrid_CollapseAllDetailRows()
    {
        if (typeof window !== 'undefined')
        {
            if (typeof window.FDListGrid !== 'undefined')
            {
                if (typeof window.FDListGrid.CollapseAllDetailRows !== 'undefined')
                {
                    if (typeof FDListGrid.CollapseAllDetailRows == 'function')
                    {
                        FDListGrid.SetFocusedRowIndex(-1);
                        FDListGrid.CollapseAllDetailRows();
                    }
                    else
                    {
                        alert("CollapseAllDetailRows is not a function");
                    }
                }
                else
                {
                    ShowLoader();
                    setTimeout(function ()
                    {
                        FDListGrid_CollapseAllDetailRows();
                        HideLoader();
                    }, Timeout100);
                }
            }
            else
            {
                alert('grid undefined')
            }
        }
        else
        {
            alert('window undefined')
        }
    }

    function FD_ViewSwitch_ValueChange(e)
    {
        FD_ViewMode = e.value == false ? "Default" : "Compact";
        if (FDList_Auto_Vouching_Mode == true)
        {
            $("#FDVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }
        else
        {
            FDListGrid.CollapseAllDetailRows();
        }
    }
        function OnFDCellClick(event, cell,col, row)
        {
            if (UserType_FDPrf == "AUDITOR" || UserType_FDPrf == "SUPERUSER")
            {
                if (event.button == 0)
                {
                    if (cell.style.backgroundColor.length > 0)
                    {
                        cell.style.backgroundColor = "";
                    }
                    else
                    {
                        cell.style.backgroundColor = 'skyblue';
                    }
                }
            }
        }
        function FDOnInit(s, e) {
            FDAdjustSize();
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                FDAdjustSize();
            });    
        }
    function FDGrid_BeginCallBack(s, e) {
        FD_FocusedRowIndexBeforeRefresh = s.GetFocusedRowIndex();
            e.customArgs["command"] = e.command;
            e.customArgs["ShowHorizontalBar"] = FD_ShowHorizontalBar;
            e.customArgs["VouchingMode"] = FD_IsVouchingMode;
            e.customArgs["ViewMode"] = FD_ViewMode;
            e.customArgs["ColumnToBeShownIndex"] = FD_ColumnToBeShownIndex;
            e.customArgs["ColumnToBeHidddenIndex"] = FD_ColumnToBeHidddenIndex;
    }
    var FD_ColumnToBeShownIndex = "";
    var FD_ColumnToBeHidddenIndex = "";
        function OnGridFDListGrid_EndCallback(s, e) {
            //FDAdjustSize();
            ASPxClientControl.AdjustControls(document.getElementById("FDProfile_ParentDiv"));
            FD_ColumnToBeShownIndex = s.cpColumnToBeShownIndex;
            FD_ColumnToBeHidddenIndex = s.cpColumnToBeHidddenIndex;
            FDGridLayout = s.cpClientLayout;
            if (e.command == "REFRESH") { s.SetFocusedRowIndex(-1); s.SetFocusedRowIndex(FD_FocusedRowIndexBeforeRefresh); }
            if (FD_IsVouchingMode == true) {
                $(".FDListGrid_PreviewRow").hide();
            }
            else {
                $(".FDListGrid_PreviewRow").show();
            }
            GetSessionStorage("FDListGrid");
            SendCustomArgs_FilterControl(s, e);
        }
        function FDAdjustSize() {
            var height = (document.documentElement.clientHeight * 90) / 100;
            try{ FDListGrid.SetHeight(height); } catch(err){}
        }
        function FDchangeMode() {
            ShowLoader();
            if (FD_ShowHorizontalBar == 0) {
                FD_ShowHorizontalBar = 1;
                $("#FDToggleScrollBar").find("span").text("Default Data");
                $("#FDToggleScrollBar").width(110);
            }
            else {
                FD_ShowHorizontalBar = 0;
                $("#FDToggleScrollBar").find("span").text("Full Data");
                $("#FDToggleScrollBar").width(90);
            }
            $.ajax({
                url: '@Url.Action("Frm_FD_Info_Grid", "FD")',
                type: "GET",
                data: { ShowHorizontalBar: FD_ShowHorizontalBar, VouchingMode: FD_IsVouchingMode, ViewMode: FD_ViewMode, ColumnToBeHidddenIndex: FD_ColumnToBeHidddenIndex, ColumnToBeShownIndex: FD_ColumnToBeShownIndex  },
                success: function (res) {
                    $("#FDreloadPartialView").html(res);
                    if (FD_IsVouchingMode == true) {
                        $(".FDListGrid_PreviewRow").hide();
                    }
                    else {
                        $(".FDListGrid_PreviewRow").show();
                    }
                    GetSessionStorage("FDListGrid");
                }
            });
            HideLoader();
        }
        function FDContextMenuFunction(s, e) {
            if (e.item.name == 'New') {
                OnNewClick();
            }
            if (e.item.name == 'Close') {
                closeProfile_FD();
            }
            else if (e.item.name == 'Edit') {
                OnEditClick();
            }
            else if (e.item.name == 'Delete') {
                OnDeleteClick();
            }
            else if (e.item.name == 'View') {
                OnViewClick();
            }
            else if (e.item.name == 'ListPreview') {
                OnListPreviewClick();
            }
            else if (e.item.name == 'NewAudit') {
                OnNewAuditClick();
            }
            else if (e.item.name == 'ViewAudit') {
                OnViewAuditClick();
            }
            else if (e.item.name == 'Lock') {
                OnLockClick();
            }
            else if (e.item.name == 'UnLock') {
                OnUnlockClick();
            }
            else if (e.item.name == 'Refresh') {
                FDListGrid.Refresh();
            }
        }
