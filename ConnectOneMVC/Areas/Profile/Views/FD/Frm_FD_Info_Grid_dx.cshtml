@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;    
    int ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;
}
@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar)
                 .ID("FDListGrid")
                 .DataSource(d => d.Mvc().Controller("FD").LoadAction("Frm_FD_Info_GridData_dx").LoadMode(DataSourceLoadMode.Raw).Key("ID"))
                 .Columns(columns =>
                 {
                     columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);//Bug #137209 Fix
                     columns.Add().DataField("iIcon").Name("iIcon").Caption("").CellTemplate(new JS("FDListGrid_dx_iIconTemplate")).Width(30)
                     .HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource")).RenderAsync(true);
                     columns.Add().DataField("FDListGrid_dx_Compact_Column").Name("FDListGrid_dx_Compact_Column").Caption("").Visible(false).CellTemplate(new JS("FDListGrid_dx_Compact_Column_Template"))
                     .CalculateCellValue("FDListGrid_dx_Compact_Column_CellValue").Width("100%").RenderAsync(true).ShowInColumnChooser(false);
                     columns.Add().DataField("FD_DATE").Caption("F.D. Date").Visible(true).MinWidth(30).Width(80).DataType(GridColumnDataType.Date).Format("dd/MM/yyyy");
                     columns.Add().DataField("FD_AS_DATE").Caption("As Of Date").Visible(true).MinWidth(30).Width(80).DataType(GridColumnDataType.Date).Format("dd/MM/yyyy");
                     columns.Add().DataField("FD_NO").Caption("F.D. A/c. No").MinWidth(30).Width(100);
                     columns.Add().DataField("FD_AMOUNT").Caption("F.D. Amount").MinWidth(30).Width(100).DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("FD_INT_RATE").Caption("Interest(%)").MinWidth(40).Width(75).DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("FD_MAT_DATE").Caption("Maturity Date").Visible(true).MinWidth(30).Width(95).DataType(GridColumnDataType.Date).Format("dd/MM/yyyy");
                     columns.Add().DataField("FD_MAT_AMT").Caption("Maturity Amount").MinWidth(30).Width(115).DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("FD_INT_PAY_COND").Caption("Interest condition").MinWidth(30).Width(120);
                     columns.Add().DataField("BA_CUST_NO").Caption("Customer No.").MinWidth(30).Width(100);
                     columns.Add().DataField("BB_BRANCH_NAME").Caption("Branch").MinWidth(30).Width(100);
                     columns.Add().DataField("FD_Status").Caption("FD Status").MinWidth(30).Width(100);
                     columns.Add().DataField("FD_Less_Maturity").Caption("Maturity - FD Amt").MinWidth(30).Width(120).DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("Interest_Recd").Caption("Gross Interest").MinWidth(30).Width(100).DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("TDS_Paid").Caption("TDS Deducted").MinWidth(30).Width(100).DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("Nett_Interest").Caption("Nett Interest").MinWidth(30).Width(100).DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}")).DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("Special_Ref").Caption("Reference").MinWidth(30).Width(100).Visible(true);
                     columns.Add().DataField("Other_Detail").Caption("Other Details").MinWidth(30).Width(100);
                     columns.Add().DataField("Remarks").Caption("Remarks").MinWidth(30).Width(100);
                     columns.Add().DataField("CLOSE_DATE").Caption("Close Date").Visible(true).MinWidth(30).Width(100).DataType(GridColumnDataType.Date).Format("dd/MM/yyyy");
                     columns.Add().DataField("Action_By").Caption("Action By").Visible(false).MinWidth(125);
                     columns.Add().DataField("Action_Date").Caption("Action Date").Visible(false).MinWidth(125).DataType(GridColumnDataType.Date).Format("dd MMMM yyyy HH:mm");
                     columns.Add().DataField("Add_By").Caption("Add By").Visible(false).MinWidth(125);
                     columns.Add().DataField("Add_Date").Caption("Add Date").Visible(false).MinWidth(125);
                     columns.Add().DataField("CrossedTimeLimit").Caption("CrossedTimeLimit").Visible(false).MinWidth(125);
                     columns.Add().DataField("Edit_By").Caption("Edit By").Visible(false).MinWidth(125);
                     columns.Add().DataField("Edit_Date").Caption("Edit Date").Visible(false).MinWidth(125);
                     columns.Add().DataField("ID").Caption("ID").Visible(false).MinWidth(125);
                     columns.Add().DataField("OpenActions").Caption("OpenActions").Visible(false).MinWidth(125);
                     columns.Add().DataField("RemarkStatus").Caption("RemarkStatus").Visible(false).MinWidth(125);
                     columns.Add().DataField("TR_ID").Caption("TR_ID").Visible(false).MinWidth(125);
                     columns.Add().DataField("REJECTED_COUNT").Caption("iREJECTED_COUNT").Visible(false).MinWidth(125);
                     columns.Add().DataField("RESPONDED_COUNT").Caption("iRESPONDED_COUNT").Visible(false).MinWidth(125);
                     columns.Add().DataField("COMPLETE_ATTACH_COUNT").Caption("iCOMPLETE_ATTACH_COUNT").Visible(false).MinWidth(125);
                     columns.Add().DataField("REQ_ATTACH_COUNT").Caption("iREQ_ATTACH_COUNT").Visible(false).MinWidth(125);
                     columns.Add().DataField("OTHER_ATTACH_CNT").Caption("OTHER_ATTACH_CNT").Visible(false).MinWidth(125);
                     columns.Add().DataField("ALL_ATTACH_CNT").Caption("ALL_ATTACH_CNT").Visible(false).MinWidth(125);
                     columns.Add().DataField("Entry_Type").GroupIndex(0).MinWidth(125).Visible(false);
                     columns.Add().DataField("Action_Status").GroupIndex(1).MinWidth(125).Visible(false);
                     columns.Add().DataField("BI_BANK_NAME").GroupIndex(2).MinWidth(125).Visible(false);
                 })       
                 .Summary(s =>
                 {
                 })
                 .MasterDetail(md =>
                 {
                     md.AutoExpandAll(false);
                     md.Enabled(!VouchingMode);
                     md.Template(new JS("FDListGrid_dx_DetailTemplate"));
                 })
         .OnInitialized("FDListGrid_dx_OnInitialized")
         .OnCellPrepared("FDListGrid_dx_OnCellPrepared")
         .OnRowPrepared("FDListGrid_dx_OnRowPrepared")
         .OnContentReady("FDListGrid_dx_OnContentReady")
         .OnCellDblClick("FDListGrid_dx_OnCellDblClick")
         .OnSelectionChanged("FDListGrid_dx_OnSelectionChanged")
         //.OnFocusedRowChanged("FDListGrid_dx_OnFocusedRowChanged")
         .OnRowExpanding("FDListGrid_dx_OnRowExpanding")
         .OnRowCollapsing("FDListGrid_dx_OnRowCollapsing")
         .OnContextMenuPreparing("FDListGrid_dx_OnContextMenuPreparing")
//.OnEditorPreparing("FDListGrid_dx_OnEditorPreparing")
)