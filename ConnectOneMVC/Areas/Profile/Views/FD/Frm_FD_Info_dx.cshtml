    function FD_VouchingSwitch_ValueChange(e)
    {
        FD_IsVouchingMode = e.value;
        if (FDList_Auto_Vouching_Mode == true)
        {
            FDList_Auto_Vouching_Mode = false;
        }
        else
        {
            FDPrf_FAB.SetVisible(false);
        }
        if (FD_IsVouchingMode == true) {
            OpenRightPane();
            ClearLeftPane();
            OpenLeftPane();
        }
        else {
            FDPrf_FAB.SetActionContext("AddAttachmentContext", false);
            CloseRightPane();
            ClearLeftPane();
            CloseLeftPane();
        }
        FDListGrid.clearSelection();
        FDListGrid.option("masterDetail.enabled", !FD_IsVouchingMode)
        FDListGrid.repaint();
    }

    function FD_ViewSwitch_ValueChange(e)
    {
        FD_ViewMode = e.value == false ? "Default" : "Compact";
        if (FDList_Auto_Vouching_Mode == true)
        {
            $("#FDVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }
        FDListGrid.beginUpdate();
        var columns = FDListGrid.option("columns");
        if (FD_ViewMode == "Compact") {
            VisibleColumns_FDListGrid = [];
            for (var i = 0; i < columns.length; i++) {
                var name = columns[i].dataField;
                var ColumnVisible = FDListGrid.columnOption(name, "visible");
                if (name == "FDListGrid_dx_Compact_Column") {
                    FDListGrid.columnOption(name, "visible", true);
                }
                else if (ColumnVisible == true && name != "iIcon") {
                    VisibleColumns_FDListGrid.push(name);
                    FDListGrid.columnOption(name, "visible", false);
                }
            }
        }
        else {
            FDListGrid.columnOption("FDListGrid_dx_Compact_Column", "visible", false);
            for (var i = 0; i < VisibleColumns_FDListGrid.length; i++) {
                FDListGrid.columnOption(VisibleColumns_FDListGrid[i], "visible", true);
            }
        }
        FDListGrid.repaint();
        FDListGrid.endUpdate();
    }
    function OnFDCellClick(event, cell,col, row)
    {
        if (UserType_FDPrf == "AUDITOR" || UserType_FDPrf == "SUPERUSER")
        {
            if (event.button == 0)
            {
                if (cell.style.backgroundColor.length > 0)
                {
                    cell.style.backgroundColor = "";
                }
                else
                {
                    cell.style.backgroundColor = 'skyblue';
                }
            }
        }
    }
    function FDchangeMode() {
        if (FD_ShowHorizontalBar == 0) {
            FD_ShowHorizontalBar = 1;
            $("#FDToggleScrollBar").find("span").text("Default Data");
            $("#FDToggleScrollBar").width(110);
            FDListGrid.option("columnHidingEnabled", false);
            FDListGrid.option("allowColumnResizing", true)
        }
        else {
            FD_ShowHorizontalBar = 0;
            $("#FDToggleScrollBar").find("span").text("Full Data");
            $("#FDToggleScrollBar").width(90);
            FDListGrid.option("columnHidingEnabled", false);
            FDListGrid.option("allowColumnResizing", true)
        }
    }
