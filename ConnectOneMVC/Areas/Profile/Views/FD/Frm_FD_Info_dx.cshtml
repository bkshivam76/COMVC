    function FDListGrid_dx_OnRowExpanding(e) {
        if (Array.isArray(e.key) == false) {
            e.component.collapseRow(Expanded_Row_Key_FD)
            e.component.selectRows(e.key);
            Expanded_Row_Key_FD = e.key;
            FDInfo_IsDetailRowExpanded = true;
            var DetailGridID = e.element[0].id + e.key;
            var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
            if (instance != void 0) {
                instance.state(null) // grid maintains its state after collapsing so resetting the state when expands again as per old grid
            }
        }
        else {
            e.component.option("CustomProp.groupRowExpanded", true);
        }
    }
    function FDListGrid_dx_OnRowCollapsing(e) {
        if (Array.isArray(e.key)==false) {
            var DetailGridID = e.element[0].id + e.key;
            sessionStorage.removeItem(DetailGridID + "_DetailGridState") //removing grid state from session storage on collapse
            FDInfo_IsDetailRowExpanded = false;
            e.component.selectRows(e.key);
            if (FD_IsVouchingMode == false) {
                FDPrf_FAB.SetVisible(false);
            }
            var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
            if (instance != void 0) {
                instance.clearSelection();
            }
        }
        else {
            e.component.option("CustomProp.groupRowCollapsed", true);
        }
    }
    function FDListGrid_dx_OnContextMenuPreparing(e) {
        if (!e.items) e.items = [];
        if (e.target == "header")
        {
            DxGrid_HeaderContextMenu(e)
        }
        else if ((e.target == "content" && e.row && e.row.rowType == "groupFooter") || e.target == "footer")
        {
            if (FD_ViewMode == "Compact")
                DxGrid_FooterContextMenu(e, true);
            else
                DxGrid_FooterContextMenu(e);
        }
        else if (e.target == "content" && e.row && (e.row.rowType == "data" || e.row.rowType =="detailAdaptive"))
        {
            var key = e.component.getKeyByRowIndex(e.row.rowIndex);
            e.component.selectRows(key);
            var expanded = e.component.isRowExpanded(key);
            e.items = [
                {
                    text: "Expand Detail",
                    icon: "fa-solid fa-arrow-down-wide-short " + (expanded ? "text-muted" : "text-info"),
                    disabled: expanded,
                    visible: !FD_IsVouchingMode,
                    onItemClick: function ()
                    {
                        if (expanded)
                        {
                        }
                        else
                        {
                            e.component.expandRow(key);
                        }
                    }
                }, {
                    text: "Collapse Detail",
                    icon: "fa-solid fa-arrow-up-wide-short " + (!expanded ? "text-muted" : "text-info"),
                    disabled: !expanded,
                    visible: !FD_IsVouchingMode,
                    onItemClick: function () {
                        if (expanded) {
                            e.component.collapseRow(key);
                        }
                        else {
                        }
                    }
                },
                {
                    text: "Export",
                    icon: "fa-solid fa-file-export text-warning",
                    visible: "@FD_ExportRight" == "True",
                    beginGroup: true,
                    onItemClick: function () {
                        OnListPreviewClick();
                    }
                },
                    
                {
                    text: "Close",
                    icon: "fa-solid fa-rectangle-xmark text-danger",
                    beginGroup: true,
                    onItemClick: function ()
                    {
                        closeProfile_FD();
                    }
                },
                {
                    text: "Refresh",
                    icon: "fa-solid fa-arrow-rotate-right text-success",
                    beginGroup: true,
                    onItemClick: function ()
                    {
                        FDListGrid.refresh();
                    }
                }
            ]
        }
    }
    function closeProfile_FD() {
        $(".TabPanalMenu-tabs .active span").click();

    }
    $(".TabPanalMenu-tabs .active span").on("click", function () {
        $.ajax({
            type: 'GET',
            url: "/Profile/FD/SessionClear",
            cache: false
        });
        var pane = Mainspliter.GetPaneByName('RightPane');
        pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
        var Leftpane = Mainspliter.GetPaneByName('LeftPane');
        ClearLeftPane();
        if (Leftpane.IsCollapsed() == false) {
            Leftpane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
        }
        ClearAllReferences_FDProfile();
    });
    </script>

    <script>
    var FDInfo_IsDetailRowExpanded = false;
    var FDInfo_NestedRecord_FocusedRowIndex = -1;
    var FDInfo_NestedGrid_AccessID;
    var FDInfo_AtachmentID;
    var FDInfo_FileName;
    var FDInfo_ParamMandatory;
    var FDInfo_FromDateLabel;
    var FDInfo_ToDateLabel;
    var FDInfo_DescriptionLabel;
    var FDInfo_Doc_ID;
    var FDInfo_Doc_Category;
    var FDInfo_MasterRowRecID;
    var FDInfo_MasterRowMID;
    var FDInfo_NestedRowMapID;
    var FDInfo_reason;
    var FDInfo_Attachment_RecStatus;
    var FDInfo_NestedRowReasonID;
    var FDInfo_NestedRowUniqueID;
    function On_FDProfile_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@Help_Attachment_AddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (FDInfo_ParamMandatory == 1)
            {
                AddAttachment(FDInfo_MasterRowRecID, "Profile_FD", FDInfo_Doc_ID, FDInfo_Doc_Category, FDInfo_ParamMandatory, FDInfo_FromDateLabel, FDInfo_ToDateLabel, FDInfo_DescriptionLabel, "FDProfileAttachment", null, "FDListGrid", FDInfo_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(FDInfo_MasterRowRecID, "Profile_FD", FDInfo_Doc_ID, "FDProfileAttachment", "FDListGrid", FDInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (FDInfo_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(FDInfo_MasterRowRecID, "Profile_FD", FDInfo_AtachmentID, FDInfo_ParamMandatory, FDInfo_FromDateLabel, FDInfo_ToDateLabel, FDInfo_DescriptionLabel, "FDProfileAttachment", null, "FDListGrid", FDInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(FDInfo_MasterRowRecID, "Profile_FD", FDInfo_AtachmentID, FDInfo_ParamMandatory, FDInfo_FromDateLabel, FDInfo_ToDateLabel, FDInfo_DescriptionLabel, null, "FDListGrid", FDInfo_NestedGrid_AccessID, FDInfo_Attachment_RecStatus);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@Help_Attachment_ViewRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }


            ViewDocument(FDInfo_AtachmentID, FDInfo_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(FDInfo_MasterRowRecID, "Profile_FD", "FD Information", "FDListGrid", FDInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Add_Reason")
        {
            if (FDInfo_Doc_Category.toLowerCase() == "others") {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else {
                AttachmentAddReason(FDInfo_MasterRowRecID, FDInfo_NestedRowMapID, "Profile_FD", "FDListGrid", FDInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(FDInfo_MasterRowRecID, FDInfo_NestedRowMapID, "Profile_FD", "FDListGrid", FDInfo_NestedGrid_AccessID, FDInfo_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(FDInfo_MasterRowRecID, FDInfo_NestedRowMapID, "FDListGrid", FDInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
        else if (e.actionName == "AuditAction")
        {
            FDPrf_FAB.SetActionContext("AuditActionContext", true);
        }
        else if (e.actionName == "BackAudit")
        {
            if (FDInfo_Nested_Doc_Status == "")
            {
                FDPrf_FAB.SetActionContext("AutoItemContext", true);
            }
            if (FDInfo_Nested_Doc_Status == "NO")
            {
                FDPrf_FAB.SetActionContext("EditItemContext", true);
            }
            if (FDInfo_Nested_Doc_Status == "YES")
            {
                FDPrf_FAB.SetActionContext("actionItemContext", true);
            }
        }
        else if (e.actionName == "Accept")
        {
            FDInfo_AcceptwithoutRemarks();
        }
        else if (e.actionName == "Reject")
        {
            FDInfo_AcceptRejectVoucher("Reject");
        }
        else if (e.actionName == "AcceptWithRemarks")
        {
            FDInfo_AcceptRejectVoucher("Accept");
        }
        else if (e.actionName == "AcceptDoc") {

            OnFDInfo_AcceptDoc();
        }
        else if (e.actionName == "RejectDoc") {

            OnFDInfo_RejectDoc();
        }
    }
    function OnFDInfo_RejectDoc() {
        if (FDInfo_AtachmentID == null || FDInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        RejectAttachment(FDInfo_AtachmentID, "FDListGrid", FDInfo_NestedGrid_AccessID);
    }
    function OnFDInfo_AcceptDoc() {
        if (FDInfo_AtachmentID == null || FDInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        AcceptAttachment(FDInfo_AtachmentID, "FDListGrid", FDInfo_NestedGrid_AccessID);
    }
    function FDInfo_AcceptwithoutRemarks()
    {
        var Recid;
        if (FDInfo_IsDetailRowExpanded == true || FD_IsVouchingMode==true)
        {
            if (FDInfo_MasterRowRecID == null || FDInfo_MasterRowRecID == "")
            {
                Recid = ID;
            }
            else
            {
                Recid = FDInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = ID;
        }
        Entry_AcceptwithoutRemarks(Recid, "Profile_FD", "FDListGrid", FDInfo_AtachmentID, FDInfo_NestedRowReasonID, FDInfo_NestedRowUniqueID);
    }
    function FDInfo_AcceptRejectVoucher(_actionMethod)
    {
        var Recid;
        if (FDInfo_IsDetailRowExpanded == true || FD_IsVouchingMode == true)
        {
            if (FDInfo_MasterRowRecID == null || FDInfo_MasterRowRecID == "")
            {
                Recid = ID;
            }
            else
            {
                Recid = FDInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = ID;
        }
        Entry_AcceptReject(_actionMethod, Recid, "Profile_FD", "FDListGrid", FDInfo_AtachmentID, FDInfo_NestedRowReasonID, FDInfo_NestedRowUniqueID);
    }
    function FDListGrid_dx_iIconTemplate(container, templateData) {
        var iREQ_ATTACH_COUNT = templateData.data.REQ_ATTACH_COUNT
        var iCOMPLETE_ATTACH_COUNT = templateData.data.COMPLETE_ATTACH_COUNT
        var iRESPONDED_COUNT = templateData.data.RESPONDED_COUNT
        var iREJECTED_COUNT = templateData.data.REJECTED_COUNT
        var iOTHER_ATTACH_CNT = templateData.data.OTHER_ATTACH_CNT
        var iALL_ATTACH_CNT = templateData.data.ALL_ATTACH_CNT
        var iIcon = templateData.data.iIcon
        var UniqueID = templateData.component.element()[0].id
        var key = templateData.data.ID
        var VisibleIndex = templateData.rowIndex
        var htmlString = "";
        htmlString = DxGrid_AttachmentIcons(iREQ_ATTACH_COUNT, iCOMPLETE_ATTACH_COUNT, iRESPONDED_COUNT, iREJECTED_COUNT, iOTHER_ATTACH_CNT, iALL_ATTACH_CNT);
        htmlString += DxGrid_VouchingAuditIcons(iIcon)
        htmlString += DxGrid_AuditIconAfterClick(UniqueID, key, VisibleIndex)
        $(container).html(htmlString)
    }
    function FDListGrid_dx_DetailTemplate(container, templateData) {
        var GridName = templateData.component.element()[0].id
        var RecID = templateData.data.ID;
        FDListGrid_dx_Detail(container, GridName, RecID, FD_IsVouchingMode, FD_ShowHorizontalBar);
    }
    function FDListGrid_dx_Detail(container, GridName, RecID, vouchingMode, AllColumns)
    {
        var url = "/Profile/FD/Frm_FD_Info_DetailGrid_dx?VouchingMode=" + vouchingMode + "&RecID=" + RecID
        var instance = DxGrid_AttachmentGrid_Create(container, GridName, RecID, vouchingMode, AllColumns, url)
        instance.option("onSelectionChanged", FDListGrid_dx_Detail_onSelectionChanged);    
    } 
    function FDListGrid_dx_Detail_onSelectionChanged(e) {
        if (FDInfo_IsDetailRowExpanded || FD_IsVouchingMode) {
            if (e.selectedRowsData != null && e.selectedRowsData.length > 0) {
                FDInfo_NestedGrid_AccessID = e.element[0].id;
                FDListGrid_dx_Detail_SelectedRowData(e.selectedRowsData)
            }
            else {
                FDPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }
    function FDListGrid_dx_Detail_SelectedRowData(selectedData = null) {
        if (selectedData == null) {
            selectedData = $("#" + FDInfo_NestedGrid_AccessID).dxDataGrid("getSeletedRowsData");
        }
        var values = selectedData[0];
        FDInfo_NestedRowUniqueID = values["UniqueID"];
        if (values["UniqueID"] != null) {
            FDPrf_FAB.SetVisible(true);
            FDInfo_Nested_Doc_Status = values["Doc_Status"];

            if (FD_IsVouchingMode == true) {
                FDPrf_FAB.SetActionContext("AuditActionContext", true);
            }
            else {
                if (FDInfo_Nested_Doc_Status == "") {
                    FDPrf_FAB.SetActionContext("AutoItemContext", true);
                }
                else if (FDInfo_Nested_Doc_Status == "NO") {
                    FDPrf_FAB.SetActionContext("EditItemContext", true);
                }
                else if (FDInfo_Nested_Doc_Status == "YES") {
                    FDPrf_FAB.SetActionContext("actionItemContext", true);
                }
            }
            FDInfo_ParamMandatory = values["Params_Mandatory"];
            FDInfo_FromDateLabel = values["LABEL_FROM_DATE"];
            FDInfo_ToDateLabel = values["LABEL_TO_DATE"];
            FDInfo_DescriptionLabel = values["LABEL_DESCRIPTION"];
            FDInfo_Doc_Category = values["Document_Category"];
            FDInfo_Doc_ID = values["Document_ID"];
            FDInfo_AtachmentID = values["ATTACH_ID"];
            IndexAttachmentID = FDInfo_AtachmentID;
            FDInfo_MasterRowRecID = values["TxnID"];
            FDInfo_MasterRowMID = values["TxnMID"];
            FDInfo_NestedRowMapID = values["MAP_ID"];
            FDInfo_reason = values["Reason"];
            FDInfo_FileName = values["ATTACH_FILE_NAME"];
            FDInfo_Attachment_RecStatus = values["Attachment_Action_Status"];
            if (FD_IsVouchingMode == true) {
                if (FDInfo_FileName != null && FDInfo_FileName.length > 0) {
                    ViewDocument(FDInfo_AtachmentID, FDInfo_FileName, "FDPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else {
                    CloseRightPane();
                    ClearRightPane();
                }
            }
        }
        FDInfo_NestedRowReasonID = values["ReasonID"];
        IndexAttachmentReasonID = FDInfo_NestedRowReasonID;
    }
    
    function LeftPaneContent_FD(GridName, RecID, vouchingMode, AllColumns = 0) {
        $("#LeftPane_Div_Content").html(null);
        $("#LeftPane_Div_Content").append("<div class='col-xs-12'><label>Documents Attached:</label><div class='AttachmentGrid'><form></form></div></div><div class='col-xs-12'><label>Additional Info:</label><div class='AdditionalInfoGrid'><form></form></div></div>")
        FDListGrid_dx_Detail($("#LeftPane_Div_Content .AttachmentGrid>form"), GridName, RecID, vouchingMode, AllColumns)
        setTimeout( function () {
            AdditionalInfoGrid_FD($("#LeftPane_Div_Content .AdditionalInfoGrid>form"), GridName, RecID, vouchingMode, AllColumns)
        })
    }
    function AdditionalInfoGrid_FD(container, GridName, RecID, vouchingMode, AllColumns)
    {
        var url = "/Profile/FD/AdditionalInfo_Grid_dx?VouchingMode=" + vouchingMode + "&RecID=" + RecID
        DxGrid_CreateAdditionalInfoGrid(container, GridName, RecID, vouchingMode, AllColumns, url)
    }
</script>
