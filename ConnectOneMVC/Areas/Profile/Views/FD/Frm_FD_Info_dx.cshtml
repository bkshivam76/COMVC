    function FDProf_UpdateFooterDetail(FD_ID, FD_Action_Status, FD_Add_Date, FD_Add_By, FD_Action_Date, FD_Action_By, FD_Edit_Date, FD_Edit_By) {

        var Status = "";
        var Lbl_Status = "";
        var Lbl_StatusBy = "";
        var Pic_Status = "";
        var Lbl_Create = "";
        var Lbl_Modify = "";
        var Lbl_Status_Color = "";
        var Add_Date = "";
        var Add_By = "";
        var Status_On = "";
        var Status_By = "";
        var StatusStr = "Completed";
        var Lbl_StatusOn = "";
        var Lbl_StatusBy = "";

        Status = FD_Action_Status;

        if (Status && Status.toUpperCase() == "LOCKED") {

            Pic_Status = "Fa Fa-Lock";
        }
        else {
            Pic_Status = "Fa Fa-UnLock";

        }

        Add_Date = (moment(FD_Add_Date).format("DD/MM/YYYY HH:mm:ss"));;
        Add_By = FD_Add_By;
        Status_On = (moment(FD_Action_Date).format("DD/MM/YYYY HH:mm:ss"));
        Status_By = FD_Action_By;

        if (Status == "Locked")
            StatusStr = "Locked";
        else
            StatusStr = "UnLocked";

        if (Status_On) {
            Lbl_StatusOn = StatusStr + " On: " + Status_On;
            Lbl_StatusBy = StatusStr + " By: " + Status_By;
        }
        else {
            Lbl_StatusOn = StatusStr + " On: " + "?";
            Lbl_StatusBy = StatusStr + " By: " + Status_By;
        }

        if (Add_Date) {
            Lbl_Create = "Add On: " + Add_Date + ", By: " + Add_By;
        }
        else {
            Lbl_Create = "Add On: " + "?, By: " + Add_By;
        }

        var Edit_Date = "";
        var Edit_By = "";

        Edit_Date = (moment(FD_Edit_Date).format("DD/MM/YYYY HH:mm:ss"));
        Edit_By = FD_Edit_By;

        if (Edit_Date) {
            Lbl_Modify = "Edit On: " + Edit_Date + ", By: " + Edit_By;
        }
        else {
            Lbl_Modify = "Edit On: " + "?, By: " + Edit_By;
        }
        $('#FD_Lbl_ActionOn').text(Lbl_StatusOn)
        $('#FD_Lbl_ActionBy').text(Lbl_StatusBy);
        $('#FDLbl_Create').text(Lbl_Create);
        $('#FDLbl_Modify').text(Lbl_Modify);
        if (Lbl_Status_Color != "") {
            $('#FDLbl_Status').css('color', Lbl_Status_Color);
        }
        if (Pic_Status != "") {
            $('#FD_LockICON').css('class', Pic_Status);
        }
    }
    function OnNewClick() {
        if ("@FD_AddRight" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        IsFDNewPopup = true;
        IsFDViewPopup = false;
        IsFDSucessPopup = true;
        $.ajax({
            type: 'GET',
            url: "/Profile/FD/DataNavigation",
            data: { ActionMethod: "NEW" },
            cache: false,
            success: function (New_Get_Frm_FD_Window_result) {
                if (New_Get_Frm_FD_Window_result.result == "true" || New_Get_Frm_FD_Window_result.result == true) {
                    $("#popup_Frm_FD_Window").dxPopup("show");
                    $("#popup_Frm_FD_Window").dxPopup("instance").option("title", "New ~ Fixed Deposit");
                    ShowLoader();
                    $("#popup_Frm_FD_Window_result").load("@Url.Action("Frm_FD_Window", "FD", new { @area = "Profile" })?ActionMethod=New", function () {
                        HideLoader();
                        FDListGrid.Refresh();
                    });
                }
                else {
                    DevExpress.ui.dialog.alert(New_Get_Frm_FD_Window_result.Message, "Information...!");
                    FDListGrid.Refresh();
                }
            }
        });
    }
    function OnListPreviewClick() {
        if ("@FD_ExportRight" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        OpenPopup("FD_report_modal", "Export Option", "@Url.Action("Frm_Export_Options_dx", "FD", new { @area = "Profile" })", "auto", 125, false, null);
    }
    function OnEditClick() {
        if ("@FD_UpdateRight" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        IsFDViewPopup = false;
        if (ID == "" || ID == undefined) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }

        $.ajax({
            type: 'GET',
            url: "/Profile/FD/DataNavigation",
            data: { ActionMethod: "EDIT", id: ID, CLOSE_DATE: CLOSE_DATE, YearID: YearID, Action_Status: Action_Status, Edit_Date: Edit_Date, TR_ID: TR_ID, OpenActions: OpenActions },
            cache: false,
            success: function (Edit_Get_Frm_FD_Window_result) {
                if (Edit_Get_Frm_FD_Window_result.result == "true" || Edit_Get_Frm_FD_Window_result.result == true) {
                    $("#popup_Frm_FD_Window").dxPopup("show");
                    $("#popup_Frm_FD_Window").dxPopup("instance").option("title", "Edit ~ F.D.");
                    ShowLoader();
                    $("#popup_Frm_FD_Window_result").load("@Url.Action("Frm_FD_Window", "FD", new { @area = "Profile" })?ActionMethod=" + "Edit" + "&id=" + ID + '&Edit_Date=' + encodeURIComponent(Edit_Date), function () {
                        HideLoader();

                    });
                }
                else {
                    DevExpress.ui.dialog.alert(Edit_Get_Frm_FD_Window_result.Message, "Information");
                    FDListGrid.Refresh();
                }
            }
        });
    }
    function OnDeleteClick() {
        if ("@FD_DeleteRight" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        IsFDViewPopup = false;
        if (ID == "" || ID == undefined) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        var result = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Delete ~ F.D.");
        result.done(function (dialogResult) {
            if (dialogResult) {
                $("#popup_Frm_FD_Window_Close_result").dxPopup("hide");

                $.ajax({
                    type: 'GET',
                    url: "/Profile/FD/DataNavigation",
                    data: { ActionMethod: "DELETE", id: ID, CLOSE_DATE: CLOSE_DATE, YearID: YearID, Action_Status: Action_Status, Edit_Date: Edit_Date, TR_ID: TR_ID, OpenActions: OpenActions },
                    cache: false,
                    success: function (FD_DELETE_Get_DataNavigation_result) {
                        if (FD_DELETE_Get_DataNavigation_result.result == "true" || FD_DELETE_Get_DataNavigation_result.result == true) {
                            $("#popup_Frm_FD_Window").dxPopup("show");
                            $("#popup_Frm_FD_Window").dxPopup("instance").option("title", "Delete ~ F.D.");
                            ShowLoader();
                            FDListGrid.Refresh();
