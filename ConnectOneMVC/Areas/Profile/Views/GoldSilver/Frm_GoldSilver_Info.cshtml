    <script>
    var GoldSilverInfo_IsDetailRowExpanded = false;
    var GoldSilverInfo_NestedRecord_FocusedRowIndex = -1;
    var GoldSilverInfo_NestedGrid_AccessID;
    var GoldSilverInfo_AtachmentID;
    var GoldSilverInfo_FileName;
    var GoldSilverInfo_ParamMandatory;
    var GoldSilverInfo_FromDateLabel;
    var GoldSilverInfo_ToDateLabel;
    var GoldSilverInfo_DescriptionLabel;
    var GoldSilverInfo_Doc_ID;
    var GoldSilverInfo_Doc_Category;
    var GoldSilverInfo_MasterRowRecID;
    var GoldSilverInfo_MasterRowMID;
    var GoldSilverInfo_NestedRowMapID;
    var GoldSilverInfo_reason;
    var GoldSilverInfo_Attachment_RecStatus;
    var GoldSilverInfo_NestedRowReasonID;
    var GoldSilverInfo_NestedRowKeyValue;

    function On_GoldSilverProfile_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@Help_Attachment_AddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (GoldSilverInfo_ParamMandatory == 1)
            {
                AddAttachment(GoldSilverInfo_MasterRowRecID, "Profile_GoldSilver", GoldSilverInfo_Doc_ID, GoldSilverInfo_Doc_Category, GoldSilverInfo_ParamMandatory, GoldSilverInfo_FromDateLabel, GoldSilverInfo_ToDateLabel, GoldSilverInfo_DescriptionLabel, "GoldSilverProfileAttachment", null, "GoldSilverListGrid", GoldSilverInfo_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(GoldSilverInfo_MasterRowRecID, "Profile_GoldSilver", GoldSilverInfo_Doc_ID, "GoldSilverProfileAttachment", "GoldSilverListGrid", GoldSilverInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (GoldSilverInfo_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(GoldSilverInfo_MasterRowRecID, "Profile_GoldSilver", GoldSilverInfo_AtachmentID, GoldSilverInfo_ParamMandatory, GoldSilverInfo_FromDateLabel, GoldSilverInfo_ToDateLabel, GoldSilverInfo_DescriptionLabel, "GoldSilverProfileAttachment", null, "GoldSilverListGrid", GoldSilverInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(GoldSilverInfo_MasterRowRecID, "Profile_GoldSilver", GoldSilverInfo_AtachmentID, GoldSilverInfo_ParamMandatory, GoldSilverInfo_FromDateLabel, GoldSilverInfo_ToDateLabel, GoldSilverInfo_DescriptionLabel, null, "GoldSilverListGrid", GoldSilverInfo_NestedGrid_AccessID, GoldSilverInfo_Attachment_RecStatus);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@Help_Attachment_ViewRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }


            ViewDocument(GoldSilverInfo_AtachmentID, GoldSilverInfo_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(GoldSilverInfo_MasterRowRecID, "Profile_GoldSilver", "Gold/Silver Information", "GoldSilverListGrid", GoldSilverInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Add_Reason")
        {
            if (GoldSilverInfo_Doc_Category.toLowerCase() == "others")
            {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else {
                AttachmentAddReason(GoldSilverInfo_MasterRowRecID, GoldSilverInfo_NestedRowMapID, "Profile_GoldSilver", "GoldSilverListGrid", GoldSilverInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(GoldSilverInfo_MasterRowRecID, GoldSilverInfo_NestedRowMapID, "Profile_GoldSilver", "GoldSilverListGrid", GoldSilverInfo_NestedGrid_AccessID, GoldSilverInfo_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(GoldSilverInfo_MasterRowRecID, GoldSilverInfo_NestedRowMapID, "GoldSilverListGrid", GoldSilverInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
        else if (e.actionName == "AuditAction")
        {
            GoldSilverPrf_FAB.SetActionContext("AuditActionContext", true);
        }
        else if (e.actionName == "BackAudit")
        {
            if (GoldSilverInfo_Nested_Doc_Status == "")
            {
                GoldSilverPrf_FAB.SetActionContext("AutoItemContext", true);
            }
            if (GoldSilverInfo_Nested_Doc_Status == "NO")
            {
                GoldSilverPrf_FAB.SetActionContext("EditItemContext", true);
            }
            if (GoldSilverInfo_Nested_Doc_Status == "YES")
            {
                GoldSilverPrf_FAB.SetActionContext("actionItemContext", true);
            }
        }
        else if (e.actionName == "Accept")
        {
            GoldSilverInfo_AcceptwithoutRemarks();
        }
        else if (e.actionName == "Reject")
        {
            GoldSilverInfo_AcceptRejectVoucher("Reject");
        }
        else if (e.actionName == "AcceptWithRemarks")
        {
            GoldSilverInfo_AcceptRejectVoucher("Accept");
        }
        else if (e.actionName == "AcceptDoc") {

            OnGoldSilverInfo_AcceptDoc();
        }
        else if (e.actionName == "RejectDoc") {

            OnGoldSilverInfo_RejectDoc();
        }
    }
    function OnGoldSilverInfo_RejectDoc() {
        if (GoldSilverInfo_AtachmentID == null || GoldSilverInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        RejectAttachment(GoldSilverInfo_AtachmentID, "GoldSilverListGrid", GoldSilverInfo_NestedGrid_AccessID);
    }
    function OnGoldSilverInfo_AcceptDoc() {
        if (GoldSilverInfo_AtachmentID == null || GoldSilverInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        AcceptAttachment(GoldSilverInfo_AtachmentID, "GoldSilverListGrid", GoldSilverInfo_NestedGrid_AccessID);
    }
    function GoldSilverInfo_AcceptwithoutRemarks()
    {
        var Recid;
        if (GoldSilverInfo_IsDetailRowExpanded == true || GoldSilver_IsVouchingMode == true)
        {
            if (GoldSilverInfo_MasterRowRecID == null || GoldSilverInfo_MasterRowRecID == "") {
                Recid = GoldSilverID;;
            }
            else
            {
                Recid = GoldSilverInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = GoldSilverID;;
        }

        Entry_AcceptwithoutRemarks(Recid, "Profile_GoldSilver", "GoldSilverListGrid", GoldSilverInfo_AtachmentID, GoldSilverInfo_NestedRowReasonID, GoldSilverInfo_NestedRowKeyValue);
    }
    function GoldSilverInfo_AcceptRejectVoucher(_actionMethod)
    {
        var Recid;

        if (GoldSilverInfo_IsDetailRowExpanded == true || GoldSilver_IsVouchingMode == true)
        {
            if (GoldSilverInfo_MasterRowRecID == null || GoldSilverInfo_MasterRowRecID == "")
            {
                Recid = ID;
            }
            else
            {
                Recid = GoldSilverInfo_MasterRowRecID;
            }
        }
        else {
            Recid = ID;
        }
        Entry_AcceptReject(_actionMethod, Recid, "Profile_GoldSilver", "GoldSilverListGrid", GoldSilverInfo_AtachmentID, GoldSilverInfo_NestedRowReasonID, GoldSilverInfo_NestedRowKeyValue);
    }
    function OnGoldSilverListGridNestedFocusedRowChange(s, e)
    {
        if (GoldSilverInfo_IsDetailRowExpanded == true || GoldSilver_IsVouchingMode == true)
        {
            GoldSilverInfo_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
            if (GoldSilverInfo_NestedRecord_FocusedRowIndex >= 0)
            {
                ShowLoader();
                GoldSilverInfo_NestedGrid_AccessID = s.uniqueID;
                s.GetRowValues(s.GetFocusedRowIndex(), 'Doc_Status;Params_Mandatory;LABEL_FROM_DATE;LABEL_TO_DATE;LABEL_DESCRIPTION;Document_Category;Document_ID;ATTACH_ID;TxnID;TxnMID;MAP_ID;Reason;ATTACH_FILE_NAME;Attachment_Action_Status;UniqueID;ReasonID', OnGoldSilverInfo_GetGridRowValues);
            }
            else
            {
                GoldSilverPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }
    function OnGoldSilverInfo_GetGridRowValues(values)
    {
        HideLoader();
        if (values[14] != null)
        {
            GoldSilverPrf_FAB.SetVisible(true);
            GoldSilverInfo_Nested_Doc_Status = values[0];
            if (GoldSilver_IsVouchingMode == true) {
                GoldSilverPrf_FAB.SetActionContext("AuditActionContext", true);
            }
            else {
                if (GoldSilverInfo_Nested_Doc_Status == "") {
                    GoldSilverPrf_FAB.SetActionContext("AutoItemContext", true);
                }
                else if (GoldSilverInfo_Nested_Doc_Status == "NO") {
                    GoldSilverPrf_FAB.SetActionContext("EditItemContext", true);
                }
                else if (GoldSilverInfo_Nested_Doc_Status == "YES") {
                    GoldSilverPrf_FAB.SetActionContext("actionItemContext", true);
                }
            }

            GoldSilverInfo_ParamMandatory = values[1];
            GoldSilverInfo_FromDateLabel = values[2];
            GoldSilverInfo_ToDateLabel = values[3];
            GoldSilverInfo_DescriptionLabel = values[4];
            GoldSilverInfo_Doc_Category = values[5];
            GoldSilverInfo_Doc_ID = values[6];
            GoldSilverInfo_AtachmentID = values[7];
            IndexAttachmentID = GoldSilverInfo_AtachmentID;
            GoldSilverInfo_MasterRowRecID = values[8];
            GoldSilverInfo_MasterRowMID = values[9];
            GoldSilverInfo_NestedRowMapID = values[10];
            GoldSilverInfo_reason = values[11];
            GoldSilverInfo_FileName = values[12];
            GoldSilverInfo_Attachment_RecStatus = values[13];
            GoldSilverInfo_NestedRowKeyValue = values[14];
            if (GoldSilver_IsVouchingMode == true)
            {
                if (GoldSilverInfo_FileName != null && GoldSilverInfo_FileName.length > 0)
                {
                    ViewDocument(GoldSilverInfo_AtachmentID, GoldSilverInfo_FileName, "GoldSilverPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else
                {
                    CloseRightPane();
                    ClearRightPane();
                }
            }
        }
        GoldSilverInfo_NestedRowReasonID = values[15];
        IndexAttachmentReasonID = GoldSilverInfo_NestedRowReasonID;
    }
    function GoldSilverGrid_Nested_BeginCallBack(s, e)
    {
        e.customArgs["ShowHorizontalBar"] = GS_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = GoldSilver_IsVouchingMode;
        e.customArgs["command"] = e.command;
    }
    function GoldSilverGrid_DetailRowExpanding(s, e)
    {
        GoldSilverInfo_IsDetailRowExpanded = true;
        s.SetFocusedRowIndex(e.visibleIndex);
        var pane = Mainspliter.GetPaneByName('RightPane');
        if (GoldSilver_IsVouchingMode == true)
        {
            pane.Expand();
        }
        else
        {
            pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
        }
    }
    function GoldSilverGrid_DetailRowCollapsing(s, e)
    {
        GoldSilverInfo_IsDetailRowExpanded = false;
        s.SetFocusedRowIndex(e.visibleIndex);
        if (GoldSilver_IsVouchingMode == true)
        {
            if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false)
            {
                CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
        else
        {
            GoldSilverPrf_FAB.SetVisible(false);
        }
    }
    </script>
    @*attachment and nested grid*@

</div>