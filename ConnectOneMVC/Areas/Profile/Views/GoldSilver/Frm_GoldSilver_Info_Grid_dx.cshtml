@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool GS_SpecialGrouping = (bool)ViewData["GS_SpecialGrouping"];
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;
    int ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;
}

@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar)
                            .ID("GoldSilverListGrid")
                            .DataSource(d => d.Mvc().Controller("GoldSilver").LoadAction("Frm_GoldSilver_Info_Grid_dx").LoadMode(DataSourceLoadMode.Raw).Key("ID"))
                            .ShowBorders(true)
                            .Columns(columns =>
                            {
                                columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);
                                columns.Add().DataField("iIcon").Name("iIcon").Caption("").CellTemplate(new JS("GoldSilverListGrid_dx_iIconTemplate")).Width(30).HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource")).RenderAsync(true);
                                columns.Add().DataField("GoldSilverListGrid_dx_Compact_Column").Name("GoldSilverListGrid_dx_Compact_Column").Caption("").Visible(false).CellTemplate(new JS("GoldSilverListGrid_dx_Compact_Column_Template"))
                                .CalculateCellValue("GoldSilverListGrid_dx_Compact_Column_CellValue").Width("100%").RenderAsync(true).ShowInColumnChooser(false);
                                if (GS_SpecialGrouping == true)
                                {
                                    columns.Add().DataField("Entry_Type").Caption("Entry Type").MinWidth(100).GroupIndex(0).GroupCellTemplate(new JS("GoldSilverListGrid_dx_GroupCell_Template"));
                                    columns.Add().DataField("Action_Status").Caption("Action Status").MinWidth(120).GroupIndex(1).GroupCellTemplate(new JS("GoldSilverListGrid_dx_GroupCell_Template"));
                                    columns.Add().DataField("Type").Caption("GOLD").MinWidth(100).GroupIndex(2).GroupCellTemplate(new JS("GoldSilverListGrid_dx_GroupCell_Template"));

                                }
                                else
                                {
                                    columns.Add().DataField("Action_Status").Caption("Status").Visible(false);
                                }
                                columns.Add().DataField("ITEM_NAME").Caption("Item Name").MinWidth(120);
                                columns.Add().DataField("MISC_NAME").Caption("Description").MinWidth(120);
                                columns.Add().DataField("GS_AMT").Caption("Value").MinWidth(120);
                                columns.Add().DataField("Curr_Value").Caption("Curr Value").MinWidth(120);
                                columns.Add().DataField("GS_ITEM_WEIGHT").DataType(GridColumnDataType.Number).Caption("Weight").MinWidth(120);
                                columns.Add().DataField("Curr_Weight").DataType(GridColumnDataType.Number).Caption("Curr Weight").MinWidth(120);
                                columns.Add().DataField("Rate_per_Gram").Caption("Rate per Gram").MinWidth(120);
                                columns.Add().DataField("AL_LOC_NAME").Caption("Location").MinWidth(120);
                                columns.Add().DataField("GS_OTHER_DETAIL").Caption("Other Detail").MinWidth(120);
                                columns.Add().DataField("Sale_Status").Caption("Sale_Status").MinWidth(120);
                                columns.Add().DataField("Special_Ref").Caption("Special_Ref").MinWidth(120);
                                columns.Add().DataField("ALL_ATTACH_CNT").Caption("ALL_ATTACH_CNT").Visible(false).MinWidth(120);
                                columns.Add().DataField("OTHER_ATTACH_CNT").Caption("iOTHER_ATTACH_CNT").Visible(false).MinWidth(120);
                                columns.Add().DataField("REQ_ATTACH_COUNT").Caption("iREQ_ATTACH_COUNT").Visible(false).MinWidth(120);
                                columns.Add().DataField("iCOMPLETE_ATTACH_COUNT").Caption("iCOMPLETE_ATTACH_COUNT").Visible(false).MinWidth(120);
                                columns.Add().DataField("REJECTED_COUNT").Caption("iREJECTED_COUNT").Visible(false).MinWidth(120);
                                columns.Add().DataField("RESPONDED_COUNT").Caption("iRESPONDED_COUNT").Visible(false).MinWidth(120);
                                columns.Add().DataField("ID").Caption("ID").Visible(false).SortOrder(SortOrder.Asc).MinWidth(120);
                                columns.Add().DataField("Add_By").Caption("Added By").Visible(false).MinWidth(120);
                                columns.Add().DataField("Add_Date").Caption("Added Date").Visible(false).MinWidth(120);
                                columns.Add().DataField("Edit_By").Caption("Edited By").Visible(false).MinWidth(120);
                                columns.Add().DataField("Edit_Date").Caption("Edited Date").Visible(false).MinWidth(120);
                                columns.Add().DataField("Action_Date").Caption("Action Date").Visible(false).MinWidth(120);
                                columns.Add().DataField("Action_By").Caption("Action By").Visible(false).MinWidth(120);
                                columns.Add().DataField("Action_Status").Caption("Action_Status").Visible(false).MinWidth(120);
                                columns.Add().DataField("TR_ID").Caption("TR_ID").Visible(false).MinWidth(120);
                                columns.Add().DataField("CrossedTimeLimit").Caption("CrossedTimeLimit").Visible(false).MinWidth(120);
                                columns.Add().DataField("OpenActions").Caption("OpenActions").Visible(false).MinWidth(120);
                                columns.Add().DataField("Remark_Count").Caption("Remark_Count").Visible(false).MinWidth(120);
                                columns.Add().DataField("Remark_Status").Caption("Remark_Status").Visible(false).MinWidth(120);
                                columns.Add().DataField("Remarks").Caption("Remark").Visible(false).MinWidth(120);
                                columns.Add().DataField("YEAR_ID").Caption("YEAR_ID").Visible(false).MinWidth(120);
                                columns.Add().DataField("Entry_Type").Caption("Entry_Type").Visible(false).MinWidth(120);
                            })                        
                            .OnContentReady("GoldSilverListGrid_dx_OnContentReady")
                            .MasterDetail(md =>
                            {
                                md.AutoExpandAll(false);
                                md.Enabled(!VouchingMode);
                                md.Template(new JS("GoldSilverListGrid_dx_DetailTemplate"));
                            })      
                             .Summary(s =>
                             {
                                 s.GroupItems(item =>
                                     item.Add()
                                         .Name("Curr_Weight_Curr_Weight_Sum")
                                         .SummaryType(SummaryType.Sum)
                                         .Column("Curr_Weight")
                                         .ShowInGroupFooter(true)
                                         .ShowInColumn("GoldSilverListGrid_dx_Compact_Column")
                                         .DisplayFormat("Total: {0}")
                                         .ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"))
                                 );
                             
                                 s.GroupItems(item =>
                                     item.Add()
                                         .Name("GS_ITEM_WEIGHT_GS_ITEM_WEIGHT_Sum")
                                         .SummaryType(SummaryType.Sum)
                                         .Column("GS_ITEM_WEIGHT")
                                         .ShowInColumn("GoldSilverListGrid_dx_Compact_Column")
                                         .ShowInGroupFooter(true)
                                         .DisplayFormat("Total: {0}")
                                         .ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"))
                                 );
                             })

                    .OnInitialized("GoldSilverListGrid_dx_OnInitialized")
                    .OnCellPrepared("GoldSilverListGrid_dx_OnCellPrepared")
                    .OnRowPrepared("GoldSilverListGrid_dx_OnRowPrepared")
                    .OnCellDblClick("GoldSilverListGrid_dx_OnCellDblClick")
                    .OnSelectionChanged("GoldSilverListGrid_dx_OnSelectionChanged")
                    .OnRowExpanding("GoldSilverListGrid_dx_OnRowExpanding")
                    .OnRowCollapsing("GoldSilverListGrid_dx_OnRowCollapsing")
                    .OnContextMenuPreparing("GoldSilverListGrid_dx_OnContextMenuPreparing")                   
    )