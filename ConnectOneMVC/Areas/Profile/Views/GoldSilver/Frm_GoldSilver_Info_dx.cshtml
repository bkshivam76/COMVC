    IsViewPopup = null;
    GSProfile_SetVouchingModeOn = null;
    UserType_GoldandSPrf = null;
    GoldSilver_IsVouchingMode = null;
    GoldSilver_FocusedRowBeforeRefresh = null;
    GoldS_ViewMode = null;
    GS_ColumnToBeShownIndex = null;
    GS_ColumnToBeHidddenIndex = null;
    GoldSilverID = null;
    GoldSilver_EditDate = null;
    GoldSilver_Add_Date = null;
    GoldSilver_Add_By = null;
    GoldSilver_Edit_By = null;
    GoldSilver_Action_Status = null;
    GoldSilver_Action_Date = null;
    GoldSilver_Action_By = null;
    GoldSilverTr_ID = null;
    GoldSilver_YearID = null;
    GoldSilver_OpenAction = null;
    GoldSilver_EntryType = null;
    GoldSilverInfo_IsDetailRowExpanded = null;
    GoldSilverInfo_NestedRecord_FocusedRowIndex = null;
    GoldSilverInfo_NestedGrid_AccessID = null;
