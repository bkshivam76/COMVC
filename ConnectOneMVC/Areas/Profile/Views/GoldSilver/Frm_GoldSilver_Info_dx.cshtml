      var IsViewPopup = false;
      var GSProfile_SetVouchingModeOn = "@GSProfile_Auto_Vouching_Mode" == "True" ? true : false;
      var UserType_GoldandSPrf = "@UserType".toUpperCase();
      var GoldSilver_IsVouchingMode = false;
      var GoldSilver_FocusedRowBeforeRefresh;
      var GoldS_ViewMode = "Default";


     $(document).ready(function () {

          if ("@GoldS_ExportRight" == "False")
          {
              $("#GoldSilverModelListPreview").hide();
          }

          IsSucessPopup = false;
          IsViewPopup = false;
          //SetGoldSilverGroupPanelFooterVisible();
          //SetGoldSilverFooterVisible();

          $(".GoldSilverListGrid_PreviewRow").hide();
          GetSessionStorage("GoldSilverListGrid");
          if (GSProfile_SetVouchingModeOn == true)
          {
              $("#GoldSViewModeSwitch").dxSwitch("instance").option("value", true);
          }
     });


      $(".TabPanalMenu-tabs .active span").on("click", function () {
          $.ajax({
              type: 'GET',
              url: "/Profile/GoldSilver/SessionClear",
              cache: false
          });
          CloseRightPane();
          ClearLeftPane();
          CloseLeftPane();
          DxGrid_EventsOnScreenClose(GoldSilverListGrid);
          ClearAllReferences_GoldSilverProfile();
      });


