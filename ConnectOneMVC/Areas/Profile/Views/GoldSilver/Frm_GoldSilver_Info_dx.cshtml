        function GoldSilverListGrid_dx_Compact_Column_CellValue(rowData) {
            var data =
                [
                    rowData.ITEM_NAME, rowData.MISC_NAME, rowData.GS_AMT, rowData.Curr_Value, rowData.GS_ITEM_WEIGHT, rowData.Curr_Weight, rowData.Rate_per_Gram, rowData.AL_LOC_NAME, rowData.GS_OTHER_DETAIL, rowData.Sale_Status, rowData.Special_Ref
                ]
            return data.join(" ")
        }
        function GoldSilverListGrid_dx_GroupCell_Template(container, templateData) {
            DxGrid_GroupCell_Template(container, templateData)
        } 

        function LeftPaneContent_GoldSilver(GridName, RecID, vouchingMode, AllColumns = 0) {
            $("#LeftPane_Div_Content").html(null);
            $("#LeftPane_Div_Content").append("<div class='col-xs-12'><label>Documents Attached:</label><div class='AttachmentGrid'><form></form></div></div><div class='col-xs-12'><label>Additional Info:</label><div class='AdditionalInfoGrid'><form></form></div></div>")
            GoldSilverListGrid_dx_Detail($("#LeftPane_Div_Content .AttachmentGrid>form"), GridName, RecID, vouchingMode, AllColumns)
            setTimeout(function () {
                AdditionalInfoGrid_GoldSilver($("#LeftPane_Div_Content .AdditionalInfoGrid>form"), GridName, RecID, vouchingMode, AllColumns)
            })
        }
        function AdditionalInfoGrid_GoldSilver(container, GridName, RecID, vouchingMode, AllColumns)
        {
            var url = "/Profile/GoldSilver/Frm_GoldSilver_AdditionalGridData_dx?VouchingMode=" + vouchingMode + "&RecID=" + RecID
            DxGrid_CreateAdditionalInfoGrid(container, GridName, RecID, vouchingMode, AllColumns, url)           
        }
    </script>
