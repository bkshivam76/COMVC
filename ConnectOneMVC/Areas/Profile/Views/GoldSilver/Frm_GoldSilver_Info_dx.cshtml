    function OnGoldSilverListPreviewClick() {
    if ("@GoldS_ExportRight" == "False") {
        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
        return;
    }

    OpenPopup("GoldSilver_report_modal_result", "Export Option", "/Profile/GoldSilver/Frm_Export_Options_dx/", "auto", "10%", false, false);
    }

    function On_GoldSilverProfile_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@Help_Attachment_AddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (GoldSilverInfo_ParamMandatory == 1)
            {
                AddAttachment(GoldSilverInfo_MasterRowRecID, "Profile_GoldSilver", GoldSilverInfo_Doc_ID, GoldSilverInfo_Doc_Category, GoldSilverInfo_ParamMandatory, GoldSilverInfo_FromDateLabel, GoldSilverInfo_ToDateLabel, GoldSilverInfo_DescriptionLabel, "GoldSilverProfileAttachment", null, "GoldSilverListGrid", GoldSilverInfo_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(GoldSilverInfo_MasterRowRecID, "Profile_GoldSilver", GoldSilverInfo_Doc_ID, "GoldSilverProfileAttachment", "GoldSilverListGrid", GoldSilverInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (GoldSilverInfo_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(GoldSilverInfo_MasterRowRecID, "Profile_GoldSilver", GoldSilverInfo_AtachmentID, GoldSilverInfo_ParamMandatory, GoldSilverInfo_FromDateLabel, GoldSilverInfo_ToDateLabel, GoldSilverInfo_DescriptionLabel, "GoldSilverProfileAttachment", null, "GoldSilverListGrid", GoldSilverInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(GoldSilverInfo_MasterRowRecID, "Profile_GoldSilver", GoldSilverInfo_AtachmentID, GoldSilverInfo_ParamMandatory, GoldSilverInfo_FromDateLabel, GoldSilverInfo_ToDateLabel, GoldSilverInfo_DescriptionLabel, null, "GoldSilverListGrid", GoldSilverInfo_NestedGrid_AccessID, GoldSilverInfo_Attachment_RecStatus);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@Help_Attachment_ViewRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }


            ViewDocument(GoldSilverInfo_AtachmentID, GoldSilverInfo_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(GoldSilverInfo_MasterRowRecID, "Profile_GoldSilver", "Gold/Silver Information", "GoldSilverListGrid", GoldSilverInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Add_Reason")
        {
            if (GoldSilverInfo_Doc_Category.toLowerCase() == "others")
            {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else {
                AttachmentAddReason(GoldSilverInfo_MasterRowRecID, GoldSilverInfo_NestedRowMapID, "Profile_GoldSilver", "GoldSilverListGrid", GoldSilverInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(GoldSilverInfo_MasterRowRecID, GoldSilverInfo_NestedRowMapID, "Profile_GoldSilver", "GoldSilverListGrid", GoldSilverInfo_NestedGrid_AccessID, GoldSilverInfo_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(GoldSilverInfo_MasterRowRecID, GoldSilverInfo_NestedRowMapID, "GoldSilverListGrid", GoldSilverInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
        else if (e.actionName == "AuditAction")
        {
            GoldSilverPrf_FAB.SetActionContext("AuditActionContext", true);
        }
        else if (e.actionName == "BackAudit")
        {
            if (GoldSilverInfo_Nested_Doc_Status == "")
            {
                GoldSilverPrf_FAB.SetActionContext("AutoItemContext", true);
            }
            if (GoldSilverInfo_Nested_Doc_Status == "NO")
            {
                GoldSilverPrf_FAB.SetActionContext("EditItemContext", true);
            }
            if (GoldSilverInfo_Nested_Doc_Status == "YES")
            {
                GoldSilverPrf_FAB.SetActionContext("actionItemContext", true);
            }
        }
        else if (e.actionName == "Accept")
        {
            GoldSilverInfo_AcceptwithoutRemarks();
        }
        else if (e.actionName == "Reject")
        {
            GoldSilverInfo_AcceptRejectVoucher("Reject");
        }
        else if (e.actionName == "AcceptWithRemarks")
        {
            GoldSilverInfo_AcceptRejectVoucher("Accept");
        }
        else if (e.actionName == "AcceptDoc") {

            OnGoldSilverInfo_AcceptDoc();
        }
        else if (e.actionName == "RejectDoc") {

            OnGoldSilverInfo_RejectDoc();
        }
    }

    function closeProfile_GoldSilver() {
        $(".TabPanalMenu-tabs .active span").click();

    }

    function OnGoldSilverInfo_RejectDoc() {
        if (GoldSilverInfo_AtachmentID == null || GoldSilverInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        RejectAttachment(GoldSilverInfo_AtachmentID, "GoldSilverListGrid", GoldSilverInfo_NestedGrid_AccessID);
    }

    function OnGoldSilverInfo_AcceptDoc() {
        if (GoldSilverInfo_AtachmentID == null || GoldSilverInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        AcceptAttachment(GoldSilverInfo_AtachmentID, "GoldSilverListGrid", GoldSilverInfo_NestedGrid_AccessID);
    }

    function GoldSilverInfo_AcceptwithoutRemarks() {
        var Recid;
        if (GoldSilverInfo_IsDetailRowExpanded == true || GoldSilver_IsVouchingMode == true) {
            if (GoldSilverInfo_MasterRowRecID == null || GoldSilverInfo_MasterRowRecID == "") {
                Recid = GoldSilverID;;
            }
            else {
                Recid = GoldSilverInfo_MasterRowRecID;
            }
        }
        else {
            Recid = GoldSilverID;
        }

        Entry_AcceptwithoutRemarks(Recid, "Profile_GoldSilver", "GoldSilverListGrid", GoldSilverInfo_AtachmentID, GoldSilverInfo_NestedRowReasonID, GoldSilverInfo_NestedRowKeyValue);
    }

    function GoldSilverInfo_AcceptRejectVoucher(_actionMethod) {
        var Recid;

        if (GoldSilverInfo_IsDetailRowExpanded == true || GoldSilver_IsVouchingMode == true) {
            if (GoldSilverInfo_MasterRowRecID == null || GoldSilverInfo_MasterRowRecID == "") {
                Recid = ID;
            }
            else {
                Recid = GoldSilverInfo_MasterRowRecID;
            }
        }
        else {
            Recid = ID;
        }
        Entry_AcceptReject(_actionMethod, Recid, "Profile_GoldSilver", "GoldSilverListGrid", GoldSilverInfo_AtachmentID, GoldSilverInfo_NestedRowReasonID, GoldSilverInfo_NestedRowKeyValue);
    }
    </script>

    @*attachment and nested grid*@

    @*DevExtreme Start*@

    <script>
        var GoldSilverListGrid = null;
        var GoldSilverInfo_IsDetailRowExpanded = false;
        var Expanded_Row_Key_GoldSilver = null;
        var VisibleColumns_GoldSilverListGrid = [];
    </script>
    <script>
        function GoldSilverchangeMode() {
            GoldSilverListGrid.beginUpdate();
            if (GS_ShowHorizontalBar == 0) {
                GS_ShowHorizontalBar = 1;
                $("#GoldSilverToggleScrollBar").find("span").text("Default Data");
                $("#GoldSilverToggleScrollBar").width(110);
                GoldSilverListGrid.option("columnHidingEnabled", false);
                GoldSilverListGrid.option("allowColumnResizing", true)
            }
            else {
                GS_ShowHorizontalBar = 0;
                $("#GoldSilverToggleScrollBar").find("span").text("Full Data");
                $("#GoldSilverToggleScrollBar").width(90);
                GoldSilverListGrid.option("columnHidingEnabled", true);
                GoldSilverListGrid.option("allowColumnResizing", false)
            }
            GoldSilverListGrid.endUpdate();
        }

        function GoldSilver_VouchingSwitch_ValueChange(e) {
            GoldSilver_IsVouchingMode = e.value;
            if (GSProfile_SetVouchingModeOn == true) {
                GSProfile_SetVouchingModeOn = false;
            }
            else {
                GoldSilverPrf_FAB.SetVisible(false);
            }
            if (GoldSilver_IsVouchingMode == true) {
                OpenRightPane();
                ClearLeftPane();
                OpenLeftPane();
            }
            else {
                GoldSilverPrf_FAB.SetActionContext("AddAttachmentContext", false);
                CloseRightPane();
                ClearLeftPane();
                CloseLeftPane();
            }
            GoldSilverListGrid.clearSelection();
            GoldSilverListGrid.option("masterDetail.enabled", !GoldSilver_IsVouchingMode)
            GoldSilverListGrid.repaint();
        }

        function GoldS_ViewSwitch_ValueChange(e) {
            GoldS_ViewMode = e.value == false ? "Default" : "Compact";
            if (GSProfile_SetVouchingModeOn == true) {
                $("#GoldSilverVouchingModeSwitch").dxSwitch("instance").option("value", true);
            }
            GoldSilverListGrid.beginUpdate();
            var columns = GoldSilverListGrid.option("columns");
            if (GoldS_ViewMode == "Compact") {
                VisibleColumns_GoldSilverListGrid = [];
                for (var i = 0; i < columns.length; i++) {
                    var name = columns[i].dataField;
                    var ColumnVisible = GoldSilverListGrid.columnOption(name, "visible");
                    if (name == "GoldSilverListGrid_dx_Compact_Column") {
                        GoldSilverListGrid.columnOption(name, "visible", true);
                    }
                    else if (ColumnVisible == true && name != "iIcon") {
                        VisibleColumns_GoldSilverListGrid.push(name);
                        GoldSilverListGrid.columnOption(name, "visible", false);
                    }
                }
            }
            else {
                GoldSilverListGrid.columnOption("GoldSilverListGrid_dx_Compact_Column", "visible", false);
                for (var i = 0; i < VisibleColumns_GoldSilverListGrid.length; i++) {
                    GoldSilverListGrid.columnOption(VisibleColumns_GoldSilverListGrid[i], "visible", true);
                }
            }
            GoldSilverListGrid.repaint();
            GoldSilverListGrid.endUpdate();
        }

        function GoldSilver_UpdateFooterDetail(GoldSilverID, GoldSilver_Action_Status, GoldSilver_Add_Date, GoldSilver_Add_By, GoldSilver_Action_Date, GoldSilver_Action_By, GoldSilver_Edit_Date, GoldSilver_Edit_By) {
            var Status = "";
            var Lbl_Status = "";
            var Lbl_StatusBy = "";
            var Pic_Status = "";
            var Lbl_Create = "";
            var Lbl_Modify = "";
            var Lbl_Status_Color = "";
            var Lbl_ActionOn = "";
            var Lbl_ActionBy = "";

            Status = GoldSilver_Action_Status;

            if (Status && Status.toUpperCase() == "LOCKED") {
                Lbl_Status = "Completed";
                Lbl_Status_Color = "blue";
                Pic_Status = "Fa Fa-Lock";
            }
            else {
                Pic_Status = "Fa Fa-UnLock";
                Lbl_Status = Status;
                if (Status && Status.toUpperCase() == "COMPLETED")
                    Lbl_Status_Color = "green";
                else
                    Lbl_Status_Color = "red";
            }

            if (GoldSilver_Add_Date) {
                Lbl_Create = "Add On: " + GoldSilver_Add_Date + ", By: " + GoldSilver_Add_By;
            }
            else {
                Lbl_Create = "Add On: " + "?, By: " + GoldSilver_Add_By;
            }

            if (GoldSilver_Edit_Date) {
                Lbl_Modify = "Edit On: " + GoldSilver_Edit_Date + ", By: " + GoldSilver_Edit_By;
            }
            else {
                Lbl_Modify = "Edit On: " + "?, By: " + GoldSilver_Edit_By;
            }

            if (GoldSilver_Action_Date) {
                Lbl_ActionOn = "UnLocked On: " + GoldSilver_Action_Date;
            }
            else {
                Lbl_ActionOn = "UnLocked On: " + "?";
            }

            Lbl_ActionBy = "UnLocked By: " + GoldSilver_Action_By;

            $('#GoldSilverLbl_Status').text(Lbl_Status);
            $('#GoldSilverLbl_Create').text(Lbl_Create);
            $('#GoldSilver_Lbl_ActionOn').text(Lbl_ActionOn);
            $('#GoldSilver_Lbl_ActionBy').text(Lbl_ActionBy);
            $('#GoldSilverLbl_Modify').text(Lbl_Modify);

            if (Lbl_Status_Color != "") {
                $('#GoldSilverLbl_Status').css('color', Lbl_Status_Color);
            }

            if (Pic_Status != "") {
                $('#GoldSilver_LockICON').css('class', Pic_Status);
            }
        }

    </script>
    @*Grid Functions*@

    <script>
    function GoldSilverListGrid_dx_OnInitialized(e) {
        DxGrid_AdjustSize(e.component, $("#GoldSilver_ParentDiv .report_button_div"))
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            DxGrid_AdjustSize(e.component, $("#GoldSilver_ParentDiv .report_button_div"), "", evt)
        });
        GoldSilverListGrid = e.component;
    }

    function GoldSilverListGrid_dx_OnCellPrepared(e) {
        if (e.rowType == "data") {
            if (GoldSilver_IsVouchingMode == true) {
                if (e.column.dataField === "iIcon") {
                    $(e.cellElement).attr("onmouseover", "OnGridRowMouseHoverIn(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.key + "')");
                    $(e.cellElement).attr("onmouseout", "OnGridRowMouseHoverOut(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.key + "')");
                }
            }
            $(e.cellElement).attr("id", e.element[0].id + "_Cell_" + e.key + "|" + e.column.dataField);
        }

    }

    function GoldSilverListGrid_dx_OnRowPrepared(e) {
        if (e.rowType == "data") {
            var GridName = e.element[0].id;
            $(e.rowElement).addClass(GridName + "_DataRow_" + e.key)
            if (e.data.RemarkStatus != null && e.data.RemarkStatus == "OPEN" || e.data.RemarkStatus == "REOPENED") {
                $(e.rowElement).css("background-color", "gold");
            }
            if (e.data.RemarkStatus == null && e.data.Remarks != null && e.data.Remarks == true && e.data.CrossedTimeLimit != null && e.data.CrossedTimeLimit == 0) {
                $(e.rowElement).css("background-color", "lightgreen");
            }
            if (e.data.CrossedTimeLimit != null && e.data.CrossedTimeLimit > 0) {
                $(e.rowElement).css("background-color", "mistyrose");
            }
            DxGrid_CreatePreviewRow(e, GoldSilver_IsVouchingMode, "Master")
        }
        else if (e.rowType == "detailAdaptive") {
            DxGrid_MovePreviewRowAfterAdaptiveRow(e)
        }
    }
    function GoldSilverListGrid_dx_OnContentReady(e) {
        DxGrid_OnContentReady(e, GS_ShowHorizontalBar);
        }
        function GoldSilverListGrid_dx_OnCellDblClick(e) {
            if (e.rowType == "data") {
                if (GoldSilver_IsVouchingMode == true && GoldS_ViewMode == "Default") {
                    OnGridCellClick(e.event, e.cellElement[0], e.columnIndex, e.rowIndex, e.element[0].id, e.key, e.column.dataField)
                }
            }
    }
    function GoldSilverListGrid_dx_OnSelectionChanged(e) {
        var selectedRowKeys = e.selectedRowKeys;
        if (selectedRowKeys != null && selectedRowKeys.length > 0) {
            if (GoldSilver_IsVouchingMode) {
                GoldSilverPrf_FAB.SetVisible(true);
                GoldSilverPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
            GoldSilverListGrid_dx_SelectedRowData(e.selectedRowsData);
        }
        else {
            GoldSilverID = null;
            GoldSilver_UpdateFooterDetail(GoldSilverID, GoldSilver_Action_Status, GoldSilver_Add_Date, GoldSilver_Add_By, GoldSilver_Action_Date, GoldSilver_Action_By, GoldSilver_Edit_Date, GoldSilver_Edit_By);
        }
    }
    function GoldSilverListGrid_dx_SelectedRowData(selectedData = null) {
        if (selectedData == null) {
            selectedData = GoldSilverListGrid.getSelectedRowsData();
        }
        if (selectedData != null && selectedData.length > 0) {
            var values = selectedData[0];
            console.table(values);
            GoldSilverID = values["ID"];
            GoldSilver_Edit_Date = values["Edit_Date"];
            GoldSilver_Add_Date = values["Add_Date"];
            GoldSilver_Add_By = values["Add_By"];
            GoldSilver_Edit_By = values["Edit_By"];
            GoldSilver_Action_Status = values["Action_Status"];
            GoldSilver_Action_Date = values["Action_Date"];
            GoldSilver_Action_By = values["Action_By"];
            GoldSilverTr_ID = values["TR_ID"];
            GoldSilver_YearID = values["YearID"];
            GoldSilver_EntryType = values["Entry_Type"];

            if (GoldSilver_IsVouchingMode == true) {
                OpenLeftPane();
                LeftPaneContent_GoldSilver("GoldSilverListGrid", GoldSilverID, GoldSilver_IsVouchingMode, "");
            }
            else {
                GoldSilverID = null;
            }
        }
    }
        function GoldSilverListGrid_dx_OnRowExpanding(e) {

        if (Array.isArray(e.key) == false)
        {
            e.component.collapseRow(Expanded_Row_Key_GoldSilver)
            e.component.selectRows(e.key);
            Expanded_Row_Key_GoldSilver = e.key;
            GoldSilverInfo_IsDetailRowExpanded = true;
            var DetailGridID = e.element[0].id + e.key;
            var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
            if (instance != void 0) {
                instance.state(null)
            }
            //e.component.collapseAll(-1);
            }
        else {
            e.component.option("CustomProp.groupRowExpanded", true);
        }
    }
    function GoldSilverListGrid_dx_OnRowCollapsing(e) {
        if (Array.isArray(e.key) == false) //not group row
        {
            var DetailGridID = e.element[0].id + e.key;
            sessionStorage.removeItem(DetailGridID + "_DetailGridState") //removing grid state from session storage on collapse
            GoldSilverInfo_IsDetailRowExpanded = false;
            e.component.selectRows(e.key);
            if (GoldSilver_IsVouchingMode == false) {
                GoldSilverPrf_FAB.SetVisible(false);
            }
        }
        else {
            e.component.option("CustomProp.groupRowCollapsed", true);
        }
    }
    function GoldSilverListGrid_dx_OnContextMenuPreparing(e) {
        if (!e.items) e.items = [];
        if (e.target == "header") {

            DxGrid_HeaderContextMenu(e, "@GS_SpecialGrouping");
        }
        else if ((e.target == "content" && e.row && e.row.rowType == "groupFooter") || e.target == "footer") {
            if (GoldS_ViewMode == "Compact")
                DxGrid_FooterContextMenu(e, true);
            else
                DxGrid_FooterContextMenu(e);
        }
        else if (e.target == "content" && e.row && (e.row.rowType == "data" || e.row.rowType =="detailAdaptive"))
            {
                var key = e.component.getKeyByRowIndex(e.row.rowIndex);
                e.component.selectRows(key);
                var expanded = e.component.isRowExpanded(key);
                e.items = [
                    {
                        text: "Expand Detail",
                        icon: "fa-solid fa-arrow-down-wide-short " + (expanded ? "text-muted" : "text-info"),
                        disabled: expanded,
                        visible: !GoldSilver_IsVouchingMode,
                        onItemClick: function ()
                        {
                            if (expanded){ }
                            else {e.component.expandRow(key); }
                        }
                    }, {
                        text: "Collapse Detail",
                        icon: "fa-solid fa-arrow-up-wide-short " + (!expanded ? "text-muted" : "text-info"),
                        disabled: !expanded,
                        visible: !GoldSilver_IsVouchingMode,
                        onItemClick: function () {
                            if (expanded) {e.component.collapseRow(key);}
                            else { }
                        }
                    },
                    {
                        text: "Export",
                        icon: "fa-solid fa-file-export text-warning",
                        visible: "@GoldS_ExportRight" == "True",
                        beginGroup: true,
                        onItemClick: function () {
                            OnGoldSilverListPreviewClick();
                        }
                    },
                    {
                        text: "Close",
                        icon: "fa-solid fa-rectangle-xmark text-danger",
                        beginGroup: true,
                        onItemClick: function ()
                        {
                            closeProfile_GoldSilver();
                        }
                    },
                    {
                        text: "Refresh",
                        icon: "fa-solid fa-arrow-rotate-right text-success",
                        beginGroup: true,
                        onItemClick: function ()
                        {
                            GoldSilverListGrid_dx_Refresh()
                        }
                    }]
            }
    }

    function GoldSilverListGrid_dx_DetailTemplate(container, templateData) {
            var GridName = templateData.component.element()[0].id
            var RecID = templateData.data.ID;
        GoldSilverListGrid_dx_Detail(container, GridName, RecID, GoldSilver_IsVouchingMode, GS_ShowHorizontalBar);
    }

        function GoldSilverListGrid_dx_Detail(container, GridName, RecID, vouchingMode, AllColumns)
        {
            var url = "/Profile/GoldSilver/Frm_GoldSilver_Info_DetailGrid_dx?VouchingMode=" + vouchingMode + "&RecID=" + RecID
            var instance = DxGrid_AttachmentGrid_Create(container, GridName, RecID, vouchingMode, AllColumns, url)
            instance.option("onSelectionChanged", GoldSilverListGrid_dx_Detail_onSelectionChanged);    
        }
    function GoldSilverListGrid_dx_Detail_onSelectionChanged(e) {
        if (GoldSilverInfo_IsDetailRowExpanded || GoldSilver_IsVouchingMode) {
            if (e.selectedRowsData != null && e.selectedRowsData.length > 0) {
                GoldSilverInfo_NestedGrid_AccessID = e.element[0].id;
                GoldSilverListGrid_dx_Detail_SelectedRowData(e.selectedRowsData)
            }
            else {
                GoldSilverPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }
    function GoldSilverListGrid_dx_Detail_SelectedRowData(selectedData = null) {
      if (selectedData == null) {
          selectedData = $("#" + GoldSilverInfo_NestedGrid_AccessID).dxDataGrid("getSeletedRowsData");
      }
      var values = selectedData[0];
      GoldSilverInfo_NestedRowKeyValue = values["UniqueID"];
      if (values["UniqueID"] != null) {
          GoldSilverPrf_FAB.SetVisible(true);
          GoldSilverInfo_Nested_Doc_Status = values["Doc_Status"];

          if (GoldSilverPrf_FAB == true) {
              GoldSilverPrf_FAB.SetActionContext("AuditActionContext", true);
          }
          else {
              if (GoldSilverInfo_Nested_Doc_Status == "") {
                  GoldSilverPrf_FAB.SetActionContext("AutoItemContext", true);
              }
              else if (GoldSilverInfo_Nested_Doc_Status == "NO") {
                  GoldSilverPrf_FAB.SetActionContext("EditItemContext", true);
              }
              else if (GoldSilverInfo_Nested_Doc_Status == "YES") {
                  GoldSilverPrf_FAB.SetActionContext("actionItemContext", true);
              }
          }
          GoldSilverInfo_ParamMandatory = values["Params_Mandatory"];
          GoldSilverInfo_FromDateLabel = values["LABEL_FROM_DATE"];
          GoldSilverInfo_ToDateLabel = values["LABEL_TO_DATE"];
          GoldSilverInfo_DescriptionLabel = values["LABEL_DESCRIPTION"];
          GoldSilverInfo_Doc_Category = values["Document_Category"];
          GoldSilverInfo_Doc_ID = values["Document_ID"];
          GoldSilverInfo_AtachmentID = values["ATTACH_ID"];
          IndexAttachmentID = GoldSilverInfo_AtachmentID;
          GoldSilverInfo_MasterRowRecID = values["TxnID"];
          GoldSilverInfo_MasterRowMID = values["TxnMID"];
          GoldSilverInfo_NestedRowMapID = values["MAP_ID"];
          GoldSilverInfo_reason = values["Reason"];
          GoldSilverInfo_FileName = values["ATTACH_FILE_NAME"];
          GoldSilverInfo_Attachment_RecStatus= values["Attachment_Action_Status"];
          if (GoldSilver_IsVouchingMode == true) {
              if (GoldSilverInfo_FileName != null && GoldSilverInfo_FileName.length > 0) {
                  ViewDocument(GoldSilverInfo_AtachmentID, GoldSilverInfo_FileName, "GoldSilverPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
              }
              else {
                  CloseRightPane();
                  ClearRightPane();
              }
          }
    }
    GoldSilverInfo_NestedRowReasonID = values["ReasonID"];
    IndexAttachmentReasonID = GoldSilverInfo_NestedRowReasonID;
    }

    </script>
    @*Grid Methods*@
    <script>
        function GoldSilverListGrid_dx_Refresh() {
            GoldSilverListGrid.refresh().done(function () { ActionAfterDataGridRefresh_GoldSilverListGrid_dx() })
        }

        async function ActionAfterDataGridRefresh_GoldSilverListGrid_dx() {

            var selectedRowKeys = GoldSilverListGrid.getSelectedRowKeys()
            if (selectedRowKeys != null && selectedRowKeys.length > 0) {
                GoldSilverListGrid.clearSelection()
                GoldSilverListGrid.selectRows(selectedRowKeys)
            }
        }

        function GoldSilverListGrid_dx_iIconTemplate(container, templateData) {
            var iREQ_ATTACH_COUNT = templateData.data.REQ_ATTACH_COUNT
            var iCOMPLETE_ATTACH_COUNT = templateData.data.COMPLETE_ATTACH_COUNT
            var iRESPONDED_COUNT = templateData.data.RESPONDED_COUNT
            var iREJECTED_COUNT = templateData.data.REJECTED_COUNT
            var iOTHER_ATTACH_CNT = templateData.data.OTHER_ATTACH_CNT
            var iALL_ATTACH_CNT = templateData.data.ALL_ATTACH_CNT
            var iIcon = templateData.data.iIcon
            var UniqueID = templateData.component.element()[0].id
            var key = templateData.data.ID
            var VisibleIndex = templateData.rowIndex
            var htmlString = "";
            htmlString = DxGrid_AttachmentIcons(iREQ_ATTACH_COUNT, iCOMPLETE_ATTACH_COUNT, iRESPONDED_COUNT, iREJECTED_COUNT, iOTHER_ATTACH_CNT, iALL_ATTACH_CNT);
            htmlString += DxGrid_VouchingAuditIcons(iIcon)
            htmlString += DxGrid_AuditIconAfterClick(UniqueID, key, VisibleIndex)
            $(container).html(htmlString)
        }
