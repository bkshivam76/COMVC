    function ChangeLblWeight(e) {

        var txtweightData = $("#Txt_Weight").dxTextBox('instance').option("value");
        if (txtweightData != "") {
            var kg_part, kg_part = "kg", gm_part = "gm", mg_part = "mg";
            var gm_and_mg = parseFloat(txtweightData).toFixed(3).split('.');//Format(double.Parse($("#Txt_Weight").val()), "0.000").ToString().Split(".");
            if ((parseFloat(gm_and_mg[0]) > 0)) {
                var kg_and_gm = parseFloat(gm_and_mg[0] / 1000).toFixed(3).split('.');
                var gm_part;
                var mg_part;
                if ((parseFloat(kg_and_gm[0]) > 0)) {
                    $("#Txt_Weight_Desc").text(((parseFloat(kg_and_gm[0]))
                                + (kg_part
                                + (((parseFloat(kg_and_gm[1]) > 0) ? (", "
                                + (parseFloat(kg_and_gm[1]) + gm_part)) : "") + ((parseFloat(gm_and_mg[1]) > 0) ? (" & "
                                + (parseFloat(gm_and_mg[1]) + mg_part)) : "")))));
                }
                else {
                    $("#Txt_Weight_Desc").text(((
                        (parseFloat(kg_and_gm[1]) > 0) ? (parseFloat(kg_and_gm[1]) + gm_part) : "") +
                        ((parseFloat(gm_and_mg[1]) > 0) ? (" && " + (parseFloat(gm_and_mg[1]) + mg_part)) : "")));
                }

            }
            else {
                $("#Txt_Weight_Desc").text(parseFloat(gm_and_mg[1]) + (" " + mg_part));
            }
        } else {
            $("#Txt_Weight_Desc").text("");
        }

    }
    function getWeightDesc(e) {
        var txtweightData = $("#Txt_Weight").dxTextBox('instance').option("value");
        if (txtweightData != "") {
            var kg_part, kg_part = "kg", gm_part = "gm", mg_part = "mg";
            var gm_and_mg = parseFloat(txtweightData).toFixed(3).split('.');//Format(double.Parse($("#Txt_Weight").val()), "0.000").ToString().Split(".");
            if ((parseFloat(gm_and_mg[0]) > 0)) {
                var kg_and_gm = parseFloat(gm_and_mg[0] / 1000).toFixed(3).split('.');
                var gm_part;
                var mg_part;
                if ((parseFloat(kg_and_gm[0]) > 0)) {
                    $("#Txt_Weight_Desc").text(((parseFloat(kg_and_gm[0]))
                                + (kg_part
                                + (((parseFloat(kg_and_gm[1]) > 0) ? (", "
                                + (parseFloat(kg_and_gm[1]) + gm_part)) : "") + ((parseFloat(gm_and_mg[1]) > 0) ? (" & "
                                + (parseFloat(gm_and_mg[1]) + mg_part)) : "")))));
                }
                else {
                    $("#Txt_Weight_Desc").text(((
                        (parseFloat(kg_and_gm[1]) > 0) ? (parseFloat(kg_and_gm[1]) + gm_part) : "") +
                        ((parseFloat(gm_and_mg[1]) > 0) ? (" && " + (parseFloat(gm_and_mg[1]) + mg_part)) : "")));
                }

            }
            else {
                $("#Txt_Weight_Desc").text(parseFloat(gm_and_mg[1]) + (" " + mg_part));
            }
        } else {
            $("#Txt_Weight_Desc").text("");
        }
    }
    function OnFrm_GoldSilver_Window_NewLocationClick()
    {
        if ("@GoldS_Profile_Core_AddRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
    }
    function GoldSilverAjaxSuccessForm(data) {
        HideLoader();
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.Message, "Error");
            VehiclesListGrid.Refresh();
        }
        else {
            IsSucessPopup = true;
            var GoldSilverSubmitSuccess = DevExpress.ui.dialog.alert(data.Message, "GoldSilver");

            GoldSilverListGrid.Refresh();
            IsSucessPopup = false;
            GoldSilverSubmitSuccess.done(function (alertResult) {
                if (alertResult) {
                    if (IsViewPopup == true) {
                        var addmoreGSresult = DevExpress.ui.dialog.confirm("Add More Entry...?", "Vehicle");
                        addmoreGSresult.done(function (dialogResult) {
                            if (dialogResult) {
                                OnGoldSilverNewClick();
                            }
                        });
                    }
                }
            });
            $("#Dynamic_Content_popup").dxPopup("hide");
        }
    }
