    </script>
    <div id="GoldSilverWindow" class="col-md-12" style="padding:0px;">
        @using (Ajax.BeginForm("Frm_GoldSilver_window", "GoldSilver",
                                                                     new AjaxOptions
                                                                     {
                                                                         HttpMethod = "POST",
                                                                         UpdateTargetId = "GoldSilverWindow",
                                                                         InsertionMode = InsertionMode.InsertAfter,
                                                                         OnBegin = "AjaxBeginFormPost",
                                                                         OnSuccess = "GoldSilverAjaxSuccessForm"
                                                                     },
                                                                         new
                                                                         {
                                                                             id = "validationForm",
                                                                             @class = "edit_form"
                                                                         }))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(x => x.TempActionMethod)
            @Html.HiddenFor(x => x.EditDate)
            @Html.HiddenFor(x => x.ActionMethod)
            @Html.HiddenFor(x => x.ID)
            @Html.HiddenFor(x => x.LastEditedOn)
            var errors = ViewData.ModelState.Where(n => n.Value.Errors.Count > 0).Select(c => c.Value.Errors).ToList();

            using (Html.DevExtreme().ValidationGroup())
            {

                <div class="full-width-header-bg">
                    <div class="row">

                        <div class="col-sm-8 pll">
                            <h3 class="popuphead"><i class="far fa-edit"></i> Gold / Silver</h3><i class="fas fa-star yellowstar"></i><span class="blu-txt2"> As on 31st March, 2017</span>
                        </div>
                        <div class="col-sm-4 prm">
                            <h5 class="mand-txt-align"><i class="fas fa-info-circle"></i> Red Fields are mandatory</h5>
                        </div>
                        @Html.ValidationSummary(true, "", new { @class = "text-red" })
                    </div>
                </div><!--[]-->



                <div class="row">
                    <div class="col-sm-2">
                        <div class="form-field">
                            <div class="container-fluid pll prm">
                                @Html.LabelFor(model => model.GS_TYPE, htmlAttributes: new { @class = "control-label text-red txt_type" })
                                @(Html.DevExtreme().SelectBoxFor(x => x.GS_TYPE)
                                    .ID("GS_TYPE")
                                    .Name("GS_TYPE")
                                    .DataSource(new[] { "GOLD", "SILVER" })
                                    .Value(Model.GS_TYPE)
                                     .ReadOnly(false || Model.ActionMethod == Common_Lib.Common.Navigation_Mode._View || Model.ActionMethod == Common_Lib.Common.Navigation_Mode._Delete)
                                    .SearchEnabled(true)
                                     .DeferRendering(false)
                                    .OnValueChanged(@<text>function () {ChangeGSType();}</text>)
                            )
                                @Html.ValidationMessageFor(model => model.GS_TYPE, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-7">
                        <div class="form-field">
                            <div class="container-fluid pll prm">
                                @Html.LabelFor(model => model.Look_ItemList, htmlAttributes: new { @class = "control-label text-red txt_item" })
                                @(Html.DevExtreme().DropDownBox()
                                    .ID("Look_ItemList")
                                    .Name("Look_ItemList")
                                    .Value(Model.Look_ItemList)
                                    .ValueExpr("ID")
                                    .DisplayExpr("Name")
                                    .DropDownOptions(ddo => ddo.Width(650))
                                    .DataSource(d => d.Mvc().Controller("GoldSilver").LoadAction("LookUp_GetItemList").Key("ID").LoadParams(new { Cmd_Type = new JS("function(){return Cmd_Type;}") }))
                                    .Placeholder("Select Item...")
                                    .ShowClearButton(true)
                                      .ReadOnly(false || Model.ActionMethod == Common_Lib.Common.Navigation_Mode._View || Model.ActionMethod == Common_Lib.Common.Navigation_Mode._Delete)
                                    .OnValueChanged("ChangeLookUp_GetItemList")
                                    .DeferRendering(false)
                                    .ContentTemplate(@<text>
                                        @Html.Partial("LookUp_GetItemList")
                                    </text>)
                            )
                                @Html.ValidationMessageFor(model => model.Look_ItemList, "", new { @class = "text-red" })
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-3">
                        <div class="form-field">
                            <div class="container-fluid pll prm">
                                @Html.LabelFor(model => model.Look_MiscList, htmlAttributes: new { @class = "control-label text-red txt_Misc" })
                                @(Html.DevExtreme().DropDownBox()
                                    .ID("Look_MiscList")
                                    .Name("Look_MiscList")
                                    .Value(Model.Look_MiscList)
                                    .ValueExpr("ID")
                                    .DisplayExpr("Name")
                                    .DropDownOptions(ddo => ddo.Width(650))
