                                <div class="row">
                                    <div class="col-sm-6">
                                        @Html.LabelFor(model => model.Txt_Weight, htmlAttributes: new { @class = "control-label text-red txt_weight" })
                                    </div>
                                    <div class="col-sm-6">
                                        @if (Model.ActionMethod.ToString().Trim() == "_New")
                                        {
                                            @(Html.DevExtreme().TextBox()
                        .ID("Txt_Weight")
                        .Name("Txt_Weight")
                        .Value(Model.Txt_Weight)
                        .ShowClearButton(true)
