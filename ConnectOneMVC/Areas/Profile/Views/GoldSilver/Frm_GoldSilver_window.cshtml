                        <div class="form-field">
                            <div class="container-fluid pll prm">
                                <div class="row">
                                    <div class="col-sm-5">
                                        @Html.LabelFor(model => model.Txt_Amount, htmlAttributes: new { @class = "control-label" })
                                    </div>
                                    <div class="col-sm-7 plm">
                                        @(Html.DevExtreme().TextBox()
                                            .ID("Txt_Amount")
                                            .Name("Txt_Amount")
                                            .Value(Model.Txt_Amount)
