                        .Placeholder("Type Weight...")
                        .OnValueChanged("ChangeLblWeight")
                                        )
                                        }
                                        @if (Model.ActionMethod.ToString().Trim() == "_Edit" || Model.ActionMethod.ToString().Trim() == "_View")
                                        {@(Html.DevExtreme().TextBox()
                        .ID("Txt_Weight")
                        .Name("Txt_Weight")
                        .Value(Model.Txt_Weight)
                        .ShowClearButton(true)
                         .ReadOnly(false || Model.ActionMethod == Common_Lib.Common.Navigation_Mode._View || Model.ActionMethod == Common_Lib.Common.Navigation_Mode._Delete)
                        .Placeholder("Type Weight...")
                        .OnValueChanged("ChangeLblWeight")
                        .OnInitialized("getWeightDesc")
                    )
                                        }
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                    <div class="col-sm-3 plm">
                        <div class="bot-shadow pll">
                            <label class="control-label" for="Txt_Weight_Desc" id="Txt_Weight_Desc" name="Txt_Weight_Desc" text="" value=""></label>
                        </div>
                    </div>
                </div>
                <div class="row">

                    <div class="col-sm-9">
                        <div class="form-field">
                            <div class="container-fluid pll prm">
                                <div class="row">
                                    <div class="col-sm-2">
                                        @Html.LabelFor(model => model.GS_LOC_AL_ID, htmlAttributes: new { @class = "control-label text-red txt_loc" })
                                    </div>
                                    <div class="col-sm-10">
                                        <div class="ext-marg-30">
                                            @(Html.DevExtreme().DropDownBox()
                                    .ID("GS_LOC_AL_ID")
                                    .Name("GS_LOC_AL_ID")
                                    .Value(Model.GS_LOC_AL_ID)
                                    .ValueExpr("AL_ID")
                                    .DisplayExpr("Location_Name")
                                    .DropDownOptions(ddo => ddo.Width(650))
                                    .DataSource(d => d.Mvc().Controller("GoldSilver").LoadAction("LookUp_GetLocList").Key("AL_ID"))
                                    .Placeholder("Select Location...")
                                    .ShowClearButton(true)
                                    .OnValueChanged("ChangeLookUp_GetLocList")
                                      .ReadOnly(false || Model.ActionMethod == Common_Lib.Common.Navigation_Mode._View || Model.ActionMethod == Common_Lib.Common.Navigation_Mode._Delete)
                                    .ContentTemplate(@<text>
                                        @Html.Partial("LookUp_GetLocList")
                                    </text>)
                                        )

                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-3">
                        <div class="form-field" style="padding:3px 4px 2px 4px;">
                            <div class="container-fluid pll prm">
                                @(Html.DevExtreme().Button()
                                    .ID("But_Loc")
                                    .Text("Add Location")
                                    .Icon("add")
                                    .Width(380)
                                      .Disabled(false || Model.ActionMethod == Common_Lib.Common.Navigation_Mode._View || Model.ActionMethod == Common_Lib.Common.Navigation_Mode._Delete)
                                    .OnClick(@<text>
                                        function () {
                                        OnFrm_GoldSilver_Window_NewLocationClick();
                                        }
                                    </text>)
                            )
                            </div>
                        </div>
                    </div>

                </div>

                <div class="row">
                    <div class="form-field">
                        <div class="container-fluid pll prm">
                            <div class="col-sm-2">
                                @Html.LabelFor(model => model.Txt_Others, htmlAttributes: new { @class = "control-label text-danger" })
                            </div>

                            <div class="col-sm-10">

                                @(Html.DevExtreme().TextBox()
                                        .ID("Txt_Others")
                                        .Name("Txt_Others")
                                        .Value(Model.Txt_Others)
                                        .ShowClearButton(true)
                                          .ReadOnly(false || Model.ActionMethod == Common_Lib.Common.Navigation_Mode._View || Model.ActionMethod == Common_Lib.Common.Navigation_Mode._Delete)
                                        .Placeholder("Type Any Other Details / Remarks...")
                                        .MaxLength(250)
                            )
                            </div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="form-field wbg brd-bot-none">
                        <div class="container-fluid pll prm">
                            <div class="col-sm-8 prm"></div>
                            <div class="col-sm-4 prm">
                                @if (Model.ActionMethod.ToString().Trim() == "_New")
                                {

                                    <div class="action-btn-wrap">
                                        @(Html.DevExtreme().Button()
                                .ID("GSCancel")
                                .Icon("fa fa-times")
                                .Text("Cancel")
                                .FocusStateEnabled(true)
                                .OnClick(@<text>
                                    function () {
                                    $("#Dynamic_Content_popup").dxPopup("hide");
                                    }
                                </text>)
                                            )
                                    </div>
                                    <div class="action-btn-sec-wrap">
                                        @(Html.DevExtreme().Button()
                                    .Icon("fa fa-check")
                                .Text("Save")
                                 .UseSubmitBehavior(true)
                                            )
                                    </div>

                                }
                                @if (Model.ActionMethod.ToString().Trim() == "_View")
                                {
                                    <div class="col-md-7"></div>
                                    <div class="col-md-5">
                                        @(Html.DevExtreme().Button()
                                    .ID("GSCancel")
                                    .Text("Close")
                                    .Icon("fa fa-times")
                                    .OnClick(@<text>
                                        function () {
                                        $("#Dynamic_Content_popup").dxPopup("hide");
                                        }
                                    </text>)
                                            )
                                    </div>
                                }
                                @if (Model.ActionMethod.ToString().Trim() == "_Edit")
                                {
                                    <div>
                                        @(Html.DevExtreme().Button()
                                .ID("GSEdit")
                                .Text("Save")
                                .Icon("fa fa-check")
                                .FocusStateEnabled(true)
                                .UseSubmitBehavior(true)
                                            )
                                        @(Html.DevExtreme().Button()
                                .ID("GSCancel")
                                .Icon("fa fa-times")
                                .Text("Cancel")
                                .OnClick(@<text>
                                    function () {
                                    $("#Dynamic_Content_popup").dxPopup("hide");
                                    }
                                </text>)
                                            )
                                    </div>
                                }

                                @if (Model.ActionMethod.ToString().Trim() == "_Delete")
                                {
                                    <div>
                                        @(Html.DevExtreme().Button()
                                .ID("GSDelete")
                                .Text("Delete")

                                .FocusStateEnabled(true)

                                .UseSubmitBehavior(true)
                                            )
                                        @(Html.DevExtreme().Button()
                                .ID("GSCancel")
                                  .Icon("fa fa-times")
                                .Text("Cancel")
                                .FocusStateEnabled(true)
                                .OnClick(@<text>
                                    function () {
                                    $("#Dynamic_Content_popup").dxPopup("hide");
                                    }
                                </text>)
                                            )
                                    </div>
                                }


                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>


    <script>
    $(document).ready(function () {
        if ("@GoldS_Profile_Core_AddRight" == "False")
        {
	        $("#But_Loc").hide();
        }
    });
    $(function () {
        if ("@Model.ActionMethod.ToString().Trim()" == "_View" || "@Model.ActionMethod.ToString().Trim()" == "_Delete") {
            $(".txt_type").removeClass("text-red");
            $(".txt_item").removeClass("text-red");
            $(".txt_Misc").removeClass("text-red");
            $(".txt_weight").removeClass("text-red");
            $(".txt_loc").removeClass("text-red");

        }
        $("#Txt_Weight").keypress(function (e) {
            e = e || window.event;
            key = e.keyCode || e.which;
            //For Firefox
            if (key == 8 || key == 127 || key == 9)
                return true
            var txt = String.fromCharCode(key);
            var reg = /[0-9-/]/;
            if (reg.test(txt))
                return true;

            e.preventDefault();
            return false;


        });
        $("#Txt_Amount").keypress(function (e) {
            e = e || window.event;
            key = e.keyCode || e.which;
            //For Firefox
            if (key == 8 || key == 127 || key == 9)
                return true
            var txt = String.fromCharCode(key);
            var reg = /[0-9.]/;
            if (reg.test(txt))
                return true;
            e.preventDefault();
            return false;

        });

    });
    </script>
</div>