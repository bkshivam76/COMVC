<div class="GoldSilver_WindowProfile_ClearReferences">

    @using DevExtreme.AspNet.Mvc;
    @model ConnectOneMVC.Areas.Profile.Models.GoldSilverDto
    <link href="/content/fontawesome/css/fontawesome-all.css" rel="stylesheet">

    @{
