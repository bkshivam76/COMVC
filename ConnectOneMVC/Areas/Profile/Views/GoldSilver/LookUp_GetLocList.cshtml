@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid()
    .ID("GoldSilverLocation-datagrid")
    .DataSource(new JS(@"component.option(""dataSource"")"))
    .Columns(columns =>
    {
        columns.Add().DataField("Location_Name").Caption("Location Name").Width(250);
        columns.Add().DataField("Matched_Type").Caption("Matched Type").Width(200);
        columns.Add().DataField("Matched_Name").Caption("Matched Name").Width(200);
        columns.Add().DataField("Matched_Instt").Caption("Matche Instt").Width(200);
        columns.Add().DataField("Final_Amount").Caption("Final Amount").Width(200);

    })
    .HoverStateEnabled(true)
    .Paging(p => p.PageSize(10))
    .FilterRow(f => f.Visible(true))
    .ColumnAutoWidth(true)
    .Scrolling(s => s.Mode(GridScrollingMode.Infinite))
    .Height(265)
    .Selection(s => s.Mode(SelectionMode.Single))
    .OnSelectionChanged(@<text>
        function(selectedItems) {
        var keys = selectedItems.selectedRowKeys;
        component.option("value", keys);
        }
    </text>)
)
