@using DevExtreme.AspNet.Mvc;

@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;
    string ViewMode = ViewBag.ViewMode == null ? "Default" : (string)ViewBag.ViewMode;
    int ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;
}

@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar)
                           .ID("LiabilitiesListGrid")
                           .DataSource(d => d.Mvc()
                           .Controller("Liabilities")
                           .LoadAction("Frm_Liabilities_Info_Grid_dx")
                           .LoadMode(DataSourceLoadMode.Raw).Key("ID")).Columns(columns=>{
                               columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);
                               columns.Add().DataField("iIcon").Name("iIcon").Caption("").CellTemplate(new JS("LiabilitiesListGrid_dx_iIconTemplate")).Width(30).HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource")).RenderAsync(true);
                               columns.Add().DataField("LiabilitiesListGrid_dx_Compact_Column").Name("LiabilitiesListGrid_dx_Compact_Column").Caption("").Visible(false).CellTemplate(new JS("LiabilitiesListGrid_dx_Compact_Column_Template"))
                               .CalculateCellValue("LiabilitiesListGrid_dx_Compact_Column_CellValue").Width("100%").RenderAsync(true).ShowInColumnChooser(false);
                               columns.Add().DataField("ITEM_NAME").Caption("Item Name").Width(160);
                               columns.Add().DataField("PARTY_NAME").Caption("Party Name").Width(200);
                               columns.Add().DataField("LI_DATE").Caption("Date").DataType(GridColumnDataType.Date).Format("dd-MM-yyyy").Width(150);
                               columns.Add().DataField("LI_PAY_DATE").Caption("Payable Date").DataType(GridColumnDataType.Date).Format("dd-MM-yyyy").Width(180);
                               columns.Add().DataField("Amount").Caption("Amount").Width(150);
                               columns.Add().DataField("Addition").Caption("Addition").Width(150);
                               columns.Add().DataField("Adjusted").Caption("Adjusted").Width(150);
                               columns.Add().DataField("Paid").Caption("Paid").Width(150);
                               columns.Add().DataField("Out_Standing").Caption("Out-Standing").Width(170);
                               columns.Add().DataField("Reason").Caption("Reason").Width(200);
                               columns.Add().DataField("LI_OTHER_DETAIL").Caption("Other Detail").Width(200);
                               columns.Add().DataField("Special_Ref").Caption("Reference").Width(200);
                               columns.Add().DataField("Type").Caption("Type").Width(180);
                               columns.Add().DataField("RemarkCount").Caption("Remark Count").Width(180);
                               columns.Add().DataField("Action_By").Caption("Action By").Visible(false);
                               columns.Add().DataField("Action_Date").Caption("Action Date").Visible(false);
                               columns.Add().DataField("Add_By").Caption("Add By").Visible(false);
                               columns.Add().DataField("Add_Date").Caption("Add Date").Visible(false);
                               columns.Add().DataField("CrossedTimeLimit").Caption("Crossed Time Limit").Visible(false);
                               columns.Add().DataField("Edit_By").Caption("Edit By").Visible(false);
                               columns.Add().DataField("Edit_Date").Caption("Edit Date").Visible(false);
                               columns.Add().DataField("ID").Caption("ID").Visible(false);
                               columns.Add().DataField("OpenActions").Caption("Open Actions").Visible(false);
                               columns.Add().DataField("RemarkStatus").Caption("Remark Status").Visible(false);
                               columns.Add().DataField("Remarks").Caption("Remarks").Visible(false);
                               columns.Add().DataField("TR_ID").Caption("Tr. ID").Visible(false);
                               columns.Add().DataField("YEAR_ID").Caption("Year ID").Visible(false);
                               columns.Add().DataField("REJECTED_COUNT").Caption("Rejected Count").Visible(false);
                               columns.Add().DataField("RESPONDED_COUNT").Caption("Responded Count").Visible(false);
                               columns.Add().DataField("COMPLETE_ATTACH_COUNT").Caption("Complete Attach Count").Visible(false);
                               columns.Add().DataField("REQ_ATTACH_COUNT").Caption("Required Attach Count").Visible(false);
                               columns.Add().DataField("OTHER_ATTACH_CNT").Caption("Other Attach Count").Visible(false);
                               columns.Add().DataField("ALL_ATTACH_CNT").Caption("All Attach Count").Visible(false);

                           })                        
                            .MasterDetail(md =>
                            {
                                md.AutoExpandAll(false);
                                md.Enabled(true);
                                md.Template(new JS("LiabilitiesListGrid_dx_DetailTemplate"));
                            })
                            .OnInitialized("LiabilitiesListGrid_dx_OnInitialized")
                            .OnCellPrepared("LiabilitiesListGrid_dx_OnCellPrepared")
                            .OnRowPrepared("LiabilitiesListGrid_dx_OnRowPrepared")
                            .OnContentReady("LiabilitiesListGrid_dx_OnContentReady")
                            .OnCellDblClick("LiabilitiesListGrid_dx_OnCellDblClick")
                            .OnSelectionChanged("LiabilitiesListGrid_dx_OnSelectionChanged")
                            .OnRowExpanding("LiabilitiesListGrid_dx_OnRowExpanding")
                            .OnRowCollapsing("LiabilitiesListGrid_dx_OnRowCollapsing")
                            .OnContextMenuPreparing("LiabilitiesListGrid_dx_OnContextMenuPreparing")                         
)