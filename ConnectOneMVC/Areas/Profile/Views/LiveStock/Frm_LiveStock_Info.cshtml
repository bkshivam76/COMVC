	                $("#LiveStockModelView").hide();
                }
                if ("@LiveStock_DeleteRight" == "False")
                {
	                $("#LiveStockModelDelete").hide();
                }
                if ("@LiveStock_ExportRight" == "False")
                {
	                $("#LiveStockModelListPreview").hide();
                }
                if ("@LiveStock_LockUnlockRight" == "False")
                {
	                $("#LiveStockModelUnlock").hide();
