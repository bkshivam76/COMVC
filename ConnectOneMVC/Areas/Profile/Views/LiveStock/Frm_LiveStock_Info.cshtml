<div class="LiveStockProfile_ClearReferences">
    @using DevExtreme.AspNet.Mvc;

    @model IEnumerable<dynamic>
    @{
        ViewBag.Title = "Index";
        Layout = null;
        string UserType = (string)ViewBag.UserType;
        bool LiveStock_AddRight = (bool)ViewData["LiveStock_AddRight"];
        bool LiveStock_UpdateRight = (bool)ViewData["LiveStock_UpdateRight"];
        bool LiveStock_ViewRight = (bool)ViewData["LiveStock_ViewRight"];
        bool LiveStock_DeleteRight = (bool)ViewData["LiveStock_DeleteRight"];
        bool LiveStock_ExportRight = (bool)ViewData["LiveStock_ExportRight"];
        bool LiveStock_LockUnlockRight = (bool)ViewData["LiveStock_LockUnlockRight"];

        bool Help_Attachment_AddRight = (bool)ViewData["Help_Attachment_AddRight"];//attachment
        bool Help_Attachment_EditRight = (bool)ViewData["Help_Attachment_EditRight"];//attachment
        bool Help_Attachment_ViewRight = (bool)ViewData["Help_Attachment_ViewRight"];//attachment
        bool Help_Attachment_DeleteRight = (bool)ViewData["Help_Attachment_DeleteRight"];//attachment
        bool LiveStock_Auto_Vouching_Mode = (bool)ViewData["LiveStock_Auto_Vouching_Mode"];
    }
    <div id="LiveStockProfile_ParentDiv">
        <div id="content" class="col-md-12 report_header_div_main">
            <div class="col-md-4 report_header_div">
                <label class="report_header_label">LiveStock Information</label>
            </div>
            @*Buttons*@
            <div class="report_button_div">
                @(Html.DevExtreme().Switch().ID("LiveStockVouchingModeSwitch").SwitchedOnText("Vouching On").SwitchedOffText("Vouching Off").OnValueChanged("LiveStock_VouchingSwitch_ValueChange").Width(100).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
                @(Html.DevExtreme().Switch().ID("LiveStockViewModeSwitch").SwitchedOnText("Compact").SwitchedOffText("Default").OnValueChanged("LiveStock_ViewSwitch_ValueChange").Width(70).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
                @(Html.DevExtreme().Button()
                                                                                                                    .ID("LiveStockModelUnlock")
                                                                                                                    .Text("Unlock")
                                                                                                                    .Icon("add")
                                                                                                                    .Visible(false)
                                                                                                                    .Disabled(true)
                                                                                                                    .OnClick(@<text>
                                                                                                                        function () {LiveStockOnUnlockClick();}
                                                                                                                    </text>)
            )
                @(Html.DevExtreme().Button()
                                                                                                                    .ID("LiveStockModelLock")
                                                                                                                    .Text("Lock")
                                                                                                                    .Icon("add")
                                                                                                                    .Visible(false)
                                                                                                                    .Disabled(true)
                                                                                                                    .OnClick(@<text>
                                                                                                                        function () {LiveStockOnLockClick();}
                                                                                                                    </text>))
                @(Html.DevExtreme().Button()
                                                                                                                    .ID("LiveStockModelNew")
                                                                                                                    .Text("New")
                                                                                                                    .Icon("add")
                                                                                                                    .Visible(false)
                                                                                                                    .Disabled(true)
                                                                                                                   .OnClick(@<text>
                                                                                                                    function () {OnLiveStockNewClick();}
                                                                                                                </text>)
            )
                @(Html.DevExtreme().Button()
                                                                                                                    .ID("LiveStockModelEdit")
                                                                                                                    .Text("Edit")
                                                                                                                     .Icon("edit")
                                                                                                                     .Visible(false)
                                                                                                                     .Disabled(true)
                                                                                                                     .OnClick(@<text>
                                                                                                                        function () {OnLiveStockEditClick();}
                                                                                                                    </text>)
            )
                @(Html.DevExtreme().Button()
                                                                                                                    .ID("LiveStockModelDelete")
                                                                                                                    .Text("Delete")
                                                                                                                    .Icon("trash")
                                                                                                                    .Visible(false)
                                                                                                                    .Disabled(true)
                                                                                                                    .OnClick(@<text>
                                                                                                                        function () {OnLiveStockDeleteClick();}
                                                                                                                    </text>)
            )
                @(Html.DevExtreme().Button()
                                                                                                                    .ID("LiveStockModelView")
                                                                                                                    .Text("View")
                                                                                                                    .Icon(IconID.ViewCustomers16x16devav)
                                                                                                                    .Icon("doc")
                                                                                                                    .Visible(false)
                                                                                                                    .Disabled(true)
                                                                                                                    .OnClick(@<text>
                                                                                                                        function () {OnLiveStockViewClick();}
                                                                                                                    </text>)
            )
                @(Html.DevExtreme().Button()
                                                                                                                    .ID("LivestockToggleScrollBar")
                                                                                                                    .Text(ViewBag.ShowHorizontalBar == 1 ? "Default Data" : "Full Data")
                                                                                                                    .Width(ViewBag.ShowHorizontalBar == 1 ? 110 : 90)
                                                                                                                    .Icon("toolbox")
                                                                                                                    .OnClick(@<text>
                                                                                                                        function () {LivestockchangeMode();}
                                                                                                                    </text>)
            )
                @(Html.DevExtreme().Button()
                                                                                                                    .ID("LiveStockModelListPreview")
                                                                                                                    .Text("Export")
                                                                                                                    .Icon("save")
                                                                                                                    .Width(80)
                                                                                                                    .OnClick(@<text>
                                                                                                                        function () {OnLiveStockListPreviewClick();}
                                                                                                                    </text>)
            )
                @(Html.DevExtreme().Button()
                                                                                                                    .ID("LiveStockModelCLOSE")
                                                                                                                    .Text("Close")
                                                                                                                    .Icon("clear")
                                                                                                                    .OnClick(@<text>
                                                                                                                        function () {closeProfile_Livestock()
                                                                                                                        }
                                                                                                                    </text>)

            )
            </div>
        </div>
        <div class="col-md-12 no-padding">
            <form>
                <div id="LiveStockreloadPartialView">
                    @Html.Partial("Frm_LiveStock_Info_Grid", Model)
                </div>
            </form>
        </div>

        <div class="footer-MainBoxdiv full-width-footer">
            @*<div class="col-lg-8 report_footer_small_buttons_div" id="LivestockFooterItem">*@
            <div class="list_footer_left_margin col-md-10">
                <div>
                    @*class="footer_new_left"*@
                    <div>
                        <div class="list_footer_left_margin">
                            <div class="footer-locktext">
                                <div id="Livestock_Lbl_ActionOn" class="left_footertext_top"></div>
                                <div id="Livestock_Lbl_ActionBy" class="left_footertext_bottom"></div>
                            </div>
                            @*<div class="footer-locktext">
                                    <div id="LivestockLbl_Status" style="font-size:23px" class="left_footertext_top"></div>
                                </div>*@
                        </div>
                        <div class="list_footer_left_margin">
                            <p id="LivestockLbl_Create" style="margin:0px" class="left_footertext_top"></p>
                            <p id="LivestockLbl_Modify" style="margin:0px" class="left_footertext_bottom"></p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="list_footer_right_margin_consistent col-md-1">
                @*<i id="Livestock_LockICON" class="fa fa-lock lock_symbol"></i>*@
            </div>
            @*</div>
                <div class="col-lg-4 listing_footer_filter_buttons_div">
                </div>*@
        </div>

        @Html.Partial("AttachmentFAB", "LiveStockPrf_FAB,LiveStockProfile_grid_DIV,Type1,LiveStockProfile," + UserType) @*fab buttons*@

        <div class="col-md-12">
            @*Add/Edit Popup*@
            @(Html.DevExtreme().Popup().CustomPopup()
                                            .ID("LiveStock_report_modal")
                                            .OnShowing("PopupOnShowing")
                                            .Title("LiveStock List Preview")
                                            .FullScreen(false)
                                            .MaxWidth(125)
                                            .Height("auto")
                                            .ShowCloseButton(true)
                                            .ContentTemplate(@<text>
                                                <div id='LiveStock_report_modal_result'>
                                                </div>
                                            </text>)
        )
            @(Html.DevExtreme().Popup().CustomPopup()
                                            .ID("popup_frm_LiveStock_Window")
                                            .Title("LiveStock")
                                            .OnShowing("PopupOnShowing")
                                            .ShowCloseButton(true)
                                            .ContentTemplate(@<text>
                                                <div id="LiveStockresult">
                                                </div>
                                            </text>)
                                                        .OnHiding(@<text>
                                                            function () {
                                                            if(IsLiveStockSucessPopup == false && IsLiveStockViewPopup == false)
                                                            {
                                                            var result = DevExpress.ui.dialog.confirm("Are you sure to cancel this entry...?", "Confirm changes");
                                                            result.done(function (dialogResult) {
                                                            if(dialogResult){
                                                            $("#popup_frm_LiveStock_Window").dxPopup("hide");
                                                            }else
                                                            {
                                                            $("#popup_frm_LiveStock_Window").dxPopup("show");
                                                            }
                                                            });
                                                            }
                                                            }
                                                        </text>)
        )
