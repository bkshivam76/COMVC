            LiveStock_LS_INS_POLICY_NO = null;
            LiveStock_LS_INS_DATE = null;
            LiveStock_LS_INS_AMT = null;
            LiveStock_AL_LOC_NAME = null;
            LiveStock_LS_OTHER_DETAIL = null;
            LiveStock_SaleStatus = null;
