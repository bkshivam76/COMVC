    function LivestockOnInit(s, e)
    {
                LivestockAdjustSize();
                ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                    LivestockAdjustSize();
                });
    }
    function OnLiveStockCellClick(event, cell,col, row)
    {
        if (UserType_LiveStockPrf == "AUDITOR" || UserType_LiveStockPrf == "SUPERUSER")
        {
            if (event.button == 0)
            {
                if (cell.style.backgroundColor.length > 0)
                {
                    cell.style.backgroundColor = "";
                }
                else
                {
                    cell.style.backgroundColor = 'skyblue';
                }
            }
        }
    }
    function LiveStock_ViewSwitch_ValueChange(e)
    {
        LiveStock_ViewMode = e.value == false ? "Default" : "Compact";
        if (LiveStock_SetVouchingModeOn == true)
        {
            $("#LiveStockVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }
        else
        {
            LiveStockListGrid.CollapseAllDetailRows();
        }
    }

    function LiveStock_VouchingSwitch_ValueChange(e)
    {
        LiveStock_IsVouchingMode = e.value;
        LiveStockListGrid.SetFocusedRowIndex(-1);
        LiveStockPrf_FAB.SetVisible(false);
        if (LiveStock_IsVouchingMode == true) {
            OpenRightPane();
            ClearLeftPane();
            OpenLeftPane();
        }
        else {
            LiveStockPrf_FAB.SetActionContext("AddAttachmentContext", false);
            CloseRightPane();
            ClearLeftPane();
            CloseLeftPane();
        }
        LiveStockListGrid_CollapseAllDetailRows();
    }
    function LiveStockListGrid_CollapseAllDetailRows()
    {
        if (typeof window !== 'undefined')
        {
            if (typeof window.LiveStockListGrid !== 'undefined')
            {
                if (typeof window.LiveStockListGrid.CollapseAllDetailRows !== 'undefined')
                {
                    if (typeof LiveStockListGrid.CollapseAllDetailRows == 'function')
                    {
                        LiveStockListGrid.SetFocusedRowIndex(-1);
                        LiveStockListGrid.CollapseAllDetailRows();
                    }
                    else
                    {
                        alert("CollapseAllDetailRows is not a function");
                    }
                }
                else {
                    ShowLoader();
                    setTimeout(function ()
                    {
                        LiveStockListGrid_CollapseAllDetailRows();
                        HideLoader();
                    }, Timeout100);
                }
            }
            else
            {
                alert('grid undefined')
            }
        }
        else
        {
            alert('window undefined')
        }
    }

    function OnGridLivestockListGrid_EndCallback(s, e)
    {

        Livestock_ColumnToBeShownIndex = s.cpColumnToBeShownIndex;
        Livestock_ColumnToBeHidddenIndex = s.cpColumnToBeHidddenIndex;
        LivestockGridLayout = s.cpClientLayout;
       $(".LiveStockListGrid_PreviewRow").hide();
        GetSessionStorage("LiveStockListGrid");
        SendCustomArgs_FilterControl(s, e);
        if (e.command == "REFRESH" && LiveStock_IsVouchingMode == true) {
            s.SetFocusedRowIndex(-1);
            s.SetFocusedRowIndex(LiveStock_FocusedRowBeforeRefresh);
        }
    }
    function LivestockAdjustSize()
    {
                var height = (document.documentElement.clientHeight * 90) / 100;
                try{LiveStockListGrid.SetHeight(height);} catch (err) { }
    }
    function LivestockchangeMode()
    {
                ShowLoader();
        if (LS_ShowHorizontalBar == 0)
        {
                    LS_ShowHorizontalBar = 1;
                    $("#LivestockToggleScrollBar").find("span").text("Default Data");
                    $("#LivestockToggleScrollBar").width(110);
        }
        else
        {
                    LS_ShowHorizontalBar = 0;
                    $("#LivestockToggleScrollBar").find("span").text("Full Data");
                    $("#LivestockToggleScrollBar").width(90);
        }
                $.ajax({
                    url: '@Url.Action("Frm_LiveStock_Info_Grid", "LiveStock")',
                    type: "GET",
                    data: { ShowHorizontalBar: LS_ShowHorizontalBar, VouchingMode: LiveStock_IsVouchingMode, ViewMode: LiveStock_ViewMode, ColumnToBeHidddenIndex: Livestock_ColumnToBeHidddenIndex, ColumnToBeShownIndex: Livestock_ColumnToBeShownIndex },
                    success: function (res)
                    {
                        $("#LiveStockreloadPartialView").html(res);
                        $(".LiveStockListGrid_PreviewRow").hide();
                        GetSessionStorage("LiveStockListGrid");
                    }
                });
                HideLoader();
    }
    function LiveStockAjaxSuccessForm(data)
    {
        if (data.result == false)
        {
                    DevExpress.ui.dialog.alert(data.Message, "Error");
        }
        else
        {
                    IsLiveStockSucessPopup = true;
                    DevExpress.ui.dialog.alert(data.Message, "Success");
                    $("#popup_frm_LiveStock_Window").dxPopup("hide");
                    LiveStockListGrid.Refresh();
                    IsLiveStockSucessPopup = false;
        }
    }
    function LiveStock_dblclickEdit(s, e)
    {
                //var key = s.GetRowKey(s.GetFocusedRowIndex());
                //LiveStockListGrid.GetValuesOnCustomCallback({ key: key }, OnLiveStockGetRowValues);
                //if (LiveStockID != null || LiveStockID == 'undefined' || LiveStockID == undefined)
                //    OnLiveStockEditClick();
    }

    function LiveStockGrid_BeginCallBack(s, e)
    {
        LiveStock_FocusedRowBeforeRefresh = s.GetFocusedRowIndex();
                e.customArgs["command"] = e.command;
                e.customArgs["ShowHorizontalBar"] = LS_ShowHorizontalBar;
                e.customArgs["VouchingMode"] = LiveStock_IsVouchingMode;
                e.customArgs["ViewMode"] = LiveStock_ViewMode;
                e.customArgs["ColumnToBeShownIndex"] = Livestock_ColumnToBeShownIndex;
                e.customArgs["ColumnToBeHidddenIndex"] = Livestock_ColumnToBeHidddenIndex;
    }

    function LiveStockOnGridFocusedRowChanged(s, e)
    {
        if (s.GetFocusedRowIndex() >= 0)
        {

            if (LiveStock_IsVouchingMode)
            {
                LiveStockPrf_FAB.SetVisible(true);
                LiveStockPrf_FAB.SetActionContext("VouchingActionContext", true);
            }
            s.GetRowValues(s.GetFocusedRowIndex(), 'ID;LivestockName;Insurance;INSURANCE_ID;LS_INS_POLICY_NO;LS_INS_DATE;LS_INS_AMT;AL_LOC_NAME;LS_OTHER_DETAIL;SaleStatus;EntryType;EditDate;AddDate;AddBy;EditBy;ActionStatus;ActionDate;ActionBy', OnLiveStockGetRowValues);
        }
        else
        {
            LiveStockID = null;
        }
    }
    function OnLiveStockGetRowValues(values)
    {

                LiveStockID = values[0];
                LivestockName = values[1];
                LiveStock_Insurance = values[2];
                LiveStock_INSURANCE_ID = values[3];
                LiveStock_LS_INS_POLICY_NO = values[4];
                LiveStock_LS_INS_DATE = values[5];
                LiveStock_LS_INS_AMT = values[6];
                LiveStock_AL_LOC_NAME = values[7];
                LiveStock_LS_OTHER_DETAIL = values[8];
                LiveStock_SaleStatus = values[9];
                LiveStock_EntryType = values[10];
                LiveStock_EditDate = values[11];
                LiveStock_AddDate = values[12];
                LiveStock_AddBy = values[13];
                LiveStock_EditBy = values[14];
                LiveStock_ActionStatus = values[15];
                LiveStock_ActionDate = values[16];
                LiveStock_ActionBy = values[17];
                LiveStock_UpdateFooterDetail(LiveStockID, LiveStock_ActionStatus, LiveStock_AddDate, LiveStock_AddBy,
                    LiveStock_ActionDate, LiveStock_ActionBy, LiveStock_EditDate, LiveStock_EditBy);
        if (LiveStock_IsVouchingMode == true) {
            OpenLeftPane();
            LoadDocumentAndAdditionalInfoInLeftPane("Profile", "LiveStock", "LeftPaneContent", LiveStockID, LiveStock_IsVouchingMode, "");
        }
    }

    function LiveStock_UpdateFooterDetail(LiveStockID, LiveStock_Action_Status, LiveStock_Add_Date, LiveStock_Add_By, LiveStock_Action_Date, LiveStock_Action_By, LiveStock_Edit_Date, LiveStock_Edit_By)
    {
                //alert(LiveStock_Action_Date.toISOString());
               // LiveStock_Action_Date = LiveStock_Action_Date != "" && LiveStock_Action_Date != null ? LiveStock_Action_Date.toISOString() : LiveStock_Action_Date;
                LiveStock_Edit_Date = LiveStock_Edit_Date != "" && LiveStock_EditDate != null ? LiveStock_Edit_Date.toISOString() : LiveStock_Edit_Date;
                LiveStock_Add_Date = LiveStock_Add_Date != "" && LiveStock_Add_Date != null ? LiveStock_Add_Date.toISOString() : LiveStock_Add_Date;
                $.ajax({
                    type: 'GET',
                    url: "/Profile/LiveStock/CreationDetail",
                    data: {
                        Xrow: LiveStockID, Action_Status: LiveStock_Action_Status, Add_Date: LiveStock_Add_Date,
                        Add_By: LiveStock_Add_By, Action_Date: LiveStock_Action_Date, Action_By: LiveStock_Action_By, Edit_Date: LiveStock_Edit_Date, Edit_By: LiveStock_Edit_By
                    },
                    cache: false,
                    success: function (LiveStockLbl_result) {
                        $('#LiveStock_Lbl_ActionOn').text(LiveStockLbl_result.Lbl_StatusOn);
                        $('#LiveStock_Lbl_ActionBy').text(LiveStockLbl_result.Lbl_StatusBy);
                        $('#LiveStockLbl_Status').text(LiveStockLbl_result.Lbl_Status);
                        $('#LiveStockLbl_Create').text(LiveStockLbl_result.Lbl_Create);
                        //alert($('#LiveStockLbl_Create').text());
                        $('#LiveStockLbl_Modify').text(LiveStockLbl_result.Lbl_Modify);
                        if (LiveStockLbl_result.Lbl_Status_Color != "") {
                            $('#LiveStockLbl_Status').css('color', LiveStockLbl_result.Lbl_Status_Color);
                        }
                        if (LiveStockLbl_result.Pic_Status != "") {
                            $('#LiveStock_LockICON').css('class', LiveStockLbl_result.Pic_Status);
                        }
                    }
                });
    }

    function LiveStockOnUnLockClick()
    {
                if ("@LiveStock_LockUnlockRight" == "False")
                {
	                DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	                return;
                }
                if (LiveStockID == 'undefined' || LiveStockID == undefined) {
                    DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
                    return;
                }
                $.ajax({
                    type: 'GET',
                    url: "/Profile/LiveStock/DataNavigation",
                    data: { ActionMethod: "UNLOCKED", id: LiveStockID, TR_ID: TR_ID, YearID: YearId, AI_PARTY_ID: AI_PARTY_ID, ActionStatus: LiveStock_ActionStatus, EditDate: LiveStock_EditDate },
                    cache: false,
                    success: function (LiveStock_UNLOCKED_Get_DataNavigation_result) {
                        if (LiveStock_UNLOCKED_Get_DataNavigation_result.result == "NoUnLockRights") {
                            DevExpress.ui.dialog.alert(LiveStock_UNLOCKED_Get_DataNavigation_result.Message, "Locked..");
                        }
                        else {
                            DevExpress.ui.dialog.alert(LiveStock_UNLOCKED_Get_DataNavigation_result.Message);
                        }
                    }

                });
    }
    function LiveStockOnLockClick()
    {
                if ("@LiveStock_LockUnlockRight" == "False")
                {
	                DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	                return;
                }
                if (LiveStockID == 'undefined' || LiveStockID == undefined) {
                    DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
                    return;
                }
                $.ajax({
                    type: 'GET',
                    url: "/Profile/LiveStock/DataNavigation",
                    data: { ActionMethod: "LOCKED", id: LiveStockID, TR_ID: TR_ID, YearID: YearId, AI_PARTY_ID: AI_PARTY_ID, ActionStatus: LiveStock_ActionStatus, EditDate: LiveStock_EditDate },
                    cache: false,
                    success: function (LiveStock_LOCKED_Get_DataNavigation_result) {
                        if (LiveStock_LOCKED_Get_DataNavigation_result.result == "NoLockRights") {
                            DevExpress.ui.dialog.alert(LiveStock_LOCKED_Get_DataNavigation_result.Message, "Locked..");
