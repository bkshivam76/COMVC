@using DevExtreme.AspNet.Mvc;
@{
    var ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;
}

@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar)
    .ID("LiveStockListGrid")
    .DataSource(d => d.Mvc()
        .Controller("LiveStock")
        .LoadAction("Frm_LiveStock_Info_Grid_dx")
        .LoadMode(DataSourceLoadMode.Raw)
        .Key("ID")
    )
    .Columns(columns =>
    {
        columns.Add().DataField("SummaryColumn")
            .Name("SummaryColumn")
            .Caption("SummaryColumn")
            .Visible(false)
            .ShowInColumnChooser(false);

        columns.Add().DataField("iIcon")
            .Name("iIcon")
            .Caption("")
            .CellTemplate(new JS("LiveStockListGrid_dx_iIconTemplate"))
            .Width(30)
            .HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource"))
            .RenderAsync(true);

        columns.Add().DataField("LiveStockListGrid_dx_Compact_Column")
            .Name("LiveStockListGrid_dx_Compact_Column")
            .Caption("")
            .Visible(false)
            .CellTemplate(new JS("LiveStockListGrid_dx_Compact_Column_Template"))
            .CalculateCellValue("LiveStockListGrid_dx_Compact_Column_CellValue")
            .Width("100%")
            .RenderAsync(true);

        columns.Add().DataField("LivestockName").Caption("Livestock Name").Width(200);
        columns.Add().DataField("BirthYear").Caption("Birth Year").Width(100);
        columns.Add().DataField("Insurance").Caption("Insurance").Width(150);
        columns.Add().DataField("INSURANCE_COMPANY").Caption("Insurance Company").Width(150);
        columns.Add().DataField("LS_INS_POLICY_NO").Caption("Policy No.").Width(150);
        columns.Add().DataField("LS_INS_DATE").Caption("Insurance Date").Width(150);
        columns.Add().DataField("LS_INS_AMT").Caption("Insurance Amount").Width(150);
        columns.Add().DataField("CurrValue").Caption("Current Value").Width(150);
        columns.Add().DataField("AL_LOC_NAME").Caption("Location").Width(150);
        columns.Add().DataField("LS_OTHER_DETAIL").Caption("Other Details").Width(150);
        columns.Add().DataField("SaleStatus").Caption("Sale Status").Width(150);
        columns.Add().DataField("EntryType").Caption("Entry Type").Width(150);
        columns.Add().DataField("ActionBy").Caption("Action By").Width(150);
        columns.Add().DataField("ActionStatus").Caption("Action Status").Width(150);
        columns.Add().DataField("AddBy").Caption("Added By").Width(150);
        columns.Add().DataField("ActionDate").Caption("Action Date").Width(150).DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
        columns.Add().DataField("AddDate").Caption("Added Date").Width(150).DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
        columns.Add().DataField("EditDate").Caption("Edited Date").Width(150).DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
        columns.Add().DataField("EditBy").Caption("Edited By").Width(150);
        columns.Add().DataField("ID").Caption("ID").Width(150);
        columns.Add().DataField("REJECTED_COUNT").Caption("Rejected Count").Width(150);
        columns.Add().DataField("RESPONDED_COUNT").Caption("Responded Count").Width(150);
        columns.Add().DataField("COMPLETE_ATTACH_COUNT").Caption("Complete Attach Count").Width(150);
        columns.Add().DataField("REQ_ATTACH_COUNT").Caption("Required Attach Count").Width(150);
        columns.Add().DataField("OTHER_ATTACH_CNT").Caption("Other Attach Count").Width(150);
        columns.Add().DataField("ALL_ATTACH_CNT").Caption("All Attach Count").Width(150);
        columns.Add().DataField("Special_Ref").Caption("Special Reference").Width(150);
    })  
    .MasterDetail(md =>
    {
        md.AutoExpandAll(false);
        md.Enabled(!VouchingMode);
        md.Template(new JS("LiveStockListGrid_dx_DetailTemplate"));
    })
    .OnInitialized("LiveStockListGrid_dx_OnInitialized")
    .OnCellPrepared("LiveStockListGrid_dx_OnCellPrepared")
    .OnRowPrepared("LiveStockListGrid_dx_OnRowPrepared")
    .OnContentReady("LiveStockListGrid_dx_OnContentReady")
    .OnCellDblClick("LiveStockListGrid_dx_OnCellDblClick")
    .OnSelectionChanged("LiveStockListGrid_dx_OnSelectionChanged")
    .OnRowExpanding("LiveStockListGrid_dx_OnRowExpanding")
    .OnRowCollapsing("LiveStockListGrid_dx_OnRowCollapsing")
    .OnContextMenuPreparing("LiveStockListGrid_dx_OnContextMenuPreparing")
)