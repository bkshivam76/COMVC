    @*Javascript Events*@
    <script type="text/javascript">
    var LiveStockListGrid = null;
    var IsLiveStockSucessPopup = false;
    var IsLiveStockViewPopup = false;
    var LS_ShowHorizontalBar = parseInt("@ViewBag.ShowHorizontalBar");
    var LiveStock_SetVouchingModeOn = "@LiveStock_Auto_Vouching_Mode" == "True" ? true : false;
    var UserType_LiveStockPrf = "@UserType".toUpperCase();
    var LiveStock_IsVouchingMode = false;
    var LiveStock_ViewMode = "Default";
    var Livestock_ColumnToBeShownIndex = "";
    var Livestock_ColumnToBeHidddenIndex = "";
    var LiveStockID;
    var LivestockName;
    var LiveStock_Insurance;
    var LiveStock_INSURANCE_ID;
    var LiveStock_LS_INS_POLICY_NO;
    var LiveStock_LS_INS_DATE;
    var LiveStock_LS_INS_AMT;
    var LiveStock_AL_LOC_NAME;
    var LiveStock_LS_OTHER_DETAIL;
    var LiveStock_SaleStatus;
    var LiveStock_EntryType;
    var LiveStock_EditDate;
    var LiveStock_AddDate;
    var LiveStock_AddBy;
    var LiveStock_EditBy;
    var LiveStock_ActionStatus;
    var LiveStock_ActionDate;
    var LiveStock_ActionBy;
    var LiveStock_FocusedRowBeforeRefresh;
    var Expanded_Row_Key_LiveStock;


        function LiveStock_VouchingSwitch_ValueChange(e) {

            LiveStock_IsVouchingMode = e.value;

            if (LiveStock_SetVouchingModeOn == true) {
                LiveStock_SetVouchingModeOn = false;
            }
            else {
                LiveStockPrf_FAB.SetVisible(false);
            }

            if (LiveStock_IsVouchingMode == true) {
                OpenRightPane();
                ClearLeftPane();
                OpenLeftPane();
            }
            else {
                LiveStockPrf_FAB.SetActionContext("AddAttachmentContext", false);
                CloseRightPane();
                ClearLeftPane();
                CloseLeftPane();
            }
           // LiveStockListGrid.clearSelection();
            LiveStockListGrid.option("masterDetail.enabled", !LiveStock_IsVouchingMode);
            LiveStockListGrid.repaint();
        }

        function LiveStock_ViewSwitch_ValueChange(e) {

            LiveStock_ViewMode = e.value == false ? "Default" : "Compact";

            if (LiveStock_SetVouchingModeOn == true) {
                $("#LiveStockVouchingModeSwitch").dxSwitch("instance").option("value", true);
            }

            //LiveStockListGrid.beginUpdate();



            var columns = LiveStockListGrid.option("columns");
            if (LiveStock_ViewMode == "Compact")
               {
                VisibleColumns_LiveStock = [];

                for (var i = 0; i < columns.length; i++) {
                    var name = columns[i].dataField;
                    var ColumnVisible = LiveStockListGrid.columnOption(name, "visible");

                    if (name == "LiveStockListGrid_dx_Compact_Column")
                    {
                        LiveStockListGrid.columnOption(name, "visible", true);
                    }
                    else if (ColumnVisible == true && name != "iIcon") {
                        VisibleColumns_LiveStock.push(name);
                        LiveStockListGrid.columnOption(name, "visible", false);
                    }
                }
            } else {
                LiveStockListGrid.columnOption("LiveStockListGrid_dx_Compact_Column", "visible", false);

                for (var i = 0; i < VisibleColumns_LiveStock.length; i++) {
                    LiveStockListGrid.columnOption(VisibleColumns_LiveStock[i], "visible", true);
                }
            }

            LiveStockListGrid.repaint();
            LiveStockListGrid.endUpdate();
        }

     $(document).ready(function ()
     {
           LiveStock_ExportRight_dx = ("@LiveStock_ExportRight" == "True") ? true : false;
           LiveStock_LockUnlockRight_dx = ("@LiveStock_LockUnlockRight" == "True") ? true : false;

           if (LiveStock_ExportRight_dx != true)
           {
               $("#LiveStockModelListPreview").hide();
           }
           if (LiveStock_LockUnlockRight_dx != true)
           {
               $("#LiveStockModelUnlock").hide();
               $("#LiveStockModelLock").hide();
           }

           IsLiveStockSucessPopup = false;
           IsLiveStockViewPopup = false;
           $("#livestocklistgrid").hover(function () {
              var grid = $("#livestocklistgrid").dxdatagrid("instance");
               if (grid) {
                  grid.focus();
               }
           });


           HideUnreleasedFunctionality('Frm_LiveStock_info');

           if (LiveStock_SetVouchingModeOn == true)
           {
              $("#LiveStockViewModeSwitch").dxSwitch("instance").option("value", true);
           }
     });


    function  LivestockchangeMode_dx()
    {
        LiveStockListGrid.beginUpdate();
        if (LS_ShowHorizontalBar == 0)
        {
                    LS_ShowHorizontalBar = 1;
                    $("#LivestockToggleScrollBar").find("span").text("Default Data");
                    $("#LivestockToggleScrollBar").width(110);
            LiveStockListGrid.option("columnHidingEnabled", false);
            LiveStockListGrid.option("allowColumnResizing", true);
        }
        else
        {
                    LS_ShowHorizontalBar = 0;
                    $("#LivestockToggleScrollBar").find("span").text("Full Data");
                    $("#LivestockToggleScrollBar").width(90);
            LiveStockListGrid.option("columnHidingEnabled", true);
            LiveStockListGrid.option("allowColumnResizing", false);
        }

        LiveStockListGrid.endUpdate();
    }
    function LiveStockListGrid_dx_OnInitialized(e)
    {

        DxGrid_AdjustSize(e.component, $("#LiveStockProfile_ParentDiv_dx .report_button_div"));
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            DxGrid_AdjustSize(e.component, $("#LiveStockProfile_ParentDiv_dx .report_button_div"), "", evt);
        });

        LiveStockListGrid = e.component
    }

    function LiveStockListGrid_dx_OnCellPrepared(e) {
        if (e.rowType == "data") {         
            if (LiveStock_IsVouchingMode == true) {
                if (e.column.dataField === "iIcon") {
                    $(e.cellElement).attr("onmouseover", "OnGridRowMouseHoverIn(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.key + "')");
                    $(e.cellElement).attr("onmouseout", "OnGridRowMouseHoverOut(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.key + "')");
                }
            }
            $(e.cellElement).attr("id", e.element[0].id + "_Cell_" + e.key + "|" + e.column.dataField);
        }
    }

    function LiveStockListGrid_dx_OnRowPrepared(e) {
        if (e.rowType == "data") {
            var GridName = e.element[0].id;     
            $(e.rowElement).addClass(GridName + "_DataRow_" + e.key)
            DxGrid_CreatePreviewRow(e, LiveStock_IsVouchingMode, "Master")
        }
        else if (e.rowType == "detailAdaptive") {
            DxGrid_MovePreviewRowAfterAdaptiveRow(e)
        }
    }

        function LiveStockListGrid_dx_OnContentReady(e)
        {
            DxGrid_OnContentReady(e, LS_ShowHorizontalBar);
        }
        function LiveStockListGrid_dx_OnCellDblClick(e) {
            if (e.rowType == "data") {
                if (LiveStock_IsVouchingMode == true && LiveStock_ViewMode == "Default") {                   
                    OnGridCellClick(e.event, e.cellElement[0], e.columnIndex, e.rowIndex, e.element[0].id, e.key, e.column.dataField)
                }
                //    else if (LiveStock_IsVouchingMode == false) { OnAddressEditClick_dx(); }
            }
        }
    function LiveStockListGrid_dx_OnSelectionChanged(e) {
        var selectedRowKeys = e.selectedRowKeys;
        if (selectedRowKeys != null && selectedRowKeys.length > 0) {
            if (LiveStock_IsVouchingMode) {
                LiveStockPrf_FAB.SetVisible(true);
                LiveStockPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
            LiveStockListGrid_dx_SelectedRowData(e.selectedRowsData);
        }
        else {
            LiveStockIDLiveStockID = null;
            LiveStock_UpdateFooterDetail_dx(LiveStockID, LiveStock_ActionStatus, LiveStock_AddDate, LiveStock_AddBy, LiveStock_ActionDate, LiveStock_ActionBy, LiveStock_EditDate, LiveStock_EditBy);
        }
    }
    function LiveStockListGrid_dx_SelectedRowData(selectedData = null) {
        if (selectedData == null) {
            selectedData = LiveStockListGrid.getSelectedRowsData();
        }
        if (selectedData != null && selectedData.length > 0) {
            var values = selectedData[0]

            console.table(values)

            LiveStockID = values["ID"];
            LivestockName = values["LivestockName"];
            LiveStock_Insurance = values["Insurance"];
            LiveStock_INSURANCE_ID = values["INSURANCE_ID"];
            LiveStock_LS_INS_POLICY_NO = values["LS_INS_POLICY_NO"];
            LiveStock_LS_INS_DATE = values["LS_INS_DATE"];
            LiveStock_LS_INS_AMT = values["LS_INS_AMT"];
            LiveStock_AL_LOC_NAME = values["AL_LOC_NAME"];
            LiveStock_LS_OTHER_DETAIL = values["LS_OTHER_DETAIL"];
            LiveStock_SaleStatus = values["SaleStatus"];
            LiveStock_EntryType = values["EntryType"];
            LiveStock_EditDate = values["EditDate"];
            LiveStock_AddDate = values["AddDate"];
            LiveStock_AddBy = values["AddBy"];
            LiveStock_EditBy = values["EditBy"];
            LiveStock_ActionStatus = values["ActionStatus"];
            LiveStock_ActionDate = values["ActionDate"];
            LiveStock_ActionBy = values["ActionBy"];
            LiveStock_UpdateFooterDetail_dx(LiveStockID, LiveStock_ActionStatus, LiveStock_AddDate, LiveStock_AddBy,
                LiveStock_ActionDate, LiveStock_ActionBy, LiveStock_EditDate, LiveStock_EditBy);
            if (LiveStock_IsVouchingMode == true) {
                OpenLeftPane();
                LeftPaneContent_LiveStock_dx("LiveStockListGrid", LiveStockID, LiveStock_IsVouchingMode, "");
            }
        }
    }
    function LiveStockListGrid_dx_OnRowExpanding(e) {
            if (Array.isArray(e.key) == false) //not group row
            {
                e.component.collapseRow(Expanded_Row_Key_LiveStock)
                e.component.selectRows(e.key);
                Expanded_Row_Key_LiveStock = e.key;
                LiveStockInfo_IsDetailRowExpanded = true;
                var DetailGridID = e.element[0].id + e.key;
                var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
                if (instance != void 0) {
                    instance.state(null) // grid maintains its state after collapsing so resetting the state when expands again as per old grid
                }
                //e.component.collapseAll(-1);
        }
            else {
                e.component.option("CustomProp.groupRowExpanded", true);
            }
    }
    function LiveStockListGrid_dx_OnRowCollapsing(e) {
            if (Array.isArray(e.key) == false) //not group row
            {
                var DetailGridID = e.element[0].id + e.key;
                sessionStorage.removeItem(DetailGridID + "_DetailGridState") //removing grid state from session storage on collapse

                LiveStockInfo_IsDetailRowExpanded = false;
                e.component.selectRows(e.key);
                if (LiveStock_IsVouchingMode == false) {
                    LiveStockPrf_FAB.SetVisible(false);
                }
        }
            else {
                e.component.option("CustomProp.groupRowCollapsed", true);
            }
    }
         
    function LiveStock_UpdateFooterDetail_dx(LiveStockID, LiveStock_Action_Status, LiveStock_Add_Date, LiveStock_Add_By, LiveStock_Action_Date, LiveStock_Action_By, LiveStock_Edit_Date, LiveStock_Edit_By)
    {
        var Status = "";
        var Lbl_Status = "";
        var Lbl_StatusBy = "";
        var Pic_Status = "";
        var Lbl_Create = "";
        var Lbl_Modify = "";
        var Lbl_Status_Color = "";
        var Lbl_ActionOn = "";
        var Lbl_ActionBy = "";
        var StatusStr = "";
        if (LiveStockID != null) {
            Status = LiveStock_Action_Status;
            StatusStr = Status == "Locked" ? "Locked" : Status == null ? null : "UnLocked";
            if (Status && Status.toUpperCase() == "LOCKED") {
                Lbl_Status = "Completed";
                Lbl_Status_Color = "blue";
                Pic_Status = "fa fa-lock";
            }
            else {
                Pic_Status = "fa fa-unlock";
                Lbl_Status = Status;
                if (Status && Status.toUpperCase() == "COMPLETED") {
                    Lbl_Status_Color = "green";
                }
                else {
                    Lbl_Status_Color = "red";
                }
            }
            if (LiveStock_Action_Date) {
                Lbl_ActionOn = StatusStr + " On: " + LiveStock_Action_Date;
                Lbl_ActionBy = StatusStr + " By: " + LiveStock_Action_By;
            }
            else {
                Lbl_ActionOn = "";
                Lbl_ActionBy = "";
            }
            if (LiveStock_Add_Date) {
                Lbl_Create = "Add On: " + LiveStock_Add_Date + ", By: " + LiveStock_Add_By;
            }
            else {
                Lbl_Create = "";
            }
            if (LiveStock_Edit_Date) {
                Lbl_Modify = "Edit On: " + LiveStock_Edit_Date + ", By: " + LiveStock_Edit_By;
            }
            else {
                Lbl_Modify = "";
            }
        }
        $('#AB_Status_dx').text(Lbl_Status);
        $('#AB_Lbl_ActionOn_dx').text(Lbl_ActionOn)
        $('#AB_Lbl_ActionBy_dx').text(Lbl_ActionBy);
        $('#AB_Create_dx').text(Lbl_Create);
        $('#AB_Modify_dx').text(Lbl_Modify);
        if (Lbl_Status_Color != "") {
            $('#ActionItem_Status_dx').css('color', Lbl_Status_Color);
        }
        if (Pic_Status == "fa fa-lock") {
            $('#ActionItem_LockICON_dx').addClass(Pic_Status).removeClass("fa-unlock");
        }
        else if (Pic_Status == "fa fa-unlock") {
            $('#ActionItem_LockICON_dx').addClass(Pic_Status).removeClass("fa-lock");
        }
        else {
            $('#ActionItem_LockICON_dx').removeClass("fa");
            $('#ActionItem_LockICON_dx').removeClass("fa-lock");
            $('#ActionItem_LockICON_dx').removeClass("fa-unlock");
        }
    }

    function LiveStockOnUnLockClick()
    {
                if ("@LiveStock_LockUnlockRight" == "False")
                {
	                DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	                return;
                }
                if (LiveStockID == 'undefined' || LiveStockID == undefined) {
                    DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
                    return;
                }
                $.ajax({
                    type: 'GET',
                    url: "/Profile/LiveStock/DataNavigation",
                    data: { ActionMethod: "UNLOCKED", id: LiveStockID, TR_ID: TR_ID, YearID: YearId, AI_PARTY_ID: AI_PARTY_ID, ActionStatus: LiveStock_ActionStatus, EditDate: LiveStock_EditDate },
                    cache: false,
                    success: function (LiveStock_UNLOCKED_Get_DataNavigation_result) {
                        if (LiveStock_UNLOCKED_Get_DataNavigation_result.result == "NoUnLockRights") {
