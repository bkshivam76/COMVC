    function LiveStockListGrid_dx_Detail_onSelectionChanged(e) {
        if (LiveStockInfo_IsDetailRowExpanded || LiveStock_IsVouchingMode) {
            if (e.selectedRowsData != null && e.selectedRowsData.length > 0) {
                LiveStockInfo_NestedGrid_AccessID = e.element[0].id;
                LiveStockListGrid_dx_Detail_SelectedRowData(e.selectedRowsData)
                //AddressBook_FAB_dx.SetVisible(true);
            }
            else {
                LiveStockPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }
    function LiveStockListGrid_dx_Detail_SelectedRowData(selectedData = null) {
        if (selectedData == null) {
            selectedData = $("div[id='" + LiveStockInfo_NestedGrid_AccessID + "']").dxDataGrid("getSeletedRowsData");
        }
        var values = selectedData[0];
        if (values["UniqueID"] != null) {
            LiveStockPrf_FAB.SetVisible(true);
            LiveStockInfo_Nested_Doc_Status = values["Doc_Status"];
            if (LiveStock_IsVouchingMode == true) {
                LiveStockPrf_FAB.SetActionContext("AuditActionContext", true);
            }
            else {
                if (LiveStockInfo_Nested_Doc_Status == "") {
                    LiveStockPrf_FAB.SetActionContext("AutoItemContext", true);
                }
                else if (LiveStockInfo_Nested_Doc_Status == "NO") {
                    LiveStockPrf_FAB.SetActionContext("EditItemContext", true);
                }
                else if (LiveStockInfo_Nested_Doc_Status == "YES") {
                    LiveStockPrf_FAB.SetActionContext("actionItemContext", true);
                }
            }
            LiveStockInfo_ParamMandatory = values["Params_Mandatory"];
            LiveStockInfo_FromDateLabel = values["LABEL_FROM_DATE"];
            LiveStockInfo_ToDateLabel = values["LABEL_TO_DATE"];
            LiveStockInfo_DescriptionLabel = values["LABEL_DESCRIPTION"];
            LiveStockInfo_Doc_Category = values["Document_Category"];
            LiveStockInfo_Doc_ID = values["Document_ID"];
            LiveStockInfo_AtachmentID = values["ATTACH_ID"];
            IndexAttachmentID = LiveStockInfo_AtachmentID;
            LiveStockInfo_MasterRowRecID = values["TxnID"];
            LiveStockInfo_MasterRowMID = values["TxnMID"];
            LiveStockInfo_NestedRowMapID = values["MAP_ID"];
            LiveStockInfo_reason = values["Reason"];
            LiveStockInfo_FileName = values["ATTACH_FILE_NAME"];
            LiveStockInfo_Attachment_RecStatus = values["Attachment_Action_Status"];
            LiveStockInfo_NestedRowKeyValue = values["UniqueID"];
            if (LiveStock_IsVouchingMode == true) {
                if (LiveStockInfo_FileName != null && LiveStockInfo_FileName.length > 0) {
                    ViewDocument(LiveStockInfo_AtachmentID, LiveStockInfo_FileName, "LiveStockPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else {
                    CloseRightPane();
                    ClearRightPane();
                }
            }
        }
        LiveStockInfo_NestedRowReasonID = values["ReasonID"];
        IndexAttachmentReasonID = LiveStockInfo_NestedRowReasonID;
    }

