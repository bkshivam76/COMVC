    </div>

    <script>
        $(function () {

            if ("@CalledFromOtherScreen".length > 0) {
                DxGrid_EventsOnScreenClose(LiveStockListGrid);
                if ("@CalledFromOtherScreen" != "Dynamic_Content_popup")
                {
                    $("#" + "@CalledFromOtherScreen").dxPopup({
                        onHiding: function (e) {
                            $.ajax({
                                type: 'GET',
                                url: "/Profile/LiveStock/SessionClear",
                                cache: false
                            });
                            if ("@PartyRefreshFunction".length > 0) {
                                var fn = window["@PartyRefreshFunction"];
                                if (typeof fn == "function")
                                {
                                    fn();
                                }
                            }
                            if (LiveStock_IsVouchingMode == true) {
                                ClearLeftPane();
                                CloseLeftPane();
                                ClearRightPane();
                                CloseRightPane();
                            }
                        }
                    });
                }
            }
        });

        function closeProfile_Livestock() {
            $(".TabPanalMenu-tabs .active span").click();
        }//Redmine Bug #133403 fixed

        function closeLiveStock_dx()
        {
            DxGrid_EventsOnScreenClose(LiveStockListGrid);
            if ("@CalledFromOtherScreen".length > 0)
            {
                var popupid = "#" + "@CalledFromOtherScreen";
                $(popupid).dxPopup("hide");
            }
            else
            {
                $(".TabPanalMenu-tabs .active span").click();
            }
        }

    $(".TabPanalMenu-tabs .active span").on("click", function () {
        $.ajax({
            type: 'GET',
            url: "/Profile/LiveStock/SessionClear",
            cache: false
        });
        CloseRightPane();
        ClearLeftPane();
        CloseLeftPane();
        DxGrid_EventsOnScreenClose(LiveStockListGrid);
        ClearAllReferences_LiveStockProfile();
    });

