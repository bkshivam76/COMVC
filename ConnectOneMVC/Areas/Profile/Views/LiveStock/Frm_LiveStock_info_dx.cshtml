    function OnLiveStockListGridNestedFocusedRowChange(s, e)
    {
        if (LiveStockInfo_IsDetailRowExpanded == true || LiveStock_IsVouchingMode == true)
        {
            LiveStockInfo_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
            if (LiveStockInfo_NestedRecord_FocusedRowIndex >= 0)
            {
                ShowLoader();
                LiveStockInfo_NestedGrid_AccessID = s.uniqueID;
                s.GetRowValues(s.GetFocusedRowIndex(), 'Doc_Status;Params_Mandatory;LABEL_FROM_DATE;LABEL_TO_DATE;LABEL_DESCRIPTION;Document_Category;Document_ID;ATTACH_ID;TxnID;TxnMID;MAP_ID;Reason;ATTACH_FILE_NAME;Attachment_Action_Status;UniqueID;ReasonID', OnLiveStockInfo_GetGridRowValues);
            }
            else
            {
                LiveStockPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }
    function OnLiveStockInfo_GetGridRowValues(values)
    {
        HideLoader();
        if (values[14] != null)
        {
            LiveStockPrf_FAB.SetVisible(true);
            LiveStockInfo_Nested_Doc_Status = values[0];
            if (LiveStock_IsVouchingMode == true) {
                LiveStockPrf_FAB.SetActionContext("AuditActionContext", true);
            }
            else
            {
                if (LiveStockInfo_Nested_Doc_Status == "")
                {
                    LiveStockPrf_FAB.SetActionContext("AutoItemContext", true);
                }
                else if (LiveStockInfo_Nested_Doc_Status == "NO")
                {
                    LiveStockPrf_FAB.SetActionContext("EditItemContext", true);
                }
                else if (LiveStockInfo_Nested_Doc_Status == "YES")
                {
                    LiveStockPrf_FAB.SetActionContext("actionItemContext", true);
                }
            }
            LiveStockInfo_ParamMandatory = values[1];
            LiveStockInfo_FromDateLabel = values[2];
            LiveStockInfo_ToDateLabel = values[3];
            LiveStockInfo_DescriptionLabel = values[4];
            LiveStockInfo_Doc_Category = values[5];
            LiveStockInfo_Doc_ID = values[6];
            LiveStockInfo_AtachmentID = values[7];
            IndexAttachmentID = LiveStockInfo_AtachmentID;
            LiveStockInfo_MasterRowRecID = values[8];
            LiveStockInfo_MasterRowMID = values[9];
            LiveStockInfo_NestedRowMapID = values[10];
            LiveStockInfo_reason = values[11];
            LiveStockInfo_FileName = values[12];
            LiveStockInfo_Attachment_RecStatus = values[13];
            LiveStockInfo_NestedRowKeyValue = values[14];
            if (LiveStock_IsVouchingMode == true)
            {
                if (LiveStockInfo_FileName != null && LiveStockInfo_FileName.length > 0)
                {
                    ViewDocument(LiveStockInfo_AtachmentID, LiveStockInfo_FileName, "LiveStockPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else
                {
                    CloseRightPane();
                    ClearRightPane();
                }
            }
        }
        LiveStockInfo_NestedRowReasonID = values[15];
        IndexAttachmentReasonID = LiveStockInfo_NestedRowReasonID;
    }
    function LiveStockGrid_Nested_BeginCallBack(s, e)
    {
        e.customArgs["ShowHorizontalBar"] = LS_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = LiveStock_IsVouchingMode;
        e.customArgs["command"] = e.command;
    }
    function LiveStockGrid_DetailRowExpanding(s, e)
    {
        LiveStockInfo_IsDetailRowExpanded = true;
        s.SetFocusedRowIndex(e.visibleIndex);
        var pane = Mainspliter.GetPaneByName('RightPane');
        if (LiveStock_IsVouchingMode == true)
        {
            pane.Expand();
        }
        else
        {
            pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
        }
    }
    function LiveStockGrid_DetailRowCollapsing(s, e)
    {
        LiveStockInfo_IsDetailRowExpanded = false;
        s.SetFocusedRowIndex(e.visibleIndex);
        if (LiveStock_IsVouchingMode == true)
        {
            if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false)
            {
                CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
        else
        {
            LiveStockPrf_FAB.SetVisible(false);
        }
    }
    </script>



