    function On_LiveStockProfile_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@Help_Attachment_AddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (LiveStockInfo_ParamMandatory == 1)
            {
                AddAttachment(LiveStockInfo_MasterRowRecID, "Profile_LiveStock", LiveStockInfo_Doc_ID, LiveStockInfo_Doc_Category, LiveStockInfo_ParamMandatory, LiveStockInfo_FromDateLabel, LiveStockInfo_ToDateLabel, LiveStockInfo_DescriptionLabel, "LiveStockProfileAttachment", null, "LiveStockListGrid", LiveStockInfo_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(LiveStockInfo_MasterRowRecID, "Profile_LiveStock", LiveStockInfo_Doc_ID, "LiveStockProfileAttachment", "LiveStockListGrid", LiveStockInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (LiveStockInfo_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(LiveStockInfo_MasterRowRecID, "Profile_LiveStock", LiveStockInfo_AtachmentID, LiveStockInfo_ParamMandatory, LiveStockInfo_FromDateLabel, LiveStockInfo_ToDateLabel, LiveStockInfo_DescriptionLabel, "LiveStockProfileAttachment", null, "LiveStockListGrid", LiveStockInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            debugger
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(LiveStockInfo_MasterRowRecID, "Profile_LiveStock", LiveStockInfo_AtachmentID, LiveStockInfo_ParamMandatory, LiveStockInfo_FromDateLabel, LiveStockInfo_ToDateLabel, LiveStockInfo_DescriptionLabel, null, "LiveStockListGrid", LiveStockInfo_NestedGrid_AccessID, LiveStockInfo_Attachment_RecStatus);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@Help_Attachment_ViewRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            ViewDocument(LiveStockInfo_AtachmentID, LiveStockInfo_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(LiveStockInfo_MasterRowRecID, "Profile_LiveStock", "LiveStock Information", "LiveStockListGrid", LiveStockInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Add_Reason")
        {
            if (LiveStockInfo_Doc_Category.toLowerCase() == "others")
            {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else {
                AttachmentAddReason(LiveStockInfo_MasterRowRecID, LiveStockInfo_NestedRowMapID, "Profile_LiveStock", "LiveStockListGrid", LiveStockInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(LiveStockInfo_MasterRowRecID, LiveStockInfo_NestedRowMapID, "Profile_LiveStock", "LiveStockListGrid", LiveStockInfo_NestedGrid_AccessID, LiveStockInfo_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(LiveStockInfo_MasterRowRecID, LiveStockInfo_NestedRowMapID, "LiveStockListGrid", LiveStockInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
        else if (e.actionName == "AuditAction")
        {
            LiveStockPrf_FAB.SetActionContext("AuditActionContext", true);
        }
        else if (e.actionName == "BackAudit")
        {
            if (LiveStockInfo_Nested_Doc_Status == "")
            {
                LiveStockPrf_FAB.SetActionContext("AutoItemContext", true);
            }
            if (LiveStockInfo_Nested_Doc_Status == "NO")
            {
                LiveStockPrf_FAB.SetActionContext("EditItemContext", true);
            }
            if (LiveStockInfo_Nested_Doc_Status == "YES")
            {
                LiveStockPrf_FAB.SetActionContext("actionItemContext", true);
            }
        }
        else if (e.actionName == "Accept")
        {
            LiveStockInfo_AcceptwithoutRemarks();
        }
        else if (e.actionName == "Reject")
        {
            LiveStockInfo_AcceptRejectVoucher("Reject");
        }
        else if (e.actionName == "AcceptWithRemarks")
        {
            LiveStockInfo_AcceptRejectVoucher("Accept");
        }
        else if (e.actionName == "AcceptDoc") {

            OnLiveStockInfo_AcceptDoc();
        }
        else if (e.actionName == "RejectDoc") {

            OnLiveStockInfo_RejectDoc();
        }
    }
    function OnLiveStockInfo_RejectDoc() {
        if (LiveStockInfo_AtachmentID == null || LiveStockInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        RejectAttachment(LiveStockInfo_AtachmentID, "LiveStockListGrid", LiveStockInfo_NestedGrid_AccessID);
    }
    function OnLiveStockInfo_AcceptDoc() {
        if (LiveStockInfo_AtachmentID == null || LiveStockInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        AcceptAttachment(LiveStockInfo_AtachmentID, "LiveStockListGrid", LiveStockInfo_NestedGrid_AccessID);
    }
    function LiveStockInfo_AcceptwithoutRemarks()
    {
        var Recid;
        if (LiveStockInfo_IsDetailRowExpanded == true || LiveStock_IsVouchingMode == true)
        {
            if (LiveStockInfo_MasterRowRecID == null || LiveStockInfo_MasterRowRecID == "")
            {
                Recid = LiveStockID;
            }
            else
            {
                Recid = LiveStockInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = LiveStockID;
        }
        Entry_AcceptwithoutRemarks(Recid, "Profile_LiveStock", "LiveStockListGrid", LiveStockInfo_AtachmentID, LiveStockInfo_NestedRowReasonID, LiveStockInfo_NestedRowKeyValue);
    }
    function LiveStockInfo_AcceptRejectVoucher(_actionMethod)
    {
        var Recid;
        if (LiveStockInfo_IsDetailRowExpanded == true || LiveStock_IsVouchingMode == true)
        {
            if (LiveStockInfo_MasterRowRecID == null || LiveStockInfo_MasterRowRecID == "")
            {
                Recid = LiveStockID;
            }
            else
            {
                Recid = LiveStockInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = LiveStockID;
        }
        Entry_AcceptReject(_actionMethod, Recid, "Profile_LiveStock", "LiveStockListGrid", LiveStockInfo_AtachmentID, LiveStockInfo_NestedRowReasonID, LiveStockInfo_NestedRowKeyValue);
