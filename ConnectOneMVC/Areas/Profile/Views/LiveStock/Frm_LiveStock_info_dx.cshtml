    var LiveStockInfo_FileName;
    var LiveStockInfo_ParamMandatory;
    var LiveStockInfo_FromDateLabel;
    var LiveStockInfo_ToDateLabel;
    var LiveStockInfo_DescriptionLabel;
    var LiveStockInfo_Doc_ID;
    var LiveStockInfo_Doc_Category;
    var LiveStockInfo_MasterRowRecID;
    var LiveStockInfo_MasterRowMID;
    var LiveStockInfo_NestedRowMapID;
