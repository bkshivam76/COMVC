    function OnMagazineCellClick(event, cell,col, row)
    {
        if (UserType_MagazinePrf == "AUDITOR" || UserType_MagazinePrf == "SUPERUSER")
        {
            if (event.button == 0)
            {
                if (cell.style.backgroundColor.length > 0)
                {
                    cell.style.backgroundColor = "";
                }
                else
                {
                    cell.style.backgroundColor = 'skyblue';
                }
            }
        }
    }
    function Magazine_ViewSwitch_ValueChange(e)
    {
        Magazine_ViewMode = e.value == false ? "Default" : "Compact";
        if (Magazine_SetVouchingModeOn == true)
        {
            Magazine_SetVouchingModeOn = false;
            $("#MagzinVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }
        else
        {
            ExistingMagMemberListGrid.CollapseAllDetailRows();
        }
    }
    function Magzin_VouchingSwitch_ValueChange(e)
    {
        Magzin_IsVouchingMode = e.value;
        ExistingMagMemberListGrid.SetFocusedRowIndex(-1);
        Magazine_MembersPrf_FAB.SetVisible(false);
        if (Magzin_IsVouchingMode == true) {
            OpenRightPane();
            ClearLeftPane();
            OpenLeftPane();
        }
        else {
            Magazine_MembersPrf_FAB.SetActionContext("AddAttachmentContext", false);
            CloseRightPane();
            ClearLeftPane();
            CloseLeftPane();
        }
        ExistingMagMemberListGrid_CollapseAllDetailRows();
    }
    function ExistingMagMemberListGrid_CollapseAllDetailRows()
    {
        if (typeof window !== 'undefined')
        {
            if (typeof window.ExistingMagMemberListGrid !== 'undefined')
            {
                if (typeof window.ExistingMagMemberListGrid.CollapseAllDetailRows !== 'undefined')
                {
                    if (typeof ExistingMagMemberListGrid.CollapseAllDetailRows == 'function')
                    {
                        ExistingMagMemberListGrid.SetFocusedRowIndex(-1);
                        ExistingMagMemberListGrid.CollapseAllDetailRows();
                    }
                    else
                    {
                        alert("CollapseAllDetailRows is not a function");
                    }
                }
                else
                {
                    ShowLoader();
                    setTimeout(function ()
                    {
                        ExistingMagMemberListGrid_CollapseAllDetailRows();
                        HideLoader();
                    }, Timeout100);
                }
            }
            else
            {
                alert('grid undefined')
            }
        }
        else
        {
            alert('window undefined')
        }
    }
    function ExistingMagMemberOnInit(s, e) {
        ExistingMagMemberAdjustSize();
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            ExistingMagMemberAdjustSize();
        });
    }
    function OnEndCallback(s, e) {
        ExistingMagMemberAdjustSize();
        SendCustomArgs_FilterControl(s, e);
    }
    function ExistingMagMemberAdjustSize() {
        var height = (document.documentElement.clientHeight * 90) / 100;
        try{ExistingMagMemberListGrid.SetHeight(height);}catch(err){}
    }

    var Mag_ColumnToBeShownIndex = "";
    var Mag_ColumnToBeHidddenIndex = "";
    function OnGridExistingMagMemberListGrid_EndCallback(s, e)
    {
        Mag_ColumnToBeShownIndex = s.cpColumnToBeShownIndex;
        Mag_ColumnToBeHidddenIndex = s.cpColumnToBeHidddenIndex;

        $(".ExistingMagMemberListGrid_PreviewRow").hide();
        GetSessionStorage("ExistingMagMemberListGrid");
        SendCustomArgs_FilterControl(s, e);
        if (e.command == "REFRESH" && Magzin_IsVouchingMode == true)
        {
            s.SetFocusedRowIndex(-1);
            s.SetFocusedRowIndex(Magzin_FocusedRowBeforeRefresh);
        }
    }
    function ExistingMagMemberchangeMode() {
        ShowLoader();
        if (ExistingMagMember_ShowHorizontalBar == 0) {
            ExistingMagMember_ShowHorizontalBar = 1;
            $("#ExistingMagMemberToggleScrollBar").find("span").text("Default Data");
            $("#ExistingMagMemberToggleScrollBar").width(110);
        }
        else {
            ExistingMagMember_ShowHorizontalBar = 0;
            $("#ExistingMagMemberToggleScrollBar").find("span").text("Full Data");
            $("#ExistingMagMemberToggleScrollBar").width(90);
        }
        $.ajax({
            url: '@Url.Action("Frm_Magazine_Members_Info_Grid", "Magazine")',
            type: "GET",
            data: { ShowHorizontalBar: ExistingMagMember_ShowHorizontalBar, VouchingMode: Magzin_IsVouchingMode, ViewMode: Magazine_ViewMode, ColumnToBeHidddenIndex: Mag_ColumnToBeHidddenIndex, ColumnToBeShownIndex: Mag_ColumnToBeShownIndex  },
            success: function (res) {

                $("#ExistingMagMemberreloadPartialView").html(res);//redmine bug 133466 fix
                $(".ExistingMagMemberListGrid_PreviewRow").hide();
                GetSessionStorage("ExistingMagMemberListGrid");
            }
        });
        HideLoader();
    }
    function ExistingMagMemberAjaxSuccessForm(data) {
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.Message, "Error");
        }
        else {
            //IsSucessPopup = true;
            DevExpress.ui.dialog.alert(data.Message, "Success");
            $("#popup_frm_ExistingMagMember_Window").dxPopup("hide");
            ExistingMagMemberListGrid.Refresh();
            //IsSucessPopup = false;
        }
    }

