    function OnExistingMagMemberNewClick() {
        if ("@Magazine_AddRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        IsViewPopup = false;
        //  OpenDynamicPopup("New ~ other ExistingMagMember", "", "680", "460")
        $("#popup_frm_ExistingMagMember_Window").dxPopup("show");
        $("#popup_frm_ExistingMagMember_Window").dxPopup("instance").option("title", "New ~ ExistingMagMember");
        $("#ExistingMagMemberresult").html('');
        ShowLoader();
        $("#ExistingMagMemberresult").load("@Url.Action("Frm_ExistingMagMember_Window", "ExistingMagMember", new { @area = "Profile" })?ActionMethod=New", function () {
            HideLoader();
        });
    }

    function OnExistingMagMemberEditClick() {
        if ("@Magazine_UpdateRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        //IsViewPopup = false;
        if (ExistingMagMemberID == 'undefined' || ExistingMagMemberID == undefined) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        $.ajax({
            type: 'GET',
            url: "/Profile/ExistingMagMember/DataNavigation",
            data: { ActionMethod: "Edit", id: ExistingMagMemberID, Edit_Date: encodeURIComponent(ExistingMagMember_EditDate) },
            cache: false,
            success: function (ExistingMagMember_Edit_ButtonClick_result) {
                if (ExistingMagMember_Edit_ButtonClick_result.result == "true" || ExistingMagMember_Edit_ButtonClick_result.result == true) {
                    $("#popup_frm_ExistingMagMember_Window").dxPopup("show");
                    $("#popup_frm_ExistingMagMember_Window").dxPopup("instance").option("title", "Edit ~ ExistingMagMember");
                    $("#ExistingMagMemberresult").html('');
                    ShowLoader();
                    $("#ExistingMagMemberresult").load("@Url.Action("frm_ExistingMagMember_window", "ExistingMagMember", new { @area = "Profile" })?ActionMethod=" + "Edit" + "&ID=" + ExistingMagMemberID + "&EditedOn=" + encodeURIComponent(ExistingMagMember_EditDate), function () {
                        HideLoader();
                    });
                }
                else {
                    DevExpress.ui.dialog.alert(ExistingMagMember_Edit_ButtonClick_result.Message);
                    ExistingMagMemberListGrid.Refresh();
                }
            }
        });
    }

    function OnExistingMagMemberViewClick() {
        if ("@Magazine_ViewRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        if (ExistingMagMemberID == 'undefined' || ExistingMagMemberID == undefined) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        $.ajax({
            type: 'GET',
            url: "/Profile/ExistingMagMember/DataNavigation",
            data: { ActionMethod: "View", id: ExistingMagMemberID, Edit_Date: ExistingMagMember_EditDate.toISOString() },
            cache: false,
            success: function (ExistingMagMember_View_ButtonClick_result) {
                if (ExistingMagMember_View_ButtonClick_result.result == "true" || ExistingMagMember_View_ButtonClick_result.result == true) {
                    //IsViewPopup = true;
                    $("#popup_frm_ExistingMagMember_Window").dxPopup("show");
                    $("#popup_frm_ExistingMagMember_Window").dxPopup("instance").option("title", "View ~ ExistingMagMember");
                    $("#ExistingMagMemberresult").html('');
                    ShowLoader();
                    $("#ExistingMagMemberresult").load("@Url.Action("frm_ExistingMagMember_window", "ExistingMagMember", new { @area = "Profile" })?ActionMethod=" + "View" + "&ID=" + ExistingMagMemberID + "&EditedOn=" + encodeURIComponent(ExistingMagMember_EditDate), function () {
                        HideLoader();
                    });
