<div class="Magazine_MembersProfile_ClearReferences">
    @using DevExtreme.AspNet.Mvc;

    @model IEnumerable<dynamic>
    @{
        ViewBag.Title = "Index";
        Layout = null;
        string UserType = (string)ViewBag.UserType;
        bool Magazine_AddRight = (bool)ViewData["Magazine_AddRight"];
        bool Magazine_UpdateRight = (bool)ViewData["Magazine_UpdateRight"];
        bool Magazine_ViewRight = (bool)ViewData["Magazine_ViewRight"];
        bool Magazine_DeleteRight = (bool)ViewData["Magazine_DeleteRight"];
        bool Magazine_ExportRight = (bool)ViewData["Magazine_ExportRight"];
        bool Help_Attachment_AddRight = (bool)ViewData["Help_Attachment_AddRight"];//attachment
        bool Help_Attachment_EditRight = (bool)ViewData["Help_Attachment_EditRight"];//attachment
        bool Help_Attachment_ViewRight = (bool)ViewData["Help_Attachment_ViewRight"];//attachment
        bool Help_Attachment_DeleteRight = (bool)ViewData["Help_Attachment_DeleteRight"];//attachment
        bool Magazine_Auto_Vouching_Mode = (bool)ViewData["Magazine_Auto_Vouching_Mode"];
    }
    <div id="Magazine_Members_ParentDiv" class="col-md-12 report_header_div_main">
        <div class="col-md-4 report_header_div">
            <label class="report_header_label">Existing Magazine Members</label>
        </div>
        @*Buttons*@
        <div class="report_button_div">
            @(Html.DevExtreme().Switch().ID("MagzinVouchingModeSwitch").SwitchedOnText("Vouching On").SwitchedOffText("Vouching Off").OnValueChanged("Magzin_VouchingSwitch_ValueChange").Width(100).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
            @(Html.DevExtreme().Switch().ID("MagazineViewModeSwitch").SwitchedOnText("Compact").SwitchedOffText("Default").OnValueChanged("Magazine_ViewSwitch_ValueChange").Width(70).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
            @(Html.DevExtreme().Button()
                                                                        .ID("ExistingMagMemberModelNew")
                                                                        .Text("New")
                                                                        .Icon("add")
                                                                        .Visible(false)
                                                                        .Disabled(true)
                                                                        .OnClick(@<text>
                                                                            function () {
                                                                            OnExistingMagMemberNewClick();
                                                                            }
                                                                        </text>)
        )
            @(Html.DevExtreme().Button()
                                                                        .ID("ExistingMagMemberModelEdit")
                                                                        .Text("Edit")
                                                                         .Icon("edit")
                                                                         .Visible(false)
                                                                         .Disabled(true)
                                                                         .OnClick(@<text>
                                                                            function () {
                                                                            OnExistingMagMemberEditClick();
                                                                            }
                                                                        </text>)
        )
            @(Html.DevExtreme().Button()
                                                                        .ID("ExistingMagMemberModelDelete")
                                                                        .Text("Delete")
                                                                        .Icon("trash")
                                                                        .Visible(false)
                                                                        .Disabled(true)
                                                                        .OnClick(@<text>
                                                                            function () {
                                                                            OnExistingMagMemberDeleteClick();
                                                                            }
                                                                        </text>)
        )
            @(Html.DevExtreme().Button()
                                                                        .ID("ExistingMagMemberModelView")
                                                                        .Text("View")
                                                                        .Icon(IconID.ViewCustomers16x16devav)
                                                                        .Icon("doc")
                                                                        .Visible(false)
                                                                        .Disabled(true)
                                                                        .OnClick(@<text>
                                                                            function () {
                                                                            OnExistingMagMemberViewClick();
                                                                            }
                                                                        </text>)
        )
            @(Html.DevExtreme().Button()
                                                                        .ID("ExistingMagMemberToggleScrollBar")
                                                                        .Text(ViewBag.ShowHorizontalBar == 1 ? "Default Data" : "Full Data")
                                                                        .Width(ViewBag.ShowHorizontalBar == 1 ? 110 : 90)
                                                                        .Icon("toolbox")
                                                                        .OnClick(@<text>
                                                                            function () {
                                                                            ExistingMagMemberchangeMode();
                                                                            }
                                                                        </text>)
        )
            @(Html.DevExtreme().Button()
                                                                        .ID("ExistingMagMemberModelListPreview")
                                                                        .Text("Export")
                                                                        .Icon("save")
                                                                        .Width(80)
                                                                        .OnClick(@<text>
                                                                            function () {
                                                                            OnExistingMagMemberListPreviewClick();
                                                                            }
                                                                        </text>)
        )
            @(Html.DevExtreme().Button()
                                                                        .ID("ExistingMagMemberModelCLOSE")
                                                                        .Text("Close")
                                                                        .Icon("clear")
                                                                        .OnClick(@<text>
                                                                            function (){$(".TabPanalMenu-tabs .active span").click()}
                                                                        </text>)

        )
        </div>

    </div>
    <div class="col-md-12 no-padding">
        <form>
            <div id="ExistingMagMemberreloadPartialView" class="parent_table">
                @Html.Partial("Frm_Magazine_Members_Info_Grid", Model)
            </div>
        </form>
    </div>
    <div class="col-md-12">
        @*Add/Edit Popup*@
        @(Html.DevExtreme().Popup().CustomPopup()
                                .ID("ExistingMagMember_report_modal")
                                .OnShowing("PopupOnShowing")
                                .Title("ExistingMagMember List Preview")
                                .FullScreen(false)
                                .MaxWidth(125)
                                .Height("auto")
                                .ShowCloseButton(true)
                                .ContentTemplate(@<text>
                                    <div id="ExistingMagMember_report_modal_result">
                                    </div>
                                </text>)
    )
        @(Html.DevExtreme().Popup().CustomPopup()
                                .ID("popup_frm_ExistingMagMember_Window")
                                .Title("ExistingMagMember")
                                .OnShowing("PopupOnShowing")
                                .ShowCloseButton(true)
                                .ContentTemplate(@<text>
                                    <div id="ExistingMagMemberresult">
                                    </div>
                                </text>)
                                                .OnHiding(@<text>
                                                    function () {
                                                    if(IsSucessPopup == false && IsViewPopup == false)
                                                    {
                                                    var result = DevExpress.ui.dialog.confirm("Are you sure to cancel this entry...?", "Confirm changes");
                                                    result.done(function (dialogResult) {
                                                    if(dialogResult){
                                                    $("#popup_frm_ExistingMagMember_Window").dxPopup("hide");
                                                    }else
                                                    {
                                                    $("#popup_frm_ExistingMagMember_Window").dxPopup("show");
                                                    }
                                                    });
                                                    }
                                                    }
                                                </text>)
    )
    </div>
