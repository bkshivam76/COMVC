    }

    function OnExistingMagMemberDeleteClick() {
        if ("@Magazine_DeleteRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        //IsViewPopup = true;
        if (ExistingMagMemberID == 'undefined' || ExistingMagMemberID == undefined) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        var result = DevExpress.ui.dialog.confirm("Sure you want to delete?", "Confirm changes");
        result.done(function (dialogResult) {
            if (dialogResult) {
                $("#popup_frm_ExistingMagMember_Window_Close").dxPopup("hide");

                $.ajax({
                    type: 'GET',
                    url: "/Profile/ExistingMagMember/DataNavigation",
                    data: { ActionMethod: "Delete", id: ExistingMagMemberID, Edit_Date: ExistingMagMember_EditDate.toISOString() },
                    cache: false,
                    success: function (ExistingMagMember_Delete_ButtonClick_result) {
                        if (ExistingMagMember_Delete_ButtonClick_result.result == "true" || ExistingMagMember_Delete_ButtonClick_result.result == true) {
                            $("#popup_frm_ExistingMagMember_Window").dxPopup("show");
                            $("#popup_frm_ExistingMagMember_Window").dxPopup("instance").option("title", "Delete ~ ExistingMagMember");
                            ShowLoader();
                            $("#ExistingMagMemberresult").load("@Url.Action("frm_ExistingMagMember_window", "ExistingMagMember", new { @area = "Profile" })?ActionMethod=" + "Delete" + "&ID=" + ExistingMagMemberID + "&EditedOn=" + encodeURIComponent(ExistingMagMember_EditDate), function () {
                                HideLoader();
                            });
                        }
                        else {
                            DevExpress.ui.dialog.alert(ExistingMagMember_Delete_ButtonClick_result.Message);
                            ExistingMagMemberListGrid.Refresh();
                        }
                    }
                });
            }
        });
    }

    function OnExistingMagMemberListPreviewClick() {
        if ("@Magazine_ExportRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        $("#ExistingMagMember_report_modal").dxPopup("show");
        $("#ExistingMagMember_report_modal").dxPopup("instance").option("title", "Export Option");
        $("#ExistingMagMember_report_modal").html('');
        ShowLoader();
        $("#ExistingMagMember_report_modal_result").load("@Url.Action("Frm_Export_Options", "Magazine", new { @area = "Profile" })", function () {
            HideLoader();
        });
    }

    function GetSelectedFieldValuesCallback(values) {
        SelectedRows.BeginUpdate();
        try {
            SelectedRows.ClearItems();
            for (var i = 0; i < values.length; i++) {
                SelectedRows.AddItem(values[i]);
            }
        } finally {
            SelectedRows.EndUpdate();
        }
        $("#count").html(gvRowSelection.GetSelectedRowCount());

    }

    function ExistingMagMemberContextMenuFunction(s, e) {
        if (e.item.name == 'New') {
            OnExistingMagMemberNewClick();
        }
        if (e.item.name == 'Close') {
            btnCloseActiveTab();
        }
        else if (e.item.name == 'Edit') {
            OnExistingMagMemberEditClick();
        }
        else if (e.item.name == 'Delete') {
            OnExistingMagMemberDeleteClick();
        }
        else if (e.item.name == 'View') {
            OnExistingMagMemberViewClick();
        }
        else if (e.item.name == 'ListPreview') {
            OnExistingMagMemberListPreviewClick();
        }
        else if (e.item.name == 'Discontinue') {
            OnExistingMagMemberDiscontinueClick();
        }
        else if (e.item.name == 'continue') {
            OnExistingMagMembercontinueClick();
        }
        else if (e.item.name == 'Refresh') {
            ExistingMagMemberListGrid.Refresh();
        }

    }

</script>

    <script>
    var Magazine_Members_IsDetailRowExpanded = false;
    var Magazine_Members_NestedRecord_FocusedRowIndex = -1;
    var Magazine_Members_NestedGrid_AccessID;
    var Magazine_Members_AtachmentID;
    var Magazine_Members_FileName;
    var Magazine_Members_ParamMandatory;
    var Magazine_Members_FromDateLabel;
    var Magazine_Members_ToDateLabel;
    var Magazine_Members_DescriptionLabel;
    var Magazine_Members_Doc_ID;
    var Magazine_Members_Doc_Category;
    var Magazine_Members_MasterRowRecID;
    var Magazine_Members_MasterRowMID;
    var Magazine_Members_NestedRowMapID;
    var Magazine_Members_reason;
    var Magazine_Members_Attachment_RecStatus;
    var Magazine_Members_NestedRowReasonID;
    var Magazine_Members_NestedRowKeyValue;

    function On_Magazine_Members_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@Help_Attachment_AddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (Magazine_Members_ParamMandatory == 1)
            {
                AddAttachment(Magazine_Members_MasterRowRecID, "Magazine_Membership", Magazine_Members_Doc_ID, Magazine_Members_Doc_Category, Magazine_Members_ParamMandatory, Magazine_Members_FromDateLabel, Magazine_Members_ToDateLabel, Magazine_Members_DescriptionLabel, "Magazine_MembersProfileAttachment", null, "ExistingMagMemberListGrid", Magazine_Members_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(Magazine_Members_MasterRowRecID, "Magazine_Membership", Magazine_Members_Doc_ID, "Magazine_MembersProfileAttachment", "ExistingMagMemberListGrid", Magazine_Members_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (Magazine_Members_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(Magazine_Members_MasterRowRecID, "Magazine_Membership", Magazine_Members_AtachmentID, Magazine_Members_ParamMandatory, Magazine_Members_FromDateLabel, Magazine_Members_ToDateLabel, Magazine_Members_DescriptionLabel, "Magazine_MembersProfileAttachment", null, "ExistingMagMemberListGrid", Magazine_Members_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(Magazine_Members_MasterRowRecID, "Magazine_Membership", Magazine_Members_AtachmentID, Magazine_Members_ParamMandatory, Magazine_Members_FromDateLabel, Magazine_Members_ToDateLabel, Magazine_Members_DescriptionLabel, null, "ExistingMagMemberListGrid", Magazine_Members_NestedGrid_AccessID, Magazine_Members_Attachment_RecStatus);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@Help_Attachment_ViewRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            ViewDocument(Magazine_Members_AtachmentID, Magazine_Members_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(Magazine_Members_MasterRowRecID, "Magazine_Membership", "Existing Magazine Members", "ExistingMagMemberListGrid", Magazine_Members_NestedGrid_AccessID);
        }
        else if (e.actionName === "Add_Reason")
        {
            if (Magazine_Members_Doc_Category.toLowerCase() == "others")
            {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else
            {
                AttachmentAddReason(Magazine_Members_MasterRowRecID, Magazine_Members_NestedRowMapID, "Magazine_Membership", "ExistingMagMemberListGrid", Magazine_Members_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(Magazine_Members_MasterRowRecID, Magazine_Members_NestedRowMapID, "Magazine_Membership", "ExistingMagMemberListGrid", Magazine_Members_NestedGrid_AccessID, Magazine_Members_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(Magazine_Members_MasterRowRecID, Magazine_Members_NestedRowMapID, "ExistingMagMemberListGrid", Magazine_Members_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
        else if (e.actionName == "AuditAction")
        {
            Magazine_MembersPrf_FAB.SetActionContext("AuditActionContext", true);
        }
        else if (e.actionName == "BackAudit")
        {
            if (Magazine_Members_Nested_Doc_Status == "")
            {
                Magazine_MembersPrf_FAB.SetActionContext("AutoItemContext", true);
            }
            if (Magazine_Members_Nested_Doc_Status == "NO")
            {
                Magazine_MembersPrf_FAB.SetActionContext("EditItemContext", true);
            }
            if (Magazine_Members_Nested_Doc_Status == "YES")
            {
                Magazine_MembersPrf_FAB.SetActionContext("actionItemContext", true);
            }
        }
        else if (e.actionName == "Accept")
        {
            Magazine_Members_AcceptwithoutRemarks();
        }
        else if (e.actionName == "Reject")
        {
            Magazine_Members_AcceptRejectVoucher("Reject");
        }
        else if (e.actionName == "AcceptWithRemarks")
        {
            Magazine_Members_AcceptRejectVoucher("Accept");
        }
        else if (e.actionName == "AcceptDoc") {

            OnMagazine_Members_AcceptDoc();
        }
        else if (e.actionName == "RejectDoc") {

            OnMagazine_Members_RejectDoc();
        }
    }
    function OnMagazine_Members_RejectDoc() {
        if (Magazine_Members_AtachmentID == null || Magazine_Members_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        RejectAttachment(Magazine_Members_AtachmentID, "ExistingMagMemberListGrid", Magazine_Members_NestedGrid_AccessID);
    }
    function OnMagazine_Members_AcceptDoc() {
        if (Magazine_Members_AtachmentID == null || Magazine_Members_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        AcceptAttachment(Magazine_Members_AtachmentID, "ExistingMagMemberListGrid", Magazine_Members_NestedGrid_AccessID);
    }
    function Magazine_Members_AcceptwithoutRemarks()
    {
        var Recid;
        if (Magazine_Members_IsDetailRowExpanded == true || Magzin_IsVouchingMode == true)
        {
            if (Magazine_Members_MasterRowRecID == null || Magazine_Members_MasterRowRecID == "")
            {
                Recid = ExistingMagMemberID;
            }
            else
            {
                Recid = Magazine_Members_MasterRowRecID;
            }
        }
        else
        {
            Recid = ExistingMagMemberID;
        }
        Entry_AcceptwithoutRemarks(Recid, "Magazine_Membership", "ExistingMagMemberListGrid", Magazine_Members_AtachmentID, Magazine_Members_NestedRowReasonID, Magazine_Members_NestedRowKeyValue);
    }
    function Magazine_Members_AcceptRejectVoucher(_actionMethod)
    {
        var Recid;
        if (Magazine_Members_IsDetailRowExpanded == true || Magzin_IsVouchingMode == true)
        {
            if (Magazine_Members_MasterRowRecID == null || Magazine_Members_MasterRowRecID == "")
            {
                Recid = ExistingMagMemberID;
            }
            else
            {
                Recid = Magazine_Members_MasterRowRecID;
            }
        }
        else
        {
            Recid = ExistingMagMemberID;
        }
        Entry_AcceptReject(_actionMethod, Recid, "Magazine_Membership", "ExistingMagMemberListGrid", Magazine_Members_AtachmentID, Magazine_Members_NestedRowReasonID, Magazine_Members_NestedRowKeyValue);
    }
    function OnExistingMagMemberListGridNestedFocusedRowChange(s, e)
    {
        if (Magazine_Members_IsDetailRowExpanded == true || Magzin_IsVouchingMode == true)
        {
            Magazine_Members_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
            if (Magazine_Members_NestedRecord_FocusedRowIndex >= 0)
            {
                ShowLoader();
                Magazine_Members_NestedGrid_AccessID = s.uniqueID;
                s.GetRowValues(s.GetFocusedRowIndex(), 'Doc_Status;Params_Mandatory;LABEL_FROM_DATE;LABEL_TO_DATE;LABEL_DESCRIPTION;Document_Category;Document_ID;ATTACH_ID;TxnID;TxnMID;MAP_ID;Reason;ATTACH_FILE_NAME;Attachment_Action_Status;UniqueID;ReasonID', OnMagazine_Members_GetGridRowValues);
            }
            else
            {
                Magazine_MembersPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }
    function OnMagazine_Members_GetGridRowValues(values)
    {
        HideLoader();
        if (values[14] != null)
        {
            Magazine_MembersPrf_FAB.SetVisible(true);
            Magazine_Members_Nested_Doc_Status = values[0];
            if (Magzin_IsVouchingMode == true)
            {
                Magazine_MembersPrf_FAB.SetActionContext("AuditActionContext", true);
            }
            else
            {
                if (Magazine_Members_Nested_Doc_Status == "")
                {
                    Magazine_MembersPrf_FAB.SetActionContext("AutoItemContext", true);
                }
                else if (Magazine_Members_Nested_Doc_Status == "NO")
                {
                    Magazine_MembersPrf_FAB.SetActionContext("EditItemContext", true);
                }
                else if (Magazine_Members_Nested_Doc_Status == "YES")
                {
                    Magazine_MembersPrf_FAB.SetActionContext("actionItemContext", true);
                }
            }
            Magazine_Members_ParamMandatory = values[1];
            Magazine_Members_FromDateLabel = values[2];
            Magazine_Members_ToDateLabel = values[3];
            Magazine_Members_DescriptionLabel = values[4];
            Magazine_Members_Doc_Category = values[5];
            Magazine_Members_Doc_ID = values[6];
            Magazine_Members_AtachmentID = values[7];
            IndexAttachmentID = Magazine_Members_AtachmentID;
            Magazine_Members_MasterRowRecID = values[8];
            Magazine_Members_MasterRowMID = values[9];
            Magazine_Members_NestedRowMapID = values[10];
            Magazine_Members_reason = values[11];
            Magazine_Members_FileName = values[12];
            Magazine_Members_Attachment_RecStatus = values[13];
            Magazine_Members_NestedRowKeyValue = values[14];
            if (Magzin_IsVouchingMode == true)
            {
                if (Magazine_Members_FileName != null && Magazine_Members_FileName.length > 0)
                {
                    ViewDocument(Magazine_Members_AtachmentID, Magazine_Members_FileName, "Magazine_MembersPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else
                {
                    CloseRightPane();
                    ClearRightPane();
                }
            }
        }
        Magazine_Members_NestedRowReasonID = values[15];
        IndexAttachmentReasonID = Magazine_Members_NestedRowReasonID;
    }
    function ExistingMagMemberGrid_Nested_BeginCallBack(s, e)
    {
        e.customArgs["ShowHorizontalBar"] = ExistingMagMember_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = Magzin_IsVouchingMode;
        e.customArgs["command"] = e.command;
    }
    function ExistingMagMemberGrid_DetailRowExpanding(s, e)
    {
        Magazine_Members_IsDetailRowExpanded = true;
        s.SetFocusedRowIndex(e.visibleIndex);
        var pane = Mainspliter.GetPaneByName('RightPane');
        if (Magzin_IsVouchingMode == true)
        {
            pane.Expand();
        }
        else
        {
            pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
        }
    }
    function ExistingMagMemberGrid_DetailRowCollapsing(s, e)
    {
        Magazine_Members_IsDetailRowExpanded = false;
        s.SetFocusedRowIndex(e.visibleIndex);
        if (Magzin_IsVouchingMode == true)
        {
            if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false)
            {
                CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
        else
        {
            Magazine_MembersPrf_FAB.SetVisible(false);
        }
    }
    </script>
    @*attachment and nested grid*@
</div>