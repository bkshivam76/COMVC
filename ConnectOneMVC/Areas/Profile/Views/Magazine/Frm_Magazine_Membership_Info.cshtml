@using DevExtreme.AspNet.Mvc;

@model IEnumerable<dynamic>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div id="content" class="col-md-12">

    @*Buttons*@
    <div style="float:right;margin-bottom:20px;">
        @(Html.DevExtreme().Button()
                                        .ID("MagMemberModelNew")
                                        .Text("New")
                                        .Icon("add")
                                        .OnClick(@<text>
                                            function () {
                                            OnNewClick();
                                            }
                                        </text>)
        )

        @(Html.DevExtreme().Button()
                                        .ID("MagMemberModelEdit")
                                        .Text("Edit")
                                         .Icon("edit")
                                         .OnClick(@<text>
                                            function () {
                                            OnEditClick();
                                            }
                                        </text>)
        )

        @(Html.DevExtreme().Button()
                                        .ID("MagMemberModelDelete")
                                        .Text("Delete")
                                        .Icon("trash")
                                        .OnClick(@<text>
                                            function () {
                                            OnDeleteClick();
                                            }
                                        </text>)
        )

        @(Html.DevExtreme().Button()
                                        .ID("MagMemberModelView")
                                        .Text("View")
                                        .Icon(IconID.ViewCustomers16x16devav)
                                        .Icon("doc")
                                        .OnClick(@<text>
                                            function () {
                                            OnViewClick();
                                            }
                                        </text>)
        )

        @(Html.DevExtreme().Button()
                                        .ID("MagMemberModelListPreview")
                                        .Text("Export")
                                        .Icon("print")
                                        .Width(80)
                                        .OnClick(@<text>
                                            function () {
                                            OnListPreviewClick();
                                            }
                                        </text>)
        )
        <br />
    </div>
    <div id="MagMemberreloadPartialView">
        @Html.Partial("Frm_Magazine_Membership_Info_Grid", Model)
    </div>
</div>
<div class="col-lg-12" id="FooterItem">
    @(Html.DevExtreme().Button()
                                    .ID("MagMemberCreateFilterButton")
                                    .Icon("todo")
                                    .Hint("Open Filter Builder")
                                    .ElementAttr(new Dictionary<string, object>() { { "class", "float-right" } })
                                    .OnClick(@<text>
                                        function () {
                                        MagMemberCreateFilterClick();
                                        }
                                    </text>)
    )

    @(Html.DevExtreme().Button()
                                    .ID("MagMemberShowFooter")
                                    .Icon("overflow")
                                    .Hint("Show  footer")
                                    .ElementAttr(new Dictionary<string, object>() { { "class", "float-right" } })
                                    .OnClick(@<text>
                                        function () {
                                        SetMagMemberFooterVisible();
                                        }
                                    </text>)
    )

    @(Html.DevExtreme().Button()
                                    .ID("MagMemberShowGroupFooter")
                                    .Icon("overflow")
                                    .Hint("Show Group footer")
                                    .ElementAttr(new Dictionary<string, object>() { { "class", "float-right" } })
                                    .OnClick(@<text>
                                        function () {
                                        SetMagMemberGroupPanelFooterVisible();
                                        }
                                    </text>)
    )

    @(Html.DevExtreme().Button()
                                        .ID("MagMemberGroupColumn")
                                        .Icon("group")
                                        .Hint("Show column Group")
                                        .ElementAttr(new Dictionary<string, object>() { { "class", "float-right" } })
                                        .OnClick(@<text>
                                            function () {
                                            OnMagMemberGroupeClick();
                                            }
                                        </text>)
    )

    @(Html.DevExtreme().Button()
                                        .ID("btShowGroupPanel")
                                        .Icon("spinup")
                                        .Hint("Show Group Box")
                                        .ElementAttr(new Dictionary<string, object>() { { "class", "float-right" } })
                                        .OnClick(@<text>
                                            function () {
                                            ShowGroupPanel();
                                            }
                                        </text>)
    )

    @(Html.DevExtreme().Button()
                                        .ID("btShowColumnChooser")
                                        .Icon("add")
                                        .Hint("Show Column Chooser")
                                        .ElementAttr(new Dictionary<string, object>() { { "class", "float-right" } })
                                        .OnClick(@<text>
                                            function () {
                                            ShowColumnChooser();
                                            }
                                        </text>)
    )

</div>
<div id="setFooterItem">
    <div class="footer-inner">
        <div class="row">
            <div class="col-sm-2 header-margin-right">
                <div class="footer-text">
                    <div id="Lbl_Status" style="font-size:23px"></div>
                    @*<p id="Lbl_StatusOn"></p>*@
                    @*<p id="Lbl_StatusBy"></p>*@
                </div>
            </div>
            <div class="col-sm-10">
                <div class="footer-text">
                    <p id="Lbl_Create"></p>
                    <p id="Lbl_Modify"></p>
                </div>
            </div>
        </div>
        <div class="footer-filter">
            @Html.DevExpress().TrackBar(
                   tb =>
                   {
                       tb.Name = "trackBar";
                       tb.Properties.ScalePosition = ScalePosition.LeftOrTop;
                       tb.Properties.ValueToolTipPosition = ValueToolTipPosition.RightOrBottom;
                       tb.Properties.ValueType = typeof(string);
                       tb.Width = 150;
                       tb.Position = 2;
                       tb.ControlStyle.CssClass = "float-right";
                       tb.Properties.ScalePosition = ScalePosition.None;
                   }
               ).GetHtml()

            @(Html.DevExtreme().Button()
                                        .ID("MagMemberSearch")
                                        .Text("Find")
                                        .Icon("find")
                                        .Hint("Show search")
                                        .ElementAttr(new Dictionary<string, object>() { { "class", "float-right" } })
                                        .OnClick(@<text>
                                            function () {
                                            OnMagMemberSearchClick();
                                            }
                                        </text>))

            @(Html.DevExtreme().Button()
                                        .ID("MagMemberFind")
                                        .Text("Filter")
                                        .Icon("find")
                                        .Hint("Show filter")
                                        .ElementAttr(new Dictionary<string, object>() { { "class", "float-right" } })
                                        .OnClick(@<text>
                                            function () {
                                            OnMagMemberFilterClick();
                                            }
                                        </text>)
            )


        </div>
    </div>
</div>

@*Add/Edit Popup*@
@(Html.DevExtreme().Popup().CustomPopup()
                .ID("popup_frm_Magazine_Membership_Window_Export")
                .Title("Magazine Membership")
                .OnShowing("PopupOnShowing")
                .MinHeight(150)
                .MaxHeight(500)
                .MinWidth(400)
                .MaxWidth(1000)
                .ContentTemplate(  @<text><div id=myid>
                        <text>
                            @*@Html.Partial("ToolbarExport", ConnectOneMVC.Helper.GridViewExportDemoHelper.ExportFormatsInfo.Keys)*@
