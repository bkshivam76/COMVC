        //FAB related. partial view name is Attachment.cshtml
        function On_MembershipWw_FABActionItemClick(s, e)
        {
            debugger;
            var img = document.getElementById('RightPane_Img');
            s.ExpandActionGroupItems();
            if (e.actionName === "add_attach")
            {
                if ("@ViewData["Help_Attachment_AddRight"]" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                if (MembershipWw_ParamMandatory == 1)
                {
                    AddAttachment(MembershipWw_MasterRowRecID, "Profile_Membership", MembershipWw_Doc_ID, MembershipWw_Doc_Category, MembershipWw_ParamMandatory, MembershipWw_FromDateLabel, MembershipWw_ToDateLabel, MembershipWw_DescriptionLabel, "MembershipWwProfileAttachment", null, "MembershipWithWingListGrid", MembershipWw_NestedGrid_AccessID);
                }
                else
                {
                    Attachment_DirectBrowse(MembershipWw_MasterRowRecID, "Profile_Membership", MembershipWw_Doc_ID, "MembershipWwProfileAttachment", "MembershipWithWingListGrid", MembershipWw_NestedGrid_AccessID);
                }
            }
            else if (e.actionName === "edit_attach")
            {
                if ("@ViewData["Help_Attachment_EditRight"]" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                if (MembershipWw_Attachment_RecStatus.toUpperCase() == "LOCKED")
                {
                    DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                    return;
                }
                EditAttachment(MembershipWw_MasterRowRecID, "Profile_Membership", MembershipWw_AtachmentID, MembershipWw_ParamMandatory, MembershipWw_FromDateLabel, MembershipWw_ToDateLabel, MembershipWw_DescriptionLabel, "MembershipWwProfileAttachment", null, "MembershipWithWingListGrid", MembershipWw_NestedGrid_AccessID);
            }
            else if (e.actionName === "delete_attach")
            {
                if ("@ViewData["Help_Attachment_DeleteRight"]" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                DeleteAttachment(MembershipWw_MasterRowRecID, "Profile_Membership", MembershipWw_AtachmentID, MembershipWw_ParamMandatory, MembershipWw_FromDateLabel, MembershipWw_ToDateLabel, MembershipWw_DescriptionLabel, null, "MembershipWithWingListGrid", MembershipWw_NestedGrid_AccessID, MembershipWw_Attachment_RecStatus);
            }
            else if (e.actionName === "view_attach")
            {
                if ("@ViewData["Help_Attachment_ViewRight"]" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                ViewDocument(MembershipWw_AtachmentID, MembershipWw_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
            }
            else if (e.actionName == "Link_Attach")
            {
                LinkAttachment(MembershipWw_MasterRowRecID, "Profile_Membership", "Land & Building Information", "MembershipWithWingListGrid", MembershipWw_NestedGrid_AccessID);
            }
            else if (e.actionName === "Add_Reason")
            {
                if (MembershipWw_Doc_Category.toLowerCase() == "others")
                {
                    DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
                }
                else
                {
                    AttachmentAddReason(MembershipWw_MasterRowRecID, MembershipWw_NestedRowMapID, "Profile_Membership", "MembershipWithWingListGrid", MembershipWw_NestedGrid_AccessID);
                }
            }
            else if (e.actionName === "Edit_Reason")
            {
                AttachmentEditReason(MembershipWw_MasterRowRecID, MembershipWw_NestedRowMapID, "Profile_Membership", "MembershipWithWingListGrid", MembershipWw_NestedGrid_AccessID, MembershipWw_reason);
            }
            else if (e.actionName === "Delete_Reason")
            {
                AttachmentDeleteReason(MembershipWw_MasterRowRecID, MembershipWw_NestedRowMapID, "MembershipWithWingListGrid", MembershipWw_NestedGrid_AccessID);
            }
            else if (e.actionName === "Rotate")
            {
                ImageRotate(img);
            }
            else if (e.actionName === "ZoomOut")
            {
                ImageZoomOut(img);
            }
            else if (e.actionName === "ZoomIn")
            {
                ImageZoomIn(img);
            }
            else if (e.actionName == "Fit")
            {
                ImageFit(img);
            }
            else if (e.actionName == "Back")
            {
                ImageBack(s.uniqueID, "actionItemContext");
            }
            else if (e.actionName == "AuditAction")
            {
                MembershipWw_FAB.SetActionContext("AuditActionContext", true);
            }
            else if (e.actionName == "BackAudit")
            {
                if (MembershipWw_Nested_Doc_Status == "")
                {
                    MembershipWw_FAB.SetActionContext("AutoItemContext", true);
                }
                if (MembershipWw_Nested_Doc_Status == "NO")
                {
                    MembershipWw_FAB.SetActionContext("EditItemContext", true);
                }
                if (MembershipWw_Nested_Doc_Status == "YES")
                {
                    MembershipWw_FAB.SetActionContext("actionItemContext", true);
                }
            }
            else if (e.actionName == "Accept")
            {
                MembershipWw_AcceptwithoutRemarks();
            }
            else if (e.actionName == "Reject")
            {
                MembershipWw_AcceptRejectVoucher("Reject");
            }
            else if (e.actionName == "AcceptWithRemarks")
            {
                MembershipWw_AcceptRejectVoucher("Accept");
            }
            else if (e.actionName == "AcceptDoc")
            {
                OnMembershipWw_AcceptDoc();
            }
            else if (e.actionName == "RejectDoc")
            {
                OnMembershipWw_RejectDoc();
            }
        }

        function OnMembershipWw_RejectDoc()
        {
            if (MembershipWw_AtachmentID == null || MembershipWw_AtachmentID.length == 0)
            {
                DevExpress.ui.dialog.alert("No Document Attached..", "Error");
                return;
            }
            RejectAttachment(MembershipWw_AtachmentID, "MembershipWithWingListGrid", MembershipWw_NestedGrid_AccessID);
        }
    function OnMembershipWw_AcceptDoc() {
        if (MembershipWw_AtachmentID == null || MembershipWw_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        AcceptAttachment(MembershipWw_AtachmentID, "MembershipWithWingListGrid", MembershipWw_NestedGrid_AccessID);
    }
    function MembershipWw_AcceptwithoutRemarks() {
        MembershipWw_MasterRowMID;
        var Recid;
        if (MembershipWw_IsDetailRowExpanded == true || MembershipWw_IsVouchingMode == true) {
            if (MembershipWw_MasterRowRecID == null || MembershipWw_MasterRowRecID == "") {
                Recid = WingMemberID;
            }
            else {
                Recid = MembershipWw_MasterRowRecID;
            }
        }
        else {
            Recid = WingMemberID;
        }
        Entry_AcceptwithoutRemarks(Recid, "Profile_Membership", "MembershipWithWingListGrid", MembershipWw_AtachmentID, MembershipWw_NestedRowReasonID, MembershipWw_NestedRowKeyValue);
    }
    function MembershipWw_AcceptRejectVoucher(_actionMethod) {
        debugger;
        MembershipWw_MasterRowMID;
        var Recid;
        if (MembershipWw_IsDetailRowExpanded == true || MembershipWw_IsVouchingMode == true) {
            if (MembershipWw_MasterRowRecID == null || MembershipWw_MasterRowRecID == "") {
                Recid = WingMemberID;
            }
            else {
                Recid = MembershipWw_MasterRowRecID;
            }
        }
        else {
            Recid = WingMemberID;
        }
        Entry_AcceptReject(_actionMethod, Recid, "Profile_Membership", "MembershipWithWingListGrid", MembershipWw_AtachmentID, MembershipWw_NestedRowReasonID, MembershipWw_NestedRowKeyValue);
    }

    </script>


