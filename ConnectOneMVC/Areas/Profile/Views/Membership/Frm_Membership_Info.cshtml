        //Show Listing button on click function
        function ShowListing_Membership_Ww()
        {
            debugger;
            /*if ($("#Txt_Str_Membership_Ww").dxTextBox("instance").option("value").length < 3) { return; }*/
            TextStringText_Ww = $("#Txt_Str_Membership_Ww").dxTextBox("instance").option("value");
            SelectedWing_Ww = $("#GLookUp_WingList_Membership_Ww").dxDropDownBox("instance").option("value");
            var selectBoxVal = $("#Cmb_ListBy_Membership_Ww").dxSelectBox("instance").option("value");
            switch (selectBoxVal)
            {
                case "WING WISE":
                    if (SelectedWing_Ww == null)
                    {
                        alert("Incomplete Information..." + "\n" + "Wing Name Not Selected...!");
                        return;
                    }
                    other_condition = " AND MS.MS_WING_ID = '" + SelectedWing_Ww + "' ";
                    break;
                case "MEMBERSHIP NO.":
                    if (TextStringText_Ww.trim().length < 3)
                    {
                        alert("Incomplete Information..." + "\n" + "Text cannot be Blank/Minimum 3 Characters required..!");
                        return;
                    }
                    other_condition = " AND MS.MS_NO LIKE '%" + TextStringText_Ww + "%' ";
                    break;
                case "MEMBER NAME":
                    if (TextStringText_Ww.trim().length < 3)
                    {
                        alert("Incomplete Information..." + "\n" + "Text cannot be Blank/Minimum 3 Characters required..!");
                        return;
                    }
                    other_condition = " AND AB.C_NAME LIKE '%" + TextStringText_Ww + "%' ";
                    break;
                case "CENTRE NAME":
                    if (TextStringText_Ww.trim().length < 3)
                    {
                        alert("Incomplete Information..." + "\n" + "Text cannot be Blank/Minimum 3 Characters required..!");
                        return;
                    }
                    other_condition = " AND CASE WHEN COALESCE(AB.C_CEN_CATEGORY,0) = 0 THEN C.CEN_NAME ELSE O.CEN_NAME END LIKE '%" + TextStringText_Ww + "%' ";
                    break;
                case "CENTRE UID":
                    if (TextStringText_Ww.trim().length < 3)
                    {
                        alert("Incomplete Information..." + "\n" + "Text cannot be Blank/Minimum 3 Characters required..!");
                        return;
                    }
                    other_condition = " AND CASE WHEN COALESCE(AB.C_CEN_CATEGORY,0) = 0 THEN C.CEN_UID ELSE O.CEN_UID END LIKE '%" + TextStringText_Ww + "%' ";
                    break;
                case "DISCONTINUED MEMBER":
                    if (TextStringText_Ww.trim().length < 3)
                    {
                        alert("Incomplete Information..." + "\n" + "Text cannot be Blank/Minimum 3 Characters required..!");
                        return;
                    }
                    other_condition = " AND AB.C_NAME LIKE '%" + TextStringText_Ww + "%' AND  MS.MS_CLOSE_DATE IS NOT NULL ";
            }
            MembershipWithWingListGrid.Refresh();
        }
