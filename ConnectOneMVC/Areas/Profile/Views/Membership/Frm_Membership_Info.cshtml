        function Cmb_ListBy_SelectedIndexChanged_Membership_Ww(e)
        {
            //Here SearchBy_MembershipWw and selectBoxVal are same. to note the two types of code returns same value, I have written like that.
            debugger;
            SearchBy_MembershipWw = e.value
            var selectBoxVal = $("#Cmb_ListBy_Membership_Ww").dxSelectBox("instance").option("value");
            //var indexInDataSource = e.component.getDataSource().items().indexOf(selectBoxVal);
