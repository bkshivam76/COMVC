                            visible: true,
                            readOnly: false,
                            placeholder: "Type Centre Name..."
                        });
                        $("#Txt_Str_Membership_Ww").dxTextBox("focus");
                        break;

                    case "CENTRE UID":
                        $("#GLookUp_WingList_Membership_Ww").dxDropDownBox({
                            visible: false,
                        });
                        $("#GLookUp_WingList_Membership_Ww").dxDropDownBox("focus");
                        $("#Txt_Str_Membership_Ww").dxTextBox({
                            visible: true,
                            readOnly: false,
                            placeholder: "Type Centre UID..."
                        });
                        $("#Txt_Str_Membership_Ww").dxTextBox("focus");
                        break;

                    case "DISCONTINUED MEMBER":
                        $("#GLookUp_WingList_Membership_Ww").dxDropDownBox({
                            visible: false,
                        });
                        $("#GLookUp_WingList_Membership_Ww").dxDropDownBox("focus");
                        $("#Txt_Str_Membership_Ww").dxTextBox({
                            visible: true,
                            readOnly: false,
                            placeholder: "Type Membership Name..."
                        });
                        $("#Txt_Str_Membership_Ww").dxTextBox("focus");
                        break;
                }

            }
            if (SearchBy_MembershipWw == '' || SearchBy_MembershipWw == null)
            {
                $("#Txt_Str_Membership_Ww").dxTextBox({
                    value: "",
                    readOnly: true
                });
                $("#GLookUp_WingList_Membership_Ww").dxDropDownBox({
