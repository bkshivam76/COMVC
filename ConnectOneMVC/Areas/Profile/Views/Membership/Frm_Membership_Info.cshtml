        //This is the replication of "Creationdetail()" in the windows code
        function MembershipWw_UpdateFooterDetail(ID, MembershipWw_Action_Status, MembershipWw_Add_Date, MembershipWw_Add_By, MembershipWw_Action_Date, MembershipWw_Action_By, MembershipWw_Edit_Date, MembershipWw_Edit_By)
        {
            debugger;
            HideLoader();
            var Status = "";
            var MembershipWw_Status = "";
            var MembershipWw_StatusBy = "";
            var Pic_Status = "";
            var MembershipWw_Create = "";
            var MembershipWw_Modify = "";
            var MembershipWw_Status_Color = "";
            var MembershipWw_ActionOn = "";
            var MembershipWw_ActionBy = "";
            var StatusStr = "";
            if (ID != null)
            {
                MembershipWw_Add_Date = (moment(MembershipWw_Add_Date, "DD/MM/YYYY HH:mm:ss").format("DD/MM/YYYY HH:mm:ss"));
                MembershipWw_Edit_Date = (moment(MembershipWw_Edit_Date, "DD/MM/YYYY HH:mm:ss").format("DD/MM/YYYY HH:mm:ss"));
                MembershipWw_Action_Date = (moment(MembershipWw_Action_Date, "DD/MM/YYYY HH:mm:ss").format("DD/MM/YYYY HH:mm:ss"));
                Status = MembershipWw_Action_Status;
                StatusStr = Status == "Locked" ? "Locked" : Status == null ? null : "UnLocked";
                if (Status && Status.toUpperCase() == "LOCKED")
                {
                    MembershipWw_Status = "Completed";
                    MembershipWw_Status_Color = "blue";
                    Pic_Status = "fa fa-lock";
                }
                else
                {
                    Pic_Status = "fa fa-unlock";
                    MembershipWw_Status = Status;
                    if (Status && Status.toUpperCase() == "COMPLETED")
                    {
                        MembershipWw_Status_Color = "green";
                    }
                    else
                    {
                        MembershipWw_Status_Color = "red";
                    }
                }
                if (MembershipWw_Action_Date)
                {
                    MembershipWw_ActionOn = StatusStr + " On: " + MembershipWw_Action_Date;
                    MembershipWw_ActionBy = StatusStr + " By: " + MembershipWw_Action_By;
                }

                else
                {
                    MembershipWw_ActionOn = "";
                    MembershipWw_ActionBy = "";
                }
                if (MembershipWw_Add_Date)
                {
                    MembershipWw_Create = "Add On: " + MembershipWw_Add_Date + ", By: " + MembershipWw_Add_By;
                }
                else
                {
                    MembershipWw_Create = "";
                }

                if (MembershipWw_Edit_Date)
                {
                    MembershipWw_Modify = "Edit On: " + MembershipWw_Edit_Date + ", By: " + MembershipWw_Edit_By;
                }
                else
                {
                    MembershipWw_Modify = "";
                }
            }
            $('#MembershipWw_Status').text(MembershipWw_Status);
            $('#MembershipWw_ActionOn').text(MembershipWw_ActionOn);
            $('#MembershipWw_ActionBy').text(MembershipWw_ActionBy);
            $('#MembershipWw_Create').text(MembershipWw_Create);
            $('#MembershipWw_Modify').text(MembershipWw_Modify);
            if (MembershipWw_Status_Color != "")
            {
                $('#MembershipWw_Status').css('color', MembershipWw_Status_Color);
            }
            if (Pic_Status == "fa fa-lock")
            {
                $('#MembershipWw_LockICON').addClass(Pic_Status).removeClass("fa-unlock");
            }
            else if (Pic_Status == "fa fa-unlock")
            {
                $('#MembershipWw_LockICON').addClass(Pic_Status).removeClass("fa-lock");
            }
            else
            {
                $('#MembershipWw_LockICON').removeClass("fa");
                $('#MembershipWw_LockICON').removeClass("fa-lock");
                $('#MembershipWw_LockICON').removeClass("fa-unlock");
            }
        }

        function MembershipWwOnInit()   // This function is to set height of the grid
        {
            MembershipWwAdjustSize();
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt)
            {
                MembershipWwAdjustSize();
