                        .ID("MembershipWithWingModelListPreview")
                        .Text("Unlock")
                        .Icon("save")
                        .Width(90)
                        .OnClick(@<text> function () { Membership_WwOnUnLockClick(); } </text>) )*@

                    @(Html.DevExtreme().Button()
                    .ID("MembershipWithWingModelCLOSE")
                    .Text("Close")
                    .Icon("clear")
                    .Width(90)
                    .OnClick(@<text> function (){closeMembershipWw();} </text>) )

                </div>
            </div>
        </div>
