        //This is Begin Call back function of the grid to send the Parameters
        function MembershipWithWing_BeginCallBack(s, e) //s sender and e - event
        {
            MembershipWw_FocusedRowBeforeRefresh = s.GetFocusedRowIndex();
            debugger;
            e.customArgs["command"] = e.command;
            e.customArgs["ShowHorizontalBar"] = MembershipWw_ShowHorizontalBar;
            e.customArgs["OtherCondition"] = other_condition;

            if ($("#Look_SubsList_Membership_Ww").dxDropDownBox("instance").option("value") == "ALL")
            {
                other_condition1 = "";
            }
            else
            {
                other_condition1 = " AND  CASE WHEN SI.SI_NAME = 'ANNUAL' THEN 'ANNUAL' ELSE 'LIFE' END ='" + $("#Look_SubsList_Membership_Ww").dxDropDownBox("instance").option("value") + "' ";
            }
            e.customArgs["OtherCondition_1"] = other_condition1;
            e.customArgs["VouchingMode"] = MembershipWw_IsVouchingMode;
