            $("#MembershipWithWingListGrid").hover(function ()
            {
                MembershipWithWingListGrid.Focus()
            });
        }

        // This is to set the vertical height of the grid after setting vertical scrollbar visible in the grid view page.
        function MembershipWwAdjustSize()
        {
            var height = (document.documentElement.clientHeight * 90) / 100;
            try
            {
                MembershipWithWingListGrid.SetHeight(height);
            }
            catch (err)
            {

            }
        }



        //Full Data
        function MembershipWw_changeMode()
        {
            debugger;
            ShowLoader();
            if (MembershipWw_ShowHorizontalBar == 0)
            {
                MembershipWw_ShowHorizontalBar = 1;
                $("#MembershipWwToggleScrollBar").find("span").text("Default Data");
                $("#MembershipWwToggleScrollBar").width(130);
            }
            else
            {
                MembershipWw_ShowHorizontalBar = 0;
                $("#MembershipWwToggleScrollBar").find("span").text("Full Data");
                $("#MembershipWwToggleScrollBar").width(130);
            }
            $.ajax({
                url: "/Profile/Membership/Frm_Membership_Ww_Info_Grid",
