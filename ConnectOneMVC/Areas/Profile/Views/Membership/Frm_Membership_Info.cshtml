                                        })
                                    )
                                </div>
                                <div class="col-sm-3 col-md-3 col-lg-3">
                                    @(Html.DevExtreme().TextBox()
                                    .CustomTextBox(true, true) //This (true, true) is for sql datavalidation of entered text and
                                                                //Next true is to make the entered text to capital.
                                    .ID("Txt_Str_Membership_Ww")
                                    .Name("Txt_Str_Membership_Ww")
                                    .Value(Model.Txt_Str_Membership_Ww)
