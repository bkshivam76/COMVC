                },
                success: function (res)
                {
                    $("#Membership_Ww_GridPartialView").html(res);
                    if (MembershipWw_IsVouchingMode == true)
                    {
                        $(".MembershipWithWingListGrid_PreviewRow").hide();
                    }
                    else
                    {
                        $(".MembershipWithWingListGrid_PreviewRow").show();
                    }
                    GetSessionStorage("MembershipWithWingListGrid");
                }
            });
            HideLoader();
        }

        function MembershipWwGrid_DetailRowExpanding(s, e)
        {
            debugger;
            MembershipWw_IsDetailRowExpanded = true;
            s.SetFocusedRowIndex(e.visibleIndex);
            var pane = Mainspliter.GetPaneByName('RightPane');
            if (MembershipWw_IsVouchingMode == true)
            {
                pane.Expand();
            }
            else
            {
                pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
            }
        }

        function MembershipWwGrid_DetailRowCollapsing(s, e)
        {
            debugger;
            MembershipWw_IsDetailRowExpanded = false;
            s.SetFocusedRowIndex(e.visibleIndex);
            if (MembershipWw_IsVouchingMode == true)
            {
                if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false)
                {
                    CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
                }
            }
            else
            {
                MembershipWw_FAB.SetVisible(false);
            }
        }
