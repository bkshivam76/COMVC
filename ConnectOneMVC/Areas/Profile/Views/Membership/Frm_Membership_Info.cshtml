                /*if ($("#Txt_Str_Membership_Ww").dxTextBox("instance").option("value").length < 3) { return; }*/
                switch (selectBoxVal)
                {
                    case "WING WISE":
                        $("#GLookUp_WingList_Membership_Ww").dxDropDownBox({
                            visible: true
                        });
                        $("#GLookUp_WingList_Membership_Ww").dxDropDownBox("focus");
                        $("#Txt_Str_Membership_Ww").dxTextBox({
                            visible: false,
                            readOnly: true,
                            placeholder: ""
                        });
