    // Switch button onchange codes
        function MembershipWw_VouchingSwitch_ValueChange(e)
        {
            ShowLoader();
            MembershipWw_IsVouchingMode = e.value;
            if (MembershipWw_SetVouchingModeOn == true) {
                MembershipWw_SetVouchingModeOn = false;
            }
            else {
                MembershipWw_FAB.SetVisible(false);
            }
            if (MembershipWw_IsVouchingMode == true) {
                OpenRightPane();
                ClearLeftPane();
                OpenLeftPane();
            }
            else {
                MembershipWw_FAB.SetActionContext("AddAttachmentContext", false);
                CloseRightPane();
                ClearLeftPane();
                CloseLeftPane();
            }
            MembershipWithWingListGrid_CollapseAllDetailRows();
        }
        function MembershipWw_ViewSwitch_ValueChange(e)
        {
            debugger;
            ShowLoader();
            MembershipWw_ViewMode = e.value == false ? "Default" : "Compact";
            if (MembershipWw_SetVouchingModeOn == true)
            {
                $("#MembershipWwVouchingModeSwitch").dxSwitch("instance").option("value", true);
            }
            else
            {
                if (MembershipWw_IsVouchingMode == false)
                {
                    MembershipWw_FAB.SetVisible(false);
                }
                //MembershipWithWingListGrid.CollapseAllDetailRows();
                MembershipWithWingListGrid_CollapseAllDetailRows();
            }
            HideLoader();
        }

        function MembershipWithWingListGrid_CollapseAllDetailRows()
        {
            ShowLoader();
            if (typeof window !== 'undefined')
            {
                if (typeof window.MembershipWithWingListGrid !== 'undefined')
                {
                    if (typeof window.MembershipWithWingListGrid.CollapseAllDetailRows !== 'undefined')
                    {
                        if (typeof MembershipWithWingListGrid.CollapseAllDetailRows == 'function')
                        {
                            HideLoader();
                            MembershipWithWingListGrid.SetFocusedRowIndex(-1);
                            MembershipWithWingListGrid.CollapseAllDetailRows();
                        }
                        else
                        {
                            alert("CollapseAllDetailRows is not a function");
                        }
                    }
                    else
                    {
                        ShowLoader();
                        setTimeout(function ()
                        {
                            MembershipWithWingListGrid_CollapseAllDetailRows();
                            HideLoader();
                        }, 500);
                    }
                }
                else
                {
                    alert('grid undefined')
                }
            }
            else
            {
                alert('window undefined')
            }
        }


