@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("LookUp_GetSubsList_Membership_Wow_datagrid")
    .Columns(columns =>
    {
        columns.Add().DataField("SI_REC_ID").Caption("ID").Visible(false);
        columns.Add().DataField("SI_NAME").Caption("Name").Visible(true);
        columns.Add().DataField("SI_CATEGORY").Caption("Category").Visible(false);
        columns.Add().DataField("SI_START_MONTH").Caption("Start Month").Visible(false);
        columns.Add().DataField("SI_TOTAL_MONTH").Caption("Total Month").Visible(false); 
    })

    .Selection(s => s.Mode(SelectionMode.Single))
    .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}")
)
