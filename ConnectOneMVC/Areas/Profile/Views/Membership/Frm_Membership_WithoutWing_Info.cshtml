            }
            else {
                MembershipWow_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }

    function MembershipWow_Vouching_Grid_Nested_BeginCallBack(s, e) {
        debugger;
        e.customArgs["ShowHorizontalBar"] = MembershipWow_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = MembershipWow_IsVouchingMode;
        e.customArgs["command"] = e.command;
        e.customArgs["RecID"] = MembershipWowID;
    }

    //FAB related. partial view name is Attachment.cshtml
    function On_MembershipWow_FABActionItemClick(s, e) {
        debugger;
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@ViewData["Help_Attachment_AddRight"]" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (MembershipWow_ParamMandatory == 1)
            {
                AddAttachment(MembershipWow_MasterRowRecID, "Profile_Membership", MembershipWow_Doc_ID, MembershipWow_Doc_Category, MembershipWow_ParamMandatory, MembershipWow_FromDateLabel, MembershipWow_ToDateLabel, MembershipWow_DescriptionLabel, "MembershipWowProfileAttachment", null, "MembershipWithoutWingListGrid", MembershipWow_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(MembershipWow_MasterRowRecID, "Profile_Membership", MembershipWow_Doc_ID, "MembershipWowProfileAttachment", "MembershipWithoutWingListGrid", MembershipWow_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@ViewData["Help_Attachment_EditRight"]" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (MembershipWow_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(MembershipWow_MasterRowRecID, "Profile_Membership", MembershipWow_AtachmentID, MembershipWow_ParamMandatory, MembershipWow_FromDateLabel, MembershipWow_ToDateLabel, MembershipWow_DescriptionLabel, "MembershipWowProfileAttachment", null, "MembershipWithoutWingListGrid", MembershipWow_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@ViewData["Help_Attachment_DeleteRight"]" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(MembershipWow_MasterRowRecID, "Profile_Membership", MembershipWow_AtachmentID, MembershipWow_ParamMandatory, MembershipWow_FromDateLabel, MembershipWow_ToDateLabel, MembershipWow_DescriptionLabel, null, "MembershipWithoutWingListGrid", MembershipWow_NestedGrid_AccessID, MembershipWow_Attachment_RecStatus);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@ViewData["Help_Attachment_ViewRight"]" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            ViewDocument(MembershipWow_AtachmentID, MembershipWow_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(MembershipWow_MasterRowRecID, "Profile_Membership", "Land & Building Information", "MembershipWithoutWingListGrid", MembershipWow_NestedGrid_AccessID);
        }
        else if (e.actionName === "Add_Reason")
        {
            if (MembershipWow_Doc_Category.toLowerCase() == "others")
            {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else {
                AttachmentAddReason(MembershipWow_MasterRowRecID, MembershipWow_NestedRowMapID, "Profile_Membership", "MembershipWithoutWingListGrid", MembershipWow_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(MembershipWow_MasterRowRecID, MembershipWow_NestedRowMapID, "Profile_Membership", "MembershipWithoutWingListGrid", MembershipWow_NestedGrid_AccessID, MembershipWow_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(MembershipWow_MasterRowRecID, MembershipWow_NestedRowMapID, "MembershipWithoutWingListGrid", MembershipWow_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
        else if (e.actionName == "AuditAction")
        {
            MembershipWow_FAB.SetActionContext("AuditActionContext", true);
        }
        else if (e.actionName == "BackAudit")
        {
            if (MembershipWow_Nested_Doc_Status == "")
            {
                MembershipWow_FAB.SetActionContext("AutoItemContext", true);
            }
            if (MembershipWow_Nested_Doc_Status == "NO")
            {
                MembershipWow_FAB.SetActionContext("EditItemContext", true);
            }
            if (MembershipWow_Nested_Doc_Status == "YES")
            {
                MembershipWow_FAB.SetActionContext("actionItemContext", true);
            }
        }
        else if (e.actionName == "Accept")
        {
            MembershipWow_AcceptwithoutRemarks();
        }
        else if (e.actionName == "Reject")
        {
            MembershipWow_AcceptRejectVoucher("Reject");
        }
        else if (e.actionName == "AcceptWithRemarks")
        {
            MembershipWow_AcceptRejectVoucher("Accept");
        }
        else if (e.actionName == "AcceptDoc") {

            OnMembershipWow_AcceptDoc();
        }
        else if (e.actionName == "RejectDoc") {

            OnMembershipWow_RejectDoc();
        }
    }

