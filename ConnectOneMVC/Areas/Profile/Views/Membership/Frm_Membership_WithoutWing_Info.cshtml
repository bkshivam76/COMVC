                    .Icon("toolbox")
                    .OnClick(@<text>
                        function () {
                        MembershipWow_changeMode();
                        }
                    </text>)
                )
                    @(Html.DevExtreme().Button()
                .ID("MembershipWowModelListPreview")
                .Text("Export")
                .Icon("save")
                .Width(80)
