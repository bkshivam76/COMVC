    //Context Menu Function
    function MembershipWowContextMenuFunction(s, e) { //This code is to handle context menu filled user defined buttons functionality.
        debugger;
        if (e.item.name == 'Close') {
            closeMembershipWow();
        }
        else if (e.item.name == 'Export') {
            OnMembershipWow_ExportClick();
        }
        else if (e.item.name == 'New_Audit') {
            OnNewAuditClick_MembershipWow();
        }
        else if (e.item.name == 'View_Audit') {
            OnViewAuditClick_New_Audit();
        }
        else if (e.item.name == 'Lock') {
            OnMembershipWowLockClick();
        }
        else if (e.item.name == 'Unlock') {
