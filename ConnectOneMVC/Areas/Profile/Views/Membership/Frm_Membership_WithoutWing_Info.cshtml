    <script>
        // Switch button onchange codes
        function MembershipWow_VouchingSwitch_ValueChange(e) {
            ShowLoader();
            MembershipWow_IsVouchingMode = e.value;
            if (MembershipWow_SetVouchingModeOn == true) {
                MembershipWow_SetVouchingModeOn = false;
            }
            else {
                MembershipWow_FAB.SetVisible(false);
            }
            if (MembershipWow_IsVouchingMode == true) {
                OpenRightPane();
                ClearLeftPane();
                OpenLeftPane();
            }
            else {
                MembershipWow_FAB.SetActionContext("AddAttachmentContext", false);
                CloseRightPane();
                ClearLeftPane();
                CloseLeftPane();
            }
            MembershipWithoutWingListGrid_CollapseAllDetailRows();
        }
        function MembershipWow_ViewSwitch_ValueChange(e) {
            debugger;
            ShowLoader();
            MembershipWow_ViewMode = e.value == false ? "Default" : "Compact";
            if (MembershipWow_SetVouchingModeOn == true) {
                $("#MembershipWowVouchingModeSwitch").dxSwitch("instance").option("value", true);
            }
            else {
                if (MembershipWow_IsVouchingMode == false) {
                    MembershipWow_FAB.SetVisible(false);
                }
                //MembershipWithoutWingListGrid.CollapseAllDetailRows();
                MembershipWithoutWingListGrid_CollapseAllDetailRows();
            }
            HideLoader();
        }

        function MembershipWithoutWingListGrid_CollapseAllDetailRows() {
            ShowLoader();
            if (typeof window !== 'undefined') {
                if (typeof window.MembershipWithoutWingListGrid !== 'undefined') {
                    if (typeof window.MembershipWithoutWingListGrid.CollapseAllDetailRows !== 'undefined') {
                        if (typeof MembershipWithoutWingListGrid.CollapseAllDetailRows == 'function') {
                            HideLoader();
                            MembershipWithoutWingListGrid.SetFocusedRowIndex(-1);
                            MembershipWithoutWingListGrid.CollapseAllDetailRows();
                        }
                        else {
                            alert("CollapseAllDetailRows is not a function");
                        }
                    }
                    else {
                        ShowLoader();
                        setTimeout(function () {
                            MembershipWithoutWingListGrid_CollapseAllDetailRows();
                            HideLoader();
                        }, 500);
                    }
                }
                else {
                    alert('grid undefined')
                }
            }
            else {
                alert('window undefined')
            }
        }

    </script>

