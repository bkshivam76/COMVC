        //Show Listing button on click function
        function ShowListing_Membership_Wow() {
            //debugger;
            TextStringText_Wow = $("#Txt_Str_Membership_Wow").dxTextBox("instance").option("value");
            var selectBoxVal = $("#Cmb_ListBy_Membership_Wow").dxSelectBox("instance").option("value");
            //var indexInDataSource = e.component.getDataSource().items().indexOf(selectBoxVal);
            switch (selectBoxVal) {
                case "MEMBERSHIP NO.":
                    if (length(trim(TextStringText_Wow)) < 3) {
                        alert("Incomplete Information..." + "\n" + "Text cannot be Blank/Minimum 3 Characters required..!");
                        return;
                    }
                    other_condition = " AND MS.MS_NO LIKE '%" + TextStringText_Wow + "%' ";
                    break;
                case "MEMBER NAME":
                    if (length(trim(TextStringText_Wow)) < 3) {
                        alert("Incomplete Information..." + "\n" + "Text cannot be Blank/Minimum 3 Characters required..!");
                        return;
                    }
                    other_condition = " AND AB.C_NAME LIKE '%" + TextStringText_Wow + "%' ";
                    break;
                case "CENTRE NAME":
                    if (length(trim(TextStringText_Wow)) < 3) {
                        alert("Incomplete Information..." + "\n" + "Text cannot be Blank/Minimum 3 Characters required..!");
                        return;
                    }
                    other_condition = " AND CASE WHEN COALESCE(AB.C_CEN_CATEGORY,0) = 0 THEN C.CEN_NAME ELSE O.CEN_NAME END LIKE '%" + TextStringText_Wow + "%' ";
                    break;
                case "CENTRE UID":
                    if (length(trim(TextStringText_Wow)) < 3) {
                        alert("Incomplete Information..." + "\n" + "Text cannot be Blank/Minimum 3 Characters required..!");
                        return;
                    }
                    other_condition = " AND CASE WHEN COALESCE(AB.C_CEN_CATEGORY,0) = 0 THEN C.CEN_UID ELSE O.CEN_UID END LIKE '%" + TextStringText_Wow + "%' ";
                    break;
                case "DISCONTINUED MEMBER":
                    if (length(trim(TextStringText_Wow)) < 3) {
                        alert("Incomplete Information..." + "\n" + "Text cannot be Blank/Minimum 3 Characters required..!");
                        return;
                    }
                    other_condition = " AND AB.C_NAME LIKE '%" + TextStringText_Wow + "%' AND  MS.MS_CLOSE_DATE IS NOT NULL ";
                    break;
                case "ALL RECORDS":
                    other_condition = "";
            }
            MembershipWithoutWingListGrid.Refresh();
        }
    </script>


