    <script>
    //All the Grid view functions comes here.
    var MembershipWow_FocusedRowBeforeRefresh;
    var MembershipWow_ShowHorizontalBar = parseInt("@ViewBag.ShowHorizontalBar");

    var MembershipWow_SetVouchingModeOn = "@ViewData["Membership_Wow_Auto_Vouching_Mode"]" == "True" ? true : false;
    var MembershipWow_IsVouchingMode = false;
    var MembershipWow_ColumnToBeShownIndex = "";
    var MembershipWow_ColumnToBeHidddenIndex = "";
    var MembershipWowGridLayout = null;
    var MembershipWow_ViewMode = "Default";





    var MembershipWowID;
    var MembershipWowCategory;
    var MembershipWowConstruction_Year;
    var MembershipWowCrossed_Time_Limit;
    var MembershipWowDeposit_Amount;
    var MembershipWowCurr_Value;
    var MembershipWow_EditDate;
    var MembershipWow_AddDate;
    var MembershipWow_AddBy;
    var MembershipWow_EditBy;
    var MembershipWow_ActionStatus;
    var MembershipWow_ActionDate;
    var MembershipWow_ActionBy;
    var MembershipWow_EntryType;
    var YearID;
    var MembershipWow_FocusedRowBeforeRefresh;
    var MembershipWow_Select_xid = "";



    //This is Begin Call back function of the grid to send the Parameters
    function MembershipWithoutWing_BeginCallBack(s, e) { //s sender and e - event
        MembershipWow_FocusedRowBeforeRefresh = s.GetFocusedRowIndex();
        debugger;
        e.customArgs["command"] = e.command;
        e.customArgs["ShowHorizontalBar"] = MembershipWow_ShowHorizontalBar;
        e.customArgs["OtherCondition"] = other_condition;

        if ($("#Look_SubsList_Membership_Wow").dxDropDownBox("instance").option("value") == "ALL") {
        other_condition1 = "";
    }
        else {
        other_condition1 = " AND MS.MS_SI_ID='" + $("#Look_SubsList_Membership_Wow").dxDropDownBox("instance").option("value") + "' ";
    }
    e.customArgs["OtherCondition_1"] = other_condition1;
    e.customArgs["VouchingMode"] = MembershipWow_IsVouchingMode;
    e.customArgs["ViewMode"] = MembershipWow_ViewMode;
    e.customArgs["ColumnToBeShownIndex"] = MembershipWow_ColumnToBeShownIndex;
    e.customArgs["ColumnToBeHidddenIndex"] = MembershipWow_ColumnToBeHidddenIndex;

        //ViewBag.VouchingMode = VouchingMode;
        //ViewBag.ViewMode = ViewMode;
        //ViewBag.ColumnToBeShownIndex = ColumnToBeShownIndex;
        //ViewBag.ColumnToBeHidddenIndex = ColumnToBeHidddenIndex;
    }

    function OnGridMembershipWithoutWing_EndCallback(s, e) {
        debugger;
        MembershipWow_ColumnToBeShownIndex = s.cpColumnToBeShownIndex;
        MembershipWow_ColumnToBeHidddenIndex = s.cpColumnToBeHidddenIndex;
        MembershipWowGridLayout = s.cpClientLayout;
        if (MembershipWow_IsVouchingMode == true) {
            $(".MembershipWithoutWingListGrid_PreviewRow").hide();
        }
        else {
            $(".MembershipWithoutWingListGrid_PreviewRow").show();
        }
        GetSessionStorage("MembershipWithoutWingListGrid");
        SendCustomArgs_FilterControl(s, e);
        if (e.command == "REFRESH") {
            if (MembershipWow_FocusedRowBeforeRefresh == s.GetFocusedRowIndex()) {
                s.SetFocusedRowIndex(-1);
                s.SetFocusedRowIndex(MembershipWow_FocusedRowBeforeRefresh);
            }
            MembershipWow_Select_xid = "";
        }
    }

    //This code is for General Nested Grid Focus Row change
    function OnMembershipWowGridFocusedRowChanged(s, e) {
        debugger;
        if (s.GetFocusedRowIndex() >= 0) {
            if (!MembershipWithoutWingListGrid.IsGroupRow(s.GetFocusedRowIndex())) {
                MembershipWowID = s.GetRowKey(s.GetFocusedRowIndex());
                if (MembershipWow_IsVouchingMode == true) {
                    MembershipWow_FAB.SetVisible(true);
                    MembershipWow_FAB.SetActionContext("VouchingActionContext", true);
                }
                s.GetRowValues(s.GetFocusedRowIndex(), 'ID;Edit_Date;Add_Date;Add_By;Edit_By;Action_Status;Action_Date;Action_By;Entry_Type', MembershipWowOnGetRowValues);
            }
            else {
                MembershipWowID = null;
                MembershipWow_UpdateFooterDetail(MembershipWowID, MembershipWow_ActionStatus, MembershipWow_AddDate, MembershipWow_AddBy,
                    MembershipWow_ActionDate, MembershipWow_ActionBy, MembershipWow_EditDate, MembershipWow_EditBy);
            }
        }
        else {
            MembershipWowID = null;
            MembershipWow_UpdateFooterDetail(MembershipWowID, MembershipWow_ActionStatus, MembershipWow_AddDate, MembershipWow_AddBy,
                MembershipWow_ActionDate, MembershipWow_ActionBy, MembershipWow_EditDate, MembershipWow_EditBy);
        }
    }



    function MembershipWowOnGetRowValues(values) {
        debugger;
        MembershipWowID = values[0];
        MembershipWow_EditDate = values[1];
        MembershipWow_AddDate = values[2];
        MembershipWow_AddBy = values[3];
        MembershipWow_EditBy = values[4];
        MembershipWow_ActionStatus = values[5];
        MembershipWow_ActionDate = values[6];
        MembershipWow_ActionBy = values[7];
        MembershipWow_EntryType = values[8];
        MembershipWow_UpdateFooterDetail(MembershipWowID, MembershipWow_ActionStatus, MembershipWow_AddDate, MembershipWow_AddBy,
            MembershipWow_ActionDate, MembershipWow_ActionBy, MembershipWow_EditDate, MembershipWow_EditBy);

        if (MembershipWow_IsVouchingMode == true) {
            OpenLeftPane();
            LoadDocumentAndAdditionalInfoInLeftPane("Profile", "Membership", "LeftPaneContent", MembershipWowID, MembershipWow_IsVouchingMode, "");
        }
    }

    //This is the replication of "Creationdetail()" in the windows code
    function MembershipWow_UpdateFooterDetail(ID, MembershipWow_Action_Status, MembershipWow_Add_Date, MembershipWow_Add_By, MembershipWow_Action_Date, MembershipWow_Action_By, MembershipWow_Edit_Date, MembershipWow_Edit_By) {
        debugger;
        HideLoader();
        var Status = "";
        var MembershipWow_Status = "";
        var MembershipWow_StatusBy = "";
        var Pic_Status = "";
        var MembershipWow_Create = "";
        var MembershipWow_Modify = "";
        var MembershipWow_Status_Color = "";
        var MembershipWow_ActionOn = "";
        var MembershipWow_ActionBy = "";
        var StatusStr = "";
        if (ID != null) {
            MembershipWow_Add_Date = (moment(MembershipWow_Add_Date, "DD/MM/YYYY HH:mm:ss").format("DD/MM/YYYY HH:mm:ss"));
            MembershipWow_Edit_Date = (moment(MembershipWow_Edit_Date, "DD/MM/YYYY HH:mm:ss").format("DD/MM/YYYY HH:mm:ss"));
            MembershipWow_Action_Date = (moment(MembershipWow_Action_Date, "DD/MM/YYYY HH:mm:ss").format("DD/MM/YYYY HH:mm:ss"));
            Status = MembershipWow_Action_Status;
            StatusStr = Status == "Locked" ? "Locked" : Status == null ? null : "UnLocked";
            if (Status && Status.toUpperCase() == "LOCKED") {
                MembershipWow_Status = "Completed";
                MembershipWow_Status_Color = "blue";
                Pic_Status = "fa fa-lock";
            }
            else {
                Pic_Status = "fa fa-unlock";
                MembershipWow_Status = Status;
                if (Status && Status.toUpperCase() == "COMPLETED") {
                    MembershipWow_Status_Color = "green";
                }
                else {
                    MembershipWow_Status_Color = "red";
                }
            }
            if (MembershipWow_Action_Date) {
