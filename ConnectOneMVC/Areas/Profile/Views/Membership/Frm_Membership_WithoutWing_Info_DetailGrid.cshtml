@using System.Text.RegularExpressions;
@{
    int ShowHorizontalBar = ViewBag.MembershipWowInfo_ShowHorizontalBar == null ? 0 : (int)ViewBag.MembershipWowInfo_ShowHorizontalBar;
    string RecID = ViewBag.MembershipWowInfo_RecID == null ? "" : (string)ViewBag.MembershipWowInfo_RecID;
    string MID = ViewBag.MembershipWowInfo_MID == null ? "" : (string)ViewBag.MembershipWowInfo_MID;
    string Gridpk = ViewBag.MembershipWowGridPrimaryKey == null? "" : (string)ViewBag.MembershipWowGridPrimaryKey;
    var SessionGUID = Request.QueryString["SessionGUID"];
}
@Html.DevExpress().GridView(settings =>
{
    settings.Name = "MembershipWowListGrid" + Gridpk;
    settings.SettingsDetail.MasterGridName = "MembershipWithoutWingListGrid";
    settings.CallbackRouteValues = new { Controller = "Membership", Action = "Frm_Membership_WithoutWing_Info_DetailGrid", RecID = RecID, SessionGUID = SessionGUID, Gridpk = Gridpk };
    settings.EnableTheming = true;
    settings.Theme = "Aqua";
    settings.HtmlRowPrepared = (s, e) =>
    {
        MVCxGridView grid = (MVCxGridView)s;
        if (e.RowType == GridViewRowType.Data)
        {
            if (e.VisibleIndex % 2 == 0)
            {
                e.Row.BackColor = System.Drawing.Color.Linen;
            }
            else
            {
                e.Row.BackColor = System.Drawing.Color.AliceBlue;
            }
        }
        if (e.RowType == GridViewRowType.Preview)
        {
            e.Row.BackColor = System.Drawing.Color.LightGray;
        }

    };
    settings.Styles.FocusedRow.BackColor = System.Drawing.Color.FromArgb(0, 114, 198);
    settings.Styles.FocusedRow.ForeColor = System.Drawing.Color.White;


    settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
    settings.KeyFieldName = "pKey";

  

    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Entry_Date";
            column.Caption = "Entry Date";
            column.MinWidth = 60;
            column.MaxWidth = 100;
            column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
        }
    });

    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Mem_No";
            column.Caption = "Mebership No.";
            column.MinWidth = 70;
            //column.CellStyle.Wrap = DefaultBoolean.True;
        }
    });

    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Membership";
            column.Caption = "Mebership";
            column.MinWidth = 70;
            //column.CellStyle.Wrap = DefaultBoolean.True;
        }
    });

    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Description";
            column.Caption = "Description";
            column.MinWidth = 70;
            column.CellStyle.Wrap = DefaultBoolean.True;
          
        }
    });

    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Period_From";
            column.Caption = "Period From";
            column.MinWidth = 60;
            column.MaxWidth = 100;
            column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
        }
    });

    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Period_To";
            column.Caption = "Period To";
            column.MinWidth = 60;
            column.MaxWidth = 100;
            column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
        }
    });

    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Amount";
            column.Caption = "Amount";
            column.Visible = true;

        }
    });
 
    

    

    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "MS_ID";
            column.Caption = "Mebership ID";
            column.MinWidth = 70;
            column.Visible = false;
            //column.CellStyle.Wrap = DefaultBoolean.True;
        }
    });

    

    

    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "pKey";
            column.Caption = "Primary Key";
            column.MinWidth = 70;
            //column.CellStyle.Wrap = DefaultBoolean.True;
            column.Visible = false;
        }
    });


    settings.ClientSideEvents.FocusedRowChanged = "OnMembershipWowListGridNestedFocusedRowChange";
    settings.ClientSideEvents.BeginCallback = "MembershipWow_Grid_Nested_BeginCallBack";

    settings.Settings.ShowGroupPanel = false;
    settings.Settings.ShowGroupFooter = GridViewGroupFooterMode.Hidden;
    settings.SettingsContextMenu.Enabled = true;
    settings.SettingsContextMenu.EnableGroupFooterMenu = DefaultBoolean.False;
    settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
    settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
    settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;
    settings.Settings.ShowHeaderFilterButton = true;
    settings.KeyboardSupport = true;
    //settings.AccessKey = "G";
    settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
    settings.SettingsBehavior.ProcessColumnMoveOnClient = true;
    settings.SettingsBehavior.ColumnMoveMode = GridColumnMoveMode.AmongSiblings;
    settings.Settings.ShowGroupFooter = GridViewGroupFooterMode.VisibleAlways;
    settings.Settings.UseFixedTableLayout = true;
    settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
    settings.SettingsBehavior.AllowSort = true;
    settings.SettingsBehavior.AllowSelectByRowClick = true;
    settings.SettingsBehavior.EnableCustomizationWindow = true;
    settings.SettingsPager.Mode = GridViewPagerMode.ShowAllRecords;
    settings.SettingsSearchPanel.ShowApplyButton = true;
    settings.SettingsSearchPanel.ShowClearButton = true;
    settings.SettingsBehavior.AllowFocusedRow = true;
    // show filter control
    settings.Settings.ShowFilterBar = GridViewStatusBarMode.Visible;
    settings.Settings.ShowFilterRow = false;
    settings.Settings.AutoFilterCondition = AutoFilterCondition.Contains;
    settings.SettingsFilterControl.ViewMode = true ? FilterControlViewMode.VisualAndText : FilterControlViewMode.Visual;
    settings.SettingsFilterControl.AllowHierarchicalColumns = true;// AllowHierarchicalColumns;
    settings.SettingsFilterControl.ShowAllDataSourceColumns = true;//FilterBuilderDemoHelper.Options.ShowAllDataSourceColumns;
    settings.SettingsFilterControl.MaxHierarchyDepth = 1;

    settings.Settings.ShowFooter = false;
    settings.SettingsCustomizationDialog.ShowSortingPage = true;
    settings.SettingsCustomizationDialog.ShowGroupingPage = true;
    settings.SettingsCustomizationDialog.ShowFilteringPage = true;
    settings.SettingsCustomizationDialog.ShowColumnChooserPage = true;
    MyExtensions.GridViewHelper.CustomGridView(settings);

}).Bind(Model).GetHtml()

