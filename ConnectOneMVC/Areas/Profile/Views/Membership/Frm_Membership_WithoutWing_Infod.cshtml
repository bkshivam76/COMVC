    function OnWingMemberListGridNestedFocusedRowChange(s, e)
    {        
        if (MembershipWing_IsDetailRowExpanded == true || Membrship_IsVouchingMode == true)
        {
            MembershipWing_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
            if (MembershipWing_NestedRecord_FocusedRowIndex >= 0)
            {
                ShowLoader();
                MembershipWing_NestedGrid_AccessID = s.uniqueID;
                s.GetRowValues(s.GetFocusedRowIndex(), 'Doc_Status;Params_Mandatory;LABEL_FROM_DATE;LABEL_TO_DATE;LABEL_DESCRIPTION;Document_Category;Document_ID;ATTACH_ID;TxnID;TxnMID;MAP_ID;Reason;ATTACH_FILE_NAME;Attachment_Action_Status;UniqueID;ReasonID', OnMembershipWing_GetGridRowValues);
            }
            else
            {
                MembershipPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }
    function OnMembershipWing_GetGridRowValues(values)
    {      
        HideLoader();
        if (values[14] != null)
        {
            MembershipPrf_FAB.SetVisible(true);
            MembershipWing_Nested_Doc_Status = values[0];   
            if (Membrship_IsVouchingMode == true)
            {
                MembershipPrf_FAB.SetActionContext("AuditActionContext", true);
            }
            else {
                if (MembershipWing_Nested_Doc_Status == "")
                {
                    MembershipPrf_FAB.SetActionContext("AutoItemContext", true);
                }
                else if (MembershipWing_Nested_Doc_Status == "NO")
                {
                    MembershipPrf_FAB.SetActionContext("EditItemContext", true);
                }
                else if (MembershipWing_Nested_Doc_Status == "YES")
                {
                    MembershipPrf_FAB.SetActionContext("actionItemContext", true);
                }
            }
            MembershipWing_ParamMandatory = values[1];
            MembershipWing_FromDateLabel = values[2];
            MembershipWing_ToDateLabel = values[3];
            MembershipWing_DescriptionLabel = values[4];
            MembershipWing_Doc_Category = values[5];
            MembershipWing_Doc_ID = values[6];
            MembershipWing_AtachmentID = values[7];
            IndexAttachmentID = MembershipWing_AtachmentID;
            MembershipWing_MasterRowRecID = values[8];
            MembershipWing_MasterRowMID = values[9];
            MembershipWing_NestedRowMapID = values[10];
            MembershipWing_reason = values[11];
            MembershipWing_FileName = values[12];
            MembershipWing_Attachment_RecStatus = values[13];
            MembershipWing_NestedRowKeyValue = values[14];
            if (Membrship_IsVouchingMode == true)
            {
                if (MembershipWing_FileName != null && MembershipWing_FileName.length > 0)
                {
                    ViewDocument(MembershipWing_AtachmentID, MembershipWing_FileName, "MembershipPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else
                {
                    CloseRightPane();
                    ClearRightPane();
                }
            }
        }
        MembershipWing_NestedRowReasonID = values[15];
        IndexAttachmentReasonID = MembershipWing_NestedRowReasonID;

    }
    function WingMemberGrid_Nested_BeginCallBack(s, e)
    {
        e.customArgs["ShowHorizontalBar"] = WingMember_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = Membrship_IsVouchingMode;
        e.customArgs["command"] = e.command;
    }
    function WingMemberGrid_DetailRowExpanding(s, e)
    {
        MembershipWing_IsDetailRowExpanded = true;
        s.SetFocusedRowIndex(e.visibleIndex);
        var pane = Mainspliter.GetPaneByName('RightPane');
        if (Membrship_IsVouchingMode == true)
        {
            pane.Expand();
        }
        else
        {
            pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
        }
        IsAllDetailExpanded = true;
    }
    function WingMemberGrid_DetailRowCollapsing(s, e)
    {
        MembershipWing_IsDetailRowExpanded = false;
        s.SetFocusedRowIndex(e.visibleIndex);
        if (Membrship_IsVouchingMode == true)
        {
            if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false)
            {
                CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
        else
        {
            MembershipPrf_FAB.SetVisible(false);
        }
        IsAllDetailExpanded = false;
    }
</script>@*attachment and nested grid*@
