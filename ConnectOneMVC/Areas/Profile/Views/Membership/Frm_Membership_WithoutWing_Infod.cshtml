    {
        debugger;
        MembershipWing_MasterRowMID;
        var Recid;
        if (MembershipWing_IsDetailRowExpanded == true || Membrship_IsVouchingMode == true)
        {
            if (MembershipWing_MasterRowRecID == null || MembershipWing_MasterRowRecID == "")
            {
                Recid = WingMemberID;
            }
            else
