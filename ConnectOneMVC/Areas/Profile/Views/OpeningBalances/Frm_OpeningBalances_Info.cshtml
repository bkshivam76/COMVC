    function OpenBal_VouchingSwitch_ValueChange(e)
    {
        OpeningbalancesListGrid.SetFocusedRowIndex(-1);
        OpenBal_IsVouchingMode = e.value;
        OpeningBalancesPrf_FAB.SetVisible(false);
        if (OpenBal_IsVouchingMode == true) {
            OpenRightPane();
            ClearLeftPane();
            OpenLeftPane();
        }
        else {
            OpeningBalancesPrf_FAB.SetActionContext("AddAttachmentContext", false);
            CloseRightPane();
            ClearLeftPane();
            CloseLeftPane();
        }
        OpeningbalancesListGrid_CollapseAllDetailRows();
    }
    function OpeningbalancesListGrid_CollapseAllDetailRows()
    {
        if (typeof window !== 'undefined')
        {
            if (typeof window.OpeningbalancesListGrid !== 'undefined')
            {
                if (typeof window.OpeningbalancesListGrid.CollapseAllDetailRows !== 'undefined')
                {
                    if (typeof OpeningbalancesListGrid.CollapseAllDetailRows == 'function')
                    {
                        OpeningbalancesListGrid.SetFocusedRowIndex(-1);
                        OpeningbalancesListGrid.CollapseAllDetailRows();
                    }
                    else
                    {
                        alert("CollapseAllDetailRows is not a function");
                    }
                }
                else
                {
                    ShowLoader();
                    setTimeout(function ()
                    {
                        OpeningbalancesListGrid_CollapseAllDetailRows();
                        HideLoader();
                    }, 500);
                }
            }
            else
            {
                alert('grid undefined')
            }
        }
        else {
            alert('window undefined')
        }
    }
    function OpenBalance_ViewSwitch_ValueChange(e)
    {
        OpenBalance_ViewMode = e.value == false ? "Default" : "Compact";
        if (Openingbalances_SetVouchingModeOn == true)
        {
            $("#OpenBalVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }
        else
        {
            OpeningbalancesListGrid.CollapseAllDetailRows();
        }
    }
    $(document).ready(function () {
        $("#OpeningbalancesListGrid").hover(function () {
            OpeningbalancesListGrid.Focus()
        })
        if ("@OpenBalance_LockUnlockRight" == "False")
        {
            $("#OpeningBalancesModelUnlock").hide();
            $("#OpeningBalancesModelLock").hide();
        }
        if ("@OpenBalance_AddRight" == "False")
        {
            $("#OpeningBalancesModelNew").hide();
        }
        if ("@OpenBalance_UpdateRight" == "False")
        {
            $("#OpeningBalancesModelEdit").hide();
        }
        if ("@OpenBalance_ViewRight" == "False")
        {
            $("#OpeningBalancesView").hide();
        }
        if ("@OpenBalance_DeleteRight" == "False")
        {
            $("#OpeningBalancesModelDelete").hide();
        }
        if ("@OpenBalance_ExportRight" == "False")
        {
            $("#OpeningBalancesModelListPreview").hide();
        }
        $(".OpeningbalancesListGrid_PreviewRow").hide();
        GetSessionStorage("OpeningbalancesListGrid");
        if (Openingbalances_SetVouchingModeOn == true)
        {
            $("#OpenBalanceViewModeSwitch").dxSwitch("instance").option("value", true);
        }
        $(".TabPanalMenu-tabs .active span").on("click", function () {
                $.ajax({
                    type: 'GET',
                    url: "/Profile/OpeningBalances/SessionClear",
                    cache: false
                });
                CloseRightPane();
                ClearLeftPane();
            CloseLeftPane();
            ClearAllReferences_OpeningBalancesProfile();
        });
    });
    function OpeningBalancesOnInit(s, e) {
        OpeningBalancesAdjustSize();
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            OpeningBalancesAdjustSize();
        });
    }
    function OBGrid_BeginCallBack(s, e)
    {
        Openingbalances_FocusedRowBeforeRefresh = s.GetFocusedRowIndex();
        e.customArgs["command"] = e.command;
        e.customArgs["ShowHorizontalBar"] = Openingbalances_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = OpenBal_IsVouchingMode;
        e.customArgs["ViewMode"] = OpenBalance_ViewMode;
        e.customArgs["ColumnToBeShownIndex"] = OpenBal_ColumnToBeShownIndex;
        e.customArgs["ColumnToBeHidddenIndex"] = OpenBal_ColumnToBeHidddenIndex;
    }
    var OpenBal_ColumnToBeShownIndex = "";
    var OpenBal_ColumnToBeHidddenIndex = "";

    function OnGridOpeningBalancesListGrid_EndCallback(s, e)
    {
        OpenBal_ColumnToBeShownIndex = s.cpColumnToBeShownIndex;
        OpenBal_ColumnToBeHidddenIndex = s.cpColumnToBeHidddenIndex;
        OpeningBalancesGridLayout = s.cpClientLayout;
        if (e.command == "REFRESH" && OpenBal_IsVouchingMode == true)
        {
                s.SetFocusedRowIndex(-1);
                s.SetFocusedRowIndex(Openingbalances_FocusedRowBeforeRefresh);
        }
            $(".OpeningbalancesListGrid_PreviewRow").hide();
        GetSessionStorage("OpeningbalancesListGrid");
        SendCustomArgs_FilterControl(s, e);
    }

    function OpeningBalancesAdjustSize() {
        var height = (document.documentElement.clientHeight * 90) / 100;
        try{  OpeningbalancesListGrid.SetHeight(height);
            OpeningbalancesListGrid.SetHeight(height);
        } catch (err) { }
    }
    function OpeningBalanceschangeMode() {
        ShowLoader();
        if (Openingbalances_ShowHorizontalBar == 0) {
            Openingbalances_ShowHorizontalBar = 1;
            $("#OpeningBalancesToggleScrollBar").find("span").text("Default Data");
            $("#OpeningBalancesToggleScrollBar").width(110);
        }
        else {
            Openingbalances_ShowHorizontalBar = 0;
            $("#OpeningBalancesToggleScrollBar").find("span").text("Full Data");
            $("#OpeningBalancesToggleScrollBar").width(90);
        }
        $.ajax({
            url: '@Url.Action("Frm_OpeningBalances_Info_Grid", "OpeningBalances")',
            type: "GET",
            data: { ShowHorizontalBar: Openingbalances_ShowHorizontalBar, VouchingMode: OpenBal_IsVouchingMode, ViewMode: OpenBalance_ViewMode, ColumnToBeHidddenIndex: OpenBal_ColumnToBeHidddenIndex, ColumnToBeShownIndex: OpenBal_ColumnToBeShownIndex },
            success: function (res) {
                $("#OpeningbalancesreloadPartialView").html(res);
                $(".OpeningbalancesListGrid_PreviewRow").hide();
                GetSessionStorage("OpeningbalancesListGrid");
            }
        });
        HideLoader();
    }
