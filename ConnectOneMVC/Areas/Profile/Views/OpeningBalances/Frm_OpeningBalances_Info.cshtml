        var Lbl_Create = "";
        var Lbl_Modify = "";
        var Lbl_Status_Color = "";
        var Add_Date = "";
        var Add_By = "";
        var Status_On = "";
        var Status_By = "";
        var StatusStr = "Completed";
        var Lbl_StatusOn = "";
        var Lbl_StatusBy = "";

        Status = OB_Action_Status;

        Add_Date = OB_Add_Date;
        Add_By = OB_Add_By;
        Status_On = OB_Action_Date;
