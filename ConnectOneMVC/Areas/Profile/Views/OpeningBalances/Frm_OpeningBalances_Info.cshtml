    function OpeningBalancesUpdateFooterDetail(OB_ID, OB_Action_Status, OB_Add_Date, OB_Add_By, OB_Action_Date, OB_Action_By, OB_Edit_Date, OB_Edit_By) {

        var Status = "";
        var Lbl_Status = "";
        var Lbl_StatusBy = "";
