    <script>
    var OpeningBalancesInfo_IsDetailRowExpanded = false;
    var OpeningBalancesInfo_NestedRecord_FocusedRowIndex = -1;
    var OpeningBalancesInfo_NestedGrid_AccessID;
    var OpeningBalancesInfo_AtachmentID;
    var OpeningBalancesInfo_FileName;
    var OpeningBalancesInfo_ParamMandatory;
    var OpeningBalancesInfo_FromDateLabel;
    var OpeningBalancesInfo_ToDateLabel;
    var OpeningBalancesInfo_DescriptionLabel;
    var OpeningBalancesInfo_Doc_ID;
    var OpeningBalancesInfo_Doc_Category;
    var OpeningBalancesInfo_MasterRowRecID;
    var OpeningBalancesInfo_MasterRowMID;
    var OpeningBalancesInfo_NestedRowMapID;
    var OpeningBalancesInfo_reason;
    var OpeningBalancesInfo_Attachment_RecStatus;
    var OpeningBalancesInfo_NestedRowReasonID;
    var OpeningBalancesInfo_NestedRowKeyValue ;

    function On_OpeningBalancesProfile_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@Help_Attachment_AddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (OpeningBalancesInfo_ParamMandatory == 1)
            {
                AddAttachment(OpeningBalancesInfo_MasterRowRecID, "Profile_OpeningBalances", OpeningBalancesInfo_Doc_ID, OpeningBalancesInfo_Doc_Category, OpeningBalancesInfo_ParamMandatory, OpeningBalancesInfo_FromDateLabel, OpeningBalancesInfo_ToDateLabel, OpeningBalancesInfo_DescriptionLabel, "OpeningBalancesProfileAttachment", null, "OpeningbalancesListGrid", OpeningBalancesInfo_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(OpeningBalancesInfo_MasterRowRecID, "Profile_OpeningBalances", OpeningBalancesInfo_Doc_ID, "OpeningBalancesProfileAttachment", "OpeningbalancesListGrid", OpeningBalancesInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (OpeningBalancesInfo_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(OpeningBalancesInfo_MasterRowRecID, "Profile_OpeningBalances", OpeningBalancesInfo_AtachmentID, OpeningBalancesInfo_ParamMandatory, OpeningBalancesInfo_FromDateLabel, OpeningBalancesInfo_ToDateLabel, OpeningBalancesInfo_DescriptionLabel, "OpeningBalancesProfileAttachment", null, "OpeningbalancesListGrid", OpeningBalancesInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(OpeningBalancesInfo_MasterRowRecID, "Profile_OpeningBalances", OpeningBalancesInfo_AtachmentID, OpeningBalancesInfo_ParamMandatory, OpeningBalancesInfo_FromDateLabel, OpeningBalancesInfo_ToDateLabel, OpeningBalancesInfo_DescriptionLabel, null, "OpeningbalancesListGrid", OpeningBalancesInfo_NestedGrid_AccessID, OpeningBalancesInfo_Attachment_RecStatus);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@Help_Attachment_ViewRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            ViewDocument(OpeningBalancesInfo_AtachmentID, OpeningBalancesInfo_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(OpeningBalancesInfo_MasterRowRecID, "Profile_OpeningBalances", "Opening Balances Information", "OpeningbalancesListGrid", OpeningBalancesInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Add_Reason")
        {
            if (OpeningBalancesInfo_Doc_Category.toLowerCase() == "others")
            {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else
            {
                AttachmentAddReason(OpeningBalancesInfo_MasterRowRecID, OpeningBalancesInfo_NestedRowMapID, "Profile_OpeningBalances", "OpeningbalancesListGrid", OpeningBalancesInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(OpeningBalancesInfo_MasterRowRecID, OpeningBalancesInfo_NestedRowMapID, "Profile_OpeningBalances", "OpeningbalancesListGrid", OpeningBalancesInfo_NestedGrid_AccessID, OpeningBalancesInfo_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(OpeningBalancesInfo_MasterRowRecID, OpeningBalancesInfo_NestedRowMapID, "OpeningbalancesListGrid", OpeningBalancesInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
        else if (e.actionName == "AuditAction")
        {
            OpeningBalancesPrf_FAB.SetActionContext("AuditActionContext", true);
        }
        else if (e.actionName == "BackAudit")
        {
            if (OpeningBalancesInfo_Nested_Doc_Status == "")
            {
                OpeningBalancesPrf_FAB.SetActionContext("AutoItemContext", true);
            }
            if (OpeningBalancesInfo_Nested_Doc_Status == "NO")
            {
                OpeningBalancesPrf_FAB.SetActionContext("EditItemContext", true);
            }
            if (OpeningBalancesInfo_Nested_Doc_Status == "YES")
            {
                OpeningBalancesPrf_FAB.SetActionContext("actionItemContext", true);
            }
        }
        else if (e.actionName == "Accept")
        {
            Openingbalances_AcceptwithoutRemarks();
        }
        else if (e.actionName == "Reject")
        {
            Openingbalances_AcceptRejectVoucher("Reject");
        }
        else if (e.actionName == "AcceptWithRemarks")
        {
            Openingbalances_AcceptRejectVoucher("Accept");
        }
        else if (e.actionName == "AcceptDoc") {

            OnOpeningbalances_AcceptDoc();
        }
        else if (e.actionName == "RejectDoc") {

            OnOpeningbalances_RejectDoc();
        }
    }
    function OnOpeningbalances_RejectDoc() {
        if (OpeningBalancesInfo_AtachmentID == null || OpeningBalancesInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        RejectAttachment(OpeningBalancesInfo_AtachmentID, "OpeningbalancesListGrid", OpeningBalancesInfo_NestedGrid_AccessID);
    }
    function OnOpeningbalances_AcceptDoc() {
        if (OpeningBalancesInfo_AtachmentID == null || OpeningBalancesInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        AcceptAttachment(OpeningBalancesInfo_AtachmentID, "OpeningbalancesListGrid", OpeningBalancesInfo_NestedGrid_AccessID);
    }
    function Openingbalances_AcceptwithoutRemarks()
    {
        var Recid;
        if (OpeningBalancesInfo_IsDetailRowExpanded == true || OpenBal_IsVouchingMode == true)
        {
            if (OpeningBalancesInfo_MasterRowRecID == null || OpeningBalancesInfo_MasterRowRecID == "")
            {
                Recid = ID;
            }
            else
            {
                Recid = OpeningBalancesInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = ID;
        }

        Entry_AcceptwithoutRemarks(Recid, "Profile_OpeningBalances", "OpeningbalancesListGrid", OpeningBalancesInfo_AtachmentID, OpeningBalancesInfo_NestedRowReasonID, OpeningBalancesInfo_NestedRowKeyValue);
    }
    function Openingbalances_AcceptRejectVoucher(_actionMethod)
    {
        var Recid;
        if (OpeningBalancesInfo_IsDetailRowExpanded == true || OpenBal_IsVouchingMode == true)
        {
            if (OpeningBalancesInfo_MasterRowRecID == null || OpeningBalancesInfo_MasterRowRecID == "")
            {
                Recid = ID;
            }
            else
            {
                Recid = OpeningBalancesInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = ID;
        }
        Entry_AcceptReject(_actionMethod, Recid, "Profile_OpeningBalances", "OpeningbalancesListGrid", OpeningBalancesInfo_AtachmentID, OpeningBalancesInfo_NestedRowReasonID, OpeningBalancesInfo_NestedRowKeyValue );
    }
    function OnOpeningBalancesListGridNestedFocusedRowChange(s, e)
    {
        if (OpeningBalancesInfo_IsDetailRowExpanded == true || OpenBal_IsVouchingMode == true)
        {
            OpeningBalancesInfo_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
            if (OpeningBalancesInfo_NestedRecord_FocusedRowIndex >= 0)
            {
                ShowLoader();
                OpeningBalancesInfo_NestedGrid_AccessID = s.uniqueID;
                s.GetRowValues(s.GetFocusedRowIndex(), 'Doc_Status;Params_Mandatory;LABEL_FROM_DATE;LABEL_TO_DATE;LABEL_DESCRIPTION;Document_Category;Document_ID;ATTACH_ID;TxnID;TxnMID;MAP_ID;Reason;ATTACH_FILE_NAME;Attachment_Action_Status;UniqueID;ReasonID', OnOpeningBalancesInfo_GetGridRowValues);
            }
            else
            {
                OpeningBalancesPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }
    function OnOpeningBalancesInfo_GetGridRowValues(values)
    {
        HideLoader();
        if (values[14] != null)
        {
            OpeningBalancesPrf_FAB.SetVisible(true);
            OpeningBalancesInfo_Nested_Doc_Status = values[0];
            if (OpenBal_IsVouchingMode == true)
            {
                OpeningBalancesPrf_FAB.SetActionContext("AuditActionContext", true);
            }
            else
            {
                if (OpeningBalancesInfo_Nested_Doc_Status == "")
                {
                    OpeningBalancesPrf_FAB.SetActionContext("AutoItemContext", true);
                }
                else if (OpeningBalancesInfo_Nested_Doc_Status == "NO")
                {
                    OpeningBalancesPrf_FAB.SetActionContext("EditItemContext", true);
                }
                else if (OpeningBalancesInfo_Nested_Doc_Status == "YES")
                {
                    OpeningBalancesPrf_FAB.SetActionContext("actionItemContext", true);
                }
            }
            OpeningBalancesInfo_ParamMandatory = values[1];
            OpeningBalancesInfo_FromDateLabel = values[2];
            OpeningBalancesInfo_ToDateLabel = values[3];
            OpeningBalancesInfo_DescriptionLabel = values[4];
            OpeningBalancesInfo_Doc_Category = values[5];
            OpeningBalancesInfo_Doc_ID = values[6];
            OpeningBalancesInfo_AtachmentID = values[7];
            IndexAttachmentID = OpeningBalancesInfo_AtachmentID;
            OpeningBalancesInfo_MasterRowRecID = values[8];
            OpeningBalancesInfo_MasterRowMID = values[9];
            OpeningBalancesInfo_NestedRowMapID = values[10];
            OpeningBalancesInfo_reason = values[11];
            OpeningBalancesInfo_FileName = values[12];
            OpeningBalancesInfo_Attachment_RecStatus = values[13];
            OpeningBalancesInfo_NestedRowKeyValue = values[14];
            OpeningBalancesInfo_NestedRowReasonID = values[15];
            IndexAttachmentReasonID = OpeningBalancesInfo_NestedRowReasonID;

            if (OpenBal_IsVouchingMode == true)
            {
                if (OpeningBalancesInfo_FileName != null && OpeningBalancesInfo_FileName.length > 0)
                {
                    ViewDocument(OpeningBalancesInfo_AtachmentID, OpeningBalancesInfo_FileName, "OpeningBalancesPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else
                {
                    CloseRightPane();
                    ClearRightPane();
                }
            }
        }

    }
    function OpeningBalancesGrid_Nested_BeginCallBack(s, e)
    {

        e.customArgs["ShowHorizontalBar"] = Openingbalances_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = OpenBal_IsVouchingMode;
        e.customArgs["command"] = e.command;
    }
    function OpeningBalancesGrid_DetailRowExpanding(s, e)
    {
        OpeningBalancesInfo_IsDetailRowExpanded = true;
        s.SetFocusedRowIndex(e.visibleIndex);
        var pane = Mainspliter.GetPaneByName('RightPane');
        if (OpenBal_IsVouchingMode == true)
        {
            pane.Expand();
        }
        else
        {
            pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
        }
    }
    function OpeningBalancesGrid_DetailRowCollapsing(s, e)
    {
        OpeningBalancesInfo_IsDetailRowExpanded = false;
        s.SetFocusedRowIndex(e.visibleIndex);
        if (OpenBal_IsVouchingMode == true)
        {
            if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false)
            {
                CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
        else
        {
            OpeningBalancesPrf_FAB.SetVisible(false);
        }
    }
    </script>
