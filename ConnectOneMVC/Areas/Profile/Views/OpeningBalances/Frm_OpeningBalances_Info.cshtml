    function OnOpenBalCellClick(event, cell,col, row)
    {
        if (UserType_OpenBalPrf == "AUDITOR" || UserType_OpenBalPrf == "SUPERUSER")
        {
            if (event.button == 0)
            {
                if (cell.style.backgroundColor.length > 0)
                {
                    cell.style.backgroundColor = "";
                }
                else
                {
                    cell.style.backgroundColor = 'skyblue';
                }
            }
        }
    }

