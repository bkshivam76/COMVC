    function OBOnGridFocusedRowChanged(s, e)
    {
        if (s.GetFocusedRowIndex() >= 0)
        {
            if (OpenBal_IsVouchingMode)
            {
                OpeningBalancesPrf_FAB.SetVisible(true);
                OpeningBalancesPrf_FAB.SetActionContext("VouchingActionContext", true);
            }
            var key = s.GetRowKey(s.GetFocusedRowIndex());
            OpeningbalancesListGrid.GetValuesOnCustomCallback({ key: key }, OBOnGetRowValues);
        }
        else
        {
            ID = null;
        }
    }

    function OBOnGetRowValues(OpeningBalancesData) {
        var values = OpeningBalancesData.split("![");
        ItemName = values[0];
        Head = values[1];
        HeadType = values[2];
        Amount = values[3];
        Type = values[4];
        other_DetField = values[5];
        Add_By = values[6];
        Add_Date = values[7];
        Edit_By = values[8];
        Edit_Date = values[9];
        Action_Status = values[10];
        Action_By = values[11];
        Action_Date = values[12];
        OBID = values[13];
        ID = values[14];
        Remarks = values[15];
        RemarkStatus = values[16];
        OpenActions = values[17];
        CrossedTimeLimit = values[18];
        YearID = values[19];

        OpeningBalancesUpdateFooterDetail(ID, Action_Status, Add_Date, Add_By,
            Action_Date, Action_By, Edit_Date, Edit_By);
        if (OpenBal_IsVouchingMode == true) {
            OpenLeftPane();
            LoadDocumentAndAdditionalInfoInLeftPane("Profile", "OpeningBalances", "LeftPaneContent", ID, OpenBal_IsVouchingMode, "");
        }
    }

    function OpeningBalancesContextMenuFunction(s, e) {
        if (e.item.name == 'New') {
            OnNewClick();
        }
        if (e.item.name == 'Close') {
            closeProfile_OpeningBalances();
        }
        else if (e.item.name == 'Edit') {
            OnEditClick();
        }
        else if (e.item.name == 'Delete') {
            OnDeleteClick();
        }
        else if (e.item.name == 'View') {
            OnViewClick();
        }
        else if (e.item.name == 'ListPreview') {
            OnListPreviewClick();
        }
        else if (e.item.name == 'NewAudit') {
            OnNewAuditClick();
        }
        else if (e.item.name == 'ViewAudit') {
            OnViewAuditClick();
        }
        else if (e.item.name == 'Lock') {
            OnLockClick();
        }
        else if (e.item.name == 'UnLock') {
            OnUnlockClick();
        }
        else if (e.item.name == 'Refresh') {
            OpeningbalancesListGrid.Refresh();
        }
    }

    var OBData = "";
    function LookUp_OBDetails_Gen_OB_ChangeEvent(e) {
        debugger;

        var dropDownBox = $("#ItemName").dxDropDownBox("instance");
        dropDownBox.close();
        var $dataGrid = $("#Frm_Profile_Win_opening_GLookUp_OBList_datagrid");
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(e.value, false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                //bankData = (item["REC_ID"]);
                //$("#bankData").val(bankData);
                OBData = item.REC_ID;
                $("#Head").dxTextBox("instance").option("value", item["Head"]);
                $("#HeadType").dxTextBox("instance").option("value", item["HeadType"]);
            }
        }
        //Branch.Refresh();
    }
    function OBAjaxSuccessForm(data) {
        HideLoader();
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.Message, "Error");
            //$("#popup_frm_Bank_Window").dxPopup("hide");
            OpeningbalancesListGrid.Refresh();
        }
        else {
            IsSucessPopup = true;
            var OBSubmitSuccess = DevExpress.ui.dialog.alert(data.Message, "Opening Balances");
            $("#popup_frm_OpeningBalances_Window").dxPopup("hide");
            OpeningbalancesListGrid.Refresh();
            IsSucessPopup = false;
            OBSubmitSuccess.done(function (alertResult) {
                if (alertResult) {
                    if (IsOBNewPopup == true) {
                        var addmoreOBresult = DevExpress.ui.dialog.confirm("Add More Entry...?", "Opening Balances");
                        addmoreOBresult.done(function (dialogResult) {
                            if (dialogResult) {
                                OnNewClick();
                            }
                        });
                    }
                }
            });
        }
    }

    function OnNewClick() {
        if ("@OpenBalance_AddRight" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        IsOBNewPopup = true;
        IsViewPopup = false;
        $("#popup_frm_OpeningBalances_Window").dxPopup("show");
        // $(".dx-popup-content").dxScrollView();
        $("#popup_frm_OpeningBalances_Window").dxPopup("instance").option("title", "New ~ Opening Balances");
        ShowLoader();
        $("#popup_frm_OpeningBalances_Window_result").load("@Url.Action("Frm_OpeningBalances_Window", "OpeningBalances", new { @area = "Profile" })?ActionMethod=New", function () {
            HideLoader();
            OpeningbalancesListGrid.Refresh();
        });
    }

    function OnOBEditClick() {
