            {
                grid.DataColumns["OpenBalance_Compact_Column"].Visible = true;
                grid.DataColumns["ItemName"].Visible = false;
                grid.DataColumns["Head"].Visible = false;
                grid.DataColumns["HeadType"].Visible = false;
                grid.DataColumns["Amount"].Visible = false;
                grid.DataColumns["Type"].Visible = false;
                grid.DataColumns["other_DetField"].Visible = false;

