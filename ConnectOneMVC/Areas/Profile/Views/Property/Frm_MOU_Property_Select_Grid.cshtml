@using DevExtreme.AspNet.Mvc;
@using Newtonsoft.Json;
@using Newtonsoft.Json.Linq;
@{ 
    var SessionGUID = Request.QueryString["SessionGUID"];
   // JArray ds = JArray.Parse(JsonConvert.SerializeObject(Model));
}


@(Html.DevExtreme().DataGrid().CustomDataGridListing()
                 .ID("MOUPropertyListGrid")
                // .DataSource(ds, "REC_ID")
                .DataSource(d => d.Mvc().Controller("Property").LoadAction("Frm_MOU_Property_Select_Grid").LoadMode(DataSourceLoadMode.Raw).Key("REC_ID"))                
         .Paging(s=>s.Enabled(false))
         .Pager(s => s.Visible(false))
         .FilterRow(s=>s.Visible(false))
         .FilterPanel(s=>s.Visible(false))
         .OnContextMenuPreparing("OnMOUPropertyListGridContextMenuPreparing")
         .OnSelectionChanged("OnMOUPropertyListGridSelectionChanged")
         .OnInitialized("OnMOUPropertyListGridInit")
         .OnContentReady("OnMOUPropertyListGridContentReady")
         .Height(350)
         .OnKeyDown("OnMOUPropertyListGridKeyDown")    
//.WordWrapEnabled(false)

)




