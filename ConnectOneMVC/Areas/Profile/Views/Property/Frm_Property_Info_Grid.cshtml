@using System.Text.RegularExpressions
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool PropertyLB_AddRight = (bool)ViewData["PropertyLB_AddRight"];
    bool PropertyLB_UpdateRight = (bool)ViewData["PropertyLB_UpdateRight"];
    bool PropertyLB_ViewRight = (bool)ViewData["PropertyLB_ViewRight"];
    bool PropertyLB_DeleteRight = (bool)ViewData["PropertyLB_DeleteRight"];
    bool PropertyLB_ExportRight = (bool)ViewData["PropertyLB_ExportRight"];
    bool PropertyLB_LockUnlockRight = (bool)ViewData["PropertyLB_LockUnlockRight"];
    bool PropertyLB_ManageRemarks = (bool)ViewData["PropertyLB_ManageRemarks"];
    bool PropertyLB_SpecialGrouping = (bool)ViewData["PropertyLB_SpecialGrouping"];
    var DetailData = ViewBag.DetailGridData;
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;
    string ViewMode = ViewBag.ViewMode == null ? "Default" : (string)ViewBag.ViewMode;
    string UserType = (string)ViewBag.UserType;
    List<string> ColumnTobeHidden = new List<string>();
    List<string> ColumnTobeShown = new List<string>();
    string ColumnToBeShowIndex = ViewBag.ColumnToBeShownIndex == null ? "" : (string)ViewBag.ColumnToBeShownIndex;
    string ColumnToBeHideIndex = ViewBag.ColumnToBeHidddenIndex == null ? "" : (string)ViewBag.ColumnToBeHidddenIndex;
    if (ColumnToBeHideIndex.Length > 0)
    {
        ColumnTobeHidden = ColumnToBeHideIndex.Split(',').ToList();
    }
    if (ColumnToBeShowIndex.Length > 0)
    {
        ColumnTobeShown = ColumnToBeShowIndex.Split(',').ToList();
    }
}

