                if (PropertyLB_UpdateRight) e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), ChangePropertyType);

                var PrintViewitem = e.CreateItem("Export", "ListPreview");
                PrintViewitem.Image.IconID = "actions_hideproduct_16x16devav";
                PrintViewitem.BeginGroup = true;
                if (PropertyLB_ExportRight) e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), PrintViewitem);

                var AuditAction = e.CreateItem("Audit Actions", "AuditActions");
                AuditAction.Image.Url = "../../../../Icons/Audit Actions1_16x16.png";
                if (PropertyLB_ManageRemarks)
                {
                    AuditAction.Items.Add("New", "NewAudit").Image.Url = "../../../../Icons/New button2_16x16.png";
                }
                AuditAction.Items.Add("View", "ViewAudit").Image.Url = "../../../../Icons/View button1_16x16.png";
                if (PropertyLB_LockUnlockRight)
                {
                    AuditAction.Items.Add("Lock", "Lock").Image.Url = "../../../../Icons/Lock1_16x16.png";
                    AuditAction.Items.Add("Unlock", "Unlock").Image.Url = "../../../../Icons/Unlock1_16x16.png";
                }

                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), AuditAction);

                var CloseItem = e.CreateItem("Close", "Close");
                CloseItem.Image.IconID = "actions_close_16x16devav";
                CloseItem.BeginGroup = true;
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), CloseItem);
            }
        };
