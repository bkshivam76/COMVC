@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;
    int ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;
    string UserType = (string)ViewBag.UserType;
    bool PropertyLB_SpecialGrouping = (bool)ViewData["PropertyLB_SpecialGrouping"];


}

@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar)
                 .ID("PropertyListGrid")
                 .DataSource(d => d.Mvc().Controller("Property").LoadAction("Frm_Property_Info_dx_Grid_Load").LoadMode(DataSourceLoadMode.Raw).Key("ID"))
                 .Columns(columns =>
                 {
                 columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);//Bug #137209 Fix
                 columns.Add().DataField("iIcon").Name("iIcon").Caption("").CellTemplate(new JS("PropertyListGrid_dx_iIconTemplate")).Width(30)
                 .HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource")).RenderAsync(true);
                 columns.Add().DataField("PropertyListGrid_dx_Compact_Column").Name("PropertyListGrid_dx_Compact_Column").Caption("").Visible(false).CellTemplate(new JS("PropertyListGrid_dx_Compact_Column_Template"))
                 .CalculateCellValue("PropertyListGrid_dx_Compact_Column_CellValue").Width("100%").RenderAsync(true).ShowInColumnChooser(false);


                 if (PropertyLB_SpecialGrouping)
                 {
                     columns.Add().DataField("Entry_Type").MinWidth(125).GroupIndex(0).GroupCellTemplate(new JS("PropertyListGrid_dx_GroupCell_Template"));
                     columns.Add().DataField("Category").Caption("Category").MinWidth(125).GroupIndex(2).GroupCellTemplate(new JS("PropertyListGrid_dx_GroupCell_Template"));
                 } else
                 {
                     columns.Add().DataField("Entry_Type").MinWidth(Request.Browser.IsMobileDevice ? 100 : 125);
                     columns.Add().DataField("Category").Caption("Category").MinWidth(125).GroupIndex(0).GroupCellTemplate(new JS("PropertyListGrid_dx_GroupCell_Template"));
                 }
                 columns.Add().DataField("Type").Caption("Type").MinWidth(100);
                 columns.Add().DataField("LB_PRO_NAME").Caption("Property / Building Name").MinWidth(Request.Browser.IsMobileDevice?100:150);
                 columns.Add().DataField("Address").Caption("Address").MinWidth(250);
                 columns.Add().DataField("Use_of_Property").Caption("Use of Property").Width(100);
                 columns.Add().DataField("Ownership").Caption("Ownership").Width(100);
                 columns.Add().DataField("Owner").Caption("Owner").MinWidth(160);
                 columns.Add().DataField("Special_Ref").Caption("Reference").MinWidth(120);
                 if (UserType.ToUpper() != "SUPERUSER" && UserType.ToUpper() != "AUDITOR")
                 {
                     columns.Add().DataField("Opening_Value").Caption("Opening Value").MinWidth(100).Visible(false)
                     .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}")); ;
                     columns.Add().DataField("Curr_Value").Caption("Curr. Value").MinWidth(100).Visible(false)
                     .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                 }
                 else
                 {
                     columns.Add().DataField("Opening_Value").Caption("Opening Value").MinWidth(100)
                     .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("Curr_Value").Caption("Curr. Value").MinWidth(100)
                     .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                 }
                 columns.Add().DataField("LB_SURVEY_NO").Caption("Survey No.").MinWidth(100);
                 columns.Add().DataField("LB_TOT_P_AREA").Caption("Total Plot Area (Sq.Ft.)").MinWidth(100)
                 .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                 columns.Add().DataField("LB_CON_AREA").Caption("Constructed Area (Sq.Ft.)").MinWidth(100)
                 .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                 columns.Add().DataField("Construction_Year").Caption("Construction Year").MinWidth(100);
                 columns.Add().DataField("RCC_Roof").Caption("RCC Roof").MinWidth(100);

                 columns.Add().DataField("Deposit_Amount").Caption("Deposit Amount").MinWidth(100)
                 .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                 columns.Add().DataField("Paid_Date").Caption("Paid Date").MinWidth(100)
                 .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                 columns.Add().DataField("Monthly_Rent").Caption("Monthly Rent").MinWidth(100)
                 .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                 columns.Add().DataField("Other_Monthly_Payments").Caption("Other Monthly Payment").MinWidth(140)
                 .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                 columns.Add().DataField("Period_From").Caption("Period From").MinWidth(120)
                  .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                 columns.Add().DataField("Period_To").Caption("Period To").MinWidth(120)
                 .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                 columns.Add().DataField("Other_Detail").Caption("Other Detail").MinWidth(170).Width(180);
                 if (UserType.ToUpper() != "SUPERUSER" && UserType.ToUpper() != "AUDITOR")
                     columns.Add().DataField("Sale_Status").Caption("Sale Status").MinWidth(125).Visible(false);
                 else
                     columns.Add().DataField("Sale_Status").Caption("Sale Status").MinWidth(125);
                 if (PropertyLB_SpecialGrouping)
                     columns.Add().DataField("Action_Status").MinWidth(125).GroupIndex(1).GroupCellTemplate(new JS("PropertyListGrid_dx_GroupCell_Template"));
                 else
                     columns.Add().DataField("Action_Status").MinWidth(125).Visible(false);

                 columns.Add().DataField("Action_By").Caption("Action By").Visible(false).MinWidth(120);
                 columns.Add().DataField("Action_Date").Caption("Action Date").Visible(false).MinWidth(120).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss");
                 columns.Add().DataField("Add_By").Caption("Added By").Visible(false).MinWidth(120);
                 columns.Add().DataField("Add_Date").Caption("Added Date").Visible(false).MinWidth(120).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss");
                 columns.Add().DataField("Crossed_Time_Limit").Caption("Crossed Time Limit").Visible(false).MinWidth(120);
                 columns.Add().DataField("Edit_By").Caption("Edited By").Visible(false).MinWidth(120);
                 columns.Add().DataField("Edit_Date").Caption("Edited Date").Visible(false).MinWidth(120).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss");
                 columns.Add().DataField("ID").Caption("ID").Visible(false).MinWidth(120)@*.SortOrder(SortOrder.Asc)*@;
                     columns.Add().DataField("Open_Actions").Visible(false).MinWidth(120);
                     columns.Add().DataField("RemarkCount").Caption("Remark Count").Visible(false).MinWidth(120);
                     columns.Add().DataField("RemarkStatus").Caption("Remark Status").Visible(false).MinWidth(120);
                     columns.Add().DataField("Remarks").Caption("Remarks").Visible(false).MinWidth(120);
                     columns.Add().DataField("TR_ID").Caption("TR. ID").Visible(false).MinWidth(120);
                     columns.Add().DataField("YearID").Caption("Year ID").Visible(false).MinWidth(120);
                     columns.Add().DataField("REJECTED_COUNT").Caption("iREJECTED_COUNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("RESPONDED_COUNT").Caption("iRESPONDED_COUNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("COMPLETE_ATTACH_COUNT").Caption("iCOMPLETE_ATTACH_COUNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("REQ_ATTACH_COUNT").Caption("iREQ_ATTACH_COUNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("OTHER_ATTACH_CNT").Caption("OTHER_ATTACH_CNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("ALL_ATTACH_CNT").Caption("ALL_ATTACH_CNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("TYPE_CHANGE_LOG").Caption("TYPE_CHANGE_LOG").Visible(false).MinWidth(120);

                 })         
                 .Summary(s =>

                 {
                 })
         .MasterDetail(md =>
         {
             md.AutoExpandAll(false);
             md.Enabled(!VouchingMode);
             md.Template(new JS("PropertyListGrid_dx_DetailTemplate"));
         })
         .OnInitialized("PropertyListGrid_dx_OnInitialized")
         .OnCellPrepared("PropertyListGrid_dx_OnCellPrepared")
         .OnRowPrepared("PropertyListGrid_dx_OnRowPrepared")
         .OnContentReady("PropertyListGrid_dx_OnContentReady")
         .OnCellDblClick("PropertyListGrid_dx_OnCellDblClick")
         .OnSelectionChanged("PropertyListGrid_dx_OnSelectionChanged")      
         .OnRowExpanding("PropertyListGrid_dx_OnRowExpanding")
         .OnRowCollapsing("PropertyListGrid_dx_OnRowCollapsing")
         .OnContextMenuPreparing("PropertyListGrid_dx_OnContextMenuPreparing")     
)