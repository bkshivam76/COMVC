        function PropertyListGrid_dx_Compact_Column_CellValue(rowData) {
            var data =
                [
                    rowData.Category, rowData.Type, rowData.LB_PRO_NAME, rowData.Address, rowData.Use_of_Property,
                    rowData.Ownership, rowData.Owner, rowData.LB_SURVEY_NO,
                    rowData.LB_TOT_P_AREA, rowData.LB_CON_AREA, rowData.Construction_Year, rowData.RCC_Roof, rowData.Opening_Value,
                    rowData.Curr_Value, rowData.Deposit_Amount, rowData.Paid_Date, rowData.Monthly_Rent,
                    rowData.Period_From, rowData.Period_To, rowData.Other_Detail, rowData.Special_Ref, rowData.Sale_Status

                ]
            return data.join(" ")

        }
        function PropertyListGrid_dx_DetailTemplate(container, templateData) {
            var GridName = templateData.component.element()[0].id
            var RecID = templateData.data.ID;
            PropertyListGrid_dx_Detail(container, GridName, RecID, LandB_IsVouchingMode, Property_ShowHorizontalBar_dx);
        }    

        function LeftPaneContent_Property_dx(GridName, RecID, vouchingMode, AllColumns = 0) {
            $("#LeftPane_Div_Content").html(null);
            $("#LeftPane_Div_Content").append("<div class='col-xs-12'><label>Documents Attached:</label><div class='AttachmentGrid'><form></form></div></div><div class='col-xs-12'><label>Additional Info:</label><div class='AdditionalInfoGrid'><form></form></div></div>")
            PropertyListGrid_dx_Detail($("#LeftPane_Div_Content .AttachmentGrid>form"), GridName, RecID, vouchingMode, AllColumns)
            setTimeout(function () {
                AdditionalInfoGrid_Property_dx($("#LeftPane_Div_Content .AdditionalInfoGrid>form"), GridName, RecID, vouchingMode, AllColumns)
            })
        }
        function AdditionalInfoGrid_Property_dx(container, GridName, RecID, vouchingMode, AllColumns) {
            var url = "/Profile/Property/Frm_Property_AdditionalGridData_dx?VouchingMode=" + vouchingMode + "&RecID=" + RecID
            DxGrid_CreateAdditionalInfoGrid(container, GridName, RecID, vouchingMode, AllColumns, url)         
        }

