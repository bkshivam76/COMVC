    function PropertyListGrid_dx_Detail(container, GridName, RecID, vouchingMode, AllColumns)
    {
        var url = "/Profile/Property/Frm_Property_Info_DetailGrid_dx_Load?VouchingMode=" + vouchingMode + "&RecID=" + RecID
        var instance = DxGrid_AttachmentGrid_Create(container, GridName, RecID, vouchingMode, AllColumns, url)
        instance.option("onSelectionChanged", PropertyListGrid_dx_Detail_onSelectionChanged);       
    }
    function PropertyListGrid_dx_Detail_onSelectionChanged(e) {
        if (PropertyInfo_IsDetailRowExpanded || LandB_IsVouchingMode) {
            if (e.selectedRowsData != null && e.selectedRowsData.length > 0) {
                PropertyInfo_NestedGrid_AccessID = e.element[0].id;
                PropertyListGrid_dx_Detail_SelectedRowData(e.selectedRowsData)
            }
            else {
                PropertyPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }
    function PropertyListGrid_dx_Detail_SelectedRowData(selectedData = null) {
        if (selectedData == null) {
            selectedData = $("#" + PropertyInfo_NestedGrid_AccessID).dxDataGrid("getSeletedRowsData");
        }
        var values = selectedData[0];
        PropertyInfo_NestedRowKeyValue = values["UniqueID"];
        if (values["UniqueID"] != null) {
            PropertyPrf_FAB.SetVisible(true);
            PropertyInfo_Nested_Doc_Status = values["Doc_Status"];

            if (LandB_IsVouchingMode  == true) {
                PropertyPrf_FAB.SetActionContext("AuditActionContext", true);
            }
            else {
                if (PropertyInfo_Nested_Doc_Status == "") {
                    PropertyPrf_FAB.SetActionContext("AutoItemContext", true);
                }
                else if (PropertyInfo_Nested_Doc_Status == "NO") {
                    PropertyPrf_FAB.SetActionContext("EditItemContext", true);
                }
                else if (PropertyInfo_Nested_Doc_Status == "YES") {
                    PropertyPrf_FAB.SetActionContext("actionItemContext", true);
                }
            }
            PropertyInfo_ParamMandatory = values["Params_Mandatory"];
            PropertyInfo_FromDateLabel = values["LABEL_FROM_DATE"];
            PropertyInfo_ToDateLabel = values["LABEL_TO_DATE"];
            PropertyInfo_DescriptionLabel = values["LABEL_DESCRIPTION"];
            PropertyInfo_Doc_Category = values["Document_Category"];
            PropertyInfo_Doc_ID = values["Document_ID"];
            PropertyInfo_AtachmentID = values["ATTACH_ID"];
            IndexAttachmentID = PropertyInfo_AtachmentID;
            PropertyInfo_MasterRowRecID = values["TxnID"];
            PropertyInfo_MasterRowMID = values["TxnMID"];
            PropertyInfo_NestedRowMapID = values["MAP_ID"];
            PropertyInfo_reason = values["Reason"];
            PropertyInfo_FileName = values["ATTACH_FILE_NAME"];
            PropertyInfo_Attachment_RecStatus = values["Attachment_Action_Status"];

            if (LandB_IsVouchingMode  == true) {
                if (PropertyInfo_FileName != null && PropertyInfo_FileName.length > 0) {
                    ViewDocument(PropertyInfo_AtachmentID, PropertyInfo_FileName, "PropertyPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else {
                    CloseRightPane();
                    ClearRightPane();
                }
            }
        }
        PropertyInfo_NestedRowReasonID = values["ReasonID"];
        IndexAttachmentReasonID = PropertyInfo_NestedRowReasonID;
    }


