<script>
    function LandB_VouchingSwitch_ValueChange_dx(e) {
        LandB_IsVouchingMode = e.value;
        if (PropertyLB_SetVouchingModeOn_dx == true) {
            PropertyLB_SetVouchingModeOn_dx = false;
        }
        else {
            PropertyPrf_FAB.SetVisible(false);
        }
        if (LandB_IsVouchingMode == true) {
            OpenRightPane();
            ClearLeftPane();
            OpenLeftPane();
        }
        else {
            CloseRightPane();
            ClearLeftPane();
            CloseLeftPane();
        }
        PropertyListGrid_dx.clearSelection();
        PropertyListGrid_dx.option("masterDetail.enabled", !LandB_IsVouchingMode)
        PropertyListGrid_dx.repaint();

       /* PropertyListGrid_CollapseAllDetailRows();*/
    }
    function PropertyLB_ViewSwitch_ValueChange_dx(e)
    {
        PropertyLB_ViewMode_dx = e.value == false ? "Default" : "Compact";
        if (PropertyLB_SetVouchingModeOn_dx == true) {
            $("#LandBVouchingModeSwitch_dx").dxSwitch("instance").option("value", true);
        }
        PropertyListGrid_dx.beginUpdate();
        var columns = PropertyListGrid_dx.option("columns");
        if (PropertyLB_ViewMode_dx == "Compact") {
            VisibleColumns_PropertyListGrid_dx = [];
            for (var i = 0; i < columns.length; i++) {
                var name = columns[i].dataField;
                var ColumnVisible = PropertyListGrid_dx.columnOption(name, "visible");
                if (name == "PropertyListGrid_dx_Compact_Column") {
                    PropertyListGrid_dx.columnOption(name, "visible", true);
                }
                else if (ColumnVisible == true && name != "iIcon") {
                    VisibleColumns_PropertyListGrid_dx.push(name);
                    PropertyListGrid_dx.columnOption(name, "visible", false);
                }
            }
        }
        else {
            PropertyListGrid_dx.columnOption("PropertyListGrid_dx_Compact_Column", "visible", false);
            for (var i = 0; i < VisibleColumns_PropertyListGrid_dx.length; i++) {
                PropertyListGrid_dx.columnOption(VisibleColumns_PropertyListGrid_dx[i], "visible", true);
            }
        }
        PropertyListGrid_dx.repaint();
        PropertyListGrid_dx.endUpdate();
    }
    function PropertychangeMode_dx() {

        PropertyListGrid_dx.beginUpdate();
        if (Property_ShowHorizontalBar_dx == 0) {
            Property_ShowHorizontalBar_dx = 1;
            $("#PropertyToggleScrollBar_dx").find("span").text("Default Data");
            $("#PropertyToggleScrollBar_dx").width(110);
            PropertyListGrid_dx.option("columnHidingEnabled", false);
            PropertyListGrid_dx.option("allowColumnResizing", true)
        }
        else {
            Property_ShowHorizontalBar_dx = 0;
            $("#PropertyToggleScrollBar_dx").find("span").text("Full Data");
            $("#PropertyToggleScrollBar_dx").width(90);
            PropertyListGrid_dx.option("columnHidingEnabled", true)
            PropertyListGrid_dx.option("allowColumnResizing", false)
        }
        PropertyListGrid_dx.endUpdate();
    }
    function Property_UpdateFooterDetail_dx(ID, Property_Action_Status, Property_Add_Date, Property_Add_By, Property_Action_Date, Property_Action_By, Property_Edit_Date, Property_Edit_By) {
        HideLoader();
        var Status = "";
        var Lbl_Status = "";
        var Lbl_StatusBy = "";
        var Pic_Status = "";
        var Lbl_Create = "";
        var Lbl_Modify = "";
        var Lbl_Status_Color = "";
        var Lbl_ActionOn = "";
        var Lbl_ActionBy = "";
        var StatusStr = "";
        if (ID != null) {
            Property_Add_Date = JS_Json_Date_To_ddMMyyyy(Property_Add_Date ?? "", "DD/MM/YYYY HH:mm:ss");
            Property_Edit_Date = JS_Json_Date_To_ddMMyyyy(Property_Edit_Date ?? "", "DD/MM/YYYY HH:mm:ss");
            Property_Action_Date = JS_Json_Date_To_ddMMyyyy(Property_Action_Date ?? "", "DD/MM/YYYY HH:mm:ss");
            Status = Property_Action_Status;
            StatusStr = Status == "Locked" ? "Locked" : Status == null ? null : "UnLocked";
            if (Status && Status.toUpperCase() == "LOCKED") {
                Lbl_Status = "Completed";
                Lbl_Status_Color = "blue";
                Pic_Status = "fa fa-lock";
            }
            else {
                Pic_Status = "fa fa-unlock";
                Lbl_Status = Status;
                if (Status && Status.toUpperCase() == "COMPLETED") {
                    Lbl_Status_Color = "green";
                }
                else {
                    Lbl_Status_Color = "red";
                }
            }
            if (Property_Action_Date) {
                Lbl_ActionOn = StatusStr + " On: " + Property_Action_Date;
                Lbl_ActionBy = StatusStr + " By: " + Property_Action_By;
            }

            else {
                Lbl_ActionOn = "";
                Lbl_ActionBy = "";
            }
            if (Property_Add_Date) {
                Lbl_Create = "Add On: " + Property_Add_Date + ", By: " + Property_Add_By;
            }
            else {
                Lbl_Create = "";
            }

            if (Property_Edit_Date) {
                Lbl_Modify = "Edit On: " + Property_Edit_Date + ", By: " + Property_Edit_By;
            }
            else {
                Lbl_Modify = "";
            }
        }
        $('#PropertyLbl_Status').text(Lbl_Status);
        $('#Property_Lbl_ActionOn').text(Lbl_ActionOn);
        $('#Property_Lbl_ActionBy').text(Lbl_ActionBy);
        $('#PropertyLbl_Create').text(Lbl_Create);
        $('#PropertyLbl_Modify').text(Lbl_Modify);
        if (Lbl_Status_Color != "") {
            $('#PropertyLbl_Status').css('color', Lbl_Status_Color);
        }
        if (Pic_Status == "fa fa-lock") {
            $('#Property_LockICON_dx').addClass(Pic_Status).removeClass("fa-unlock");
        }
        else if (Pic_Status == "fa fa-unlock") {
            $('#Property_LockICON_dx').addClass(Pic_Status).removeClass("fa-lock");
        }
        else {
            $('#Property_LockICON_dx').removeClass("fa");
            $('#Property_LockICON_dx').removeClass("fa-lock");
            $('#Property_LockICON_dx').removeClass("fa-unlock");
        }
    }
    function OnPropertyListPreviewClick() {
        if ("@PropertyLB_ExportRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        OpenPopup("report_export_modal", "Export Option", "/Profile/Property/Frm_Export_Options_dx/?GridName=PropertyListGrid", "auto", 125, false, false);
        }

    function PropertyListGrid_dx_Refresh()
    {
        PropertyListGrid_dx.refresh().done(function () { ActionAfterDataGridRefresh_PropertyListGrid_dx() })      
    }
    function ActionAfterDataGridRefresh_PropertyListGrid_dx(ActionMethod=null)
    {
        if (ActionMethod != null)
        {
            if (ActionMethod == "_New")
            {
               var confirm = DevExpress.ui.dialog.confirm('Add More Entry...?', "New ~ Land & Building");
                confirm.done(function (Result)
                {
                    if (Result)
                    {
                        OnPropertyNewClick();
                    }
                });
            }
            else if (ActionMethod == "_Edit")
            {
                 if ("@PropertyLB_LockUnlockRight" == "True")
                 {
                     var confirm = DevExpress.ui.dialog.confirm('Do you want to <font color=red>Lock</font> this Entry...?', "Confirmation");
                     confirm.done(function (Result)
                     {
                         if (Result)
                         {
                             OnPropertyLockClick();
                         }
                     });
                }            
            }
        }
        else
        {
            var selectedRowKeys = PropertyListGrid_dx.getSelectedRowKeys()
            if (selectedRowKeys != null && selectedRowKeys.length > 0)
            {
                PropertyListGrid_dx.clearSelection()
                PropertyListGrid_dx.selectRows(selectedRowKeys)
            }
        }
    }
