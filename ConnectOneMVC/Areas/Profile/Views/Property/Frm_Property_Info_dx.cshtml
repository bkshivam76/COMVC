<script>
    function PropertyListGrid_dx_OnInitialized(e) {

        DxGrid_AdjustSize(e.component, $("#Property_ParentDiv_dx .report_button_div"))
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            DxGrid_AdjustSize(e.component, $("#Property_ParentDiv_dx .report_button_div"), "", evt)
        });
        PropertyListGrid_dx = e.component;
    }
    function PropertyListGrid_dx_OnCellPrepared(e) {
        if (e.rowType == "data") {
            if (LandB_IsVouchingMode == true) {
                if (e.column.dataField === "iIcon") {
                    $(e.cellElement).attr("onmouseover", "OnGridRowMouseHoverIn(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.key + "')");
                    $(e.cellElement).attr("onmouseout", "OnGridRowMouseHoverOut(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.key + "')");
                }
            }
            $(e.cellElement).attr("id", e.element[0].id + "_Cell_" + e.key + "|" + e.column.dataField);
            /*$(e.cellElement).addClass("col_" + e.column.dataField + " row_" + e.key);*/
        }
    }
    function PropertyListGrid_dx_OnRowPrepared(e) {        
        if (e.rowType == "data") {
            var GridName = e.element[0].id;
            $(e.rowElement).addClass(GridName + "_DataRow_" + e.key)
            if (e.data.RemarkStatus != null && (e.data.RemarkStatus == "OPEN" || e.data.RemarkStatus == "REOPENED")) {
                $(e.rowElement).css("background-color", "gold");
            }
            if (e.data.RemarkStatus == null && e.data.Remarks != null && e.data.Remarks == true && e.data.Crossed_Time_Limit != null && parseInt(e.data.Crossed_Time_Limit) == 0) {
                $(e.rowElement).css("background-color", "lightgreen");
            }
            if (e.data.Crossed_Time_Limit != null && parseInt(e.data.Crossed_Time_Limit) > 0) {
                $(e.rowElement).css("background-color", "mistyrose");
            }
            DxGrid_CreatePreviewRow(e, LandB_IsVouchingMode, "Master", PropertyListGri_dx_PreviewRow_Template(e))
        }
        else if (e.rowType == "detailAdaptive") {
            DxGrid_MovePreviewRowAfterAdaptiveRow(e)
        }
    }
    async function PropertyListGrid_dx_OnContentReady(e)
    { 
        //if (Property_Select_xid != null && Property_Select_xid.length > 0) {
        //    e.component.clearSelection();
        //    if (Expanded_Row_Key_Property_dx != null) {
        //        await e.component.collapseRow(Expanded_Row_Key_Property_dx)
        //    }
        //    await e.component.selectRows(Property_Select_xid)
        //    DxGrid_RowSelectionTobeCheckedAfterAnyAction(e.component, Expanded_Row_Key_Property_dx)
        //    Property_Select_xid = null;
        //}
        //else {
        //    DxGrid_RowSelectionTobeCheckedAfterAnyAction(e.component, Expanded_Row_Key_Property_dx)
        //}        
        await DxGrid_RowSelectionTobeCheckedAfterAnyAction(e, Expanded_Row_Key_Property_dx, Property_Select_xid)
        Property_Select_xid = null;
        DxGrid_OnContentReady(e, Property_ShowHorizontalBar_dx);
    }
    function PropertyListGrid_dx_OnCellDblClick(e) {
        if (e.rowType == "data") {
            if (LandB_IsVouchingMode == true && PropertyLB_ViewMode_dx == "Default") {
                OnGridCellClick(e.event, e.cellElement[0], e.columnIndex, e.rowIndex, e.element[0].id, e.key, e.column.dataField)
            }
            else if (LandB_IsVouchingMode == false) {
                if (e.rowType == "data")
                    OnPropertyEditClick();
            }
        }
    }
    function PropertyListGrid_dx_OnSelectionChanged(e) {       
        var selectedRowKeys = e.selectedRowKeys;
        if (selectedRowKeys != null && selectedRowKeys.length > 0) {
            if (LandB_IsVouchingMode) {
                PropertyPrf_FAB.SetVisible(true);
                PropertyPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }         
            PropertyListGrid_dx_SelectedRowData(e.selectedRowsData);
        }
        else {
            PropertyID = null;
            Property_UpdateFooterDetail_dx(PropertyID, Property_ActionStatus, Property_AddDate, Property_AddBy,
                Property_ActionDate, Property_ActionBy, Property_EditDate, Property_EditBy);
        }
    }
    function PropertyListGrid_dx_SelectedRowData(selectedData = null) {
        if (selectedData == null) {
            selectedData = PropertyListGrid_dx.getSelectedRowsData();
        }
        if (selectedData != null && selectedData.length > 0) {
            var values = selectedData[0]
            PropertyID = values["ID"]
            Property_EditDate = values["Edit_Date"];
            Property_EditBy = values["Edit_By"];
            Property_AddDate = values["Add_Date"];
            Property_AddBy = values["Add_By"];
            Property_ActionDate = values["Action_Date"];
            Property_ActionBy = values["Action_By"];
            Property_ActionStatus = values["Action_Status"];
            Property_EntryType = values["Entry_Type"];
            Property_UpdateFooterDetail_dx(PropertyID, Property_ActionStatus, Property_AddDate, Property_AddBy,
                Property_ActionDate, Property_ActionBy, Property_EditDate, Property_EditBy);
            if (LandB_IsVouchingMode == true) {
                OpenLeftPane();
                LeftPaneContent_Property_dx("PropertyListGrid", PropertyID, LandB_IsVouchingMode)
            }
        }
        else {
            PropertyID = null;
        }
    }
    function PropertyListGrid_dx_OnRowExpanding(e) {     
        if (Array.isArray(e.key) == false) //not group row
        {
            e.component.collapseRow(Expanded_Row_Key_Property_dx)
            e.component.selectRows(e.key);
            Expanded_Row_Key_Property_dx = e.key;
            PropertyInfo_IsDetailRowExpanded = true;
            var DetailGridID = e.element[0].id + e.key;
            var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
            if (instance != void 0) {
                instance.state(null) // grid maintains its state after collapsing so resetting the state when expands again as per old grid
            }
            //e.component.collapseAll(-1);
        }
        else
        {
            e.component.option("CustomProp.groupRowExpanded", true);
        }
    }
    function PropertyListGrid_dx_OnRowCollapsing(e) {     
        if (Array.isArray(e.key) == false) //not group row
        {
            var DetailGridID = e.element[0].id + e.key;
            sessionStorage.removeItem(DetailGridID + "_DetailGridState") //removing grid state from session storage on collapse
            PropertyInfo_IsDetailRowExpanded = false;
            e.component.selectRows(e.key);
            if (LandB_IsVouchingMode  == false) {
                PropertyPrf_FAB.SetVisible(false);
            }
            var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
            if (instance != void 0) {
                instance.clearSelection();
            }
        }
        else {
            e.component.option("CustomProp.groupRowCollapsed", true);
        }
    }
    function PropertyListGrid_dx_OnContextMenuPreparing(e) {

        if (!e.items) e.items = [];
        if (e.target == "header") {

            DxGrid_HeaderContextMenu(e, "@PropertyLB_SpecialGrouping")
        }
        else if ((e.target == "content" && e.row && e.row.rowType == "groupFooter") || e.target == "footer") {
            if (PropertyLB_ViewMode_dx == "Compact")
                DxGrid_FooterContextMenu(e, true);
            else
                DxGrid_FooterContextMenu(e);
        }
        else if (e.target == "content" && e.row && (e.row.rowType == "data" || e.row.rowType == "detailAdaptive")) {
            var key = e.component.getKeyByRowIndex(e.row.rowIndex);
            e.component.selectRows(key);
            var expanded = e.component.isRowExpanded(key);
            e.items = [
                {
                    text: "Expand Detail",
                    icon: "fa-solid fa-arrow-down-wide-short " + (expanded ? "text-muted" : "text-info"),
                    disabled: expanded,
                    visible: !LandB_IsVouchingMode,
                    onItemClick: function () {
                        if (expanded) {
                        }
                        else {
                            e.component.expandRow(key);
                        }
                    }
                }, {
                    text: "Collapse Detail",
                    icon: "fa-solid fa-arrow-up-wide-short " + (!expanded ? "text-muted" : "text-info"),
                    disabled: !expanded,
                    visible: !LandB_IsVouchingMode,
                    onItemClick: function () {
                        if (expanded) {
                            e.component.collapseRow(key);
                        }
                        else {
                        }
                    }
                },
                {
                    text: "New",
                    icon: "fa-solid fa-plus text-success",
                    beginGroup: true,
