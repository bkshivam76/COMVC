        var PropertyID;
        var PropertyCategory;
        var PropertyConstruction_Year;
        var PropertyCrossed_Time_Limit;
        var PropertyDeposit_Amount;
        var PropertyCurr_Value;
        var Property_EditDate;
        var Property_AddDate;
        var Property_AddBy;
