<div class="LandBuilding_Info_ClearReferences">
    @using DevExtreme.AspNet.Mvc;

    @model IEnumerable<dynamic>
    @{
        ViewBag.Title = "Index";
        Layout = null;
        string UserType = (string)ViewBag.UserType;
        bool PropertyLB_AddRight = (bool)ViewData["PropertyLB_AddRight"];
        bool PropertyLB_UpdateRight = (bool)ViewData["PropertyLB_UpdateRight"];
        bool PropertyLB_ViewRight = (bool)ViewData["PropertyLB_ViewRight"];
        bool PropertyLB_DeleteRight = (bool)ViewData["PropertyLB_DeleteRight"];
        bool PropertyLB_ExportRight = (bool)ViewData["PropertyLB_ExportRight"];
        bool PropertyLB_LockUnlockRight = (bool)ViewData["PropertyLB_LockUnlockRight"];
        bool PropertyLB_ManageRemarks = (bool)ViewData["PropertyLB_ManageRemarks"];
        bool PropertyLB_ViewRemarks = (bool)ViewData["PropertyLB_ViewRemarks"];
        bool PropertyLB_SpecialGrouping = (bool)ViewData["PropertyLB_SpecialGrouping"];
        bool Help_Attachment_AddRight = (bool)ViewData["Help_Attachment_AddRight"];//attachment
        bool Help_Attachment_EditRight = (bool)ViewData["Help_Attachment_EditRight"];//attachment
        bool Help_Attachment_ViewRight = (bool)ViewData["Help_Attachment_ViewRight"];//attachment
        bool Help_Attachment_DeleteRight = (bool)ViewData["Help_Attachment_DeleteRight"];//attachment
        bool PropertyLB_Auto_Vouching_Mode = (bool)ViewData["PropertyLB_Auto_Vouching_Mode"];
    }
    <div id="Property_ParentDiv_dx">
        <div id="content" class="col-md-12 report_header_div_main">
            <div class="col-md-6 report_header_div">
                <label class="report_header_label"> @ViewBag.TitleX</label>
            </div>
            @*Buttons*@
            <div class="report_button_div">
                @(Html.DevExtreme().Switch().ID("LandBVouchingModeSwitch_dx").SwitchedOnText("Vouching On").SwitchedOffText("Vouching Off").OnValueChanged("LandB_VouchingSwitch_ValueChange_dx").Width(100).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
                @(Html.DevExtreme().Switch().ID("PropertyLBViewModeSwitch_dx").SwitchedOnText("Compact").SwitchedOffText("Default").OnValueChanged("PropertyLB_ViewSwitch_ValueChange_dx").Width(70).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
                @if (PropertyLB_LockUnlockRight != false)
                {
                    @(Html.DevExtreme().Button().ID("PropertyModelUnlock").Text("Unlock").Icon("fa fa-unlock").OnClick(@<text> function () { PropertyOnUnlockClick(); } </text>) )
                    @(Html.DevExtreme().Button().ID("PropertyModelLock").Text("Lock").Icon("fa fa-lock").OnClick(@<text> function () { OnPropertyLockClick(); } </text>) )
                }
                @(Html.DevExtreme().Button() .ID("PropertyModelNew").Text("New").Icon("add").OnClick(@<text> function () { OnPropertyNewClick(); } </text>) )
                @(Html.DevExtreme().Button() .ID("PropertyModelEdit").Text("Edit").Icon("edit").OnClick(@<text> function () { OnPropertyEditClick(); } </text>) )
                @(Html.DevExtreme().Button() .ID("PropertyModelDelete").Text("Delete").Icon("trash").OnClick(@<text> function () { OnPropertyDeleteClick(); } </text>) )
                @(Html.DevExtreme().Button() .ID("PropertyModelView").Text("View").Icon("doc").OnClick(@<text> function () { OnPropertyViewClick(); } </text>) )
                @(Html.DevExtreme().Button() .ID("PropertyToggleScrollBar_dx").Text(ViewBag.ShowHorizontalBar == 1 ? "Default Data" : "Full Data").Width(ViewBag.ShowHorizontalBar == 1 ? 110 : 90).Icon("toolbox").OnClick(@<text> function () { PropertychangeMode_dx(); } </text>) )
                @(Html.DevExtreme().Button() .ID("PropertyModelListPreview").Text("Export").Icon("save").Width(80).OnClick(@<text> function () { OnPropertyListPreviewClick(); } </text>) )
                @(Html.DevExtreme().Button() .ID("PropertyModelCLOSE").Text("Close").Icon("clear").OnClick(@<text> function (){ closeProfile_Property();  } </text>)  )
            </div>
        </div>
        <div class="col-md-12 no-padding">
            <form>
                <div id="PropertyreloadPartialView" class="parent_table">
                    @Html.Partial("Frm_Property_Info_Grid_dx")
                </div>
            </form>
        </div>
        <div class="footer-MainBoxdiv full-width-footer" style="display:inline-block;width:100%">
            <div class="setFooterItem">
                <div class="footer-inner">
                    <div class="list_footer_left_margin">
                        <div class="footericon">
                            <i id="Property_LockICON_dx" style="color:red;font-size:35px;"></i>
                        </div>
                        <div class="footer-locktext">
                            <div id="Property_Lbl_ActionOn" class="left_footertext_top"></div>
                            <div id="Property_Lbl_ActionBy" class="left_footertext_bottom"></div>
                        </div>
                    </div>
                    <div class="list_footer_left_margin">
                        <div class="footer-text">
                            <p id="PropertyLbl_Create" style="margin:0px" class="left_footertext_top"></p>
                            <p id="PropertyLbl_Modify" style="margin:0px" class="left_footertext_bottom"></p>
                        </div>
                    </div>

                </div>
            </div>
            <div class="list_footer_right_margin_consistent col-md-1">
                @*<i id="Property_LockICON" class="fa fa-lock lock_symbol"></i>*@
            </div>
        </div>
        @Html.Partial("AttachmentFAB", "PropertyPrf_FAB,Property_ParentDiv_dx,Type1,PropertyProfile," + UserType) @*fab buttons*@

    </div>

    <script type="text/javascript">

    var UserType_LandBPrf = "@UserType".toUpperCase();
    $(document).ready(function ()
    {
        if ("@PropertyLB_AddRight" == "False")
        {
	        $("#PropertyModelNew").hide();
        }
        if ("@PropertyLB_UpdateRight" == "False")
        {
	        $("#PropertyModelEdit").hide();
        }
        if ("@PropertyLB_ViewRight" == "False")
        {
	        $("#PropertyModelView").hide();
        }
        if ("@PropertyLB_DeleteRight" == "False")
        {
	        $("#PropertyModelDelete").hide();
        }
        if ("@PropertyLB_LockUnlockRight" == "False")
        {
	        $("#PropertyModelUnlock").hide();
	        $("#PropertyModelLock").hide();
        }
        HideUnreleasedFunctionality('Property_frm_Property_Info');
        $(".PropertyListGrid_PreviewRow").hide();
        GetSessionStorage("PropertyListGrid");
        if (PropertyLB_SetVouchingModeOn_dx == true)
        {
            $("#PropertyLBViewModeSwitch_dx").dxSwitch("instance").option("value", true);
        }
    });
    function PropertyLB_ViewSwitch_ValueChange(e)
    {
        ShowLoader();
        PropertyLB_ViewMode_dx = e.value == false ? "Default" : "Compact";
        if (PropertyLB_SetVouchingModeOn_dx == true)
        {
            $("#LandBVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }
        else
        {
            if (LandB_IsVouchingMode == false)
            {
                PropertyPrf_FAB.SetVisible(false);
            }
            PropertyListGrid.CollapseAllDetailRows();
        }
        HideLoader();
    }
    function closeProfile_Property()
    {
        $(".TabPanalMenu-tabs .active span").click();
    }
    $(".TabPanalMenu-tabs .active span").on("click", function ()
    {
        DxGrid_EventsOnScreenClose(PropertyListGrid_dx);

        $.ajax({
            type: 'GET',
            url: "/Profile/Property/SessionClear",
            cache: false
        });
        CloseRightPane();
        ClearLeftPane();
        CloseLeftPane();

        ClearAllReferences_LandBuilding_Info();
    });

        function ClearAllReferences_LandBuilding_Info() {

            Property_ShowHorizontalBar = null;
            PropertyLB_SetVouchingModeOn_dx = null;
            UserType_LandBPrf = null;
            LandB_IsVouchingMode = null;
            PropertyLB_ViewMode_dx = null;
            PropertyInfo_IsDetailRowExpanded = null;
            PropertyInfo_NestedRecord_FocusedRowIndex = null;
            PropertyInfo_NestedGrid_AccessID = null;
            PropertyInfo_AtachmentID = null;
            PropertyInfo_FileName = null;
            PropertyInfo_ParamMandatory = null;
            PropertyInfo_FromDateLabel = null;
            PropertyInfo_ToDateLabel = null;
            PropertyInfo_DescriptionLabel = null;
            PropertyInfo_Doc_ID = null;
            PropertyInfo_Doc_Category = null;
            PropertyInfo_MasterRowRecID = null;
            PropertyInfo_MasterRowMID = null;
            PropertyInfo_NestedRowMapID = null;
            PropertyInfo_reason = null;
            PropertyInfo_Attachment_RecStatus = null;
            PropertyInfo_NestedRowReasonID = null;
            PropertyInfo_NestedRowKeyValue = null;
            PropertyID = null;
            PropertyCategory = null;
            PropertyConstruction_Year = null;
            PropertyCrossed_Time_Limit = null;
            PropertyDeposit_Amount = null;
            PropertyCurr_Value = null;
            Property_EditDate = null;
            Property_AddDate = null;
            Property_AddBy = null;
            Property_EditBy = null;
            Property_ActionStatus = null;
            Property_ActionDate = null;
            Property_ActionBy = null;
            Property_EntryType = null;
            YearID = null;
            Property_FocusedRowBeforeRefresh = null;
            Property_Select_xid = null;
            Prop_ColumnToBeShownIndex = null;
            Prop_ColumnToBeHidddenIndex = null;
            PropertyGridLayout = null;


             PropertyListGrid_dx = null;
            Property_ShowHorizontalBar_dx = null;
            LandB_IsVouchingMode = null;
            PropertyLB_ViewMode_dx = null;
            PropertyLB_SetVouchingModeOn_dx = null;
            Expanded_Row_Key_Property_dx = null;

            ClearAllReferences("LandBuilding_Info_ClearReferences");
        }

    </script> @* ready *@
    <script>
    var PropertyInfo_NestedRecord_FocusedRowIndex = -1;
    var PropertyInfo_AtachmentID;
    var PropertyInfo_FileName;
    var PropertyInfo_ParamMandatory;
    var PropertyInfo_FromDateLabel;
    var PropertyInfo_ToDateLabel;
    var PropertyInfo_DescriptionLabel;
    var PropertyInfo_Doc_ID;
    var PropertyInfo_Doc_Category;
    var PropertyInfo_MasterRowRecID;
    var PropertyInfo_MasterRowMID;
    var PropertyInfo_NestedRowMapID;
    var PropertyInfo_reason;
    var PropertyInfo_Attachment_RecStatus;
    var PropertyInfo_NestedRowReasonID;
    var PropertyInfo_NestedRowKeyValue ;

    function On_PropertyProfile_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@Help_Attachment_AddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (PropertyInfo_ParamMandatory == 1)
            {
                AddAttachment(PropertyInfo_MasterRowRecID, "Profile_LandAndBuilding", PropertyInfo_Doc_ID, PropertyInfo_Doc_Category, PropertyInfo_ParamMandatory, PropertyInfo_FromDateLabel, PropertyInfo_ToDateLabel, PropertyInfo_DescriptionLabel, "PropertyProfileAttachment", null, "PropertyListGrid", PropertyInfo_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(PropertyInfo_MasterRowRecID, "Profile_LandAndBuilding", PropertyInfo_Doc_ID, "PropertyProfileAttachment", "PropertyListGrid", PropertyInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (PropertyInfo_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(PropertyInfo_MasterRowRecID, "Profile_LandAndBuilding", PropertyInfo_AtachmentID, PropertyInfo_ParamMandatory, PropertyInfo_FromDateLabel, PropertyInfo_ToDateLabel, PropertyInfo_DescriptionLabel, "PropertyProfileAttachment", null, "PropertyListGrid", PropertyInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(PropertyInfo_MasterRowRecID, "Profile_LandAndBuilding", PropertyInfo_AtachmentID, PropertyInfo_ParamMandatory, PropertyInfo_FromDateLabel, PropertyInfo_ToDateLabel, PropertyInfo_DescriptionLabel, null, "PropertyListGrid", PropertyInfo_NestedGrid_AccessID, PropertyInfo_Attachment_RecStatus);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@Help_Attachment_ViewRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            ViewDocument(PropertyInfo_AtachmentID, PropertyInfo_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(PropertyInfo_MasterRowRecID, "Profile_LandAndBuilding", "Land & Building Information", "PropertyListGrid", PropertyInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Add_Reason")
        {
            if (PropertyInfo_Doc_Category.toLowerCase() == "others")
            {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else {
                AttachmentAddReason(PropertyInfo_MasterRowRecID, PropertyInfo_NestedRowMapID, "Profile_LandAndBuilding", "PropertyListGrid", PropertyInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(PropertyInfo_MasterRowRecID, PropertyInfo_NestedRowMapID, "Profile_LandAndBuilding", "PropertyListGrid", PropertyInfo_NestedGrid_AccessID, PropertyInfo_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(PropertyInfo_MasterRowRecID, PropertyInfo_NestedRowMapID, "PropertyListGrid", PropertyInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
        else if (e.actionName == "AuditAction")
        {
            PropertyPrf_FAB.SetActionContext("AuditActionContext", true);
        }
        else if (e.actionName == "BackAudit")
        {
            if (PropertyInfo_Nested_Doc_Status == "")
            {
                PropertyPrf_FAB.SetActionContext("AutoItemContext", true);
            }
            if (PropertyInfo_Nested_Doc_Status == "NO")
            {
                PropertyPrf_FAB.SetActionContext("EditItemContext", true);
            }
            if (PropertyInfo_Nested_Doc_Status == "YES")
            {
                PropertyPrf_FAB.SetActionContext("actionItemContext", true);
            }
        }
        else if (e.actionName == "Accept")
        {
            PropertyInfo_AcceptwithoutRemarks();
        }
        else if (e.actionName == "Reject")
        {
            PropertyInfo_AcceptRejectVoucher("Reject");
        }
        else if (e.actionName == "AcceptWithRemarks")
        {
            PropertyInfo_AcceptRejectVoucher("Accept");
        }
        else if (e.actionName == "AcceptDoc") {

            OnPropertyInfo_AcceptDoc();
        }
        else if (e.actionName == "RejectDoc") {

            OnPropertyInfo_RejectDoc();
        }
    }
    function OnPropertyInfo_RejectDoc() {
        if (PropertyInfo_AtachmentID == null || PropertyInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        RejectAttachment(PropertyInfo_AtachmentID, "PropertyListGrid", PropertyInfo_NestedGrid_AccessID);
    }
    function OnPropertyInfo_AcceptDoc() {
        if (PropertyInfo_AtachmentID == null || PropertyInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        AcceptAttachment(PropertyInfo_AtachmentID, "PropertyListGrid", PropertyInfo_NestedGrid_AccessID);
    }
    function PropertyInfo_AcceptwithoutRemarks()
    {
        var Recid;
        if (PropertyInfo_IsDetailRowExpanded == true || LandB_IsVouchingMode == true)
        {
            if (PropertyInfo_MasterRowRecID == null || PropertyInfo_MasterRowRecID == "")
            {
                Recid = PropertyID;
            }
            else
            {
                Recid = PropertyInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = PropertyID;
        }

        Entry_AcceptwithoutRemarks(Recid, "Profile_LandAndBuilding", "PropertyListGrid", PropertyInfo_AtachmentID, PropertyInfo_NestedRowReasonID, PropertyInfo_NestedRowKeyValue);
    }
    function PropertyInfo_AcceptRejectVoucher(_actionMethod)
    {
        var Recid;

        if (PropertyInfo_IsDetailRowExpanded == true || LandB_IsVouchingMode == true)
        {
            if (PropertyInfo_MasterRowRecID == null || PropertyInfo_MasterRowRecID == "")
            {
                Recid = PropertyID;
            }
            else
            {
                Recid = PropertyInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = PropertyID;
        }
        Entry_AcceptReject(_actionMethod, Recid, "Profile_LandAndBuilding", "PropertyListGrid", PropertyInfo_AtachmentID, PropertyInfo_NestedRowReasonID, PropertyInfo_NestedRowKeyValue);
    }
    </script> @* attachment and nested grid *@
