        var PropertyGridLayout = null;
        function PropertyContextMenuFunction(s, e) {
            if (e.item.name == 'New') {
                OnPropertyNewClick();
            }
            if (e.item.name == 'Close') {
                closeProfile_Property();
            }
            else if (e.item.name == 'Edit') {
                OnPropertyEditClick();
            }
            else if (e.item.name == 'Delete') {
                OnPropertyDeleteClick();
            }
            else if (e.item.name == 'View') {
                OnPropertyViewClick();
            }
            else if (e.item.name == 'ChangeRent') {
                OnPropertyChangeRentClick();
            }
            else if (e.item.name == 'ListPreview') {
                OnPropertyListPreviewClick();
            }
            else if (e.item.name == 'NewAudit') {
                OnNewAuditClick_P();
            }
            else if (e.item.name == 'ViewAudit') {
                OnViewAuditClick_P();
            }
            else if (e.item.name == 'Lock') {
                OnPropertyLockClick();
            }
            else if (e.item.name == 'Unlock') {
                PropertyOnUnlockClick();
            }
            else if (e.item.name == 'Refresh') {
                PropertyListGrid.Refresh();
            }
            else if (e.item.name == 'ChangePropertyType') {
                OnPropertyEditClick(false, true);
            }

        }
    </script> @* Main Grid *@
    <script>
    function OnPropertyNewClick()
    {
        if ("@PropertyLB_AddRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Profile/Property/Frm_Property_Window_Profile",
            data: { Tag:"New" },
            cache: false,
            success: function (data)
            {
                OpenDynamicPopup("New ~ Land & Building", null, "auto", 1100, true, data);
            }
        });
    }
        function OnPropertyEditClick(_MultiUserConformation = false, isCallForPropertyTypeChange = false)
    {
        if ("@PropertyLB_UpdateRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        if (PropertyID == 'undefined' || PropertyID == undefined || PropertyID==null)
        {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Profile/Property/DataNavigation",
            data: { ActionMethod: "Edit", ID: PropertyID, MultiUserConfirmation: _MultiUserConformation, isCallForPropertyTypeChange: isCallForPropertyTypeChange},
            cache: false,
            success: function (data)
            {
                if (data.jsonParam.result == true)
                {
                    ShowLoader();
                    $.ajax({
                        type: 'GET',
                        url: "/Profile/Property/Frm_Property_Window_Profile",
                        data: {
                            Tag: "Edit",
                            xID: PropertyID,
                            Info_LastEditedOn: data.Info_LastEditedOn,
                            defaultPropCategory: data.defaultPropCategory,
                            Address: data.Address,
                            EntryType: data.EntryType,
                            isCallForPropertyTypeChange: isCallForPropertyTypeChange,
                        },
                        cache: false,
                        success: function (data)
                        {
                            OpenDynamicPopup("Edit ~ Land & Building", null, "auto", 1100, true, data);
                        }
                    });
                }
                else
                {
                    HideLoader();
                    if (data.jsonParam.isconfirm == true)
                    {
                        DevExpress.ui.dialog.confirm(data.jsonParam.message, data.jsonParam.title).done(function (result)
                        {
                            if (result)
                            {
                                OnPropertyEditClick(true);
                            }
                            else
                            {
                                //RefreshGridView("PropertyListGrid");
                                PropertyListGrid_dx_Refresh();
                            }
                        });
                    }
                    else
                    {
                        DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                        if (data.jsonParam.refreshgrid == true)
                        {
                            //RefreshGridView("PropertyListGrid");
                            PropertyListGrid_dx_Refresh();
                        }
                    }
                }
            }
        });
    }
    function OnPropertyViewClick()
    {
        if ("@PropertyLB_ViewRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        if (PropertyID == 'undefined' || PropertyID == undefined || PropertyID == null)
        {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Profile/Property/DataNavigation",
            data: { ActionMethod: "View", ID: PropertyID },
            cache: false,
            success: function (data)
            {
                if (data.jsonParam.result == true)
                {
                    $.ajax({
                        type: 'GET',
                        url: "/Profile/Property/Frm_Property_Window_Profile",
