    function OnPropertyAddressClick() {
        var Txt_PName_PropertyAddress = $("#Txt_PName").dxTextBox('instance').option('value');
        var Txt_R_Add1_PropertyAddress = $("#Txt_R_Add1").dxTextBox('instance').option('value');
        var Txt_R_Add2_PropertyAddress = $("#Txt_R_Add2").dxTextBox('instance').option('value');
        var Txt_R_Add3_PropertyAddress = $("#Txt_R_Add3").dxTextBox('instance').option('value');
        var Txt_R_Add4_PropertyAddress = $("#Txt_R_Add4").dxTextBox('instance').option('value');
        var Txt_R_Pincode_PropertyAddress = $("#Txt_R_Pincode").dxTextBox('instance').option('value');
        var Txt_Add_PropertyAddress = $("#Txt_Add").dxTextBox('instance').option('value');
        //var GLookUp_StateList_PropertyAddress = $("#GLookUp_StateList").dxDropDownBox('instance').option('value');
        //var GLookUp_DistrictList_PropertyAddress = $("#GLookUp_DistrictList").dxDropDownBox('instance').option('value');
        //var GLookUp_CityList_PropertyAddress = $("#GLookUp_CityList").dxDropDownBox('instance').option('value');

        $.ajax({
            type: 'GET',
            url: "/Account/ProfilePaymentVoucher/AddressChecks",
            data: { Txt_R_Add1: Txt_R_Add1_PropertyAddress, Txt_R_Add2: Txt_R_Add2_PropertyAddress, Txt_R_Add3: Txt_R_Add3_PropertyAddress, Txt_R_Add4: Txt_R_Add4_PropertyAddress, GLookUp_StateList: GLookUp_StateList_PropertyAddress, GLookUp_DistrictList: GLookUp_DistrictList_PropertyAddress, GLookUp_CityList: GLookUp_CityList_PropertyAddress, Txt_R_Pincode: Txt_R_Pincode_PropertyAddress },
            cache: false,
            success: function (data) {

                HideLoader();
                if (data.result) {
                    $("#Txt_Add").dxTextBox({ value: data.Txt_Add });
                    $("#Frm_Property_Window_Property_Address_popup").dxPopup("hide");
                }
                else {
                    DevExpress.ui.dialog.alert(data.message, "Error");
                }

            }
        });
    }
