    function onInitialized_BuildingAddressState(e) {
        e.component.option("dataSource").store.load().done(function (d) {

            if (d.length == 1)
                e.component.option("value", d[0].R_ST_NAME);
        });

        var key = e.component.option("value");
        if (key != null) {
            e.component.getDataSource().store().byKey(key).done(function (result) {
                if (result != null && result != undefined && result != "undefined") {
                    resStateCode = "@Model.tempStateCodeForAddressPopUP";
                    $("#GLookUp_DistrictList").dxDropDownBox("instance").repaint();
                    $("#GLookUp_CityList").dxDropDownBox("instance").repaint();
                }
            })
        }
    }
    function ChangeBuildingAddressCity(e) {

        var dropDownBox = $("#GLookUp_CityList").dxDropDownBox("instance");
        dropDownBox.close();

        var $dataGrid = $("#CityList-datagrid");

        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(e.value, false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                GLookUp_CityList_PropertyAddress = item.R_CI_NAME;

            }
        }
    }
    function ChangeBuildingAddressState(e) {
        var dropDownBox = $("#GLookUp_StateList").dxDropDownBox("instance");
        dropDownBox.close();

        var $dataGrid = $("#StateList-datagrid");

        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(dropDownBox.option("value"), false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                GLookUp_StateList_PropertyAddress = item.R_ST_NAME;
                resStateCode = item.R_ST_CODE;
                if (resStateCode != "") {
                    $("#GLookUp_DistrictList").dxDropDownBox("instance").option("readOnly", false);
                    $("#DistrictList-datagrid").dxDataGrid("instance").refresh();
                }
                if (resStateCode != "") {
                    $("#GLookUp_CityList").dxDropDownBox("instance").option("readOnly", false);
                    $("#CityList-datagrid").dxDataGrid("instance").refresh();
                }
            }
        }
    }
