    function Frm_Property_Window_Ext_OnSuccess(result) {
        if (result.result == false) {
            DevExpress.ui.dialog.alert(result.message, "Error");
            HideLoader();
        }
        else if (result.result == true) {
            DevExpress.ui.dialog.alert(result.message, "Successful");
            HideLoader();
            $("#Frm_Property_Window_Property_Ext_popup").dxPopup("hide");
            Property_Window_ExtendedPropertyGrid.Refresh();
        }
    }

