                            </div>
                        </div><!--[Add]-->
                    </div><!--[row 2]-->
                    <div class="row">
                        <div class="col-sm-3 col-md-3 col-lg-3">
                            <div class="form-field">
                                <label class="control-label text-red" for="Cmd_Ownership_LBW">Ownership:</label>
                                @(Html.DevExtreme().SelectBox().CustomSelectBox() .ID("Cmd_Ownership_LBW") .Name("Cmd_Ownership_LBW") .DataSource(new[] { "INSTITUTION", "THIRD PARTY" }) .OnValueChanged("Cmd_Ownership_SelectedIndexChanged_LBW").ReadOnly(true).FocusStateEnabled(true) )

                            </div>
                        </div><!--[Ownership]-->
                        <div class="col-sm-6 col-md-7 col-lg-7">
                            <div class="form-field">
                                <label class="control-label text-red" for="Look_OwnList_LBW">Owner Name:</label>
                                @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("Look_OwnList_LBW").Name("Look_OwnList_LBW").ValueExpr("ID").DisplayExpr("Name").OnValueChanged("Look_OwnList_EditValueChanged_LBW").ContentTemplate(@<text>@Html.Partial("Frm_Vehicle_Window_GLookUp_OwnList")</text>)
                                  .DataSource(d => d.Mvc().Area("Profile").Controller("Property").LoadAction("LookUp_GetOwnList").Key("ID").LoadParams(new { DDRefresh = new JS("function (){ return OwnerListRefresh_LBW_DD;}") }).LoadMode(DataSourceLoadMode.Raw).CacheRawData(true)).Placeholder("Select Owner...").ReadOnly(true).FocusStateEnabled(false) )
                                @(Html.DevExtreme().TextBox().CustomTextBox() .ID("TextEdit1_LBW") .Name("TextEdit1_LBW") .Value(Model.TextEdit1_LBW) .ReadOnly(true) .Visible(false)  )

                            </div>
                        </div><!--[Owner Name]-->
                        <div class="col-sm-3 col-md-2 col-lg-2">
                            <div class="form-field">
                                @(Html.DevExtreme().Button().ID("But_Owner_LBW").Text("Manage Owner").Icon("add").Width(300) .Disabled(true) .OnClick("PropertyManageOwnerClick_LBW").Icon(Url.Content("../../../../Icons/manage user.png")))
                            </div>
                        </div>
                    </div><!--[row 3]-->
                    <div class="row">
                        <div class="col-sm-2 col-md-2 col-lg-2">
                            <div class="form-field">
                                <label class="control-label" for="Txt_SNo_LBW" id="lbl_surveyNo_lbw">Survey No.:</label>
                                @(Html.DevExtreme().TextBox().CustomTextBox(true) .ID("Txt_SNo_LBW") .Name("Txt_SNo_LBW") .Value(Model.Txt_SNo_LBW) .MaxLength(100) .Placeholder("Type Survey No...")  )

                            </div>
                        </div><!--[Survey No]-->
                        <div class="col-sm-4 col-md-2 col-lg-2">
                            <div class="form-field">
                                <label class="control-label" for="Txt_Tot_Area_LBW" id="lbl_tpa_lbw">Total Plot Area(Sq.Ft.):</label>
                                @(Html.DevExtreme().NumberBox().CustomNumberBox() .Placeholder("Type Plot Area(Sq.Ft.)...") .Format("#0.00") .ID("Txt_Tot_Area_LBW") .Name("Txt_Tot_Area_LBW") .Value(Model.Txt_Tot_Area_LBW)  )

                            </div>
                        </div><!--[Total Area]-->
                        <div class="col-sm-5 col-md-3 col-lg-3">
                            <div class="form-field">
                                <label class="control-label" for="Txt_Con_Area_LBW" id="lbl_con_area_lbw">Constructed Area(Sq.Ft.):</label>
                                @(Html.DevExtreme().NumberBox().CustomNumberBox() .Placeholder("Type Constructed Area(Sq.Ft.)...") .Format("#0.00") .ID("Txt_Con_Area_LBW") .Name("Txt_Con_Area_LBW") .Value(Model.Txt_Con_Area_LBW)   )

                            </div>
                        </div><!--[Const Area]-->
                        <div class="col-sm-6 col-md-2 col-lg-2">
                            <div class="form-field">
                                <label class="control-label" for="user" id="lbl_con_year_lbw">Construction Year:</label>
                                @(Html.DevExtreme().SelectBox().CustomSelectBox() .ID("Cmd_Con_Year_LBW") .Name("Cmd_Con_Year_LBW") .DataSource(ViewBag.Cmd_Con_Year_Bind) .Value(Model.Cmd_Con_Year_LBW) .Placeholder("Year...") )
                            </div>
                        </div><!--[Year]-->
                        <div class="col-sm-6 col-md-3 col-lg-3">
                            <div class="form-field">
                                <label class="control-label" for="Cmd_RccType_LBW" id="lbl_rccType_lbw">RCC Constructed Roof:</label>
                                @(Html.DevExtreme().SelectBox().CustomSelectBox() .ID("Cmd_RccType_LBW") .Name("Cmd_RccType_LBW") .Value(Model.Cmd_RccType_LBW) .DataSource(new[] { "YES", "NO" }) .Placeholder("Select Yes/No...")    )
                            </div>
                        </div><!--[Roof]-->
                    </div><!--[row 4]-->
                    <div class="row">
                        <div class="col-sm-12 col-md-12 col-lg-12">
                            <div class="form-field">

                                @(Html.DevExtreme().TabPanel().ID("ProfileLBTab").Items(items =>
                                                                                                                                                                                               {
                                                                                                                                                                                                   items.Add().Title("Leased And Constructed (Long Term)").Template(@<text> @LeasedAndConstructedView() </text>);
                                                                                                                                                                                        items.Add().Title("Extended Property").Template(@<text> @ExtendedPropertyView()  </text>);
                                                                                                                                                                                items.Add().Title("Documents").Template(@<text> @DocumentsView() </text>);
                                                                                                                                                                    }).DeferRendering(false))
                                @helper LeasedAndConstructedView()
                                {
                                    /**/
                                    @Html.Partial("LB_LeasedConstructed_View", Model);
                                }
                                @helper ExtendedPropertyView()
                                {
                                    /**/
                                    @Html.Partial("LB_ExtendedProperty_View", Model);
                                }
                                @helper DocumentsView()
                                {
                                    /**/
                                    @Html.Partial("LB_Profile_Documents_View", Model);
                                }

                            </div>
                        </div>
                    </div><!--[Tabs]-->
                    <div class="row">
                        <div class="col-sm-8" id="LayoutControlItem25_lbw">
                            <div class="form-field">
                                <div class="row">
                                    <div class="col-sm-2 pll"><label class="control-label" for="Txt_Remarks_LBW">Other Details:</label></div>
                                    <div class="col-sm-10 prm">
                                        @(Html.DevExtreme().TextBox().CustomTextBox(true)
                                                         .ID("Txt_Remarks_LBW")
                                                         .Name("Txt_Remarks_LBW")
                                                         .Value(Model.Txt_Remarks_LBW)

                                                         .MaxLength(8000)
                                                         .Placeholder("Type Any Other Detail / Remarks...")

                                        )

                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-4" id="LayoutControlItem18_lbw">
                            <div class="form-field">
                                <div class="row">
                                    <div class="col-sm-5 col-md-4 col-lg-4 pll"><label class="control-label" for="Txt_LB_Amount_LBW">Opening Value:</label></div>
                                    <div class="col-sm-7 col-md-8 col-lg-8 pll">
                                        @(Html.DevExtreme().NumberBox().CustomNumberBox()
                                                   .Format("#0.00")
                                                   .ID("Txt_LB_Amount_LBW")
                                                   .Name("Txt_LB_Amount_LBW")
                                                   .Value(Model.Txt_LB_Amount_LBW)
                                                   .Placeholder("Type Opening Value...")


                                        )
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-12 col-md-12 col-lg-12">
                            <div class="row">
                                <div class="col-sm-6 col-md-6 col-lg-6">
                                    @Html.Partial("Drop_Request", String.Format("Send Your Request to Madhuban for ( {0} ~ Item Detail (Land & Building Detail)...)...", Model.Tag.ToString().Substring(1)))
                                </div>
                                <div class="col-sm-6 col-md-6 col-lg-6">
                                    <div class="styleActionBtn">
                                        @(Html.DevExtreme().Button().CustomSaveButton(Model.Tag.ToString()).ID("LB_Profile_Save").Text(Model.Tag.ToString() == "_Delete" ? "Delete" : "Save").UseSubmitBehavior(false).OnClick("property_profile_saveClick").Visible(Model.Tag.ToString() == "_View" ? false : true) )
                                        @(Html.DevExtreme().Button().CustomCloseButton().ID("LB_Profile_Cancel").Text(Model.Tag.ToString() == "_View" ? "Close" : "Cancel").FocusStateEnabled(true).OnClick("BUT_CANCEL_Click_LBW"))

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div><!--[Buttons]-->
                    @(Html.DevExtreme().Popup().CustomPopup() .ID("Frm_Property_Window_Property_Address_popup_LBW").Height("auto").Width(550).MaxWidth("100%").CloseOnOutsideClick(true).ShowTitle(true).OnShowing("AddPropertyAddressPopupScroll_LBW").OnHiding("PopupContainerEdit1_Closed_LBW").ContentTemplate(@<text> <div id="result_Frm_Property_Window_Property_Address_popup_LBW"> @Html.Action("Frm_Property_Window_Property_Address", "Property", new { @area = "Profile", @Txt_Address=Model.Txt_Address_LBW, @Txt_R_Add1=Model.Txt_R_Add1_LBW, @Txt_R_Add2=Model.Txt_R_Add2_LBW, @Txt_R_Add3=Model.Txt_R_Add3_LBW, @Txt_R_Add4=Model.Txt_R_Add4_LBW, @GLookUp_StateList=Model.GLookUp_StateList_LBW, @GLookUp_DistrictList=Model.GLookUp_DistrictList_LBW, @GLookUp_CityList=Model.GLookUp_CityList_LBW, @Txt_R_Pincode=Model.Txt_R_Pincode_LBW }) </div> </text>) )
                </div>
            }
        }
    </div>
    <script>
    function property_profile_saveClick(e)
    {
        validations_LBW()
        var result = e.validationGroup.validate();
        if (result.isValid)
        {
            $("#Txt_LB_Amount_ReadOnly").val($("#Txt_LB_Amount_LBW").dxNumberBox("option", "readOnly"));
            $("#MOU_Property_Select").val(false);

            var form = $("#ID_Frm_Property_Window_Form_Profile");

            if ("@Model.Tag" == "_Delete")
            {
                DeleteAfterConfirmation(TransformText("@Model.TitleX"), "", form);
            }
            else
            {
                form.submit();
            }
        }
    }
    function Frm_Property_Window_AjaxSuccessForm_LBW(data)
    {
        HideLoader();
        if (data.xid != null) {
            Property_Select_xid = data.xid;
        }
        if (data.jsonParam.result == false) {

            var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
            alertclick.done(function (alertResult) {
                if (alertResult) {

                    switch (data.jsonParam.focusid) {
                        case "Cmd_PCategory_LBW":
                            $("#Cmd_PCategory_LBW").dxSelectBox("instance").focus();
                            break;
                        case "Cmd_PType_LBW":
                            $("#Cmd_PType_LBW").dxSelectBox("instance").focus();
                            break;
                        case "Cmd_PUse_LBW":
                            $("#Cmd_PUse_LBW").dxSelectBox("instance").focus();
                            break;
                        case "Txt_PName_LBW":
                            $("#Txt_PName_LBW").dxTextBox("instance").focus();
                            break;
                        case "Txt_Add_LBW":
                            $("#Txt_Add_LBW").dxTextBox("instance").focus();
                            break;
                        case "Txt_R_Add1_LBW":
                            $("#Frm_Property_Window_Property_Address_popup_LBW").dxPopup("show");
                            setTimeout(function () { $("#Txt_R_Add1_LBW").dxTextBox("instance").focus(); }, Timeout500);
                            break;
                        case "GLookUp_StateList_LBW":
                            $("#Frm_Property_Window_Property_Address_popup_LBW").dxPopup("show");
                            setTimeout(function () { $("#GLookUp_StateList_LBW").dxDropDownBox("instance").focus(); }, Timeout500);
                            break;
                        case "GLookUp_DistrictList_LBW":
                            $("#Frm_Property_Window_Property_Address_popup_LBW").dxPopup("show");
                            setTimeout(function () { $("#GLookUp_DistrictList_LBW").dxDropDownBox("instance").focus(); }, Timeout500);
                            break;
                        case "GLookUp_CityList_LBW":
                            $("#Frm_Property_Window_Property_Address_popup_LBW").dxPopup("show");
                            setTimeout(function () { $("#GLookUp_CityList_LBW").dxDropDownBox("instance").focus(); }, Timeout500);
                            break;
                        case "Txt_R_Pincode_LBW":
                            $("#Frm_Property_Window_Property_Address_popup_LBW").dxPopup("show");
                            setTimeout(function () { $("#Txt_R_Pincode_LBW").dxTextBox("instance").focus(); }, Timeout500);
                            break;
                        case "Cmd_Ownership_LBW":
                            $("#Cmd_Ownership_LBW").dxSelectBox("instance").focus();
                            break;
                        case "Look_OwnList_LBW":
                            $("#Look_OwnList_LBW").dxDropDownBox("instance").focus();
                            break;
                        case "Txt_SNo_LBW":
                            $("#Txt_SNo_LBW").dxTextBox("instance").focus();
                            break;
                        case "Txt_LB_Amount_LBW":
                            $("#Txt_LB_Amount_LBW").dxNumberBox("instance").focus();
                            break;
                        case "Txt_Tot_Area_LBW":
                            $("#Txt_Tot_Area_LBW").dxNumberBox("instance").focus();
                            break;
                        case "Txt_Con_Area_LBW":
                            $("#Txt_Con_Area_LBW").dxNumberBox("instance").focus();
                            break;
                        case "Cmd_Con_Year_LBW":
                            $("#Cmd_Con_Year_LBW").dxSelectBox("instance").focus();
                            break;
                        case "Cmd_RccType_LBW":
                            $("#Cmd_RccType_LBW").dxSelectBox("instance").focus();
                            break;
                        case "Txt_Dep_Amt_LBW":
                            $("#ProfileLBTab").dxTabPanel("instance").option("selectedIndex", 0);
                            $("#Txt_Dep_Amt_LBW").dxNumberBox("instance").focus();
                            break;
                        case "Txt_Mon_Rent_LBW":
                            $("#ProfileLBTab").dxTabPanel("instance").option("selectedIndex", 0);
                            $("#Txt_Mon_Rent_LBW").dxNumberBox("instance").focus();
                            break;
                        case "Txt_Other_Payments_LBW":
                            $("#ProfileLBTab").dxTabPanel("instance").option("selectedIndex", 0);
                            $("#Txt_Other_Payments_LBW").dxNumberBox("instance").focus();
                            break;
                        case "Txt_T_Date_LBW":
                            $("#ProfileLBTab").dxTabPanel("instance").option("selectedIndex", 0);
                            $("#Txt_T_Date_LBW").dxDateBox("instance").focus();
                            break;
                    }

                    if (data.jsonParam.refreshgrid)
                    {
                        RefreshGridView("PropertyListGrid", ActionAfterDataGridRefresh_PropertyListGrid_dx)
                    }

                    if (data.jsonParam.closeform) {
                        dontaskpopupcloseconfirmation = true;
                        $("#Dynamic_Content_popup").dxPopup("hide");
                    }
                }
            });
        }
        else
        {
            if (data.jsonParam.popup_form_name && data.jsonParam.popup_form_name.length > 0)
            {
                OpenPopup("MOU_Property_Select_popup", data.jsonParam.popup_title, data.jsonParam.popup_form_path + "?" + data.jsonParam.popup_querystring, "auto", 785, false, null);
            }
            else
            {
                var check = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                check.done(function (dialogResult)
                {
                    if (dialogResult)
                    {
                        RefreshGridView("PropertyListGrid", ActionAfterDataGridRefresh_PropertyListGrid_dx.bind(null, "@Model.Tag"))
                        dontaskpopupcloseconfirmation = true;
                        $("#Dynamic_Content_popup").dxPopup("hide");
                    }
                });
            }
        }
    }
    function PropertyManageOwnerClick_LBW(e)
    {
        if ("@PropertyLB_ListAdresBookRight" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        if ("@Model.Tag" == "_New" || "@Model.Tag" == "_Edit" || "@Model.Tag" == "_New_From_Selection")
        {
            ManageParty("LBW_Manage_Party", "LookUp_GetOwnList_LBW","Address Book (Ownership)...");
        }
    }
    function BUT_CANCEL_Click_LBW() {
        $("#Dynamic_Content_popup").dxPopup("hide");
    }
    </script> @* save button and ajax success *@
<script>
    $(document).ready(async function ()
    {
        ShowLoader_Ready();
        TransformTextForDB("ID_Frm_Property_Window_Form_Profile");
        if ("@Model.Tag" != "_View")
        {
            dontaskpopupcloseconfirmation = false;
        }
        sessionclearpath = "/Profile/Property/SessionClear_Window";
        $("#Frm_Property_Window_Property_Address_popup_LBW").dxPopup("show");
        $("#Frm_Property_Window_Property_Address_popup_LBW").dxPopup("hide");
        var tabpanel = $("#ProfileLBTab").dxTabPanel("instance");
        tabpanel.option("items[0].visible", false);
        tabpanel.option("items[1].visible", false);
        tabpanel.option("selectedIndex", 2);
        InitAllDropdownDataGrid_LBW();
        await Promise.all([LookUp_GetOwnList_LBW(true), LookUp_Get_StateList_LBW(true)]);
        if ("@Model.Tag" == "_Edit" || "@Model.Tag" == "_View" || "@Model.Tag" == "_Delete")
        {
            $("#Cmd_PType_LBW").dxSelectBox("instance").option("value", "@Model.Cmd_PType_LBW");
            $("#Cmd_PCategory_LBW").dxSelectBox("instance").option("value", "@Model.Cmd_PCategory_LBW");
            $("#Cmd_PUse_LBW").dxSelectBox("instance").option("value", "@Model.Cmd_PUse_LBW");
            $("#Txt_PName_LBW").dxTextBox("instance").option("value", TransformText("@Model.Txt_PName_LBW"));
            $("#Txt_Address_LBW").dxTextArea("instance").option("value", "@Model.Txt_Address_LBW");
            $("#Txt_Add_LBW").dxTextBox("instance").option("value", TransformText("@Model.Txt_Add_LBW"));
            Control_SetReadOnly("GLookUp_StateList_LBW", "dxDropDownBox", false);
            Control_SetReadOnly("GLookUp_DistrictList_LBW", "dxDropDownBox", false);
            Control_SetReadOnly("GLookUp_CityList_LBW", "dxDropDownBox", false);
            if ("@Model.Txt_R_Add1_LBW".length > 0)
            {
                $("#Txt_R_Add1_LBW").dxTextBox("instance").option("value", TransformText("@Model.Txt_R_Add1_LBW"));
                $("#Txt_R_Add2_LBW").dxTextBox("instance").option("value", TransformText("@Model.Txt_R_Add2_LBW"));
                $("#Txt_R_Add3_LBW").dxTextBox("instance").option("value", TransformText("@Model.Txt_R_Add3_LBW"));
