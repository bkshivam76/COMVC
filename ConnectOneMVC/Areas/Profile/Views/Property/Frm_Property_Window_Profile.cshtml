<script>
    function Cmd_PCategory_SelectedIndexChanged_LBW(e)
    {
        $("#Cmd_PCategory_LBW").dxSelectBox("blur");
        if (e.value != null)
        {
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Profile/Property/Cmd_PCategory_SelectedIndexChanged",
                data:
                {
                    ActionMethod: "@Model.TempActionMethod",
                    xID: "@Model.xID",
                    PCategory: e.value
                },
                cache: false,
                success: function (data)
                {
                    HideLoader();
                    if (data.jsonParam.result == false)
                    {
                        if (data.jsonParam.message)
                        {
                            DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title).done(function (result)
                            {
                                $("#Cmd_PCategory_LBW").dxSelectBox("focus");
                            });
                        }
                        if (data.defaultPropCategory)
                        {
                            $("#Cmd_PCategory_LBW").dxSelectBox("option", "value", data.defaultPropCategory);
                        }
                        else
                        {
                            $("#Cmd_PCategory_LBW").dxSelectBox("option","value",null);
                        }
                    }
                    else if (data.jsonParam.result == true)
                    {
                        if (data.jsonParam.closeform == true)
                        {
                            dontaskpopupcloseconfirmation = true;
                            $("#Dynamic_Content_popup").dxPopup("hide");
                        }
                        if (data.IsLBCarriedFwd == true)
                        {
                            Control_SetReadOnly("Cmd_PCategory_LBW", "dxSelectBox", true);
                            Control_SetReadOnly("Cmd_PType_LBW", "dxSelectBox", true);
                            Control_SetReadOnly("Txt_LB_Amount_LBW", "dxNumberBox", true);
                        }
                        if (data._open_User_Type && data._open_User_Type.toUpperCase() != "SUPERUSER" && data._open_User_Type.toUpperCase() != "AUDITOR")
                        {
                            Control_SetReadOnly("Txt_R_Add1_LBW", "dxTextBox", true);
                            Control_SetReadOnly("Txt_R_Add2_LBW", "dxTextBox", true);
                            Control_SetReadOnly("Txt_R_Add3_LBW", "dxTextBox", true);
                            Control_SetReadOnly("Txt_R_Add4_LBW", "dxTextBox", true);
                            Control_SetReadOnly("Txt_R_Pincode_LBW", "dxTextBox", true);
                            Control_SetReadOnly("GLookUp_CityList_LBW", "dxDropDownBox", true);
                            Control_SetReadOnly("GLookUp_DistrictList_LBW", "dxDropDownBox", true);
                            Control_SetReadOnly("GLookUp_StateList_LBW", "dxDropDownBox", true);
                        }
                        var tabpanel = $("#ProfileLBTab").dxTabPanel("instance");
                        if (e.value.includes("PURCHASED") || e.value.includes("GIFTED") || e.value.includes("MOU"))
                        {
                            tabpanel.option("items[0].visible", false);
                            tabpanel.option("items[1].visible", true);
                            tabpanel.option("selectedIndex", 2);
                        }
                        else if (e.value.includes("LEASED") || e.value.includes("MORTGAGE") || e.value.includes("RENTED"))
                        {
                            if (e.value == "LEASED AND CONSTRUCTED (Long Term)")
                            {
                                tabpanel.option("items[0].visible", true);
                                tabpanel.option("items[1].visible", true);
                                tabpanel.option("selectedIndex", 2);
                                tabpanel.option("items[0].title", e.value.toProperCase());
                                $("#Txt_Dep_Amt_LBW").dxNumberBox("instance").focus();
                            }
                            else
                            {
                                tabpanel.option("items[0].visible", true);
                                tabpanel.option("items[1].visible", false);
                                tabpanel.option("selectedIndex", 2);
                                tabpanel.option("items[0].title", e.value.toProperCase());
                                $("#Txt_Dep_Amt_LBW").dxNumberBox("instance").focus();
                            }
                        }
                        else if (e.value=="FREE USE")
                        {
                            tabpanel.option("items[0].visible", false);
                            tabpanel.option("items[1].visible", false);
                            tabpanel.option("selectedIndex", 2);
                        }
                        if (e.value.includes("PURCHASED") || e.value.includes("GIFTED") || e.value.includes("MOU"))
                        {
                            $("#Cmd_Ownership_LBW").dxSelectBox({ value: "INSTITUTION" });
                        }
                        else
                        {
                            $("#Cmd_Ownership_LBW").dxSelectBox({ value: "THIRD PARTY" });
                        }
                        Cmd_PType_SelectedIndexChanged_LBW();
                        $("#Cmd_PCategory_LBW").dxSelectBox("focus");
                    }
                }
            });
        }
    }
    function Cmd_PType_SelectedIndexChanged_LBW(e)
    {
        var cmdPtype = $("#Cmd_PType_LBW").dxSelectBox("instance").option("value");
        if (cmdPtype == "LAND" || !IsAccountingPropertyCategory_LBW())
        {
            $("#Txt_Con_Area_LBW").dxNumberBox('instance').option('value', '');
            $("#Cmd_Con_Year_LBW").dxSelectBox('instance').option('value', '');
            $("#Cmd_RccType_LBW").dxSelectBox('instance').option('value', 'NO');

            Control_SetReadOnly("Txt_Con_Area_LBW", "dxNumberBox", true);
            Control_SetReadOnly("Cmd_Con_Year_LBW", "dxSelectBox", true);
            Control_SetReadOnly("Cmd_RccType_LBW", "dxSelectBox", true);

            $("#lbl_rccType_lbw").addClass("disabletxt").removeClass("text-red");
            $("#lbl_con_year_lbw").addClass("disabletxt").removeClass("text-red");
            $("#lbl_con_area_lbw").addClass("disabletxt").removeClass("text-red");

        }
        else
        {
            Control_SetReadOnly("Txt_Con_Area_LBW", "dxNumberBox", false);
            Control_SetReadOnly("Cmd_Con_Year_LBW", "dxSelectBox", false);
            Control_SetReadOnly("Cmd_RccType_LBW", "dxSelectBox", false);

            $("#Txt_Con_Area_LBW").dxNumberBox('instance').option('value', '');
            $("#Cmd_Con_Year_LBW").dxSelectBox('instance').option('value', '');
            $("#Cmd_RccType_LBW").dxSelectBox('instance').option('value', '');

            $("#lbl_rccType_lbw").removeClass("disabletxt").addClass("text-red");
            $("#lbl_con_year_lbw").removeClass("disabletxt").addClass("text-red");
            $("#lbl_con_area_lbw").removeClass("disabletxt").addClass("text-red");
        }
        if (cmdPtype == "LAND")
        {
            $('#lbl_tpa_lbw').removeClass("disabletxt").addClass("text-red");
        }
        else
        {
            $('#lbl_tpa_lbw').removeClass("disabletxt").removeClass("text-red");
        }
        if (IsAccountingPropertyCategory_LBW())
        {
            $('#lbl_surveyNo_lbw').removeClass("disabletxt").addClass("text-red");
        }
        else
        {
            if (cmdPtype == "LAND")
            {
                $('#lbl_surveyNo_lbw').removeClass("disabletxt").addClass("text-red");
            }
            else
            {
                $('#lbl_surveyNo_lbw').removeClass("disabletxt").removeClass("text-red");
            }
        }
    }
    function Cmd_PUse_SelectedIndexChanged_LBW(e)
    {
        $("#Cmd_PUse_LBW").dxSelectBox("blur");
        if (e.value == "MAIN CENTRE")
        {
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Profile/Property/Cmd_PUse_SelectedIndexChanged",
                cache: false,
                success: async function (data)
                {
                    HideLoader();
                    if (data.result == false)
                    {
                        DevExpress.ui.dialog.alert(data.message, 'Error');
                        $("#Cmd_PUse_LBW").dxSelectBox("focus");
                    }
                    else
                    {
                        $("#Txt_PName_LBW").dxTextBox({ value: TransformText(data.Txt_PName) });
                        if (PUse_ValueChange_FirstCall_LBW  &&   "@Model.Tag" != "_New")
                        {
                            $("#Txt_PName_LBW").dxTextBox("instance").option("value", TransformText("@Model.Txt_PName_LBW"));
                        }
                        PUse_ValueChange_FirstCall_LBW = false;
                        $("#Txt_R_Add1_LBW").dxTextBox({ value: TransformText(data.Txt_R_Add1) });
                        $("#Txt_R_Add2_LBW").dxTextBox({ value: TransformText(data.Txt_R_Add2) });
                        $("#Txt_R_Add3_LBW").dxTextBox({ value: TransformText(data.Txt_R_Add3) });
                        $("#Txt_R_Add4_LBW").dxTextBox({ value: TransformText(data.Txt_R_Add4) });
                        Control_SetReadOnly("Txt_R_Add1_LBW", "dxTextBox", true, "#696969");
                        Control_SetReadOnly("Txt_R_Add2_LBW", "dxTextBox", true, "#696969");
                        Control_SetReadOnly("Txt_R_Add3_LBW", "dxTextBox", true, "#696969");
                        Control_SetReadOnly("Txt_R_Add4_LBW", "dxTextBox", true, "#696969");
                        if (data.Cen_State_ID.length > 0)
                        {
                            await State_LBW_DG.selectRows(data.Cen_State_ID, false);
                        }
                        wait_LBW();
                        async function wait_LBW()
                        {
                            ShowLoader();
                            if (StateDDvalueChangeFinishExecution_LBW)
                            {
                                Control_SetReadOnly("GLookUp_StateList_LBW", "dxDropDownBox", true, "#696969");
                                if (data.Cen_District_ID.length > 0)
                                {
                                    await District_LBW_DG.selectRows(data.Cen_District_ID, false);
                                }
                                Control_SetReadOnly("GLookUp_DistrictList_LBW", "dxDropDownBox", true, "#696969");
                                if (data.Cen_City_ID.length > 0)
                                {
                                    await City_LBW_DG.selectRows(data.Cen_City_ID, false);
                                }
                                Control_SetReadOnly("GLookUp_CityList_LBW", "dxDropDownBox", true, "#696969");
                                $("#Txt_R_Pincode_LBW").dxTextBox({ value: data.Txt_R_Pincode });
                                Control_SetReadOnly("Txt_R_Pincode_LBW", "dxTextBox", true, "#696969");
                                PopupContainerEdit1_Closed_LBW();
                                $("#Cmd_PUse_LBW").dxSelectBox("focus");
                                HideLoader();
                            }
                            else
                            {
                                setTimeout(function ()
                                {
                                    wait_LBW();
                                }, Timeout100);
                            }
                        }
                    }
                }
            });
        }
        else
        {
            $("#Txt_Add_LBW").dxTextBox({ value: "" });
            $("#Txt_PName_LBW").dxTextBox({ value: "" });
            $("#Txt_Address_LBW").dxTextArea({ value: "" });
            $("#Txt_R_Add1_LBW").dxTextBox({ value: "" });
            $("#Txt_R_Add2_LBW").dxTextBox({ value: "" });
            $("#Txt_R_Add3_LBW").dxTextBox({ value: "" });
            $("#Txt_R_Add4_LBW").dxTextBox({ value: "" });
            $("#Txt_R_Pincode_LBW").dxTextBox({ value: "" });
            Control_SetReadOnly("Txt_R_Add1_LBW", "dxTextBox", false);
            Control_SetReadOnly("Txt_R_Add2_LBW", "dxTextBox", false);
            Control_SetReadOnly("Txt_R_Add3_LBW", "dxTextBox", false);
            Control_SetReadOnly("Txt_R_Add4_LBW", "dxTextBox", false);
            Control_SetReadOnly("Txt_R_Pincode_LBW", "dxTextBox", false);
            $("#GLookUp_StateList_LBW").dxDropDownBox("instance").reset();
            $("#GLookUp_DistrictList_LBW").dxDropDownBox("instance").reset();
            $("#GLookUp_CityList_LBW").dxDropDownBox("instance").reset();
            Control_SetReadOnly("GLookUp_CityList_LBW", "dxDropDownBox", false);
            Control_SetReadOnly("GLookUp_DistrictList_LBW", "dxDropDownBox", false);
            Control_SetReadOnly("GLookUp_StateList_LBW", "dxDropDownBox", false);
            $("#Cmd_PUse_LBW").dxSelectBox("focus");
            PUse_ValueChange_FirstCall_LBW = false;
        }
    }
    function Cmd_Ownership_SelectedIndexChanged_LBW(e)
    {
        if (e.value)
        {
            if (e.value == "INSTITUTION")
            {
                $("#TextEdit1_LBW").dxTextBox({ visible: true });
                $("#Look_OwnList_LBW").dxDropDownBox({ visible: false });
                Control_SetReadOnly("Look_OwnList_LBW", "dxDropDownBox", true);
                $("#But_Owner_LBW").dxButton({ disabled: true });
                OwnerList_LBW_DG.clearSelection();
            }
            else
            {
                $("#TextEdit1_LBW").dxTextBox({ visible: false });
                $("#Look_OwnList_LBW").dxDropDownBox({ visible: true });
                Control_SetReadOnly("Look_OwnList_LBW", "dxDropDownBox", false);
                OwnerList_LBW_DG.clearSelection();
                if ("@Model.Tag" != "_View" && "@Model.Tag" != "_Delete")
                {
                    $("#But_Owner_LBW").dxButton({ disabled: false });
                }
            }
        }
    }
    function IsAccountingPropertyCategory_LBW()
    {
        var Category = $("#Cmd_PCategory_LBW").dxSelectBox("instance").option("value");
        if (Category == "PURCHASED" || Category == "PURCHASED AND CONSTRUCTED" || Category == "GIFTED" || Category == "GIFTED AND CONSTRUCTED" || Category == "LEASED (Long Term)" || Category == "LEASED AND CONSTRUCTED (Long Term)" || Category == "MOU")
        {
            return true;
        }
        return false;
    }
    function Chk_OtherDoc_CheckedChanged_LBW(e)
    {
        if (e.value)
        {
            $("#Txt_OtherDoc_LBW").dxTextBox({ readOnly: false });
            $("#Txt_OtherDoc_LBW").dxTextBox("instance").reset();
            $("#Txt_OtherDoc_LBW").dxTextBox("instance").focus();
        }
        else
        {
            $("#Txt_OtherDoc_LBW").dxTextBox("instance").reset();
            $("#Txt_OtherDoc_LBW").dxTextBox({ readOnly: true });
        }
    }
</script> @* other value change *@
