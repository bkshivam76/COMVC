<div class="LandBuilding_Window_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    @model ConnectOneMVC.Areas.Profile.Models.PropertyWindowProfile
    @{
        bool PropertyLB_LockUnlockRight = (bool)ViewData["PropertyLB_LockUnlockRight"];
        bool PropertyLB_ListAdresBookRight = (bool)ViewData["PropertyLB_ListAdresBookRight"];
        Html.EnableClientValidation();
        Html.EnableUnobtrusiveJavaScript();
        Html.AntiForgeryToken();
        string UserType = (string)ViewBag.userType;
        bool? InsuranceAuditor = ViewBag.InsuranceAuditor == null ? (bool?)null : (bool)ViewBag.InsuranceAuditor;
        int? TransactionCount = ViewBag.TransactionCount == null ? (int?)null : (int)ViewBag.TransactionCount;
    }
    <style>
        #Frm_Property_Window_popup_profile {
            padding-left: 0px;
            padding-right: 0px;
        }

        #But_Owner_LBW .dx-icon {
            width: 32px;
            height: 32px;
            /*  line-height: normal;
        left: 45px;
        top: -10px;
        bottom: 0;*/
        }

        #But_Owner_LBW .dx-button-content {
            height: inherit;
            padding-top: 11px;
            padding-bottom: 11px;
            padding-left: 30px;
        }
    </style>

    <div id="Frm_Property_Window_popup_profile" class="col-md-12">
        @using (Ajax.BeginForm("Frm_Property_Window_BUT_SAVE_Click", "Property",
               new AjaxOptions
               {
                   HttpMethod = "POST",
                   UpdateTargetId = "Frm_Property_Window_popup",
                   InsertionMode = InsertionMode.InsertAfter,
                   OnBegin = "AjaxBeginFormPost",
                   OnSuccess = "Frm_Property_Window_AjaxSuccessForm_LBW"
               },
