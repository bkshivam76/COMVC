                Control_SetReadOnly("Cmd_PCategory_LBW", "dxSelectBox", true);
                Control_SetReadOnly("Txt_LB_Amount_LBW", "dxNumberBox", true);
            }
            if ("@InsuranceAuditor" == "False")
            {
                Control_SetReadOnly("Txt_Con_Area_LBW", "dxNumberBox", true);
                Control_SetReadOnly("Cmd_Con_Year_LBW", "dxSelectBox", true);
                Control_SetReadOnly("Cmd_RccType_LBW", "dxSelectBox", true);
            }
        }
        if ("@UserType".toUpperCase() != "SUPERUSER" && "@UserType".toUpperCase() != "AUDITOR")
        {
            $("#LayoutControlItem18_lbw").hide();
            $("#LayoutControlItem25_lbw").removeClass("col-sm-8").addClass("col-sm-12");
        }
        validations_LBW()
        setTimeout(function ()
        {
            if ("@Model.isCallForPropertyTypeChange" == "True") {
                Set_Form_View_Delete_Mode(null, "ID_Frm_Property_Window_Form_Profile", "View");

                Control_SetReadOnly("Cmd_PType_LBW", "dxSelectBox", false);
                Control_SetReadOnly("Txt_SNo_LBW", "dxTextBox", false);
                Control_SetReadOnly("Txt_Tot_Area_LBW", "dxNumberBox", false);
