        $("#Txt_Add_LBW").dxTextBox({ value: "" });
    }
    function PopupContainerEdit1_Closed_LBW(e)
    {
        $("#Txt_Add_LBW").dxTextBox("focus");
        $("#Txt_Add_LBW").dxTextBox({ value: TransformText($("#Txt_Address_LBW").dxTextArea("instance").option("value")) });
        var Txt_R_Add1 = $("#Txt_R_Add1_LBW").dxTextBox('instance').option('value');
        var Txt_R_Add2 = $("#Txt_R_Add2_LBW").dxTextBox('instance').option('value');
        var Txt_R_Add3 = $("#Txt_R_Add3_LBW").dxTextBox('instance').option('value');
        var Txt_R_Add4 = $("#Txt_R_Add4_LBW").dxTextBox('instance').option('value');
        var Txt_R_Pincode = $("#Txt_R_Pincode_LBW").dxTextBox('instance').option('value');
        if (Txt_R_Add1 != null && Txt_R_Add1.length > 0)
        {
            var Address = Txt_R_Add1 + (Txt_R_Add2 != null && Txt_R_Add2.length > 0 ? ", " + Txt_R_Add2 : "") +
                (Txt_R_Add3 != null && Txt_R_Add3.length > 0 ? ", " + Txt_R_Add3 : "") +
                (Txt_R_Add4 != null && Txt_R_Add4.length > 0 ? ", " + Txt_R_Add4 : "") + ", " + (GLookUp_CityName_LBW == null ? "" : GLookUp_CityName_LBW.toUpperCase()) +
                ",Dist. " + (GLookUp_DistrictName_LBW == null ? "" : GLookUp_DistrictName_LBW) + ", " + (GLookUp_StateName_LBW == null ? "" : GLookUp_StateName_LBW) + "-" + Txt_R_Pincode;
            $("#Txt_Add_LBW").dxTextBox({ value: TransformText(Address) });
        }
    }
    function OnPropertyAddressOKClick_LBW(e)
    {
        ShowLoader();
        var Txt_R_Add1_PropertyAddress = $("#Txt_R_Add1_LBW").dxTextBox('instance').option('value');
        var Txt_R_Pincode_PropertyAddress = $("#Txt_R_Pincode_LBW").dxTextBox('instance').option('value');
        if (IsNullOrWhitespace("Txt_R_Add1_LBW"))
        {
            HideLoader();
            DevExpress.ui.dialog.alert("Property Address Cannot Be Blank...!", "Incomplete Information...").done(function (r)
            {
                setTimeout(function ()
                {
                    $("#Txt_R_Add1_LBW").find('input').focus();
                }, Timeout100);
            });
            return;
        }
        if (State_LBW_DG.getSelectedRowsData().length < 1)
        {
            HideLoader();
            DevExpress.ui.dialog.alert("State Cannot Be Blank...!", "Incomplete Information...").done(function (r)
            {
            setTimeout(function ()
            {
                $("#GLookUp_StateList_LBW").find('input').focus();
            }, Timeout100);
            });
            return;
        }
        if (District_LBW_DG.getSelectedRowsData().length < 1)
        {
            HideLoader();
            DevExpress.ui.dialog.alert("District Cannot Be Blank...!", "Incomplete Information...").done(function (r) {
            setTimeout(function ()
            {
                $("#GLookUp_DistrictList_LBW").find('input').focus();
            }, Timeout100);
            });
            return;
        }
        if (City_LBW_DG.getSelectedRowsData().length < 1)
        {
            HideLoader();
            DevExpress.ui.dialog.alert("City Cannot Be Blank...!", "Incomplete Information...").done(function (r) {
            setTimeout(function ()
            {
                $("#GLookUp_CityList_LBW").find('input').focus();
            }, Timeout100);
            });
            return;
        }
        if (Txt_R_Pincode_PropertyAddress == null || Txt_R_Pincode_PropertyAddress.length == 0)
        {
            HideLoader();
            DevExpress.ui.dialog.alert("Pincode Cannot Be Blank...!", "Incomplete Information...").done(function (r) {
            setTimeout(function () {
                $("#Txt_R_Pincode_LBW").find('input').focus();
            }, Timeout100);
            });
            return;
        }
        if ($("#Txt_R_Pincode_LBW").dxTextBox('instance').option('isValid') == false || Txt_R_Pincode_PropertyAddress.length < 6)
        {
            HideLoader();
            DevExpress.ui.dialog.alert("Pincode Is Invalid", "Incomplete Information...").done(function (r) {
            setTimeout(function () {
                $("#Txt_R_Pincode_LBW").find('input').focus();
            }, Timeout100);
            });
            return;
        }
        $("#Frm_Property_Window_Property_Address_popup_LBW").dxPopup("hide");
        HideLoader();
    }
