    function Look_OwnList_EditValueChanged_LBW(e)
    {
        var OwnerDropdown = $("#Look_OwnList_LBW").dxDropDownBox("instance")
        OwnerDropdown.close();
        if ((e.value == null||e.value.length==0) && e.previousValue != null)
        {
            OwnerList_LBW_DG.clearSelection();
        }
        if (OwnerList_LBW_DG.getSelectedRowsData().length > 0)
        {
            var SelectedItemRow = OwnerList_LBW_DG.getSelectedRowsData()[0];
            $("#Owner_Rec_Edit_On").val(SelectedItemRow.REC_EDIT_ON);
        }
    }
    function GLookUp_StateList_EditValueChanged_LBW(e)
    {
        StateDDvalueChangeFinishExecution_LBW = false;
        e.component.close();
        if ((e.value == null || e.value.length == 0) && e.previousValue != null)
        {
            State_LBW_DG.clearSelection();
            GLookUp_StateName_LBW = null;
            resStateCode_LBW = null;
            Promise.all([LookUp_Get_DistrictList_LBW(), LookUp_Get_CityList_LBW()]);
            District_LBW_DG.clearSelection();
            City_LBW_DG.clearSelection();
            StateDDvalueChangeFinishExecution_LBW = true;
            return;
        }
        if (State_LBW_DG.getSelectedRowsData().length > 0)
        {
            var item = State_LBW_DG.getSelectedRowsData()[0];
            GLookUp_StateName_LBW = item.R_ST_NAME;
            resStateCode_LBW = item.R_ST_CODE;
            District_LBW_DG.clearSelection();
            City_LBW_DG.clearSelection();
            Promise.all([LookUp_Get_DistrictList_LBW("@Model.Tag" === "_New" ? false : StateDDvalueChangeExecution_LBW_FirstTime), LookUp_Get_CityList_LBW("@Model.Tag" === "_New" ? false : StateDDvalueChangeExecution_LBW_FirstTime)]).then(([r1, r2])=>
            {
                StateDDvalueChangeExecution_LBW_FirstTime = false;
                StateDDvalueChangeFinishExecution_LBW = true;
            });
        }
    }
    function GLookUp_DistrictList_EditValueChanged_LBW(e)
    {
        e.component.close();
        if ((e.value == null || e.value.length == 0) && e.previousValue != null)
        {
            District_LBW_DG.clearSelection();
            GLookUp_DistrictName_LBW = null;
            return;
        }
        if (District_LBW_DG.getSelectedRowsData().length > 0)
        {

            var item = District_LBW_DG.getSelectedRowsData()[0];
            GLookUp_DistrictName_LBW = item.R_DI_NAME;
        }
    }
    function GLookUp_CityList_EditValueChanged_LBW(e)
    {
        e.component.close();
        if ((e.value == null || e.value.length == 0) && e.previousValue != null)
        {
            City_LBW_DG.clearSelection();
            GLookUp_CityName_LBW = null;
            return;
        }
        if (City_LBW_DG.getSelectedRowsData().length > 0)
        {
            var item = City_LBW_DG.getSelectedRowsData()[0];
            GLookUp_CityName_LBW = item.R_CI_NAME;
        }
    }
