               {
                   id = "ID_Frm_Property_Window_Form_Profile",
                   @class = "edit_form form-horizontal"
               }))
        {
            @Html.HiddenFor(x => x.TitleX)
            @Html.HiddenFor(x => x.SubTitleX)
            @Html.HiddenFor(x => x.Info_LastEditedOn)
            @Html.HiddenFor(x => x.LastEditedOn)
            @Html.HiddenFor(x => x.YearID)
