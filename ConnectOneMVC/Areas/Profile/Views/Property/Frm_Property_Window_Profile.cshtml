                        return $("#Txt_F_Date_LBW").dxDateBox("option", "isValid")
                    },
                    reevaluate: true,
                    ignoreEmptyValue: true
                }],

                validationGroup: "LandAndBuilding_Profile"
            });
        $("#Txt_T_Date_LBW").dxDateBox({})
            .dxValidator({
                validationRules: [{
                    type: 'custom',
                    validationCallback: function (options) {
                        return $("#Txt_T_Date_LBW").dxDateBox("option", "isValid")
                    },
                    reevaluate: true,
                    ignoreEmptyValue: true
                }],

                validationGroup: "LandAndBuilding_Profile"
            });}
