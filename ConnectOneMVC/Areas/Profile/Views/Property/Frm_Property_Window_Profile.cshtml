    var Refresh_State_LBW_DD = false;
    var Refresh_District_LBW_DD = false;
    var Refresh_City_LBW_DD = false;
    var OwnerListRefresh_LBW_DD = false;

    var GLookUp_StateName_LBW = null;
    var resStateCode_LBW = null;
    var StateDDvalueChangeExecution_LBW_FirstTime = true;
    var StateDDvalueChangeFinishExecution_LBW = true;
    var GLookUp_DistrictName_LBW = null;
    var GLookUp_CityName_LBW = null;
    var PUse_ValueChange_FirstCall_LBW = true;

    function InitAllDropdownDataGrid_LBW()
    {
        var $LBW_State_DG = $("#StateList-datagrid_LBW");
        if ($LBW_State_DG.length)
        {
            State_LBW_DG = $LBW_State_DG.dxDataGrid("instance");
        }
