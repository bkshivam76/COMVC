                $("#lbl_tpa_lbw").removeClass("disabletxt");
                $("#lbl_con_area_lbw").removeClass("disabletxt");
                $("#lbl_con_year_lbw").removeClass("disabletxt");
                $("#lbl_rccType_lbw").removeClass("disabletxt");
                Cmd_PType_SelectedIndexChanged_LBW();
                $("#Cmd_PType_LBW").dxSelectBox('instance').focus();
            }
            else {
                Set_Form_View_Delete_Mode(null, "ID_Frm_Property_Window_Form_Profile", "@Model.Tag");
                $("#Cmd_PCategory_LBW").dxSelectBox('instance').focus();
            }
            HideLoader_Ready();
        }, Timeout500);      
    })
    function validations_LBW()
    {
        $("#Txt_PaidDate_LBW").dxDateBox({})
        .dxValidator({
            validationRules: [{
                type: 'custom',
                validationCallback: function (options)
                {
                    return $("#Txt_PaidDate_LBW").dxDateBox("option","isValid")
                },
                reevaluate: true,
                ignoreEmptyValue:true
