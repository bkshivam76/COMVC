            @Html.HiddenFor(x => x.xID)
            @Html.HiddenFor(x => x.MOU_Property_Select)
            @Html.HiddenFor(x => x.isCallForPropertyTypeChange)
            using (Html.DevExtreme().ValidationGroup("LandAndBuilding_Profile"))
            {
                <div class="container-fluid">
                    <div class="full-width-header-bg2">
                        <div class="row">
                            <div class="col-sm-8 pll">
                                <h3 class="popuphead"><i class="far fa-edit"></i> @Model.TitleX </h3><i class="fas fa-star yellowstar"></i><span class="blu-txt2"> @Model.SubTitleX</span>
                            </div>
                            <div class="col-sm-4 prm">
                                <h5 class="mand-txt-align"><i class="fas fa-info-circle"></i> Red Fields are mandatory</h5>
                            </div>
                        </div>
                    </div><!--[Header]-->
                    <div class="row">
                        <div class="col-sm-4 col-md-4 col-lg-4">
                            <div class="form-field">
                                <label class="control-label text-red" for="Cmd_PCategory_LBW">Property Category:</label>
                                @(Html.DevExtreme().SelectBox().CustomSelectBox() .ID("Cmd_PCategory_LBW") .Name("Cmd_PCategory_LBW") .Placeholder("Select Category...").DataSource(new[] { "PURCHASED", "PURCHASED AND CONSTRUCTED", "GIFTED", "GIFTED AND CONSTRUCTED", "RENTED", "LEASED (Short Term)", "LEASED (Long Term)", "LEASED AND CONSTRUCTED (Long Term)", "MORTGAGE (Short Term)", "FREE USE", "MOU" })
                                  .OnValueChanged("Cmd_PCategory_SelectedIndexChanged_LBW").ShowClearButton(false))
                            </div>
                        </div><!--[category]-->
                        <div class="col-sm-4 col-md-4 col-lg-4">
                            <div class="form-field">
                                <label class="control-label text-red" for="Cmd_PType_LBW" id="lbl_PType_LBW">Property Type:</label>
                                @(Html.DevExtreme().SelectBox().CustomSelectBox() .ID("Cmd_PType_LBW") .Name("Cmd_PType_LBW")   .Placeholder("Select Type...")  .OnValueChanged("Cmd_PType_SelectedIndexChanged_LBW")  .DataSource(new[] { "LAND", "BUILDING", "FLAT", "FLAT (in Multiple Floor)" }) )

                            </div>
                        </div><!--[Type]-->
                        <div class="col-sm-4 col-md-4 col-lg-4">
                            <div class="form-field">
                                <label class="control-label text-red" for="Cmd_PUse_LBW">Use of Property:</label>
                                @(Html.DevExtreme().SelectBox().CustomSelectBox() .ID("Cmd_PUse_LBW") .Name("Cmd_PUse_LBW") .DataSource(new[] { "MAIN CENTRE", "CLASS", "MUSEUM", "STORE", "GARDEN", "GARAGE", "DEPARTMENT", "RESIDENCE", "RETREAT CENTRE", "NOT IN USE" })   .Placeholder("Select Use of Property...") .OnValueChanged("Cmd_PUse_SelectedIndexChanged_LBW")   )

                            </div>
                        </div><!--[Use]-->
                    </div><!--[row 1]-->
                    <div class="row">
                        <div class="col-sm-4 col-md-4 col-lg-4">
                            <div class="form-field">
                                <label class="control-label text-red" for="Txt_PName_LBW">Property / Building Name:</label>
