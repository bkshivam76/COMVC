    async function LookUp_GetOwnList_LBW(FirstCall = false)
    {
        if (FirstCall === false)
        {
            OwnerListRefresh_LBW_DD = true;
            await OwnerList_LBW_DG.refresh();
            OwnerListRefresh_LBW_DD = false;
        }
        ResetDropdownWithSameValue("Look_OwnList_LBW", OwnerList_LBW_DG);
    }
    async function LookUp_Get_StateList_LBW(FirstCall = false)
    {
        if (FirstCall === false)
        {
            Refresh_State_LBW_DD = true;
            await State_LBW_DG.refresh();
            Refresh_State_LBW_DD = false;
        }
        if ("@Model.Tag" == "_New")
        {
            Control_SetReadOnly("GLookUp_StateList_LBW", "dxDropDownBox", false);
        }
