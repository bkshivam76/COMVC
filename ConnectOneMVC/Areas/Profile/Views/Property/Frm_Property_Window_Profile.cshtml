            {
               await OwnerList_LBW_DG.selectRows("@Model.Look_OwnList_LBW", false);
            }
            $("#Txt_SNo_LBW").dxTextBox("instance").option("value", TransformText("@Model.Txt_SNo_LBW"));
            $("#Txt_Tot_Area_LBW").dxNumberBox("instance").option("value", parseFloat("@Model.Txt_Tot_Area_LBW"));
            $("#Txt_Con_Area_LBW").dxNumberBox("instance").option("value", parseFloat("@Model.Txt_Con_Area_LBW"));
            $("#Cmd_Con_Year_LBW").dxSelectBox("instance").option("value", "@Model.Cmd_Con_Year_LBW");
            $("#Cmd_RccType_LBW").dxSelectBox("instance").option("value", "@Model.Cmd_RccType_LBW");
