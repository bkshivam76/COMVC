    async function LookUp_Get_DistrictList_LBW(FirstCall = false)
    {
        if (FirstCall === false)
        {
            Refresh_District_LBW_DD = true;
            await District_LBW_DG.refresh();
            Refresh_District_LBW_DD = false;
        }
        if ("@Model.Tag" == "_New")
        {
            Control_SetReadOnly("GLookUp_DistrictList_LBW", "dxDropDownBox", false);
        }
    }
    async function LookUp_Get_CityList_LBW(FirstCall = false)
    {
        if (FirstCall === false)
        {
            Refresh_City_LBW_DD = true;
            await City_LBW_DG.refresh();
