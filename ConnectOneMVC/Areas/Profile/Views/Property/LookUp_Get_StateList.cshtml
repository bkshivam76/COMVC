
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("StateList-datagrid_LBW")   
    .Columns(columns =>
    {
        columns.Add().DataField("R_ST_REC_ID").Visible(false);
        columns.Add().DataField("R_ST_NAME").Caption("State");
        columns.Add().DataField("R_ST_CODE").Visible(false);
    })   
    .Selection(s => s.Mode(SelectionMode.Single)))

