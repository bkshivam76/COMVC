@{ 
    var SessionGUID = Request.QueryString["SessionGUID"];
}

@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "Property_ExtendedPropertyGrid_LBW";
        settings.CallbackRouteValues = new
        {
            Controller = "Property",
            Action = "SetGridData",
            ActionMethodName="_View",
            SessionGUID = SessionGUID

        };
        settings.Settings.VerticalScrollBarMode = ScrollBarMode.Visible;
        settings.Settings.VerticalScrollableHeight = 100;
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Visible;
        settings.KeyboardSupport = true;
        //settings.AccessKey = "G";
        settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
        settings.Settings.UseFixedTableLayout = true;

        settings.Settings.ShowGroupFooter = GridViewGroupFooterMode.Hidden;


        settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
        settings.SettingsBehavior.AllowSort = true;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsResizing.Visualization = ResizingMode.Live;
        settings.SettingsBehavior.AllowEllipsisInText = true;

        // Filter and serach
        settings.Settings.ShowFilterRowMenu = true;
        settings.Settings.ShowFilterBar = GridViewStatusBarMode.Hidden;
        settings.Settings.ShowFilterRow = false;
        settings.Settings.AutoFilterCondition = AutoFilterCondition.Contains;

        settings.SettingsPager.Mode = GridViewPagerMode.ShowAllRecords;
        settings.SettingsSearchPanel.ShowApplyButton = true;
        settings.SettingsSearchPanel.ShowClearButton = true;

        settings.SettingsBehavior.AllowFocusedRow = true;
        settings.ClientSideEvents.FocusedRowChanged = "OnExtendedPropertyGrid_LBW_FocusedRowChanged";
        settings.ClientSideEvents.RowDblClick = "OnFrm_Property_Window_Ext_LBW_EditClick";

        settings.Settings.ShowHeaderFilterBlankItems = false;

        settings.Settings.ShowHeaderFilterBlankItems = false;

        settings.SettingsContextMenu.Enabled = false;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.Refresh = false;
        settings.FillContextMenuItems = (sender, e) =>
        {
            if (e.MenuType == GridViewContextMenuType.Rows)
            {
                var Additem = e.CreateItem("New", "New");
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Additem);
                Additem.Image.IconID = "actions_new_16x16gray";
                var Edititem = e.CreateItem("Edit", "Edit");
                Edititem.Image.IconID = "actions_edit_16x16devav";
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Edititem);
                var Deleteitem = e.CreateItem("Delete", "Delete");
                Deleteitem.Image.IconID = "actions_delete_16x16devav";
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Deleteitem);

            }
        };
        settings.ClientSideEvents.ContextMenuItemClick = "OnFrm_Property_Window_Ext_LBW_ContextMenuFunction";

        settings.KeyFieldName = "Sr";

        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Sr";
                column.Caption = "Sr.";
                column.Visible = true;
                column.Width = 50;
                column.SortAscending();
                column.FixedStyle = GridViewColumnFixedStyle.Left;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Institution";
                column.Caption = "Institution";
                column.Visible = true;
                column.Width = 350;
                column.FixedStyle = GridViewColumnFixedStyle.Left;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Total_Plot_Area";
                column.Caption = "Total Plot Area(Sq.Ft.)";
                column.Visible = true;
                column.Width = 150;
                column.PropertiesEdit.DisplayFormatString = "#0.###";
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Constructed_Area";
                column.Caption = "Constructed Area(Sq.Ft.)";
                column.Visible = true;
                column.Width = 160;
                column.PropertiesEdit.DisplayFormatString = "#0.###";
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Construction_Year";
                column.Caption = "Construction Year";
                column.Visible = true;
                column.Width = 120;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "M_O_U_Date";
                column.Caption = "M.O.U Date";
                column.Visible = true;
                column.Width = 120;
                column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Value";
                column.Caption = "Value";
                column.Visible = true;
                column.Width = 80;
               
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Other_Detail";
                column.Caption = "Other Detail";
                column.Visible = true;
                column.Width = 170;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Ins_ID";
                column.Caption = "Ins_ID";
                column.Visible = false;
                column.Width = 80;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Value";
                column.Caption = "Value";
                column.Visible = false;
                column.Width = 80;
                column.PropertiesEdit.DisplayFormatString = "#.000";
            }
        });

        settings.Settings.ShowFilterBar = GridViewStatusBarMode.Hidden;
        settings.SettingsFilterControl.ViewMode = true ? FilterControlViewMode.VisualAndText : FilterControlViewMode.Visual;
        settings.SettingsFilterControl.AllowHierarchicalColumns = true;// AllowHierarchicalColumns;
        settings.SettingsFilterControl.ShowAllDataSourceColumns = true;//FilterBuilderDemoHelper.Options.ShowAllDataSourceColumns;
        settings.SettingsFilterControl.MaxHierarchyDepth = 1;

    }).Bind(Model).GetHtml()

