@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("LookUp_GetOwnerList_ServicePlaces_datagrid")  
    .Columns(columns =>
    {
        columns.Add().DataField("ID").Caption("ID").Visible(false);
        columns.Add().DataField("NAME").Caption("Name");
        columns.Add().DataField("BUILDING").Caption("Building");
        columns.Add().DataField("HOUSE_NO").Caption("House No").Visible(true);
        columns.Add().DataField("AREA_STREET").Caption("Area").Visible(true);
        columns.Add().DataField("DISTRICT").Caption("District").Visible(true);
        columns.Add().DataField("MOBILE").Caption( "Phone").Visible(false);
        columns.Add().DataField("REC_EDIT_ON").Caption("Recent Edit").Visible(false);
        
    })

    .Selection(s => s.Mode(SelectionMode.Single))

)
