    <script>
    var ServicePlace_IsDetailRowExpanded = false;
    var ServicePlace_NestedRecord_FocusedRowIndex = -1;
    var ServicePlace_NestedGrid_AccessID;
    var ServicePlace_AtachmentID;
    var ServicePlace_FileName;
    var ServicePlace_ParamMandatory;
    var ServicePlace_FromDateLabel;
    var ServicePlace_ToDateLabel;
    var ServicePlace_DescriptionLabel;
    var ServicePlace_Doc_ID;
    var ServicePlace_Doc_Category;
    var ServicePlace_MasterRowRecID;
    var ServicePlace_MasterRowMID;
    var ServicePlace_NestedRowMapID;
    var ServicePlace_reason;
    var ServicePlace_Attachment_RecStatus;


    function On_ServicePlace_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@Help_Attachment_AddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (ServicePlace_ParamMandatory == 1)
            {
                AddAttachment(ServicePlace_MasterRowRecID, "Profile_ServicePlaces", ServicePlace_Doc_ID, ServicePlace_Doc_Category, ServicePlace_ParamMandatory, ServicePlace_FromDateLabel, ServicePlace_ToDateLabel, ServicePlace_DescriptionLabel, "ServicePlaceProfileAttachment", null, "ServicePlacesListGrid", ServicePlace_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(ServicePlace_MasterRowRecID, "Profile_ServicePlaces", ServicePlace_Doc_ID, "ServicePlaceProfileAttachment", "ServicePlacesListGrid", ServicePlace_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (ServicePlace_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(ServicePlace_MasterRowRecID, "Profile_ServicePlaces", ServicePlace_AtachmentID, ServicePlace_ParamMandatory, ServicePlace_FromDateLabel, ServicePlace_ToDateLabel, ServicePlace_DescriptionLabel, "ServicePlaceProfileAttachment", null, "ServicePlacesListGrid", ServicePlace_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(ServicePlace_MasterRowRecID, "Profile_ServicePlaces", ServicePlace_AtachmentID, ServicePlace_ParamMandatory, ServicePlace_FromDateLabel, ServicePlace_ToDateLabel, ServicePlace_DescriptionLabel, null, "ServicePlacesListGrid", ServicePlace_NestedGrid_AccessID,ServicePlace_Attachment_RecStatus);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@Help_Attachment_ViewRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }


            ViewDocument(ServicePlace_AtachmentID, ServicePlace_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'),document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(ServicePlace_MasterRowRecID, "Profile_ServicePlaces", "Service Places Information", "ServicePlacesListGrid", ServicePlace_NestedGrid_AccessID);
        }
        else if (e.actionName === "Add_Reason")
        {
            if (ServicePlace_Doc_Category.toLowerCase() == "others") {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else {
                AttachmentAddReason(ServicePlace_MasterRowRecID, ServicePlace_NestedRowMapID, "Profile_ServicePlaces", "ServicePlacesListGrid", ServicePlace_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(ServicePlace_MasterRowRecID, ServicePlace_NestedRowMapID, "Profile_ServicePlaces", "ServicePlacesListGrid", ServicePlace_NestedGrid_AccessID, ServicePlace_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(ServicePlace_MasterRowRecID, ServicePlace_NestedRowMapID, "ServicePlacesListGrid", ServicePlace_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
    }
    function OnServicePlacesListGridNestedFocusedRowChange(s, e)
    {
        if (ServicePlace_IsDetailRowExpanded)
        {
            ServicePlace_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
            if (ServicePlace_NestedRecord_FocusedRowIndex >= 0)
            {
                ShowLoader();
                ServicePlace_NestedGrid_AccessID = s.uniqueID;
                s.GetRowValues(s.GetFocusedRowIndex(),'Doc_Status;Params_Mandatory;LABEL_FROM_DATE;LABEL_TO_DATE;LABEL_DESCRIPTION;Document_Category;Document_ID;ATTACH_ID;TxnID;TxnMID;MAP_ID;Reason;ATTACH_FILE_NAME;Attachment_Action_Status;UniqueID', OnServicePlace_GetGridRowValues);
            }
            else
            {
                ServicePlacePrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }
    function OnServicePlace_GetGridRowValues(values)
    {
        HideLoader();
        if (values[14] != null)
        {
            ServicePlacePrf_FAB.SetVisible(true);
            ServicePlace_Nested_Doc_Status = values[0];
            if (ServicePlace_Nested_Doc_Status == "") {
                ServicePlacePrf_FAB.SetActionContext("AutoItemContext", true);
            }
            else if (ServicePlace_Nested_Doc_Status == "NO") {
               ServicePlacePrf_FAB.SetActionContext("EditItemContext", true);
            }
            else if (ServicePlace_Nested_Doc_Status == "YES") {
                ServicePlacePrf_FAB.SetActionContext("actionItemContext", true);
            }
            ServicePlace_ParamMandatory = values[1];
            ServicePlace_FromDateLabel = values[2];
            ServicePlace_ToDateLabel = values[3];
            ServicePlace_DescriptionLabel = values[4];
            ServicePlace_Doc_Category = values[5];
            ServicePlace_Doc_ID = values[6];
            ServicePlace_AtachmentID = values[7];
            ServicePlace_MasterRowRecID = values[8];
            ServicePlace_MasterRowMID = values[9];
            ServicePlace_NestedRowMapID = values[10];
            ServicePlace_reason = values[11];
            ServicePlace_FileName = values[12];
            ServicePlace_Attachment_RecStatus = values[13];
            if (SrvicPlac_IsVouchingMode == true)
            {
                if (ServicePlace_FileName != null && ServicePlace_FileName.length > 0)
                {
                    ViewDocument(ServicePlace_AtachmentID, ServicePlace_FileName, "ServicePlacePrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else
                {
                    var pane = Mainspliter.GetPaneByName('RightPane');
                    pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
                    document.getElementById('RightPane_div_Iframe').style.display = "none";
                    document.getElementById('RightPane_div_Img').style.display = "none";
                }
            }
        }
    }
    function ServicePlacesGrid_Nested_BeginCallBack(s, e)
    {
        e.customArgs["ShowHorizontalBar"] = ServicePlaces_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = SrvicPlac_IsVouchingMode;
        e.customArgs["command"] = e.command;
    }
    function ServicePlace_DetailRowExpanding(s, e)
    {
        ServicePlace_IsDetailRowExpanded = true;
        s.SetFocusedRowIndex(e.visibleIndex);
        var pane = Mainspliter.GetPaneByName('RightPane');
        if (SrvicPlac_IsVouchingMode == true)
        {
            pane.Expand();
        }
        else
        {
            pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
        }
    }
    function ServicePlace_DetailRowCollapsing(s, e)
    {
        ServicePlace_IsDetailRowExpanded = false;
        s.SetFocusedRowIndex(e.visibleIndex);
        if (SrvicPlac_IsVouchingMode == true)
        {
            if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false)
            {
                CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
        else
        {
            ServicePlacePrf_FAB.SetVisible(false);
        }
    }


    </script>
