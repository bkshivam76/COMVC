<div class="ServicePlacesProfile_ClearReferences">

    @using DevExtreme.AspNet.Mvc;

    @model IEnumerable<dynamic>
    @{
        ViewBag.Title = "Index";
        Layout = null;
        var UserType = ViewBag.UserType;
        bool ServicePlaces_AddRight = (bool)ViewData["ServicePlaces_AddRight"];
        bool ServicePlaces_UpdateRight = (bool)ViewData["ServicePlaces_UpdateRight"];
        bool ServicePlaces_ViewRight = (bool)ViewData["ServicePlaces_ViewRight"];
        bool ServicePlaces_DeleteRight = (bool)ViewData["ServicePlaces_DeleteRight"];
        bool ServicePlaces_ExportRight = (bool)ViewData["ServicePlaces_ExportRight"];
        bool Help_Attachment_AddRight = (bool)ViewData["Help_Attachment_AddRight"];//attachment
        bool Help_Attachment_EditRight = (bool)ViewData["Help_Attachment_EditRight"];//attachment
        bool Help_Attachment_ViewRight = (bool)ViewData["Help_Attachment_ViewRight"];//attachment
        bool Help_Attachment_DeleteRight = (bool)ViewData["Help_Attachment_DeleteRight"];//attachment
        bool ServicePlaceInfo_Auto_Vouching_Mode = (bool)ViewData["ServicePlaceInfo_Auto_Vouching_Mode"];

    }
    <div id="ServicePlace_ParentDiv" class="col-md-12 report_header_div_main">
        <div class="col-md-4 report_header_div">
            <label class="report_header_label">Service Places Information</label>
        </div>
        @*Buttons*@
    <div class="report_button_div">
        @(Html.DevExtreme().Switch().ID("SrvicPlacVouchingModeSwitch").SwitchedOnText("Vouching On").SwitchedOffText("Vouching Off").OnValueChanged("SrvicPlac_VouchingSwitch_ValueChange").Width(100).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
        @(Html.DevExtreme().Switch().ID("ServicePlacesViewModeSwitch").SwitchedOnText("Compact").SwitchedOffText("Default").OnValueChanged("ServicePlaces_ViewSwitch_ValueChange").Width(70).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
        @*New Button*@
        @(
            Html.DevExtreme()
                .Button()
                .ID("ServicePlacesModelNew")
                .Text("New")
                .Icon("add")
                .Visible(true)
                .Disabled(false)
                .OnClick(@<text>
                    function () { OnServicePlacesNewClick(); }
                </text>)
        )
        @*Edit Button*@
        @(
            Html.DevExtreme()
                .Button()
                .ID("ServicePlacesModelEdit")
                .Text("Edit")
                .Icon("edit")
                .Visible(true)
                .Disabled(false)
                .OnClick(@<text>
                function (){ OnServicePlacesEditClick(); }
            </text>)
        )
        @*Delete Button Code*@
        @(
            Html.DevExtreme()
                .Button()
                .ID("ServicePlacesModelDelete").Text("Delete")
                .Icon("trash")
                .Visible(true)
                .Disabled(false)
                .OnClick(@<text>
                    function () { OnServicePlacesDeleteClick(); }
                </text>)
        )
        @*View Button Code*@
        @(
            Html.DevExtreme()
                .Button()
                .ID("ServicePlacesModelView")
                .Text("View")
                .Icon(IconID.ViewCustomers16x16devav)
                .Icon("doc")
                .OnClick(@<text>
                    function (){  OnServicePlacesViewClick(); }
                </text>)
        )
        @*Full Data code*@
        @(
            Html.DevExtreme()
                .Button()
                .ID("ServicePlacesToggleScrollBar")
                .Text(ViewBag.ShowHorizontalBar == 1 ? "Default Data" : "Full Data")
                .Width(ViewBag.ShowHorizontalBar == 1 ? 110 : 90)
                .Icon("toolbox")
                .OnClick(@<text>
                    function (){ ServicePlaceschangeMode();}
                </text>)
        )
        @*Export Button Code*@
        @(
            Html.DevExtreme()
                .Button()
                .ID("ServicePlacesModelListPreview")
                .Text("Export")
                .Icon("save")
                .Width(80)
                .OnClick(@<text>
                    function (){ OnServicePlacesListPreviewClick();}
                </text>)
        )
        @*Close Button Code*@
        @(
            Html.DevExtreme()
                .Button()
                .ID("ServicePlacesModelCLOSE")
                .Text("Close")
                .Icon("clear")
                .OnClick("colse_ServicePlaces")
        )
    </div>

    </div>

