        .Title("ServicePlaces")
        .OnShowing("PopupOnShowing")
        .ShowCloseButton(true)
        .ContentTemplate(@<text>
            <div id="ServicePlacesresult">
            </div>
        </text>)
            .OnHiding(@<text>
