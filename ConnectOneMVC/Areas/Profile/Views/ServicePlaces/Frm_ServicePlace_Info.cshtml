    @*Javascript Events*@
<script type="text/javascript">
    var ServicePlaces_ShowHorizontalBar = parseInt("@ViewBag.ShowHorizontalBar");
    //var IsSucessPopup = false;
    //var IsViewPopup = false;
    var ServicePlaceInfo_SetVouchingModeOn = "@ServicePlaceInfo_Auto_Vouching_Mode" == "True" ? true : false;
    var UserType_SerPlacePrf = "@UserType".toUpperCase();
    var SrvicPlac_IsVouchingMode = false;
    var ServicePlaces_ViewMode = "Default";
    var ServicePlaceID_ServicePlaceProfile = null;

    //Info Page Grid related global variables.
    var ServiePlace_Select_xid = "";
    var ServicePlace_FocusedRowBeforeRefresh

    $(".TabPanalMenu-tabs .active span").on("click", function () {
        $.ajax({
            type: 'GET',
            url: "/Profile/ServicePlaces/SessionClear",
            cache: false
        });
        ClearAllReferences_ServicePlacesProfile();

    });

        function colse_ServicePlaces() {
            $(".TabPanalMenu-tabs .active span").click();
        }
    $(document).ready(function () {
        if ("@ServicePlaces_AddRight" == "False")
        {
	        $("#ServicePlacesModelNew").hide();
        }
        if ("@ServicePlaces_UpdateRight" == "False")
        {
            $("#ServicePlacesModelEdit").hide();
        }
        if ("@ServicePlaces_ViewRight" == "False")
        {
            $("#ServicePlacesModelView").hide();
        }
        if ("@ServicePlaces_DeleteRight" == "False")
        {
            $("#ServicePlacesModelDelete").hide();
        }
        if ("@ServicePlaces_ExportRight" == "False")
        {
            $("#ServicePlacesModelListPreview").hide();
        }
        HideUnreleasedFunctionality('Frm_ServicePlace_Info');
        ////IsSucessPopup = false;
        //IsViewPopup = false;
        //SetServicePlacesGroupPanelFooterVisible();
        //SetServicePlacesFooterVisible();
        $("#ServicePlacesListGrid").hover(function () {
            //ServicePlacesListGrid.Focus()
        })
        $(".ServicePlacesListGrid_PreviewRow").hide();
        GetSessionStorage("ServicePlacesListGrid");
        if (ServicePlaceInfo_SetVouchingModeOn == true)
        {
            $("#ServicePlacesViewModeSwitch").dxSwitch("instance").option("value", true);
        }
    });
    function OnSerPlaceCellClick(event, cell,col, row)
    {
        if (UserType_SerPlacePrf == "AUDITOR" || UserType_SerPlacePrf == "SUPERUSER")
        {
            if (event.button == 0)
            {
                if (cell.style.backgroundColor.length > 0)
                {
                    cell.style.backgroundColor = "";
                }
                else
                {
                    cell.style.backgroundColor = 'skyblue';
                }
            }
        }
    }
    function SrvicPlac_VouchingSwitch_ValueChange(e)
    {
        SrvicPlac_IsVouchingMode = e.value;
        ServicePlacesListGrid_CollapseAllDetailRows();
    }
    function ServicePlacesListGrid_CollapseAllDetailRows()
    {
        if (typeof window !== 'undefined')
        {
            if (typeof window.ServicePlacesListGrid !== 'undefined')
            {
                if (typeof window.ServicePlacesListGrid.CollapseAllDetailRows !== 'undefined')
                {
                    if (typeof ServicePlacesListGrid.CollapseAllDetailRows == 'function')
                    {
                        ServicePlacesListGrid.CollapseAllDetailRows();
                    }
                    else
                    {
                        alert("CollapseAllDetailRows is not a function");
                    }
                }
                else
                {
                    ShowLoader();
                    setTimeout(function ()
                    {
                        ServicePlacesListGrid_CollapseAllDetailRows();
                        HideLoader();
                    }, Timeout100);
                }
            }
            else
            {
                alert('grid undefined')
            }
        }
        else
        {
            alert('window undefined')
        }
    }
    function ServicePlaces_ViewSwitch_ValueChange(e)
    {
        ServicePlaces_ViewMode = e.value == false ? "Default" : "Compact";
        if (ServicePlaceInfo_SetVouchingModeOn == true)
        {
            ServicePlaceInfo_SetVouchingModeOn = false;
            $("#SrvicPlacVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }
        else
        {
            ServicePlacesListGrid.CollapseAllDetailRows();
        }
    }
    function ServicePlacesOnInit(s, e) {
        ServicePlacesAdjustSize();
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            ServicePlacesAdjustSize();
        });
    }
    var ServicePlace_ColumnToBeShownIndex = "";
    var ServicePlace_ColumnToBeHidddenIndex = "";

    function ServicePlacesGrid_BeginCallBack(s, e) {

        ServicePlace_FocusedRowBeforeRefresh = s.GetFocusedRowIndex();
        e.customArgs["command"] = e.command;
        e.customArgs["VouchingMode"] = SrvicPlac_IsVouchingMode;
        e.customArgs["ViewMode"] = ServicePlaces_ViewMode;
        e.customArgs["ColumnToBeShownIndex"] = ServicePlace_ColumnToBeShownIndex;
        e.customArgs["ColumnToBeHidddenIndex"] = ServicePlace_ColumnToBeHidddenIndex;
        e.customArgs["RowKeyToFocus"] = ServiePlace_Select_xid;
    }

    function OnGridServicePlacesListGrid_EndCallback(s, e)
    {
        //ServicePlacesAdjustSize();
        ServicePlace_ColumnToBeShownIndex = s.cpColumnToBeShownIndex;
        ServicePlace_ColumnToBeHidddenIndex = s.cpColumnToBeHidddenIndex;
        $(".ServicePlacesListGrid_PreviewRow").hide();
        GetSessionStorage("ServicePlacesListGrid");
        SendCustomArgs_FilterControl(s, e);
        //Reset Focus Code
        if (e.command == "REFRESH") {

            if (ServicePlace_FocusedRowBeforeRefresh == s.GetFocusedRowIndex()) {
                //s.SetFocusedRowIndex(-1);
                s.SetFocusedRowIndex(ServicePlace_FocusedRowBeforeRefresh);
            }
            ServiePlace_Select_xid = "";
        }


    }
    function ServicePlacesAdjustSize() {
        var height = (document.documentElement.clientHeight * 90) / 100;
        try{ServicePlacesListGrid.SetHeight(height);}catch(err){}
    }
    function ServicePlaceschangeMode() {
        ShowLoader();
        if (ServicePlaces_ShowHorizontalBar == 0) {
            ServicePlaces_ShowHorizontalBar = 1;
            $("#ServicePlacesToggleScrollBar").find("span").text("Default Data");
            $("#ServicePlacesToggleScrollBar").width(110);
        }
        else {
            ServicePlaces_ShowHorizontalBar = 0;
            $("#ServicePlacesToggleScrollBar").find("span").text("Full Data");
            $("#ServicePlacesToggleScrollBar").width(90);
        }
        $.ajax({
            url: '@Url.Action("Frm_ServicePlace_Info_Grid", "ServicePlaces")',
            type: "GET",
            data: { ShowHorizontalBar: ServicePlaces_ShowHorizontalBar, VouchingMode: SrvicPlac_IsVouchingMode, ViewMode: ServicePlaces_ViewMode, ColumnToBeHidddenIndex: ServicePlace_ColumnToBeHidddenIndex, ColumnToBeShownIndex: ServicePlace_ColumnToBeShownIndex  },
            success: function (res) {
                $("#ServicePlacesreloadPartialView").html(res);
                $(".ServicePlacesListGrid_PreviewRow").hide();
                GetSessionStorage("ServicePlacesListGrid");
            }
        });
        HideLoader();
    }
    function ServicePlacesAjaxSuccessForm(data) {
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.Message, "Error");
        }
        else {
            //IsSucessPopup = true;
            DevExpress.ui.dialog.alert(data.Message, "Success");
            $("#popup_frm_ServicePlaces_Window").dxPopup("hide");
            ServicePlacesListGrid.Refresh();
            //IsSucessPopup = false;
        }
    }

    var ServicePlacesID;
    var ServicePlaces_EditDate;
    var ServicePlaces_AddDate;
    var ServicePlaces_AddBy;
    var ServicePlaces_EditBy;
    var ServicePlaces_ActionStatus;
    var ServicePlaces_ActionDate;
    var ServicePlaces_ActionBy;

    function ServicePlaces_dblclickEdit(s, e) {
        //var key = s.GetRowKey(s.GetFocusedRowIndex());
        //ServicePlacesListGrid.GetValuesOnCustomCallback({ key: key }, ServicePlacesOnGetRowValues);
        //if (ServicePlacesID != null || ServicePlacesID == 'undefined' || ServicePlacesID == undefined)
        //    OnServicePlacesEditClick();
    }

    function OnServicePlacesGridFocusedRowChanged(s, e) {

        if (s.GetFocusedRowIndex() >= 0)
        {
            if (!s.IsGroupRow(s.GetFocusedRowIndex())) {
                s.GetRowValues(s.GetFocusedRowIndex(), 'ID;Edit_Date;Add_Date;Add_By;Edit_By;Action_Status;Action_Date;Action_By', ServicePlacesOnGetRowValues);
            }
            else {
                ServicePlacesID = null;
            }
        }
        else {
            ServicePlacesID = null;
        }
    }

    function ServicePlacesOnGetRowValues(values) {
        ServicePlacesID = values[0];
        ServicePlaces_EditDate = values[1];
        ServicePlaces_AddDate = values[2];
        ServicePlaces_AddBy = values[3];
        ServicePlaces_EditBy = values[4];
        ServicePlaces_ActionStatus = values[5];
        ServicePlaces_ActionDate = values[6];
        ServicePlaces_ActionBy = values[7];
        ServicePlaces_UpdateFooterDetail(ServicePlacesID, ServicePlaces_ActionStatus, ServicePlaces_AddDate, ServicePlaces_AddBy,
        ServicePlaces_ActionDate, ServicePlaces_ActionBy, ServicePlaces_EditDate, ServicePlaces_EditBy);
    }

    function ServicePlaces_UpdateFooterDetail(ServicePlacesID, ServicePlaces_Action_Status, ServicePlaces_Add_Date, ServicePlaces_Add_By, ServicePlaces_Action_Date, ServicePlaces_Action_By, ServicePlaces_Edit_Date, ServicePlaces_Edit_By) {
        ServicePlaces_Action_Date = ServicePlaces_Action_Date != "" && ServicePlaces_Action_Date != null ? ServicePlaces_Action_Date : ServicePlaces_Action_Date;
        ServicePlaces_Edit_Date = ServicePlaces_Edit_Date != "" && ServicePlaces_Edit_Date != null ? ServicePlaces_Edit_Date : ServicePlaces_Edit_Date;
        ServicePlaces_Add_Date = ServicePlaces_Add_Date != "" && ServicePlaces_Add_Date != null ? ServicePlaces_Add_Date : ServicePlaces_Add_Date;
        $.ajax({
            type: 'GET',
            url: "/Profile/ServicePlaces/CreationDetail",
            data: {
                Xrow: ServicePlacesID, Action_Status: ServicePlaces_Action_Status, Add_Date: ServicePlaces_Add_Date,
                Add_By: ServicePlaces_Add_By, Action_Date: ServicePlaces_Action_Date, Action_By: ServicePlaces_Action_By, Edit_Date: ServicePlaces_Edit_Date, Edit_By: ServicePlaces_Edit_By
            },
            cache: false,
            success: function (ServicePlacesLbl_result) {
                $('#ServicePlaces_Lbl_ActionOn').text(ServicePlacesLbl_result.Lbl_StatusOn);
                $('#ServicePlaces_Lbl_ActionBy').text(ServicePlacesLbl_result.Lbl_StatusBy);
                $('#ServicePlacesLbl_Status').text(ServicePlacesLbl_result.Lbl_Status);
                $('#ServicePlacesLbl_Create').text(ServicePlacesLbl_result.Lbl_Create);
                $('#ServicePlacesLbl_Modify').text(ServicePlacesLbl_result.Lbl_Modify);
                if (ServicePlacesLbl_result.Lbl_Status_Color != "") {
                    $('#ServicePlacesLbl_Status').css('color', ServicePlacesLbl_result.Lbl_Status_Color);
                }
                if (ServicePlacesLbl_result.Pic_Status != "") {
                    $('#ServicePlaces_LockICON').css('class', ServicePlacesLbl_result.Pic_Status);
                }

            }
        });
    }
</script>

    <script type="text/javascript">
    function OnServicePlacesNewClick() {
        if ("@ServicePlaces_AddRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        @*if ('@ViewData["Open_Ins_Id_Check"]' != "00001") {

            var insName = '@ViewData["Open_Ins_Name"]';
            DevExpress.ui.dialog.alert("In " + insName + " <br><br> Godly Service Place Creation Not Applicable...!", "Service Places");
            return;
        }*@

        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Profile/ServicePlaces/Frm_ServicePlace_Window",
            data: { Tag: "New" },
            cache: false,
            success: function (data) {
                OpenDynamicPopup("New ~ Service Places", null, "auto", 700, true, data);
            }
        });

    }

    function OnServicePlacesEditClick() {

        if ("@ServicePlaces_UpdateRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }

        if (ServicePlacesID == 'undefined' || ServicePlacesID == undefined) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }

        $.ajax({
            type: 'GET',
            url: "/Profile/ServicePlaces/DataNavigation",
            data: { ActionMethod: "Edit", id: ServicePlacesID, Edit_Date: encodeURIComponent(ServicePlaces_EditDate) },
            cache: false,

            success: function (data) {
                HideLoader();
                if(data.jsonParam.result == true){
                    OpenServicePlaceWindowEditMode()
                }
                else {
                    if (data.jsonParam.isconfirm == true) {
                        var confirmation = DevExpress.ui.dialog.confirm(data.jsonParam.message, data.jsonParam.title);
                        confirmation.done(function (result) {
                            if (result) {
                                OpenServicePlaceWindowEditMode();
                            }
                            else if (data.jsonParam.refreshgrid) {
                                ServicePlacesListGrid.Refresh();
                            }
                        });
                    }
                    else {
                        DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                        if (data.jsonParam.refreshgrid) {
                            ServicePlacesListGrid.Refresh();
                        }
                    }
                }
            }
        });

    }

    function OpenServicePlaceWindowEditMode() {

        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Profile/ServicePlaces/Frm_ServicePlace_window",
            data:
            {
                Tag: "Edit",
                xId: ServicePlacesID,
                Info_LastEditedOn: ServicePlaces_EditDate
            },
            cache: false,
            success: function (data) {
                OpenDynamicPopup("Edit ~ ServicePlaces", null, "auto", 700, true, data);
                /*OpenPopup("popup_frm_Bank_Window", "Edit ~ ServicePlaces", null, "auto", 1024, true, data);*/
            }
        });
    }

    function OnServicePlacesViewClick()
     {
        if ("@ServicePlaces_ViewRight" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        if (ServicePlacesID == 'undefined' || ServicePlacesID == undefined) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }

        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Profile/ServicePlaces/DataNavigation",
            data: { ActionMethod: "View", id: ServicePlacesID, Edit_Date: ServicePlaces_EditDate.toString()},
            cache: false,
            success: function (data)
            {

                HideLoader();
                if (data.jsonParam.result == true)
                {
                    $.ajax({
                        type: 'GET',
                        url: "/Profile/ServicePlaces/Frm_ServicePlace_Window",
                        data:
                        {
                            Tag: "View",
                            xId: ServicePlacesID,
                            Info_LastEditedOn: ServicePlaces_EditDate
                        },
                        cache: false,
                        success: function (data) {
                            ShowLoader();
                            OpenDynamicPopup("View ~ ServicePlaces", null, "auto", 700, true, data);
                            //OpenPopup("popup_frm_ServicePlaces_Window", "View ~ Bank Account", null, "auto", 1024, true, data);
                        }
                    });
                }
                else
                {
                    DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                    if (data.jsonParam.refreshgrid)
                    {
                        ServicePlacesListGrid.Refresh();
                    }
                }
            }
        });
     }

    function OnServicePlacesDeleteClick() {

        if ("@ServicePlaces_DeleteRight" == "False") {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        if (ServicePlacesID == 'undefined' || ServicePlacesID == undefined) {
                DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
                return;
            }
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Profile/ServicePlaces/DataNavigation",
                data: { ActionMethod: "Delete", id: ServicePlacesID, Edit_Date: ServicePlaces_EditDate.toString() },
                cache: false,
                success: function (data) {
                    HideLoader();
                    if (data.jsonParam.result == true) {
                        OpenServicePlaceWindowDeleteMode()
                    }
                    else {
                        if (data.jsonParam.isconfirm == true) {
                            var confirmation = DevExpress.ui.dialog.confirm(data.jsonParam.message, data.jsonParam.title);
                            confirmation.done(function (result) {
                                if (result) {
                                    OpenServicePlaceWindowDeleteMode();
                                }
                                else if (data.jsonParam.refreshgrid) {
                                    ServicePlacesListGrid.Refresh();
                                }
                            });
                        }
                        else {
                            DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                            if (data.jsonParam.refreshgrid) {
                                ServicePlacesListGrid.Refresh();
                            }
                        }
                    }
                }
            });
        }

    function OpenServicePlaceWindowDeleteMode()
     {
         ShowLoader();
         $.ajax({
             type: 'GET',
             url: "/Profile/ServicePlaces/Frm_ServicePlace_window",
             data:
             {
                 Tag: "Delete",
                 xId: ServicePlacesID,
                 Info_LastEditedOn: ServicePlaces_EditDate
             },
             cache: false,
             success: function (data) {
                 OpenDynamicPopup("Delete ~ ServicePlaces", null, "auto", 700, true, data);
                 //OpenPopup("popup_frm_Bank_Window", "Delete ~ Bank Account", null, "auto", 1024, true, data);
             }
         });
     }

    function OnServicePlacesListPreviewClick() {
        if ("@ServicePlaces_ExportRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        @*$("#ServicePlaces_report_modal").dxPopup("show");
        $("#ServicePlaces_report_modal").dxPopup("instance").option("title", "Export Option");
