@using DevExtreme.AspNet.Mvc;
@{

    var SessionGUID = Request.QueryString["SessionGUID"];
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;
    int ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;

}
@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar)
                 .ID("ServicePlacesListGrid_dx")
                 .DataSource(d => d.Mvc().Controller("ServicePlaces").LoadAction("Frm_ServicePlace_Info_Grid_dx").LoadMode(DataSourceLoadMode.Raw).Key("ID"))
                 .Columns(columns =>
                 {
                     columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);//Bug #137209 Fix
                     columns.Add().DataField("iIcon").Name("iIcon").Caption("").CellTemplate(new JS("ServicePlacesListGrid_dx_iIconTemplate")).Width(30)
                     .HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource")).RenderAsync(true);
                     columns.Add().DataField("ServicePlacesListGrid_dx_Compact_Column").Name("ServicePlacesListGrid_dx_Compact_Column").Caption("").Visible(false).CellTemplate(new JS("ServicePlacesListGrid_dx_Compact_Column_Template"))
                     .CalculateCellValue("ServicePlacesListGrid_dx_Compact_Column_CellValue").Width("100%").RenderAsync(true).ShowInColumnChooser(false);

                     columns.Add().DataField("Service_Place_Name").Caption("Service Place Name").MinWidth(150);
                     columns.Add().DataField("Start_Date").Caption("Start Date").MinWidth(140)
                     .DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                     columns.Add().DataField("Weekdays").Caption("Weekdays").MinWidth(150);

                     columns.Add().DataField("Timing").Width(100).Visible(true);
                     //.HeaderFilter(s => s.DataSource("function (e){return DxGrid_TimeColHeaderDS(e,'Timing')}"))
                     //.CalculateFilterExpression("DxGrid_TimeColFilterExp")
                     //.DataType(GridColumnDataType.DateTime).Format("hh:mm")
                     //.CalculateCellValue("function (rowData) {return DxGrid_TimeColCellValue(rowData,'Timing'); }");
                     columns.Add().DataField("Status").Caption("Status").MinWidth(60);
                     columns.Add().DataField("Place_Owner").Caption("Place Owner").MinWidth(100);
                     columns.Add().DataField("Place_Address").Caption("Place_Address").MinWidth(100);
                     columns.Add().DataField("R_City").Caption("R_City").MinWidth(100);
                     columns.Add().DataField("Place_Contact_No").Caption("Place Contact No").MinWidth(100);
                     columns.Add().DataField("Responsible_Person").Caption("Responsible Person").MinWidth(100);
                     columns.Add().DataField("Contact_No").Caption("Contact No").MinWidth(90);
                     columns.Add().DataField("Other_Details").Caption("Other Details").MinWidth(100);
                     columns.Add().DataField("Type").Caption("Type").MinWidth(100).GroupIndex(1).GroupCellTemplate(new JS("ServicePlacesListGrid_dx_GroupCell_Template"));

                     columns.Add().DataField("ORG_REC").Caption("ORG_REC").Visible(false);
                     columns.Add().DataField("LOC_ID").Caption("LOC_ID").Visible(false);
                     columns.Add().DataField("YearID").Caption("YearID").Visible(false);
                     columns.Add().DataField("Action_Status").Caption("Action_Status").Visible(false).MinWidth(120);
                     columns.Add().DataField("Action_By").Caption("Action By").Visible(false).MinWidth(120);
                     columns.Add().DataField("Action_Date").Caption("Action Date").Visible(false).MinWidth(120);
                     columns.Add().DataField("Add_By").Caption("Added By").Visible(false).MinWidth(120);
                     columns.Add().DataField("Add_Date").Caption("Added Date").Visible(false).MinWidth(120);
                     columns.Add().DataField("CITYID").Caption("CITYID").Visible(false).MinWidth(120);
                     columns.Add().DataField("Edit_By").Caption("Edited By").Visible(false).MinWidth(120);
                     columns.Add().DataField("Edit_Date").Caption("Edited Date").Visible(false).MinWidth(120);
                     columns.Add().DataField("ID").Caption("ID").Visible(false).MinWidth(120).SortOrder(SortOrder.Asc);
                     columns.Add().DataField("iREQ_ATTACH_COUNT").Caption("iREQ_ATTACH_COUNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("iCOMPLETE_ATTACH_COUNT").Caption("iCOMPLETE_ATTACH_COUNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("iRESPONDED_COUNT").Caption("iRESPONDED_COUNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("iREJECTED_COUNT").Caption("iREJECTED_COUNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("iOTHER_ATTACH_CNT").Caption("iOTHER_ATTACH_CNT").Visible(false).MinWidth(120);
                     columns.Add().DataField("iALL_ATTACH_CNT").Caption("iALL_ATTACH_CNT").Visible(false).MinWidth(120);

                 })      
//.Summary(s =>

//{

//    s.TotalItems(item => item.Add().Name("OP_AMOUNT_OP_AMOUNT_sum").SummaryType(SummaryType.Sum).Column("OP_AMOUNT").DisplayFormat("Grand Total= {0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}")));

//    if (SpecialGroupings == false)
