.MasterDetail(md =>
{
    md.AutoExpandAll(false);
    md.Enabled(!VouchingMode);
    md.Template(new JS("ServicePlacesListGrid_dx_DetailTemplate"));
})
.OnInitialized("ServicePlacesListGrid_dx_OnInitialized")
.OnCellPrepared("ServicePlacesListGrid_dx_OnCellPrepared")
.OnRowPrepared("ServicePlacesListGrid_dx_OnRowPrepared")
.OnContentReady("ServicePlacesListGrid_dx_OnContentReady")
.OnCellDblClick("ServicePlacesListGrid_dx_OnCellDblClick")
.OnSelectionChanged("ServicePlacesListGrid_dx_OnSelectionChanged")
////.OnFocusedRowChanged("BankListGrid_dx_OnFocusedRowChanged")
.OnRowExpanding("ServicePlacesListGrid_dx_OnRowExpanding")
.OnRowCollapsing("ServicePlacesListGrid_dx_OnRowCollapsing")
.OnContextMenuPreparing("ServicePlacesListGrid_dx_OnContextMenuPreparing")
.OnEditorPreparing("ServicePlacesListGrid_dx_OnEditorPreparing")
)
