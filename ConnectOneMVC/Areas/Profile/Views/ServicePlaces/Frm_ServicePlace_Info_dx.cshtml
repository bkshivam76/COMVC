<div class="ServicePlacesProfile_ClearReferences">

    @using DevExtreme.AspNet.Mvc;

    @model IEnumerable<dynamic>
    @{
        ViewBag.Title = "Index";
        Layout = null;
        var UserType = ViewBag.UserType;
        bool ServicePlaces_AddRight = (bool)ViewData["ServicePlaces_AddRight"];
        bool ServicePlaces_UpdateRight = (bool)ViewData["ServicePlaces_UpdateRight"];
        bool ServicePlaces_ViewRight = (bool)ViewData["ServicePlaces_ViewRight"];
        bool ServicePlaces_DeleteRight = (bool)ViewData["ServicePlaces_DeleteRight"];
        bool ServicePlaces_ExportRight = (bool)ViewData["ServicePlaces_ExportRight"];
