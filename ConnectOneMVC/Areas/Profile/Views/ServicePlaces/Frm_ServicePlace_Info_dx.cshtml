    <script type="text/javascript">
    function OnServicePlacesNewClick() {
        if ("@ServicePlaces_AddRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        @*if ('@ViewData["Open_Ins_Id_Check"]' != "00001") {

            var insName = '@ViewData["Open_Ins_Name"]';
            DevExpress.ui.dialog.alert("In " + insName + " <br><br> Godly Service Place Creation Not Applicable...!", "Service Places");
            return;
        }*@

        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Profile/ServicePlaces/Frm_ServicePlace_Window",
            data: { Tag: "New" },
            cache: false,
            success: function (data) {
                OpenDynamicPopup("New ~ Service Places", null, "auto", 700, true, data);
            }
        });

    }

    function OnServicePlacesEditClick() {

        if ("@ServicePlaces_UpdateRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }

        if (ServicePlacesID == 'undefined' || ServicePlacesID == undefined) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }

        $.ajax({
            type: 'GET',
            url: "/Profile/ServicePlaces/DataNavigation",
            data: { ActionMethod: "Edit", id: ServicePlacesID, Edit_Date: encodeURIComponent(ServicePlaces_EditDate) },
            cache: false,

            success: function (data) {
                HideLoader();
                if(data.jsonParam.result == true){
                    OpenServicePlaceWindowEditMode()
                }
                else {
                    if (data.jsonParam.isconfirm == true) {
                        var confirmation = DevExpress.ui.dialog.confirm(data.jsonParam.message, data.jsonParam.title);
                        confirmation.done(function (result) {
                            if (result) {
                                OpenServicePlaceWindowEditMode();
                            }
                            else if (data.jsonParam.refreshgrid) {
                                ServicePlacesListGrid.Refresh();
                            }
                        });
                    }
                    else {
                        DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                        if (data.jsonParam.refreshgrid) {
                            ServicePlacesListGrid.Refresh();
                        }
                    }
                }
            }
        });

    }

    function OpenServicePlaceWindowEditMode() {

        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Profile/ServicePlaces/Frm_ServicePlace_window",
            data:
            {
                Tag: "Edit",
                xId: ServicePlacesID,
                Info_LastEditedOn: ServicePlaces_EditDate
            },
            cache: false,
            success: function (data) {
                OpenDynamicPopup("Edit ~ ServicePlaces", null, "auto", 700, true, data);
                /*OpenPopup("popup_frm_Bank_Window", "Edit ~ ServicePlaces", null, "auto", 1024, true, data);*/
            }
        });
    }

    function OnServicePlacesViewClick()
     {
        if ("@ServicePlaces_ViewRight" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        if (ServicePlacesID == 'undefined' || ServicePlacesID == undefined) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }

        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Profile/ServicePlaces/DataNavigation",
            data: { ActionMethod: "View", id: ServicePlacesID, Edit_Date: ServicePlaces_EditDate.toString()},
            cache: false,
            success: function (data)
            {

                HideLoader();
                if (data.jsonParam.result == true)
                {
                    $.ajax({
                        type: 'GET',
                        url: "/Profile/ServicePlaces/Frm_ServicePlace_Window",
                        data:
                        {
                            Tag: "View",
                            xId: ServicePlacesID,
                            Info_LastEditedOn: ServicePlaces_EditDate
                        },
                        cache: false,
                        success: function (data) {
                            ShowLoader();
                            OpenDynamicPopup("View ~ ServicePlaces", null, "auto", 700, true, data);
                            //OpenPopup("popup_frm_ServicePlaces_Window", "View ~ Bank Account", null, "auto", 1024, true, data);
                        }
                    });
                }
                else
                {
                    DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                    if (data.jsonParam.refreshgrid)
                    {
                        ServicePlacesListGrid.Refresh();
                    }
                }
            }
        });
     }

    function OnServicePlacesDeleteClick() {

        if ("@ServicePlaces_DeleteRight" == "False") {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        if (ServicePlacesID == 'undefined' || ServicePlacesID == undefined) {
                DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
                return;
            }
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Profile/ServicePlaces/DataNavigation",
                data: { ActionMethod: "Delete", id: ServicePlacesID, Edit_Date: ServicePlaces_EditDate.toString() },
                cache: false,
                success: function (data) {
                    HideLoader();
                    if (data.jsonParam.result == true) {
                        OpenServicePlaceWindowDeleteMode()
                    }
                    else {
                        if (data.jsonParam.isconfirm == true) {
                            var confirmation = DevExpress.ui.dialog.confirm(data.jsonParam.message, data.jsonParam.title);
                            confirmation.done(function (result) {
                                if (result) {
                                    OpenServicePlaceWindowDeleteMode();
                                }
                                else if (data.jsonParam.refreshgrid) {
                                    ServicePlacesListGrid.Refresh();
                                }
                            });
                        }
                        else {
                            DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                            if (data.jsonParam.refreshgrid) {
                                ServicePlacesListGrid.Refresh();
                            }
                        }
                    }
                }
            });
        }

