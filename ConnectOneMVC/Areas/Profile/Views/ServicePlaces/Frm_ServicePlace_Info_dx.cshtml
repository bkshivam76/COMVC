    <script type="text/javascript">

    function ServicePlacesContextMenuFunction(s, e) {
        if (e.item.name == 'New') {
            OnServicePlacesNewClick();
        }
        if (e.item.name == 'Close') {
            btnCloseActiveTab();
        }
        else if (e.item.name == 'Edit') {
            OnServicePlacesEditClick();
        }
        else if (e.item.name == 'Delete') {
            OnServicePlacesDeleteClick();
        }
        else if (e.item.name == 'View') {
            OnServicePlacesViewClick();
        }
        else if (e.item.name == 'ListPreview') {
            OnServicePlacesListPreviewClick();
        }
        else if (e.item.name == 'Discontinue') {
            OnServicePlacesDiscontinueClick();
        }
        else if (e.item.name == 'continue') {
            OnServicePlacescontinueClick();
        }
        else if (e.item.name == 'Refresh') {
            ServicePlacesListGrid.Refresh();
        }

    }

    </script>

    <script>
    var ServicePlace_IsDetailRowExpanded = false;
    var ServicePlace_NestedRecord_FocusedRowIndex = -1;
    var ServicePlace_NestedGrid_AccessID;
    var ServicePlace_AtachmentID;
    var ServicePlace_FileName;
    var ServicePlace_ParamMandatory;
    var ServicePlace_FromDateLabel;
    var ServicePlace_ToDateLabel;
    var ServicePlace_DescriptionLabel;
    var ServicePlace_Doc_ID;
    var ServicePlace_Doc_Category;
    var ServicePlace_MasterRowRecID;
    var ServicePlace_MasterRowMID;
    var ServicePlace_NestedRowMapID;
    var ServicePlace_reason;
    var ServicePlace_Attachment_RecStatus;


    function On_ServicePlace_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@Help_Attachment_AddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (ServicePlace_ParamMandatory == 1)
            {
                AddAttachment(ServicePlace_MasterRowRecID, "Profile_ServicePlaces", ServicePlace_Doc_ID, ServicePlace_Doc_Category, ServicePlace_ParamMandatory, ServicePlace_FromDateLabel, ServicePlace_ToDateLabel, ServicePlace_DescriptionLabel, "ServicePlaceProfileAttachment", null, "ServicePlacesListGrid_dx", ServicePlace_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(ServicePlace_MasterRowRecID, "Profile_ServicePlaces", ServicePlace_Doc_ID, "ServicePlaceProfileAttachment", "ServicePlacesListGrid_dx", ServicePlace_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (ServicePlace_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(ServicePlace_MasterRowRecID, "Profile_ServicePlaces", ServicePlace_AtachmentID, ServicePlace_ParamMandatory, ServicePlace_FromDateLabel, ServicePlace_ToDateLabel, ServicePlace_DescriptionLabel, "ServicePlaceProfileAttachment", null, "ServicePlacesListGrid_dx", ServicePlace_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(ServicePlace_MasterRowRecID, "Profile_ServicePlaces", ServicePlace_AtachmentID, ServicePlace_ParamMandatory, ServicePlace_FromDateLabel, ServicePlace_ToDateLabel, ServicePlace_DescriptionLabel, null, "ServicePlacesListGrid_dx", ServicePlace_NestedGrid_AccessID,ServicePlace_Attachment_RecStatus);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@Help_Attachment_ViewRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }


            ViewDocument(ServicePlace_AtachmentID, ServicePlace_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'),document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(ServicePlace_MasterRowRecID, "Profile_ServicePlaces", "Service Places Information", "ServicePlacesListGrid_dx", ServicePlace_NestedGrid_AccessID);
        }
        else if (e.actionName === "Add_Reason")
        {
            if (ServicePlace_Doc_Category.toLowerCase() == "others") {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else {
                AttachmentAddReason(ServicePlace_MasterRowRecID, ServicePlace_NestedRowMapID, "Profile_ServicePlaces", "ServicePlacesListGrid_dx", ServicePlace_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(ServicePlace_MasterRowRecID, ServicePlace_NestedRowMapID, "Profile_ServicePlaces", "ServicePlacesListGrid_dx", ServicePlace_NestedGrid_AccessID, ServicePlace_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(ServicePlace_MasterRowRecID, ServicePlace_NestedRowMapID, "ServicePlacesListGrid_dx", ServicePlace_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
    }


