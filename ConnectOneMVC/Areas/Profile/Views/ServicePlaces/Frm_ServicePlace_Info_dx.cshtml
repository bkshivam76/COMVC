    @*General Fns*@
<script>
    function SrvicPlac_VouchingSwitch_ValueChange(e) {
        if (ServicePlaceInfo_SetVouchingModeOn == true) {
            ServicePlaceInfo_SetVouchingModeOn = false;
        }
        SrvicPlac_IsVouchingMode = e.value;
        ServicePlacesListGrid_dx.clearSelection();
        ServicePlacesListGrid_dx.option("masterDetail.enabled", !SrvicPlac_IsVouchingMode)
        ServicePlacesListGrid_dx.repaint();

        /*ServicePlacesListGrid_CollapseAllDetailRows();*/
    }
    function ServicePlaces_ViewSwitch_ValueChange(e) {
       
        ServicePlaces_ViewMode = e.value == false ? "Default" : "Compact";
        if (ServicePlaceInfo_SetVouchingModeOn == true) {
            $("#SrvicPlacVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }
        ServicePlacesListGrid_dx.beginUpdate();
        var columns = ServicePlacesListGrid_dx.option("columns");
        if (ServicePlaces_ViewMode == "Compact") {
            VisibleColumns_ServicePlacesListGrid = [];
            for (var i = 0; i < columns.length; i++) {
                var name = columns[i].dataField;
                var ColumnVisible = ServicePlacesListGrid_dx.columnOption(name, "visible");
                if (name == "ServicePlacesListGrid_dx_Compact_Column") {
                    ServicePlacesListGrid_dx.columnOption(name, "visible", true);
                }
                else if (ColumnVisible == true && name != "iIcon") {
                    VisibleColumns_ServicePlacesListGrid.push(name);
                    ServicePlacesListGrid_dx.columnOption(name, "visible", false);
                }
            }
        }
        else {
            ServicePlacesListGrid_dx.columnOption("ServicePlacesListGrid_dx_Compact_Column", "visible", false);
            for (var i = 0; i < VisibleColumns_ServicePlacesListGrid.length; i++) {
                ServicePlacesListGrid_dx.columnOption(VisibleColumns_ServicePlacesListGrid[i], "visible", true);
            }
        }
        ServicePlacesListGrid_dx.repaint();
        ServicePlacesListGrid_dx.endUpdate();
    }

    function ServicePlaceschangeMode() {
        ServicePlacesListGrid_dx.beginUpdate();
        if (ServicePlaces_ShowHorizontalBar == 0) {
            ServicePlaces_ShowHorizontalBar = 1;
            $("#ServicePlacesToggleScrollBar").find("span").text("Default Data");
            $("#ServicePlacesToggleScrollBar").width(110);
            ServicePlacesListGrid_dx.option("columnHidingEnabled", false);
            ServicePlacesListGrid_dx.option("allowColumnResizing", true)
        }
        else {
            ServicePlaces_ShowHorizontalBar = 0;
            $("#ServicePlacesToggleScrollBar").find("span").text("Full Data");
            $("#ServicePlacesToggleScrollBar").width(90);
            ServicePlacesListGrid_dx.option("columnHidingEnabled", true)
            ServicePlacesListGrid_dx.option("allowColumnResizing", false)
        }
        ServicePlacesListGrid_dx.endUpdate();
    }

</script>
    @*grid methods*@
<script>
        function ServicePlacesListGrid_dx_OnInitialized(e) {
            DxGrid_AdjustSize(e.component, $("#ServicePlace_ParentDiv .report_button_div"))
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                DxGrid_AdjustSize(e.component, $("#ServicePlace_ParentDiv .report_button_div"), "", evt)
            });
            ServicePlacesListGrid_dx = e.component;
        }
        function ServicePlacesListGrid_dx_OnCellPrepared(e) {
            if (e.rowType == "data") {
                if (SrvicPlac_IsVouchingMode == true) {
                    if (e.column.dataField === "iIcon") {
                        $(e.cellElement).attr("onmouseover", "OnGridRowMouseHoverIn(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.key + "')");
                        $(e.cellElement).attr("onmouseout", "OnGridRowMouseHoverOut(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.key + "')");
                    }
                }
                $(e.cellElement).attr("id", e.element[0].id + "_Cell_" + e.key + "|" + e.column.dataField);
                /*$(e.cellElement).addClass("col_" + e.column.dataField + " row_" + e.key);*/
            }
        }
        function ServicePlacesListGrid_dx_OnRowPrepared(e) {
            if (e.rowType == "data") {
                var GridName = e.element[0].id;
                $(e.rowElement).addClass(GridName + "_DataRow_" + e.key)
                if (e.data.RemarkStatus != null && e.data.RemarkStatus == "OPEN" || e.data.RemarkStatus == "REOPENED") {
                    $(e.rowElement).css("background-color", "gold");
                }
                if (e.data.RemarkStatus == null && e.data.Remarks != null && e.data.Remarks == true && e.data.CrossedTimeLimit != null && e.data.CrossedTimeLimit == 0) {
                    $(e.rowElement).css("background-color", "lightgreen");
                }
                if (e.data.CrossedTimeLimit != null && e.data.CrossedTimeLimit > 0) {
                    $(e.rowElement).css("background-color", "mistyrose");
                }
                DxGrid_CreatePreviewRow(e, SrvicPlac_IsVouchingMode, "Master")
            }
            else if (e.rowType == "detailAdaptive") {
                DxGrid_MovePreviewRowAfterAdaptiveRow(e)
            }
        }
        function ServicePlacesListGrid_dx_OnContentReady(e) {
            DxGrid_OnContentReady(e, ServicePlaces_ShowHorizontalBar);
        }
    function ServicePlacesListGrid_dx_OnCellDblClick(e) {
        if (e.rowType == "data") {
            if (SrvicPlac_IsVouchingMode == true && ServicePlaces_ViewMode == "Default") {
                OnGridCellClick(e.event, e.cellElement[0], e.columnIndex, e.rowIndex, e.element[0].id, e.key, e.column.dataField)
            }
            else if (SrvicPlac_IsVouchingMode == false) {
                //if (e.rowType == "data")
                //    BankProfile_OnEditClick_dx();
            }
        }
        }
        function ServicePlacesListGrid_dx_OnSelectionChanged(e) {
            var selectedRowKeys = e.selectedRowKeys;
            if (selectedRowKeys != null && selectedRowKeys.length > 0) {

                ServicePlacesListGrid_dx_SelectedRowData(e.selectedRowsData);
            }
            else {
                ServicePlacesID = null;
                ServicePlaces_UpdateFooterDetail(ServicePlacesID, ServicePlaces_ActionStatus, ServicePlaces_AddDate, ServicePlaces_AddBy,
                    ServicePlaces_ActionDate, ServicePlaces_ActionBy, ServicePlaces_EditDate, ServicePlaces_EditBy);
            }
        }

    function ServicePlacesListGrid_dx_SelectedRowData(selectedData = null) {
        if (selectedData == null) {
            selectedData = ServicePlacesListGrid_dx.getSelectedRowsData();
        }
        if (selectedData != null && selectedData.length > 0) {
            var values = selectedData[0]
            ServicePlacesID = values["ID"]
            ServicePlaces_EditDate = values["Edit_Date"];
            ServicePlaces_EditBy = values["Edit_By"];
            ServicePlaces_AddDate = values["Add_Date"];
            ServicePlaces_AddBy = values["Add_By"];
            ServicePlaces_ActionDate = values["Action_Date"];
            ServicePlaces_ActionBy = values["Action_By"];
            ServicePlaces_ActionStatus = values["Action_Status"];
            ServicePlaces_UpdateFooterDetail(ServicePlacesID, ServicePlaces_ActionStatus, ServicePlaces_AddDate, ServicePlaces_AddBy,
                ServicePlaces_ActionDate, ServicePlaces_ActionBy, ServicePlaces_EditDate, ServicePlaces_EditBy);
        }
        else {
            ServicePlacesID = null;
        }
    }
    function ServicePlacesListGrid_dx_OnRowExpanding(e) {
        if (Array.isArray(e.key) == false) //not group row
        {
            e.component.collapseRow(Expanded_Row_Key_ServicePlaces_dx)
            e.component.selectRows(e.key);
            Expanded_Row_Key_ServicePlaces_dx = e.key;
            ServicePlace_IsDetailRowExpanded = true;
            var DetailGridID = e.element[0].id + e.key;
            var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
            if (instance != void 0) {
                instance.state(null) // grid maintains its state after collapsing so resetting the state when expands again as per old grid
            }
            //e.component.collapseAll(-1);
        }
        else {
            e.component.option("CustomProp.groupRowExpanded", true);
        }
    }
    function ServicePlacesListGrid_dx_OnRowCollapsing(e)
    {
        if (Array.isArray(e.key) == false) //not group row
        {
            var DetailGridID = e.element[0].id + e.key;
            sessionStorage.removeItem(DetailGridID + "_DetailGridState") //removing grid state from session storage on collapse
            ServicePlace_IsDetailRowExpanded = false;
            e.component.selectRows(e.key);
            if (SrvicPlac_IsVouchingMode == false) {
                ServicePlacePrf_FAB.SetVisible(false);
            }
        }
        else {
            e.component.option("CustomProp.groupRowCollapsed", true);
        }
    }
    function ServicePlacesListGrid_dx_OnContextMenuPreparing(e) {
        if (!e.items) e.items = [];
        if (e.target == "header") {

            DxGrid_HeaderContextMenu(e)
        }
        else if ((e.target == "content" && e.row && e.row.rowType == "groupFooter") || e.target == "footer") {
            if (ServicePlaces_ViewMode == "Compact")
                DxGrid_FooterContextMenu(e, true);
            else
                DxGrid_FooterContextMenu(e);
        }
        else if (e.target == "content" && e.row && (e.row.rowType == "data" || e.row.rowType == "detailAdaptive")) {
            var key = e.component.getKeyByRowIndex(e.row.rowIndex);
            e.component.selectRows(key);
            var expanded = e.component.isRowExpanded(key);
                            e.items = [
                    {
                        text: "Expand Detail",
                        icon: "fa-solid fa-arrow-down-wide-short " + (expanded ? "text-muted" : "text-info"),
                        disabled: expanded,
                        visible: !SrvicPlac_IsVouchingMode,
                        onItemClick: function ()
                        {
                            if (expanded)
                            {
                            }
                            else
                            {
                                e.component.expandRow(key);
                            }
                        }
                    }, {
                        text: "Collapse Detail",
                        icon: "fa-solid fa-arrow-up-wide-short " + (!expanded ? "text-muted" : "text-info"),
                        disabled: !expanded,
                        visible: !SrvicPlac_IsVouchingMode,
                        onItemClick: function () {
                            if (expanded) {
                                e.component.collapseRow(key);
                            }
                            else {
                            }
                        }
                    },
                    {
                        text: "Export",
                        icon: "fa-solid fa-file-export text-warning",
                        visible: "@ServicePlaces_ExportRight" == "True",
                        beginGroup: true,
                        onItemClick: function () {
                            OnServicePlacesListPreviewClick();
                        }
                    },
                    
                    {
                        text: "Close",
                        icon: "fa-solid fa-rectangle-xmark text-danger",
                        beginGroup: true,
                        onItemClick: function ()
                        {
                            btnCloseActiveTab();
                        }
                    },
                    {
                        text: "Refresh",
                        icon: "fa-solid fa-arrow-rotate-right text-success",
                        beginGroup: true,
                        onItemClick: function ()
                        {
                            ServicePlacesListGrid_Refresh()
                        }
                    }]

        }
    }
    function ServicePlacesListGrid_dx_OnEditorPreparing(e) {
        if (e.parentType === "filterRow" && (e.dataField === "Timing")) {
            e.editorOptions.pickerType = "calendar",
                e.editorOptions.displayFormat = "HH:mm",
                e.editorOptions.calendarOptions =
                {
                    visible: false
                }
        }
        DxGrid_onEditorPreparing(e)
    }

