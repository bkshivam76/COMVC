        //    "<div class='col-sm-12 col-md-9 col-lg-9 compact_column_data wrapText' id='" + Name + "_Cell_" + KeyValue + "|Special_Ref' ondblclick = OnGridCellClick(event,this,'','','" + Name + "','" + KeyValue + "','','True','" + VouchingMode + "')>" +
        //    (JS_Json_Date_To_ddMMyyyy((templateData.data.Special_Ref ?? ""), "DD-MM-YYYY HH:mm:ss") ?? "") + "</div></div></div>";

        $(container).html(htmlString)
    }
    function ServicePlacesListGrid_dx_Compact_Column_CellValue(rowData) {
        var data =
            [
                rowData.Service_Place_Name, rowData.Start_Date, rowData.Weekdays, rowData.Timing,
                rowData.Status, rowData.Place_Owner, rowData.Place_Address,
                rowData.Place_Contact_No, rowData.Responsible_Person, rowData.Contact_No, rowData.Other_Details,
                rowData.Type

            ]
        return data.join(" ")
    }
    function ServicePlacesListGrid_dx_iIconTemplate(container, templateData) {
        var iREQ_ATTACH_COUNT = templateData.data.iREQ_ATTACH_COUNT
        var iCOMPLETE_ATTACH_COUNT = templateData.data.iCOMPLETE_ATTACH_COUNT
        var iRESPONDED_COUNT = templateData.data.iRESPONDED_COUNT
        var iREJECTED_COUNT = templateData.data.iREJECTED_COUNT
        var iOTHER_ATTACH_CNT = templateData.data.iOTHER_ATTACH_CNT
        var iALL_ATTACH_CNT = templateData.data.iALL_ATTACH_CNT
        var iIcon = templateData.data.iIcon
        var UniqueID = templateData.component.element()[0].id
        var key = templateData.data.ID
        var VisibleIndex = templateData.rowIndex
        var htmlString = "";
        htmlString = DxGrid_AttachmentIcons(iREQ_ATTACH_COUNT, iCOMPLETE_ATTACH_COUNT, iRESPONDED_COUNT, iREJECTED_COUNT, iOTHER_ATTACH_CNT, iALL_ATTACH_CNT);
        htmlString += DxGrid_VouchingAuditIcons(iIcon)
        htmlString += DxGrid_AuditIconAfterClick(UniqueID, key, VisibleIndex)
        $(container).html(htmlString)
    }
    function ServicePlacesListGrid_dx_GroupCell_Template(container, templateData) {
        DxGrid_GroupCell_Template(container, templateData)
    }    
</script>
