        function Look_PlaceOwner_EditValueChanged_ServicePlaces(e) {
            e.component.close();
            if ((e.value == null || e.value.length == 0) && e.previousValue != null) {
                Look_PlaceOwner_DataGrid.clearSelection();
                $("#Lbl_PlaceAddress_ServicePlaces").text('');
                $("#Lbl_Contact_ServicePlaces").text('');
                return;
            }

            if (Look_PlaceOwner_DataGrid.getSelectedRowsData().length > 0) {
                var item = Look_PlaceOwner_DataGrid.getSelectedRowsData()[0];
                if ((item["HOUSE_NO"] != undefined || item["HOUSE_NO"] != null) && item["HOUSE_NO"].length > 0)
                {
                    $("#Lbl_PlaceAddress_ServicePlaces").text("Address: " + item["BUILDING"]);
                } else {
                    $("#Lbl_PlaceAddress_ServicePlaces").text("Address: " +  "Not Specified");
                }

                if ((item["HOUSE_NO"]!= undefined || item["HOUSE_NO"] != null) && item["HOUSE_NO"].length > 0) {
                    $("#Lbl_PlaceAddress_ServicePlaces").text($("#Lbl_PlaceAddress_ServicePlaces").html() + ", " + item["HOUSE_NO"]);
                }
                if ((item["AREA_STREET"]!= undefined || item["AREA_STREET"]!= null) && item["AREA_STREET"].length > 0) {
                    $("#Lbl_PlaceAddress_ServicePlaces").text($("#Lbl_PlaceAddress_ServicePlaces").html() + ", " + item["AREA_STREET"]);
                }

                if ((item["MOBILE"]!= undefined || item["MOBILE"]!= null) && item["MOBILE"].length > 0) {
                    $("#Lbl_Contact_ServicePlaces").text("Contact No.: " + item["MOBILE"]);
                }
                else {
                    $("#Lbl_Contact_ServicePlaces").text("Contact No.: Not Specified");
                }
            }

        }
