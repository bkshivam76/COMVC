    @*Global Variables declarations and Document.Ready function.*@
<script type="text/javascript">


    //var ActionMethod_ServicePlace = "@Model.ActionMethod";
    var ActionMethod_ServicePlace = "@Model.Tag";

    //Dropdown related variables
    var Look_PlaceOwner_DataGrid;
    var Look_ResponsiblePerson_DataGrid;


    var Look_PlaceOwner_DDrefresh = false;
    var Look_ResponsiblePerson_DDrefresh = false;

    $(document).ready(async function () {        
        if ("@Model.ActionMethod".toUpperCase() == "_EDIT" || "@Model.ActionMethod".toUpperCase() == "_NEW") {
            dontaskpopupcloseconfirmation = false;
        } else {
            dontaskpopupcloseconfirmation = true;
        }
        
        TransformTextForDB("ServicePlacesForm")
        sessionclearpath = "/Profile/ServicePlaces/SessionClear_Window";
        InitAllDropdownDatagrid_SerivePlaces();
        await LookUp_GetOwnerList_ServicePlaces(true);
        await LookUp_GetResponsibleList_ServicePlaces(true);

        if ("@Model.Look_PlaceOwner_ServicePlaces".length > 0) {
            await Look_PlaceOwner_DataGrid.selectRows("@Model.Look_PlaceOwner_ServicePlaces", false);
        }

        if ("@Model.Look_ResponsiblePerson_ServicePlaces".length > 0) {
            await Look_ResponsiblePerson_DataGrid.selectRows("@Model.Look_ResponsiblePerson_ServicePlaces", false);
        }

        $("#Chk_Mon").dxCheckBox({})
            .dxValidator({
                validationRules:
                    [{
                        type: 'custom',
                        reevaluate: true,
                        validationCallback: function (e)
                        {
                            var x = 0;
                            if ($("#Chk_Mon").dxCheckBox("instance").option("value") == true) { x = x + 1 }
                            if ($("#Chk_Tue").dxCheckBox("instance").option("value") == true) { x = x + 1 }
                            if ($("#Chk_Wed").dxCheckBox("instance").option("value") == true) { x = x + 1 }
                            if ($("#Chk_Thu").dxCheckBox("instance").option("value") == true) { x = x + 1 }
                            if ($("#Chk_Fri").dxCheckBox("instance").option("value") == true) { x = x + 1 }
                            if ($("#Chk_Sat").dxCheckBox("instance").option("value") == true) { x = x + 1 }
                            if ($("#Chk_Sun").dxCheckBox("instance").option("value") == true) { x = x + 1 }
                            //console.log(x);
                            if (x == 0) {
                                return false;
                            } else {
                                return true;
                            }
                        },
                        message: " Weekdays Not Specified..!!"
                    }],
                validationGroup: "ServicePlaceValidationGroup"
            });

        $("#Txt_MaxCapacity_ServicePlaces").dxNumberBox({})
            .dxValidator({
                validationRules: [{
                    type: 'custom',
                    validationCallback: function (options) {
                        debugger;
                        var result = true;
                        if (options.value > 99999) {
                            result = false;
                        }
                        return result;
                    },
                    reevaluate: true,
                    ignoreEmptyValue: true,
                    message: "Maximum is 99999"
                }],
                validationGroup: "ServicePlaceValidationGroup"
        });

    });



</script> @*Global Variables declarations and Document.Ready function.*@

    <script type="text/javascript">
    function ServicePlace_SaveClick(e)
    {
        if (e.component.option("text") == "Delete") {
            CreateCustomConfirmDialog("@Model.TitleX_ServicePlace", "", true).show().done(function (dialogResult) {
                if (dialogResult) {
                    $("#ServicePlacesForm").submit();
                }
            });
        }
        else {

            var check = e.validationGroup.validate();            
            if (check.isValid) {

                $("#ServicePlacesForm").submit();
            }
            else {
                if (check.brokenRules[0]['message'] == " Weekdays Not Specified..!!") {
                    DevExpress.ui.dialog.alert(check.brokenRules[0]['message'])
                }
            }
        }
    }


    function ServicePlacesAjaxSuccessForm(data)
    {
        HideLoader();
        if (data.jsonParam.result == false) {


            if (data.jsonParam.refreshgrid) {
                var GridInstance = $('#ServicePlacesListGrid_dx').data("dxDataGrid")
                if (GridInstance !== void 0) {

                    ServicePlacesListGrid_Refresh();
                }
                else
                    RefreshGridView("ServicePlacesListGrid");
            }
            var alertclick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
            alertclick.done(function (alertResult) {
                if (alertResult) {
                    if (data.jsonParam.focusid) {
                        var id = "#" + data.jsonParam.focusid;
                        setTimeout(function () {
                            $(id).find('input').focus();
                        }, Timeout100);
                    }
                }
            });
            if (data.jsonParam.closeform)
            {
                dontaskpopupcloseconfirmation = true;
                $("#Dynamic_Content_popup").dxPopup("hide");
            }
        }
        else if (data.jsonParam.result == true)
        {

            var SavealertClick = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);


            if (typeof ServicePlacesListGrid !== 'undefined')
            {
                if (data.xid != null) {
                    ServiePlace_Select_xid = data.xid;
                }
                RefreshGridView("ServicePlacesListGrid")

                if ("@Model.Tag" == "_New" || "@Model.Tag" == "_New_From_Selection")
                {
                    SavealertClick.done(function (result)
                    {
                        if (result)
                        {
                            var confirm = DevExpress.ui.dialog.confirm('Add More Entry...?', "Service Place");
                            confirm.done(function (dialogResult)
                            {
                                if (dialogResult)
                                {
                                    OnServicePlacesNewClick();
                                }
                            });
                        }
                    });
                }
            }
            dontaskpopupcloseconfirmation = true;
            $("#Dynamic_Content_popup").dxPopup("hide");
        }
    }

    </script> @*This code is for Save button functionality and onsuccessful return of ajax call*@

