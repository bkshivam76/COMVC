<div class="col-md-12">
    @*Add/Edit Popup*@
    @(Html.DevExtreme().Popup().CustomPopup()
                        .ID("StockProfile_report_modal")
                        .OnShowing("PopupOnShowing")
                        .Title("Stock Profile List Preview")
                        .FullScreen(false)
                        .MaxWidth(125)
                        .Height("auto")
                        .ShowCloseButton(true)
                        .ContentTemplate(@<text>
                            <div id="StockProfile_report_modal_result">
                            </div>
                        </text>)
    )

    @(Html.DevExtreme().Popup().CustomPopup()
                .ID("popup_frm_StockProfile_Window_Close")
                .OnShowing("PopupOnShowing")
                .Title("Bank")
                .MaxHeight(460)
                .MaxWidth(750)
                .ContentTemplate( @<text>
                    <div id='popup_frm_StockProfile_Window_Close_result'>
                    </div>
                </text>)
    )

    @(Html.DevExtreme().Popup().CustomPopup()
                        .ID("popup_frm_StockProfile_Window")
                        .Title("StockProfile")
                        .OnShowing("PopupOnShowing")
                        .DragEnabled(true)
                        .Height(200)
                        .Width(650)
                        .ShowCloseButton(true)
                        .ContentTemplate(@<text>
                            <div id="popup_frm_StockProfile_Window_result">
                            </div>
                        </text>)
                    @*.OnHiding(@<text>
                                function () {

                                var result = DevExpress.ui.dialog.confirm("Are you sure to cancel this entry...?", "Confirm changes");
                                result.done(function (dialogResult) {
                                if(dialogResult){
                                $("#popup_frm_OpeningBalances_Window").dxPopup("hide");
                                }else
                                {
                                $("#popup_frm_OpeningBalances_Window").dxPopup("show");
                                }
                                });

                                }
                        </text>)*@
    )

    @* Testing MVC Popup here *@

    @* Testing ends here *@

</div>

@*Javascript Events*@
<script type="text/javascript">
    var StockProfile_ShowHorizontalBar = 0;
  
    var IsSFNewPopup = false;
    var IsSucessPopup = false;
    var IsViewPopup = false;
    $(document).ready(function () {
        $("#StockProfileListGrid").hover(function () {
            StockProfileListGrid.Focus()
        })
    });
    function StockprofileOnInit(s, e) {
        StockprofileAdjustSize();
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            StockprofileAdjustSize();
        });
    }
    function StockprofileGrid_BeginCallBack(s, e) {
        e.customArgs["command"] = e.command;
    }
   
    function StockprofileAdjustSize() {
        var height = (document.documentElement.clientHeight * 90) / 100;
        StockProfileListGrid.SetHeight(height);
        StockProfileListGrid.SetHeight(height);
    }
    function StockProfilechangeMode() {
        ShowLoader();
        if (StockProfile_ShowHorizontalBar == 0) {
            StockProfile_ShowHorizontalBar = 1;
            $("#StockProfileToggleScrollBar").find("span").text("Default Data");
            $("#StockProfileToggleScrollBar").width(110);
        }
        else {
            Openingbalances_ShowHorizontalBar = 0;
            $("#StockProfileToggleScrollBar").find("span").text("Full Data");
            $("#StockProfileToggleScrollBar").width(90);
        }
        $.ajax({
            url: '@Url.Action("Frm_Stock_Info_Grid", "Stock")',
            type: "GET",
            data: { ShowHorizontalBar: StockProfile_ShowHorizontalBar },
            success: function (res) {
                $("#StockProfilereloadPartialView").html(res);
            }
        });
        HideLoader();
    }
   

    function StockprofiledblclickEdit(s, e) {
        //var key = s.GetRowKey(s.GetFocusedRowIndex());
        //OpeningbalancesListGrid.GetValuesOnCustomCallback({ key: key }, FDOnGetRowValues);
        //if (FDID != null || FDID == "" || FDID == undefined)
        //    OnEditClick();
    }

    function StockprofileContextMenuFunction(s, e) {
        if (e.item.name == 'New') {
            OnNewClick();
        }
        if (e.item.name == 'Close') {
            btnCloseActiveTab();
        }
        else if (e.item.name == 'Edit') {
            OnEditClick();
        }
        else if (e.item.name == 'Delete') {
            OnDeleteClick();
        }
        else if (e.item.name == 'View') {
            OnViewClick();
        }
        else if (e.item.name == 'ListPreview') {
            OnListPreviewClick();
        }
        else if (e.item.name == 'Lock') {
            OnLockClick();
        }
        else if (e.item.name == 'UnLock') {
            OnUnlockClick();
        }
        else if (e.item.name == 'Refresh') {
            StockProfileListGrid.Refresh();
        }
    } 

</script>
