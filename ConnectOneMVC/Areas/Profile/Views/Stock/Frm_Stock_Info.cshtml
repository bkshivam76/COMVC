@using DevExtreme.AspNet.Mvc;

@model IEnumerable<dynamic>
@{
    ViewBag.Title = "Index";
    Layout = null;
}
<div id="content" class="col-md-12 report_header_div_main">
    <div class="col-md-4 report_header_div">
        <label class="report_header_label">Stock Profile</label>
    </div>
    @*Buttons*@
    <div class="report_button_div">
        @(Html.DevExtreme().Button()
                                                .ID("StockProfileUnlock")
                                                .Text("Unlock")
                                                .Icon("add")
                                                .Visible(false)
                                                .Disabled(true)
                                                .OnClick(@<text>
                                                        function () {
                                                        StockProfileUnlockClick();
                                                        }
                                                    </text>)
        )

        @(Html.DevExtreme().Button()
                                                .ID("StockProfileLock")
                                                .Text("Lock")
                                                .Icon("add")
                                                .Visible(false)
                                                .Disabled(true)
                                                .OnClick(@<text>
                                                        function () {
                                                        StockProfileLockClick();
                                                        }
                                                    </text>)
        )
        @(Html.DevExtreme().Button()
                                                .ID("StockProfileNew")
                                                .Text("New")
                                                .Icon("add")
                                                .Visible(false)
                                                .Disabled(true)
                                                .OnClick(@<text>
                                                        function () {
                                                        StockProfileNewClick();
                                                        }
                                                    </text>)
        )
        @(Html.DevExtreme().Button()
                                                .ID("StockProfileEdit")
                                                .Text("Edit")
                                                .Icon("edit")
                                                .Visible(false)
                                                .Disabled(true)
                                                .OnClick(@<text>
                                                        function () {
                                                        StockProfileOBEditClick();
                                                        }
                                                    </text>)
        )
        @(Html.DevExtreme().Button()
                                                .ID("StockProfileDelete")
                                                .Text("Delete")
                                                .Icon("trash")
                                                .Visible(false)
                                                .Disabled(true)
                                                .OnClick(@<text>
                                                        function () {
                                                        StockProfileDeleteClick();
                                                        }
                                                    </text>)
        )

        @(Html.DevExtreme().Button()
                                                .ID("StockProfileView")
                                                .Text("View")
                                                .Icon(IconID.ViewCustomers16x16devav)
                                                .Icon("doc")
                                                .Visible(false)
                                                .Disabled(true)
                                                .OnClick(@<text>
                                                        function () {
                                                        StockProfileViewClick();
                                                        }
                                                    </text>)
        )
        @(Html.DevExtreme().Button()
                                                                            .ID("StockProfileToggleScrollBar")
                                                                            .Text("Full Data")
                                                                            .Width(90)
                                                                            .Icon("toolbox")
                                                                            .OnClick(@<text>
                                                                                    function () {
                                                                                    StockProfilechangeMode();
                                                                                    }
                                                                                </text>)
        )
        @(Html.DevExtreme().Button()
                                                                            .ID("StockProfileListPreview")
                                                                            .Text("Export")
                                                                            .Icon("save")
                                                                            .Width(75)
                                                                            .OnClick(@<text>
                                                                                    function () {
                                                                                    StockProfileListPreviewClick();
                                                                                    }
                                                                                </text>)
        )

        @(Html.DevExtreme().Button()
                                                                            .ID("StockProfileCLOSE")
                                                                            .Text("Close")
                                                                            .Icon("clear")
                                                                            .OnClick(@<text>
                                                                                    function (){$(".TabPanalMenu-tabs .active span").click()}
                                                                                </text>)

        )
    </div>
</div>
<div class="col-md-12 no-padding">
    <form>
        <div id="StockProfilereloadPartialView" class="parent_table">           
            @Html.Partial("Frm_Stock_Info_Grid", Model)             
