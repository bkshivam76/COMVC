        }
        Grid_Display_Telephone();
        $("#TelephoneListGrid").hover(function ()
        {
            TelephoneListGrid.Focus()
        });
        $(".TelephoneListGrid_PreviewRow").hide();
        GetSessionStorage("TelephoneListGrid");
    });
    $(".TabPanalMenu-tabs .active span").on("click", function ()
    {
        $.ajax({
            type: 'GET',
            url: "/Profile/Telephone/SessionClear",
            cache: false
        });
        CloseRightPane();
        ClearLeftPane();
        CloseLeftPane();
