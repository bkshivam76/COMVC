        {
            $("#TelephoneModelEdit").hide();
        }
        if ("@Telephone_ViewRight" == "False")
        {
            $("#TelephoneModelView").hide();
        }
        if ("@Telephone_DeleteRight" == "False")
        {
            $("#TelephoneModelDelete").hide();
        }
        if ("@Telephone_ExportRight" == "False")
