    <script>
        function Grid_Display_Telephone() {
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Profile/Telephone/Grid_Display",
                async: false,
                cache: false,
                success: function (data) {
                    if (data.result == false) {
                        DevExpress.ui.dialog.alert(data.message, "Error!!");
                    }
                    else {
                        ShowLoader();
                        Telephone_TotalRowCount = data.TotalRowCount;
                        TelephoneRefresh();

                    }
                }
            });
            HideLoader();
        }
        function TelephoneRefresh() {
            if (typeof window !== 'undefined') {
                if (typeof window.TelephoneListGrid !== 'undefined') {
                    if (typeof window.TelephoneListGrid.Refresh !== 'undefined') {
                        if (typeof TelephoneListGrid.Refresh == 'function') {
                            //window.TelephoneListGrid.Refresh();
                            if (Telephone_SetVouchingModeOn == true) {
                                $("#TelephoneViewModeSwitch").dxSwitch("instance").option("value", true);
                            }
                            else {
                                TelephoneListGrid.PerformCallback({});
                            }

                        }
                        else {
                            alert("refresh is not a function");
                        }
                    }
                    else {
                        ShowLoader();
                        setTimeout(function () {
                            TelephoneRefresh();
                            HideLoader();
                        }, Timeout100);
                    }
                }
                else {
                    alert('grid undefined')
                }
            }
            else {
                alert('window undefined')
            }
        }
    </script>
    <script>
    var TelephoneInfo_IsDetailRowExpanded = false;
    var TelephoneInfo_NestedRecord_FocusedRowIndex = -1;
    var TelephoneInfo_NestedGrid_AccessID;
    var TelephoneInfo_AtachmentID;
    var TelephoneInfo_FileName;
    var TelephoneInfo_ParamMandatory;
    var TelephoneInfo_FromDateLabel;
    var TelephoneInfo_ToDateLabel;
    var TelephoneInfo_DescriptionLabel;
    var TelephoneInfo_Doc_ID;
    var TelephoneInfo_Doc_Category;
    var TelephoneInfo_MasterRowRecID;
    var TelephoneInfo_MasterRowMID;
    var TelephoneInfo_NestedRowMapID;
    var TelephoneInfo_reason;
    var TelephoneInfo_Attachment_RecStatus;
    var TelephoneInfo_NestedRowReasonID;
    var TelephoneInfo_NestedRowKeyValue;

    function On_TelephoneProfile_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@Help_Attachment_AddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (TelephoneInfo_ParamMandatory == 1)
            {
                AddAttachment(TelephoneInfo_MasterRowRecID, "Profile_Telephone", TelephoneInfo_Doc_ID, TelephoneInfo_Doc_Category, TelephoneInfo_ParamMandatory, TelephoneInfo_FromDateLabel, TelephoneInfo_ToDateLabel, TelephoneInfo_DescriptionLabel, "TelephoneProfileAttachment", null, "TelephoneListGrid", TelephoneInfo_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(TelephoneInfo_MasterRowRecID, "Profile_Telephone", TelephoneInfo_Doc_ID, "TelephoneProfileAttachment", "TelephoneListGrid", TelephoneInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (TelephoneInfo_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(TelephoneInfo_MasterRowRecID, "Profile_Telephone", TelephoneInfo_AtachmentID, TelephoneInfo_ParamMandatory, TelephoneInfo_FromDateLabel, TelephoneInfo_ToDateLabel, TelephoneInfo_DescriptionLabel, "TelephoneProfileAttachment", null, "TelephoneListGrid", TelephoneInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(TelephoneInfo_MasterRowRecID, "Profile_Telephone", TelephoneInfo_AtachmentID, TelephoneInfo_ParamMandatory, TelephoneInfo_FromDateLabel, TelephoneInfo_ToDateLabel, TelephoneInfo_DescriptionLabel, null, "TelephoneListGrid", TelephoneInfo_NestedGrid_AccessID, TelephoneInfo_Attachment_RecStatus);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@Help_Attachment_ViewRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            ViewDocument(TelephoneInfo_AtachmentID, TelephoneInfo_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(TelephoneInfo_MasterRowRecID, "Profile_Telephone", "Telephone Information", "TelephoneListGrid", TelephoneInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Add_Reason")
        {
            if (TelephoneInfo_Doc_Category.toLowerCase() == "others")
            {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else
            {
                AttachmentAddReason(TelephoneInfo_MasterRowRecID, TelephoneInfo_NestedRowMapID, "Profile_Telephone", "TelephoneListGrid", TelephoneInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(TelephoneInfo_MasterRowRecID, TelephoneInfo_NestedRowMapID, "Profile_Telephone", "TelephoneListGrid", TelephoneInfo_NestedGrid_AccessID, TelephoneInfo_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(TelephoneInfo_MasterRowRecID, TelephoneInfo_NestedRowMapID, "TelephoneListGrid", TelephoneInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
        else if (e.actionName == "AuditAction")
        {
            TelephonePrf_FAB.SetActionContext("AuditActionContext", true);
        }
        else if (e.actionName == "BackAudit")
        {
            if (TelephoneInfo_Nested_Doc_Status == "")
            {
                TelephonePrf_FAB.SetActionContext("AutoItemContext", true);
            }
            if (TelephoneInfo_Nested_Doc_Status == "NO")
            {
                TelephonePrf_FAB.SetActionContext("EditItemContext", true);
            }
            if (TelephoneInfo_Nested_Doc_Status == "YES")
            {
                TelephonePrf_FAB.SetActionContext("actionItemContext", true);
            }
        }
        else if (e.actionName == "Accept")
        {
            TelephoneInfo_AcceptwithoutRemarks();
        }
        else if (e.actionName == "Reject")
        {
            TelephoneInfo_AcceptRejectVoucher("Reject");
        }
        else if (e.actionName == "AcceptWithRemarks")
        {
            TelephoneInfo_AcceptRejectVoucher("Accept");
        }
        else if (e.actionName == "AcceptDoc") {

            OnTelephoneInfo_AcceptDoc();
        }
        else if (e.actionName == "RejectDoc") {

            OnTelephoneInfo_RejectDoc();
        }
    }
    function OnTelephoneInfo_RejectDoc() {
        if (TelephoneInfo_AtachmentID == null || TelephoneInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        RejectAttachment(TelephoneInfo_AtachmentID, "TelephoneListGrid", TelephoneInfo_NestedGrid_AccessID);
    }
    function OnTelephoneInfo_AcceptDoc() {
        if (TelephoneInfo_AtachmentID == null || TelephoneInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        AcceptAttachment(TelephoneInfo_AtachmentID, "TelephoneListGrid", TelephoneInfo_NestedGrid_AccessID);
    }
    function TelephoneInfo_AcceptwithoutRemarks()
    {
        var Recid;
        if (TelephoneInfo_IsDetailRowExpanded == true || Telephone_IsVouchingMode == true)
        {
            if (TelephoneInfo_MasterRowRecID == null || TelephoneInfo_MasterRowRecID == "")
            {
                Recid = TelephoneID;
            }
            else
            {
                Recid = TelephoneInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = TelephoneID;
        }
        Entry_AcceptwithoutRemarks(Recid, "Profile_Telephone", "TelephoneListGrid", TelephoneInfo_AtachmentID, TelephoneInfo_NestedRowReasonID, TelephoneInfo_NestedRowKeyValue);
    }
    function TelephoneInfo_AcceptRejectVoucher(_actionMethod)
    {
        var Recid;
        if (TelephoneInfo_IsDetailRowExpanded == true || Telephone_IsVouchingMode == true)
        {
            if (TelephoneInfo_MasterRowRecID == null || TelephoneInfo_MasterRowRecID == "")
            {
                Recid = TelephoneID;
            }
            else
            {
                Recid = TelephoneInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = TelephoneID;
        }
        Entry_AcceptReject(_actionMethod, Recid, "Profile_Telephone", "TelephoneListGrid", TelephoneInfo_AtachmentID, TelephoneInfo_NestedRowReasonID, TelephoneInfo_NestedRowKeyValue);
    }
    function OnTelephoneListGridNestedFocusedRowChange(s, e)
    {
        if (TelephoneInfo_IsDetailRowExpanded == true || Telephone_IsVouchingMode == true)
        {
            TelephoneInfo_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
            if (TelephoneInfo_NestedRecord_FocusedRowIndex >= 0)
            {
                ShowLoader();
                TelephoneInfo_NestedGrid_AccessID = s.uniqueID;
                s.GetRowValues(s.GetFocusedRowIndex(), 'Doc_Status;Params_Mandatory;LABEL_FROM_DATE;LABEL_TO_DATE;LABEL_DESCRIPTION;Document_Category;Document_ID;ATTACH_ID;TxnID;TxnMID;MAP_ID;Reason;ATTACH_FILE_NAME;Attachment_Action_Status;UniqueID;ReasonID', OnTelephoneInfo_GetGridRowValues);
            }
            else
            {
                TelephonePrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }
    function OnTelephoneInfo_GetGridRowValues(values)
    {
        HideLoader();
        if (values[14] != null)
        {
            TelephonePrf_FAB.SetVisible(true);
            TelephoneInfo_Nested_Doc_Status = values[0];
            if (Telephone_IsVouchingMode == true)
            {
                TelephonePrf_FAB.SetActionContext("AuditActionContext", true);
            }
            else
            {
                if (TelephoneInfo_Nested_Doc_Status == "")
                {
                    TelephonePrf_FAB.SetActionContext("AutoItemContext", true);
                }
                else if (TelephoneInfo_Nested_Doc_Status == "NO")
                {
                    TelephonePrf_FAB.SetActionContext("EditItemContext", true);
                }
                else if (TelephoneInfo_Nested_Doc_Status == "YES")
                {
                    TelephonePrf_FAB.SetActionContext("actionItemContext", true);
                }
            }
            TelephoneInfo_ParamMandatory = values[1];
            TelephoneInfo_FromDateLabel = values[2];
            TelephoneInfo_ToDateLabel = values[3];
            TelephoneInfo_DescriptionLabel = values[4];
            TelephoneInfo_Doc_Category = values[5];
            TelephoneInfo_Doc_ID = values[6];
            TelephoneInfo_AtachmentID = values[7];
            IndexAttachmentID = TelephoneInfo_AtachmentID;
            TelephoneInfo_MasterRowRecID = values[8];
            TelephoneInfo_MasterRowMID = values[9];
            TelephoneInfo_NestedRowMapID = values[10];
            TelephoneInfo_reason = values[11];
            TelephoneInfo_FileName = values[12];
            TelephoneInfo_Attachment_RecStatus = values[13];
            TelephoneInfo_NestedRowKeyValue = values[14];
            if (Telephone_IsVouchingMode == true)
            {
                if (TelephoneInfo_FileName != null && TelephoneInfo_FileName.length > 0)
                {
                    ViewDocument(TelephoneInfo_AtachmentID, TelephoneInfo_FileName, "TelephonePrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else
                {
                    CloseRightPane();
                    ClearRightPane();
                }
            }
        }
        TelephoneInfo_NestedRowReasonID = values[15];
        IndexAttachmentReasonID = TelephoneInfo_NestedRowReasonID;
    }
    function TelephoneGrid_Nested_BeginCallBack(s, e)
    {
        e.customArgs["ShowHorizontalBar"] = Telephone_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = Telephone_IsVouchingMode;
        e.customArgs["command"] = e.command;
    }
    function TelephoneGrid_DetailRowExpanding(s, e)
    {
        TelephoneInfo_IsDetailRowExpanded = true;
        s.SetFocusedRowIndex(e.visibleIndex);
        var pane = Mainspliter.GetPaneByName('RightPane');
        if (Telephone_IsVouchingMode == true)
        {
            pane.Expand();
        }
        else
        {
            pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
        }
    }
    function TelephoneGrid_DetailRowCollapsing(s, e)
    {
        TelephoneInfo_IsDetailRowExpanded = false;
        s.SetFocusedRowIndex(e.visibleIndex);
        if (Telephone_IsVouchingMode == true)
        {
            if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false)
            {
                CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
        else
        {
            TelephonePrf_FAB.SetVisible(false);
        }
    }
    </script>
    @*attachment and nested grid*@

</div>