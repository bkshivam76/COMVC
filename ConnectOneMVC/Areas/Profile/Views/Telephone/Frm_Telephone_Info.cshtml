<div class="TelephoneProfile_ClearReferences">

    @using DevExtreme.AspNet.Mvc;

    @model IEnumerable<dynamic>
    @{
        ViewBag.Title = "Index";
        Layout = null;
        string UserType = (string)ViewBag.UserType;
        bool Telephone_AddRight = (bool)ViewData["Telephone_AddRight"];
        bool Telephone_UpdateRight = (bool)ViewData["Telephone_UpdateRight"];
        bool Telephone_ViewRight = (bool)ViewData["Telephone_ViewRight"];
        bool Telephone_DeleteRight = (bool)ViewData["Telephone_DeleteRight"];
        bool Telephone_ExportRight = (bool)ViewData["Telephone_ExportRight"];
        var xid = (string)ViewData["xid"];
        bool Help_Attachment_AddRight = (bool)ViewData["Help_Attachment_AddRight"];//attachment
        bool Help_Attachment_EditRight = (bool)ViewData["Help_Attachment_EditRight"];//attachment
        bool Help_Attachment_ViewRight = (bool)ViewData["Help_Attachment_ViewRight"];//attachment
        bool Help_Attachment_DeleteRight = (bool)ViewData["Help_Attachment_DeleteRight"];//attachment
        bool Telephone_Auto_Vouching_Mode = (bool)ViewData["Telephone_Auto_Vouching_Mode"];
