    function OnTelephoneCellClick(event, cell,col, row)
    {
        if (UserType_TelephonePrf == "AUDITOR" || UserType_TelephonePrf == "SUPERUSER")
        {
            if (event.button == 0)
            {
                if (cell.style.backgroundColor.length > 0)
                {
                    cell.style.backgroundColor = "";
                }
                else
                {
                    cell.style.backgroundColor = 'skyblue';
                }
            }
        }
    }
    function Telephone_VouchingSwitch_ValueChange(e)
    {
        Telephone_IsVouchingMode = e.value;
        TelephoneListGrid.SetFocusedRowIndex(-1);
        TelephonePrf_FAB.SetVisible(false);
        if (Telephone_IsVouchingMode == true) {
            OpenRightPane();
            ClearLeftPane();
            OpenLeftPane();
        }
        else {
            TelephonePrf_FAB.SetActionContext("AddAttachmentContext", false);
            CloseRightPane();
            ClearLeftPane();
            CloseLeftPane();
        }
        TelephoneListGrid_CollapseAllDetailRows();
    }
    function TelephoneListGrid_CollapseAllDetailRows()
    {
        if (typeof window !== 'undefined')
        {
            if (typeof window.TelephoneListGrid !== 'undefined')
            {
                if (typeof window.TelephoneListGrid.CollapseAllDetailRows !== 'undefined')
                {
                    if (typeof TelephoneListGrid.CollapseAllDetailRows == 'function')
                    {
                        TelephoneListGrid.SetFocusedRowIndex(-1);
                        TelephoneListGrid.CollapseAllDetailRows();
                    }
                    else
                    {
                        alert("CollapseAllDetailRows is not a function");
                    }
                }
                else
                {
                    ShowLoader();
                    setTimeout(function ()
                    {
                        TelephoneListGrid_CollapseAllDetailRows();
                        HideLoader();
                    }, Timeout100);
                }
            }
            else
            {
                alert('grid undefined')
            }
        }
        else
        {
            alert('window undefined')
        }
    }
    function Telephone_ViewSwitch_ValueChange(e)
    {
        Telephone_ViewMode = e.value == false ? "Default" : "Compact";
        if (Telephone_SetVouchingModeOn == true)
        {
            $("#TelephoneVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }
        else
        {
            TelephoneListGrid.CollapseAllDetailRows();
        }
    }
</script>

    <script>

    function TelephoneOnInit(s, e)
    {
        TelephoneAdjustSize();
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt)
        {
            TelephoneAdjustSize();
        });
        $(".TelephoneListGrid_PreviewRow").hide();
    }

    var Tele_ColumnToBeShownIndex = "";
    var Tele_ColumnToBeHidddenIndex = "";
    function TelephoneListGrid_EndCallback(s, e)
    {
        //TelephoneAdjustSize();
        Tele_ColumnToBeShownIndex = s.cpColumnToBeShownIndex;
        Tele_ColumnToBeHidddenIndex = s.cpColumnToBeHidddenIndex;
        TelephoneLayout = s.cpClientLayout;
        $(".TelephoneListGrid_PreviewRow").hide();
        if (e.command == "REFRESH")
        {
            if (TelephoneFocusRowIndexBeforeRefresh == s.GetFocusedRowIndex())
            {
                s.SetFocusedRowIndex(-1);
                s.SetFocusedRowIndex(TelephoneFocusRowIndexBeforeRefresh);
            }
            Select_xid_Telephone = "";
        }
        else if (e.command == "CUSTOMCALLBACK")
        {
            $(".TelephoneListGrid_PreviewRow").hide();
            if (TelephoneFocusRowIndexBeforeRefresh == s.GetFocusedRowIndex()) {
                s.SetFocusedRowIndex(-1);
                s.SetFocusedRowIndex(TelephoneFocusRowIndexBeforeRefresh);
            }
            Select_xid_Telephone = "";
        }

        GetSessionStorage("TelephoneListGrid");
        SendCustomArgs_FilterControl(s, e);
        ASPxClientControl.AdjustControls(document.getElementById("TelephoneProfile_ParentDiv"));
    }
    function TelephoneAdjustSize()
    {
        var height = (document.documentElement.clientHeight * 90) / 100;
            try{TelephoneListGrid.SetHeight(height);}catch(err){}
    }
    function TelephonechangeMode()
    {
        ShowLoader();
        if (Telephone_ShowHorizontalBar == 0)
        {
            Telephone_ShowHorizontalBar = 1;
            $("#TelephoneToggleScrollBar").find("span").text("Default Data");
            $("#TelephoneToggleScrollBar").width(110);
        }
        else {
            Telephone_ShowHorizontalBar = 0;
            $("#TelephoneToggleScrollBar").find("span").text("Full Data");
            $("#TelephoneToggleScrollBar").width(90);
        }
        $.ajax({
            url: '@Url.Action("Frm_Telephone_Info_Grid", "Telephone")',
            type: "GET",
            data: { ShowHorizontalBar: Telephone_ShowHorizontalBar, Layout: TelephoneLayout, VouchingMode: Telephone_IsVouchingMode, ViewMode: Telephone_ViewMode, ColumnToBeHidddenIndex: Tele_ColumnToBeHidddenIndex, ColumnToBeShownIndex: Tele_ColumnToBeShownIndex  },
            success: function (res)
            {
                $("#TelephonereloadPartialView").html(res);
                $(".TelephoneListGrid_PreviewRow").hide();
                GetSessionStorage("TelephoneListGrid");
            }
        });
        HideLoader();
    }

    var TelephoneID;
    var tP_NOField;
    var telMiscIdField;
    var Telephone_categoryField;
    var Telephone_typeField;
    var Telephone_EditDate;
    var Telephone_AddDate;
    var Telephone_AddBy;
    var Telephone_EditBy;
    var Telephone_ActionStatus;

        function TelephonedblclickEdit(s, e)
        {
        //if (TelephoneID != null || TelephoneID == 'undefined' || TelephoneID == undefined)
        //    OnTelephoneEditClick();
    }

    function TelephoneGrid_BeginCallBack(s, e)
    {
        TelephoneFocusRowIndexBeforeRefresh = s.GetFocusedRowIndex();
        e.customArgs["command"] = e.command;
        e.customArgs["ShowHorizontalBar"] = Telephone_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = Telephone_IsVouchingMode;
        e.customArgs["ViewMode"] = Telephone_ViewMode;
        e.customArgs["ColumnToBeShownIndex"] = Tele_ColumnToBeShownIndex;
        e.customArgs["ColumnToBeHidddenIndex"] = Tele_ColumnToBeHidddenIndex;
        e.customArgs["RowKeyToFocus"] = Select_xid_Telephone;
    }

    function OnTelephoneGridFocusedRowChanged(s, e)
    {
        if (s.GetFocusedRowIndex() > -1)
        {
                var key = s.GetRowKey(s.GetFocusedRowIndex());
                TelephoneListGrid.GetValuesOnCustomCallback({ key: key }, TelephoneOnGetRowValues);
        }
        else
        {
            TelephoneID = null;
        }
    }

    function TelephoneOnGetRowValues(TelephoneData)
    {
        var values = TelephoneData.split("![");
        TelephoneID = values[0];
        TP_NO = values[1];
        telMiscIdField = values[2];
        Telephone_categoryField = values[3];
        Telephone_typeField = values[4];
        Telephone_EditDate = values[5];
        Telephone_AddDate = values[6];
        Telephone_AddBy = values[7];
        Telephone_EditBy = values[8];
        Telephone_ActionStatus = values[9];
        var actiondate = values[10];
        var actionby = values[11];
        Telephone_UpdateFooterDetail(TelephoneID, Telephone_ActionStatus, Telephone_AddDate, Telephone_AddBy,
            actiondate, actionby, Telephone_EditDate, Telephone_EditBy);
        if (Telephone_IsVouchingMode == true) {
            OpenLeftPane();
            LoadDocumentAndAdditionalInfoInLeftPane("Profile", "Telephone", "LeftPaneContent", TelephoneID, Telephone_IsVouchingMode, "");
        }
    }

        function Telephone_UpdateFooterDetail(TelephoneID, Telephone_Action_Status, Telephone_Add_Date, Telephone_Add_By, Telephone_Action_Date, Telephone_Action_By, Telephone_Edit_Date, Telephone_Edit_By)
        {
            var Status = "";
            var Lbl_Status = "";
            var Lbl_StatusBy = "";
            var Pic_Status = "";
            var Lbl_Create = "";
            var Lbl_Modify = "";
            var Lbl_Status_Color = "";
            var Lbl_ActionOn = "";
            var Lbl_ActionBy = "";
            var StatusStr = "";
            Status = Telephone_Action_Status;
            StatusStr = Status == "Locked" ? "Locked" : Status == null ? null : "UnLocked";
            if (Status && Status.toUpperCase() == "LOCKED") {
                Lbl_Status = "Completed";
                Lbl_Status_Color = "blue";
                Pic_Status = "fa fa-lock";
            }
            else {
                Pic_Status = "fa fa-unlock";
                Lbl_Status = Status;
                if (Status && Status.toUpperCase() == "COMPLETED") {
                    Lbl_Status_Color = "green";
                }
                else {
                    Lbl_Status_Color = "red";
                }
            }
            if (Telephone_Add_Date) {
                Lbl_Create = "Add On: " + Telephone_Add_Date + ", By: " + Telephone_Add_By;
            }
            if (Telephone_Edit_Date) {
                Lbl_Modify = "Edit On: " + Telephone_Edit_Date + ", By: " + Telephone_Edit_By;
            }

                Lbl_ActionOn = StatusStr + " On: " + Telephone_Action_Date;


                Lbl_ActionBy = StatusStr + " By: " + Telephone_Action_By;

            $('#TelephoneLbl_Status').text(Lbl_Status);
            $('#TelephoneLbl_Create').text(Lbl_Create);
            $('#TelephoneLbl_Modify').text(Lbl_Modify);
            $('#Telephone_Lbl_ActionOn').text(Lbl_ActionOn);
            $('#Telephone_Lbl_ActionBy').text(Lbl_ActionBy);
            if (Lbl_Status_Color != "") {
                $('#TelephoneLbl_Status').css('color', Lbl_Status_Color);
            }
            if (Pic_Status == "fa fa-lock") {
                $('#Telephone_LockICON').addClass(Pic_Status).removeClass("fa-unlock");
            }
            else if (Pic_Status == "fa fa-unlock") {
                $('#Telephone_LockICON').addClass(Pic_Status).removeClass("fa-lock");
            }
            else {
                $('#Telephone_LockICON').removeClass("fa").removeClass("fa-lock").removeClass("fa-unlock");
            }

        }



    function OnTelephoneNewClick()
    {
        if ("@Telephone_AddRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        ShowLoader();
        OpenPopup("popup_frm_Telephone_Window", "New ~ Telephone", "@Url.Action("frm_Telephone_window", "Telephone", new { @area = "Profile" })?ActionMethod=" + "New", "auto",800, false, null);
    }
    function OnTelephoneEditClick()
    {
        if ("@Telephone_UpdateRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        if (TelephoneID == 'undefined' || TelephoneID == undefined || TelephoneID == null || TelephoneID.length<1)
        {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        $.ajax({
            type: 'GET',
            url: "/Profile/Telephone/DataNavigation",
            data:
            {
                ActionMethod: "Edit", id: TelephoneID
            },
            cache: false,
            success: function (data)
            {
                if (data.result == true)
                {
                    $.ajax({
                        type: 'GET',
                        url: "/Profile/Telephone/frm_Telephone_window",
                        data:
                        {
                            ActionMethod: "Edit",
                            ID: TelephoneID,
                            EditedOn: Telephone_EditDate
                        },
                        success: function (data)
                        {
                            ShowLoader();
                            OpenPopup("popup_frm_Telephone_Window", "Edit ~ Telephone",null, "auto",800,true,data);
                        }
                    });
                }
                else
                {
                    DevExpress.ui.dialog.alert(data.message, 'Information...');
                    Grid_Display_Telephone();
                }
            }
        });
    }

