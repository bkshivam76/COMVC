    var UserType_TelephonePrf = "@UserType".toUpperCase();
    var Telephone_IsVouchingMode = false;
    var Telephone_ViewMode = "Default";
    $(document).ready(function ()
    {
        if ("@Telephone_AddRight" == "False")
