    <style>
        .wrapText {
            word-break: break-all;
        }
    </style>
    <div id="TelephoneProfile_ParentDiv">
        <div id="content_TelephoneProfile" class="col-md-12 report_header_div_main">
            <div class="col-md-4 report_header_div">
                <label class="report_header_label">Telephone Information</label>
            </div>
            @*Buttons*@
            <div class="report_button_div">
                @(Html.DevExtreme().Switch().ID("TelephoneVouchingModeSwitch").SwitchedOnText("Vouching On").SwitchedOffText("Vouching Off").OnValueChanged("Telephone_VouchingSwitch_ValueChange").Width(100).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
                @(Html.DevExtreme().Switch().ID("TelephoneViewModeSwitch").SwitchedOnText("Compact").SwitchedOffText("Default").OnValueChanged("Telephone_ViewSwitch_ValueChange").Width(70).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
                @(Html.DevExtreme().Button().ID("TelephoneModelNew").Text("New").Icon("add").OnClick(@<text> function () { OnTelephoneNewClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("TelephoneModelEdit").Text("Edit").Icon("edit").OnClick(@<text> function () { OnTelephoneEditClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("TelephoneModelDelete").Text("Delete").Icon("trash").OnClick(@<text> function () { OnTelephoneDeleteClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("TelephoneModelView").Text("View").Icon("doc").OnClick(@<text> function () { OnTelephoneViewClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("TelephoneToggleScrollBar").Text(ViewBag.ShowHorizontalBar == 1 ? "Default Data" : "Full Data").Width(ViewBag.ShowHorizontalBar == 1 ? 110 : 90).Icon("toolbox").OnClick(@<text> function () { TelephonechangeMode(); } </text>) )
                @(Html.DevExtreme().Button().ID("TelephoneModelListExport").Text("Export").Icon("save").Width(80).OnClick(@<text> function () { OnTelephoneListPreviewClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("TelephoneModelCLOSE").Text("Close").Icon("clear").OnClick(@<text> function (){closeProfile_Telephone();} </text>) )
            </div>
        </div>
        <div class="col-md-12 no-padding">
            <form>
                <div id="TelephonereloadPartialView" class="parent_table">
                    @Html.Partial("Frm_Telephone_Info_Grid", Model)
                </div>
            </form>
        </div>
        <div class="footer-MainBoxdiv" style="display:inline-block;width:100%">
            <div class="setFooterItem">
                <div class="footer-inner">
                    <div class="list_footer_left_margin">
                        <div class="footericon">
                            <i id="Telephone_LockICON" style="color:red;font-size:35px;"></i>
                        </div>
                        <div class="footer-locktext">
                            <div id="Telephone_Lbl_ActionOn" class="left_footertext_top"></div>
                            <div id="Telephone_Lbl_ActionBy" class="left_footertext_bottom"></div>
                        </div>
                    </div>
                    <div class="list_footer_left_margin">
                        <div class="footer-text">
                            <p id="TelephoneLbl_Create" class="right_footertext_top"></p>
                            <p id="TelephoneLbl_Modify" class="right_footertext_bottom"></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        @Html.Partial("AttachmentFAB", "TelephonePrf_FAB,TelephoneProfile_grid_DIV,Type1,TelephoneProfile," + UserType) @*fab buttons*@
        <div class="col-md-12">
            @*Add/Edit Popup*@
            @(Html.DevExtreme().Popup().CustomPopup()
                                                                                    .ID("Telephone_report_modal")
                                                                                    .Title("Telephone List Preview")
                                                                                    .FullScreen(false)
                                                                                    .MaxWidth(125)
                                                                                    .Height("auto")
                                                                                    .ShowCloseButton(true)
                                                                                    .ContentTemplate(@<text>
                                                                                        <div id='Telephone_report_modal_result'>
                                                                                        </div>
                                                                                    </text>)
        )
            @(Html.DevExtreme().Popup().CustomPopup()
                                                                                    .ID("popup_frm_Telephone_Window")
                                                                                    .Title("Telephone")
                                                                                    .OnShowing("PopupOnShowing")
                                                                                    .DragEnabled(true)
                                                                                    .MaxHeight("auto")
                                                                                    .MaxWidth(1000)
                                                                                    .ShowCloseButton(true)
                                                                                    .ContentTemplate(@<text>
                                                                                        <div id="Telephoneresult">
                                                                                        </div>
                                                                                    </text>)
                                                                                                                                .OnHiding(@<text>function(){TelephonePopupOnHiding();}</text>))

        </div>
    </div>
    @*Javascript Events*@

<script type="text/javascript">
