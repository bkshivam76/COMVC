@using DevExpress.XtraReports.UI;

@Html.DevExpress().DocumentViewer(
            settings =>
            {
                settings.Name = "TelephoneReportViewer";
                settings.AutoHeight = true;
                settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
                settings.Report = (XtraReport)Session["TelephoneReport"];
                settings.CallbackRouteValues = new { Controller = "Telephone", Action = "ReportViewerPartial", isFromReportViewer = true };
                settings.ExportRouteValues = new { Controller = "Telephone", Action = "ReportViewerExportTo" };
                settings.ControlStyle.CssClass = "DevexpressComponents";

            }).GetHtml()