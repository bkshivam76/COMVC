@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("LocationList_Datagrid_VPW")    
    .Columns(columns =>
    {
        columns.Add().DataField("Location_Name").Caption("Location Name");
        columns.Add().DataField("Matched_Type").Caption("Matched Type");
        columns.Add().DataField("Matched_Name").Caption("Matched Name");
        columns.Add().DataField("Matched_Instt").Caption("Matched Instt");
        columns.Add().DataField("Final_Amount").Caption("Final Amount");
        columns.Add().DataField("AL_ID").Caption("Final Amount").Visible(false);
        columns.Add().DataField("REC_EDIT_ON").Caption("Edit on").Visible(false);
        
    })   
    .Selection(s => s.Mode(SelectionMode.Single)) 
    .OnContentReady("SingleLocationFunction_VPW")
    .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}")

)
