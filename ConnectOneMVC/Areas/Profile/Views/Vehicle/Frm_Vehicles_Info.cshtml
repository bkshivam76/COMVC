    <script>
    var VehiclesInfo_IsDetailRowExpanded = false;
    var VehiclesInfo_NestedRecord_FocusedRowIndex = -1;
    var VehiclesInfo_NestedGrid_AccessID;
    var VehiclesInfo_AtachmentID;
    var VehiclesInfo_FileName;
    var VehiclesInfo_ParamMandatory;
    var VehiclesInfo_FromDateLabel;
    var VehiclesInfo_ToDateLabel;
    var VehiclesInfo_DescriptionLabel;
    var VehiclesInfo_Doc_ID;
    var VehiclesInfo_Doc_Category;
    var VehiclesInfo_MasterRowRecID;
    var VehiclesInfo_MasterRowMID;
    var VehiclesInfo_NestedRowMapID;
    var VehiclesInfo_reason;
    var VehiclesInfo_Attachment_RecStatus;
    var VehiclesInfo_NestedRowReasonID;
    var VehiclesInfo_NestedRowKeyValue;

    function On_VehiclesProfile_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@Help_Attachment_AddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (VehiclesInfo_ParamMandatory == 1)
            {
                AddAttachment(VehiclesInfo_MasterRowRecID, "Profile_Vehicles", VehiclesInfo_Doc_ID, VehiclesInfo_Doc_Category, VehiclesInfo_ParamMandatory, VehiclesInfo_FromDateLabel, VehiclesInfo_ToDateLabel, VehiclesInfo_DescriptionLabel, "VehiclesProfileAttachment", null, "VehiclesListGrid", VehiclesInfo_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(VehiclesInfo_MasterRowRecID, "Profile_Vehicles", VehiclesInfo_Doc_ID, "VehiclesProfileAttachment", "VehiclesListGrid", VehiclesInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (VehiclesInfo_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(VehiclesInfo_MasterRowRecID, "Profile_Vehicles", VehiclesInfo_AtachmentID, VehiclesInfo_ParamMandatory, VehiclesInfo_FromDateLabel, VehiclesInfo_ToDateLabel, VehiclesInfo_DescriptionLabel, "VehiclesProfileAttachment", null, "VehiclesListGrid", VehiclesInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(VehiclesInfo_MasterRowRecID, "Profile_Vehicles", VehiclesInfo_AtachmentID, VehiclesInfo_ParamMandatory, VehiclesInfo_FromDateLabel, VehiclesInfo_ToDateLabel, VehiclesInfo_DescriptionLabel, null, "VehiclesListGrid", VehiclesInfo_NestedGrid_AccessID, VehiclesInfo_Attachment_RecStatus);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@Help_Attachment_ViewRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            ViewDocument(VehiclesInfo_AtachmentID, VehiclesInfo_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(VehiclesInfo_MasterRowRecID, "Profile_Vehicles", "Vehicles Information", "VehiclesListGrid", VehiclesInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Add_Reason")
        {
            if (VehiclesInfo_Doc_Category.toLowerCase() == "others")
            {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else
            {
                AttachmentAddReason(VehiclesInfo_MasterRowRecID, VehiclesInfo_NestedRowMapID, "Profile_Vehicles", "VehiclesListGrid", VehiclesInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(VehiclesInfo_MasterRowRecID, VehiclesInfo_NestedRowMapID, "Profile_Vehicles", "VehiclesListGrid", VehiclesInfo_NestedGrid_AccessID, VehiclesInfo_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(VehiclesInfo_MasterRowRecID, VehiclesInfo_NestedRowMapID, "VehiclesListGrid", VehiclesInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
        else if (e.actionName == "AuditAction")
        {
            VehiclesPrf_FAB.SetActionContext("AuditActionContext", true);
        }
        else if (e.actionName == "BackAudit")
        {
            if (VehiclesInfo_Nested_Doc_Status == "")
            {
                VehiclesPrf_FAB.SetActionContext("AutoItemContext", true);
            }
            if (VehiclesInfo_Nested_Doc_Status == "NO")
            {
                VehiclesPrf_FAB.SetActionContext("EditItemContext", true);
            }
            if (VehiclesInfo_Nested_Doc_Status == "YES")
            {
                VehiclesPrf_FAB.SetActionContext("actionItemContext", true);
            }
        }
        else if (e.actionName == "Accept")
        {
            VehiclesInfo_AcceptwithoutRemarks();
        }
        else if (e.actionName == "Reject")
        {
            VehiclesInfo_AcceptRejectVoucher("Reject");
        }
        else if (e.actionName == "AcceptWithRemarks")
        {
            VehiclesInfo_AcceptRejectVoucher("Accept");
        }
        else if (e.actionName == "AcceptDoc") {

            OnVehiclesInfo_AcceptDoc();
        }
        else if (e.actionName == "RejectDoc") {

            OnVehiclesInfo_RejectDoc();
        }
    }
    function OnVehiclesInfo_RejectDoc() {
        if (VehiclesInfo_AtachmentID == null || VehiclesInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        RejectAttachment(VehiclesInfo_AtachmentID, "VehiclesListGrid", VehiclesInfo_NestedGrid_AccessID);
    }
    function OnVehiclesInfo_AcceptDoc() {
        if (VehiclesInfo_AtachmentID == null || VehiclesInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        AcceptAttachment(VehiclesInfo_AtachmentID, "VehiclesListGrid", VehiclesInfo_NestedGrid_AccessID);
    }

    function VehiclesInfo_AcceptwithoutRemarks()
    {
        var Recid;
        if (VehiclesInfo_IsDetailRowExpanded == true || Vehicle_IsVouchingMode == true)
        {
            if (VehiclesInfo_MasterRowRecID == null || VehiclesInfo_MasterRowRecID == "")
            {
                Recid = VehiclesID;
            }
            else
            {
                Recid = VehiclesInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = VehiclesID;
        }
        Entry_AcceptwithoutRemarks(Recid, "Profile_Vehicles", "VehiclesListGrid", VehiclesInfo_AtachmentID, VehiclesInfo_NestedRowReasonID, VehiclesInfo_NestedRowKeyValue);
    }
    function VehiclesInfo_AcceptRejectVoucher(_actionMethod)
    {
        var Recid;
        if (VehiclesInfo_IsDetailRowExpanded == true || Vehicle_IsVouchingMode == true)
        {
            if (VehiclesInfo_MasterRowRecID == null || VehiclesInfo_MasterRowRecID == "")
            {
                Recid = VehiclesID;
            }
            else
            {
                Recid = VehiclesInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = VehiclesID;
        }
        Entry_AcceptReject(_actionMethod, Recid, "Profile_Vehicles", "VehiclesListGrid", VehiclesInfo_AtachmentID, VehiclesInfo_NestedRowReasonID, VehiclesInfo_NestedRowKeyValue);
    }
    function OnVehiclesListGridNestedFocusedRowChange(s, e)
    {
        if (VehiclesInfo_IsDetailRowExpanded == true || Vehicle_IsVouchingMode == true)
        {
            VehiclesInfo_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
            if (VehiclesInfo_NestedRecord_FocusedRowIndex >= 0)
            {
                ShowLoader();
                VehiclesInfo_NestedGrid_AccessID = s.uniqueID;
                s.GetRowValues(s.GetFocusedRowIndex(), 'Doc_Status;Params_Mandatory;LABEL_FROM_DATE;LABEL_TO_DATE;LABEL_DESCRIPTION;Document_Category;Document_ID;ATTACH_ID;TxnID;TxnMID;MAP_ID;Reason;ATTACH_FILE_NAME;Attachment_Action_Status;UniqueID;ReasonID', OnVehiclesInfo_GetGridRowValues);
            }
            else
            {
                VehiclesPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }
    function OnVehiclesInfo_GetGridRowValues(values)
    {
        HideLoader();
        if (values[14] != null)
        {
            VehiclesPrf_FAB.SetVisible(true);
            VehiclesInfo_Nested_Doc_Status = values[0];
            if (Vehicle_IsVouchingMode == true)
            {
                VehiclesPrf_FAB.SetActionContext("AuditActionContext", true);
            }
            else
            {
                if (VehiclesInfo_Nested_Doc_Status == "")
                {
                    VehiclesPrf_FAB.SetActionContext("AutoItemContext", true);
                }
                else if (VehiclesInfo_Nested_Doc_Status == "NO")
                {
                    VehiclesPrf_FAB.SetActionContext("EditItemContext", true);
                }
                else if (VehiclesInfo_Nested_Doc_Status == "YES")
                {
                    VehiclesPrf_FAB.SetActionContext("actionItemContext", true);
                }
            }
            VehiclesInfo_ParamMandatory = values[1];
            VehiclesInfo_FromDateLabel = values[2];
            VehiclesInfo_ToDateLabel = values[3];
            VehiclesInfo_DescriptionLabel = values[4];
            VehiclesInfo_Doc_Category = values[5];
            VehiclesInfo_Doc_ID = values[6];
            VehiclesInfo_AtachmentID = values[7];
            IndexAttachmentID = VehiclesInfo_AtachmentID;
            VehiclesInfo_MasterRowRecID = values[8];
            VehiclesInfo_MasterRowMID = values[9];
            VehiclesInfo_NestedRowMapID = values[10];
            VehiclesInfo_reason = values[11];
            VehiclesInfo_FileName = values[12];
            VehiclesInfo_Attachment_RecStatus = values[13];
            VehiclesInfo_NestedRowKeyValue = values[14];
            if (Vehicle_IsVouchingMode == true)
            {
                if (VehiclesInfo_FileName != null && VehiclesInfo_FileName.length > 0)
                {
                    ViewDocument(VehiclesInfo_AtachmentID, VehiclesInfo_FileName, "VehiclesPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else
                {
                    CloseRightPane();
                    ClearRightPane();
                }
            }
        }
        VehiclesInfo_NestedRowReasonID = values[15];
        IndexAttachmentReasonID = VehiclesInfo_NestedRowReasonID;
    }
    function VehiclesGrid_Nested_BeginCallBack(s, e)
    {
        e.customArgs["ShowHorizontalBar"] = Vehicles_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = Vehicle_IsVouchingMode;
        e.customArgs["command"] = e.command;
    }
    function VehiclesGrid_DetailRowExpanding(s, e)
    {
        VehiclesInfo_IsDetailRowExpanded = true;
        s.SetFocusedRowIndex(e.visibleIndex);
        var pane = Mainspliter.GetPaneByName('RightPane');
        if (Vehicle_IsVouchingMode == true)
        {
            pane.Expand();
        }
        else
        {
            pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
        }
    }
    function VehiclesGrid_DetailRowCollapsing(s, e)
    {
        VehiclesInfo_IsDetailRowExpanded = false;
        s.SetFocusedRowIndex(e.visibleIndex);
        if (Vehicle_IsVouchingMode == true)
        {
            if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false)
            {
                CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
        else
        {
            VehiclesPrf_FAB.SetVisible(false);
        }
    }
    </script>
