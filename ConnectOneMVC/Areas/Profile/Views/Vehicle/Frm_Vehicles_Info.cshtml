            data:
            {
                ActionMethod: "Unlocked",
                xID: VehiclesID,
                MultiUserConfirmation: _MultiUserConfirmation,
            },
            cache: false,
            success: function (data) {                
                if (data.jsonParam.isconfirm == true) {
                    var confirmbox = CreateCustomConfirmDialog(data.jsonParam.title, data.jsonParam.message, false);
                    confirmbox.done(function (confirmboxResult) {
                        if (confirmboxResult) {
                            onVehiclesUnlockClick(true);
                        }
                        else {
                            RefreshGridView("VehiclesListGrid");
                        }
                    });
                }
                else {
                    var alertBoxDone = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title)
                    alertBoxDone.done(function (alertBoxResult) {
                        if (data.jsonParam.refreshgrid) {
                            RefreshGridView("VehiclesListGrid");
                        }
                    });
                }
            }
        });
    }
    function OnNewAuditClick() {
        if (Vehicle_AddHelp_ActionItemsRight == "False") {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        if (VehiclesID == null || VehiclesID == "undefined") {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        //Details: The below if block is written because the VehiclesID takes time to fill up & if user clicks the row before that.
        //if (VehiclesID == "")//pritam: commented it because handled it through  VehiclesID= s.GetRowKey(s.GetFocusedRowIndex());
        //{
        //    DevExpress.ui.dialog.alert('Please Select the row again', 'Alert ');
        //    return;
        //}
        $.ajax({
            type: 'GET',
            url: "/Profile/Vehicle/DataNavigation",
            data:
            {
                ActionMethod: "AddRemarks",
                xID: VehiclesID,
            },
            cache: false,
            success: function (data) {
                if (data.jsonParam.result == true) {
                    OpenPopup("VPW_ActionItem_Popup", "New ~ Action", "/Help/ActionItems/Frm_Action_Items_Window/" + "?" + encodeURI("ActionMethod=New" + "&RefScreen=" + "Profile_Vehicles" + "&RefTable=" + "VEHICLES_INFO" + "&RefRecID=" + VehiclesID + "&PopupID=" + "VPW_ActionItem_Popup" + "&GridToBeRefreshed=" + "VehiclesListGrid"), "auto", 1000, false, false);
                }
                else {
                    DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title)
                }
            }
        });
    }
