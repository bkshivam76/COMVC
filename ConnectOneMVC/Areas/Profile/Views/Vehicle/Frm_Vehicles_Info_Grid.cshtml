@using System.Text.RegularExpressions;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool Vehicle_AddRight = (bool)ViewData["Vehicle_AddRight"];
    bool Vehicle_UpdateRight = (bool)ViewData["Vehicle_UpdateRight"];
    bool Vehicle_ViewRight = (bool)ViewData["Vehicle_ViewRight"];
    bool Vehicle_DeleteRight = (bool)ViewData["Vehicle_DeleteRight"];
    bool Vehicle_ExportRight = (bool)ViewData["Vehicle_ExportRight"];
    bool Vehicle_AddHelp_ActionItemsRight = (bool)ViewData["Vehicle_AddHelp_ActionItemsRight"];
    bool Vehicle_ListHelp_ActionItemsRight = (bool)ViewData["Vehicle_ListHelp_ActionItemsRight"];
    bool Vehicle_LockUnlockRight = (bool)ViewData["Vehicle_LockUnlockRight"];
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;
    bool Manage_Remarks = (bool)ViewBag.Manage_Remarks;
    bool Special_Groupings = (bool)ViewBag.Special_Groupings;
    string ViewMode = ViewBag.ViewMode == null ? "Default" : (string)ViewBag.ViewMode;
    string UserType = ((string)ViewBag.UserType).ToUpper();
    List<string> ColumnTobeHidden = new List<string>();
    List<string> ColumnTobeShown = new List<string>();
    string ColumnToBeShowIndex = ViewBag.ColumnToBeShownIndex == null ? "" : (string)ViewBag.ColumnToBeShownIndex;
    string ColumnToBeHideIndex = ViewBag.ColumnToBeHidddenIndex == null ? "" : (string)ViewBag.ColumnToBeHidddenIndex;
    if (ColumnToBeHideIndex.Length > 0)
    {
        ColumnTobeHidden = ColumnToBeHideIndex.Split(',').ToList();
    }
    if (ColumnToBeShowIndex.Length > 0)
    {
        ColumnTobeShown = ColumnToBeShowIndex.Split(',').ToList();
    }
}
@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "VehiclesListGrid";
        settings.CallbackRouteValues = new
        {
            Controller = "Vehicle",
            Action = "Frm_Vehicles_Info_Grid",
            FilterVisible = false,
            SearchVisible = false,
            ShowGroupedColumns = true,
            SessionGUID = SessionGUID
        };
        settings.EnableTheming = true;
        settings.Theme = "Aqua";
        settings.Styles.FocusedRow.BackColor = System.Drawing.Color.FromArgb(0, 114, 198);
        settings.Styles.FocusedRow.ForeColor = System.Drawing.Color.White;
        settings.Settings.VerticalScrollBarMode = ScrollBarMode.Auto;
