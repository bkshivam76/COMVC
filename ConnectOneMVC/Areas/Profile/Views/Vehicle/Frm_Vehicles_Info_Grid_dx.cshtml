@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool SpecialGroupings = (bool)ViewBag.Special_Groupings;
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;
    string UserType = ((string)ViewBag.UserType).ToUpper();
    int ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;
}

@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar)
    .ID("VehiclesListGrid").DataSource(d => d.Mvc().Controller("Vehicle").LoadAction("Frm_Vehicles_Info_Grid_dx").LoadMode(DataSourceLoadMode.Raw).Key("ID"))
    .Columns(columns =>
    {
        columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);
        columns.Add().DataField("iIcon").Name("iIcon").Caption("").CellTemplate(new JS("VehicleListGrid_dx_iIconTemplate")).Width(30).HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource")).RenderAsync(true);
        columns.Add().DataField("VehiclesListGrid_Compact_Column").Name("VehiclesListGrid_Compact_Column").Caption("").Visible(false).CellTemplate(new JS("VehicleListGrid_dx_Compact_Column_Template")).CalculateCellValue("VehicleListGrid_dx_Compact_Column_CellValue").Width("100%").RenderAsync(true).ShowInColumnChooser(false);
        if (SpecialGroupings == true)
        {
            columns.Add().DataField("ITEM_NAME").Caption("Item Name").MinWidth(30).Width(50).GroupIndex(2).GroupCellTemplate(new JS("VehicleListGrid_dx_GroupCell_Template"));
            columns.Add().DataField("Entry_Type").Caption("Entry Type").GroupIndex(0).GroupCellTemplate(new JS("VehicleListGrid_dx_GroupCell_Template"));

        }
        else
        {
            columns.Add().DataField("ITEM_NAME").Caption("Item Name").MinWidth(30).Width(50).GroupIndex(0).GroupCellTemplate(new JS("VehicleListGrid_dx_GroupCell_Template"));
            columns.Add().DataField("Entry_Type").Caption("Entry Type");
        }
        columns.Add().DataField("MAKE").Caption("Make").MinWidth(30).Width(60);
        columns.Add().DataField("Model").Caption("Model").MinWidth(30).Width(110);
        columns.Add().DataField("VI_REG_NO").Caption("Registration No.").MinWidth(30).Width(115);
        columns.Add().DataField("Date_of_First_Registration").Caption("Registration Date").MinWidth(30).Width(110).DataType(GridColumnDataType.Date).Format("dd/MM/yyyy");
        columns.Add().DataField("Opening_Value").Caption("Opening Value").MinWidth(30).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"))
                        .Visible(UserType == "SUPERUSER" || UserType == "AUDITOR").ShowInColumnChooser(UserType == "SUPERUSER" || UserType == "AUDITOR").Width(90);
        columns.Add().DataField("Curr_Value").Caption("Curr Value").MinWidth(30).Visible(UserType == "SUPERUSER" || UserType == "AUDITOR").ShowInColumnChooser(UserType == "SUPERUSER" || UserType == "AUDITOR").Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}")).Width(90);
        columns.Add().DataField("Ownership").Caption("Ownership").MinWidth(30).Width(90);
        columns.Add().DataField("Special_Ref").Caption("Reference").MinWidth(30).Width(100);
        columns.Add().DataField("VI_DOC_RC_BOOK").Caption("R.C Book").MinWidth(30).Width(75);
        columns.Add().DataField("Affidavit").Caption("Affidavit").MinWidth(30).Width(75);
        columns.Add().DataField("Will").Caption("Will").MinWidth(30).Width(75);
        columns.Add().DataField("Transfer_Lettter").Caption("Lettter").MinWidth(30).Width(75);
        columns.Add().DataField("Free_Use_Letter").Caption("Free Use Letter").MinWidth(30).Width(75);
        columns.Add().DataField("Other_Documents").Caption("Other Documents").MinWidth(30).Width(75);
        columns.Add().DataField("Insurance_Company").Caption("Insurance Company").MinWidth(30).Width(75);
        columns.Add().DataField("VI_INS_POLICY_NO").Caption("Policy No.").MinWidth(30).Width(100);
        columns.Add().DataField("Expiry_Date").Caption("Expiry Date").MinWidth(30).Width(100).DataType(GridColumnDataType.Date).Format("dd/MM/yyyy");
        columns.Add().DataField("VI_OTHER_DETAIL").Caption("Other Detail").MinWidth(30).Width(100);
        columns.Add().DataField("AL_LOC_Name").Caption("Location").MinWidth(30).Width(85);
        columns.Add().DataField("Sale_Status").Caption("Sale Status").MinWidth(30).Width(100);
        columns.Add().DataField("Entry_Status").Caption("Entry Status").Visible(false);
        columns.Add().DataField("Action_By").Caption("Action By").MinWidth(30).Visible(false);
        columns.Add().DataField("Action_Date").Caption("Action Date").MinWidth(30).Visible(false).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss");
        if (SpecialGroupings)
            columns.Add().DataField("Action_Status").Caption("Action Status").GroupIndex(1).GroupCellTemplate(new JS("VehicleListGrid_dx_GroupCell_Template"));
        else
            columns.Add().DataField("Action_Status").Caption("Action Status").MinWidth(30).Visible(false);
        columns.Add().DataField("Add_By").Caption("Add By").MinWidth(30).Visible(false);
        columns.Add().DataField("Add_Date").Caption("Add Date").MinWidth(30).Visible(false).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss");
        columns.Add().DataField("Crossed_Time_Limit").Caption("Crossed Time Limit").MinWidth(30).Visible(false);
        columns.Add().DataField("Edit_By").Caption("Edit By").MinWidth(30).Visible(false);
        columns.Add().DataField("Edit_Date").Caption("Edit Date").MinWidth(30).Visible(false).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss");
        columns.Add().DataField("ID").Caption("ID").MinWidth(30).Visible(false);
        columns.Add().DataField("INSURANCE_ID").Caption("INSURANCE ID").MinWidth(30).Visible(false);
        columns.Add().DataField("Open_Actions").Caption("Open Actions").MinWidth(30).Visible(false);
        columns.Add().DataField("Remark_Count").Caption("Remark Count").Visible(false).MinWidth(30);
        columns.Add().DataField("Remark_Status").Caption("Remark Status").Visible(false).MinWidth(30);
        columns.Add().DataField("Remarks").Caption("Remarks").Visible(false).MinWidth(30);
        columns.Add().DataField("TR_ID").Caption("Tr. ID").Visible(false).MinWidth(30);
        columns.Add().DataField("YEAR_ID").Caption("Year ID").Visible(false).MinWidth(30);
        columns.Add().DataField("REJECTED_COUNT").Caption("iREJECTED_COUNT").Visible(false).MinWidth(30);
        columns.Add().DataField("RESPONDED_COUNT").Caption("iRESPONDED_COUNT").Visible(false).MinWidth(30);
        columns.Add().DataField("COMPLETE_ATTACH_COUNT").Caption("iCOMPLETE_ATTACH_COUNT").Visible(false).MinWidth(30);
        columns.Add().DataField("REQ_ATTACH_COUNT").Caption("iREQ_ATTACH_COUNT").Visible(false).MinWidth(30);
        columns.Add().DataField("OTHER_ATTACH_CNT").Visible(false);
        columns.Add().DataField("ALL_ATTACH_CNT").Visible(false);
    })
    //.Summary(s =>
    //{
    //    s.GroupItems(item => item.Add().Name("MAKE_MAKE_count").SummaryType(SummaryType.Count).Column("MAKE").ShowInGroupFooter(true).DisplayFormat("Total: {0}"));
    //    s.RecalculateWhileEditing(true);
    //})
    .MasterDetail(md =>
    {
        md.AutoExpandAll(false);
        md.Enabled(!VouchingMode);
        md.Template(new JS("VehicleListGrid_dx_DetailTemplate"));
    })
    .OnInitialized("VehicleListGrid_dx_OnInitialized")
         .OnCellPrepared("VehicleListGrid_dx_OnCellPrepared")
         .OnRowPrepared("VehicleListGrid_dx_OnRowPrepared")
         .OnContentReady("VehicleListGrid_dx_OnContentReady")
         .OnCellDblClick("VehicleListGrid_dx_OnCellDblClick")
         .OnSelectionChanged("VehicleListGrid_dx_OnSelectionChanged")
         //.OnFocusedRowChanged("VehicleListGrid_dx_OnFocusedRowChanged")
         .OnRowExpanding("VehicleListGrid_dx_OnRowExpanding")
         .OnRowCollapsing("VehicleListGrid_dx_OnRowCollapsing")
         .OnContextMenuPreparing("VehicleListGrid_dx_OnContextMenuPreparing")
//.OnEditorPreparing("VehicleListGrid_dx_OnEditorPreparing")
)