    function VehicleListGrid_dx_OnCellPrepared(e) {

        if (e.rowType == "data") {
            if (Vehicle_IsVouchingMode == true) {
                if (e.column.dataField === "iIcon") {
                    $(e.cellElement).attr("onmouseover", "OnGridRowMouseHoverIn(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.key + "')");
                    $(e.cellElement).attr("onmouseout", "OnGridRowMouseHoverOut(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.key + "')");
                }
            }
            $(e.cellElement).attr("id", e.element[0].id + "_Cell_" + e.key + "|" + e.column.dataField);
        }
    }
    function VehicleListGrid_dx_OnRowPrepared(e) {

        if (e.rowType == "data") {
            var GridName = e.element[0].id;
            $(e.rowElement).addClass(GridName + "_DataRow_" + e.key)
            if (e.data.Remark_Status != null && (e.data.Remark_Status == "OPEN" || e.data.Remark_Status == "REOPENED")) {
                $(e.rowElement).css("background-color", "gold");
            }
            if (e.data.Remark_Status == null && e.data.Remarks != null && e.data.Remarks == true && e.data.Crossed_Time_Limit != null && e.data.Crossed_Time_Limit == 0) {
                $(e.rowElement).css("background-color", "lightgreen");
            }
            if (e.data.Crossed_Time_Limit != null && e.data.Crossed_Time_Limit > 0) {
                $(e.rowElement).css("background-color", "mistyrose");
            }
            if (e.data.Action_Status == "INCOMPLETE")
            {
                $(e.rowElement).css("background-color", "LightSalmon");
            }
            DxGrid_CreatePreviewRow(e, Vehicle_IsVouchingMode, "Master")
        }
        else if (e.rowType == "detailAdaptive") {
            DxGrid_MovePreviewRowAfterAdaptiveRow(e)
        }
        //Need to check for Group color
    }
