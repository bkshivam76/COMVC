<div class="VehiclesProfile_ClearReferences">
    @using DevExtreme.AspNet.Mvc;

    @model IEnumerable<dynamic>
    @{
        ViewBag.Title = "Index";
        Layout = null;
        string UserType = (string)ViewBag.UserType;


        bool Help_Attachment_AddRight = (bool)ViewData["Help_Attachment_AddRight"];//attachment
        bool Help_Attachment_EditRight = (bool)ViewData["Help_Attachment_EditRight"];//attachment
        bool Help_Attachment_ViewRight = (bool)ViewData["Help_Attachment_ViewRight"];//attachment
        bool Help_Attachment_DeleteRight = (bool)ViewData["Help_Attachment_DeleteRight"];//attachment
        bool Vehicle_Auto_Vouching_Mode = (bool)ViewData["Vehicle_Auto_Vouching_Mode"];
        bool Manage_Remarks = (bool)ViewBag.Manage_Remarks;
        bool Special_Groupings = (bool)ViewBag.Special_Groupings;
    }
    <style>
        .VehicleProfile_CellCss {
            overflow-wrap: break-word;
        }
    </style>
    <div id="VehiclesProfile_ParentDiv">
        <div id="content" class="col-md-12 report_header_div_main">
            <div class="col-md-4 report_header_div">
                <label class="report_header_label">Vehicles Information</label>
            </div>
            <div class="report_button_div">
                @(Html.DevExtreme().Switch().ID("VehicleVouchingModeSwitch").SwitchedOnText("Vouching On").SwitchedOffText("Vouching Off").OnValueChanged("Vehicle_VouchingSwitch_ValueChange").Width(100).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
                @(Html.DevExtreme().Switch().ID("VehicleViewModeSwitch").SwitchedOnText("Compact").SwitchedOffText("Default").OnValueChanged("Vehicle_ViewSwitch_ValueChange").Width(70).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
                @(Html.DevExtreme().Button().ID("VehiclesModelUnlock").Text("Unlock").Icon("add").Visible(true).Disabled(false).OnClick(@<text> function () { onVehiclesUnlockClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("VehiclesModelLock").Text("Lock").Icon("add").Visible(true).Disabled(false).OnClick(@<text> function () { OnVehiclesLockClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("VehiclesModelInsurance").Text("Insurance").Icon("").Disabled(false).Visible(true).OnClick(@<text> function () { OnVehiclesInsuranceClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("VehiclesModelNew").Text("New").Icon("add").Visible(true).Disabled(false).OnClick(@<text> function () {VehicleProfile_OnNewClick();}</text>))
                @(Html.DevExtreme().Button().ID("VehiclesModelEdit").Text("Edit").Icon("edit").Visible(true).Disabled(false).OnClick(@<text> function () { OnVehiclesEditClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("VehiclesModelDelete").Text("Delete").Icon("trash").Visible(true).Disabled(false).OnClick(@<text> function () { OnVehiclesDeleteClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("VehiclesModelView").Text("View").Icon(IconID.ViewCustomers16x16devav).Icon("doc").Visible(true).Disabled(false).OnClick(@<text> function () { OnVehiclesViewClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("VehiclesToggleScrollBar").Text(ViewBag.ShowHorizontalBar == 1 ? "Default Data" : "Full Data").Width(ViewBag.ShowHorizontalBar == 1 ? 110 : 90).Icon("toolbox").OnClick(@<text> function () { VehicleschangeMode(); } </text>) )
                @(Html.DevExtreme().Button().ID("VehiclesModelListPreview").Text("Export").Icon("save").Width(100).OnClick(@<text> function () { OnVehiclesListPreviewClick(); } </text>) )
                @(Html.DevExtreme().Button().ID("VehiclesModelCLOSE").Text("Close").Icon("clear").OnClick(@<text> function (){closeProfile_Vehicles();} </text>) )
            </div>
        </div>
        <div class="col-md-12 no-padding">
            <form>
                <div id="VehiclesreloadPartialView" class="parent_table">
                    @Html.Partial("Frm_Vehicles_Info_Grid_dx", Model)
                </div>
            </form>
        </div>
        <div class="footer-MainBoxdiv" style="display:inline-block;width:100%">
            <div class="setFooterItem">
                <div class="footer-inner">
                    <div class="list_footer_left_margin">
                        <div class="footericon">
                            <i id="Vehicles_LockICON" style="color:red;font-size:35px;"></i>
                        </div>
                        @*<div class="footer-locktext">
                                <div id="VehiclesLbl_Status" style="font-size:23px" class="left_footertext_top"></div>
                            </div>*@
                        <div class="footer-locktext">
                            <div id="Vehicles_Lbl_ActionOn" class="left_footertext_top"></div>
                            <div id="Vehicles_Lbl_ActionBy" class="left_footertext_bottom"></div>
                        </div>
                    </div>
                    <div class="list_footer_left_margin">
                        <div class="footer-text">
                            <p id="VehiclesLbl_Create" class="right_footertext_top"></p>
                            <p id="VehiclesLbl_Modify" class="right_footertext_bottom"></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        @Html.Partial("AttachmentFAB", "VehiclesPrf_FAB,VehiclesProfile_grid_DIV,Type1,VehiclesProfile," + UserType) @*fab buttons*@
 
    </div>

