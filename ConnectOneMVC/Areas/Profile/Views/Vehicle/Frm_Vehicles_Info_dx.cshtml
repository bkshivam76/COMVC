        function VehicleListGrid_dx_OnCellDblClick(e)
        {
            if (e.rowType == "data") {
                if (Vehicle_IsVouchingMode == true && Vehicle_ViewMode == "Default") {
                    OnGridCellClick(e.event, e.cellElement[0], e.columnIndex, e.rowIndex, e.element[0].id, e.key, e.column.dataField)
                }
                else if (Vehicle_IsVouchingMode == false) {
                    if (e.rowType == "data")
                        OnVehiclesEditClick();
                }
            }
        }
    function VehicleListGrid_dx_OnSelectionChanged(e) {      
        var selectedRowKeys = e.selectedRowKeys;
        if (selectedRowKeys != null && selectedRowKeys.length > 0) {
            if (Vehicle_IsVouchingMode) {
                VehiclesPrf_FAB.SetVisible(true);
                VehiclesPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
            VehiclesListGrid_dx_SelectedRowData(e.selectedRowsData);
        }
        else {
            VehiclesID = null;
            Vehicles_UpdateFooterDetail(VehiclesID, Vehicles_ActionStatus, Vehicles_AddDate, Vehicles_AddBy, Vehicles_ActionDate, Vehicles_ActionBy, Vehicles_EditDate, Vehicles_EditBy);
        }
    }
    function VehiclesListGrid_dx_SelectedRowData(selectedData = null) {
        if (selectedData == null) {
            selectedData = VehiclesListGrid.getSelectedRowsData();
        }
        if (selectedData != null && selectedData.length > 0) {
            var values = selectedData[0]
            VehiclesID = values["ID"]
            Vehicles_EditDate = values["Edit_Date"];
            Vehicles_EditBy = values["Edit_By"];
            Vehicles_AddDate = values["Add_Date"];
            Vehicles_AddBy = values["Add_By"];
            Vehicles_ActionDate = values["Action_Date"];
            Vehicles_ActionBy = values["Action_By"];
            Vehicles_ActionStatus = values["Action_Status"];
            Vehicles_UpdateFooterDetail(VehiclesID, Vehicles_ActionStatus, Vehicles_AddDate, Vehicles_AddBy, Vehicles_ActionDate, Vehicles_ActionBy, Vehicles_EditDate, Vehicles_EditBy);
            if (Vehicle_IsVouchingMode == true) {
                OpenLeftPane();
                LeftPaneContent_Vehicles("VehiclesListGrid", VehiclesID, Vehicle_IsVouchingMode)
            }
        }
        else {
            VehiclesID = null;
        }
    }
    function VehicleListGrid_dx_OnRowExpanding(e) {

        if (Array.isArray(e.key) == false) //not group row
        {
            e.component.collapseRow(Expanded_Row_Key_Vehicle)
            e.component.selectRows(e.key);
            Expanded_Row_Key_Vehicle = e.key;
            VehiclesInfo_IsDetailRowExpanded = true;
            var DetailGridID = e.element[0].id + e.key;
            var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
            if (instance != void 0) {
                instance.state(null) // grid maintains its state after collapsing so resetting the state when expands again as per old grid
            }
            //e.component.collapseAll(-1);
        }
        else {
            e.component.option("CustomProp.groupRowExpanded", true);
        }
    }
    function VehicleListGrid_dx_OnRowCollapsing(e) {

        if (Array.isArray(e.key) == false) //not group row
        {
            var DetailGridID = e.element[0].id + e.key;
            sessionStorage.removeItem(DetailGridID + "_DetailGridState") //removing grid state from session storage on collapse

            VehiclesInfo_IsDetailRowExpanded = false;
            e.component.selectRows(e.key);
            if (Vehicle_IsVouchingMode == false) {
                VehiclesPrf_FAB.SetVisible(false);
            }
            var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
            if (instance != void 0) {
                instance.clearSelection();
            }
        }
        else {
            e.component.option("CustomProp.groupRowCollapsed", true);
        }
    }
    function VehicleListGrid_dx_OnContextMenuPreparing(e) {
        if (!e.items) e.items = [];
