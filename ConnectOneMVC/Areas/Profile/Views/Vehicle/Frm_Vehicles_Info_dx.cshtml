                            onItemClick: function () {
                                onVehiclesUnlockClick();
                            }
                        }
                    ]
                },
                {
                    text: "Creation Entry",
                        icon:"fa-solid fa-gears text-primary",
                        items: [
                            {
                                text: "Edit",
                                icon: "fa-solid fa-pen text-info",
                                visible:true,
                                onItemClick: function () {

                                    OnVehiclesCreationEntryEditClick();
                                }
                            },
                            {
                                text: "View",
                                icon:"fa-regular fa-eye",
                                  visible: true,
                                onItemClick: function () {
                                    OnVehiclesCreationEntryViewClick();
                                }
                            },
                            {
                                text: "Delete",
                                icon:"fa-solid fa-trash",
                                  visible:true,
                                onItemClick: function () {
                                    OnVehiclesCreationEntryDeleteClick();
                                }
                            }
                        ]
                    },
                {
                    text: "Close",
                    icon: "fa-solid fa-rectangle-xmark text-danger",
                    beginGroup: true,
                    onItemClick: function ()
                    {
                        closeProfile_Vehicles();
                    }
                },
                {
                    text: "Refresh",
                    icon: "fa-solid fa-arrow-rotate-right text-success",
                    beginGroup: true,
                    onItemClick: function ()
                    {
                        VehicleListGrid_dx_Refresh()
                    }
                }]
        }
        else if (e.target == "content" && e.row == void 0) {
            e.items = [
                {
                    text: "Close",
                    icon: "fa-solid fa-rectangle-xmark text-danger",
                    beginGroup: true,
                    onItemClick: function () {
                        closeProfile_Vehicles();
                    }
                },
                {
                    text: "Refresh",
                    icon: "fa-solid fa-arrow-rotate-right text-success",
                    beginGroup: true,
                    onItemClick: function () {
