    }

    function VehicleListGrid_dx_DetailTemplate(container, templateData) {
        var GridName = templateData.component.element()[0].id
        var RecID = templateData.data.ID;
        VehicleListGrid_dx_Detail(container, GridName, RecID, Vehicle_IsVouchingMode, Vehicles_ShowHorizontalBar);
    }
        function VehicleListGrid_dx_Detail(container, GridName, RecID, vouchingMode, AllColumns)
        {
            var url = "/Profile/Vehicle/Frm_Vehicles_Info_DetailGrid_dx?VouchingMode=" + vouchingMode + "&RecID=" + RecID
            var instance = DxGrid_AttachmentGrid_Create(container, GridName, RecID, vouchingMode, AllColumns, url)
            instance.option("onSelectionChanged", VehicleListGrid_dx_Detail_onSelectionChanged);    
    }
    function VehicleListGrid_dx_Detail_onSelectionChanged(e) {
        if (VehiclesInfo_IsDetailRowExpanded || Vehicle_IsVouchingMode) {
            if (e.selectedRowsData != null && e.selectedRowsData.length > 0) {
                VehiclesInfo_NestedGrid_AccessID = e.element[0].id;
                VehicleListGrid_dx_Detail_SelectedRowData(e.selectedRowsData)
            }
            else {
                VehiclesPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }
    function VehicleListGrid_dx_Detail_SelectedRowData(selectedData = null) {

        if (selectedData == null) {
            selectedData = $("#" + VehiclesInfo_NestedGrid_AccessID).dxDataGrid("getSeletedRowsData");
        }
        var values = selectedData[0];
        VehiclesInfo_NestedRowUniqueID = values["UniqueID"];
        if (values["UniqueID"] != null) {
            VehiclesPrf_FAB.SetVisible(true);
            VehiclesInfo_Nested_Doc_Status = values["Doc_Status"];

            if (Vehicle_IsVouchingMode == true) {
                VehiclesPrf_FAB.SetActionContext("AuditActionContext", true);
            }
            else {
                if (VehiclesInfo_Nested_Doc_Status == "") {
                    VehiclesPrf_FAB.SetActionContext("AutoItemContext", true);
                }
                else if (VehiclesInfo_Nested_Doc_Status == "NO") {
                    VehiclesPrf_FAB.SetActionContext("EditItemContext", true);
                }
                else if (VehiclesInfo_Nested_Doc_Status == "YES") {
                    VehiclesPrf_FAB.SetActionContext("actionItemContext", true);
                }
            }
            VehiclesInfo_ParamMandatory = values["Params_Mandatory"];
            VehiclesInfo_FromDateLabel = values["LABEL_FROM_DATE"];
            VehiclesInfo_ToDateLabel = values["LABEL_TO_DATE"];
            VehiclesInfo_DescriptionLabel = values["LABEL_DESCRIPTION"];
            VehiclesInfo_Doc_Category = values["Document_Category"];
            VehiclesInfo_Doc_ID = values["Document_ID"];
            VehiclesInfo_AtachmentID = values["ATTACH_ID"];
            IndexAttachmentID = VehiclesInfo_AtachmentID;
            VehiclesInfo_MasterRowRecID = values["TxnID"];
            VehiclesInfo_MasterRowMID = values["TxnMID"];
            VehiclesInfo_NestedRowMapID = values["MAP_ID"];
            VehiclesInfo_reason = values["Reason"];
            VehiclesInfo_FileName = values["ATTACH_FILE_NAME"];
            VehiclesInfo_Attachment_RecStatus = values["Attachment_Action_Status"];
            if (Vehicle_IsVouchingMode == true) {
                if (VehiclesInfo_FileName != null && VehiclesInfo_FileName.length > 0) {
                    ViewDocument(VehiclesInfo_AtachmentID, VehiclesInfo_FileName, "VehiclesPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else {
                    CloseRightPane();
                    ClearRightPane();
                }
            }
        }
        VehiclesInfo_NestedRowReasonID = values["ReasonID"];
        IndexAttachmentReasonID = VehiclesInfo_NestedRowReasonID;
    }
         
    function LeftPaneContent_Vehicles(GridName, RecID, vouchingMode, AllColumns = 0) {
        $("#LeftPane_Div_Content").html(null);
        $("#LeftPane_Div_Content").append("<div class='col-xs-12'><label>Documents Attached:</label><div class='AttachmentGrid'><form></form></div></div><div class='col-xs-12'><label>Additional Info:</label><div class='AdditionalInfoGrid'><form></form></div></div>")
        VehicleListGrid_dx_Detail($("#LeftPane_Div_Content .AttachmentGrid>form"), GridName, RecID, vouchingMode, AllColumns)
        setTimeout(function () {
            AdditionalInfoGrid_Vehicle_dx($("#LeftPane_Div_Content .AdditionalInfoGrid>form"), GridName, RecID, vouchingMode, AllColumns)
        })
    }
        function AdditionalInfoGrid_Vehicle_dx(container, GridName, RecID, vouchingMode, AllColumns)
        {
            var url = "/Profile/Vehicle/Frm_Vehicle_Info_AdditionalGridData_dx?VouchingMode=" + vouchingMode + "&RecID=" + RecID
            DxGrid_CreateAdditionalInfoGrid(container, GridName, RecID, vouchingMode, AllColumns, url)
        }
    function VehicleListGrid_dx_Refresh()
    {
        VehiclesListGrid.refresh().done(function () { ActionAfterDataGridRefresh_VehicleListGrid_dx() })
    }
    async function ActionAfterDataGridRefresh_VehicleListGrid_dx(ActionMethod = null)
    {    
        if (ActionMethod != null) {
            if (ActionMethod == "_New") {
                DevExpress.ui.dialog.confirm("Add More Entry...?", "New ~ Vehicle").done(function (confirmDialogResult) {
                    if (confirmDialogResult) {
                        VehicleProfile_OnNewClick();
                    }
                })
            }
            else if (ActionMethod == "_Edit") {
                //var selectedRowKeys = VehiclesListGrid.getSelectedRowKeys()
                //if (selectedRowKeys != null && selectedRowKeys.length > 0) {
                //    VehiclesListGrid.clearSelection()
                //    VehiclesListGrid.selectRows(selectedRowKeys)
                //}
                if ("@ViewData["Vehicle_LockUnlockRight"]" == "True") {
                    DevExpress.ui.dialog.confirm("Do you want to <font color=red>Lock</font> this Entry...?", "Confirmation...").done(function (confirmDialogResult) {
                        if (confirmDialogResult) {
                            OnVehiclesLockClick();
                        }
                    });
                }            
            }
        }
        else
        {
            var selectedRowKeys = VehiclesListGrid.getSelectedRowKeys()
            if (selectedRowKeys != null && selectedRowKeys.length > 0) {
                VehiclesListGrid.clearSelection()
                VehiclesListGrid.selectRows(selectedRowKeys)
            }
        }
    }   
    </script>
</div>