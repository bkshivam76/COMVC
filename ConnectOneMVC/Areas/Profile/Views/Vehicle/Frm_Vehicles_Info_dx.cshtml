    $(document).ready(function ()
    {
        if (Vehicle_AddRight == "False")
        {
            $("#VehiclesModelNew").hide();
        }
        if (Vehicle_UpdateRight == "False")
        {
            $("#VehiclesModelEdit").hide();
        }
        if (Vehicle_ViewRight == "False")
        {
            $("#VehiclesModelView").hide();
        }
        if (Vehicle_DeleteRight == "False")
        {
            $("#VehiclesModelDelete").hide();
        }
        if (Vehicle_ExportRight == "False")
        {
            $("#VehiclesModelListPreview").hide();
        }
        if (Vehicle_LockUnlockRight == "False")
        {
            $("#VehiclesModelUnlock").hide();
            $("#VehiclesModelLock").hide();
        }
        IsVehiclesSucessPopup = false;
        IsVehiclesViewPopup = false;
        HideUnreleasedFunctionality('VEHICALS_frm_Vehicles_Info');
        if (Vehicle_IsVouchingMode == true)
        {
            $(".VehiclesListGrid_PreviewRow").hide();
        }
        else
        {
            $(".VehiclesListGrid_PreviewRow").show();
        }
        GetSessionStorage("VehiclesListGrid");
        if (Vehicle_SetVouchingModeOn == true)
        {
            $("#VehicleViewModeSwitch").dxSwitch("instance").option("value", true);
        }
    });
    function Vehicle_ViewSwitch_ValueChange(e)
    {

        Vehicle_ViewMode = e.value == false ? "Default" : "Compact";
        if (Vehicle_SetVouchingModeOn == true)
        {
            $("#VehicleVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }
        VehiclesListGrid.beginUpdate();
        var columns = VehiclesListGrid.option("columns");
        if (Vehicle_ViewMode == "Compact") {
            VisibleColumns_VehiclesListGrid = [];
            for (var i = 0; i < columns.length; i++) {
                var name = columns[i].dataField;
                var ColumnVisible = VehiclesListGrid.columnOption(name, "visible");
                if (name == "VehiclesListGrid_Compact_Column") {
                    VehiclesListGrid.columnOption(name, "visible", true);
                } else if (ColumnVisible == true && name != "iIcon") {
                    VisibleColumns_VehiclesListGrid.push(name);
                    VehiclesListGrid.columnOption(name, "visible", false);
                }
            }
        } else {
            VehiclesListGrid.columnOption("VehiclesListGrid_Compact_Column", "visible", false);
            for (var i = 0; i < VisibleColumns_VehiclesListGrid.length; i++) {
                VehiclesListGrid.columnOption(VisibleColumns_VehiclesListGrid[i], "visible", true);
            }
        }
        VehiclesListGrid.repaint();
        VehiclesListGrid.endUpdate();
    }
    function Vehicle_VouchingSwitch_ValueChange(e)
    {

        Vehicle_IsVouchingMode = e.value;
        if (Vehicle_SetVouchingModeOn == true)
        {
            Vehicle_SetVouchingModeOn = false;
        }
        else
        {
            VehiclesPrf_FAB.SetVisible(false);
        }
        if (Vehicle_IsVouchingMode == true)
        {
            OpenRightPane();
            ClearLeftPane();
            OpenLeftPane();
        }
        else
        {
            VehiclesPrf_FAB.SetActionContext("AddAttachmentContext", false);
            CloseRightPane();
            ClearLeftPane();
            CloseLeftPane();
        }
        VehiclesListGrid.clearSelection();
        VehiclesListGrid.option("masterDetail.enabled", !Vehicle_IsVouchingMode)
        VehiclesListGrid.repaint();
    }  
    function VehicleschangeMode()
    {
        VehiclesListGrid.beginUpdate();
        if (Vehicles_ShowHorizontalBar == 0) {
            Vehicles_ShowHorizontalBar = 1;
            $("#VehiclesToggleScrollBar").find("span").text("Default Data");
            $("#VehiclesToggleScrollBar").width(110);
            VehiclesListGrid.option("columnHidingEnabled", false);
            VehiclesListGrid.option("allowColumnResizing", true)
        }
        else {
            Vehicles_ShowHorizontalBar = 0;
            $("#VehiclesToggleScrollBar").find("span").text("Full Data");
            $("#VehiclesToggleScrollBar").width(90);
            VehiclesListGrid.option("columnHidingEnabled", true);
            VehiclesListGrid.option("allowColumnResizing", false)
        }
        VehiclesListGrid.endUpdate();
    }

    function Vehicles_UpdateFooterDetail(VehiclesID, Vehicles_Action_Status, Vehicles_Add_Date, Vehicles_Add_By, Vehicles_Action_Date, Vehicles_Action_By, Vehicles_Edit_Date, Vehicles_Edit_By)
    {
                var Status = "";
                var Lbl_Status = "";
                var Lbl_StatusBy = "";
                var Pic_Status = "";
                var Lbl_Create = "";
                var Lbl_Modify = "";
                var Lbl_Status_Color = "";
                var StatusStr = "";
                var Lbl_ActionOn = "";
                var Lbl_ActionBy = "";
                if (VehiclesID != null) {
                    Vehicles_Action_Date = (moment(Vehicles_Action_Date).format("DD/MM/YYYY HH:mm:ss"))
                    Vehicles_Edit_Date = (moment(Vehicles_Edit_Date).format("DD/MM/YYYY HH:mm:ss"));
                    Vehicles_Add_Date = (moment(Vehicles_Add_Date).format("DD/MM/YYYY HH:mm:ss"));
                    Status = Vehicles_Action_Status;
                    StatusStr = Status == "Locked" ? "Locked" : Status == null ? null : "UnLocked";
                    if (Status && Status.toUpperCase() == "LOCKED") {
                        Lbl_Status = "Completed";
                        Lbl_Status_Color = "blue";
                        Pic_Status = "fa fa-lock";
                    }
                    else {
                        Pic_Status = "fa fa-unlock";
                        Lbl_Status = Status;
                        if (Status && Status.toUpperCase() == "COMPLETED") {
                            Lbl_Status_Color = "green";
                        }
                        else {
                            Lbl_Status_Color = "red";
                        }
                    }
                    if (Vehicles_Action_Date) {
                        Lbl_ActionOn = StatusStr + " On: " + Vehicles_Action_Date;
                        Lbl_ActionBy = StatusStr + " By: " + Vehicles_Action_By;
                    }
                    else {
                        Lbl_ActionOn = "";
                        Lbl_ActionBy = "";
                    }
                    if (Vehicles_Add_Date) {
                        Lbl_Create = "Add On: " + Vehicles_Add_Date + ", By: " + Vehicles_Add_By;
                    }
                    else {
                        Lbl_Create = "";
                    }
                    if (Vehicles_Edit_Date) {
                        Lbl_Modify = "Edit On: " + Vehicles_Edit_Date + ", By: " + Vehicles_Edit_By;
                    }
                    else {
                        Lbl_Modify = "";
                    }
                }
                $('#VehiclesLbl_Status').text(Lbl_Status);
                $('#Vehicles_Lbl_ActionOn').text(Lbl_ActionOn)
                $('#Vehicles_Lbl_ActionBy').text(Lbl_ActionBy);
                $('#VehiclesLbl_Create').text(Lbl_Create);
                $('#VehiclesLbl_Modify').text(Lbl_Modify);
                if (Lbl_Status_Color != "") {
                    $('#VehiclesLbl_Status').css('color', Lbl_Status_Color);
                }
                if (Pic_Status == "fa fa-lock") {
                    $('#Vehicles_LockICON').addClass(Pic_Status).removeClass("fa-unlock");
                }
                else if (Pic_Status == "fa fa-unlock") {
                    $('#Vehicles_LockICON').addClass(Pic_Status).removeClass("fa-lock");
                }
                else {
                    $('#Vehicles_LockICON').removeClass("fa");
                    $('#Vehicles_LockICON').removeClass("fa-lock");
                    $('#Vehicles_LockICON').removeClass("fa-unlock");
                }
            }

    function OnVehiclesInsuranceClick(_MultiUserConfirmation = false) {
        if (VehiclesID == null || VehiclesID == "" || VehiclesID == undefined) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        $.ajax({
            type: 'GET',
            url: "/Profile/Vehicle/DataNavigation",
            data: {
                ActionMethod: "CHANGE-INSURANCE",
                xID: VehiclesID,
                MultiUserConfirmation: _MultiUserConfirmation
            }, cache: false,
            success: function (data) {
                if (data.jsonParam.result == false) {
                    var alertResult = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                    alertResult.done(function () {
                        VehicleListGrid_dx_Refresh();
                    });
                }
                else {
                    OpenPopup("Change_Vehicle_Insurance", data.jsonParam.popup_title, data.jsonParam.popup_form_path + "?" + data.jsonParam.popup_querystring, "auto", 800, false, null);
                }


            }
        });
    }

