    <script>

        var VehicleWindowProfileGroup = "VehicleWindowProfileGroup";

    </script> @* Global Variables *@

    <script>
        var ActionMethod_VPW = "@Model.ActionMethod";
        $("#Txt_PolicyNo_VPW").on('input', function (evt)
        {       
            evt.target.value = evt.target.value.replace(/[^a-zA-Z0-9-/?]/gi, '');           
        });
        $("#Txt_RegNo_VPW").on('input', function (evt)
        {
            if ($("#RAD_RegPattern_VPW").dxRadioGroup('instance').option("value") == "OTHER")
            {         
                evt.target.value = evt.target.value.replace(/[^a-zA-Z0-9-/?]/gi, '');                
            }
        });
    $(document).ready( async function ()
    {
        ShowLoader_Ready();

        initDropdowns_VPW();

        BUT_CANCEL_Click_ForDocumentReady_VPW();

        TransformTextForDB("Vehicle_Window_Profile");

        await SetDefault_VPW();

        HideLoader_Ready();

    });
    function ControlValidation_VPW(ItemName="",xSpid="")
    {
        $("#Txt_RegDate_VPW").dxValidator({
            name: "Date of First Registration",
            validationGroup: VehicleWindowProfileGroup,
            validationRules: [
                {
                    type: "custom",
                    reevaluate: true,
                    validationCallback: function (options)
                    {
                        var result = true;
                        if ((ItemName.toUpperCase() != "YO BIKE" && ItemName.toUpperCase() != "CYCLE" && ItemName.toUpperCase() != "GOLF CART") && xSpid.length==0)
                        {
                            if (options.value == "" || options.value==null)
                            {
                                result = false;
                            }
                        }
                        return result;
                    },
                    message: "Please fill the Date of First Registration"
                }
            ]
        });
        $("#Look_InsList_VPW").dxValidator({
            name: "Insurance Company Name",
            validationGroup: VehicleWindowProfileGroup,
            validationRules: [
                {
                    type: "custom",
                    reevaluate: true,
                    validationCallback: function (options) {
                        var result = true;
                        if ((ItemName.toUpperCase() != "YO BIKE" && ItemName.toUpperCase() != "CYCLE" && ItemName.toUpperCase() != "GOLF CART")&& xSpid.length == 0) {
                            if (options.value == "" || options.value == null) {
                                result = false;
                            }
                        }
                        return result;
                    },
                    message: "Please select the Insurance Company Name"
                }
            ]
        });
        $("#Txt_PolicyNo_VPW").dxValidator({
            name: "Policy No.",
            validationGroup: VehicleWindowProfileGroup,
            validationRules: [
                {
                    type: "custom",
                    reevaluate: true,
                    validationCallback: function (options)
                    {
                        var result = true;
                        if ((ItemName.toUpperCase() != "YO BIKE" && ItemName.toUpperCase() != "CYCLE" && ItemName.toUpperCase() != "GOLF CART") && xSpid.length == 0)
                        {
                            if (options.value == "" || options.value == null)
                            {
                                result = false;
                            }
                        }
                        return result;
                    },
                    message: "Policy no. cannot be blank..."
                },
                {
                    type: "pattern",
                    pattern: /[a-zA-Z0-9\/?/-]/,
                    message: "Policy number can have digits from 0-9,Alphabets & forward slash, question mark & hypen as special characters"
                }
            ]
        });
        $("#Txt_E_Date_VPW").dxValidator({
            name: "Expiry Date",
            validationGroup: VehicleWindowProfileGroup,
            validationRules: [
                {
                    type: "custom",
                    reevaluate: true,
                    validationCallback: function (options) {
                        var result = true;
                        if ((ItemName.toUpperCase() != "YO BIKE" && ItemName.toUpperCase() != "CYCLE" && ItemName.toUpperCase() != "GOLF CART") && xSpid.length == 0) {
                            if (options.value == "" || options.value == null) {
                                result = false;
                            }
                        }
                        return result;
                    },
                    message: "Please fill Expiry Date of the Insurance Policy"
                }
            ]
        });
        $("#Txt_RegNo_VPW").dxValidator({
            name: "Registration No.",
            validationGroup: VehicleWindowProfileGroup,
            validationRules: [
                {
                    type: "custom",
                    reevaluate: true,
                    validationCallback: function (options) {
                        var result = true;
                        if ((ItemName.toUpperCase() != "YO BIKE" && ItemName.toUpperCase() != "CYCLE" && ItemName.toUpperCase() != "GOLF CART")) {
                            if (options.value == "" || options.value == null) {
                                result = false;
                            }
                        }
                        return result;
                    },
                    message: "Please fill the Registration No."
                }
            ]
        });
        $("#RAD_RegPattern_VPW").dxValidator({
            name: "Registration No. Pattern",
            validationGroup: VehicleWindowProfileGroup,
            validationRules: [
                {
                    type: "custom",
                    reevaluate: true,
                    validationCallback: function (options) {
                        var result = true;
                        if ((ItemName.toUpperCase() != "YO BIKE" && ItemName.toUpperCase() != "CYCLE" && ItemName.toUpperCase() != "GOLF CART")) {
                            if (options.value == "" || options.value == null) {
                                result = false;
                            }
                        }
                        return result;
                    },
                    message: "Please select the Registration No. Pattern"
                }
            ]
        });
    }
    </script> @* Document.Ready() *@

    <script>
    async function SetDefault_VPW()
    {
        ShowLoader_Ready();
        $("#TextEdit1_VPW").dxTextBox("option", "visible", false);
        $("#RAD_RegPattern_VPW").dxRadioGroup("option", "value", "NEW");
        $("#Cmd_Make_VPW").find("input").addClass("CleanTextForDB");
        $("#Cmd_Model_VPW").find("input").addClass("CleanTextForDB");
        await LookUp_GetLocList_VPW(true);
        if (ActionMethod_VPW == "_Edit" || ActionMethod_VPW == "_View" || ActionMethod_VPW == "_Delete")
        {
            if ("@Model.Chk_RC_Book_VPW" == "True") { RC_Book_VPW = true; } else { RC_Book_VPW = false; }
            if ("@Model.Chk_Affidavit_VPW" == "True") { Affidavit_VPW = true; } else { Affidavit_VPW = false; }
            if ("@Model.Chk_Will_VPW" == "True") { Will_VPW = true; } else { Will_VPW = false; }
            if ("@Model.Chk_Trf_Letter_VPW" == "True") { Trf_Letter_VPW = true; } else { Trf_Letter_VPW = false; }
            if ("@Model.Chk_FU_Letter_VPW" == "True") { FU_Letter_VPW = true; } else { FU_Letter_VPW = false; }
            if ("@Model.Chk_OtherDoc_VPW" == "True") { OtherDoc_VPW = true; } else { OtherDoc_VPW = false; }

            await Look_ItemList_EditValueChanged_VPW(null, true);
            if (TransformText("@Model.Cmd_Make_VPW").length > 0)
            {
                await AddCustomDatatoMake_VPW();
            }
            if (TransformText("@Model.Cmd_Model_VPW").length > 0)
            {
                AddCustomDatatoModel_VPW();
            }
