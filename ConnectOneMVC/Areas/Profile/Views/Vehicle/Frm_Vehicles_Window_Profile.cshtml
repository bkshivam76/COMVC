                    $("#Txt_RegDate_VPW").dxDateBox("option", "value", "");
                    $("#Txt_RegDate_VPW").dxDateBox("option", "readOnly", true);
                }
                else
                {
                    $("#lbl_Reg_No_VPW").addClass("text-red");
