        }
        await ItemName_Datagrid_VPW.selectRows(itemID);

        if (ItemName_Datagrid_VPW.getSelectedRowsData().length > 0)
        {
            var SelectedItemRow = ItemName_Datagrid_VPW.getSelectedRowsData()[0]
            try
            {
                $("#Look_ItemList_DisplayName_VPW").val(SelectedItemRow.Name); // Details: Hidden input element created for storing the dispaly value of the Item Name Dropdown
                if (SelectedItemRow.Name.toUpperCase() == "YO BIKE" || SelectedItemRow.Name.toUpperCase() == "CYCLE" || SelectedItemRow.Name.toUpperCase() == "GOLF CART")
                {
                    $("#lbl_Reg_No_VPW,#lbl_Txt_RegDate_VPW,#lbl_Look_InsList_VPW,#lbl_Txt_PolicyNo_VPW,#lbl_Txt_E_Date_VPW").removeClass("text-red");
