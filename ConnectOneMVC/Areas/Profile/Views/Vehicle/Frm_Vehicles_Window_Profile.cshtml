<script>
    async function BUT_Save_Click_VPW(e)
    {
        if (ActionMethod_VPW == "_Delete")
        {
            var confirm = await CreateCustomConfirmDialog("Delete ~ Vehicles", "", true).show();
            if (confirm == true)
            {

                SaveVehicle_VPW()
            }
            else
            {
                $("#BUT_SAVE_COM_VPW").dxButton("focus");
            }
        }
        else if (ActionMethod_VPW == "_New" || ActionMethod_VPW == "_Edit")
        {
            var result = e.validationGroup.validate();
            if (result.isValid)
            {
                SaveVehicle_VPW()
            }
            else
            {
                DevExpress.ui.dialog.alert("Please fill all the required fields", "!!! Validation Error !!!")
            }
        }
    }
    function SaveVehicle_VPW()
    {
        ShowLoader();
        $.ajax({
            type: "Post",
            data: $("#Vehicle_Window_Profile").serialize(),
            url: "/Profile/Vehicle/Frm_Vehicles_Window_Profile",
            cache: false,
            success: function (data)
            {
                HideLoader();               
                if (data.jsonParam.result == false)
                {
                    DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title).done(function (alertResult)
                    {                      
                        if (data.jsonParam.refreshgrid)
                        {
                            RefreshGridView("VehiclesListGrid", ActionAfterDataGridRefresh_VehicleListGrid_dx.bind(null, ActionMethod_VPW == "_New" ? "" : ActionMethod_VPW))
                        }
                        if (data.jsonParam.focusid)
                        {
                            var id = "#" + data.jsonParam.focusid;
                            setTimeout(function ()
                            {
                                $(id).find('input').focus();
                            }, Timeout100);
                        }
                        if (data.jsonParam.closeform == true) {
                            dontaskpopupcloseconfirmation = true;
                            $("#Dynamic_Content_popup").dxPopup("hide");
                        }
                    });
                }
                else if (data.jsonParam.result == true)
                {
                    DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title).done(function (alertResult)
                    {
                        if (typeof data.xid !== "undefined")
                        {
                            Select_xid_VPW = data.xid;
                        }
                        RefreshGridView("VehiclesListGrid",  ActionAfterDataGridRefresh_VehicleListGrid_dx.bind(null,ActionMethod_VPW) )
                        if (data.jsonParam.closeform == true)
                        {
                            dontaskpopupcloseconfirmation = true;
                            $("#Dynamic_Content_popup").dxPopup("hide");
                        }
                    });
                }
            }
        });
    }   
    function BUT_CANCEL_Click_VPW()
    {
        $("#Dynamic_Content_popup").dxPopup("hide");
    }
    function BUT_CANCEL_Click_ForDocumentReady_VPW()
    {
        sessionclearpath = "/Profile/Vehicle/SessionClear_VPWindow";
        if (ActionMethod_VPW == "_View")
        {
            dontaskpopupcloseconfirmation = true;
        }
        else
        {
            dontaskpopupcloseconfirmation = false;
        }
    };

</script> @* Button Click: Save & Cancel *@

