            @(Html.DevExtreme().Button().ID("WIPModelView").Text("View").Icon(IconID.ViewCustomers16x16devav).Icon("doc").Visible(true).Disabled(false).OnClick(@<text>function () {datanavigation("VIEW");}</text>))
            @(Html.DevExtreme().Button().ID("WIPModelToggleScrollBar").Text(ViewBag.ShowHorizontalBar == 1 ? "Default Data" : "Full Data").Width(ViewBag.ShowHorizontalBar == 1 ? 110 : 90).Icon("toolbox").OnClick(@<text>function () {WIPchangeMode();}</text>))
            @(Html.DevExtreme().Button().ID("WIPModelListPreview").Text("Export").Icon("save").Width(75).OnClick(@<text>function () {OnWIPListPreviewClick();}</text>))
            @(Html.DevExtreme().Button().ID("WIPModelCLOSE").Text("Close").Icon("clear").OnClick(@<text>function (){closeProfile_WIP();} </text>))
        </div>
