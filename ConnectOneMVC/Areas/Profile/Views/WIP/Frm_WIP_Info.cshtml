    <script type="text/javascript">
    function WIPGrid_BeginCallBack(s, e)
    {
        WIP_FocusedRowBeforeRefresh = s.GetFocusedRowIndex();
        e.customArgs["command"] = e.command;
        e.customArgs["ShowHorizontalBar"] = WIP_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = WIP_IsVouchingMode;
        e.customArgs["ViewMode"] = WIP_ViewMode;
        e.customArgs["ColumnToBeShownIndex"] = Wip_ColumnToBeShownIndex;
        e.customArgs["ColumnToBeHidddenIndex"] = Wip_ColumnToBeHidddenIndex;
    }

    function WIP_dblclickEdit(s, e)
    {
        //var key = s.GetRowKey(s.GetFocusedRowIndex());
        //WIPListGrid.GetValuesOnCustomCallback({ key: key }, WIPOnGetRowValues);
        //if (WIPID != null || WIPID == 'undefined' || WIPID == undefined)
        //    OnWIPEditClick();
    }

    function WIPOnInit(s, e)
    {
        WIPAdjustSize();
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt)
        {
            WIPAdjustSize();
        });
    }

    function OnGridWIPListGrid_EndCallback(s, e)
    {
        Wip_ColumnToBeShownIndex = s.cpColumnToBeShownIndex;
        Wip_ColumnToBeHidddenIndex = s.cpColumnToBeHidddenIndex;
        WIPGridLayout = s.cpClientLayout;
        $(".WIPListGrid_PreviewRow").hide();
        GetSessionStorage("WIPListGrid");
        if (e.command == "REFRESH" && WIP_IsVouchingMode == true)
        {
            s.SetFocusedRowIndex(-1);
            s.SetFocusedRowIndex(WIP_FocusedRowBeforeRefresh);
        }
        SendCustomArgs_FilterControl(s, e);
    }

    function WIPAdjustSize()
    {
        var height = (document.documentElement.clientHeight * 90) / 100;
        try { WIPListGrid.SetHeight(height); } catch (err) { }
    }

    function WIPchangeMode()
    {
        ShowLoader();
        if (WIP_ShowHorizontalBar == 0)
        {
            WIP_ShowHorizontalBar = 1;
            $("#WIPModelToggleScrollBar").find("span").text("Default Data");
            $("#WIPModelToggleScrollBar").width(110);
        }
        else
        {
            WIP_ShowHorizontalBar = 0;
            $("#WIPModelToggleScrollBar").find("span").text("Full Data");
            $("#WIPModelToggleScrollBar").width(90);
        }
        $.ajax(
        {
            url: '@Url.Action("Frm_WIP_Info_Grid", "WIP")',
            type: "GET",
            data: { ShowHorizontalBar: WIP_ShowHorizontalBar, VouchingMode: WIP_IsVouchingMode, ViewMode: WIP_ViewMode, ColumnToBeHidddenIndex: Wip_ColumnToBeHidddenIndex, ColumnToBeShownIndex: Wip_ColumnToBeShownIndex },
            success: function (res)
            {
                $("#WIPreloadPartialView").html(res);
                $(".WIPListGrid_PreviewRow").hide();
                GetSessionStorage("WIPListGrid");
            }
        });
        HideLoader();
    }

    function WIPOnGridFocusedRowChanged(s, e)
    {
        if (s.GetFocusedRowIndex() >= 0)
        {
            if (!s.IsGroupRow(s.GetFocusedRowIndex()))
            {
                if (WIP_IsVouchingMode)
                {
                    WIPPrf_FAB.SetVisible(true);
                    WIPPrf_FAB.SetActionContext("VouchingActionContext", true);
                }
                WIPID = s.GetRowKey(s.GetFocusedRowIndex());
                WIPListGrid.GetValuesOnCustomCallback({ key: WIPID }, WIPOnGetRowValues);
            }
            else
            {
                WIPID = null;
                WIP_UpdateFooterDetail(WIPID, WIP_ActionStatus, WIP_AddDate, WIP_AddBy, WIP_ActionDate, WIP_ActionBy, WIP_EditDate, WIP_EditBy);
            }
        }
        else
        {
            WIPID = null;
            WIP_UpdateFooterDetail(WIPID, WIP_ActionStatus, WIP_AddDate, WIP_AddBy, WIP_ActionDate, WIP_ActionBy, WIP_EditDate, WIP_EditBy);
        }
    }

    function WIPOnGetRowValues(WIPData)
    {
        debugger;
        var values = WIPData.split("![");
        WIPID = values[0];
        WIP_EditDate = values[1];
        WIP_AddDate = values[2];
        WIP_AddBy = values[3];
        WIP_EditBy = values[4];
        WIP_ActionStatus = values[5];
        WIP_ActionDate = values[6];
        WIP_ActionBy = values[7];
        Opening = values[8];
        LedgerID = values[9];
        LedgerName = values[10];
        Reference = values[11];
        OpeningDate = values[12];
        TR_ID = values[13];
        Entry_Type = values[14];
        WIP_OpenActions = values[15];
        WIP_YearID = values[16];
        WIP_UpdateFooterDetail(WIPID, WIP_ActionStatus, WIP_AddDate, WIP_AddBy, WIP_ActionDate, WIP_ActionBy, WIP_EditDate, WIP_EditBy);
        if (WIP_IsVouchingMode == true)
        {
            OpenLeftPane();
            LoadDocumentAndAdditionalInfoInLeftPane("Profile", "WIP", "LeftPaneContent", WIPID, WIP_IsVouchingMode, "");
        }
    }

    function WIP_UpdateFooterDetail(WIPID, WIP_Action_Status, WIP_Add_Date, WIP_Add_By, WIP_Action_Date, WIP_Action_By, WIP_Edit_Date, WIP_Edit_By)
    {
        WIP_Action_Date = WIP_Action_Date != "" && WIP_Action_Date != null ? WIP_Action_Date : WIP_Action_Date;
        WIP_Edit_Date = WIP_Edit_Date != "" && WIP_Edit_Date != null ? WIP_Edit_Date : WIP_Edit_Date;
        WIP_Add_Date = WIP_Add_Date != "" && WIP_Add_Date != null ? WIP_Add_Date : WIP_Add_Date;
        $.ajax(
        {
            type: 'GET',
            url: "/Profile/WIP/CreationDetail",
            data:
            {
                Xrow: WIPID, Action_Status: WIP_Action_Status, Add_Date: WIP_Add_Date, Add_By: WIP_Add_By,
                Action_Date: WIP_Action_Date, Action_By: WIP_Action_By, Edit_Date: WIP_Edit_Date, Edit_By: WIP_Edit_By
            },
            cache: false,
            success: function (WIPLbl_result)
            {
                $('#WIP_Lbl_ActionOn').text(WIPLbl_result.Lbl_StatusOn);
                $('#WIP_Lbl_ActionBy').text(WIPLbl_result.Lbl_StatusBy);
                $('#WIPLbl_Status').text(WIPLbl_result.Lbl_Status);
                $('#WIPLbl_Create').text(WIPLbl_result.Lbl_Create);
                $('#WIPLbl_Modify').text(WIPLbl_result.Lbl_Modify);
                if (WIPLbl_result.Lbl_Status_Color != "")
                {
                    $('#WIPLbl_Status').css('color', WIPLbl_result.Lbl_Status_Color);
                }
                if (WIPLbl_result.Pic_Status != "")
                {
                    $('#WIP_LockICON').css('class', WIPLbl_result.Pic_Status);
                }
            }
        });
    }

    function WIPContextMenuFunction(s, e)
    {
        if (e.item.name == 'New')
        {
            OnWIPNewClick();
        }
        if (e.item.name == 'Close')
        {
            closeProfile_WIP();
        }
        else if (e.item.name == 'Edit')
        {
            datanavigation("EDIT");
        }
        else if (e.item.name == 'Delete')
        {
            datanavigation("DELETE");
        }
        else if (e.item.name == 'View')
        {
            datanavigation("VIEW");
        }
        else if (e.item.name == 'ListPreview')
        {
            OnWIPListPreviewClick();
        }
        else if (e.item.name == 'TxnReport')
        {
            datanavigation("TxnReport");
        }
        else if (e.item.name == 'CEI_Edit')
        {
            WIP_EditPaymentVoucherClick();
        }
        else if (e.item.name == 'CEI_View')
        {
            WIP_ViewPaymentVoucherClick();
        }
        else if (e.item.name == 'CEI_Delete')
        {
            WIP_DeletePaymentVoucherClick();
        }
        else if (e.item.name == 'AAI_New')
        {
            datanavigation("Audit_Add");
        }
        else if (e.item.name == 'AAI_View')
        {
            datanavigation("Audit_View");
        }
        else if (e.item.name == 'Lock')
        {
            datanavigation("LOCK");
        }
        else if (e.item.name == 'UnLock')
        {
            datanavigation("UNLOCK");
        }
    }

    function OnWIPCellClick(event, cell, col, row)
    {
        if (UserType_WIPPrf == "AUDITOR" || UserType_WIPPrf == "SUPERUSER")
        {
            if (event.button == 0)
            {
                if (cell.style.backgroundColor.length > 0)
                {
                    cell.style.backgroundColor = "";
                }
                else
                {
                    cell.style.backgroundColor = 'skyblue';
                }
            }
        }
    }

    function WIP_VouchingSwitch_ValueChange(e)
    {
        WIP_IsVouchingMode = e.value;
        if (WIPInfo_SetVouchingModeOn == true) {
            WIPInfo_SetVouchingModeOn = false;
        }
        else {
            WIPPrf_FAB.SetVisible(false);
        }
        if (WIP_IsVouchingMode == true)
        {
            OpenRightPane();
            ClearLeftPane();
            OpenLeftPane();
        }
        else
        {
            WIPPrf_FAB.SetActionContext("AddAttachmentContext", false);
            CloseRightPane();
            ClearLeftPane();
            CloseLeftPane();
        }
        WIPListGrid_CollapseAllDetailRows();
    }

    function WIPListGrid_CollapseAllDetailRows()
    {
        if (typeof window !== 'undefined')
        {
            if (typeof window.WIPListGrid !== 'undefined')
            {
                if (typeof window.WIPListGrid.CollapseAllDetailRows !== 'undefined')
                {
                    if (typeof WIPListGrid.CollapseAllDetailRows == 'function')
                    {
                        WIPListGrid.SetFocusedRowIndex(-1);
                        WIPListGrid.CollapseAllDetailRows();
                    }
                    else
                    {
                        alert("CollapseAllDetailRows is not a function");
                    }
                }
                else
                {
                    ShowLoader();
                    setTimeout(function () {
                        WIPListGrid_CollapseAllDetailRows();
                        HideLoader();
                    }, Timeout100);
                }
            }
            else
            {
                alert('grid undefined')
            }
        }
        else
        {
            alert('window undefined')
        }
    }

    function WIP_ViewSwitch_ValueChange(e)
    {
        WIP_ViewMode = e.value == false ? "Default" : "Compact";
        if (WIPInfo_SetVouchingModeOn == true)
        {
            $("#WIPVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }
        else
        {
            WIPListGrid.CollapseAllDetailRows();
        }
    }
    </script>
    @*Grid Functions*@

    <script type="text/javascript">

        function GetSelectedFieldValuesCallback(values) {
            SelectedRows.BeginUpdate();
            try {
                SelectedRows.ClearItems();
                for (var i = 0; i < values.length; i++) {
                    SelectedRows.AddItem(values[i]);
                }
            }
            finally {
                SelectedRows.EndUpdate();
            }
            $("#count").html(gvRowSelection.GetSelectedRowCount());
        }

    </script>

    <script type="text/javascript">

    function datanavigation(Action)
    {
        if (WIPID == 'undefined' || WIPID == undefined || WIPID == "")
        {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        switch (Action)
        {
            case "UNLOCK":
                WIPOnUnlockClick();
                break;

            case "LOCK":
                WIPOnLockClick();
                break;

            case "EDIT":
                OnWIPEditClick();
                break;

            case "DELETE":
                OnWIPDeleteClick();
                break;

            case "VIEW":
                OnWIPViewClick();
                break;

            case "Audit_Add":
                WIP_AddAuditActions();
                break;

            case "Audit_View":
                WIP_ViewAuditActions();
                break;

            case "TxnReport":
                WIPOnTxnReportClick();
                break;
        }
    }

    function WIP_AddAuditActions()
    {
        if ("@WIP_ManageRemarks" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        $.ajax({
            type: 'GET',
            url: "/Profile/WIP/DataNavigation",
            data:
            {
                ActionMethod: "ADD REMARKS",
                ID: WIPID
            },
            cache: false,
            success: function (data)
            {
                if (data.jsonParam.result == true)
