@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool WIP_SpecialGrouping = (bool)ViewData["WIP_SpecialGrouping"];
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;
    int ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;
}
@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar)
                 .ID("WIPListGrid")
                 .DataSource(d => d.Mvc().Controller("WIP").LoadAction("Frm_WIP_Info_Grid_dx").LoadMode(DataSourceLoadMode.Raw).Key("ID"))
                 .Columns(columns =>
                 {
                     columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);
                     columns.Add().DataField("iIcon").Name("iIcon").Caption("").CellTemplate(new JS("WIPListGrid_dx_iIconTemplate")).Width(30)
                     .HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource")).RenderAsync(true);
                     columns.Add().DataField("WIPListGrid_dx_Compact_Column").Name("WIPListGrid_dx_Compact_Column").Caption("").Visible(false).CellTemplate(new JS("WIPListGrid_dx_Compact_Column_Template"))
                     .CalculateCellValue("WIPListGrid_dx_Compact_Column_CellValue").Width("100%").RenderAsync(true).ShowInColumnChooser(false);

                     if (WIP_SpecialGrouping == true)
                     {
                         columns.Add().DataField("WIP_Ledger").Caption("WIP Ledger").GroupIndex(2).GroupCellTemplate(new JS("WIPListGrid_dx_GroupCell_Template"));
                         columns.Add().DataField("Entry_Type").Caption("Entry Type").GroupIndex(0).GroupCellTemplate(new JS("WIPListGrid_dx_GroupCell_Template"));
                         columns.Add().DataField("Action_Status").Caption("Action Status").GroupIndex(1).GroupCellTemplate(new JS("WIPListGrid_dx_GroupCell_Template"));

                     }
                     else
                     {
                         columns.Add().DataField("WIP_Ledger").Caption("WIP Ledger").MinWidth(100);
                         columns.Add().DataField("Action_Status").Caption("Action Status").Visible(false);
                         columns.Add().DataField("Entry_Type").Caption("Entry Type");
                     }
                     columns.Add().DataField("Reference").SortOrder(SortOrder.Asc).MinWidth(100).Width(Request.Browser.IsMobileDevice?100:300);
                     columns.Add().DataField("Opening").Caption("Opening").Width(Request.Browser.IsMobileDevice ? 100 : 180)
                     .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("Addition").Caption("Addition")
                     .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("Deduction").Caption("Deduction")
                     .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("Closing").Caption("Closing")
                     .DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));

                     columns.Add().DataField("Special_Ref").Caption("Special Reference");
                     columns.Add().DataField("Action_Date").Caption("Action Date").Visible(false).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss");
                     columns.Add().DataField("Action_By").Caption("Action By").Visible(false);
                     columns.Add().DataField("TR_ID").Caption("TR_ID").Visible(false);
                     columns.Add().DataField("Add_By").Caption("Added By").Visible(false);
                     columns.Add().DataField("Add_Date").Caption("Added Date").Visible(false).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss");
                     columns.Add().DataField("Edit_By").Caption("Edited By").Visible(false);
                     columns.Add().DataField("Edit_Date").Caption("Edited Date").Visible(false).DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss");
                     columns.Add().DataField("ID").Caption("ID").Visible(false);
                     columns.Add().DataField("REJECTED_COUNT").Caption("iREJECTED_COUNT").Visible(false);
                     columns.Add().DataField("RESPONDED_COUNT").Caption("iRESPONDED_COUNT").Visible(false);
                     columns.Add().DataField("COMPLETE_ATTACH_COUNT").Caption("iCOMPLETE_ATTACH_COUNT").Visible(false);
                     columns.Add().DataField("REQ_ATTACH_COUNT").Caption("iREQ_ATTACH_COUNT").Visible(false);
                     columns.Add().DataField("OTHER_ATTACH_CNT").Caption("iOTHER_ATTACH_CNT").Visible(false);
                     columns.Add().DataField("ALL_ATTACH_CNT").Caption("ALL_ATTACH_CNT").Visible(false);
                     columns.Add().DataField("LED_ID").Caption("LED_ID").Visible(false);
                     columns.Add().DataField("AUDIT_TOTAL_COUNT").Caption("AUDIT_TOTAL_COUNT").Visible(false);
                     columns.Add().DataField("AUDIT_REJECTED_COUNT").Caption("AUDIT_REJECTED_COUNT").Visible(false);
                     columns.Add().DataField("AUDIT_ACCEPTED_WITH_REMARKS_COUNT").Caption("AUDIT_ACCEPTED_WITH_REMARKS_COUNT").Visible(false);
                     columns.Add().DataField("AUDIT_ACCEPTED_COUNT").Caption("AUDIT_ACCEPTED_COUNT").Visible(false);
                     columns.Add().DataField("AUDIT_PENDING_COUNT").Caption("AUDIT_PENDING_COUNT").Visible(false);
                     columns.Add().DataField("VOUCHING_TOTAL_COUNT").Caption("VOUCHING_TOTAL_COUNT").Visible(false);
                     columns.Add().DataField("VOUCHING_REJECTED_COUNT").Caption("VOUCHING_REJECTED_COUNT").Visible(false);
                     columns.Add().DataField("VOUCHING_ACCEPTED_WITH_REMARKS_COUNT").Caption("VOUCHING_ACCEPTED_WITH_REMARKS_COUNT").Visible(false);
                     columns.Add().DataField("VOUCHING_ACCEPTED_COUNT").Caption("VOUCHING_ACCEPTED_COUNT").Visible(false);
                     columns.Add().DataField("VOUCHING_PENDING_COUNT").Caption("VOUCHING_PENDING_COUNT").Visible(false);
                     columns.Add().DataField("YearID").Caption("YearID").Visible(false);
                     columns.Add().DataField("SNo").Caption("SNo").Visible(false);
                     columns.Add().DataField("RemarkStatus").Caption("RemarkStatus").Visible(false);
                     columns.Add().DataField("RemarkCount").Caption("RemarkCount").Visible(false);
                     columns.Add().DataField("Remarks").Caption("Remarks").Visible(false);
                     columns.Add().DataField("OpenActions").Caption("OpenActions").Visible(false);
                     columns.Add().DataField("Next_Year_Closing_Value").Caption("Next_Year_Closing_Value").Visible(false);
                     columns.Add().DataField("Deduction").Caption("Deduction").Visible(false);
                     columns.Add().DataField("Date_of_Creation").Caption("Date_of_Creation").Visible(false).DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                     columns.Add().DataField("CrossedTimeLimit").Caption("CrossedTimeLimit").Visible(false);                    
                 })

.MasterDetail(md =>
{
    md.AutoExpandAll(false);
    md.Enabled(!VouchingMode);
    md.Template(new JS("WIPListGrid_dx_DetailTemplate"));
})
.OnInitialized("WIPListGrid_dx_OnInitialized")
.OnCellPrepared("WIPListGrid_dx_OnCellPrepared")
.OnRowPrepared("WIPListGrid_dx_OnRowPrepared")
.OnContentReady("WIPListGrid_dx_OnContentReady")
.OnCellDblClick("WIPListGrid_dx_OnCellDblClick")
.OnSelectionChanged("WIPListGrid_dx_OnSelectionChanged")
.OnRowExpanding("WIPListGrid_dx_OnRowExpanding")
.OnRowCollapsing("WIPListGrid_dx_OnRowCollapsing")
.OnContextMenuPreparing("WIPListGrid_dx_OnContextMenuPreparing")
)
          