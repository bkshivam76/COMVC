<script>
    function WIPListGrid_dx_Refresh()
    {
        WIPListGrid.refresh().done(function () { ActionAfterDataGridRefresh_WIPListGrid_dx() })
    }
    async function ActionAfterDataGridRefresh_WIPListGrid_dx(ActionMethod = null)
    {     
        if (ActionMethod != null)
        {
            if (ActionMethod == "_New")
            {
                DevExpress.ui.dialog.confirm("Add More Entry...?", "New ~ WIP Info").done(function (confirmDialogResult)
                {
                    if (confirmDialogResult)
                    {
                        OnWIPNewClick();
                    }
                })
            }
            else if (ActionMethod == "_Edit")
            {            
                if ("@ViewData["WIP_LockUnlockRight"]" == "True")
                {
                    DevExpress.ui.dialog.confirm("Do you want to <font color=red>Lock</font> this Entry...?", "Confirmation...").done(function (confirmDialogResult)
                    {
                        if (confirmDialogResult)
                        {
                            datanavigation_WIP("LOCK");
                        }
                    });
                }
            }
        }
        else {
            var selectedRowKeys = WIPListGrid.getSelectedRowKeys()
            if (selectedRowKeys != null && selectedRowKeys.length > 0) {
                WIPListGrid.clearSelection()
                WIPListGrid.selectRows(selectedRowKeys)
            }
        }
