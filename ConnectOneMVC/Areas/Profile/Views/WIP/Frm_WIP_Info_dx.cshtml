    function WIPListGrid_dx_Compact_Column_CellValue(rowData) {
        var data =
            [
                rowData.WIP_Ledger, rowData.Reference, rowData.Opening, rowData.Special_Ref, rowData.Addition, rowData.Deduction, rowData.Closing

