    function WIPListGrid_dx_DetailTemplate(container, templateData) {
        var GridName = templateData.component.element()[0].id
        var RecID = templateData.data.ID;
        WIPListGrid_dx_Detail(container, GridName, RecID, WIP_IsVouchingMode, WIP_ShowHorizontalBar);
    }
    function WIPListGrid_dx_Detail(container, GridName, RecID, vouchingMode, AllColumns)
    {
        var url = "/Profile/WIP/Frm_WIP_Info_GridData_detail_dx?VouchingMode=" + vouchingMode + "&RecID=" + RecID
        var instance = DxGrid_AttachmentGrid_Create(container, GridName, RecID, vouchingMode, AllColumns, url)
        instance.option("onSelectionChanged", WIPListGrid_dx_Detail_onSelectionChanged);
    }
    function WIPListGrid_dx_Detail_onSelectionChanged(e) {
        if (WIPInfo_IsDetailRowExpanded || WIP_IsVouchingMode) {
            if (e.selectedRowsData != null && e.selectedRowsData.length > 0) {
                WIPInfo_NestedGrid_AccessID = e.element[0].id;
                WIPListGrid_dx_Detail_SelectedRowData(e.selectedRowsData)
            }
            else {
                WIPPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }
    function WIPListGrid_dx_Detail_SelectedRowData(selectedData = null)
    {
        if (selectedData == null)
        {
            selectedData = $("#" + WIPInfo_NestedGrid_AccessID).dxDataGrid("getSeletedRowsData");
        }
        var values = selectedData[0];
        WIPInfo_NestedRowKeyValue = values["UniqueID"];
        if (values["UniqueID"] != null)
        {
            WIPPrf_FAB.SetVisible(true);
            WIPInfo_Nested_Doc_Status = values["Doc_Status"];

            if (WIP_IsVouchingMode == true) {
                WIPPrf_FAB.SetActionContext("AuditActionContext", true);
            }
            else {
                if (WIPInfo_Nested_Doc_Status == "") {
                    WIPPrf_FAB.SetActionContext("AutoItemContext", true);
                }
                else if (WIPInfo_Nested_Doc_Status == "NO") {
                    WIPPrf_FAB.SetActionContext("EditItemContext", true);
                }
                else if (WIPInfo_Nested_Doc_Status == "YES") {
                    WIPPrf_FAB.SetActionContext("actionItemContext", true);
                }
            }
            WIPInfo_ParamMandatory = values["Params_Mandatory"];
            WIPInfo_FromDateLabel = values["LABEL_FROM_DATE"];
            WIPInfo_ToDateLabel = values["LABEL_TO_DATE"];
            WIPInfo_DescriptionLabel = values["LABEL_DESCRIPTION"];
            WIPInfo_Doc_Category = values["Document_Category"];
            WIPInfo_Doc_ID = values["Document_ID"];
            WIPInfo_AtachmentID= values["ATTACH_ID"];
            IndexAttachmentID = WIPInfo_AtachmentID;
            WIPInfo_MasterRowRecID = values["TxnID"];
            WIPInfo_MasterRowMID = values["TxnMID"];
            WIPInfo_NestedRowMapID = values["MAP_ID"];
            WIPInfo_reason = values["Reason"];
            WIPInfo_FileName = values["ATTACH_FILE_NAME"];
            WIPInfo_Attachment_RecStatus= values["Attachment_Action_Status"];
            if (WIP_IsVouchingMode == true) {
                if (WIPInfo_FileName != null && WIPInfo_FileName.length > 0) {
                    ViewDocument(WIPInfo_AtachmentID, WIPInfo_FileName, "WIPPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else {
                    CloseRightPane();
                    ClearRightPane();
                }
            }
        }
         WIPInfo_NestedRowReasonID = values["ReasonID"];
        IndexAttachmentReasonID = WIPInfo_NestedRowReasonID;
    }
    function LeftPaneContent_WIP(GridName, RecID, vouchingMode, AllColumns = 0) {
        $("#LeftPane_Div_Content").html(null);
        $("#LeftPane_Div_Content").append("<div class='col-xs-12'><label>Documents Attached:</label><div class='AttachmentGrid'><form></form></div></div><div class='col-xs-12'><label>Additional Info:</label><div class='AdditionalInfoGrid'><form></form></div></div>")
        WIPListGrid_dx_Detail($("#LeftPane_Div_Content .AttachmentGrid>form"), GridName, RecID, vouchingMode, AllColumns)
        setTimeout(function () {
            AdditionalInfoGrid_WIP($("#LeftPane_Div_Content .AdditionalInfoGrid>form"), GridName, RecID, vouchingMode, AllColumns)
        })
    }
    function AdditionalInfoGrid_WIP(container, GridName, RecID, vouchingMode, AllColumns) {
        var url = "/Profile/WIP/Frm_WIP_Info_AdditionalGridData_dx?VouchingMode=" + vouchingMode + "&RecID=" + RecID
        DxGrid_CreateAdditionalInfoGrid(container, GridName, RecID, vouchingMode, AllColumns, url)
    }
