    function WIPListGrid_dx_OnSelectionChanged(e) {
        var selectedRowKeys = e.selectedRowKeys;
        if (selectedRowKeys != null && selectedRowKeys.length > 0) {
            if (WIP_IsVouchingMode)
            {
                WIPPrf_FAB.SetVisible(true);
                WIPPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
            WIPListGrid_dx_SelectedRowData(e.selectedRowsData);
        }
        else {
            WIPID = null;
            WIP_UpdateFooterDetail(WIPID, WIP_ActionStatus, WIP_AddDate, WIP_AddBy, WIP_ActionDate, WIP_ActionBy, WIP_EditDate, WIP_EditBy);
        }
    }
    function WIPListGrid_dx_SelectedRowData(selectedData = null) {
        if (selectedData == null) {
            selectedData = WIPListGrid.getSelectedRowsData();
        }
        if (selectedData != null && selectedData.length > 0) {
            var values = selectedData[0]
            WIPID = values["ID"]
            WIP_EditDate = values["Edit_Date"];
            WIP_EditBy = values["Edit_By"];
            WIP_AddDate = values["Add_Date"];
            WIP_AddBy = values["Add_By"];
            WIP_ActionDate = values["Action_Date"];
            WIP_ActionBy = values["Action_By"];
            WIP_ActionStatus = values["Action_Status"];
            WIP_Opening = values["Opening"];
            WIP_LedgerID = values["LED_ID"];
            WIP_LedgerName = values["WIP_Ledger"];
            WIP_Reference = values["Reference"];
            WIP_OpeningDate = values["Date_of_Creation"];
            WIP_TR_ID = values["TR_ID"];
            WIP_Entry_Type = values["Entry_Type"];
            WIP_OpenActions = values["OpenActions"];
            WIP_YearID = values["YearID"];


            WIP_UpdateFooterDetail(WIPID, WIP_ActionStatus, WIP_AddDate, WIP_AddBy, WIP_ActionDate, WIP_ActionBy, WIP_EditDate, WIP_EditBy);
            if (WIP_IsVouchingMode == true) {
                OpenLeftPane();
                LeftPaneContent_WIP("WIPListGrid", WIPID, WIP_IsVouchingMode)
            }
        }
        else {
            WIPID = null;
        }
    }
    function WIPListGrid_dx_OnRowExpanding(e) {
        if (Array.isArray(e.key) == false) //not group row
        {
            e.component.collapseRow(Expanded_Row_Key_WIP)
            e.component.selectRows(e.key);
            Expanded_Row_Key_WIP = e.key;
            WIPInfo_IsDetailRowExpanded = true;
            var DetailGridID = e.element[0].id + e.key;
            var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
            if (instance != void 0) {
                instance.state(null) // grid maintains its state after collapsing so resetting the state when expands again as per old grid
            }
            //e.component.collapseAll(-1);
        }
        else {
            e.component.option("CustomProp.groupRowExpanded", true);
        }
    }
    function WIPListGrid_dx_OnRowCollapsing(e)
    {
        if (Array.isArray(e.key) == false) //not group row
        {
            var DetailGridID = e.element[0].id + e.key;
            sessionStorage.removeItem(DetailGridID + "_DetailGridState") //removing grid state from session storage on collapse
            WIPInfo_IsDetailRowExpanded = false;
            e.component.selectRows(e.key);
            if (WIP_IsVouchingMode == false) {
                WIPPrf_FAB.SetVisible(false);
            }
            var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
            if (instance != void 0) {
                instance.clearSelection();
            }
        }
        else {
            e.component.option("CustomProp.groupRowCollapsed", true);
        }
    }
