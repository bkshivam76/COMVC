            DxGrid_FormatNumber(templateData.data.Closing ?? "") + "</div></div>";
        htmlString += "<div class='row'>" +
            "<div class='col-sm-12 col-md-3 col-lg-3 compact_column_label'>" +
            "<label class='control-label'>Special Reference:</label></div>" +
