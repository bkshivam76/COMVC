<script>
    function On_WIPProfile_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@Help_Attachment_AddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (WIPInfo_ParamMandatory == 1)
            {
                AddAttachment(WIPInfo_MasterRowRecID, "Profile_WIP", WIPInfo_Doc_ID, WIPInfo_Doc_Category, WIPInfo_ParamMandatory, WIPInfo_FromDateLabel, WIPInfo_ToDateLabel, WIPInfo_DescriptionLabel, "WIPProfileAttachment", null, "WIPListGrid", WIPInfo_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(WIPInfo_MasterRowRecID, "Profile_WIP", WIPInfo_Doc_ID, "WIPProfileAttachment", "WIPListGrid", WIPInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (WIPInfo_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(WIPInfo_MasterRowRecID, "Profile_WIP", WIPInfo_AtachmentID, WIPInfo_ParamMandatory, WIPInfo_FromDateLabel, WIPInfo_ToDateLabel, WIPInfo_DescriptionLabel, "WIPProfileAttachment", null, "WIPListGrid", WIPInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(WIPInfo_MasterRowRecID, "Profile_WIP", WIPInfo_AtachmentID, WIPInfo_ParamMandatory, WIPInfo_FromDateLabel, WIPInfo_ToDateLabel, WIPInfo_DescriptionLabel, null, "WIPListGrid", WIPInfo_NestedGrid_AccessID, WIPInfo_Attachment_RecStatus);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@Help_Attachment_ViewRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            ViewDocument(WIPInfo_AtachmentID, WIPInfo_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(WIPInfo_MasterRowRecID, "Profile_WIP", "WIP Information", "WIPListGrid", WIPInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Add_Reason")
        {
            if (WIPInfo_Doc_Category.toLowerCase() == "others")
            {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else
            {
                AttachmentAddReason(WIPInfo_MasterRowRecID, WIPInfo_NestedRowMapID, "Profile_WIP", "WIPListGrid", WIPInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(WIPInfo_MasterRowRecID, WIPInfo_NestedRowMapID, "Profile_WIP", "WIPListGrid", WIPInfo_NestedGrid_AccessID, WIPInfo_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(WIPInfo_MasterRowRecID, WIPInfo_NestedRowMapID, "WIPListGrid", WIPInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
        else if (e.actionName == "AuditAction")
        {
            WIPPrf_FAB.SetActionContext("AuditActionContext", true);
        }
        else if (e.actionName == "BackAudit")
        {
            if (WIPInfo_Nested_Doc_Status == "")
            {
                WIPPrf_FAB.SetActionContext("AutoItemContext", true);
            }
            if (WIPInfo_Nested_Doc_Status == "NO")
            {
                WIPPrf_FAB.SetActionContext("EditItemContext", true);
            }
            if (WIPInfo_Nested_Doc_Status == "YES")
            {
                WIPPrf_FAB.SetActionContext("actionItemContext", true);
            }
        }
        else if (e.actionName == "Accept")
        {
            WIPInfo_AcceptwithoutRemarks();
        }
        else if (e.actionName == "Reject")
        {
            WIPInfo_AcceptRejectVoucher("Reject");
        }
        else if (e.actionName == "AcceptWithRemarks")
        {
            WIPInfo_AcceptRejectVoucher("Accept");
        }
        else if (e.actionName == "AcceptDoc")
        {
            OnWIPInfo_AcceptDoc();
        }
        else if (e.actionName == "RejectDoc")
        {
            OnWIPInfo_RejectDoc();
        }
    }
    function OnWIPInfo_RejectDoc()
    {
        if (WIPInfo_AtachmentID == null || WIPInfo_AtachmentID.length == 0)
        {
                DevExpress.ui.dialog.alert("No Document Attached..", "Error");
                return;
        }
        RejectAttachment(WIPInfo_AtachmentID, "WIPListGrid", WIPInfo_NestedGrid_AccessID);
    }
    function OnWIPInfo_AcceptDoc()
    {
        if (WIPInfo_AtachmentID == null || WIPInfo_AtachmentID.length == 0)
        {
                DevExpress.ui.dialog.alert("No Document Attached..", "Error");
                return;
        }

        AcceptAttachment(WIPInfo_AtachmentID, "WIPListGrid", WIPInfo_NestedGrid_AccessID);
    }
    function WIPInfo_AcceptwithoutRemarks()
    {
        var Recid;
        if (WIPInfo_IsDetailRowExpanded == true || WIP_IsVouchingMode == true)
        {
            if (WIPInfo_MasterRowRecID == null || WIPInfo_MasterRowRecID == "")
            {
                Recid = WIPID;
            }
            else
            {
                Recid = WIPInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = WIPID;
        }
        Entry_AcceptwithoutRemarks(Recid, "Profile_WIP", "WIPListGrid", WIPInfo_AtachmentID, WIPInfo_NestedRowReasonID, WIPInfo_NestedRowKeyValue);
    }
    function WIPInfo_AcceptRejectVoucher(_actionMethod)
    {
        var Recid;
        if (WIPInfo_IsDetailRowExpanded == true || WIP_IsVouchingMode == true)
        {
            if (WIPInfo_MasterRowRecID == null || WIPInfo_MasterRowRecID == "")
            {
                Recid = WIPID;
            }
            else
            {
                Recid = WIPInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = WIPID;
        }
        Entry_AcceptReject(_actionMethod, Recid, "Profile_WIP", "WIPListGrid", WIPInfo_AtachmentID, WIPInfo_NestedRowReasonID, WIPInfo_NestedRowKeyValue);
    }
</script>
