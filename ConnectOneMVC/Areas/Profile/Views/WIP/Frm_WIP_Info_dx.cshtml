    function WIPOnTxnReportClick()
    {
        if ("@WIP_ReportRight" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        WIP_CallingFrom = "WIP_Profile";
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Profile/WIP/Frm_WIP_Txn_Report",
            data:
            {
