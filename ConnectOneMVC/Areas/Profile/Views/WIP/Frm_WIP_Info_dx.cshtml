    @*Document.ready, AjaxSuccess Functions*@
<script type="text/javascript">
    function datanavigation_WIP(Action)
    {
        if (WIPID == null || WIPID == "")
        {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        switch (Action)
        {
            case "UNLOCK":
                WIPOnUnlockClick();
                break;

            case "LOCK":
                WIPOnLockClick();
                break;

            case "EDIT":
                OnWIPEditClick();
                break;

            case "DELETE":
                OnWIPDeleteClick();
                break;

            case "VIEW":
                OnWIPViewClick();
                break;

            case "Audit_Add":
                WIP_AddAuditActions();
                break;

            case "Audit_View":
                WIP_ViewAuditActions();
                break;

            case "TxnReport":
                WIPOnTxnReportClick();
                break;
        }
    }
    function WIP_AddAuditActions()
    {
        if ("@WIP_ManageRemarks" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Profile/WIP/DataNavigation",
            data:
            {
                ActionMethod: "ADD REMARKS",
                ID: WIPID,
                Edit_Date: WIP_EditDate,
                Action_Status: WIP_ActionStatus,
                Entry_Type: WIP_Entry_Type,
                TR_ID: WIP_TR_ID,
                YearID: WIP_YearID,
                OpenActions: WIP_OpenActions,
            },
            cache: false,
            success: function (data)
            {
                HideLoader();
                if (data.jsonParam.result == true)
                {
                    Add_Actions(WIPID, "WIP_INFO", "Profile_WIP", "WIP_AddActionItem_Popup", "WIPListGrid");
                }
                else
                {
                    HideLoader();
                    DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                }
            }
        });
    }
    function WIP_ViewAuditActions()
    {
        if ("@WIP_ViewRemarks" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        if (WIP_Entry_Type.toUpperCase() == "VOUCHER ENTRY")
        {
            DevExpress.ui.dialog.alert('Entries created from vouchers can be audited from vouchers only...!<br><br>Please unselect Entries Created from Voucher...!', "Information...");
            return;
        }

        View_Actions(WIPID, "WIP_INFO", "Profile_WIP", WIP_ActionStatus, "WIP_ViewActionItem_Popup", "WIPListGrid")
    }
    function WIPOnUnlockClick(_MultiUserConfirmation = false)
    {
        if ("@WIP_LockUnlockRight" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Profile/WIP/DataNavigation",
            data:
            {
                ActionMethod: "UNLOCKED",
                ID: WIPID,
                Edit_Date: WIP_EditDate,
                Action_Status: WIP_ActionStatus,
                Entry_Type: WIP_Entry_Type,
                TR_ID: WIP_TR_ID,
                YearID: WIP_YearID,
                OpenActions: WIP_OpenActions,
                MultiUserConfirmation: _MultiUserConfirmation
            },
            cache: false,
            success: function (data)
            {
                HideLoader();
                if (data.jsonParam.isconfirm == true)
                {
                    var confirmbox = CreateCustomConfirmDialog(data.jsonParam.title, data.jsonParam.message, false).show();
                    confirmbox.done(function (confirmboxResult)
                    {
                        if (confirmboxResult)
                        {
                            WIPOnUnlockClick(true);
                        }
                        else
                        {
                            WIPListGrid_dx_Refresh();
                        }
                    });
                }
                else
                {
                    var alertBoxDone = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title)
                    alertBoxDone.done(function (alertBoxResult)
                    {
                        if (data.jsonParam.result)
                        {
                            Select_xid_WIP = WIPID
                        }
                        if (data.jsonParam.refreshgrid)
                        {
                            WIPListGrid_dx_Refresh();
                        }
                    });
                }
            }
        });
    }
    function WIPOnLockClick(_MultiUserConfirmation = false)
    {
        if ("@WIP_LockUnlockRight" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Profile/WIP/DataNavigation",
            data:
            {
                ActionMethod: "LOCKED",
                ID: WIPID,
                Edit_Date: WIP_EditDate,
                Action_Status: WIP_ActionStatus,
                Entry_Type: WIP_Entry_Type,
                TR_ID: WIP_TR_ID,
                YearID: WIP_YearID,
                OpenActions: WIP_OpenActions,
                MultiUserConfirmation: _MultiUserConfirmation
            },
            cache: false,
            success: function (data)
            {
                HideLoader();
                if (data.jsonParam.isconfirm == true) {
                    var confirmbox = CreateCustomConfirmDialog(data.jsonParam.title, data.jsonParam.message, false).show();
                    confirmbox.done(function (confirmboxResult) {
                        if (confirmboxResult) {
                            WIPOnLockClick(true);
                        }
                        else {
                            WIPListGrid_dx_Refresh();
                        }
                    });
                }
                else {
                    var alertBoxDone = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title)
                    alertBoxDone.done(function (alertBoxResult) {
                        if (data.jsonParam.result) {
                            Select_xid_WIP = WIPID
                        }
                        if (data.jsonParam.refreshgrid) {
                            WIPListGrid_dx_Refresh();
                        }
                    });
                }
            }
        });
    }
    function OnWIPNewClick()
    {
        debugger;
        if ("@WIP_AddRight" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
            return;
        }

        $.ajax({
            type: 'GET',
            url: "/Profile/WIP/DataNavigation",
            data: { ActionMethod: "New" },
            cache: false,
            success: function (data)
            {
                if (data.jsonParam.result == "true" || data.jsonParam.result == true)
