<script>
    var WIPListGrid = null;    
    var Expanded_Row_Key_WIP = null;
    var VisibleColumns_WIPListGrid_dx = [];
    function WIPchangeMode() {
        WIPListGrid.beginUpdate();
        if (WIP_ShowHorizontalBar == 0) {
            WIP_ShowHorizontalBar = 1;
            $("#WIPModelToggleScrollBar").find("span").text("Default Data");
            $("#WIPModelToggleScrollBar").width(110);
            WIPListGrid.option("columnHidingEnabled", false);
            WIPListGrid.option("allowColumnResizing", true)
            WIPListGrid.option("columnResizingMode", "widget")
        }
        else {
            WIP_ShowHorizontalBar = 0;
            $("#WIPModelToggleScrollBar").find("span").text("Full Data");
            $("#WIPModelToggleScrollBar").width(90);
            WIPListGrid.option("columnHidingEnabled", true)
            WIPListGrid.option("allowColumnResizing", false)
            WIPListGrid.option("columnResizingMode", "nextColumn")
        }
        WIPListGrid.endUpdate();
    }
    function WIP_VouchingSwitch_ValueChange(e) {
        WIP_IsVouchingMode = e.value;
        if (WIPInfo_SetVouchingModeOn == true) {
            WIPInfo_SetVouchingModeOn = false;
        }
        else {
            WIPPrf_FAB.SetVisible(false);
        }
        if (WIP_IsVouchingMode == true) {
            OpenRightPane();
            ClearLeftPane();
            OpenLeftPane();
        }
        else
        {              
            CloseRightPane();
            ClearLeftPane();
            CloseLeftPane();
        }
        WIPListGrid.clearSelection();
        WIPListGrid.option("masterDetail.enabled", !WIP_IsVouchingMode)
        WIPListGrid.repaint();
    }
    function WIP_ViewSwitch_ValueChange(e) {
        WIP_ViewMode = e.value == false ? "Default" : "Compact";
        if (WIPInfo_SetVouchingModeOn == true) {
            $("#WIPVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }
        WIPListGrid.beginUpdate();
        var columns = WIPListGrid.option("columns");
        if (WIP_ViewMode == "Compact") {
            VisibleColumns_WIPListGrid_dx = [];
            for (var i = 0; i < columns.length; i++) {
                var name = columns[i].dataField;
                var ColumnVisible = WIPListGrid.columnOption(name, "visible");
                if (name == "WIPListGrid_dx_Compact_Column") {
                    WIPListGrid.columnOption(name, "visible", true);
                }
                else if (ColumnVisible == true && name != "iIcon") {
                    VisibleColumns_WIPListGrid_dx.push(name);
                    WIPListGrid.columnOption(name, "visible", false);
                }
            }
        }
        else {
            WIPListGrid.columnOption("WIPListGrid_dx_Compact_Column", "visible", false);
            for (var i = 0; i < VisibleColumns_WIPListGrid_dx.length; i++) {
                WIPListGrid.columnOption(VisibleColumns_WIPListGrid_dx[i], "visible", true);
            }
        }
        WIPListGrid.repaint();
        WIPListGrid.endUpdate();
    }  
    function WIP_UpdateFooterDetail(ID, Action_Status, Add_Date, Add_By, Action_Date, Action_By, Edit_Date, Edit_By)
    {
        var Status = "";
        var Lbl_Status = "";
        var Lbl_StatusBy = "";
        var Pic_Status = "";
        var Lbl_Create = "";
        var Lbl_Modify = "";
        var Lbl_Status_Color = "";
        var Lbl_ActionOn = "";
        var Lbl_ActionBy = "";
        var StatusStr = "";
        if (ID != null) {
            Add_Date = (JS_Json_Date_To_ddMMyyyy((Add_Date ?? ""), "DD-MM-YYYY HH:mm:ss") ?? "")
            Edit_Date = (JS_Json_Date_To_ddMMyyyy((Edit_Date ?? ""), "DD-MM-YYYY HH:mm:ss") ?? "")
            Action_Date = (JS_Json_Date_To_ddMMyyyy((Action_Date ?? ""), "DD-MM-YYYY HH:mm:ss") ?? "")
            Status = Action_Status;
            StatusStr = Status == "Locked" ? "Locked" : Status == null ? null : "UnLocked";
            if (Status && Status.toUpperCase() == "LOCKED") {
                Lbl_Status = "Completed";
                Lbl_Status_Color = "blue";
                Pic_Status = "fa fa-lock";
            }
            else {
                Pic_Status = "fa fa-unlock";
                Lbl_Status = Status;
                if (Status && Status.toUpperCase() == "COMPLETED") {
                    Lbl_Status_Color = "green";
                }
                else {
                    Lbl_Status_Color = "red";
                }
            }
            if (Action_Date) {
                Lbl_ActionOn = StatusStr + " On: " + Action_Date;
                Lbl_ActionBy = StatusStr + " By: " + Action_By;
            }

            else {
                Lbl_ActionOn = "";
                Lbl_ActionBy = "";
            }
            if (Add_Date) {
                Lbl_Create = "Add On: " + Add_Date + ", By: " + Add_By;
            }
            else {
                Lbl_Create = "";
            }

            if (Edit_Date) {
                Lbl_Modify = "Edit On: " + Edit_Date + ", By: " + Edit_By;
            }
            else {
                Lbl_Modify = "";
            }
        }
        $('#WIPLbl_Status').text(Lbl_Status);
        $('#WIP_Lbl_ActionOn').text(Lbl_ActionOn);
        $('#WIP_Lbl_ActionBy').text(Lbl_ActionBy);
        $('#WIPLbl_Create').text(Lbl_Create);
        $('#WIPLbl_Modify').text(Lbl_Modify);
        if (Lbl_Status_Color != "") {
            $('#WIPLbl_Status').css('color', Lbl_Status_Color);
        }
        if (Pic_Status == "fa fa-lock") {
            $('#WIP_LockICON').addClass(Pic_Status).removeClass("fa-unlock");
        }
        else if (Pic_Status == "fa fa-unlock") {
            $('#WIP_LockICON').addClass(Pic_Status).removeClass("fa-lock");
        }
        else {
            $('#WIP_LockICON').removeClass("fa");
            $('#WIP_LockICON').removeClass("fa-lock");
            $('#WIP_LockICON').removeClass("fa-unlock");
        }
    }
</script>
