@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
}

@(Html.DevExtreme().DataGrid().CustomDataGridListing()
                 .ID("WIP_Txn_Grid")
                 .DataSource(d => d.Mvc().Controller("WIP").LoadAction("Frm_WIP_Txn_Grid").LoadMode(DataSourceLoadMode.Raw)
                 .OnBeforeSend("WIPtxnReport_OnBeforeSend"))
                 .Columns(columns =>
                 {
                     columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);
                     columns.Add().DataField("Voucher").Caption("Voucher").Visible(false);
                    // columns.Add().DataField("Date").Caption("Date").MinWidth(80).CalculateDisplayValue(new JS("function(rowData){return calDisplayValue(rowData)}"))/*DataType(GridColumnDataType.Date).Format("dd/MM/yyyy")*/.SortingMethod("calSortingMethod").Option("IsDate",true).HeaderFilter(s => s.DataSource("function (e){return ColHeaderDS(e,'Date')}")).CalculateFilterExpression("calcFilterExpression");
                     columns.Add().DataField("Date").Caption("Date").MinWidth(80).DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                     columns.Add().DataField("ItemName").Caption("Item Name").MinWidth(Request.Browser.IsMobileDevice?150:300);
                     columns.Add().DataField("Party").Caption("Party").Visible(false);
                     columns.Add().DataField("Debit").Caption("Debit").DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("Credit").Caption("Credit").DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("Balance").Caption("Balance");
                 })
                 .Height(400)
         .Paging(s=>s.Enabled(false))
         .Pager(s => s.Visible(false))
         .OnContextMenuPreparing("WIP_Txn_Grid_ContextMenuPreparing")
         .OnContentReady("WIP_Txn_Grid_OnContentReady")    
         )

