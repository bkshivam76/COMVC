<div class="WIP_Txn_Rprt_ExportProfile_ClearReferences">

    @using DevExtreme.AspNet.Mvc;
    <div>
        @(Html.DevExtreme().Button()
                        .ID("WIP_Txn_ExportGridDatapdf")
                        .Text("Export to PDF")
                        .OnClick("ExportPDF")
                        .Visible(false)
                        .Width(120)
    )

        @(Html.DevExtreme().Button()
                        .ID("WIP_Txn_ExportGridDataxls")
                        .Text("Export to XLS")
                        .OnClick("ExportXLS")
                        .Visible(false)
                        .Width(120)
    )
        @(Html.DevExtreme().Button()
                        .ID("WIP_Txn_ExportGridDataxlsx")
                        .Text("Export to XLSX")
                        .OnClick("ExportXLSX_dx")
                        .Visible(true)
                        .Width(120)
    )

        @(Html.DevExtreme().Button()
                        .ID("WIP_Txn_ExportGridDatadocx")
                        .Text("Export to DOCX")
                        .OnClick("ExportDOCX")
                        .Visible(false)
                        .Width(120)
    )

        @(Html.DevExtreme().Button()
                        .ID("WIP_Txn_ExportGridDatartf")
                        .Text("Export to RTF")
                        .OnClick("ExportRTF")
                        .Visible(false)
                        .Width(120)
    )

        @(Html.DevExtreme().Button()
                        .ID("WIP_Txn_ExportGridDatacsv")
                        .Text("Export to CSV")
                        .OnClick("ExportCSV")
                        .Visible(false)
                        .Width(120)
    )
    </div>
    <script>
        function ExportPDF() {
            WIP_Txn_Grid.ExportTo(ASPxClientGridViewExportFormat.Pdf);
            $("#WIP_Txn_ListPreview_modal").dxPopup("hide");
        }
        function ExportXLS() {
            WIP_Txn_Grid.ExportTo(ASPxClientGridViewExportFormat.Xls);
            $("#WIP_Txn_ListPreview_modal").dxPopup("hide");
        }
        function ExportXLSX() {
            WIP_Txn_Grid.ExportTo(ASPxClientGridViewExportFormat.Xlsx);
            $("#WIP_Txn_ListPreview_modal").dxPopup("hide");
        }
        function ExportCSV() {
            WIP_Txn_Grid.ExportTo(ASPxClientGridViewExportFormat.Csv);
            $("#WIP_Txn_ListPreview_modal").dxPopup("hide");
        }
        function ExportDOCX() {
            WIP_Txn_Grid.ExportTo(ASPxClientGridViewExportFormat.Docx);
            $("#WIP_Txn_ListPreview_modal").dxPopup("hide");
        }
        function ExportRTF() {
            WIP_Txn_Grid.ExportTo(ASPxClientGridViewExportFormat.Rtf);
            $("#WIP_Txn_ListPreview_modal").dxPopup("hide");
        }
        function ExportXLSX_dx() {
            const workbook = new ExcelJS.Workbook();
            const worksheet = workbook.addWorksheet('Sheet');

            DevExpress.excelExporter.exportDataGrid({
                worksheet: worksheet,
                component: $("#WIP_Txn_Grid").dxDataGrid("instance"),
                autoFilterEnabled: true,
                customizeCell({ excelCell, gridCell }) {
                    if (gridCell.rowType === 'header') {
                        const columnDataField = gridCell.column.dataField;
                        if (columnDataField === 'iIcon') {
                            const Column = worksheet.getColumn(excelCell.col);
                            Column.width = 20;
                        }
                    }
                }
            }).then(function (exportRange) {
                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: 'application/octet-stream' }), 'WIP_Transaction_Report.xlsx');
                });
            });
            $("#WIP_Txn_ListPreview_modal").dxPopup("hide");
        }
    </script>
</div>