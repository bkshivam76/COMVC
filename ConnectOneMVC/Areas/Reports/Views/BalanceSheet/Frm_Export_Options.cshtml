                settings.Properties.Items.Add("Yes, this time only");
                settings.Properties.Items.Add("No, not this time");
                settings.Properties.Items.Add("Yes, always");
                settings.Properties.Items.Add("No, never");
            })*@
    </div>
    <script>
        function ExportPDF() {
            BalanceSheetReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Pdf);
            $("#BalanceSheetReport_report_modal").dxPopup("hide");
        }
        function ExportXLS() {
            BalanceSheetReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Xls);
            $("#BalanceSheetReport_report_modal").dxPopup("hide");
        }
        function ExportXLSX() {
            BalanceSheetReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Xlsx);
            $("#BalanceSheetReport_report_modal").dxPopup("hide");
        }
        function ExportCSV() {
            BalanceSheetReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Csv);
            $("#BalanceSheetReport_report_modal").dxPopup("hide");
        }
        function ExportDOCX() {
            BalanceSheetReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Docx);
            $("#BalanceSheetReport_report_modal").dxPopup("hide");
        }
        function ExportRTF() {
            BalanceSheetReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Rtf);
            $("#BalanceSheetReport_report_modal").dxPopup("hide");
        }
    </script>
</div>