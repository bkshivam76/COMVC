    <div class="col-md-12">
        @*Add/Edit Popup*@
        @(Html.DevExtreme().Popup().CustomPopup()
                .ID("ConstructionReport_report_modal")
                 .OnShowing("PopupOnShowing")
                .Title("Construction Report Preview")
                .FullScreen(false)
                .MaxWidth(125)
                .Height("auto")
                .ShowCloseButton(true)
                .ContentTemplate(@<text>
                    <div id='ConstructionReport_report_modal_result'>
                    </div>
                </text>)
    )

    </div>

    @*Javascript Events*@
<script type="text/javascript">

        var IsConstructionReportSucessPopup = false;
        var IsConstructionReportViewPopup = false;
        var ConstructionReportSearchVisible = true;
        var ConstructionReportFilterVisible = true;
        var ConstructionReportGroupedColumnsVisible = false;
        var ConstructionReportGroupPanelFooterVisible = true;
        var ConstructionReportFooterVisible = true;
        var ConstructionReportGroupPanelVisible = true;

    $(document).ready(function () {
        if ("@ConstructionReport_ExportRight" == "False")
        {
	        $("#ConstructionReportsModelListPreview").hide();
        }
        IsConstructionReportSucessPopup = false;
        IsConstructionReportViewPopup = false;
        SetConstructionReportGroupPanelFooterVisible();
        $("#ConstructionReportListGrid").hover(function () {
            ConstructionReportListGrid.Focus()
        })
    });
    $(".TabPanalMenu-tabs .active span").on("click", function () {
        $.ajax({
            type: 'GET',
            url: "/Reports/ConstructionReport/SessionClear",
            cache: false
        });
        ClearAllReferences_ConstructionReport();
    });
        function ClearAllReferences_ConstructionReport()
        {
            IsConstructionReportSucessPopup = null;
            IsConstructionReportViewPopup = null;
            ConstructionReportSearchVisible = null;
            ConstructionReportFilterVisible = null;
            ConstructionReportGroupedColumnsVisible = null;
            ConstructionReportGroupPanelFooterVisible = null;
            ConstructionReportFooterVisible = null;
            ConstructionReportGroupPanelVisible = null;

            ClearAllReferences("ConstructionReport_ClearReferences");
        }
    function ConstructionReportOnInit(s, e) {
        ConstructionReportAdjustSize();
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            ConstructionReportAdjustSize();
        });
    }

    function OnEndCallback(s, e) {
        ConstructionReportAdjustSize();
    }

    function ConstructionReportAdjustSize() {
        var height = (document.documentElement.clientHeight * 90) / 100;
        try{ConstructionReportListGrid.SetHeight(height);} catch (err) { }
    }

    function UpdateConstructionReportCustomizationWindowVisibility() {
        if (ConstructionReportListGrid.IsCustomizationWindowVisible()) {
            ConstructionReportListGrid.HideCustomizationWindow();
            $("#btnConstructionReportShowColumnChooser").attr("title", "Show Column Chooser ")
        }
        else {
            ConstructionReportListGrid.ShowCustomizationWindow();
            $("#btnConstructionReportShowColumnChooser").attr("title", "Hide Column Chooser ");
            $("#btnConstructionReportShowColumnChooser").find("i").toggleClass("dx-icon-add").toggleClass("dx-icon-close");
        }

    }

    function CloseColumnChooser() {

        if (!ConstructionReportListGrid.IsCustomizationWindowVisible()) {
            $("#btnConstructionReportShowColumnChooser").find("i").toggleClass("dx-icon-add").toggleClass("dx-icon-close");
            $("#btnConstructionReportShowColumnChooser").attr("title", "Show Column Chooser ");
        }
    }

    function ConstructionReportTrackBarPositionChanged() {
        var ConstructionReportcurrentZoom = 1.0;
        var ConstructionReporttrackBarCurrentValue = ConstructionReportTrackBar.GetValue()
        if (ConstructionReporttrackBarCurrentValue != 0) {
            ConstructionReportcurrentZoom += ConstructionReporttrackBarCurrentValue / 100;
        }
        $('#ConstructionReportreloadPartialView').animate({ 'zoom': ConstructionReportcurrentZoom }, 'slow');
    }

    $("#ConstructionReportTrackBar").click(function (evt) {

    });

    function OnConstructionReportListPreviewClick() {
        if ("@ConstructionReport_ExportRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        
        OpenPopup("ConstructionReport_report_modal", "Export Option", "@Url.Action("Frm_Export_Options", "ConstructionReport", new { @area = "Reports" })", "auto", "auto", false, null)
    }

    function ContextMenuFunction(s, e) {
        if (e.item.name == 'Close') {
            btnCloseActiveTab();
        }
        else if (e.item.name == 'ListPreview') {
            OnConstructionReportListPreviewClick();
        }
        else if (e.item.name == 'Refresh') {
            ConstructionReportListGrid.Refresh();
        }
    }

    function ConstructionReportShowColumnChooser() {
        UpdateConstructionReportCustomizationWindowVisibility();
    }

    function ConstructionReportShowGroupPanel() {
        ConstructionReportGroupPanelVisibility();
    }

    function OnConstructionReportGroupClick() {
        if ($('[id^=ConstructionReportListGrid_groupcol').length != 0) {
            ConstructionReportListGrid.PerformCallback({ 'FilterVisible': ConstructionReportFilterVisible, "SearchVisible": ConstructionReportSearchVisible, "ShowGroupedColumns": !ConstructionReportGroupedColumnsVisible });
            $("#ConstructionReportGroupColumn").find("i").toggleClass("fa fa-forward fa-rotate-270").toggleClass("fa fa-backward fa-rotate-270");
            ConstructionReportGroupedColumnsVisible = !ConstructionReportGroupedColumnsVisible;
            if (!ConstructionReportGroupedColumnsVisible) {
                $("#ConstructionReportGroupColumn").attr("title", "Show Grouped Column")
            } else {
                $("#ConstructionReportGroupColumn").attr("title", "Hide Grouped Column")
            }
        }
    }

    function OnConstructionReportSearchClick() {
        ConstructionReportListGrid.PerformCallback({ 'FilterVisible': ConstructionReportFilterVisible, "SearchVisible": ConstructionReportSearchVisible, "ShowGroupedColumns": !ConstructionReportGroupedColumnsVisible });
        if (ConstructionReportSearchVisible) {
            ConstructionReportListGrid.contextMenuHelper.ContextMenuShowSearchPanel(1);
            $("#ConstructionReportSearch").attr("title", "Hide Search ")
        }
        else {
            ConstructionReportListGrid.contextMenuHelper.ContextMenuShowSearchPanel(0);
            $("#ConstructionReportSearch").attr("title", "Show Search ")
        }
        ConstructionReportSearchVisible = !ConstructionReportSearchVisible;
    }

    function OnConstructionReportFilterClick() {
        ConstructionReportListGrid.PerformCallback({ 'FilterVisible': ConstructionReportFilterVisible, "SearchVisible": ConstructionReportSearchVisible, "ShowGroupedColumns": !ConstructionReportGroupedColumnsVisible });
        if (ConstructionReportFilterVisible) {
            $("#ConstructionReportFind").attr("title", "Hide Filter ")
            ConstructionReportListGrid.contextMenuHelper.ContextMenuShowFilterRow(1);
        }
        else {
            $("#ConstructionReportFind").attr("title", "Show Filter ")
            ConstructionReportListGrid.contextMenuHelper.ContextMenuShowFilterRow(0);
        }
        ConstructionReportFilterVisible = !ConstructionReportFilterVisible;
    }

    function OnGridConstructionReportListGrid_EndCallback() {
        if (!ConstructionReportGroupPanelFooterVisible)
        { $('#ConstructionReportListGrid .dxgvGroupFooter_MetropolisBlue').show(); }
        else {
            $('#ConstructionReportListGrid .dxgvGroupFooter_MetropolisBlue').hide();
        }
    }

    function ConstructionReportGroupPanelVisibility() {
        if (ConstructionReportGroupPanelVisible) {
            if (ConstructionReportListGrid.contextMenuHelper == undefined)
            { ConstructionReportListGrid.Refresh(); }
            $("#btnConstructionReportShowGroupPanel").attr("title", "Hide Group box ")
            ConstructionReportListGrid.contextMenuHelper.ContextMenuShowGroupPanel(1)
        }
        else {
            $("#btnConstructionReportShowGroupPanel").attr("title", "Show Group box ")
            ConstructionReportListGrid.contextMenuHelper.ContextMenuShowGroupPanel(0);
        }
        ConstructionReportGroupPanelVisible = !ConstructionReportGroupPanelVisible;

        $("#btnConstructionReportShowGroupPanel").find("i").toggleClass("dx-icon-spinup").toggleClass("dx-icon-spindown");
    }

    function SetConstructionReportGroupPanelFooterVisible() {
        if (ConstructionReportGroupPanelFooterVisible) {
            $("#ConstructionReportShowGroupFooter").attr("title", "Hide Group  Footer Bar");
            $('#ConstructionReportListGrid .dxgvGroupFooter_MetropolisBlue').show();
        }
        else {
            $("#ConstructionReportShowGroupFooter").attr("title", "Show Group Footer Bar");
            $('#ConstructionReportListGrid .dxgvGroupFooter_MetropolisBlue').hide();
        }
        ConstructionReportGroupPanelFooterVisible = !ConstructionReportGroupPanelFooterVisible;
    }

    function SetConstructionReportFooterVisible() {
        $("#ConstructionReportShowFooter").find("i").toggleClass("fa fa-fast-forward fa-rotate-270").toggleClass("fa fa-fast-backward fa-rotate-270");
        if (ConstructionReportFooterVisible) {
            $("#ConstructionReportShowFooter").attr("title", "Hide Footer Bar");
            ConstructionReportListGrid.contextMenuHelper.ContextMenuShowFooter(1);
        }
        else {
            $("#ConstructionReportShowFooter").attr("title", "Show Footer Bar");
            ConstructionReportListGrid.contextMenuHelper.ContextMenuShowFooter(0);
        }
        ConstructionReportFooterVisible = !ConstructionReportFooterVisible;
    }

    function ConstructionReportCreateFilterClick() {
        ASPx.GVShowFilterControl('ConstructionReportListGrid');
    }

</script>
</div>