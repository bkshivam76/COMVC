@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
}
@(Html.DevExtreme().DataGrid().CustomDataGridListing(1)
                 .ID("ReconcileListGrid")
                 .DataSource(d => d.Mvc().Controller("DailyBalances")
                 .LoadAction("Frm_Bank_Reconcile_Grid_data").LoadMode(DataSourceLoadMode.Raw)
                 .OnBeforeSend("Bank_ReconcileListGrid_dx_OnBeforeSend").OnLoaded("Bank_ReconcileListGrid_dx_OnLoaded")
                 )
                 .Columns(columns =>
                 {
                     columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);
                     columns.Add().DataField("Voucher Date").Caption("Voucher Date").Width(140).DataType(GridColumnDataType.Date).Format("dd/MM/yyyy");
                     columns.Add().DataField("Clearing Date").Caption("Clearing Date").Width(140).DataType(GridColumnDataType.Date).Format("dd/MM/yyyy");
                     columns.Add().DataField("Mode").Caption("Mode").Width(140) ;
                     columns.Add().DataField("Ref No").Caption("Ref No").Width(140) ;
                     columns.Add().DataField("Amount").Caption("Amount").Width(140).DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("Status").Caption("Status").GroupIndex(1) ;
                 })
                 .Paging(s=>s.Enabled(false))
                 .Pager(s => s.Visible(false))
                 .Summary(s =>
                 {
                     s.GroupItems(item => item.Add().SummaryType(SummaryType.Sum).Name("Amount_Amount_sum").Column("Amount").ShowInGroupFooter(true).DisplayFormat("Total: {0}").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}")));
                 })
                 .Height(350)

.OnInitialized("Bank_Reconcile_Grid_dx_OnInitialized")
.OnContextMenuPreparing("Bank_Reconcile_Grid_dx_OnContextMenuPreparing")

)