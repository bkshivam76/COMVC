        function DailyBalancesListGrid_dx_OnEditorPreparing(e)
        {
            DxGrid_onEditorPreparing(e)
            if (e.parentType == 'dataRow')
            {
                if (e.dataField == "Clearingdate" && e.row.key == "NullOPENING BALANCE")
