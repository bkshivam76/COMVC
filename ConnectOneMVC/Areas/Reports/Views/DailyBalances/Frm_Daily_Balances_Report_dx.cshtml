            Daily_Balances_IsDetailRowExpanded = null;
            Daily_Balances_NestedRecord_FocusedRowIndex = null;
            Daily_Balances_NestedGrid_AccessID = null;
            Daily_Balances_AtachmentID = null;
            Daily_Balances_FileName = null;
            Daily_Balances_ParamMandatory = null;
            Daily_Balances_FromDateLabel = null;
            Daily_Balances_ToDateLabel = null;
            Daily_Balances_DescriptionLabel = null;
            Daily_Balances_Doc_ID = null;
            Daily_Balances_Doc_Category = null;
            Daily_Balances_MasterRowRecID = null;
            Daily_Balances_MasterRowMID = null;
            Daily_Balances_NestedRowMapID = null;
            Daily_Balances_reason = null;
            Daily_Balances_Attachment_RecStatus = null;
            Daily_Balances_RecID_ForAttachment = null;
            Daily_Balances_NestedRowReasonID = null;
            DailyBal_NestedRowUniqueID = null;
