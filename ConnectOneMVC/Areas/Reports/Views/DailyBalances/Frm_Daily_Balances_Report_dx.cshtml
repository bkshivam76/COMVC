<div class="DailyBalance_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    @model IEnumerable<dynamic>
    @{

        Layout = null;
        string xView_Sel_Id = ViewBag.xView_Sel_Id;
        string xStatus_Choice = ViewBag.xStatus_Choice;
        string BankNamewithAc = ViewBag.BankName;
        string BankAccNo = ViewBag.BankAccNo;
        string UserType = (string)ViewBag.UserType;
        bool DailyBalances_ExportRight = (bool)ViewData["DailyBalances_ExportRight"];
        bool Help_Attachment_AddRight = (bool)ViewData["Help_Attachment_AddRight"];//attachment
        bool Help_Attachment_EditRight = (bool)ViewData["Help_Attachment_EditRight"];//attachment
        bool Help_Attachment_ViewRight = (bool)ViewData["Help_Attachment_ViewRight"];//attachment
        bool Help_Attachment_DeleteRight = (bool)ViewData["Help_Attachment_DeleteRight"];//attachment
        bool DailyBalReport_Auto_Vouching_Mode = (bool)ViewData["DailyBalReport_Auto_Vouching_Mode"];

    }
    <style>
        #lbldbtext {
            font-size: 15px;
            line-height: 21px;
            padding: 3px 5px 0
        }
    </style>
    <div id="Daily_Balances_ParentDiv">
        <div class="report_header_div_main">
            <div id="contentDaily_Balances" class="col-md-12 report_header_div_main">
                <div class="col-md-8 padd report_header_div">
                    <label class="report_header_label" id="lbldbtext">@ViewBag.Txt_TitleX</label>
                </div>
                @*Buttons*@
            <div class="report_button_div">
                @(Html.DevExtreme().Switch().ID("dailyBalanceVouchingModeSwitch").SwitchedOnText("Vouching On").SwitchedOffText("Vouching Off").OnValueChanged("DailyBalance_VouchingSwitch_ValueChange").Width(100))
                @(Html.DevExtreme().Switch().ID("dailyBalanceViewModeSwitch").SwitchedOnText("Compact").SwitchedOffText("Default").OnValueChanged("dailyBalance_ViewSwitch_ValueChange").Width(70))
                @(Html.DevExtreme().Button().ID("dailyBalancesEdit").Text("Edit").OnClick(@<text> function () { EditClick_DB(); } </text>) )
                @(Html.DevExtreme().Button().ID("dailyBalancesDelete").Text("Delete").OnClick(@<text> function () { DeleteClick_DB(); } </text>) )
                @(Html.DevExtreme().Button().ID("dailyBalancesView").Text("View").OnClick(@<text> function () { ViewClick_DB(); } </text>) )
                @(Html.DevExtreme().Button().ID("dailyBalancesModelOptions").Text("Options").OnClick(@<text> function () { OptionsClick_DB(); } </text>) )
                @(Html.DevExtreme().Button().ID("DailyBalancesModelSave").Icon("fa fa-check").Text("Save").OnClick(@<text> function () { OnSaveClick_DB(); } </text>) )
                @(Html.DevExtreme().Button().ID("DailyBalancesModelListPreview").Text("Export").Icon("save").Width(80).OnClick(@<text> function () { OnListPreviewClick_DB(); } </text>) )
                @(Html.DevExtreme().Button().ID("DailyBalanceToggleScrollBar").Text(ViewBag.ShowHorizontalBar == 1 ? "Default Data" : "Full Data").Width(ViewBag.ShowHorizontalBar == 1 ? 110 : 90).Icon("toolbox").OnClick(@<text> function () { DailyBalance_changeMode(); } </text>))
                @(Html.DevExtreme().Button().ID("btnDailyBalanceLinkAttachment").Text("Link By Sr No").Icon("unpin").OnClick(@<text> function () {OnDailyBalanceLinkAttachmentSrNo();}</text>))
                @(Html.DevExtreme().Button().ID("btnDailyBalanceLinkAttachmentFileName").Text("Link By File Name").Icon("unpin").OnClick(@<text> function () {OnDailyBalanceLinkAttachmentFileName();}</text>))
                @(Html.DevExtreme().Button().ID("DailyBalancesModelCLOSE").Text("Close").Icon("clear").OnClick("CloseDailyBalance") )
            </div>
            </div>
        </div>
        <div id="Daily_Balances_GRID_DIV" class="parent_table">
            <form id="DailyBalncereloadPartialView">
                @Html.Partial("Frm_Daily_Balances_Info_Grid_dx")
            </form>
        </div>
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-12" style="text-align:right">
                    <div class="row">
                        <div class="col-sm-8 col-md-8 col-lg-8 pll">
                            <label class="control-label" style="text-align:right">Balance as per Txn Dates(in Rs.) :</label>
                        </div>
                        <div class="col-sm-4 col-md-4 col-lg-4 prm ">
                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("SetTxnBalance").Name("SetTxnBalance").ReadOnly(true))
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-8 col-md-8 col-lg-8 pll" style="text-align:right"><label class="control-label">Nett Difference(in Rs.):</label></div>
                        <div class="col-sm-4 col-md-4 col-lg-4 prm ">
                            @(Html.DevExtreme().TextBox() .ID("SetNetbalance") .Name("SetNetbalance").ReadOnly(true))
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-sm-8 col-md-8 col-lg-8 pll" style="text-align:right"><label class="control-label">Balance as per Clearing Dates(in Rs.) :</label></div>
                        <div class="col-sm-4 col-md-4 col-lg-4 prm ">
                            @(Html.DevExtreme().TextBox() .ID("SetClearingDate") .Name("SetClearingDate").ReadOnly(true) )
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    @Html.Partial("AttachmentFAB", "Daily_BalancesPrf_FAB,Daily_Balances_ParentDiv,Type1,Daily_Balances," + UserType) @*fab buttons*@

      
<script>
        var DailyBalance_IsVouchingMode = false;
        var DailyBalance_layout = null;
        var DailyBalance_ViewMode = "Default";
        var DailyBalReport_SetVouchingModeOn = "@DailyBalReport_Auto_Vouching_Mode" == "True" ? true : false;
        var DB_ITR_Date;
        var DB_Item;
        var DB_Mode;
        var DB_RefNo;
        var DB_Party;
        var DB_Instrumentdate;
        var DB_Clearingdate;
        var DB_Debit;
        var DB_Credit;
        var DB_Balance;
        var DB_iREC_ID;
        var DB_iTR_M_ID;
        var DB_iTR_TempID;
        var DailyBalance_ShowHorizontalBar = parseInt("@ViewBag.ShowHorizontalBar");
        var DailyBalancesListGrid = null;
        var VisibleColumns_DailyBalancesListGrid = [];
        var Expanded_Row_Key_DB_dx = null;
        var otherCondition_DB = "@ViewBag.OtherCondition";
        var Led_ID_DB  = "@ViewBag.Led_ID";
        var DisplayType_DB  = "@ViewBag.DisplayType";
        var Bank_Acc_ID_DB  = "@ViewBag.Bank_Acc_ID";
        var FromDate_DB = "@ViewBag.FromDate";
        var ToDate_DB = "@ViewBag.ToDate";
        var changesList_DB = [];
        var DB_Grid_PK = null;
        var Daily_Balances_IsDetailRowExpanded = false;
        var Daily_Balances_NestedRecord_FocusedRowIndex = -1;
        var Daily_Balances_NestedGrid_AccessID;
        var Daily_Balances_AtachmentID;
        var Daily_Balances_FileName;
        var Daily_Balances_ParamMandatory;
        var Daily_Balances_FromDateLabel;
        var Daily_Balances_ToDateLabel;
        var Daily_Balances_DescriptionLabel;
        var Daily_Balances_Doc_ID;
        var Daily_Balances_Doc_Category;
        var Daily_Balances_MasterRowRecID;
        var Daily_Balances_MasterRowMID;
        var Daily_Balances_NestedRowMapID;
        var Daily_Balances_reason;
        var Daily_Balances_Attachment_RecStatus;
        var Daily_Balances_RecID_ForAttachment;
        var Daily_Balances_NestedRowReasonID;
    var DailyBal_NestedRowUniqueID;
    var invalidRowKey_DailyBalances=null;

        $(document).ready(function ()
        {
            if ("@DailyBalances_ExportRight" == "False")
            {
	            $("#DailyBalancesModelListPreview").hide();
            }
            if (LoginUserType != "SUPERUSER" && LoginUserType != "AUDITOR")
            {
                $("#dailyBalanceVouchingModeSwitch").dxSwitch("instance").option("visible", false);
                $("#dailyBalanceViewModeSwitch").dxSwitch("instance").option("visible", false);
            }
            if (DailyBalReport_SetVouchingModeOn == true) {
                $("#dailyBalanceViewModeSwitch").dxSwitch("instance").option("value", true);
            }
        });
        function DailyBalance_VouchingSwitch_ValueChange(e)
        {
            DailyBalance_IsVouchingMode = e.value;
            if (DailyBalReport_SetVouchingModeOn == true)
            {
                DailyBalReport_SetVouchingModeOn = false;
            }
            else
            {
                Daily_BalancesPrf_FAB.SetVisible(false);
            }
            if (DailyBalance_IsVouchingMode == true) {
                OpenRightPane();
                ClearLeftPane();
                OpenLeftPane();
            }
            else {
                CloseRightPane();
                ClearLeftPane();
                CloseLeftPane();
            }
            DailyBalancesListGrid.clearSelection();
            DailyBalancesListGrid.option("masterDetail.enabled", !DailyBalance_IsVouchingMode)
            DailyBalancesListGrid.repaint();
        }
        async function dailyBalance_ViewSwitch_ValueChange(e)
        {
            DailyBalance_ViewMode = e.value == false ? "Default" : "Compact";
            if (DailyBalReport_SetVouchingModeOn == true)
            {
                $("#dailyBalanceVouchingModeSwitch").dxSwitch("instance").option("value", true);
            }
            Daily_BalancesPrf_FAB.SetActionContext("AddAttachmentContext", false); //check it
            if (Expanded_Row_Key_DB_dx != null && Expanded_Row_Key_DB_dx.length > 0)
            {
                await DailyBalancesListGrid.collapseRow(Expanded_Row_Key_DB_dx)
            }
            DailyBalancesListGrid.beginUpdate();
            var columns = DailyBalancesListGrid.option("columns");
            if (DailyBalance_ViewMode == "Compact")
            {
                VisibleColumns_DailyBalancesListGrid = [];
                for (var i = 0; i < columns.length; i++)
                {
                    var name = columns[i].dataField;
                    var ColumnVisible = DailyBalancesListGrid.columnOption(name, "visible");
                    if (name == "DailyBalancesListGrid_dx_Compact_Column")
                    {
                        DailyBalancesListGrid.columnOption(name, "visible", true);
                    }
                    else if (ColumnVisible == true && name != "iIcon")
                    {
                        VisibleColumns_DailyBalancesListGrid.push(name);
                        DailyBalancesListGrid.columnOption(name, "visible", false);
                    }
                }
            }
            else
            {
                DailyBalancesListGrid.columnOption("DailyBalancesListGrid_dx_Compact_Column", "visible", false);
                for (var i = 0; i < VisibleColumns_DailyBalancesListGrid.length; i++)
                {
                    DailyBalancesListGrid.columnOption(VisibleColumns_DailyBalancesListGrid[i], "visible", true);
                }
            }
            DailyBalancesListGrid.repaint();
            DailyBalancesListGrid.endUpdate();
        }
        function DailyBalance_changeMode()
        {
            DailyBalancesListGrid.beginUpdate();
            if (DailyBalance_ShowHorizontalBar == 0)
            {
                DailyBalance_ShowHorizontalBar = 1;
                $("#DailyBalanceToggleScrollBar").find("span").text("Default Data");
                $("#DailyBalanceToggleScrollBar").width(110);
                DailyBalancesListGrid.option("columnHidingEnabled", false);
                DailyBalancesListGrid.option("allowColumnResizing", true)
            }
            else
            {
                DailyBalance_ShowHorizontalBar = 0;
                $("#DailyBalanceToggleScrollBar").find("span").text("Full Data");
                $("#DailyBalanceToggleScrollBar").width(90);
                DailyBalancesListGrid.option("columnHidingEnabled", true)
                DailyBalancesListGrid.option("allowColumnResizing", false)
            }
            DailyBalancesListGrid.endUpdate();
        }
        function OnListPreviewClick_DB()
        {
            if ("@DailyBalances_ExportRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
                return;
            }
            $.ajax({
                type: 'GET',
                url: "/Reports/DailyBalances/Frm_Export_Options_dx",
                data:
                {
                    GridName:"DailyBalancesListGrid",
                    title:"@ViewBag.Txt_TitleX"
                },
                cache: false,
                success: function (data)
                {
                    OpenPopup("report_export_modal", "Export Option", null, "auto", 125,true,data);
                }
            });
        }
        function OnPrintChequeClick_DB()
        {
            if (DisplayType_DB == "CASH") {
                DevExpress.ui.dialog.alert('This functionality is for Bank Report only !!', 'Alert ');
                return;
            }
            if (DB_Grid_PK == null)
            {
                DevExpress.ui.dialog.alert('Please Select A Row', 'Alert ');
                return;
            }
            if (DB_Grid_PK == "NullOPENING BALANCE")
            {
                DevExpress.ui.dialog.alert('This functionality is not for Opening Balance', 'Alert ');
                return;
            }
              $.ajax({
                type: 'Get',
                  url: "/Reports/DailyBalances/ChequePrinting",
                data:
                {
                    Party: DB_Party,
                    Amount: DB_Credit ,
                    VchDate: DB_Instrumentdate
                },
                cache: false,
                success: function (data)
                {
                    OpenPopup("ChequePrinting", "Cheque Printing",null, "auto", "100%", true, data);
                }
            });
    }
    function EditClick_DB()
    {
        if (DB_Grid_PK == null)
        {
            DevExpress.ui.dialog.alert('Please select Entry to be Edited', 'Alert ');
            return;
        }
        Vouchers_Edit_TxnEntryID(DB_iREC_ID, "Daily Balances", "DailyBalancesListGrid", DB_ITR_Date)
    }
    function DeleteClick_DB()
    {
        if (DB_Grid_PK == null) {
            DevExpress.ui.dialog.alert('Please select Entry to be Edited', 'Alert ');
            return;
        }
        Vouchers_Delete_TxnEntryID(DB_iREC_ID, "Daily Balances", "DailyBalancesListGrid", DB_ITR_Date)
    }
    function ViewClick_DB()
    {
        if (DB_Grid_PK == null) {
            DevExpress.ui.dialog.alert('Please select Entry to be Edited', 'Alert ');
            return;
        }
        Vouchers_View_TxnEntryID(DB_iREC_ID, "Daily Balances", "DailyBalancesListGrid", DB_ITR_Date)
    }
        function OnDailyBalanceLinkAttachmentSrNo(BySrNo = true) {
            if (DailyBalancesListGrid.getSelectedRowsData() < 1) {
                DevExpress.ui.dialog.alert("Please Select Main Grid Row..", "Error");
                return;
            }
            var RefID = "";
            if (DB_iTR_M_ID != null && DB_iTR_M_ID != "") {
                RefID = DB_iTR_M_ID;
            }
            else if (DB_iREC_ID != null && DB_iREC_ID != "") {
                RefID = DB_iREC_ID;
            }
            LinkAttachmentBySrNo(RefID, "Accounts_CashBook", "DailyBalancesListGrid", GetRowIndexAsPerDataSource("DailyBalancesListGrid", "dxDataGrid", DailyBalancesListGrid.getSelectedRowKeys()), "", BySrNo)
        }
        function OnDailyBalanceLinkAttachmentFileName() {
            OnDailyBalanceLinkAttachmentSrNo(false);
        }

    async function OnSaveClick_DB(SaveClick = true, close = false)
        {
            DailyBalancesListGrid.clearFilter();
            var invalid = await restrict_ifInvalid_DailyBalance()
            if (invalid) { return }
            var result =  await DevExpress.ui.dialog.confirm("Do you want to save changes...?", "Daily Balances Report");
            if (result)
            {
                $.ajax({
                    type: 'POST',
                    url: "/Reports/DailyBalances/SaveClick_dx",
                    data: { updateList: JSON.stringify(changesList_DB) },
                    cache: false,
                    success: function (data)
                    {
                        if (data.result == true)
                        {
                            changesList_DB = [];
                            DailyBalancesListGrid.cancelEditData();
                            if (close == true)
                            {
                                $(".TabPanalMenu-tabs .active span").click()
                            }
                            else
                            {
                                DBListGrid_dx_Refresh();
                            }
                        }
                    }
                });
            }
            else
            {
                if (SaveClick == false)
                {
                    changesList_DB = [];
                    DailyBalancesListGrid.cancelEditData();
                    DBListGrid_dx_Refresh();
                }
                if (close == true)
                {
                    changesList_DB = [];
                    DailyBalancesListGrid.cancelEditData();
                    $(".TabPanalMenu-tabs .active span").click()
                }
            }
        }
        function OptionsClick_DB()
        {
                $.ajax({
                    type: 'Get',
                    url: "/Reports/DailyBalances/Dialog_DailyBalances_dx",
                    data:
                    {
                        xSelModeIndex: DisplayType_DB == "CASH" ? 0 : 1,
                        xSelViewIndex: "@xView_Sel_Id",
                        xStatus_Choice: "@xStatus_Choice",
                        Bank_Acc_ID: Bank_Acc_ID_DB,
                        ViaOptionClick:true
                    },
                    cache: false,
                    success: function (data)
                    {
                        OpenDynamicPopup("Daily Balances Report", null, "auto", 500,true,data);
                    }
                });
        }
        async function OnReconsilebyClearingDate_DB()
        {
            if (DB_Grid_PK == null)
            {
                DevExpress.ui.dialog.alert('Please select a row', 'Alert ');
                return;
            }
            var invalid = await restrict_ifInvalid_DailyBalance(DB_Grid_PK)
            if (invalid) { return }
            if (DisplayType_DB == "CASH") {
                DevExpress.ui.dialog.alert('Reconciliation can be done in Bank Report only !!', 'Alert ');
                return;
            }
            if (DB_Clearingdate==null||DB_Clearingdate == "")
            {
                DevExpress.ui.dialog.alert('Clearing Date  is Incorrect !!', 'Alert ');
                return;
            }
            $.ajax({
                type: 'Get',
                url: "/Reports/DailyBalances/Frm_Bank_Reconcile_dx",
                data:
                {
                    lblTxnBalance: DB_Balance,
                    xDate: DB_Clearingdate ,
                    xBankAccID: Bank_Acc_ID_DB
                },
                cache: false,
                success: function (data)
                {
                    OpenPopup("popup_frm_Reconcile", "@BankNamewithAc",null, "auto", 750, true, data);
                }
            });
        }
        async function OnReconsilebyTxnDate_DB()
        {
            //var invalid = await restrict_ifInvalid_DailyBalance()
            //if (invalid) {return }
            if (DisplayType_DB == "CASH")
            {
                DevExpress.ui.dialog.alert('Reconciliation can be done in Bank Report only !!', 'Alert ');
                return;
            }
            if (DB_ITR_Date==null||DB_ITR_Date=="")
            {
                DevExpress.ui.dialog.alert('Txn Date  is Incorrect !!', 'Alert ');
                return;
            }
            $.ajax({
                type: 'Get',
                url: "/Reports/DailyBalances/Frm_Bank_Reconcile_dx",
                data:
                {
                    lblTxnBalance: DB_Balance,
                    xDate:DB_ITR_Date ,
                    xBankAccID: Bank_Acc_ID_DB
                },
                cache: false,
                success: function (data)
                {
                    OpenPopup("popup_frm_Reconcile", "@BankNamewithAc",null, "auto", 750, true, data);
                }
            });
        }

        async function CloseDailyBalance()
        {
            var invalid = await restrict_ifInvalid_DailyBalance()
            var hasChanges = hasChanges_DailyBalance()
            if (invalid) { return }
            if (hasChanges)
            {
                OnSaveClick_DB(true, true);
            }
            else
            {
                $(".TabPanalMenu-tabs .active span").click()
            }
        }
        $(".TabPanalMenu-tabs .active span").on("click", async function (e) {

            var invalid = await restrict_ifInvalid_DailyBalance()
            var hasChanges = hasChanges_DailyBalance()
            if (invalid) { return }
            if (hasChanges) {
                e.stopImmediatePropagation();
                OnSaveClick_DB(true, true);
            }
            else
            {
                DxGrid_EventsOnScreenClose(DailyBalancesListGrid)
                $.ajax({
                    type: 'GET',
                    url: "/Reports/DailyBalances/SessionClear_Report",
                    cache: false
                });
                CloseRightPane();
                ClearLeftPane();
                CloseLeftPane();
                ClearAllReferences_DailyBalance();
            }
        });
