                        CloseRightPane();
                        ClearRightPane();
                    }
                }
            }
            Daily_Balances_NestedRowReasonID  = values["ReasonID"];
            IndexAttachmentReasonID = Daily_Balances_NestedRowReasonID ;
        }

        function LeftPaneContent_DailyBalancesListGrid(GridName, RecID, MID, vouchingMode, AllColumns = 0, key = "") {
            $("#LeftPane_Div_Content").html(null);
            $("#LeftPane_Div_Content").append("<div class='col-xs-12'><label>Documents Attached:</label><div class='AttachmentGrid'><form></form></div></div><div class='col-xs-12'><label>Additional Info:</label><div class='AdditionalInfoGrid'><form></form></div></div>")
            DailyBalancesListGrid_dx_Detail($("#LeftPane_Div_Content .AttachmentGrid>form"), GridName, RecID, vouchingMode, AllColumns, key)
            setTimeout(function () {
                AdditionalInfoGrid_DailyBalances_dx($("#LeftPane_Div_Content .AdditionalInfoGrid>form"), GridName, RecID, MID, vouchingMode, AllColumns, key)
            })
        }
        function AdditionalInfoGrid_DailyBalances_dx(container, GridName, RecID, MID, vouchingMode, AllColumns, key = "") {
            var url = "/Reports/DailyBalances/Frm_Daily_Balances_Info_AdditionalGridData_dx?VouchingMode=" + vouchingMode + "&RecID=" + RecID + "&MID=" + MID
            DxGrid_CreateAdditionalInfoGrid(container, GridName, RecID, vouchingMode, AllColumns, url, key)
        }

        function SetBalances_DB(data) {
            let txnBalance = 0;
            let netBalance = 0;
            let clearingBalance = 0;
            for (var i = 0; i < data.length; i++) {
                if (data[i].Debit) {
                    txnBalance = txnBalance + data[i].Debit;
                    if (data[i].Clearingdate) {
                        clearingBalance = clearingBalance + data[i].Debit;
                    }
                }
                if (data[i].Credit) {
                    txnBalance = txnBalance - data[i].Credit;
                    if (data[i].Clearingdate) {
                        clearingBalance = clearingBalance - data[i].Credit;
                    }
                }
            }
            netBalance = txnBalance - clearingBalance;
            $("#SetTxnBalance").dxTextBox("option", "value", new Intl.NumberFormat("en-IN", { style: "currency", currency: "INR" }).format(txnBalance))
            $("#SetNetbalance").dxTextBox("option", "value", new Intl.NumberFormat("en-IN", { style: "currency", currency: "INR" }).format(netBalance))
            $("#SetClearingDate").dxTextBox("option", "value", new Intl.NumberFormat("en-IN", { style: "currency", currency: "INR" }).format(clearingBalance))
        }
        function clearingDateValidation_DB(options)
        {
            if (new Date(options.value) < new Date(options.data.Instrumentdate)) {
                return false;
            }
            return true
        }
        function clearingDateCustomSort_DB(value1, value2)
        {
            if (value1 == null && value2 == null)
            {
                return 0;
            }
            if (value1 == null) {
                return -1;
            }
            else
            {
                if (value2 == null)
                {
                    return 1;
                }
                else
                {
                    return value1.toISOString().localeCompare(value2.toISOString());
                }
            }
        }
        function hasChanges_DailyBalance()
        {
            if (changesList_DB != null && changesList_DB.length > 0)
            {
                var validEntries = changesList_DB.filter(x => x.valid == true);
                if (validEntries == null || validEntries.length == 0)
                {
                    return false
                }
                else
                {
                    var actualChanges = validEntries.filter(x => x.Cdate != x.orgValue)
                    if (actualChanges == null || actualChanges.length == 0)
                    {
                        return false
                    }
                }
            }
            else
            {
                return false
            }
            return true
        }
        function hasInvalidChanges_DailyBalance(_key = null)
        {
            if (changesList_DB != null && changesList_DB.length > 0)
            {
                var invalidEntries = changesList_DB.filter(x => x.valid == false && (_key == null || x.key == _key));
                if (invalidEntries == null || invalidEntries.length == 0)
                {
                    return null
                }
                else
                {
                    return invalidEntries
                }
            }
            else
            {
                return null
            }
            return null
        }
        async function restrict_ifInvalid_DailyBalance(_key=null)
        {
            var invalidEntries = hasInvalidChanges_DailyBalance(_key)
            if (invalidEntries != null && invalidEntries.length > 0)
            {
                await DevExpress.ui.dialog.alert('There are invalid clearing date cells', 'Alert ')
                invalidRowKey_DailyBalances= invalidEntries[0].key;
                await DailyBalancesListGrid.selectRows(invalidRowKey_DailyBalances)
                var rowIndex = DailyBalancesListGrid.getRowIndexByKey(invalidRowKey_DailyBalances)
                if (rowIndex > 0)
                {
                    highlightinvalidRow_DailyBalance(rowIndex, invalidRowKey_DailyBalances)
                    invalidRowKey_DailyBalances = null;
                }
                else
                {
                    await DailyBalancesListGrid.navigateToRow(invalidRowKey_DailyBalances)
                }
                return true;
            }
            else
            {
                return false;
            }
        }
        function highlightinvalidRow_DailyBalance(rowIndex,key)
        {
            var el = DailyBalancesListGrid.getCellElement(rowIndex, "Clearingdate")
            if (el)
            {
                DailyBalancesListGrid.focus(el)
                DailyBalancesListGrid.editCell(rowIndex, "Clearingdate");
            }
        }

        async function DBListGrid_dx_Refresh()
        {
            var invalid = await restrict_ifInvalid_DailyBalance()
            var hasChanges = hasChanges_DailyBalance();
            if (invalid) { return }
            if (hasChanges)
            {
                OnSaveClick_DB(false);
            }
            else
            {
                RefreshGridView("DailyBalancesListGrid")         
            }
        }
    </script>
    <script>
        function On_Daily_Balances_FABActionItemClick(s, e)
        {
            var img = document.getElementById('RightPane_Img');
            s.ExpandActionGroupItems();
            if (e.actionName === "add_attach")
            {
                if ("@Help_Attachment_AddRight" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                if (Daily_Balances_ParamMandatory == 1)
                {
                    AddAttachment(Daily_Balances_RecID_ForAttachment, "Accounts_CashBook", Daily_Balances_Doc_ID, Daily_Balances_Doc_Category, Daily_Balances_ParamMandatory, Daily_Balances_FromDateLabel, Daily_Balances_ToDateLabel, Daily_Balances_DescriptionLabel, "Daily_BalancesProfileAttachment", null, "DailyBalancesListGrid", Daily_Balances_NestedGrid_AccessID);
                }
                else
                {
                    Attachment_DirectBrowse(Daily_Balances_RecID_ForAttachment, "Accounts_CashBook", Daily_Balances_Doc_ID, "Daily_BalancesProfileAttachment", "DailyBalancesListGrid", Daily_Balances_NestedGrid_AccessID);
                }
            }
            else if (e.actionName === "edit_attach")
            {
                if ("@Help_Attachment_EditRight" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                if (Daily_Balances_Attachment_RecStatus.toUpperCase() == "LOCKED")
                {
                    DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                    return;
                }
                EditAttachment(Daily_Balances_RecID_ForAttachment, "Accounts_CashBook", Daily_Balances_AtachmentID, Daily_Balances_ParamMandatory, Daily_Balances_FromDateLabel, Daily_Balances_ToDateLabel, Daily_Balances_DescriptionLabel, "Daily_BalancesProfileAttachment", null, "DailyBalancesListGrid", Daily_Balances_NestedGrid_AccessID);
            }
            else if (e.actionName === "delete_attach")
            {
                if ("@Help_Attachment_DeleteRight" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                DeleteAttachment(Daily_Balances_RecID_ForAttachment, "Accounts_CashBook", Daily_Balances_AtachmentID, Daily_Balances_ParamMandatory, Daily_Balances_FromDateLabel, Daily_Balances_ToDateLabel, Daily_Balances_DescriptionLabel, null, "DailyBalancesListGrid", Daily_Balances_NestedGrid_AccessID, Daily_Balances_Attachment_RecStatus);
            }
            else if (e.actionName === "view_attach")
            {
                if ("@Help_Attachment_ViewRight" == "False")
                {
                    DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                    return;
                }
                ViewDocument(Daily_Balances_AtachmentID, Daily_Balances_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
            }
            else if (e.actionName == "Link_Attach")
            {
                LinkAttachment(Daily_Balances_RecID_ForAttachment, "Accounts_CashBook", "Daily Balances Report", "DailyBalancesListGrid", Daily_Balances_NestedGrid_AccessID);
            }
            else if (e.actionName === "Add_Reason")
            {
                if (Daily_Balances_Doc_Category.toLowerCase() == "others") {
                    DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
                }
                else {
                    AttachmentAddReason(Daily_Balances_RecID_ForAttachment, Daily_Balances_NestedRowMapID, "Accounts_CashBook", "DailyBalancesListGrid", Daily_Balances_NestedGrid_AccessID);
                }
            }
            else if (e.actionName === "Edit_Reason")
            {
                AttachmentEditReason(Daily_Balances_RecID_ForAttachment, Daily_Balances_NestedRowMapID, "Accounts_CashBook", "DailyBalancesListGrid", Daily_Balances_NestedGrid_AccessID, Daily_Balances_reason);
            }
            else if (e.actionName === "Delete_Reason")
            {
                AttachmentDeleteReason(Daily_Balances_RecID_ForAttachment, Daily_Balances_NestedRowMapID, "DailyBalancesListGrid", Daily_Balances_NestedGrid_AccessID);
            }
            else if (e.actionName == "AuditAction") {
                s.SetActionContext("AuditActionContext", true);
            }
            else if (e.actionName == "BackAudit") {
                if (Daily_Balances_Nested_Doc_Status == "") {
                    s.SetActionContext("AutoItemContext", true);
                }
                if (Daily_Balances_Nested_Doc_Status == "NO") {
                    s.SetActionContext("EditItemContext", true);
                }
                if (Daily_Balances_Nested_Doc_Status == "YES") {
                    s.SetActionContext("actionItemContext", true);
                }
            }
            else if (e.actionName === "Rotate")
            {
                ImageRotate(img);
            }
            else if (e.actionName === "ZoomOut")
            {
                ImageZoomOut(img);
            }
            else if (e.actionName === "ZoomIn")
            {
                ImageZoomIn(img);
            }
            else if (e.actionName == "Fit")
            {
                ImageFit(img);
            }
            else if (e.actionName == "Back")
            {
                ImageBack(s.uniqueID, "actionItemContext");
            }
            else if (e.actionName == "Accept")
            {
                OnDailyBalance_AcceptwithoutRemarks();
            }
            else if (e.actionName == "Reject")
            {
                OnDailyBalance_AcceptRejectVoucher("Reject");
            }
            else if (e.actionName == "AcceptWithRemarks")
            {
                OnDailyBalance_AcceptRejectVoucher("Accept");
            }
            else if (e.actionName == "AcceptDoc")
            {
                OnDailyBalance_AcceptDoc();
            }
            else if (e.actionName == "RejectDoc")
            {
                OnDailyBalance_RejectDoc();
            }
        }
        function OnDailyBalance_RejectDoc()
        {
        if (Daily_Balances_AtachmentID == null || Daily_Balances_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        RejectAttachment(Daily_Balances_AtachmentID, "DailyBalancesListGrid", Daily_Balances_NestedGrid_AccessID);
    }
        function OnDailyBalance_AcceptDoc() {
            if (Daily_Balances_AtachmentID == null || Daily_Balances_AtachmentID.length == 0) {
                DevExpress.ui.dialog.alert("No Document Attached..", "Error");
                return;
            }
            AcceptAttachment(Daily_Balances_AtachmentID, "DailyBalancesListGrid", Daily_Balances_NestedGrid_AccessID);
        }
        function OnDailyBalance_AcceptwithoutRemarks()
        {
            var Recid;
            if (Daily_Balances_IsDetailRowExpanded == true || DailyBalance_IsVouchingMode == true)
            {
                if (Daily_Balances_MasterRowMID == null || Daily_Balances_MasterRowMID == "")
                {
                    if (Daily_Balances_MasterRowRecID == null || Daily_Balances_MasterRowRecID == "")
                    {
                        Recid = (DB_iTR_M_ID == null || DB_iTR_M_ID == "") ? DB_iREC_ID : DB_iTR_M_ID;
                    }
                    else
                    {
                        Recid = Daily_Balances_MasterRowRecID;
                    }
                }
                else
                {
                    Recid = Daily_Balances_MasterRowMID;
                }
            }
            else
            {
                Recid = (DB_iTR_M_ID == null || DB_iTR_M_ID == "") ? DB_iREC_ID : DB_iTR_M_ID;
            }

            Entry_AcceptwithoutRemarks(Recid, "Report_Daily_Balances", "DailyBalancesListGrid", Daily_Balances_AtachmentID, Daily_Balances_NestedRowReasonID, DailyBal_NestedRowUniqueID);
        }
        function OnDailyBalance_AcceptRejectVoucher(_actionMethod)
        {
            var Recid;
            if (Daily_Balances_IsDetailRowExpanded == true || DailyBalance_IsVouchingMode == true)
            {
                if (Daily_Balances_MasterRowMID == null || Daily_Balances_MasterRowMID == "")
                {
                    if (Daily_Balances_MasterRowRecID == null || Daily_Balances_MasterRowRecID == "")
                    {
                        Recid = (DB_iTR_M_ID == null || DB_iTR_M_ID == "") ? DB_iREC_ID : DB_iTR_M_ID;
                    }
                    else
                    {
                        Recid = Daily_Balances_MasterRowRecID;
                    }
                }
                else
                {
                    Recid = Daily_Balances_MasterRowMID;
                }
            }
            else
            {
                Recid = (DB_iTR_M_ID == null || DB_iTR_M_ID == "") ? DB_iREC_ID : DB_iTR_M_ID;
            }
            Entry_AcceptReject(_actionMethod, Recid, "Report_Daily_Balances", "DailyBalancesListGrid", Daily_Balances_AtachmentID, Daily_Balances_NestedRowReasonID, DailyBal_NestedRowUniqueID);
        }

    </script>
