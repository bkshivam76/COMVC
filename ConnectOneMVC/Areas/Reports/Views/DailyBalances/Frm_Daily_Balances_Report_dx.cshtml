        function DailyBalancesListGrid_dx_OnEditorPrepared(e)
        {
            if (e.parentType == 'dataRow')
            {
                if (e.dataField == 'Clearingdate')
                {
                    const defaultValueChangeHandler = e.editorOptions.onValueChanged;
                    e.editorElement.dxDateBox('instance').option('onValueChanged', args =>
                    {
                        defaultValueChangeHandler(args)
                        let prevValue = args.previousValue == "" ? null : args.previousValue;
                        let key = e.row.key;
                        if (new Date(args.value) >= new Date(e.row.data.Instrumentdate) || args.value==null) {
                            var index = changesList_DB.findIndex(x => x.key == key);
                            if (index < 0)
                            {
                                changesList_DB.push(
                                    {
                                        "key": key,
                                        "Cdate": JS_Date_toIsoString(args.value, false),
                                        "orgValue": JS_Date_toIsoString(prevValue, false),
                                        "iREC_ID":e.row.data.iREC_ID,
                                        "TxnDate": e.row.data.ITR_Date,
                                        "Ref": e.row.data.RefNo,
                                        "Mode": e.row.data.Mode,
                                        "iTR_M_ID": e.row.data.iTR_M_ID,
                                        "valid": true
                                    });
                            }
                            else {
                                changesList_DB[index].Cdate = JS_Date_toIsoString(args.value, false);
                                changesList_DB[index].valid = true;
                            }
                            //var RowIndex = e.component.getRowIndexByKey(key)
                            //if (RowIndex>-1)
                            //{
                            //   e.component.cellValue(RowIndex, e.dataField, JS_Date_toIsoString(args.value, false))
                            //}
                            var DS = e.component.getDataSource()
                            var store = DS.store();
                            var dataIndex = store.__rawData.findIndex(x => x[store._key] == key);
                            if (dataIndex > 0) {
                                store.__rawData[dataIndex][e.dataField] = JS_Date_toIsoString(args.value, false)
                            }
                            SetBalances_DB(store.__rawData)
                            DailyBalancesListGrid_dx_SelectedRowData()
                        }
                        else
                        {
                            var index = changesList_DB.findIndex(x => x.key == key);
                            if (index < 0) {
                                changesList_DB.push({
                                    "key": key,
                                    "Cdate": JS_Date_toIsoString(args.value, false),
                                    "orgValue":JS_Date_toIsoString(prevValue, false),
                                    "valid": false
                                });
                            }
                            else {
                                changesList_DB[index].valid = false;
                            }
                        }
                    });
                }
            }
        }
