</script>
    <script>
        function DailyBalanceReport_DS() {
            // return new DevExpress.data.CustomStore({
            return new DevExpress.data.DataSource({
                key: "Grid_PK",
                loadMode: "raw",
                load: function (loadOptions) {
                    const deferred = $.Deferred();
                    $.ajax({
                        type: 'GET',
                        url: "/Reports/DailyBalances/Frm_Daily_Balances_Grid_Data",
                        data:
                        {
                            OtherCondition: otherCondition_DB,
                            Led_ID: Led_ID_DB,
                            DisplayType: DisplayType_DB,
                            Bank_Acc_ID: Bank_Acc_ID_DB,
                            FromDate: FromDate_DB,
                            ToDate: ToDate_DB
                        },
                        cache: false,
                        success: function (data) {
                            SetBalances_DB(data.GridData)
                            deferred.resolve(data.GridData);
                        }
                    });
                    return deferred.promise();
                },
                update: function (key, values) {

                }
            })
        }
        function DailyBalancesListGrid_dx_OnInitialized(e)
        {
            DxGrid_AdjustSize(e.component, $("#Daily_Balances_ParentDiv .report_button_div"))
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt)
            {
                DxGrid_AdjustSize(e.component, $("#Daily_Balances_ParentDiv .report_button_div"), "", evt)
            });
            DailyBalancesListGrid = e.component;
        }
        function DailyBalancesListGrid_dx_OnCellPrepared(e)
        {
            if (e.rowType == "data")
            {
                let GridName = e.element[0].id;
                let KeyValue = "";
                if (e.data.iREC_ID == "NOTE-BOOK") {
                    KeyValue = e.data.iTR_M_ID.ReplaceSpecialwith_() + e.data.iTR_ITEM_ID
                }
                else {
                    KeyValue = e.data.Grid_PK.ReplaceSpecialwith_()
                }
                if (e.column.type == "detailExpand")
                {
                    if (e.key == "NullOPENING BALANCE") {
                        $(e.cellElement[0].firstChild).css({ "display": "none" });
                    }
                }
                if (DailyBalance_IsVouchingMode == true)
                {
                    if (e.column.dataField === "iIcon")
                    {
                        $(e.cellElement).attr("onmouseover", "OnGridRowMouseHoverIn(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + KeyValue + "')");
                        $(e.cellElement).attr("onmouseout", "OnGridRowMouseHoverOut(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + KeyValue + "')");
                    }
                }
                if (e.column.dataField === "Balance")
                {
                    e.cellElement.css({ "background-color": "goldenrod" });
                }
                $(e.cellElement).attr("id", e.element[0].id + "_Cell_" + KeyValue + "|" + e.column.dataField);
            }
        }
        function DailyBalancesListGrid_dx_OnRowPrepared(e) {
            if (e.rowType == "data") {
                var GridName = e.element[0].id;
                let keyvalue = "";
                if (e.data.iREC_ID == "NOTE-BOOK") {
                    keyvalue = e.data.iTR_M_ID.ReplaceSpecialwith_() + e.data.iTR_ITEM_ID
                }
                else {
                    keyvalue = e.data.Grid_PK.ReplaceSpecialwith_()
                }
                $(e.rowElement).addClass(GridName + "_DataRow_" + keyvalue)
