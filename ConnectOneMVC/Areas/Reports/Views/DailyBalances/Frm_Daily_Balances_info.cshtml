        <label class="report_header_label" id="lbldbtext">@ViewBag.Headertext</label>
    </div>
    @*Buttons*@
    <div class="report_button_div">


        @(Html.DevExtreme().Button()
                                                        .ID("dailyBalancesModelOptions")
