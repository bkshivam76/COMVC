                                                        // .Icon("edit")
                                                        .Visible(true)
                                                        .Disabled(false)
                                                        .OnClick(@<text>
                                                            function () {
                                                            OptionsClick();
                                                            }
                                                        </text>)
        )


        @(Html.DevExtreme().Button()
                                                    .ID("DailyBalancesModelSave")
                                                    .Icon("fa fa-check")
                                                    .Text("Save")
                                                    //.Visible(true)
                                                    //.Disabled(true)
                                                    .OnClick(@<text>
                                                        function () {
                                                        OnSaveClick();
                                                        }
                                                    </text>)
        )

        @(Html.DevExtreme().Button()
                                                                            .ID("DailyBalancesModelListPreview")
                                                                            .Text("Export")
                                                                            .Icon("save")
