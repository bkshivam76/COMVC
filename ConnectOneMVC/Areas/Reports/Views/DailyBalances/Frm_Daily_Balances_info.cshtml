        var Headertext = ViewBag.Headertext;
        var Balance = ViewBag.Balances;
        var Output = ViewBag.Outputradio;
        var Status = ViewBag.Statusradio;

        bool DailyBalances_ExportRight=(bool)ViewData["DailyBalances_ExportRight"];
