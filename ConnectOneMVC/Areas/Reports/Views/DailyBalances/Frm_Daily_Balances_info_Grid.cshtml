        settings.CustomColumnSort += (s, e) =>
        {
            MVCxGridView gv = (MVCxGridView)s;
            bool isRow1Selected = gv.Selection.IsRowSelectedByKey(e.GetRow1Value(gv.KeyFieldName));
            bool isRow2Selected = gv.Selection.IsRowSelectedByKey(e.GetRow2Value(gv.KeyFieldName));
            e.Handled = isRow1Selected != isRow2Selected;
            if (e.Handled)
            {
                e.Result = isRow1Selected ? -1 : 1;
            }
        };
        settings.CustomColumnSort = (s, e) =>
        {
            MVCxGridView grid = (MVCxGridView)s;
            if (grid.VisibleRowCount > 0)
            {
                if (e.Column.FieldName == "Clearingdate")
                {
                    e.Handled = true;
                }
                var d1 = (DateTime)e.Value1;
                var d2 = (DateTime)e.Value2;
                if (d1 == DateTime.MinValue && d2 == DateTime.MinValue)
                {
                    e.Result = 0;
                    return;
                }
                if (d1 == DateTime.MinValue)
                {
                    e.Result = 1;
                }
                else
                {
                    if (d2 == DateTime.MinValue)
                    {
                        e.Result = -1;
                    }
                    else
                    {
                        e.Result = System.Collections.Comparer.Default.Compare(d1, d2);
                    }
                }
            }
        };
