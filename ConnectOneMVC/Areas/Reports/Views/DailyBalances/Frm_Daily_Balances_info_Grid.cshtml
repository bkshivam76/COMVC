                grid.DataColumns["Instrumentdate"].Visible = true;
                grid.DataColumns["Debit"].Visible = true;
                grid.DataColumns["Credit"].Visible = true;
                grid.DataColumns["Balance"].Visible = true;

                grid.DataColumns["iTR_TEMP_ID"].Visible = false;
                grid.DataColumns["Grid_PK"].Visible = false;
                grid.DataColumns["iREC_ID"].Visible = false;
                grid.DataColumns["iTR_ITEM_ID"].Visible = false;
                grid.DataColumns["iCOMPLETE_ATTACH_COUNT"].Visible = false;
                grid.DataColumns["iRESPONDED_COUNT"].Visible = false;
                grid.DataColumns["iREQ_ATTACH_COUNT"].Visible = false;
                grid.DataColumns["iOTHER_ATTACH_CNT"].Visible = false;
                grid.DataColumns["iALL_ATTACH_CNT"].Visible = false;
                //if (ColumnTobeHidden != null && ColumnTobeHidden.Count > 0)
                //{
                //    for (int i = 0; i < ColumnTobeHidden.Count; i++)
                //    {
                //        grid.DataColumns[Convert.ToInt32(ColumnTobeHidden[i])].Visible = false;
                //    }
                //}
                //if (ColumnTobeShown != null && ColumnTobeShown.Count > 0)
                //{
                //    for (int i = 0; i < ColumnTobeShown.Count; i++)
                //    {
                //        grid.DataColumns[Convert.ToInt32(ColumnTobeShown[i])].Visible = true;
                //    }
                //}
            }

            foreach (GridViewDataColumn column in grid.DataColumns)
            {
                if (ViewMode != "Compact")
                {
                    if (ColumnTobeHidden.Contains(column.Index.ToString()))
                    {
                        column.Visible = false;
                    }
                    if (ColumnTobeShown.Contains(column.Index.ToString()))
                    {
                        column.Visible = true;
                    }
                }
                if (column.Visible)
                {
                    if (column.FieldName == "Clearingdate")
                    {
                        column.Settings.AllowSort = DefaultBoolean.True;
                        column.Settings.SortMode = DevExpress.XtraGrid.ColumnSortMode.Custom;
                    }
                    if (column.FieldName == "Balance")
                    {
                        column.Settings.AllowSort = DefaultBoolean.True;
                    }
                    else
                    {
                        column.Settings.AllowSort = DefaultBoolean.False;
                    }
                }
            }
        };
        settings.Init = (s, e) =>
        {
            MVCxGridView grid = (MVCxGridView)s;

            if (ViewMode == "Compact")
            {
                grid.DataColumns["DailyBalance_Compact_Column"].Visible = true;
                grid.DataColumns["ITR_Date"].Visible = false;
