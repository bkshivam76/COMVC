        {
            if (e.MenuType == GridViewContextMenuType.Rows)
            {
                var Txnitem = e.CreateItem("Reconsile by Txn.Date", "ReconsilebyTxnDate");
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Txnitem);

                var Clearingitem = e.CreateItem("Reconsile by Clearing Date", "ReconsilebyClearingDate");
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Clearingitem);



