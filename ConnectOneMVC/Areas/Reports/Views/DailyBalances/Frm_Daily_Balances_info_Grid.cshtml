            }

            grid.DetailRowGetButtonVisibility += (sender, args) =>
            {
                var MasterGrid = (MVCxGridView)sender;
                string Item = MasterGrid.GetRowValues(args.VisibleIndex, "Item") == null ? "" : (string)MasterGrid.GetRowValues(args.VisibleIndex, "Item");

                if (Item.ToUpper() == "OPENING BALANCE")//opening balance row
                {
                    args.ButtonState = GridViewDetailRowButtonState.Hidden;
                }
