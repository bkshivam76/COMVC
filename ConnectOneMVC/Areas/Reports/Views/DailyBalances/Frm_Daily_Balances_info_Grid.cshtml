                {
                    grid.DataColumns["Mode"].Visible = false;
                    grid.DataColumns["RefNo"].Visible = false;
                    grid.DataColumns["Clearingdate"].Visible = false;
                }
                grid.DataColumns["Party"].Visible = false;
                grid.DataColumns["Instrumentdate"].Visible = false;
                grid.DataColumns["Debit"].Visible = false;
                grid.DataColumns["Credit"].Visible = false;
                grid.DataColumns["Balance"].Visible = false;

