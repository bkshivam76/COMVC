@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
            .ID("Frm_Profile_Win_GLookUp_bankList_datagrid")
          
            .Columns(columns =>
            {
                columns.Add().DataField("BANK_NAME").Caption("BANK_NAME");
                columns.Add().DataField("BANK_BRANCH").Caption("BANK_BRANCH");
                columns.Add().DataField("BANK_ACC_NO").Caption("BANK_ACC_NO");
                columns.Add().DataField("BA_ID").Caption("BA_ID").Visible(false);

})
           
            .Selection(s => s.Mode(SelectionMode.Single))
           
)




