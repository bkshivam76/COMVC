<div class="DailyBalanceChangePeriod_ClearReference">
@using DevExtreme.AspNet.Mvc;
@model ConnectOneMVC.Areas.Reports.Models.DB_SpeceficPeriod



@{
    /**/

    Html.EnableClientValidation();
    Html.EnableUnobtrusiveJavaScript();
    Html.AntiForgeryToken();
}


<link href="/content/fontawesome/css/fontawesome-all.css" rel="stylesheet">
<div>
    @using (Ajax.BeginForm("GetSpecificPeriod", "Voucher",
           new AjaxOptions
           {
               HttpMethod = "POST",
               InsertionMode = InsertionMode.InsertAfter,
               OnBegin = "AjaxBeginFormPost",
               OnSuccess = "Frm_Change_Period_Success_DB"
           },
            new
            {
                id = "id_Frm_Change_Period_Screen_DB",
                @class = "edit_form"
            }))
    {
        using (Html.DevExtreme().ValidationGroup())
        {
            <div class="row">
                <div class="form-field">
                    <div class="container-fluid ">
                        <div class="row">
                            <div class="col-sm-3 col-md-3 col-lg-3 pll"><label class="control-label  text-red" for="Name">From:</label></div>
                            <div class="col-sm-9 col-md-9 col-lg-9 prm">

                                @(Html.DevExtreme().DateBox().CustomDateBox().ID("DB_Fromdate").Name("DB_Fromdate").Value(Model.DB_Fromdate).InvalidDateMessage("Value must be a Date!!").TabIndex(1))
                            </div>

                        </div>
                    </div>
                </div>
                <div class="form-field">
                    <div class="container-fluid ">
                        <div class="row">
                            <div class="col-sm-3 col-md-3 col-lg-3 pll"><label class="control-label  text-red" for="Name">To:</label></div>
                            <div class="col-sm-9 col-md-9 col-lg-9 prm">

                                @(Html.DevExtreme().DateBox().CustomDateBox().ID("DB_Todate").Name("DB_Todate").Value(Convert.ToDateTime(Model.DB_Todate)).InvalidDateMessage("Value must be a Date!!").TabIndex(2) )
                            </div>

                        </div>
                    </div>
                </div>
            </div><!--[row]-->
            <div class="col-sm-12 col-md-12 col-lg-12">
                <div class="styleActionBtn">
                    @(Html.DevExtreme().Button().ID("DBChangePeriod").Text("Ok").Icon("fa fa-check-circle fa-w-16 btn-icons checkgreen").FocusStateEnabled(true).TabIndex(3).UseSubmitBehavior(true) )
                    @(Html.DevExtreme().Button().ID("DBChangePeriodCancel").Text("Cancel").Icon("fa fa-times-circle fa-w-16 btn-icons crossgrey").FocusStateEnabled(true).TabIndex(4).OnClick(@<text> function () { $("#PopupDB_speceficPeriod").dxPopup("hide"); } </text>) )
             
            </div>
        </div><!--[button]-->
        }
    }
</div>
<script>
</script>

    </div>



