        settings.Settings.ShowGroupedColumns = false;
        settings.Settings.ShowFooter = false;
        settings.ClientSideEvents.Init = "Item_InfoOnInit";
        settings.ClientSideEvents.BeginCallback = "OnGridItem_InfoListGrid_BeginCallback";
