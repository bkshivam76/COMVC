        LedgerReport_TR_M_ID = MainGridRowValues[0];
        LedgerReport_REC_ID = MainGridRowValues[1];
            LedgerReport_iTR_TEMP_ID = MainGridRowValues[2];
            if (LedgerReport_iTR_TEMP_ID == "Opening_Balance")
