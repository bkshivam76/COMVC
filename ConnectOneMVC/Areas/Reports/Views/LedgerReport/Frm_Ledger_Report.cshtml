    function OnLedgerReportGridFocusedRowChanged(s, e) {
            var key = s.GetRowKey(s.GetFocusedRowIndex());
            LedgerReportListGrid.GetValuesOnCustomCallback({ key: key }, LedgerReportOnGetRowValues);
        }

        function LedgerReportOnGetRowValues(LedgerReportData) {
            var values = LedgerReportData.split("![");
            LedgerReportID = values[0];
            LedgerReport_EditDate = values[1];
            LedgerReport_AddDate = values[2];
            LedgerReport_AddBy = values[3];
            LedgerReport_EditBy = values[4];
            LedgerReport_ActionStatus = values[5];
            LedgerReport_UpdateFooterDetail(LedgerReportID, LedgerReport_ActionStatus, LedgerReport_AddDate, LedgerReport_AddBy,
            '', '', LedgerReport_EditDate, LedgerReport_EditBy);
        }

        function LedgerReport_UpdateFooterDetail(LedgerReportID, LedgerReport_Action_Status, LedgerReport_Add_Date, LedgerReport_Add_By, LedgerReport_Action_Date, LedgerReport_Action_By, LedgerReport_Edit_Date, LedgerReport_Edit_By) {
            LedgerReport_Action_Date = LedgerReport_Action_Date != "" && LedgerReport_Action_Date != null ? LedgerReport_Action_Date : LedgerReport_Action_Date;
            LedgerReport_Edit_Date = LedgerReport_Edit_Date != "" && LedgerReport_Edit_Date != null ? LedgerReport_Edit_Date : LedgerReport_Edit_Date;
            LedgerReport_Add_Date = LedgerReport_Add_Date != "" && LedgerReport_Add_Date != null ? LedgerReport_Add_Date : LedgerReport_Add_Date;
            $.ajax({
                type: 'GET',
                url: "/Reports/ItemList/CreationDetail",
                data: {
                    Xrow: LedgerReportID, Action_Status: LedgerReport_Action_Status, Add_Date: LedgerReport_Add_Date,
                    Add_By: LedgerReport_Add_By, Action_Date: LedgerReport_Action_Date, Action_By: LedgerReport_Action_By, Edit_Date: LedgerReport_Edit_Date, Edit_By: LedgerReport_Edit_By
                },
                cache: false,
                success: function (LedgerReportLbl_result) {
                    $('#LedgerReportLbl_Status').text(LedgerReportLbl_result.Lbl_Status);
                    $('#LedgerReportLbl_Create').text(LedgerReportLbl_result.Lbl_Create);
                    $('#LedgerReportLbl_Modify').text(LedgerReportLbl_result.Lbl_Modify);
                    if (LedgerReportLbl_result.Lbl_Status_Color != "") {
                        $('#LedgerReportLbl_Status').css('color', LedgerReportLbl_result.Lbl_Status_Color);
                    }
                    if (LedgerReportLbl_result.Pic_Status != "") {
                        $('#LedgerReport_LockICON').css('class', LedgerReportLbl_result.Pic_Status);
                    }

                }
            });
        }

    function OnLedgerReportListPreviewClick()
    {
        if ("@LedgerReport_ExportRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }

        OpenPopup("LedgerReport_report_modal", "Export Option", "@Url.Action("Frm_Export_Options", "LedgerReport", new { @area = "Reports" })", "auto", "auto", false, null);
    }

        function GetSelectedFieldValuesCallback(values) {
            SelectedRows.BeginUpdate();
            try {
                SelectedRows.ClearItems();
                for (var i = 0; i < values.length; i++) {
                    SelectedRows.AddItem(values[i]);
                }
            } finally {
                SelectedRows.EndUpdate();
            }
            $("#count").html(gvRowSelection.GetSelectedRowCount());

        }

        function LedgerReportContextMenuFunction(s, e) {
            if (e.item.name == 'Close') {
                btnCloseActiveTab();
            }
            else if (e.item.name == 'ListPreview') {
                OnLedgerReportListPreviewClick();
            }
            else if (e.item.name == 'Refresh') {
                LedgerReportListGrid.Refresh();
            }
        }

        function LedgerReportChangeColWidthClick() {
            LedgerReportListGrid.settings.Columns[0].Width = 500;
        }

    function OnGridLedgerReportListGrid_EndCallback(s, e) {
        LedgerReport_ColumnToBeShownIndex = s.cpColumnToBeShownIndex;
        LedgerReport_ColumnToBeHidddenIndex = s.cpColumnToBeHidddenIndex;
            $.ajax({
                type: 'GET',
                url: "/Reports/LedgerReport/GetLedgerBalance",
                data: {
                    // xFr_DateSelected: $("input[name=PeriodSelection]").val()
                },
                cache: false,
                success: function (result)
                {
                    if (LedgerReport_IsVouchingMode == true) {
                        $(".LedgerReportListGrid_PreviewRow").hide();
                    }
                    else {
                        $(".LedgerReportListGrid_PreviewRow").show();
                    }
                    GetSessionStorage("LedgerReportListGrid");
                    $("#lbl_Party_Ledger_Balance").text(result.LedgerBalance);
                }
            });
        if (e.command == "CUSTOMCALLBACK")
        {
            if (LedgerReport_Showclick == true)
            {
                if (s.GetPageIndex() > 0)
                {
                    s.GotoPage(0);
                }
            }
        }
        SendCustomArgs_FilterControl(s, e);
    }
