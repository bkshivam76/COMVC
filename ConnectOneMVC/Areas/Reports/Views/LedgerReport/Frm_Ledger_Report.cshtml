<div class="LedgerReport_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    @using DevExpress;
    @using DevExpress.Web.Mvc;

    @model IEnumerable<dynamic>
    @{
        ViewBag.Title = "Index";
        Layout = null;

        string UserType = (string)ViewBag.UserType;
        string SelectedPeriodValue = (string)ViewBag.SelectedPeriodValue;
        bool LedgerReport_ExportRight = (bool)ViewData["LedgerReport_ExportRight"];
        bool LedgerRep_Auto_Vouching_Mode = (bool)ViewData["LedgerRep_Auto_Vouching_Mode"];
        bool Help_Attachment_AddRight = (bool)ViewData["Help_Attachment_AddRight"];
        bool Help_Attachment_EditRight = (bool)ViewData["Help_Attachment_EditRight"];
        bool Help_Attachment_ViewRight = (bool)ViewData["Help_Attachment_ViewRight"];
        bool Help_Attachment_DeleteRight = (bool)ViewData["Help_Attachment_DeleteRight"];
    }
    <style>
        div#PeriodSelection {
            width: 100%;
        }

        .footer_smallbtns {
            padding-left: 16px !important;
        }
    </style>
    <div id="LedgerReport_ParentDiv" class="col-md-12 report_header_div_main">
        <div class="col-md-4 report_header_div">
            <label class="report_header_label">Ledger Report</label>
        </div>
        <div class="report_button_div">
            @(Html.DevExtreme().Switch().ID("ledgerRVouchingModeSwitch").SwitchedOnText("Vouching On").SwitchedOffText("Vouching Off").OnValueChanged("LedgerR_VouchingSwitch_ValueChange").Width(100).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
            @(Html.DevExtreme().Switch().ID("LedgerRepViewModeSwitch").SwitchedOnText("Compact").SwitchedOffText("Default").OnValueChanged("LedgerRep_ViewSwitch_ValueChange").Width(70).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
            @(Html.DevExtreme().Button().ID("LedgerToggleScrollBar").Text(ViewBag.ShowHorizontalBar == 1 ? "Default Data" : "Full Data").Width(ViewBag.ShowHorizontalBar == 1 ? 110 : 90).Icon("toolbox").OnClick(@<text> function () {LedgerReport_changeMode();}</text>))
            @(Html.DevExtreme().Button().ID("btnLedgerPrintExport").Text("Export").Icon("save").Width(80).OnClick(@<text> function () {OnLedgerReportListPreviewClick();}</text>))
            @(Html.DevExtreme().Button().ID("btnLedgerLinkAttachment").Text("Link By Serial No.").Icon("unpin").OnClick(@<text> function () {OnLedgerReportLinkAttachmentSrNo();}</text>))
            @(Html.DevExtreme().Button().ID("btnLedgerLinkAttachmentFileName").Text("Link By File Name").Icon("unpin").OnClick(@<text> function () {OnLedgerReportLinkAttachmentFileName();}</text>))
            @(Html.DevExtreme().Button().ID("LedgerReportModelCLOSE").Text("Close").Icon("clear").OnClick(@<text> function (){$(".TabPanalMenu-tabs .active span").click() }</text>))
        </div>
    </div>
    <form class="edit_form" style="">
        <div class="row">
            <input type="hidden" id="hdfxFr_Date" value="@ViewData["xFr_Date"].ToString()" />
            <input type="hidden" id="hdfxTo_Date" value="@ViewData["xTo_Date"].ToString()" />
            <div class="col-sm-6 col-md-9 col-lg-9">
                <div class="form-field">
                    <div class="container-fluid">
                        <div class="row">
                            <div class="col-sm-2 col-md-2 col-lg-2 pll"><label class="control-label" for="user">Ledger</label></div>
                            <div class="col-sm-10 col-md-10 col-lg-10 prm">
                                @(Html.DevExtreme().SelectBox()
                                                                        .ID("LedgerSelection")
                                                                        .Name("LedgerSelection")
                                                                        .DataSource(d => d.Mvc().Controller("LedgerReport").LoadAction("Fill_Ledgers").Key("ID"))
                                                                        .DisplayExpr("Name")
                                                                        .ValueExpr("ID")
                                                                        .Value(ViewData["SelectedLedgerID"].ToString())
                                                                        .SearchEnabled(true)
                                                                        .ShowClearButton(true)
                                                                        .Placeholder("Select Ledger")
                                                                        .OnValueChanged("GLookUp_LedgerList_EditValueChanged_LedgerReport")
                            )
                            </div>
                        </div>
                    </div>
                </div>
                <div class="form-field">
                    <div class="container-fluid">
                        <div class="row">
                            <div class="col-sm-2 col-md-2 col-lg-2 pll"><label class="control-label" for="user">Period</label></div>
                            <div class="col-sm-10 col-md-10 col-lg-10 prm">
                                <div class="row">
                                    <div class="col-sm-8 col-md-8 col-lg-8 prm">
                                        @(Html.DevExtreme().SelectBox()
                                                                            .ID("PeriodSelection")
                                                                            .Name("PeriodSelection")
                                                                            .DataSource(d => d.Mvc().Controller("LedgerReport").LoadAction("Fill_Change_Period_Items").Key("C_TITLE_ID"))
                                                                            .DisplayExpr("C_TITLE_NAME")
                                                                            .ValueExpr("C_TITLE_ID")
                                                                            .Value(SelectedPeriodValue)
                                                                            .SearchEnabled(true)
                                                                            .Placeholder("Select Period")
                                                                            .OnValueChanged(@<text>
                                                                                function () {
                                                                                PeriodSelectionChange();
                                                                                }
                                                                            </text>)
                                    )
                                    </div>
                                    <div class="col-sm-4 col-md-4 col-lg-4 pll">
                                        &nbsp;@(Html.DevExtreme().Button()
                                              .ID("btnChangePeriod")
                                              .Text("Change Period")
                                              .Hint("Change Period")
                                              .Disabled(true)
                                              .OnClick(@<text>
                                                function () {
                                                ChangePeriodClick();
                                                }
                                            </text>)
                                    )
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div><!--[]-->
            <div class="col-sm-6 col-md-3 col-lg-3">
                <div class="form-field">
                    <div class="container-fluid">
                        <div class="row">
                            <div class="col-sm-12" style="vertical-align:central">
                                <span id="BE_View_Period" style="padding-left:10px;">
                                    @ViewData["returnPeriod"]
                                </span> &nbsp;&nbsp;

                            </div>
                            <div class="col-sm-4 col-md-4 col-lg-4 prm" style="padding-top:11px;">
                                @(Html.DevExtreme().Button()
                                                                                              .ID("btnshowLedger")
                                                                                              .Text("Show")
                                                                                              .Hint("Show Ledger")
                                                                                              .Disabled(false)
                                                                                              .Icon("folder")
                                                                                              .Width(70)
                                                                                              .OnClick(@<text>
                                                                                                function () {
                                                                                                showLedger();
                                                                                                }
                                                                                            </text>)
                            )
                            </div>
                            <div class="col-sm-8 col-md-8 col-lg-8 prm" style="padding-top:14px;">
                                @(Html.DevExtreme().TextBox()
                                                                                               .ID("Ledger_TextForFileNameLink")


                            )
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
    <form>
        <div id="LedgerReportreloadPartialView" class="parent_table">
            @Html.Partial("Frm_Ledger_Report_Grid", Model)
        </div>
    </form>

    @Html.Partial("AttachmentFAB", "LedgerReportPrf_FAB,LedgerReport_ParentDiv,Type1,LedgerReport," + UserType) @* FAB Buttons *@

    <div class="col-md-12">
