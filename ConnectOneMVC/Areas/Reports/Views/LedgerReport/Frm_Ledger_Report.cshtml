    <script>

    function On_LedgerReport_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@Help_Attachment_AddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (LedgerReport_ParamMandatory == 1)
            {
                AddAttachment(LedgerReport_RecID_ForAttachment, "Accounts_CashBook", LedgerReport_Doc_ID, LedgerReport_Doc_Category, LedgerReport_ParamMandatory, LedgerReport_FromDateLabel, LedgerReport_ToDateLabel, LedgerReport_DescriptionLabel, "LedgerReportAttachment", null, "LedgerReportListGrid", LedgerReport_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(LedgerReport_RecID_ForAttachment, "Accounts_CashBook", LedgerReport_Doc_ID, "LedgerReportAttachment", "LedgerReportListGrid", LedgerReport_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (LedgerReport_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(LedgerReport_RecID_ForAttachment, "Accounts_CashBook", LedgerReport_AtachmentID, LedgerReport_ParamMandatory, LedgerReport_FromDateLabel, LedgerReport_ToDateLabel, LedgerReport_DescriptionLabel, "LedgerReportAttachment", null, "LedgerReportListGrid", LedgerReport_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(LedgerReport_RecID_ForAttachment, "Accounts_CashBook", LedgerReport_AtachmentID, LedgerReport_ParamMandatory, LedgerReport_FromDateLabel, LedgerReport_ToDateLabel, LedgerReport_DescriptionLabel, null, "LedgerReportListGrid", LedgerReport_NestedGrid_AccessID, LedgerReport_Attachment_RecStatus);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@Help_Attachment_ViewRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            ViewDocument(LedgerReport_AtachmentID, LedgerReport_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(LedgerReport_RecID_ForAttachment, "Accounts_CashBook", "Ledger Report", "LedgerReportListGrid", LedgerReport_NestedGrid_AccessID);
        }
        else if (e.actionName === "Add_Reason")
        {
            if (LedgerReport_Doc_Category.toLowerCase() == "others")
            {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else
            {
                AttachmentAddReason(LedgerReport_RecID_ForAttachment, LedgerReport_NestedRowMapID, "Accounts_CashBook", "LedgerReportListGrid", LedgerReport_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(LedgerReport_RecID_ForAttachment, LedgerReport_NestedRowMapID, "Accounts_CashBook", "LedgerReportListGrid", LedgerReport_NestedGrid_AccessID, LedgerReport_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(LedgerReport_RecID_ForAttachment, LedgerReport_NestedRowMapID, "LedgerReportListGrid", LedgerReport_NestedGrid_AccessID);
        }
        else if (e.actionName == "AuditAction") {
            s.SetActionContext("AuditActionContext", true);
        }
        else if (e.actionName == "BackAudit") {

            if (LedgerReport_Nested_Doc_Status == "") {
                s.SetActionContext("AutoItemContext", true);
            }
            if (LedgerReport_Nested_Doc_Status == "NO") {
                s.SetActionContext("EditItemContext", true);
            }
            if (LedgerReport_Nested_Doc_Status == "YES") {
                s.SetActionContext("actionItemContext", true);
            }
        }
        else if (e.actionName == "Accept") {
            OnLedgerReport_AcceptwithoutRemarks();
        }
        else if (e.actionName == "Reject") {
            OnLedgerReport_AcceptRejectVoucher("Reject");
        }
        else if (e.actionName == "AcceptWithRemarks") {
            OnLedgerReport_AcceptRejectVoucher("Accept");
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
    }

    function LedgerReportOnGridFocusedRowChanged(s, e)
    {
        if (s.GetFocusedRowIndex() > -1) {
            if (LedgerReport_IsVouchingMode) {
                LedgerReportPrf_FAB.SetVisible(true);
                LedgerReportPrf_FAB.SetActionContext("VouchingActionContext", true);
            }

            s.GetRowValues(s.GetFocusedRowIndex(), 'TR_M_ID;REC_ID;iTR_TEMP_ID', OnLedgerReport_GetMainGridRowValues);
        }
        else
        {
            LedgerReport_TR_M_ID = null;
            LedgerReport_REC_ID = null;
            LedgerReport_iTR_TEMP_ID = null;
        }
    }

