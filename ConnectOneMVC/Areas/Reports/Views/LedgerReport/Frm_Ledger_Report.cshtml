                        </div>
                    </div>
                </div>
                <div class="footer-filter">
                    @*<div class="filter_main">
                        </div>*@
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-12">
        @*Add/Edit Popup*@
        @(Html.DevExtreme().Popup().CustomPopup()
                                                    .ID("LedgerReport_report_modal")
