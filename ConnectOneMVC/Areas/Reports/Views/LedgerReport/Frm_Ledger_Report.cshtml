    <script>

        function OnLedgerReport_AcceptwithoutRemarks() {
            var Recid;
            if (LedgerReport_IsDetailRowExpanded == true || LedgerReport_IsVouchingMode == true)
            {
                if (LedgerReport_MasterRowMID == null || LedgerReport_MasterRowMID == "")
                {
                    if (LedgerReport_MasterRowRecID == null || LedgerReport_MasterRowRecID == "")
                    {
                        Recid = (LedgerReport_TR_M_ID == null || LedgerReport_TR_M_ID == "") ? LedgerReport_REC_ID : LedgerReport_TR_M_ID;
                    }
                    else
                    {
                        Recid = LedgerReport_MasterRowRecID;
                    }
                }
                else
                {
                    Recid = LedgerReport_MasterRowMID;
                }
            }
            else
            {
                Recid = (LedgerReport_TR_M_ID == null || LedgerReport_TR_M_ID == "") ? LedgerReport_REC_ID : LedgerReport_TR_M_ID;
            }

            Entry_AcceptwithoutRemarks(Recid, "Report_LedgerReport", "LedgerReportListGrid", LedgerReport_AtachmentID, LedgerReport_NestedRowReasonID, LedgerReport_NestedRowKeyValue);
        }

        function OnLedgerReport_AcceptRejectVoucher(_actionMethod) {
            var Recid;
            if (LedgerReport_IsDetailRowExpanded == true || LedgerReport_IsVouchingMode == true) {
                if (LedgerReport_MasterRowMID == null || LedgerReport_MasterRowMID == "") {
                    if (LedgerReport_MasterRowRecID == null || LedgerReport_MasterRowRecID == "") {
                        Recid = (LedgerReport_TR_M_ID == null || LedgerReport_TR_M_ID == "") ? LedgerReport_REC_ID : LedgerReport_TR_M_ID;
                    }
                    else {
                        Recid = LedgerReport_MasterRowRecID;
                    }
                }
                else {
                    Recid = LedgerReport_MasterRowMID;
                }
            }
            else {
                Recid = (LedgerReport_TR_M_ID == null || LedgerReport_TR_M_ID == "") ? LedgerReport_REC_ID : LedgerReport_TR_M_ID;
            }
            Entry_AcceptReject(_actionMethod, Recid, "Report_LedgerReport", "LedgerReportListGrid", LedgerReport_AtachmentID, LedgerReport_NestedRowReasonID, LedgerReport_NestedRowKeyValue);
        }
    </script>@* LedgerReport_AuditActionButton_Functions *@
