        function LedgerReportListGrid_PerformCallBack()
        {
            if (typeof window !== 'undefined')
            {
                if (typeof window.LedgerReportListGrid !== 'undefined')
                {
                    if (typeof window.LedgerReportListGrid.PerformCallback !== 'undefined')
                    {
                        if (typeof LedgerReportListGrid.PerformCallback == 'function')
                        {
                            LedgerReportListGrid.PerformCallback();
                        }
                        else
                        {
                            alert("PerformCallback is not a function");
                        }
                    }
                    else
                    {
                        ShowLoader();
                        setTimeout(function ()
                        {
                            LedgerReportListGrid_PerformCallBack();
                            HideLoader();
                        }, Timeout100);
                    }
                }
                else
                {
                    alert('grid undefined')
                }
            }
            else
            {
                alert('window undefined')
            }
        }

        function LedgerR_VouchingSwitch_ValueChange(e)
        {
            LedgerReport_IsVouchingMode = e.value;
            if (LedgerRep_SetVouchingModeOn == true)
            {
                LedgerRep_SetVouchingModeOn = false;
            }
            else
            {
                 LedgerReportPrf_FAB.SetVisible(false);
            }
            if (LedgerReport_IsVouchingMode == true)
            {
                OpenRightPane();
                ClearLeftPane();
                OpenLeftPane();
            }
            else
            {
                LedgerReportPrf_FAB.SetActionContext("AddAttachmentContext", false);
                CloseRightPane();
                ClearLeftPane();
                CloseLeftPane();
            }
            LedgerReportListGrid_CollapseAllDetailRows();
        }

    function LedgerReportListGrid_CollapseAllDetailRows() {
        if (typeof window !== 'undefined') {
            if (typeof window.LedgerReportListGrid !== 'undefined') {
                if (typeof window.LedgerReportListGrid.CollapseAllDetailRows !== 'undefined') {
                    if (typeof LedgerReportListGrid.CollapseAllDetailRows == 'function')
                    {
                        LedgerReportListGrid.SetFocusedRowIndex(-1);
                        LedgerReportListGrid.CollapseAllDetailRows();
                    }
                    else {
                        alert("CollapseAllDetailRows is not a function");
                    }
                }
                else {
                    ShowLoader();
                    setTimeout(function () {
                        LedgerReportListGrid_CollapseAllDetailRows();
                        HideLoader();
                    }, Timeout100);
                }
            }
            else {
                alert('LedgerReportListGrid is undefined')
            }
        }
        else {
            alert('window is undefined')
        }
    }
        function LedgerRep_ViewSwitch_ValueChange(e)
        {
            LedgerRep_ViewMode = e.value == false ? "Default" : "Compact";
            if (LedgerRep_SetVouchingModeOn == true)
            {
                $("#ledgerRVouchingModeSwitch").dxSwitch("instance").option("value", true);
            }
            else
            {
                LedgerReportListGrid.CollapseAllDetailRows();
            }
        }
    $(document).ready(function () {
        if ("@LedgerReport_ExportRight" == "False")
        {
	        $("#btnLedgerPrintExport").hide();
        }
            IsLedgerReportSucessPopup = false;
        IsLedgerReportViewPopup = false;

        if (LedgerReport_IsVouchingMode == true) {
            $(".LedgerReportListGrid_PreviewRow").hide();
        }
        else {
            $(".LedgerReportListGrid_PreviewRow").show();
        }
        GetSessionStorage("LedgerReportListGrid");
          //  SetLedgerReportGroupPanelFooterVisible();
            //if ($("input[name=LedgerSelection]").val().length > 0) { showLedger(); }
            //$("#LedgerReportListGrid").hover(function () {
