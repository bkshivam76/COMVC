        function LedgerReport_OnInit(s, e) {
            LedgerReport_AdjustSize();
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                LedgerReport_AdjustSize();
            });
            document.getElementById("LedgerReportListGrid").addEventListener('keydown', function (evt) {
                if (evt.repeat) { return };
                if (evt.keyCode == 35) {
                    evt.preventDefault();
                    //$("#btnLedgerLinkAttachment").click();
                    OnLedgerReportLinkAttachmentSrNo();
                    return false;
                }
                else if (evt.keyCode == 36) {
                    evt.preventDefault();
                    //$("#btnLedgerLinkAttachment").click();
                    OnLedgerReportLinkAttachmentFileName();
                    return false;
                }
            });
        }

        //function OnEndCallback(s, e) {
        //    AdjustSize();
        //}

        function LedgerReport_AdjustSize() {
            var height = (document.documentElement.clientHeight * 90) / 100;
            try{LedgerReportListGrid.SetHeight(height);} catch (err) { }
        }
        function LedgerReport_changeMode() {
            ShowLoader();
            if (LedgerReport_ShowHorizontalBar == 0) {
                LedgerReport_ShowHorizontalBar = 1;
                $("#LedgerToggleScrollBar").find("span").text("Default Data");
                $("#LedgerToggleScrollBar").width(110);
            }
            else {
                LedgerReport_ShowHorizontalBar = 0;
                $("#LedgerToggleScrollBar").find("span").text("Full Data");
                $("#LedgerToggleScrollBar").width(90);
            }
            $.ajax({
                url: '@Url.Action("Frm_Ledger_Report_Grid", "LedgerReport")',
                type: "GET",
                data: { ShowHorizontalBar: LedgerReport_ShowHorizontalBar, VouchingMode: LedgerReport_IsVouchingMode, ViewMode: LedgerRep_ViewMode, ColumnToBeHidddenIndex: LedgerReport_ColumnToBeHidddenIndex, ColumnToBeShownIndex: LedgerReport_ColumnToBeShownIndex  },
                success: function (res) {
                    $("#LedgerReportreloadPartialView").html(res);
                    if (LedgerReport_IsVouchingMode == true) {
                        $(".LedgerReportListGrid_PreviewRow").hide();
                    }
                    else {
                        $(".LedgerReportListGrid_PreviewRow").show();
                    }
                    GetSessionStorage("LedgerReportListGrid");
                }
            });
            HideLoader();
        }
