                //s.GetValuesOnCustomCallback({ key: key }, OnLedgerReport_GetGridRowValues)
                LedgerReport_NestedGrid_AccessID = s.uniqueID;
                s.GetRowValues(s.GetFocusedRowIndex(), 'Doc_Status;Params_Mandatory;LABEL_FROM_DATE;LABEL_TO_DATE;LABEL_DESCRIPTION;Document_Category;Document_ID;ATTACH_ID;TxnID;TxnMID;MAP_ID;Reason;ATTACH_FILE_NAME;Attachment_Action_Status;UniqueID;ReasonID', OnLedgerReport_GetGridRowValues);
            }
            else
            {
                LedgerReportPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }

    function OnLedgerReport_GetGridRowValues(values)
    {

        if (values[14] != null)
        {
            LedgerReportPrf_FAB.SetVisible(true);
            LedgerReport_Nested_Doc_Status = values[0];
            if (LedgerReport_IsVouchingMode == true) {
                LedgerReportPrf_FAB.SetActionContext("AuditActionContext", true);
            }
            else
            {
                if (LedgerReport_Nested_Doc_Status == "") {
                    LedgerReportPrf_FAB.SetActionContext("AutoItemContext", true);
                }
                else if (LedgerReport_Nested_Doc_Status == "NO") {
                    LedgerReportPrf_FAB.SetActionContext("EditItemContext", true);
                }
                else if (LedgerReport_Nested_Doc_Status == "YES") {
                    LedgerReportPrf_FAB.SetActionContext("actionItemContext", true);
                }
            }

            LedgerReport_ParamMandatory = values[1];
            LedgerReport_FromDateLabel = values[2];
            LedgerReport_ToDateLabel = values[3];
            LedgerReport_DescriptionLabel = values[4];
            LedgerReport_Doc_Category = values[5];
            LedgerReport_Doc_ID = values[6];
            LedgerReport_AtachmentID = values[7];
            IndexAttachmentID = LedgerReport_AtachmentID;
            LedgerReport_MasterRowRecID = values[8];
            LedgerReport_MasterRowMID = values[9];
            LedgerReport_NestedRowMapID = values[10];
            LedgerReport_reason = values[11];
            LedgerReport_FileName = values[12];
            LedgerReport_Attachment_RecStatus = values[13];
            LedgerReport_NestedRowKeyValue = values[14];
            LedgerReport_NestedRowReasonID = values[15];
            IndexAttachmentReasonID = LedgerReport_NestedRowReasonID;

            HideLoader();
            if (LedgerReport_MasterRowMID != null && LedgerReport_MasterRowMID != "") {
                LedgerReport_RecID_ForAttachment = LedgerReport_MasterRowMID;
            }
            else if (LedgerReport_MasterRowRecID != null && LedgerReport_MasterRowRecID != "") {
                LedgerReport_RecID_ForAttachment = LedgerReport_MasterRowRecID;
            }

        }
    }

    function LedgerReportListGrid_Nested_BeginCallBack(s, e)
    {
        e.customArgs["ShowHorizontalBar"] = LedgerReport_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = LedgerReport_IsVouchingMode;
        e.customArgs["command"] = e.command;
    }
    function LedgerReport_DetailRowExpanding(s, e)
    {
        LedgerReport_IsDetailRowExpanded = true;
        s.SetFocusedRowIndex(e.visibleIndex);
        var pane = Mainspliter.GetPaneByName('RightPane');
        if (LedgerReport_IsVouchingMode == true) {
            pane.Expand();
        }
        else {
            pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
        }
    }
    function LedgerReport_DetailRowCollapsing(s, e)
    {
        LedgerReport_IsDetailRowExpanded = false;
        s.SetFocusedRowIndex(e.visibleIndex);
        if (LedgerReport_IsVouchingMode == true) {
            if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false) {
                CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
        else {
            LedgerReportPrf_FAB.SetVisible(false);
        }
    }
