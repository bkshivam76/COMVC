            //})
        if (LedgerRep_SetVouchingModeOn == true)
        {
            $("#LedgerRepViewModeSwitch").dxSwitch("instance").option("value", true);
        }
        });
    $(".TabPanalMenu-tabs .active span").on("click", function () {
        $.ajax({
            type: 'GET',
            url: "/Reports/LedgerReport/SessionClear",
            cache: false
        });
        CloseRightPane();
        ClearLeftPane();
        CloseLeftPane();
        ClearAllReferences_LedgerReport();
    });

        function ClearAllReferences_LedgerReport()
        {
            IsLedgerReportSucessPopup = null;
            IsLedgerReportViewPopup = null;
            LedgerReport_ShowHorizontalBar = null;
            LedgerReport_IsVouchingMode = null;
            LedgerRep_SetVouchingModeOn = null;
            LedgerRep_ViewMode = null;
            LedgerReportID = null;
            LedgerReport_EditDate = null;
            LedgerReport_AddDate = null;
            LedgerReport_AddBy = null;
            LedgerReport_EditBy = null;
            LedgerReport_ActionStatus = null;
            LedgerReport_Showclick = null;
            LedgerReport_ColumnToBeShownIndex = null;
            LedgerReport_ColumnToBeHidddenIndex = null;
            LedgerID_LedgerRpt = null;
            LedgerName_LedgerRpt = null;
            SubLedID_LedgerRpt = null;
            LedgerReport_IsDetailRowExpanded = null;
