<div class="LocationReport_Export_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    <div>
        @(Html.DevExtreme().Button()
                .ID("Loc_ExportGridDatapdf")
                .Text("Export to PDF")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                //.AccessKey("x")
                .OnClick("ExportPDF")
                .Visible(true)
                .Width(120)
    )<br />

        @(Html.DevExtreme().Button()
                .ID("Loc_ExportGridDataxls")
                .Text("Export to XLS")
                //.Icon("fa-file-excel-o")
                //.AccessKey("X")
                .OnClick("ExportXLS")
                .Visible(true)
                .Width(120)
    )<br />
        @(Html.DevExtreme().Button()
                .ID("Loc_ExportGridDataxlsx")
                .Text("Export to XLSX")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                //.AccessKey("L")
                .OnClick("ExportXLSX")
                .Visible(true)
                .Width(120)
    )<br />

        @(Html.DevExtreme().Button()
                .ID("Loc_ExportGridDatadocx")
                .Text("Export to DOCX")
                //.Icon("export_exporttodocx_16x16office2013")
                //.AccessKey("D")
                .OnClick("ExportDOCX")
                .Visible(true)
                .Width(120)
    )<br />

        @(Html.DevExtreme().Button()
                .ID("Loc_ExportGridDatartf")
                .Text("Export to RTF")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                //.AccessKey("R")
                .OnClick("ExportRTF")
                .Visible(true)
                .Width(120)
    )<br />

        @(Html.DevExtreme().Button()
                .ID("Loc_ExportGridDatacsv")
                .Text("Export to CSV")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                //.AccessKey("C")
                .OnClick("ExportCSV")
                .Visible(true)
                .Width(120)
    )
    </div>
    <script>
        function ExportPDF() {
            LocationReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Pdf);
            $("#LocationReport_report_modal").dxPopup("hide");
        }
        function ExportXLS() {
            LocationReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Xls);
            $("#LocationReport_report_modal").dxPopup("hide");
        }
        function ExportXLSX() {
            LocationReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Xlsx);
            $("#LocationReport_report_modal").dxPopup("hide");
        }
        function ExportCSV() {
            LocationReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Csv);
            $("#LocationReport_report_modal").dxPopup("hide");
        }
        function ExportDOCX() {
            LocationReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Docx);
            $("#LocationReport_report_modal").dxPopup("hide");
        }
        function ExportRTF() {
            LocationReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Rtf);
            $("#LocationReport_report_modal").dxPopup("hide");
        }
    </script>
</div>