        try { MagSubDispatchReportListGrid2.SetHeight(height); } catch (err) { }
    }
    function MagSubDispatchReport2_OnbegincallBack(s, e)
    {
        e.customArgs["command"] = e.command;
        e.customArgs["ShowHorizontalBar"] = MagSubDpt_ShowHorizontalBar;
        e.customArgs["FromDate"] = (moment(MagSubDpt_FromDate).format("DD/MM/YYYY HH:mm:ss"));
        e.customArgs["ToDate"] = (moment(MagSubDpt_ToDate).format("DD/MM/YYYY HH:mm:ss"));
        e.customArgs["MagID"] = MagSubDpt_MagID;
