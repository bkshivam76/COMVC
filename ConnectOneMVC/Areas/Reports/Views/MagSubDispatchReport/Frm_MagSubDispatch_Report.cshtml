</script>
<script>
    var MAgReport_ShowClick = false;
    function showMagSubDptRpt() {
        if (MagSubDpt_MagID == null) {
            DevExpress.ui.dialog.alert("Please Select A Magazine", "Error"); return;
        }
        if (MagSubDpt_FromDate == null) {
            DevExpress.ui.dialog.alert("Please select From Date", "Error"); return;
        }
        if (MagSubDpt_ToDate == null) {
            DevExpress.ui.dialog.alert("Please select To Date", "Error"); return;
        }
        if (MagSubDpt_FromDate > MagSubDpt_ToDate) {
            DevExpress.ui.dialog.alert("To Date Must Be Greater Than From Date", "Error"); return;
        }
        MAgReport_ShowClick = true;
        MagSubDispatchReportListGrid.Refresh();      
    }
</script>