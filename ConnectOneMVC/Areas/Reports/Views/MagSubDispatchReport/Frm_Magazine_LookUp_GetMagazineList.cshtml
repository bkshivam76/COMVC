@using DevExtreme.AspNet.Data;
@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
        .ID("MagazineReportList")       
        .Columns(columns =>
        {
            columns.Add().DataField("Name").Caption("Name");
            columns.Add().DataField("Language").Caption("Language");
            columns.Add().DataField("Publish_On").Caption("Publish On");
            columns.Add().DataField("Short_Name").Visible(false);
            columns.Add().DataField("Magazine_Regd_No").Visible(false);
            columns.Add().DataField("Postal_Regd_No").Visible(false);
            columns.Add().DataField("Membership_Start_No").Visible(false);
            columns.Add().DataField("Foreign_Subscriptions").Visible(false);
            columns.Add().DataField("ID").Visible(false);
            columns.Add().DataField("Add_By").Visible(false);
            columns.Add().DataField("Add_Date").Visible(false);
            columns.Add().DataField("Edit_By").Visible(false);
            columns.Add().DataField("Edit_Date").Visible(false);
            columns.Add().DataField("Action_Status").Visible(false);
            columns.Add().DataField("Action_By").Visible(false);
            columns.Add().DataField("Action_Date").Visible(false);
        })
     
        .Selection(s => s.Mode(SelectionMode.Single))
    
)