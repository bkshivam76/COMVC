        function MultiBankCB_CreationDetail(ID, Action_Status, Add_Date, Add_By, Action_Date, Action_By, Edit_Date, Edit_By)
        {
            var Status = "";
            var Lbl_Status = "";
            var Lbl_StatusBy = "";
            var Pic_Status = "";
            var Lbl_Create = "";
            var Lbl_Modify = "";
            var Lbl_Status_Color = "";
            var Lbl_ActionOn = "";
            var Lbl_ActionBy = "";
            var StatusStr = "";
            if (ID != null) {
                Add_Date = (JS_Json_Date_To_ddMMyyyy((Add_Date ?? ""), "DD-MM-YYYY HH:mm:ss") ?? "")
                Edit_Date = (JS_Json_Date_To_ddMMyyyy((Edit_Date ?? ""), "DD-MM-YYYY HH:mm:ss") ?? "")
                Action_Date = (JS_Json_Date_To_ddMMyyyy((Action_Date ?? ""), "DD-MM-YYYY HH:mm:ss") ?? "")
                Status = Action_Status;
                StatusStr = Status == "Locked" ? "Locked" : Status == null ? null : "UnLocked";
                if (Status && Status.toUpperCase() == "LOCKED") {
                    Lbl_Status = "Completed";
                    Lbl_Status_Color = "blue";
                    Pic_Status = "fa fa-lock";
                }
                else {
                    Pic_Status = "fa fa-unlock";
                    Lbl_Status = Status;
                    if (Status && Status.toUpperCase() == "COMPLETED") {
                        Lbl_Status_Color = "green";
                    }
                    else {
                        Lbl_Status_Color = "red";
                    }
                }
                if (Action_Date) {
                    Lbl_ActionOn = StatusStr + " On: " + Action_Date;
                    Lbl_ActionBy = StatusStr + " By: " + Action_By;
                }

                else {
                    Lbl_ActionOn = "";
                    Lbl_ActionBy = "";
                }
                if (Add_Date) {
                    Lbl_Create = "Add On: " + Add_Date + ", By: " + Add_By;
                }
                else {
                    Lbl_Create = "";
                }

                if (Edit_Date) {
                    Lbl_Modify = "Edit On: " + Edit_Date + ", By: " + Edit_By;
                }
                else {
                    Lbl_Modify = "";
                }
            }
            $('#MultiBankCBLbl_Status').text(Lbl_Status);
            $('#MultiBankCB_Lbl_ActionOn').text(Lbl_ActionOn);
            $('#MultiBankCB_Lbl_ActionBy').text(Lbl_ActionBy);
            $('#MultiBankCBLbl_Create').text(Lbl_Create);
            $('#MultiBankCBLbl_Modify').text(Lbl_Modify);
            if (Lbl_Status_Color != "") {
                $('#MultiBankCBLbl_Status').css('color', Lbl_Status_Color);
            }
            if (Pic_Status == "fa fa-lock") {
                $('#MultiBankCB_LockICON').addClass(Pic_Status).removeClass("fa-unlock");
            }
            else if (Pic_Status == "fa fa-unlock") {
                $('#MultiBankCB_LockICON').addClass(Pic_Status).removeClass("fa-lock");
            }
            else {
                $('#MultiBankCB_LockICON').removeClass("fa");
                $('#MultiBankCB_LockICON').removeClass("fa-lock");
                $('#MultiBankCB_LockICON').removeClass("fa-unlock");
            }
        }
    </script> @* Ready Period Selection Grid refresh fns *@
    <script>
        function MultiBankCashBookListGrid_dx_OnInitialized(e) {
            DxGrid_AdjustSize(e.component, $("#MultiBankCashbook_ParentDiv .report_button_div"))
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
                DxGrid_AdjustSize(e.component, $("#MultiBankCashbook_ParentDiv .report_button_div"), "", evt)
            });
            MultiBankCashBookListGrid = e.component;
            $(".MultiBankCashBookListGrid_PreviewRow").hide();
        }
        function MultiBankCashBookListGrid_dx_OnRowPrepared(e) {
            if (e.rowType == "data") {
                let GridName = e.element[0].id;
                let keyvalue = "";
                if (e.data.iREC_ID == "NOTE-BOOK") {
                    keyvalue = e.data.iTR_M_ID.replace(/[^\w]/gi, "_") + e.data.iTR_ITEM_ID
                }
                else {
                    keyvalue = e.data.Grid_PK.replace(/[^\w]/gi, "_")
                }
                $(e.rowElement).addClass(GridName + "_DataRow_" + keyvalue)

                let Remarks = e.data.iTR_NARRATION;
                var PreviewRowContent = MultiBankCashBookListGrid_dx_PreviewRow_Template(e)
                var PreviewRowClass = GridName + "_PreviewRow " + GridName + "_PreviewRow_" + keyvalue + " DataGridPreviewRow"
                var PreviewRowOptions = ""; 
                if (Remarks == null || Remarks.length == 0)
                {
                    PreviewRowOptions = "style='display:none'";
                    PreviewRowClass += " empty";
                }                
                var EmptyTdshtml = "";
                var emptyTd = $(e.rowElement).find('td.dx-datagrid-group-space').length
                for (var i = 0; i < emptyTd; i++) {
                    EmptyTdshtml += "<td></td>"
                }
                ($(e.rowElement).parent()).append("<tr class='" + PreviewRowClass + "' " + PreviewRowOptions + ">" + EmptyTdshtml + "<td colspan='" + e.columns.length + "'>" + PreviewRowContent + "</td></tr>")

                if (e.data.iTR_REF_NO != null && e.data.iTR_REF_NO % 2 == 0) {
                    $(e.rowElement).css("background-color", "linen");
                }
                else {
                    $(e.rowElement).css("background-color", "aliceblue");
                }
                if (e.data.iCross_Ref_ID == null && (e.data.iTR_CODE != null && (e.data.iTR_CODE == 8 || e.data.iTR_CODE == 15))) {
                    $(e.rowElement).css("background-color", "pink");
                }
            }
        }
        function MultiBankCashBookListGrid_dx_OnContentReady(e)
        {
            MultiBankCashBookListGrid_dx_ShowHideNarration();
            DxGrid_RowSelectionTobeCheckedAfterAnyAction(e)
            DxGrid_OnContentReady(e, MultiBankCB_ShowHorizontalBar);       
        }
        function MultiBankCashBookListGrid_dx_OnSelectionChanged(e)
        {
            var selectedRowKeys = e.selectedRowKeys;
            if (selectedRowKeys != null && selectedRowKeys.length > 0)
            {
                MultiBankCashBookListGrid_dx_SelectedRowData(e.selectedRowsData)
            }
            else
            {               
                MultiBankCB_Grid_PK = null;
                MultiBankCB_XID = null;
            }           
            MultiBankCB_CreationDetail(MultiBankCB_XID, MultiBankCB_ACTION_STATUS, MultiBankCB_REC_ADD_ON, MultiBankCB_REC_ADD_BY, MultiBankCB_REC_STATUS_Date, MultiBankCB_REC_STATUS_BY, MultiBankCB_REC_EDIT_Date, MultiBankCB_REC_EDIT_BY);
        }
        function MultiBankCashBookListGrid_dx_SelectedRowData(selectedData = null)
        {
            if (selectedData == null)
            {
                selectedData = MultiBankCashBookListGrid.getSelectedRowsData();
            }
            if (selectedData != null && selectedData.length > 0)
            {
                var values = selectedData[0];             
                MultiBankCB_XID = values.iREC_ID;
                MultiBankCB_Grid_PK = values.Grid_PK;
                MultiBankCB_ACTION_STATUS = values.iACTION_STATUS;
                MultiBankCB_REC_STATUS_BY = values.iREC_STATUS_BY;
                MultiBankCB_REC_STATUS_Date = values.iREC_STATUS_ON;
                MultiBankCB_REC_ADD_BY = values.iREC_ADD_BY;
                MultiBankCB_REC_ADD_ON = values.iREC_ADD_ON;
                MultiBankCB_REC_EDIT_BY = values.iREC_EDIT_BY;
                MultiBankCB_REC_EDIT_Date = values.iREC_EDIT_ON;
            }
        }
        function MultiBankCashBookListGrid_dx_OnContextMenuPreparing(e) {
            if (!e.items) e.items = [];
            if (e.target == "header") {
                DxGrid_HeaderContextMenu(e)
                e.items = e.items.filter(x => x.text != "Group Panel" && x.text != "Group Footer") //remove group panel and group footer grouping not allowed
            }
            else if (e.target == "footer") {
                // DxGrid_FooterContextMenu(e, CBGrid_ViewMode == "Compact");
            }
            else if (e.target == "content" && e.row && e.row.rowType == "data")
            {
                var key = e.component.getKeyByRowIndex(e.row.rowIndex);
                e.component.selectRows(key);        
                e.items = [

                    {
                        text: "Export",
                        icon: "fa-solid fa-file-export text-warning",
                        visible: true,
                        onItemClick: function () {
                            OnMultiBankCashBookListPreviewClick();
                        }
                    },

                    {
                        text: "Close",
                        icon: "fa-solid fa-rectangle-xmark text-danger",
                        beginGroup: true,
                        onItemClick: function () {
                            CloseMultiBankCashBook();
                        }
                    },
                    {
                        text: "Refresh",
                        beginGroup: true,
                        icon: "fa-solid fa-arrow-rotate-right text-success",
                        onItemClick: function () { MultiBankCashBookListGrid.refresh(); }
                    }
                ]
            }
        }    
        function MultiBankCashBookListGrid_dx_PreviewRow_Template(e) {
            let htmlString = "";
            if (e.data.iTR_NARRATION != null && e.data.iTR_NARRATION.length > 0) {
                htmlString += "<span style = 'color: #008000' > <i>" + e.data.iTR_NARRATION + "</i></span><br><br>";
            }
            return htmlString;
        }

    </script> @* Main And Detail grid fns *@
    <script>
