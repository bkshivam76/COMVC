            if (btntotal == "Show Total Bal.") {
                var ValFormat = function (value) { return DxGrid_FormatNumber(value) };
                SummaryItems.push(
                    {
                        "name": "iTR_DATE_iTR_PARTY_1_count", "column": "iTR_DATE", "summaryType": "count", "showInColumn": "iTR_PARTY_1", "recalculateWhileEditing": true, "displayFormat": "Total Payments:\nClosing Balance:\nTotal Receipts:",
                    },
                    {
                        "name": "iTR_PAY_CASH_iTR_PAY_CASH_custom", /*"column": "iTR_PAY_CASH",*/ "summaryType": "custom", "showInColumn": "iTR_PAY_CASH", "recalculateWhileEditing": true, valueFormat: ValFormat, "displayFormat": "{0}",
                    },
                    {
                        "name": "iTR_REC_CASH_iTR_PAY_CASH_sum", "column": "iTR_REC_CASH", "summaryType": "sum", "showInColumn": "iTR_PAY_CASH", "recalculateWhileEditing": true, valueFormat: ValFormat, "displayFormat": "{0}",
                    },
                    {
                        "name": "iTR_PAY_BANK_iTR_PAY_BANK_custom", /*"column": "iTR_PAY_BANK",*/ "summaryType": "custom", "showInColumn": "iTR_PAY_BANK", "recalculateWhileEditing": true, valueFormat: ValFormat, "displayFormat": "{0}",
                    },
                    {
                        "name": "iTR_REC_BANK_iTR_PAY_BANK_sum", "column": "iTR_REC_BANK", "summaryType": "sum", "showInColumn": "iTR_PAY_BANK", "recalculateWhileEditing": true, valueFormat: ValFormat, "displayFormat": "{0}",
                    },
                    {
                        "name": "iTR_PAY_JOURNAL_iTR_PAY_JOURNAL_custom", /*"column": "iTR_PAY_JOURNAL",*/ "summaryType": "custom", "showInColumn": "iTR_PAY_JOURNAL", "recalculateWhileEditing": true, valueFormat: ValFormat, "displayFormat": "{0}",
                    },
                    {
                        "name": "iTR_REC_JOURNAL_iTR_PAY_JOURNAL_sum", "column": "iTR_REC_JOURNAL", "summaryType": "sum", "showInColumn": "iTR_PAY_JOURNAL", "recalculateWhileEditing": true, valueFormat: ValFormat, "displayFormat": "{0}",
                    },
                    {
                        "name": "iTR_REC_TOTAL_iTR_PAY_TOTAL_sum", "column": "iTR_REC_TOTAL", "summaryType": "sum", "showInColumn": "iTR_PAY_TOTAL", "recalculateWhileEditing": true, valueFormat: ValFormat, "displayFormat": "\n{0}",
                    },
                )
                $("#But_MultiBankShowTotal").dxButton("instance").option("text", "Hide Total Bal.");
