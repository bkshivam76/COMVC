            else
            {
                $("#But_MultiBankNarration").dxButton("instance").option("text", "Show Narration");
                MultiBankCashBookListGrid_dx_ShowHideNarration("Show Narration")
            }
        }
        function MultiBankCashBookListGrid_dx_ShowHideNarration(btn_text = "")
        {
            if (btn_text == null || btn_text.length == 0)
            {
                btn_text = $("#But_MultiBankNarration").dxButton("instance").option("text");
            }     
            if (btn_text == "Hide Narration")
            {
                $(".MultiBankCashBookListGrid_PreviewRow:not(.empty)").show();
            }
            else
            {
                $(".MultiBankCashBookListGrid_PreviewRow").hide();
            }            
        }
