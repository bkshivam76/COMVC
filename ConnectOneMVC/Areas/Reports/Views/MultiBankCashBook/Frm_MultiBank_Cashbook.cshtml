    <script>
        $(document).ready(function ()
        {
            PeriodSelectionChange_MultiBankCB(null, true)
        });
        async function PeriodSelectionChange_MultiBankCB(e, FirstCall = false)
        {
            var PeriodSelectedIndex;
            if (e)
            {
                PeriodSelectedIndex = e.value;
            }
            else
            {
                PeriodSelectedIndex = $("#MultiBankCB_PeriodSelection").dxSelectBox("option","value")
            }
            if (PeriodSelectedIndex == null || PeriodSelectedIndex < 0)
            {
                return;
            }
            var xFr_Date, xTo_Date, MonthText, DataSource, _xDate;
            DataSource = $("#MultiBankCB_PeriodSelection").dxSelectBox("getDataSource");
            var isLoaded = DataSource.isLoaded();
            if (isLoaded == false)
            {
                await DataSource.load();
            }
            MonthText = $("#MultiBankCB_PeriodSelection").dxSelectBox("option", "text");
            $("#MultiBankCB_btnChangePeriod").dxButton("instance").option("disabled", true);
            if (PeriodSelectedIndex == 20)
            {
                $("#MultiBankCB_btnChangePeriod").dxButton("instance").option("disabled", false);
                ChangePeriodClick_MultiBankCB();
                return;
            }
            else if (PeriodSelectedIndex >= 0 && PeriodSelectedIndex <= 11)
            {
                var Sel_Mon = (MonthText.substr(0, 3)).toUpperCase();
                var SEL_MM;
                switch (Sel_Mon) {
                    case "JAN": SEL_MM = 1; break;
                    case "FEB": SEL_MM = 2; break;
                    case "MAR": SEL_MM = 3; break;
                    case "APR": SEL_MM = 4; break;
                    case "MAY": SEL_MM = 5; break;
                    case "JUN": SEL_MM = 6; break;
                    case "JUL": SEL_MM = 7; break;
                    case "AUG": SEL_MM = 8; break;
                    case "SEP": SEL_MM = 9; break;
                    case "OCT": SEL_MM = 10; break;
                    case "NOV": SEL_MM = 11; break;
                    case "DEC": SEL_MM = 12; break;
                    default: SEL_MM = 4; break;
                }
                xFr_Date = moment(new Date(MonthText.substr(4, 4), (SEL_MM - 1), 1)) //js date starts from 0
                _xDate = xFr_Date.clone() //moment fns are mutable
                xTo_Date = _xDate.add(1, 'M').subtract(1, 'd');
            }
            else if (PeriodSelectedIndex == 12)
            {
                xFr_Date = moment(new Date("@OpenYearSdt.Year", 3, 1))
                _xDate = xFr_Date.clone()
                xTo_Date = _xDate.add(3, 'M').subtract(1, 'd');
            }
            else if (PeriodSelectedIndex == 13)
            {
                xFr_Date = moment(new Date("@OpenYearSdt.Year", 6, 1))
                _xDate = xFr_Date.clone()
                xTo_Date = _xDate.add(3, 'M').subtract(1, 'd');
            }
            else if (PeriodSelectedIndex == 14)
            {
                xFr_Date = moment(new Date("@OpenYearSdt.Year", 9, 1))
                _xDate = xFr_Date.clone()
                xTo_Date = _xDate.add(3, 'M').subtract(1, 'd');
            }
            else if (PeriodSelectedIndex == 15)
            {
                xFr_Date = moment(new Date("@OpenYearEdt.Year", 0, 1))
                _xDate = xFr_Date.clone()
                xTo_Date = _xDate.add(3, 'M').subtract(1, 'd');
            }
            else if (PeriodSelectedIndex == 16)
            {
                xFr_Date = moment(new Date("@OpenYearSdt.Year", 3, 1))
                _xDate = xFr_Date.clone()
                xTo_Date = _xDate.add(6, 'M').subtract(1, 'd');
            }
            else if (PeriodSelectedIndex == 17)
            {
                xFr_Date = moment(new Date("@OpenYearSdt.Year", 9, 1))
                _xDate = xFr_Date.clone()
                xTo_Date = _xDate.add(6, 'M').subtract(1, 'd');
            }
            else if (PeriodSelectedIndex == 18)
            {
                xFr_Date = moment(new Date("@OpenYearSdt.Year", 3, 1))
                _xDate = xFr_Date.clone()
                xTo_Date = _xDate.add(9, 'M').subtract(1, 'd');
            }
            else if (PeriodSelectedIndex == 19)
            {
                xFr_Date = moment(new Date("@OpenYearSdt.Year", 3, 1))
                xTo_Date = moment(new Date("@OpenYearEdt.Year",2, 31))
            }
            $("#MultiBankCB_Fr_Date").val(xFr_Date.format("DD-MM-YYYY"));
            $("#MultiBankCB_To_Date").val(xTo_Date.format("DD-MM-YYYY"));
            $("#MultiBankCB_BE_View_Period").dxTextBox("instance").option("value", ("Fr.: " + xFr_Date.format("DD-MMM, YYYY") + " to " + xTo_Date.format("DD-MMM, YYYY")));
            MultiBankCB_PeriodSelectionFirstTime = false;
            MultiBankCashBookListGrid.clearSelection()
            var pageIndex = MultiBankCashBookListGrid.pageIndex();
            if (pageIndex > 0) {
                MultiBankCashBookListGrid.pageIndex(0);
            }
            MultiBankCashBookListGrid.refresh()
        }
        function ChangePeriodClick_MultiBankCB()
        {
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Reports/MultiBankCashBook/Frm_MultiBank_Cashbook_Specific_Period",
                cache: false,
                data:
                {
                    PeriodSelectionFirstTime: MultiBankCB_PeriodSelectionFirstTime,
                    xFrDate: $("#MultiBankCB_Fr_Date").val(),
                    xToDate: $("#MultiBankCB_To_Date").val()
                },
                success: function (data)
                {
                    OpenPopup("PopupCB_speceficPeriod", "Change Period", false, "auto", 250, true, data);
                }
            });
        }
        function Frm_Change_Period_Success_MultiBankCB(fromDate, ToDate)
        {
            var xFr_Date = JS_Json_DateToMomentDate(fromDate)
            var xTo_Date = JS_Json_DateToMomentDate(ToDate)
            $("#MultiBankCB_Fr_Date").val(xFr_Date.format("DD-MM-YYYY"));
            $("#MultiBankCB_To_Date").val(xTo_Date.format("DD-MM-YYYY"));
            $("#MultiBankCB_BE_View_Period").dxTextBox("instance").option("value", ("Fr.: " + xFr_Date.format("DD-MMM, YYYY") + " to " + xTo_Date.format("DD-MMM, YYYY")));
            $("#PopupCB_speceficPeriod").dxPopup("hide");
            MultiBankCashBookListGrid.refresh();
        }

        function MultiBankCashBook_DS()
        {
            return new DevExpress.data.CustomStore({
                key: "Grid_PK",
                loadMode:"raw",
                load: function (loadOptions)
                {
                    var frmDate = $("#MultiBankCB_Fr_Date").val()
                    if (frmDate == null || frmDate.length == 0)
                    {
                        return []
                    }
                    const deferred = $.Deferred();
                    $.ajax({
                        type: 'GET',
                        url: "/Reports/MultiBankCashBook/GetMultiBankCashBookData",
                        data:
                        {
                            xFrDate: $("#MultiBankCB_Fr_Date").val(),
                            xToDate: $("#MultiBankCB_To_Date").val(),
                        },
                        cache: false,
                        success: function (data)
                        {
                            //$("#MultiBankCB_BE_Cash_Bank").text("Cash: " + DxGrid_FormatNumber(data.Close_Cash_Bal) + "  Bank: " + DxGrid_FormatNumber(data.Close_Bank_Bal));                            

                                AddDynamicColumns_MultiBankCashBookListGrid(data.GridData)
                            //ActionAfter_MultiBankCashBookListGrid_Refresh(GridData, FilterString);
                            deferred.resolve(data.GridData);
                        }
                    });
                    return deferred.promise();
                }
            })
        }
        function AddDynamicColumns_MultiBankCashBookListGrid(data)
        {
            var _dt = data[0];
            var ExisitngColumns = MultiBankCashBookListGrid.option("columns");
            var FlattenedExisitingColumns = DxGrid_GetAllColumns(ExisitngColumns)
            var _columns = Object.keys(_dt)
            var DynamicColumns = _columns.filter((x) => x.startsWith("Dyn_"))
            if (DynamicColumns && DynamicColumns.length > 0)
            {
                for (var i = 0; i < DynamicColumns.length; i++)
                {
                    var ColSplit = DynamicColumns[i].split("_");
                    var band = ColSplit[1]
                    var Caption = ColSplit[ColSplit.length - 1]
                    var BandColumnIndex = ExisitngColumns.findIndex(x => x.caption && x.caption.startsWith(band) && x.isBand == true)
                    var index = FlattenedExisitingColumns.findIndex(x => x.dataField == DynamicColumns[i]);
                    if (index == -1)
                    {
                        //ExisitngColumns[BandColumnIndex].columns.push({
                        //    dataField: DynamicColumns[i],
                        //    caption: Caption + (band == "Rec" ? "(R)" : "(P)"),
                        //    visible: CB_ShowDynamicBankColumns,
                        //    showInColumnChooser: CB_ShowDynamicBankColumns,
                        //    dataType: "number",
                        //    format: DxGrid_FormatNumber,
                        //    allowGrouping: false,
                        //    minWidth:50
                        //});
                        var BankColIndex = ExisitngColumns[BandColumnIndex].columns.findIndex(x => x.caption == "Bank");
                        BankColIndex = BankColIndex > -1 ? BankColIndex : 1;
                        ExisitngColumns[BandColumnIndex].columns.splice(BankColIndex,0,{
                            dataField: DynamicColumns[i],
                            caption: Caption + (band == "Rec" ? "(R)" : "(P)"),
                            visible: MultiBankCB_ShowDynamicBankColumns,
                            showInColumnChooser: MultiBankCB_ShowDynamicBankColumns,
                            dataType: "number",
                            format: DxGrid_FormatNumber,
                            allowGrouping: false,
                            minWidth: 100
                        });
                    }
                    else
                    {                      
                        var visible = MultiBankCashBookListGrid.columnOption(DynamicColumns[i], "visible");                        
                        var ColIndex = ExisitngColumns[BandColumnIndex].columns.findIndex(item => item.dataField === DynamicColumns[i]);
                        if (ColIndex !== -1)
                        {
                            ExisitngColumns[BandColumnIndex].columns[ColIndex]["showInColumnChooser"] = MultiBankCB_ShowDynamicBankColumns;
                            ExisitngColumns[BandColumnIndex].columns[ColIndex]["visible"] = (MultiBankCB_ShowDynamicBankColumns && visible);
                        }
                    }
                }
            }
            let RemovedDynamicCol = FlattenedExisitingColumns.filter((x) => x.dataField.startsWith("Dyn_") && DynamicColumns.includes(x.dataField) == false);
            if (RemovedDynamicCol && RemovedDynamicCol.length > 0)
            {
                for (var i = 0; i < RemovedDynamicCol.length; i++)
                {
                    var ColSplit = RemovedDynamicCol[i].dataField.split("_");
                    var band = ColSplit[1]
                    var Caption = ColSplit[ColSplit.length - 1]
                    var BandColumnIndex = ExisitngColumns.findIndex(x => x.caption && x.caption.startsWith(band) && x.isBand == true)
                    var ColIndex = ExisitngColumns[BandColumnIndex].columns.findIndex(item => item.dataField === RemovedDynamicCol[i].dataField);
                    if (ColIndex !== -1)
                    {
                        ExisitngColumns[BandColumnIndex].columns.splice(ColIndex,1)
                    }
                }
            }
            MultiBankCashBookListGrid.beginUpdate();
            MultiBankCashBookListGrid.option("columns", ExisitngColumns);
            MultiBankCashBookListGrid.option("summary.totalItems", AddDynamicColumnsSummary_MultiBankCashBookListGrid())
            MultiBankCashBookListGrid.endUpdate();
            //MultiBankCashBookListGrid.option("CustomProp.FilterBuilderFieldsReady",false)
        }

        function OnMultiBankCashBookListPreviewClick()
        {
            if ("@CashBook_ExportRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed!!", "NO Rights");
                return;
            }
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Reports/MultiBankCashBook/Frm_Export_Options",
                cache: false,
                data:
                {
                    GridName:"MultiBankCashBookListGrid"
                },
                success: function (data)
                {
                    OpenPopup("report_modal", "Export Option", null, "auto", 125, true, data);
                }
            });

        }
        async function OnMultiBankCBChangeMode()
        {
            MultiBankCashBookListGrid.beginUpdate();
            if (MultiBankCB_ShowHorizontalBar == 0)
            {
                MultiBankCB_ShowHorizontalBar = 1;
                $("#MultiBankCashBookToggleScrollBar").find("span").text("Default Data");
                $("#MultiBankCashBookToggleScrollBar").width(110);
                MultiBankCashBookListGrid.option("columnHidingEnabled", false);
                MultiBankCashBookListGrid.option("allowColumnResizing", true)              
            }
            else
            {
                $("#MultiBankCashBookToggleScrollBar").find("span").text("Full Data");
                $("#MultiBankCashBookToggleScrollBar").width(90);
                MultiBankCashBookListGrid.option("columnHidingEnabled", true)
                MultiBankCashBookListGrid.option("allowColumnResizing", false)            
                var btntotal = $("#But_MultiBankShowTotal").dxButton("instance").option("text");
                if (btntotal.toUpperCase() == 'HIDE TOTAL BAL.')
                {
                    await ShowGrandTotal_MultiBankCB();
                }
                MultiBankCB_ShowHorizontalBar = 0;
            }
            MultiBankCashBookListGrid.endUpdate();
        }//full data button click
