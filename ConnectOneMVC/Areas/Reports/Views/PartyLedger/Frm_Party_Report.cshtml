    function PartyLedgerReportListGrid_Detail(container, GridName, RecID, Mid, vouchingMode, AllColumns,keyValue)
    {
        var url = "/Reports/PartyLedger/Frm_Party_Report_DetailGrid_Data?VouchingMode=" + vouchingMode + "&ID=" + RecID + "&MID=" + Mid
        var instance = DxGrid_AttachmentGrid_Create(container, GridName, keyValue, vouchingMode, AllColumns, url)
        instance.option("onSelectionChanged", PartyLedgerReportListGrid_Detail_onSelectionChanged);
    }
    function PartyLedgerReportListGrid_Detail_onSelectionChanged(e)
    {
        if (PartyLedger_IsDetailRowExpanded || PartyLR_IsVouchingMode)
        {
            if (e.selectedRowsData != null && e.selectedRowsData.length > 0)
            {
                PartyLedger_NestedGrid_AccessID = e.element[0].id;
                PartyLedgerReportListGrid_Detail_SelectedRowData(e.selectedRowsData)
            }
            else
            {
                PartyLedgerPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }
    function PartyLedgerReportListGrid_Detail_SelectedRowData(selectedData = null)
    {
        debugger
        if (selectedData == null)
        {
            selectedData = $("#" + PartyLedger_NestedGrid_AccessID).dxDataGrid("getSeletedRowsData");
        }
        var values = selectedData[0];
        PartyLedger_NestedRowKeyValue = values["UniqueID"];
        if (values["UniqueID"] != null)
        {
            PartyLedgerPrf_FAB.SetVisible(true);
            PartyLedger_Nested_Doc_Status = values["Doc_Status"];

            if (PartyLR_IsVouchingMode == true) {
                PartyLedgerPrf_FAB.SetActionContext("AuditActionContext", true);
            }
            else {
                if (PartyLedger_Nested_Doc_Status == "") {
                    PartyLedgerPrf_FAB.SetActionContext("AutoItemContext", true);
                }
                else if (PartyLedger_Nested_Doc_Status == "NO") {
                    PartyLedgerPrf_FAB.SetActionContext("EditItemContext", true);
                }
                else if (PartyLedger_Nested_Doc_Status == "YES") {
                    PartyLedgerPrf_FAB.SetActionContext("actionItemContext", true);
                }
            }
            PartyLedger_ParamMandatory = values["Params_Mandatory"];
            PartyLedger_FromDateLabel = values["LABEL_FROM_DATE"];
            PartyLedger_ToDateLabel = values["LABEL_TO_DATE"];
            PartyLedger_DescriptionLabel = values["LABEL_DESCRIPTION"];
            PartyLedger_Doc_Category = values["Document_Category"];
            PartyLedger_Doc_ID = values["Document_ID"];
            PartyLedger_AtachmentID = values["ATTACH_ID"];
            IndexAttachmentID = PartyLedger_AtachmentID;
            PartyLedger_MasterRowRecID = values["TxnID"];
            PartyLedger_MasterRowMID = values["TxnMID"];
            PartyLedger_NestedRowMapID = values["MAP_ID"];
            PartyLedger_reason = values["Reason"];
            PartyLedger_FileName = values["ATTACH_FILE_NAME"];
            PartyLedger_Attachment_RecStatus = values["Attachment_Action_Status"];
            if (PartyLedger_MasterRowMID != null && PartyLedger_MasterRowMID != "") {
                PartyLedger_RecID_ForAttachment = PartyLedger_MasterRowMID;
            }
            else if (PartyLedger_MasterRowRecID != null && PartyLedger_MasterRowRecID != "") {
                PartyLedger_RecID_ForAttachment = PartyLedger_MasterRowRecID;
            }
            PartyLedger_NestedRowReasonID = values["ReasonID"];
            IndexAttachmentReasonID = PartyLedger_NestedRowReasonID;
            if (PartyLR_IsVouchingMode == true)
            {
                if (PartyLedger_FileName != null && PartyLedger_FileName.length > 0)
                {
                    ViewDocument(PartyLedger_AtachmentID, PartyLedger_FileName, "PartyLedgerPrf_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else
                {
                    CloseRightPane();
                    ClearRightPane();
                }
            }
        }
    }

    function LeftPaneContent_PartyLedgerReportListGrid(GridName, ID, MID, vouchingMode, AllColumns = 0,keyValue="")
    {
        $("#LeftPane_Div_Content").html(null);
        $("#LeftPane_Div_Content").append("<div class='col-xs-12'><label>Documents Attached:</label><div class='AttachmentGrid'><form></form></div></div><div class='col-xs-12'><label>Additional Info:</label><div class='AdditionalInfoGrid'><form></form></div></div>")
        PartyLedgerReportListGrid_Detail($("#LeftPane_Div_Content .AttachmentGrid>form"), GridName, ID, MID, vouchingMode, AllColumns, keyValue)
        setTimeout(function () {
            AdditionalInfoGrid_PartyLedgerReportListGrid($("#LeftPane_Div_Content .AdditionalInfoGrid>form"), GridName, ID, MID, vouchingMode, AllColumns)
        })
    }
    function AdditionalInfoGrid_PartyLedgerReportListGrid(container, GridName, ID, MID, vouchingMode, AllColumns, onlyAdditional = false)
    {
        if (onlyAdditional)
        {
            $(container).html(null)
        }
        var url = "/Reports/PartyLedger/Frm_Party_Report_AdditionalGrid?VouchingMode=" + vouchingMode + "&ID=" + ID + "&MID=" + MID
        DxGrid_CreateAdditionalInfoGrid(container, GridName, ID, vouchingMode, AllColumns, url)
    }
</script>
<script>
    function On_PartyLedger_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName === "add_attach")
        {
            if ("@Help_Attachment_AddRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (PartyLedger_ParamMandatory == 1)
            {
                AddAttachment(PartyLedger_RecID_ForAttachment, "Accounts_CashBook", PartyLedger_Doc_ID, PartyLedger_Doc_Category, PartyLedger_ParamMandatory, PartyLedger_FromDateLabel, PartyLedger_ToDateLabel, PartyLedger_DescriptionLabel, "PartyLedgerAttachment", null, "PartyLedgerReportListGrid", PartyLedger_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(PartyLedger_RecID_ForAttachment, "Accounts_CashBook", PartyLedger_Doc_ID, "PartyLedgerAttachment", "PartyLedgerReportListGrid", PartyLedger_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach")
        {
            if ("@Help_Attachment_EditRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (PartyLedger_Attachment_RecStatus.toUpperCase() == "LOCKED")
            {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(PartyLedger_RecID_ForAttachment, "Accounts_CashBook", PartyLedger_AtachmentID, PartyLedger_ParamMandatory, PartyLedger_FromDateLabel, PartyLedger_ToDateLabel, PartyLedger_DescriptionLabel, "PartyLedgerAttachment", null, "PartyLedgerReportListGrid", PartyLedger_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(PartyLedger_RecID_ForAttachment, "Accounts_CashBook", PartyLedger_AtachmentID, PartyLedger_ParamMandatory, PartyLedger_FromDateLabel, PartyLedger_ToDateLabel, PartyLedger_DescriptionLabel, null, "PartyLedgerReportListGrid", PartyLedger_NestedGrid_AccessID, PartyLedger_Attachment_RecStatus);
        }
        else if (e.actionName === "view_attach")
        {
            if ("@Help_Attachment_ViewRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }


            ViewDocument(PartyLedger_AtachmentID, PartyLedger_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(PartyLedger_RecID_ForAttachment, "Accounts_CashBook", "Party Ledger Information", "PartyLedgerReportListGrid", PartyLedger_NestedGrid_AccessID);
        }
        else if (e.actionName === "Add_Reason")
        {
            if (PartyLedger_Doc_Category.toLowerCase() == "others") {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else {
                AttachmentAddReason(PartyLedger_RecID_ForAttachment, PartyLedger_NestedRowMapID, "Accounts_CashBook", "PartyLedgerReportListGrid", PartyLedger_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(PartyLedger_RecID_ForAttachment, PartyLedger_NestedRowMapID, "Accounts_CashBook", "PartyLedgerReportListGrid", PartyLedger_NestedGrid_AccessID, PartyLedger_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(PartyLedger_RecID_ForAttachment, PartyLedger_NestedRowMapID, "PartyLedgerReportListGrid", PartyLedger_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
        else if (e.actionName == "AuditAction") {
            s.SetActionContext("AuditActionContext", true);
        }
        else if (e.actionName == "BackAudit") {
            if (PartyLedger_Nested_Doc_Status == "") {
                s.SetActionContext("AutoItemContext", true);
            }
            if (PartyLedger_Nested_Doc_Status == "NO") {
                s.SetActionContext("EditItemContext", true);
            }
            if (PartyLedger_Nested_Doc_Status == "YES") {
                s.SetActionContext("actionItemContext", true);
            }
        }
        else if (e.actionName == "Accept") {
            OnPartyLedger_AcceptwithoutRemarks();
        }
        else if (e.actionName == "Reject") {
            OnPartyLedger_AcceptRejectVoucher("Reject");
        }
        else if (e.actionName == "AcceptWithRemarks") {
            OnPartyLedger_AcceptRejectVoucher("Accept");
        }
    }
    function PartyLedgerOnGridFocusedRowChanged(s, e) {
        if (s.GetFocusedRowIndex() > -1) {
            if (PartyLR_IsVouchingMode) {
                PartyLedgerPrf_FAB.SetVisible(true);
                PartyLedgerPrf_FAB.SetActionContext("VouchingActionContext", true);
            }

            s.GetRowValues(s.GetFocusedRowIndex(), 'TR_M_ID;REC_ID;iTR_TEMP_ID', OnPartyLedgerReport_GetMainGridRowValues);
        }
        else {
            PartyLedger_TR_M_ID = null;
            PartyLedger_REC_ID = null;
            PartyLedger_iTR_TEMP_ID = null;
        }
    }
    function OnPartyLedgerReport_GetMainGridRowValues(PartyLedgerReport_MainGridRowValues) {
        PartyLedger_TR_M_ID = PartyLedgerReport_MainGridRowValues[0];
        PartyLedger_REC_ID = PartyLedgerReport_MainGridRowValues[1];
        PartyLedger_iTR_TEMP_ID = PartyLedgerReport_MainGridRowValues[2];
        if (PartyLR_IsVouchingMode == true) {
            OpenLeftPane();
            LoadDocumentAndAdditionalInfoInLeftPane("Reports", "PartyLedger", "LeftPaneContent", PartyLedger_REC_ID, PartyLR_IsVouchingMode, PartyLedger_iTR_TEMP_ID == PartyLedger_REC_ID ? "" : PartyLedger_iTR_TEMP_ID);
        }
    }
    function OnPartyLedgerReportListGridNestedFocusedRowChange(s, e)
    {
        if (PartyLedger_IsDetailRowExpanded || PartyLR_IsVouchingMode == true )
        {
            PartyLedger_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
            if (PartyLedger_NestedRecord_FocusedRowIndex >= 0)
            {
                ShowLoader();
                PartyLedger_NestedGrid_AccessID = s.uniqueID;
                s.GetRowValues(s.GetFocusedRowIndex(), 'Doc_Status;Params_Mandatory;LABEL_FROM_DATE;LABEL_TO_DATE;LABEL_DESCRIPTION;Document_Category;Document_ID;ATTACH_ID;TxnID;TxnMID;MAP_ID;Reason;ATTACH_FILE_NAME;Attachment_Action_Status;UniqueID;ReasonID', OnPartyLedger_GetGridRowValues);
            }
            else
            {
                PartyLedgerPrf_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }
    function OnPartyLedger_GetGridRowValues(values)
    {
        if (values[14] != null)
        {
            PartyLedgerPrf_FAB.SetVisible(true);

            PartyLedger_Nested_Doc_Status = values[0];

            if (PartyLR_IsVouchingMode == true) {
                PartyLedgerPrf_FAB.SetActionContext("AuditActionContext", true);
            }
            else {
                if (PartyLedger_Nested_Doc_Status == "") {
                    PartyLedgerPrf_FAB.SetActionContext("AutoItemContext", true);
                }
                else if (PartyLedger_Nested_Doc_Status == "NO") {
                    PartyLedgerPrf_FAB.SetActionContext("EditItemContext", true);
                }
                else if (PartyLedger_Nested_Doc_Status == "YES") {
                    PartyLedgerPrf_FAB.SetActionContext("actionItemContext", true);
                }
            }

            PartyLedger_ParamMandatory = values[1];
            PartyLedger_FromDateLabel = values[2];
            PartyLedger_ToDateLabel = values[3];
            PartyLedger_DescriptionLabel = values[4];
            PartyLedger_Doc_Category = values[5];
            PartyLedger_Doc_ID = values[6];
            PartyLedger_AtachmentID = values[7];
            IndexAttachmentID = PartyLedger_AtachmentID;
            PartyLedger_MasterRowRecID = values[8];
            PartyLedger_MasterRowMID = values[9];
            PartyLedger_NestedRowMapID = values[10];
            PartyLedger_reason = values[11];
            PartyLedger_FileName = values[12];
            PartyLedger_Attachment_RecStatus = values[13];
            PartyLedger_NestedRowKeyValue = values[14];
            PartyLedger_NestedRowReasonID = values[15];
            IndexAttachmentReasonID = PartyLedger_NestedRowReasonID;

            HideLoader();

            if (PartyLedger_MasterRowMID != null && PartyLedger_MasterRowMID != "") {
                PartyLedger_RecID_ForAttachment = PartyLedger_MasterRowMID;
            }
            else if (PartyLedger_MasterRowRecID != null && PartyLedger_MasterRowRecID != "") {
                PartyLedger_RecID_ForAttachment = PartyLedger_MasterRowRecID;
            }
        }
    }
    function PartyLedgerReportListGrid_Nested_BeginCallBack(s, e)
    {
        e.customArgs["ShowHorizontalBar"] = PartyLedgerReport_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = PartyLR_IsVouchingMode;
        e.customArgs["command"] = e.command;
    }
    function PartyLedger_DetailRowExpanding(s, e)
    {
        PartyLedger_IsDetailRowExpanded = true;
        s.SetFocusedRowIndex(e.visibleIndex);
        var pane = Mainspliter.GetPaneByName('RightPane');
        if (PartyLR_IsVouchingMode == true) {
            pane.Expand();
        }
        else {
            pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
        }
    }
    function PartyLedger_DetailRowCollapsing(s, e)
    {
        PartyLedger_IsDetailRowExpanded = false;
        s.SetFocusedRowIndex(e.visibleIndex);
        if (PartyLR_IsVouchingMode == true) {
            if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false) {
                CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
        else {
            PartyLedgerPrf_FAB.SetVisible(false);
        }
    }
    function OnPartyLedger_AcceptwithoutRemarks() {
            var Recid;
            if (PartyLedger_IsDetailRowExpanded == true || PartyLR_IsVouchingMode == true) {
                if (PartyLedger_MasterRowMID == null || PartyLedger_MasterRowMID == "") {
                    if (PartyLedger_MasterRowRecID == null || PartyLedger_MasterRowRecID == "") {
                        Recid = (PartyLedger_TR_M_ID == null || PartyLedger_TR_M_ID == "") ? PartyLedger_REC_ID : PartyLedger_TR_M_ID;
                    }
                    else {
                        Recid = PartyLedger_MasterRowRecID;
                    }
                }
                else {
                    Recid = PartyLedger_MasterRowMID;
                }
            }
            else {
                Recid = (PartyLedger_TR_M_ID == null || PartyLedger_TR_M_ID == "") ? PartyLedger_REC_ID : PartyLedger_TR_M_ID;
            }

            Entry_AcceptwithoutRemarks(Recid, "Report_PartyReport", "PartyLedgerReportListGrid", PartyLedger_AtachmentID, PartyLedger_NestedRowReasonID, PartyLedger_NestedRowKeyValue);
        }
    function OnPartyLedger_AcceptRejectVoucher(_actionMethod) {
            var Recid;
            if (PartyLedger_IsDetailRowExpanded == true || PartyLR_IsVouchingMode == true) {
                if (PartyLedger_MasterRowMID == null || PartyLedger_MasterRowMID == "") {
                    if (PartyLedger_MasterRowRecID == null || PartyLedger_MasterRowRecID == "") {
                        Recid = (PartyLedger_TR_M_ID == null || PartyLedger_TR_M_ID == "") ? PartyLedger_REC_ID : PartyLedger_TR_M_ID;
                    }
                    else {
                        Recid = PartyLedger_MasterRowRecID;
                    }
                }
                else {
                    Recid = PartyLedger_MasterRowMID;
                }
            }
            else {
                Recid = (PartyLedger_TR_M_ID == null || PartyLedger_TR_M_ID == "") ? PartyLedger_REC_ID : PartyLedger_TR_M_ID;
            }
            Entry_AcceptReject(_actionMethod, Recid, "Report_PartyReport", "PartyLedgerReportListGrid", PartyLedger_AtachmentID, PartyLedger_NestedRowReasonID, PartyLedger_NestedRowKeyValue);
        }
 </script>
    @* PartyLedger_AuditActionButton_Functions *@
</div>