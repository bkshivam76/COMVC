<script>
    function PartyLedgerReportListGrid_OnInitialized(e)
    {
        DxGrid_AdjustSize(e.component, $("#PartyLedger_ParentDiv .report_button_div"),"@CalledFromOtherScreen")
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            DxGrid_AdjustSize(e.component, $("#PartyLedger_ParentDiv .report_button_div"), "@CalledFromOtherScreen", evt)
        });
        PartyLedgerReportListGrid = e.component;
    }
    function PartyLedgerReportListGrid_OnCellPrepared(e)
    {
        if (e.rowType == "data")
        {
            if (PartyLR_IsVouchingMode == true)
            {
                if (e.column.dataField === "iIcon")
                {
                    $(e.cellElement).attr("onmouseover", "OnGridRowMouseHoverIn(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.key + "')");
                    $(e.cellElement).attr("onmouseout", "OnGridRowMouseHoverOut(event,this,'" + e.element[0].id + "','" + e.rowIndex + "','" + e.key + "')");
                }
            }
            $(e.cellElement).attr("id", e.element[0].id + "_Cell_" + e.key + "|" + e.column.dataField);
            /*$(e.cellElement).addClass("col_" + e.column.dataField + " row_" + e.key);*/
            if (e.column.type == "detailExpand")
            {
                if (e.key == "Opening_Balance")
                {
                    $(e.cellElement).addClass("hideDetail");
                }
            }
        }
    }
    function PartyLedgerReportListGrid_OnRowPrepared(e)
    {
        if (e.rowType == "data")
        {
            var GridName = e.element[0].id;
            var keyvalue = e.key.ReplaceSpecialwith_();
            var key = e.key;
            $(e.rowElement).addClass(GridName + "_DataRow_" + e.key)
            let Remarks = e.data.NARRATION;
            var PreviewRowContent = PartyLedgerReportListGrid_PreviewRow_Template(e)
            var PreviewRowClass = GridName + "_PreviewRow " + GridName + "_PreviewRow_" + key + " DataGridPreviewRow " + keyvalue
            var PreviewRowOptions = "";
            if (PartyLR_IsVouchingMode == true)
            {
                PreviewRowOptions = "style='display:none' onmouseover=OnGridPrevRowMouseHoverIn(event,this,'" + GridName + "','" + e.rowIndex + "','" + key + "') onmouseout=OnGridPrevRowMouseHoverOut(event,this,'" + GridName + "','" + e.rowIndex + "','" + key + "')"
            }
            else
            {
                if (Remarks == null || Remarks.length == 0)
                {
                    PreviewRowOptions = "style='display:none'";
                    PreviewRowClass += " empty";
                }
            }
            var EmptyTdshtml = "";
            var emptyTd = $(e.rowElement).find('td.dx-datagrid-group-space').length
            for (var i = 0; i < emptyTd; i++) {
                EmptyTdshtml += "<td></td>"
            }
            ($(e.rowElement).parent()).append("<tr class='" + PreviewRowClass + "' " + PreviewRowOptions + ">" + EmptyTdshtml + "<td colspan='" + e.columns.length + "'>" + PreviewRowContent + "</td></tr>")

        }
        else if (e.rowType == "detailAdaptive") {
            DxGrid_MovePreviewRowAfterAdaptiveRow(e)
        }
    }
    function PartyLedgerReportListGrid_OnContentReady(e)
    {
        DxGrid_RowSelectionTobeCheckedAfterAnyAction(e, PartyLedger_Expanded_Row_Key)
        DxGrid_OnContentReady(e, PartyLedgerReport_ShowHorizontalBar);       
    }
    function PartyLedgerReportListGrid_OnCellDblClick(e)
    {
        if (e.rowType == "data")
        {
            if (PartyLR_IsVouchingMode == true && PartyLedger_ViewMode == "Default")
            {
                OnGridCellClick(e.event, e.cellElement[0], e.columnIndex, e.rowIndex, e.element[0].id, e.key, e.column.dataField)
            }
        }
    }
    function PartyLedgerReportListGrid_OnSelectionChanged(e)
    {
        var selectedRowKeys = e.selectedRowKeys;
        if (selectedRowKeys != null && selectedRowKeys.length > 0)
        {
            if (PartyLR_IsVouchingMode)
            {
                PartyLedgerPrf_FAB.SetVisible(true);
                PartyLedgerPrf_FAB.SetActionContext("AddAttachmentContext", true);
            }
            PartyLedgerReportListGrid_SelectedRowData(e.selectedRowsData);
        }
        else
        {
            PartyLedger_iTR_TEMP_ID= null;
        }
    }
    function PartyLedgerReportListGrid_SelectedRowData(selectedData = null)
    {
        if (selectedData == null)
        {
            selectedData = PartyLedgerReportListGrid.getSelectedRowsData();
        }
        if (selectedData != null && selectedData.length > 0)
        {
            var values = selectedData[0]
            PartyLedger_TR_M_ID = values["TR_M_ID"];
            PartyLedger_REC_ID = values["REC_ID"];
            PartyLedger_iTR_TEMP_ID = values["iTR_TEMP_ID"];
            if (PartyLR_IsVouchingMode == true)
            {
                OpenLeftPane();
                LeftPaneContent_PartyLedgerReportListGrid("PartyLedgerReportListGrid", PartyLedger_REC_ID, PartyLedger_TR_M_ID, PartyLR_IsVouchingMode, PartyLedgerReport_ShowHorizontalBar, PartyLedger_iTR_TEMP_ID)
            }
        }
        else
        {
            PartyLedger_iTR_TEMP_ID = null;
        }
    }
    function PartyLedgerReportListGrid_OnRowExpanding(e)
    {
        if (Array.isArray(e.key) == false) //not group row
        {
            e.component.collapseRow(PartyLedger_Expanded_Row_Key)
            e.component.selectRows(e.key);
            PartyLedger_Expanded_Row_Key = e.key;
            PartyLedger_IsDetailRowExpanded = true;
            var DetailGridID = e.element[0].id + e.key;
            var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
            if (instance != void 0)
            {
                instance.state(null) // grid maintains its state after collapsing so resetting the state when expands again as per old grid
            }
            //e.component.collapseAll(-1);
        }
        else {
            e.component.option("CustomProp.groupRowExpanded", true);
        }
    }
    function PartyLedgerReportListGrid_OnRowCollapsing(e)
    {
        if (Array.isArray(e.key) == false) //not group row
        {
            var DetailGridID = e.element[0].id + e.key;
            sessionStorage.removeItem(DetailGridID + "_DetailGridState") //removing grid state from session storage on collapse
            PartyLedger_IsDetailRowExpanded = false;
            e.component.selectRows(e.key);
            if (PartyLR_IsVouchingMode == false)
            {
                PartyLedgerPrf_FAB.SetVisible(false);
            }
            var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance")
            if (instance != void 0) {
                instance.clearSelection();
            }
        }
        else {
            e.component.option("CustomProp.groupRowCollapsed", true);
        }
    }
    function PartyLedgerReportListGrid_OnContextMenuPreparing(e)
    {
        if (!e.items) e.items = [];
        if (e.target == "header")
        {
            DxGrid_HeaderContextMenu(e)
        }
        else if ((e.target == "content" && e.row && e.row.rowType == "groupFooter") || e.target == "footer")
        {
            if (PartyLedger_ViewMode == "Compact")
                DxGrid_FooterContextMenu(e, true);
            else
                DxGrid_FooterContextMenu(e);
        }
        else if (e.target == "content" && e.row && (e.row.rowType == "data" || e.row.rowType == "detailAdaptive"))
        {
            var key = e.component.getKeyByRowIndex(e.row.rowIndex);
            e.component.selectRows(key);
            var expanded = e.component.isRowExpanded(key);
            var hasDetail = true;
            if (PartyLR_IsVouchingMode == false) {
                var cellEle = e.component.getCellElement(e.row.rowIndex, 0)
                hasDetail = !(cellEle[0].classList.contains("hideDetail"))
            }
            e.items = [
                {
                    text: "Expand Detail",
                    icon: "fa-solid fa-arrow-down-wide-short " + (expanded ? "text-muted" : "text-info"),
                    disabled: expanded,
                    visible: !PartyLR_IsVouchingMode && hasDetail,
                    onItemClick: function () {
                        if (expanded) {
                        }
                        else {
                            e.component.expandRow(key);
                        }
                    }
                },
                {
                    text: "Collapse Detail",
                    icon: "fa-solid fa-arrow-up-wide-short " + (!expanded ? "text-muted" : "text-info"),
                    disabled: !expanded,
                    visible: !PartyLR_IsVouchingMode && hasDetail,
                    onItemClick: function ()
                    {
                        if (expanded)
                        {
                            e.component.collapseRow(key);
                        }
                        else
                        {
                        }
                    }
                },
                {
                    text: "Print",
                    icon: "print",
                    visible: "@PartyLedger_ExportRight" == "True",
                    beginGroup: true,
                    onItemClick: function () {
                        OnPartyLedgerReportListPreviewClick();
                    }
                },
                     {
                    text: "Export",
                    icon: "fa-solid fa-file-export text-warning",
                    visible: "@PartyLedger_ExportRight" == "True",
                    beginGroup: true,
                    onItemClick: function () {
                        OnPartyLedgerReportExportClick();
                    }
                },
                {
                    text: "Close",
                    icon: "fa-solid fa-rectangle-xmark text-danger",
                    beginGroup: true,
                    onItemClick: function ()
                    {
                        closePartyLedger();
                    }
                },
                {
                    text: "Refresh",
                    icon: "fa-solid fa-arrow-rotate-right text-success",
                    beginGroup: true,
                    onItemClick: function ()
                    {
                        gridRefreshRequired_PartyLedger = false;
                        PartyLedgerReportListGrid.refresh()
                    }
                }
            ]
        }
        else if (e.target == "content" && e.row == void 0) {
            e.items = [{
                text: "Close",
                icon: "fa-solid fa-rectangle-xmark text-danger",
                beginGroup: true,
                onItemClick: function () {
                    closePartyLedger();
                }
            },
                {
                    text: "Refresh",
                    icon: "fa-solid fa-arrow-rotate-right text-success",
                    beginGroup: true,
                    onItemClick: function () {
                        gridRefreshRequired_PartyLedger = false;
                        PartyLedgerReportListGrid.refresh()
                    }
                }

            ]
        }
    }
