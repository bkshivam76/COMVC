    var PartyLedger_NestedRowReasonID;
    var PartyLedgerReportListGrid;
    var PartyLedger_Expanded_Row_Key;
    var VisibleColumns_PartyLedger;
    var gridRefreshRequired_PartyLedger = false;

    $(document).ready(async function ()
    {
        debugger
        if ("@PartyLedger_ExportRight" == "False")
        {
	        $("#PartyLedgerReportModelListPreview").hide();
	        $("#PartyLedgerReportModelPrint").hide();
        }
        if (PartyLR_IsVouchingMode == true)
        {
            $(".PartyLedgerReportListGrid_PreviewRow").hide();
        }
        else
        {
            $(".PartyLedgerReportListGrid_PreviewRow").show();
        }
        GetSessionStorage("PartyLedgerReportListGrid");
        await PeriodSelection_PartyLedger_OnValueChanged(null,true)
        if ("@ViewBag.SelectedPartyValue".length > 0)
        {
            await Party_PartyLedger_OnValueChanged(null,true)
        }
        if ("@ViewBag.xFr_Date".length > 0)
        {
            await showPartyLedger();
        }
        if (PartyLedger_SetVouchingModeOn == true)
        {
            $("#PartyLedgerViewModeSwitch").dxSwitch("instance").option("value", true);
        }
    });
    async function Party_PartyLedger_OnValueChanged(e, FirstCall = false)
    {
        gridRefreshRequired_PartyLedger = true;
        var partyID;
        var partyDG = $("#Party_DG_PartyLedger").dxDataGrid("instance")
        if (e)
        {
            partyID = e.value;
            if ((e.value == null || e.value.length == 0) && e.previousValue != null)
            {
                partyDG.clearSelection();
                return;
            }
        }
        else
        {
            partyID = $("#Party_PartyLedger").dxDropDownBox("option", "value");
        }
        await partyDG.selectRows(partyID);   
        //if (partyDG.getSelectedRowsData().length > 0)
        //{
        //    var item = partyDG.getSelectedRowsData()[0];
        //}
    }
    async function PeriodSelection_PartyLedger_OnValueChanged(e, FirstCall = false)
    {
        debugger
        gridRefreshRequired_PartyLedger = true;
        var PeriodSelectedIndex;
        if (e)
        {
            PeriodSelectedIndex = e.value;
        }
        else
        {
            PeriodSelectedIndex = $("#PeriodSelection_PartyLedger").dxSelectBox("option", "value")
        }
        if (PeriodSelectedIndex == null || PeriodSelectedIndex < 0)
        {
            return;
        }
        var xFr_Date, xTo_Date, MonthText, DataSource, _xDate;
        DataSource = $("#PeriodSelection_PartyLedger").dxSelectBox("getDataSource");
        var isLoaded = DataSource.isLoaded();
        if (isLoaded == false)
        {
            await DataSource.load();
        }
        MonthText = $("#PeriodSelection_PartyLedger").dxSelectBox("option", "text");
        $("#btnChangePeriod_PartyLedger").dxButton("instance").option("disabled", true);
        if (PeriodSelectedIndex == 20)
        {
            $("#btnChangePeriod_PartyLedger").dxButton("instance").option("disabled", false);
            if (FirstCall == false)
            {
                $("#btnChangePeriod_PartyLedger").trigger("dxclick")
                return;
            }
            else
            {
                xFr_Date = StringToMomentDate("@ViewBag.xFr_Date","DD-MM-YYYY")
                xTo_Date = StringToMomentDate("@ViewBag.xTo_Date","DD-MM-YYYY")
            }
        }
        else if (PeriodSelectedIndex >= 0 && PeriodSelectedIndex <= 11)
        {
            var Sel_Mon = (MonthText.substr(0, 3)).toUpperCase();
            var SEL_MM;
            switch (Sel_Mon) {
                case "JAN": SEL_MM = 1; break;
                case "FEB": SEL_MM = 2; break;
                case "MAR": SEL_MM = 3; break;
                case "APR": SEL_MM = 4; break;
                case "MAY": SEL_MM = 5; break;
                case "JUN": SEL_MM = 6; break;
                case "JUL": SEL_MM = 7; break;
                case "AUG": SEL_MM = 8; break;
                case "SEP": SEL_MM = 9; break;
                case "OCT": SEL_MM = 10; break;
                case "NOV": SEL_MM = 11; break;
                case "DEC": SEL_MM = 12; break;
                default: SEL_MM = 4; break;
            }
            xFr_Date = moment(new Date(MonthText.substr(4, 4), (SEL_MM - 1), 1)) //js date starts from 0
            _xDate = xFr_Date.clone() //moment fns are mutable
            xTo_Date = _xDate.add(1, 'M').subtract(1, 'd');
        }
        else if (PeriodSelectedIndex == 12)
        {
            xFr_Date = moment(new Date("@OpenYearSdt.Year", 3, 1))
            _xDate = xFr_Date.clone()
            xTo_Date = _xDate.add(3, 'M').subtract(1, 'd');
        }
        else if (PeriodSelectedIndex == 13)
        {
            xFr_Date = moment(new Date("@OpenYearSdt.Year", 6, 1))
            _xDate = xFr_Date.clone()
            xTo_Date = _xDate.add(3, 'M').subtract(1, 'd');
        }
        else if (PeriodSelectedIndex == 14)
        {
            xFr_Date = moment(new Date("@OpenYearSdt.Year", 9, 1))
            _xDate = xFr_Date.clone()
            xTo_Date = _xDate.add(3, 'M').subtract(1, 'd');
        }
        else if (PeriodSelectedIndex == 15)
        {
            xFr_Date = moment(new Date("@OpenYearEdt.Year", 0, 1))
            _xDate = xFr_Date.clone()
            xTo_Date = _xDate.add(3, 'M').subtract(1, 'd');
        }
        else if (PeriodSelectedIndex == 16)
        {
            xFr_Date = moment(new Date("@OpenYearSdt.Year", 3, 1))
            _xDate = xFr_Date.clone()
            xTo_Date = _xDate.add(6, 'M').subtract(1, 'd');
        }
        else if (PeriodSelectedIndex == 17)
        {
            xFr_Date = moment(new Date("@OpenYearSdt.Year", 9, 1))
            _xDate = xFr_Date.clone()
            xTo_Date = _xDate.add(6, 'M').subtract(1, 'd');
        }
        else if (PeriodSelectedIndex == 18)
        {
            xFr_Date = moment(new Date("@OpenYearSdt.Year", 3, 1))
            _xDate = xFr_Date.clone()
            xTo_Date = _xDate.add(9, 'M').subtract(1, 'd');
        }
        else if (PeriodSelectedIndex == 19)
        {
            xFr_Date = moment(new Date("@OpenYearSdt.Year", 3, 1))
            xTo_Date = moment(new Date("@OpenYearEdt.Year",2, 31))
        }
        $("#Fr_Date_PartyLedger").val(xFr_Date.format("DD-MM-YYYY"));
        $("#To_Date_PartyLedger").val(xTo_Date.format("DD-MM-YYYY"));
        $("#Party_Ledger_BE_View_Period").text(("Fr.: " + xFr_Date.format("DD-MMM, YYYY") + " to " + xTo_Date.format("DD-MMM, YYYY")));
    }
    function ChangePeriodClick_PartyLedger()
    {
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Reports/PartyLedger/Frm_PartyLedger_Specific_Period",
            cache: false,
            data:
            {
                xFrDate: $("#Fr_Date_PartyLedger").val(),
                xToDate: $("#To_Date_PartyLedger").val()
            },
            success: function (data) {
                OpenPopup("PopupCB_speceficPeriod", "Change Period", false, "auto", 250, true, data);
            }
        });
    }
    function Frm_Change_Period_Success_PartyLedger(fromDate, ToDate)
    {
        var xFr_Date = JS_Json_DateToMomentDate(fromDate)
        var xTo_Date = JS_Json_DateToMomentDate(ToDate)
        $("#Fr_Date_PartyLedger").val(xFr_Date.format("DD-MM-YYYY"));
        $("#To_Date_PartyLedger").val(xTo_Date.format("DD-MM-YYYY"));
        $("#Party_Ledger_BE_View_Period").text(("Fr.: " + xFr_Date.format("DD-MMM, YYYY") + " to " + xTo_Date.format("DD-MMM, YYYY")));
        $("#PopupCB_speceficPeriod").dxPopup("hide");
    }
    async function showPartyLedger()
    {
        var _partyID = $("#Party_PartyLedger").dxDropDownBox("option", "value")
        var Period = $("#PeriodSelection_PartyLedger").dxSelectBox("option", "value")
        if (_partyID == null || _partyID.length == 0)
        {
            DevExpress.ui.dialog.alert("Please select Party", "Information").done(function ()
            {
                $("#Party_PartyLedger").dxDropDownBox("focus");
            })
            return;
        }
        if (Period == null)
        {
            DevExpress.ui.dialog.alert("Please select Period", "Information").done(function () {
                $("#PeriodSelection_PartyLedger").dxSelectBox("focus");
            })
            return;
        }
        await DevExpress.ui.dialog.alert("1. Please ensure that account analysis is not showing any mistakes relating to the party<br>2. Check the party ledger thoroughly before sending the statement to any third party", "Disclaimer")
        gridRefreshRequired_PartyLedger = false;
        await PartyLedgerReportListGrid.refresh();
    }
    function PartyLedger_DS()
    {
        return new DevExpress.data.CustomStore({
            key: "iTR_TEMP_ID",
            loadMode: "raw",
            load: function (loadOptions)
            {
                var frmDate = $("#Fr_Date_PartyLedger").val()
                var partyid = $("#Party_PartyLedger").dxDropDownBox("option", "value")
                if (frmDate == null || frmDate.length == 0 || partyid == null || partyid.length == 0)
                {
                    return []
                }
                const deferred = $.Deferred();
                $.ajax({
                    type: 'GET',
                    url: "/Reports/PartyLedger/PartyLedgerData",
                    data:
                    {
                        Fr_Date: $("#Fr_Date_PartyLedger").val(),
                        To_Date: $("#To_Date_PartyLedger").val(),
                        PartyID: partyid,
                        Opening: PartyLedger_Opening,
                    },
                    cache: false,
                    success: function (data)
                    {
                        PartyLedger_Opening = data.Opening
                        $("#lbl_Ledger_Balance").text(data.lblNetBalance);
                        deferred.resolve(data.GridData);
                    }
                });
                return deferred.promise();
            }
        })
    }

    function PartyLR_VouchingSwitch_ValueChange(e)
    {
        PartyLR_IsVouchingMode = e.value;
