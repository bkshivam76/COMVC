                <label class="report_header_label">Party Ledger</label>
            </div>
            <div class="report_button_div">
                @(Html.DevExtreme().Switch().ID("PartyLRVouchingModeSwitch").SwitchedOnText("Vouching On").SwitchedOffText("Vouching Off").OnValueChanged("PartyLR_VouchingSwitch_ValueChange").Width(100).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
                @(Html.DevExtreme().Switch().ID("PartyLedgerViewModeSwitch").SwitchedOnText("Compact").SwitchedOffText("Default").OnValueChanged("PartyLedger_ViewSwitch_ValueChange").Width(70).Visible(UserType.ToUpper() == "SUPERUSER" || UserType.ToUpper() == "AUDITOR"))
