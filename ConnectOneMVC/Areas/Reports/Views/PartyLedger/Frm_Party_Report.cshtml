    {
        var iREQ_ATTACH_COUNT = templateData.data.iREQ_ATTACH_COUNT
        var iCOMPLETE_ATTACH_COUNT = templateData.data.iCOMPLETE_ATTACH_COUNT
        var iRESPONDED_COUNT = templateData.data.iRESPONDED_COUNT
        var iREJECTED_COUNT = templateData.data.iREJECTED_COUNT
