    function PartyLedgerReportListGrid_DetailTemplate(container, templateData)
    {
        var GridName = templateData.component.element()[0].id
        var ID = templateData.data.REC_ID ?? "";
        var MID = templateData.data.TR_M_ID ?? "";
        PartyLedgerReportListGrid_Detail(container, GridName, ID, MID, PartyLR_IsVouchingMode, PartyLedgerReport_ShowHorizontalBar, templateData.data.iTR_TEMP_ID);
