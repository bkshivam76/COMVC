                @(Html.DevExtreme().Button().ID("PartyLedgerReportModelPrint").Text("Print").Icon("print").Width(80).OnClick(@<text>function () {OnPartyLedgerReportListPreviewClick();}</text>))
                @(Html.DevExtreme().Button().ID("PartyLedgerReportModelListPreview").Text("Export").Icon("save").Width(80).OnClick(@<text>function () {OnPartyLedgerReportExportClick();}</text>))
                @(Html.DevExtreme().Button().ID("PartyLedgerReportModelCLOSE").Text("Close").Icon("clear").OnClick(@<text>function (){closePartyLedger();}</text>))
