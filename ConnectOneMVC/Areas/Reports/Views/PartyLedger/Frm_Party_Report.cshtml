            CloseLeftPane();
        }
        PartyLedgerReportListGrid.clearSelection();
        PartyLedgerReportListGrid.option("masterDetail.enabled", !PartyLR_IsVouchingMode)
        PartyLedgerReportListGrid.repaint();

            //PartyLedgerReportListGrid.SetFocusedRowIndex(-1);
            //PartyLR_IsVouchingMode = e.value;
            //PartyLedgerPrf_FAB.SetVisible(false);
            //if (PartyLR_IsVouchingMode == true)
            //{
            //    OpenRightPane();
            //    ClearLeftPane();
            //    OpenLeftPane();
            //}
            //else
            //{
            //    PartyLedgerPrf_FAB.SetActionContext("AddAttachmentContext", false);
            //    CloseRightPane();
            //    ClearLeftPane();
            //    CloseLeftPane();
            //}
            //PartyLedgerReportListGrid_CollapseAllDetailRows();
    }
    function PartyLedger_ViewSwitch_ValueChange(e)
    {
        PartyLedger_ViewMode = e.value == false ? "Default" : "Compact";
        if (PartyLedger_SetVouchingModeOn == true) {
            $("#PartyLRVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }
        PartyLedgerReportListGrid.beginUpdate();
        var columns = PartyLedgerReportListGrid.option("columns");
        if (PartyLedger_ViewMode == "Compact") {
            VisibleColumns_PartyLedger = [];
            for (var i = 0; i < columns.length; i++) {
                var name = columns[i].dataField;
                var ColumnVisible = PartyLedgerReportListGrid.columnOption(name, "visible");
                if (name == "PartyLedgerReportListGrid_Compact_Column") {
                    PartyLedgerReportListGrid.columnOption(name, "visible", true);
                }
                else if (ColumnVisible == true && name != "iIcon") {
                    VisibleColumns_PartyLedger.push(name);
                    PartyLedgerReportListGrid.columnOption(name, "visible", false);
                }
            }
        }
        else {
            PartyLedgerReportListGrid.columnOption("PartyLedgerReportListGrid_Compact_Column", "visible", false);
            for (var i = 0; i < VisibleColumns_PartyLedger.length; i++) {
                PartyLedgerReportListGrid.columnOption(VisibleColumns_PartyLedger[i], "visible", true);
            }
        }
        PartyLedgerReportListGrid.repaint();
        PartyLedgerReportListGrid.endUpdate();

            //PartyLedger_ViewMode = e.value == false ? "Default" : "Compact";
            //if (PartyLedger_SetVouchingModeOn == true)
            //{
            //    PartyLedger_SetVouchingModeOn = false;
            //    $("#PartyLRVouchingModeSwitch").dxSwitch("instance").option("value", true);
            //}
            //else
            //{
            //    PartyLedgerReportListGrid.CollapseAllDetailRows();
            //}
    }
    function PartyLedgerReport_changeMode()
    {
            PartyLedgerReportListGrid.beginUpdate();
            if (PartyLedgerReport_ShowHorizontalBar == 0) {
                PartyLedgerReport_ShowHorizontalBar = 1;
                $("#PartyLedgerReportToggleScrollBar").find("span").text("Default Data");
                $("#PartyLedgerReportToggleScrollBar").width(110);
                PartyLedgerReportListGrid.option("columnHidingEnabled", false);
                PartyLedgerReportListGrid.option("allowColumnResizing", true)
            }
            else {
                PartyLedgerReport_ShowHorizontalBar = 0;
                $("#PartyLedgerReportToggleScrollBar").find("span").text("Full Data");
                $("#PartyLedgerReportToggleScrollBar").width(90);
                PartyLedgerReportListGrid.option("columnHidingEnabled", true)
                PartyLedgerReportListGrid.option("allowColumnResizing", false)
            }
            PartyLedgerReportListGrid.endUpdate();
    }
    function OnPartyLedgerReportListPreviewClick()
    {
        if ("@PartyLedger_ExportRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        var partyDG = $("#Party_DG_PartyLedger").dxDataGrid("instance")
        var selectedRowData = partyDG.getSelectedRowsData();
        if (selectedRowData == null || selectedRowData.length == 0)
        {
            DevExpress.ui.dialog.alert("Please select Party", "Information").done(function ()
            {
                $("#Party_PartyLedger").dxDropDownBox("focus");
            })
            return
        }
        if (gridRefreshRequired_PartyLedger == true)
        {
            DevExpress.ui.dialog.alert("Party Ledger Data displayed is not as per the selected party and period filters <br> Please click the show button before exporting the report", "Information").done(function ()
            {

            })
            return
        }
        ShowLoader();
        $.ajax({
            type: 'POST',
            url: "/Reports/PartyLedger/PrintableReport",
            data:
            {
                Name: selectedRowData[0]["Name"],
                GST: selectedRowData[0]["GST"],
                PAN: selectedRowData[0]["PAN"],
                State: selectedRowData[0]["State"],
                City: selectedRowData[0]["City"],
                Mobile: selectedRowData[0]["Mobile"],
                Email: selectedRowData[0]["Email"],
                PartyID: selectedRowData[0]["ID"],
                From: $("#Fr_Date_PartyLedger").val(),
                To: $("#To_Date_PartyLedger").val(),
                ReportData: JSON.stringify(GetDataSourceItems("PartyLedgerReportListGrid", "dxDataGrid"))
            },
            cache: false,
            success: function (data)
            {
                HideLoader();
                OpenPopup("PartyLedgerReport_report_modal", "Print", null, "auto", "100%", true, data);
            }
        });
    }
    function OnPartyLedgerReportExportClick()
    {
        if ("@PartyLedger_ExportRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        var partyDG = $("#Party_DG_PartyLedger").dxDataGrid("instance")
        var selectedRowData = partyDG.getSelectedRowsData();
        if (selectedRowData == null || selectedRowData.length == 0) {
            DevExpress.ui.dialog.alert("Please select Party", "Information").done(function () {
                $("#Party_PartyLedger").dxDropDownBox("focus");
            })
            return
        }
        ShowLoader();
        $.ajax({
            type: 'POST',
            url: "/Reports/PartyLedger/Frm_Export_Options",
            data:
            {
                Name: selectedRowData[0]["Name"],          
                From: $("#Fr_Date_PartyLedger").val(),
                To: $("#To_Date_PartyLedger").val(),
                GridName:"PartyLedgerReportListGrid"
            },
            cache: false,
            success: function (data) {
                HideLoader();
