                                      .DisplayExpr("Name").ValueExpr("ID").ContentTemplate(@<Text> @Html.Partial("PartyList") </Text>).Value(ViewBag.SelectedPartyValue))


                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <div class="col-sm-2"><label class="control-label">Period</label></div>
                                    <div class="col-sm-10">
                                        <div class="row">
                                            <div class="col-sm-8 col-md-8 col-lg-8">
                                                @(Html.DevExtreme().SelectBox().ID("PeriodSelection_PartyLedger").Name("PeriodSelection_PartyLedger")
                                              .DataSource(d => d.Mvc().Controller("PartyLedger").LoadAction("Fill_Change_Period_Items").Key("SelectedIndex").LoadMode(DataSourceLoadMode.Raw))
                                              .DisplayExpr("Period").ValueExpr("SelectedIndex").SearchEnabled(false).OnValueChanged("PeriodSelection_PartyLedger_OnValueChanged").Value(ViewBag.PeriodSelectedIndex))


                                            </div>
