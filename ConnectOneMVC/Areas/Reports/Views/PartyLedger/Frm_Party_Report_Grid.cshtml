            MVCxGridView grid = (MVCxGridView)s;
            if (ViewMode == "Compact")
            {
                grid.DataColumns["PartyLedger_Compact_Column"].Visible = true;
                grid.DataColumns["Voucher"].Visible = false;
                grid.DataColumns["_Date"].Visible = false;
                grid.DataColumns["Particulars"].Visible = false;
                //grid.DataColumns["Item_Name"].Visible = false;
                grid.DataColumns["Debit"].Visible = false;
                grid.DataColumns["Credit"].Visible = false;
                grid.DataColumns["Balance"].Visible = false;

                grid.DataColumns["REC_ID"].Visible = false;
                grid.DataColumns["TR_M_ID"].Visible = false;
                grid.DataColumns["NARRATION"].Visible = false;
                grid.DataColumns["iTR_TEMP_ID"].Visible = false;


            }
            else
            {
                grid.DataColumns["PartyLedger_Compact_Column"].Visible = false;
                grid.DataColumns["Voucher"].Visible = true;
                grid.DataColumns["_Date"].Visible = true;
                grid.DataColumns["Particulars"].Visible = true;
                //grid.DataColumns["Item_Name"].Visible = true;
                grid.DataColumns["Debit"].Visible = true;
                grid.DataColumns["Credit"].Visible = true;
                grid.DataColumns["Balance"].Visible = true;

                grid.DataColumns["REC_ID"].Visible = false;
                grid.DataColumns["TR_M_ID"].Visible = false;
                grid.DataColumns["NARRATION"].Visible = false;
                grid.DataColumns["iTR_TEMP_ID"].Visible = false;

                if (ColumnTobeHidden != null && ColumnTobeHidden.Count > 0)
                {
                    for (int i = 0; i < ColumnTobeHidden.Count; i++)
                    {
                        grid.DataColumns[Convert.ToInt32(ColumnTobeHidden[i])].Visible = false;
                    }
                }
                if (ColumnTobeShown != null && ColumnTobeShown.Count > 0)
                {
                    for (int i = 0; i < ColumnTobeShown.Count; i++)
                    {
                        grid.DataColumns[Convert.ToInt32(ColumnTobeShown[i])].Visible = true;
                    }
                }
            }
        };


