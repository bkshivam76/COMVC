@using DevExtreme.AspNet.Mvc;
@{

    var SessionGUID = Request.QueryString["SessionGUID"];   
    bool VouchingMode = ViewBag.VouchingMode == null ? false : (bool)ViewBag.VouchingMode;
    int ShowHorizontalBar = (int)ViewBag.ShowHorizontalBar;

}

@(Html.DevExtreme().DataGrid().CustomDataGridListing(ShowHorizontalBar)
                 .ID("PartyLedgerReportListGrid")
                 .DataSource(new JS("PartyLedger_DS()"))
                 .Columns(columns =>
                 {
                     columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);//Bug #137209 Fix
                     columns.Add().DataField("iIcon").Name("iIcon").Caption("").CellTemplate(new JS("PartyLedgerReportListGrid_iIconTemplate")).Width(30)
                     .HeaderFilter(filter => filter.DataSource("DxGrid_HeaderFilterDataSource"));
                     columns.Add().DataField("PartyLedgerReportListGrid_Compact_Column").Name("PartyLedgerReportListGrid_Compact_Column").Caption("").Visible(false).CellTemplate(new JS("PartyLedgerReportListGrid_Compact_Column_Template"))
                     .CalculateCellValue("PartyLedgerReportListGrid_Compact_Column_CellValue").Width("100%").RenderAsync(true).ShowInColumnChooser(false);
                     columns.Add().DataField("_Date").Caption("Vch Date").MinWidth(70).DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                     columns.Add().DataField("InvDt").Caption("Inv Date").MinWidth(70).DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                     columns.Add().DataField("InvNo").Caption("InvNo").MinWidth(70);
                     columns.Add().DataField("Particulars").Caption("Particulars").Width(350);
                     columns.Add().DataField("Screen").Caption("Voucher").MinWidth(70);
                     // columns.Add().DataField("Voucher").Caption("Voucher").MinWidth(70);
                     columns.Add().DataField("Payment_RefNo").Caption("Payment RefNo").MinWidth(70);
                     columns.Add().DataField("Debit").Caption("Debit").DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}")).MinWidth(70);
                     columns.Add().DataField("Credit").Caption("Credit").DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}")).MinWidth(70);
                     columns.Add().DataField("Num_Balance").Caption("Balance").MinWidth(70).DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("Balance").Caption("BalType").Width(90);
                     columns.Add().DataField("REC_ID").Caption("REC_ID").Visible(false).MinWidth(120);
                     columns.Add().DataField("TR_M_ID").Caption("TR_M_ID").Visible(false).MinWidth(120);
                     columns.Add().DataField("NARRATION").Caption("NARRATION").Visible(false).MinWidth(120);
                     columns.Add().DataField("iTR_TEMP_ID").Caption("iTR_TEMP_ID").Visible(false).MinWidth(120);
                 })
                 .Summary(s =>
                 {
                     s.TotalItems(item =>
                     {
                         item.Add().Name("Credit_Credit_sum").SummaryType(SummaryType.Sum).Column("Credit").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
                         item.Add().Name("Debit_Debit_sum").SummaryType(SummaryType.Sum).Column("Debit").ValueFormat(new JS("function(value){return DxGrid_FormatNumber(value)}"));
                     });
                     s.RecalculateWhileEditing(true);
                 })
                 .MasterDetail(md =>
                 {
                     md.AutoExpandAll(false);
                     md.Enabled(!VouchingMode);
                     md.Template(new JS("PartyLedgerReportListGrid_DetailTemplate"));
                 })
         .OnInitialized("PartyLedgerReportListGrid_OnInitialized")
         .OnCellPrepared("PartyLedgerReportListGrid_OnCellPrepared")
         .OnRowPrepared("PartyLedgerReportListGrid_OnRowPrepared")
         .OnContentReady("PartyLedgerReportListGrid_OnContentReady")
         .OnCellDblClick("PartyLedgerReportListGrid_OnCellDblClick")
         .OnSelectionChanged("PartyLedgerReportListGrid_OnSelectionChanged")
         .OnRowExpanding("PartyLedgerReportListGrid_OnRowExpanding")
         .OnRowCollapsing("PartyLedgerReportListGrid_OnRowCollapsing")
         .OnContextMenuPreparing("PartyLedgerReportListGrid_OnContextMenuPreparing")
)