@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
        .ID("Party_DG_PartyLedger")
        .Columns(columns =>
        {

            columns.Add().DataField("Name").Caption("Name");
            columns.Add().DataField("PAN").Caption("Pan");
            columns.Add().DataField("ID").Caption("ID").Visible(false);
            columns.Add().DataField("GST").Caption("GST").Visible(false);
            columns.Add().DataField("City").Caption("City").Visible(false);
            columns.Add().DataField("State").Caption("State").Visible(false);
            columns.Add().DataField("Mobile").Caption("Mobile").Visible(false);
            columns.Add().DataField("Email").Caption("Email").Visible(false);


        })
           .OnSelectionChanged("function(selectedItems){ var keys = selectedItems.selectedRowKeys;var DDvalue=component.option('value');if(keys!=DDvalue){component.option('value', keys[0]);}component.close();}")
        .Selection(s => s.Mode(SelectionMode.Single))

)




