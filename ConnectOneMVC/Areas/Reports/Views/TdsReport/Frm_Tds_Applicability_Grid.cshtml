@using DevExtreme.AspNet.Mvc;
@{
    var SessionGUID = Request.QueryString["SessionGUID"];
}

@(Html.DevExtreme().DataGrid().CustomDataGridListing((int)ViewBag.ShowHorizontalBar)
                 .ID("TdsApplicabilityReport")
                 .DataSource(d => d.Mvc().Controller("TdsReport").LoadAction("Tds_Applicability_Grid_Data").LoadMode(DataSourceLoadMode.Raw))
                 .Columns(columns =>
                 {
                     columns.Add().DataField("SummaryColumn").Name("SummaryColumn").Caption("SummaryColumn").Visible(false).ShowInColumnChooser(false);
                     columns.Add().DataField("UID").Caption("UID");
                     columns.Add().DataField("CENTRE").Caption("Centre");
                     columns.Add().DataField("ITEM").Caption("Item");
                     columns.Add().DataField("DATE").Caption("Date").DataType(GridColumnDataType.Date).Format("dd-MM-yyyy");
                     columns.Add().DataField("PARTY").Caption("Party");
                     columns.Add().DataField("PAN").Caption("PAN");
                     columns.Add().DataField("LEDGER").Caption("Ledger");
                     columns.Add().DataField("TDS CODE").Caption("TDS Code");
                     columns.Add().DataField("TDS DED (IN BILL)").Caption("TDS Deduction in Bill").DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("TDS Rate").Caption("TDS Rate");
                     columns.Add().DataField("ITEM_AMT").Caption("Item Amt").DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("BILL AMT").Caption("Bill Amt").DataType(GridColumnDataType.Number).Format(new JS("function(cellInfo){return DxGrid_FormatNumber(cellInfo)}"));
                     columns.Add().DataField("REC_ID").Caption("REC_ID").Visible(false);
                     columns.Add().DataField("TR_M_ID").Caption("TR_M_ID").Visible(false);
                     columns.Add().DataField("TR_NARRATION").Caption("Narration").Visible(false);
                     columns.Add().DataField("TR_REMARKS").Caption("Remarks").Visible(false);
                     columns.Add().DataField("REC_ADD_ON").Caption("Add On").DataType(GridColumnDataType.DateTime).Format("dd-MM-yyyy HH:mm:ss").Visible(false);
                 })
         .OnContextMenuPreparing("TdsApplicabilityReport_ContextMenuPreparing")
         .OnContentReady("TdsApplicabilityReport_OnContentReady")
         .OnInitialized("TdsApplicabilityReport_OnInitialized")    
         )