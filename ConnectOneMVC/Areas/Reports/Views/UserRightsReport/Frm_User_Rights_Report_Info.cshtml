@using DevExtreme.AspNet.Mvc;
@model System.Data.DataTable

@{
    Layout = null;
    bool Report_UserRights_ListRight = (bool)ViewData["Report_UserRights_ListRight"];
    bool Report_UserRights_ExportRight = (bool)ViewData["Report_UserRights_ExportRight"];
}

<div id="UserRightsReport_ParentDiv">
    <div id="UserRights_content" class="report_header_div_main clearfix">
        <div class="report_header_div">
            <label class="report_header_label">User Rights Report</label>
        </div>
        @*Buttons*@
        <div class="report_button_div">
            @(Html.DevExtreme().Button()
                .ID("UserRightsReportToggleScrollBar")
                .Text(ViewBag.ShowHorizontalBar == 1 ? "Default Data" : "Full Data").Width(ViewBag.ShowHorizontalBar == 1 ? 110 : 90)
                .Icon("toolbox")
                .OnClick(@<text>
                    function () {
                    UserRightsReport_changeMode();
                    }
                </text>)
            )
            @(Html.DevExtreme().Button()
                .ID("UserRightsReportModelListPreview")
                .Text("Export")
                .Icon("save")
                .Width(90)
                .OnClick(@<text>
                    function () {
                    OnUserRightsReportListPreviewClick();
                    }
                </text>)
            )
            @(Html.DevExtreme().Button()
                .ID("UserRightsReportModelCLOSE")
                .Text("Close")
                .Icon("clear")
                .Width(90)
                .OnClick(@<text>
                    function (){closeUserRightsReport();}
                </text>)
            )
        </div>
    </div>
    
        <div class="col-md-12 no-padding">
            <form>
                <div id="UserRightsReportGridPartialView" class="parent_table">
                    @Html.Partial("Frm_User_Rights_Report_Info_Grid", Model)
                </div>
            </form>
        </div>

</div>
<script>


    $(document).ready( function () {

        if ("@Report_UserRights_ListRight" == "False")
        {
            NoRightsPrevention(true);
        }
    });


    function OnUserRightsReportListPreviewClick(e)
    {
       if ("@Report_UserRights_ExportRight" == "False")
        {
            NoRightsPrevention(false, "");
            return;
        }
        OpenDynamicPopup("Export Option", "/Reports/UserRightsReport/Frm_Export_Options/", "auto", 125, false, false);
    }




</script>@* Ready *@

<script>
    //All these are grid functions
    var UserRights_FocusedRowBeforeRefresh;
    var UserRights_ShowHorizontalBar = parseInt("@ViewBag.ShowHorizontalBar");
    var UserRightsGridLayout = null;

    function UserRightsOnInit() { // This function is to set height of the grid
        UserRightsAdjustSize();
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            UserRightsAdjustSize();
        });
        $("#UserRightsReportListGrid").hover(function () {
            UserRightsReportListGrid.Focus()
        });
    }
    function UserRightsAdjustSize() {

        var height = (document.documentElement.clientHeight * 90) / 100;
        try {
            UserRightsReportListGrid.SetHeight(height);
        }
        catch (err) {

        }
    }


    //This is Begin Call back function of the grid to send the Parameters
    function UserRights_BeginCallBack(s, e) { //s sender and e - event
        //UserRights_FocusedRowBeforeRefresh = s.GetFocusedRowIndex();
        e.customArgs["command"] = e.command;
        e.customArgs["ShowHorizontalBar"] = UserRights_ShowHorizontalBar;




    }

    function OnGridUserRights_EndCallback(s, e) {

        UserRightsGridLayout = s.cpClientLayout;
        SendCustomArgs_FilterControl(s, e);

    }

    function UserRightsContextMenuFunction(s, e) { //This code is to handle context menu filled user defined buttons functionality.
        if (e.item.name == 'Close') {
            closeUserRightsReport();
        }
        else if (e.item.name == 'ListPreview')
        {
            OnUserRightsReportListPreviewClick();
        }
    }

    //Full Data
    function UserRightsReport_changeMode() {
        ShowLoader();
        if (UserRights_ShowHorizontalBar == 0) {
            UserRights_ShowHorizontalBar = 1;
            $("#UserRightsReportToggleScrollBar").find("span").text("Default Data");
            $("#UserRightsReportToggleScrollBar").width(130);
        }
        else {
            UserRights_ShowHorizontalBar = 0;
            $("#UserRightsReportToggleScrollBar").find("span").text("Full Data");
            $("#UserRightsReportToggleScrollBar").width(130);
        }
        $.ajax({
            url: "/reports/UserRightsReport/Frm_User_Rights_Report_Info_Grid",
            type: "get",
            data: { showhorizontalbar: UserRights_ShowHorizontalBar, Layout: UserRightsGridLayout},
            success: function (res) {
                $("#UserRightsReportGridPartialView").html(res);

                HideLoader();
            }
        });

    }
</script>@* Main Grid *@


<script>
    // This is for close button code of the screen
    function closeUserRightsReport() {
        $(".TabPanalMenu-tabs .active span").click();
    }
    $(".TabPanalMenu-tabs .active span").on("click", function () {
        $.ajax({
            type: 'GET',
            url: "/Reports/UserRightsReport/SessionClear",
            cache: false
        });
       
    });
</script>@* Close Button *@
