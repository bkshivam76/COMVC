<div class="UtilizationReport_Export_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    <div>
        @(Html.DevExtreme().Button()
                .ID("Utilization_ExportGridDatapdf")
                .Text("Export to PDF")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                //.AccessKey("x")
                .OnClick("ExportPDF")
                .Visible(true)
                .Width(120)
    )<br />

        @(Html.DevExtreme().Button()
                .ID("Utilization_ExportGridDataxls")
                .Text("Export to XLS")
                //.Icon("fa-file-excel-o")
                //.AccessKey("X")
                .OnClick("ExportXLS")
                .Visible(true)
                .Width(120)
    )<br />
        @(Html.DevExtreme().Button()
                .ID("Utilization_ExportGridDataxlsx")
                .Text("Export to XLSX")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                //.AccessKey("L")
                .OnClick("ExportXLSX")
                .Visible(true)
                .Width(120)
    )<br />

        @(Html.DevExtreme().Button()
                .ID("Utilization_ExportGridDatadocx")
                .Text("Export to DOCX")
                //.Icon("export_exporttodocx_16x16office2013")
                //.AccessKey("D")
                .OnClick("ExportDOCX")
                .Visible(true)
                .Width(120)
    )<br />

        @(Html.DevExtreme().Button()
                .ID("Utilization_ExportGridDatartf")
                .Text("Export to RTF")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                //.AccessKey("R")
                .OnClick("ExportRTF")
                .Visible(true)
                .Width(120)
    )<br />

        @(Html.DevExtreme().Button()
                .ID("Utilization_ExportGridDatacsv")
                .Text("Export to CSV")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                //.AccessKey("C")
                .OnClick("ExportCSV")
                .Visible(true)
                .Width(120)
    )
    </div>
    <script>
        function ExportPDF() {
            //GridViewDoCallback(UtilizationReceiptReportListGrid, function () { UtilizationReceiptReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Pdf) });
            //GridViewDoCallback(UtilizationPaymentReportListGrid, function () { UtilizationPaymentReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Pdf) });
            UtilizationPaymentReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Pdf);
            UtilizationReceiptReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Pdf);
            $("#UtilizationReport_report_modal").dxPopup("hide");
        }
        function ExportXLS() {
            GridViewDoCallback(UtilizationReceiptReportListGrid, function () { UtilizationReceiptReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Xls) });
            GridViewDoCallback(UtilizationPaymentReportListGrid, function () { UtilizationPaymentReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Xls) });

            $("#UtilizationReport_report_modal").dxPopup("hide");
        }
        function ExportXLSX() {
            GridViewDoCallback(UtilizationReceiptReportListGrid, function () { UtilizationReceiptReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Xlsx) });
            GridViewDoCallback(UtilizationPaymentReportListGrid, function () { UtilizationPaymentReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Xlsx) });

            $("#UtilizationReport_report_modal").dxPopup("hide");
        }
        function ExportCSV() {
            GridViewDoCallback(UtilizationReceiptReportListGrid, function () { UtilizationReceiptReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Csv) });
            GridViewDoCallback(UtilizationPaymentReportListGrid, function () { UtilizationPaymentReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Csv) });

            $("#UtilizationReport_report_modal").dxPopup("hide");
        }
        function ExportDOCX() {
            GridViewDoCallback(UtilizationReceiptReportListGrid, function () { UtilizationReceiptReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Docx) });
            GridViewDoCallback(UtilizationPaymentReportListGrid, function () { UtilizationPaymentReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Docx) });

            $("#UtilizationReport_report_modal").dxPopup("hide");
        }
        function ExportRTF() {
            GridViewDoCallback(UtilizationReceiptReportListGrid, function () { UtilizationReceiptReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Rtf) });
            GridViewDoCallback(UtilizationPaymentReportListGrid, function () { UtilizationPaymentReportListGrid.ExportTo(ASPxClientGridViewExportFormat.Rtf) });

            $("#UtilizationReport_report_modal").dxPopup("hide");
        }
    </script>

</div>