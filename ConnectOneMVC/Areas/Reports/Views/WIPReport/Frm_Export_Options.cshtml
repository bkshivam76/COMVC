<div class="WIPReport_Export_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    <div>
        @(Html.DevExtreme().Button()
                .ID("WIPRep_ExportGridDatapdf")
                .Text("Export to PDF")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                //.AccessKey("x")
                .OnClick("ExportPDF")
                .Visible(true)
                .Width(120)
    )<br />

        @(Html.DevExtreme().Button()
                .ID("WIPRep_ExportGridDataxls")
                .Text("Export to XLS")
                //.Icon("fa-file-excel-o")
                //.AccessKey("X")
                .OnClick("ExportXLS")
                .Visible(true)
                .Width(120)
    )<br />
        @(Html.DevExtreme().Button()
                .ID("WIPRep_ExportGridDataxlsx")
                .Text("Export to XLSX")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                //.AccessKey("L")
                .OnClick("ExportXLSX")
                .Visible(true)
                .Width(120)
    )<br />

        @(Html.DevExtreme().Button()
                .ID("WIPRep_ExportGridDatadocx")
                .Text("Export to DOCX")
                //.Icon("export_exporttodocx_16x16office2013")
                //.AccessKey("D")
                .OnClick("ExportDOCX")
                .Visible(true)
                .Width(120)
    )<br />

        @(Html.DevExtreme().Button()
                .ID("WIPRep_ExportGridDatartf")
                .Text("Export to RTF")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                //.AccessKey("R")
                .OnClick("ExportRTF")
                .Visible(true)
                .Width(120)
    )<br />

        @(Html.DevExtreme().Button()
                .ID("WIPRep_ExportGridDatacsv")
                .Text("Export to CSV")
                //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                //.AccessKey("C")
                .OnClick("ExportCSV")
                .Visible(true)
                .Width(120)
    )
    </div>
    <script>
        var protocol = window.location.protocol;
        var hostname = window.location.host;
        var Path = "";
        function ExportPDF() {
            ShowLoader();
            Path = StandardizeCallURL(protocol + "//" + hostname + "/Reports/WIPReport/WIPExportToPDF_DataAware").trim();
            window.open(Path);
            HideLoader();
            $("#WIPReport_report_modal").dxPopup("hide");
        }
        function ExportXLS() {
            ShowLoader();
            Path = StandardizeCallURL(protocol + "//" + hostname + "/Reports/WIPReport/WIPExportToXLS_DataAware");
            window.open(Path);
            HideLoader();
            $("#WIPReport_report_modal").dxPopup("hide");
        }
        function ExportXLSX() {
            ShowLoader();
            Path = StandardizeCallURL(protocol + "//" + hostname + "/Reports/WIPReport/WIPExportToXLSX_DataAware");
            window.open(Path);
            HideLoader();
            $("#WIPReport_report_modal").dxPopup("hide");
        }
        function ExportCSV() {
            ShowLoader();
            Path = StandardizeCallURL(protocol + "//" + hostname + "/Reports/WIPReport/WIPExportToCSV_DataAware");
            window.open(Path);
            HideLoader();
            $("#WIPReport_report_modal").dxPopup("hide");
        }
        function ExportDOCX() {
            ShowLoader();
            Path = StandardizeCallURL(protocol + "//" + hostname + "/Reports/WIPReport/WIPExportToDOCX_DataAware");
            window.open(Path);
            HideLoader();
            $("#WIPReport_report_modal").dxPopup("hide");
        }
        function ExportRTF() {
            ShowLoader();
            Path = StandardizeCallURL(protocol + "//" + hostname + "/Reports/WIPReport/WIPExportToRTF_DataAware");
            window.open(Path);
            HideLoader();
            $("#WIPReport_report_modal").dxPopup("hide");
        }
    </script>

</div>