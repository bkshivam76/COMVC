    <div class="col-md-12">
        @*Add/Edit Popup*@
        @(Html.DevExtreme().Popup().CustomPopup()
                .ID("WIPReport_report_modal")
                 .OnShowing("PopupOnShowing")
                .Title("WIP Report Preview")
                .FullScreen(false)
                .MaxWidth(125)
                .Height("auto")
                .ShowCloseButton(true)
                .ContentTemplate(@<text>
                    <div id='WIPReport_report_modal_result'>
                    </div>
                </text>)
    )

    </div>

    @*Javascript Events*@
    <script type="text/javascript">
        var IsWIPReportSucessPopup = false;
        var IsWIPReportViewPopup = false;

    $(document).ready(function () {
        if ("@WIPReport_ExportRight" == "False")
        {
	        $("#WIPReportsModelListPreview").hide();
        }
        IsWIPReportSucessPopup = false;
        IsWIPReportViewPopup = false;
        //SetWIPReportGroupPanelFooterVisible();
        $("#WIPReportListGrid").hover(function () {
            WIPReportListGrid.Focus()
        })
    });
    $(".TabPanalMenu-tabs .active span").on("click", function () {
        $.ajax({
            type: 'GET',
            url: "/Reports/WIPReport/SessionClear",
            cache: false
        });
        ClearAllReferences_WIPReport();
    });
        function ClearAllReferences_WIPReport()
        {
            IsWIPReportSucessPopup = null;
            IsWIPReportViewPopup = null;

            ClearAllReferences("WIPReport_ClearReferences");
        }
    function WIPReportOnInit(s, e) {
        WIPReportAdjustSize();
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            WIPReportAdjustSize();
        });
    }

    function OnEndCallback(s, e) {
        WIPReportAdjustSize();
    }

    function WIPReportAdjustSize() {
        var height = (document.documentElement.clientHeight * 90) / 100;
      try{  WIPReportListGrid.SetHeight(height);} catch (err) { }
    }

    function OnWIPReportListPreviewClick() {
        if ("@WIPReport_ExportRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }

        OpenPopup("WIPReport_report_modal", "Export Option", "@Url.Action("Frm_Export_Options", "WIPReport", new { @area = "Reports" })", "auto", "auto", false, null);
    }

    function WIPReportContextMenuFunction(s, e) {
        if (e.item.name == 'Close') {
            btnCloseActiveTab();
        }
        else if (e.item.name == 'ListPreview') {
            OnWIPReportListPreviewClick();
        }
        else if (e.item.name == 'Refresh') {
            WIPReportListGrid.Refresh();
        }
    }
    </script>

</div>