<div class="WIPReport_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    @using DevExpress;
    @using DevExpress.Web.Mvc;

    @model IEnumerable<dynamic>
    @{
        ViewBag.Title = "Index";
        Layout = null;
        bool WIPReport_ExportRight = (bool)ViewData["WIPReport_ExportRight"];
