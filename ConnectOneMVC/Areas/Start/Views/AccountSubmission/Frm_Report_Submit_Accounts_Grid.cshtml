
@using DevExtreme.AspNet.Mvc.Builders
@using DevExtreme.AspNet.Mvc

@(Html.DevExtreme().DataGrid().CustomDataGridListing()
    .ID("SubmitAccountsListGrid")
    .DataSource(d => d.Mvc()
        .Controller("AccountSubmission")
        .LoadAction("Frm_Report_Submit_Accounts_Grid")
        .LoadMode(DataSourceLoadMode.Raw)
    )
    .Columns(columns =>
    {
        columns.Add().DataField("MthName").Caption("Month").Width(150);
        columns.Add().DataField("CSA_SUBMIT_ON")
            .Caption("Last Submitted On")
            .DataType(GridColumnDataType.DateTime)
            .Format("dd-MM-yyyy HH:mm:ss")
            .Width(200);
    })
    .Paging(p => p.Enabled(false))
    .Pager(p => p.Visible(false))
    .OnContextMenuPreparing("Frm_Report_Submit_Accounts_OnContextMenuPreparing")
)







