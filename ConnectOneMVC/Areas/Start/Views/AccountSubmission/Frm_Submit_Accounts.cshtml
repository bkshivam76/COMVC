<div class="SubmitAccounts_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    @model ConnectOneMVC.Areas.Start.Models.AccountSubmissionModel



    <style>
        .section input[type="radio"],
        .section input[type="checkbox"] {
            display: none;
        }

    /*    .dx-checkbox-text {
            width: auto;
        }*/

        .chk-box {
            /* margin-bottom: 10px;*/
        }

            .chk-box label {
                position: relative;
                left: 22px;
                font-size: 12px;
            }

            /* Base styles for spans */
            .chk-box span::before,
            .chk-box span::after {
                content: '';
                position: absolute;
                top: 0;
                bottom: 0;
                margin: auto;
            }

            .chk-box span.checkbox1::before {
                width: 15px;
                height: 15px;
                background-color: #fff;
                left: -24px;
                box-sizing: border-box;
                border: 1px solid #ccc;
                transition: border-color .2s;
            }

            .chk-box span.checkbox1:hover::before {
                background-color: #edf7fd;
            }

            .chk-box span.checkbox1::after {
                content: '\f00c';
                font-family: 'FontAwesome';
                left: -22px;
                top: 1px;
                color: transparent;
                transition: color .2s;
            }

        input[type="checkbox"]:checked + label span.checkbox1::after {
            color: #383939;
        }
    </style>

    @*<link href="/content/fontawesome/css/fontawesome-all.css" rel="stylesheet">*@

    <div>
        @using (Ajax.BeginForm("Frm_Submit_Accounts", "AccountSubmission",
                     new AjaxOptions
                     {
                         HttpMethod = "POST",
                         InsertionMode = InsertionMode.InsertAfter,
                         OnBegin = "AjaxBeginFormPost",
                         OnSuccess = "ReportSubmit_Success",
                     },
                     new
                     {
                         id = "ReportSubmit_Form",
                         @class = "edit_form"
                     }))

        {
            <div class="full-width-header-bg2">
                <div class="row">
                    <div class="col-sm-12 pll">
                        <h3 class="popuphead"><i class="far fa-edit"></i>Submit Accounts</h3>
                    </div>
                </div>
            </div><!--[row]-->
            @(Html.DevExtreme().TabPanel().ID("SubmitAccount_tabPanel").DeferRendering(false).Items
	            (items =>
		            {
			            items.Add().Title("By Month").Template(@<text>@SubmitAccountByMonth()</text>);
			            items.Add().Title("By Date").Template(@<text>@SubmitAccountByDate()</text>);                            
		            }
	            ).OnSelectionChanged("NotifyTabPanelSelectionChanged_SubmitAccount")
            )
            @Html.Hidden("SelectedTabTitle_SubmitAccount")
            @helper SubmitAccountByMonth()
            {
	            @Html.Partial("Frm_Submit_Accounts_By_Month");
            }
            @helper SubmitAccountByDate()
            {
	            @Html.Partial("Frm_Submit_Accounts_By_Date");
            }
            <div class="row">
                <div class="form-field">
                    <div class="container-fluid pbs ptm pll">
                        <div class="col-sm-7">
                            <label id="lblLastCompletionOn_SubmitAccounts" class="control-label">
                                @ViewBag.lblLastCompletionOn
                            </label>
                        </div>
                        <div class="col-sm-5">
                            <div class="styleActionBtn">
                                @(Html.DevExtreme().Button().CustomSaveButton().ID("BUT_OK_SubmitAccounts").Text("Submit Accounts").OnClick("BUT_OK_Click").UseSubmitBehavior(false) )
                                @(Html.DevExtreme().Button().CustomCloseButton().ID("BUT_CANCEL_SubmitAccounts").Text("Cancel").OnClick("BUT_CANCEL_Click") )
                            </div>
                        </div>
                    </div>
                </div>
            </div><!--[lbl_lastcompletionon row]-->

        }
    </div>

