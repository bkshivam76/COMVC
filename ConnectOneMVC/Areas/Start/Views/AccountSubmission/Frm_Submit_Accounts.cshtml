            {
                var ToDate = new Date("@ViewBag.CloseYearofFY", 2, 1);
                ToDate = ToDate.setDate(ToDate.getDate() - 1);
                return ToDate
            }
            if ($("#chk_Jan_SubmitAccounts").dxCheckBox("instance").option("value"))
            {
                var ToDate = new Date("@ViewBag.CloseYearofFY", 1, 1);
                ToDate = ToDate.setDate(ToDate.getDate() - 1);
                return ToDate
            }
            if ($("#chk_Dec_SubmitAccounts").dxCheckBox("instance").option("value"))
            {
                var ToDate = new Date("@ViewBag.CloseYearofFY", 0, 1);
                ToDate = ToDate.setDate(ToDate.getDate() - 1);
                return ToDate
            }
            if ($("#chk_Nov_SubmitAccounts").dxCheckBox("instance").option("value"))
            {
                var ToDate = new Date("@ViewBag.OpenYearOfFY", 11, 1);
                ToDate = ToDate.setDate(ToDate.getDate() - 1);
                return ToDate
            }
            if ($("#chk_Oct_SubmitAccounts").dxCheckBox("instance").option("value"))
            {
                var ToDate = new Date("@ViewBag.OpenYearOfFY", 10, 1);
                ToDate = ToDate.setDate(ToDate.getDate() - 1);
                return ToDate
            }
            if ($("#chk_Sep_SubmitAccounts").dxCheckBox("instance").option("value"))
