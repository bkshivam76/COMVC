    <script>
    function BUT_CANCEL_Click(e) {

        HidePopup("Dynamic_Content_popup");

    }

    function BUT_OK_Click(e) {

        var SubmitButtonConfirmationMessage_SubmitAccounts = DevExpress.ui.dialog.confirm("Account Submission...<br><br>Are you sure you want to Submit Accounts...?", "Confirmation...");

        SubmitButtonConfirmationMessage_SubmitAccounts.done(function (dialogResult) {

            if (dialogResult)
            {
                ShowLoader();                
                var ToDate = ToDateCalculation();
                if ((ToDate === null || ToDate === undefined) && ($("#SubmitAccount_tabPanel").val().includes("By Date"))) {
                    HideLoader();
                   //DevExpress.ui.dialog.alert("Invalid Date!!!.", "Warning!!");
                    return;
                }
                else {
                    if (ToDate === "") { }
                    else {
                        ToDate = moment(new Date(ToDate)).format("DD/MM/YYYY");
                    }
                }
                $.ajax({
                    url: "/Start/AccountSubmission/Submit_Success",
                    type: "POST",
                    data: {
                        ToDate: ToDate,
                        PrevSubmittedTill : "@Model.PrevSubmittedTill_SubmitAccounts" },
                    cache: false,
                    success: function (data) {
                        HideLoader();
                        DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);

                        if (data.jsonParam.result == true)
                        {
                            dontaskpopupcloseconfirmation = true;
                            BUT_CANCEL_Click();
                        }

                    }
                });

            }

        });
    }

    </script> @* Buttons *@

<script>
    function ToDateCalculation()
    {
        if ($("#SubmitAccount_tabPanel").val().includes("By Date")) {
            //$("#Date_SubmitAccount").dxDateBox("instance").validate();//validate() forces validation of the DateBox’s value, and isValid() checks if the value is valid
            var inputDate = $("#Date_SubmitAccount").dxDateBox("instance").option("value");
            if (inputDate)
            {                
                var lastDate = moment(new Date("@ViewBag.CloseYearofFY", 2, 31), "DD/MM/YYYY");
                var currentDate = moment(new Date(), "DD/MM/YYYY");
                lastDate = lastDate.toDate();
                //var currentDate = moment(new Date(), "DD/MM/YYYY");
                @*if ((new Date()).getMonth() < 3) {
                    currentDate = moment(new Date("@ViewBag.CloseYearofFY", (new Date()).getMonth(), (new Date()).getDate()), "DD/MM/YYYY");
                }*@
                currentDate = currentDate.toDate();
                if (moment.isDate(currentDate) && moment.isDate(lastDate)) {
                    if (lastDate.getTime() < currentDate.getTime()) {
                        currentDate = lastDate;
                    }
                }
                inputDate = moment(inputDate, "DD/MM/YYYY");
                inputDate = inputDate.toDate();
                if (moment.isDate(currentDate))
                {
                    if (inputDate.getTime() > currentDate.getTime()){
                        DevExpress.ui.dialog.alert("Sorry!! Selected input Date: " + moment(inputDate).format('Do MMMM, YYYY') + " cannot be greater than Date: " + moment(currentDate).format('Do MMMM, YYYY')+ ".", "Warning!!");
                        //$("#chk_Nov_SubmitAccounts").dxCheckBox("instance").option("value", false);
                        return null;
                    }
                    //if (!$("#Date_SubmitAccount").dxDateBox("instance").isValid()) {
                    //    return null;
                    //}
                }
                var ToDate = moment(inputDate, "DD/MM/YYYY");
                return ToDate;
            }
        }
        else {
            if ($("#chk_Mar_SubmitAccounts").dxCheckBox("instance").option("value"))
            {
                var ToDate = new Date("@ViewBag.CloseYearofFY", 3, 1);
                ToDate = ToDate.setDate(ToDate.getDate() - 1);
