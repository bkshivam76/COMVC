                        @*<input type="checkbox" name="group2" id="checkbox-1">
                            <label for="checkbox-1"><span class="checkbox1"> Apr</span></label>*@
                        @(Html.DevExtreme().CheckBox().ID("chk_Apr_SubmitAccounts").Name("chk_Apr_SubmitAccounts").Disabled(false).Value(false).ReadOnly(false).OnValueChanged("Chk_SelectedIndexChanged").Text("Apr '" + ViewBag.OpenYearOfFY))
