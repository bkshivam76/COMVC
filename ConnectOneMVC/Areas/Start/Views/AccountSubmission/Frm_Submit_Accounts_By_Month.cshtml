<div class="SubmitMonthlyAccounts_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    @model ConnectOneMVC.Areas.Start.Models.AccountSubmissionModel
    <div class="row">
        <div class="col-sm-12">
            <div class="form-field">
                <div class="container-fluid pll prm" style="text-align: center">
                    <label id="Txt_Notify_SubmitAccounts" style="color:maroon">
                        Select months for which Accounts has been completed for Current Center in @ViewBag.YearName
                    </label>
                </div>
            </div>
        </div>
    </div><!--[row]-->
