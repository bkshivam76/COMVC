    @*BankChecking_GlobalVariables_ClientSide*@
    <script class="BankChecking_Scripts">

    function On_BankChecking_FABActionItemClick(s, e)
    {
        var img = document.getElementById('RightPane_Img');
        s.ExpandActionGroupItems();
        if (e.actionName == "InitialViewDocumentClick")
        {
            ViewDocument(BankCheckingInfo_AtachmentID, BankCheckingInfo_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }





        if (e.actionName === "add_attach") {
            if ("@Help_Attachment_AddRight" == "False") {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (BankCheckingInfo_ParamMandatory == 1) {
                AddAttachment(BankCheckingInfo_MasterRowRecID, "Profile_BankAccounts", BankCheckingInfo_Doc_ID, BankCheckingInfo_Doc_Category, BankCheckingInfo_ParamMandatory, BankCheckingInfo_FromDateLabel, BankCheckingInfo_ToDateLabel, BankCheckingInfo_DescriptionLabel, "BankProfileAttachment", null, "BankCheckingGrid", BankCheckingInfo_NestedGrid_AccessID);
            }
            else
            {
                Attachment_DirectBrowse(BankCheckingInfo_MasterRowRecID, "Profile_BankAccounts", BankCheckingInfo_Doc_ID, "BankProfileAttachment", "BankCheckingGrid", BankCheckingInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "edit_attach") {
            if ("@Help_Attachment_EditRight" == "False") {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            if (BankCheckingInfo_Attachment_RecStatus.toUpperCase() == "LOCKED") {
                DevExpress.ui.dialog.alert("Locked Attachment Cannot Be Edited", "Error");
                return;
            }
            EditAttachment(BankCheckingInfo_MasterRowRecID, "Profile_BankAccounts", BankCheckingInfo_AtachmentID, BankCheckingInfo_ParamMandatory, BankCheckingInfo_FromDateLabel, BankCheckingInfo_ToDateLabel, BankCheckingInfo_DescriptionLabel, "BankProfileAttachment", null, "BankCheckingGrid", BankCheckingInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "delete_attach")
        {
            if ("@Help_Attachment_DeleteRight" == "False")
            {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            DeleteAttachment(BankCheckingInfo_MasterRowRecID, "Profile_BankAccounts", BankCheckingInfo_AtachmentID, BankCheckingInfo_ParamMandatory, BankCheckingInfo_FromDateLabel, BankCheckingInfo_ToDateLabel, BankCheckingInfo_DescriptionLabel, null, "BankCheckingGrid", BankCheckingInfo_NestedGrid_AccessID, BankCheckingInfo_Attachment_RecStatus);
        }
        else if (e.actionName == "Link_Attach")
        {
            LinkAttachment(BankCheckingInfo_MasterRowRecID, "Profile_BankAccounts", "Bank Balance Checking", "BankCheckingGrid", BankCheckingInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "view_attach") {
            if ("@Help_Attachment_ViewRight" == "False") {
                DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
                return;
            }
            ViewDocument(BankCheckingInfo_AtachmentID, BankCheckingInfo_FileName, s.uniqueID, "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
        }
        else if (e.actionName === "Add_Reason") {
            if (BankCheckingInfo_Doc_Category.toLowerCase() == "others") {
                DevExpress.ui.dialog.alert("Reason can not be mentioned for 'Other' document...!!", 'Information!');
            }
            else {

                AttachmentAddReason(BankCheckingInfo_MasterRowRecID, BankCheckingInfo_NestedRowMapID, "Profile_BankAccounts", "BankListGrid", BankCheckingInfo_NestedGrid_AccessID);
            }
        }
        else if (e.actionName === "Edit_Reason")
        {
            AttachmentEditReason(BankCheckingInfo_MasterRowRecID, BankCheckingInfo_NestedRowMapID, "Profile_BankAccounts", "BankListGrid", BankCheckingInfo_NestedGrid_AccessID, BankCheckingInfo_reason);
        }
        else if (e.actionName === "Delete_Reason")
        {
            AttachmentDeleteReason(BankCheckingInfo_MasterRowRecID, BankCheckingInfo_NestedRowMapID, "BankListGrid", BankCheckingInfo_NestedGrid_AccessID);
        }
        else if (e.actionName === "Rotate")
        {
            ImageRotate(img);
        }
        else if (e.actionName === "ZoomOut")
        {
            ImageZoomOut(img);
        }
        else if (e.actionName === "ZoomIn")
        {
            ImageZoomIn(img);
        }
        else if (e.actionName == "Fit")
        {
            ImageFit(img);
        }
        else if (e.actionName == "Back")
        {
            ImageBack(s.uniqueID, "actionItemContext");
        }
        else if (e.actionName == "AuditAction") {
            BankChecking_FAB.SetActionContext("AuditActionContext", true);
        }
        else if (e.actionName == "BackAudit") {
            if (BankCheckingInfo_Nested_Doc_Status == "") {
                BankChecking_FAB.SetActionContext("AutoItemContext", true);
            }
            if (BankCheckingInfo_Nested_Doc_Status == "NO") {
                BankChecking_FAB.SetActionContext("EditItemContext", true);
            }
            if (BankCheckingInfo_Nested_Doc_Status == "YES") {
                BankChecking_FAB.SetActionContext("actionItemContext", true);
            }
        }
        else if (e.actionName == "Accept") {
            BankCheckingInfo_AcceptwithoutRemarks();
        }
        else if (e.actionName == "Reject") {
            BankInfo_AcceptRejectVoucher("Reject");
        }
        else if (e.actionName == "AcceptWithRemarks") {
            BankInfo_AcceptRejectVoucher("Accept");
        }
        else if (e.actionName == "AcceptDoc") {

            OnBankCheckingInfo_AcceptDoc();
        }
        else if (e.actionName == "RejectDoc") {

            OnBankCheckingInfo_RejectDoc();
        }
    }
    function OnBankCheckingInfo_RejectDoc() {
        if (BankCheckingInfo_AtachmentID == null || BankCheckingInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        RejectAttachment(BankCheckingInfo_AtachmentID, "BankListGrid", BankCheckingInfo_NestedGrid_AccessID);
    }
    function OnBankCheckingInfo_AcceptDoc() {
        if (BankCheckingInfo_AtachmentID == null || BankCheckingInfo_AtachmentID.length == 0) {
            DevExpress.ui.dialog.alert("No Document Attached..", "Error");
            return;
        }
        AcceptAttachment(BankCheckingInfo_AtachmentID, "BankListGrid", BankCheckingInfo_NestedGrid_AccessID);
    }
    function BankCheckingInfo_AcceptwithoutRemarks()
    {
        var Recid;
        if (BankCheckingInfo_IsDetailRowExpanded == true || BankChecking_IsVouchingMode)
        {
            if (BankCheckingInfo_MasterRowRecID == null || BankCheckingInfo_MasterRowRecID == "")
            {
                Recid = BankChecking_BA_Rec_ID;
            }
            else
            {
                Recid = BankCheckingInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = BankChecking_BA_Rec_ID;
        }
        Entry_AcceptwithoutRemarks(Recid, "Profile_BankAccounts", "BankListGrid", BankCheckingInfo_AtachmentID, BankCheckingInfo_NestedRowReasonID, BankCheckingInfo_NestedRowUniqueID);
    }
    function BankInfo_AcceptRejectVoucher(_actionMethod)
    {
        var Recid;

        if (BankCheckingInfo_IsDetailRowExpanded == true || BankChecking_IsVouchingMode)
        {
            if (BankCheckingInfo_MasterRowRecID == null || BankCheckingInfo_MasterRowRecID == "")
            {
                Recid = BankChecking_BA_Rec_ID;
            }
            else
            {
                Recid = BankCheckingInfo_MasterRowRecID;
            }
        }
        else
        {
            Recid = BankChecking_BA_Rec_ID;
        }
        Entry_AcceptReject(_actionMethod, Recid, "Profile_BankAccounts", "BankListGrid", BankCheckingInfo_AtachmentID, BankCheckingInfo_NestedRowReasonID, BankCheckingInfo_NestedRowUniqueID);
    }
    function OnBankCheckingGridNestedFocusedRowChange(s, e)
    {        
        if (BankCheckingInfo_IsDetailRowExpanded || BankChecking_IsVouchingMode)
        {
            BankCheckingInfo_NestedRecord_FocusedRowIndex = s.GetFocusedRowIndex();
            if (BankCheckingInfo_NestedRecord_FocusedRowIndex >= 0)
            {
                ShowLoader();
                BankCheckingInfo_NestedGrid_AccessID = s.uniqueID;
                s.GetRowValues(s.GetFocusedRowIndex(), 'Doc_Status;Params_Mandatory;LABEL_FROM_DATE;LABEL_TO_DATE;LABEL_DESCRIPTION;Document_Category;Document_ID;ATTACH_ID;TxnID;TxnMID;MAP_ID;Reason;ATTACH_FILE_NAME;Attachment_Action_Status;UniqueID;ReasonID', OnBankCheckingInfo_GetGridRowValues);
            }
            else
            {
                BankChecking_FAB.SetVisible(false);
               // BankChecking_FAB.SetActionContext("AddAttachmentContext", false);
            }
        }
    }
    function OnBankCheckingInfo_GetGridRowValues(values)
    {
        HideLoader();        
        BankCheckingInfo_NestedRowUniqueID = values[14];
        if (values[14] != null )
        {
            BankChecking_FAB.SetVisible(true);
            BankCheckingInfo_Nested_Doc_Status = values[0];
            BankChecking_FAB.SetActionContext("ViewAttachmentContext");
            //if (BankChecking_IsVouchingMode == true) {
            //    BankChecking_FAB.SetActionContext("AuditActionContext", true);
            //}
            //else {
            //    if (BankCheckingInfo_Nested_Doc_Status == "") {
            //        BankChecking_FAB.SetActionContext("AutoItemContext", true);
            //    }
            //    else if (BankCheckingInfo_Nested_Doc_Status == "NO") {
            //        BankChecking_FAB.SetActionContext("EditItemContext", true);
            //    }
            //    else if (BankCheckingInfo_Nested_Doc_Status == "YES") {
            //        BankChecking_FAB.SetActionContext("actionItemContext", true);
            //    }
            //}
            BankCheckingInfo_ParamMandatory = values[1];
            BankCheckingInfo_FromDateLabel = values[2];
            BankCheckingInfo_ToDateLabel = values[3];
            BankCheckingInfo_DescriptionLabel = values[4];
            BankCheckingInfo_Doc_Category = values[5];
            BankCheckingInfo_Doc_ID = values[6];
            BankCheckingInfo_AtachmentID = values[7];
            IndexAttachmentID = BankCheckingInfo_AtachmentID;
            BankCheckingInfo_MasterRowRecID = values[8];
            BankCheckingInfo_MasterRowMID = values[9];
            BankCheckingInfo_NestedRowMapID = values[10];
            BankCheckingInfo_reason = values[11];
            BankCheckingInfo_FileName = values[12];
            BankCheckingInfo_Attachment_RecStatus = values[13];
            if (BankChecking_IsVouchingMode == true) {
                if (BankCheckingInfo_FileName != null && BankCheckingInfo_FileName.length > 0) {
                    ViewDocument(BankCheckingInfo_AtachmentID, BankCheckingInfo_FileName, "BankChecking_FAB", "ImageToolBarContext", document.getElementById('RightPane_Iframe'), document.getElementById('RightPane_Img'), document.getElementById('RightPane_div_Iframe'), document.getElementById('RightPane_div_Img'), Mainspliter.GetPaneByName('RightPane'));
                }
                else {
                    var pane = Mainspliter.GetPaneByName('RightPane');
                    pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
                    document.getElementById('RightPane_div_Iframe').style.display = "none";
                    document.getElementById('RightPane_div_Img').style.display = "none";
                }
            }
        }
        BankCheckingInfo_NestedRowReasonID = values[15];
        IndexAttachmentReasonID = BankCheckingInfo_NestedRowReasonID;
    }
    function BankCheckingGrid_Nested_BeginCallBack(s, e)
    {
       
        e.customArgs["command"] = e.command;
        e.customArgs["ShowHorizontalBar"] = BankChecking_ShowHorizontalBar;
    }
    function BankCheckingGrid_DetailRowExpanding(s, e)
    {        
        BankCheckingInfo_IsDetailRowExpanded = true;
        s.SetFocusedRowIndex(e.visibleIndex);
        var pane = Mainspliter.GetPaneByName('RightPane');
        if (BankChecking_IsVouchingMode == true)
        {
            pane.Expand();
        }
        else
        {
            pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
        }
    }
    function BankCheckingGrid_DetailRowCollapsing(s, e)
    {
        BankCheckingInfo_IsDetailRowExpanded = false;
        s.SetFocusedRowIndex(e.visibleIndex);
        if (BankChecking_IsVouchingMode == false)
        {
            BankChecking_FAB.SetVisible(false);
        }
        if (BankChecking_IsVouchingMode == true)
        {
            if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false)
            {
                CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
    }
    </script>
