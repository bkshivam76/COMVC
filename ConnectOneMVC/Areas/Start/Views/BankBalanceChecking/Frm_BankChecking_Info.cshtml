    <div id="BankChecking_ParentDiv">
        <div id="contentBankChecking" class="col-md-12 report_header_div_main">
            <div class="col-md-3 report_header_div">
                <label class="report_header_label">Bank Balance Checking</label>
            </div>
            <div class="col-sm-9 prs">
                <div class="report_button_div">
                    <div class="bank_status clearfix">
                        <span> Status: </span>
                        @(Html.DevExtreme().SelectBox().ID("BankChecking_Status_SelectBox").Name("BankChecking_Status_SelectBox").DataSource(new[] { "ALL", "PENDING", "COMPLETED"}).OnValueChanged("onCheckingStatusChange").Value("PENDING"))
                    </div>
                    @(Html.DevExtreme().Button().ID("GetBankStatement_BankChecking").Text("Bank Statement").Visible(true).OnClick("getBankstatement_BankChecking_Onclick") )
                    @(Html.DevExtreme().Switch().ID("BankCheckingVouchingModeSwitch").SwitchedOnText("Vouching On").SwitchedOffText("Vouching Off").OnValueChanged("BankChecking_VouchingSwitch_ValueChange").Width(100).Visible(false))
                    @(Html.DevExtreme().Switch().ID("BankCheckingViewModeSwitch").SwitchedOnText("Compact").SwitchedOffText("Default").OnValueChanged("BankChecking_ViewSwitch_ValueChange").Width(70).Visible(false))
                    @(Html.DevExtreme().Button().ID("BankCheckingRefreshGrid").Text("Refresh").Icon(IconID.ViewCustomers16x16devav).Icon("doc").Visible(true).OnClick(@<text> function () { BankChecking_RefreshGridClick(); } </text>) )
                    @(Html.DevExtreme().Button().ID("BankCheckingToggleScrollBar").Text(ViewBag.ShowHorizontalBar == 1 ? "Default Data" : "Full Data").Width(ViewBag.ShowHorizontalBar == 1 ? 110 : 90).Icon("toolbox").OnClick(@<text> function () { BankCheckingChangeMode(); } </text>) )
                    @(Html.DevExtreme().Button().ID("BankCheckingModelListPreview").Text("Export").Icon("save").Width(80).OnClick(@<text> function () { OnBankCheckingPreviewClick(); } </text>) )
                    @(Html.DevExtreme().Button().ID("BankCheckingModelCLOSE").Text("Close").Icon("clear").OnClick(@<text> function (){ closeChecking_Bank(); } </text>) )
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12" id="BankChecking_grid_DIV">
                <form>
                    <div id="bankCheckingReloadPartialView" class="parent_table">
                        @Html.Partial("Frm_BankChecking_Info_Grid", Model)
                    </div>
                </form>
            </div>
        </div>
        <div class="footer-MainBoxdiv" style="display:inline-block;width:100%">
            <div class="setFooterItem">
                <div class="footer-inner">
                    <div class="list_footer_left_margin">
                        <div class="footericon">
                            <i id="Bank_LockICON" style="color:red;font-size:35px;"></i>
                        </div>
                        <div class="footer-locktext">
                            <div id="Bank_Lbl_ActionOn" class="left_footertext_top"></div>
                            <div id="Bank_Lbl_ActionBy" class="left_footertext_bottom"></div>
                        </div>
                    </div>
                    <div class="list_footer_left_margin">
                        <div class="footer-text">
                            <p id="BankLbl_Create" class="right_footertext_top"></p>
                            <p id="BankLbl_Modify" class="right_footertext_bottom"></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
