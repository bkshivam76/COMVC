    <script class="BankChecking_Scripts">

    function BankCheckingOnInit(s, e)
    {
        BankCheckingAdjustSize();
        $(".BankPrfPreviewRow").hide();
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt)
        {
            BankCheckingAdjustSize();
        });

    }
    function BankCheckingGrid_BeginCallback(s, e)
    {
        BankCheckingFocusedRowIndexBeforeRefresh = s.GetFocusedRowIndex();
        e.customArgs["command"] = e.command;
        e.customArgs["ShowHorizontalBar"] = BankChecking_ShowHorizontalBar;
        e.customArgs["VouchingMode"] = BankChecking_IsVouchingMode;
        e.customArgs["ViewMode"] = BankChecking_ViewMode;
        e.customArgs["ColumnToBeShownIndex"] = BankChecking_ColumnToBeShownIndex;
        e.customArgs["ColumnToBeHidddenIndex"] = BankChecking_ColumnToBeHidddenIndex;
       // e.customArgs["RowKeyToFocus"] = BankChecking_BA_Rec_ID;
        e.customArgs["CheckingStatus"] = BankChecking_StatusValue;
    }

    function OnGridBankCheckingGrid_EndCallback(s, e)
    {       
        ASPxClientControl.AdjustControls(document.getElementById("BankChecking_ParentDiv"));
        BankChecking_ColumnToBeShownIndex = s.cpColumnToBeShownIndex;
        BankChecking_ColumnToBeHidddenIndex = s.cpColumnToBeHidddenIndex;
        BankCheckingGridLayout = s.cpClientLayout;
        if (BankChecking_IsVouchingMode == true) {
            $(".BankCheckingGrid_PreviewRow").hide();
        }
        else {
            $(".BankCheckingGrid_PreviewRow").show();
        }
        GetSessionStorage("BankCheckingGrid");
        SendCustomArgs_FilterControl(s, e);        

        if (BankCheckingFocusedRowIndexBeforeRefresh == s.GetFocusedRowIndex())
        {
            s.SetFocusedRowIndex(-1);
            s.SetFocusedRowIndex(BankCheckingFocusedRowIndexBeforeRefresh);
        }
     }
    function BankCheckingAdjustSize()
    {
        var height = (document.documentElement.clientHeight * 90) / 100;
        try{ BankCheckingGrid.SetHeight(height); } catch(err){}
        }

    function onCheckingStatusChange(e) {
        BankChecking_StatusValue = e.value
        BankCheckingGrid.Refresh();
    }
    function BankCheckingChangeMode()
    {
        ShowLoader();
        if (BankChecking_ShowHorizontalBar == 0)
        {
            BankChecking_ShowHorizontalBar = 1;
            $("#BankCheckingToggleScrollBar").find("span").text("Default Data");
            $("#BankCheckingToggleScrollBar").width(110);
        }
        else
        {
            BankChecking_ShowHorizontalBar = 0;
            $("#BankCheckingToggleScrollBar").find("span").text("Full Data");
            $("#BankCheckingToggleScrollBar").width(90);
        }
        $.ajax({
            url: '@Url.Action("Frm_BankChecking_Info_Grid", "BankBalanceChecking")',
            type: "GET",
            data: { ShowHorizontalBar: BankChecking_ShowHorizontalBar, Layout: BankCheckingGridLayout, VouchingMode: BankChecking_IsVouchingMode, ViewMode: BankChecking_ViewMode, ColumnToBeHidddenIndex: BankChecking_ColumnToBeHidddenIndex, ColumnToBeShownIndex: BankChecking_ColumnToBeShownIndex },
            success: function (res)
            {
                $("#bankCheckingReloadPartialView").html(res);
                if (BankChecking_IsVouchingMode == true) {
                    $(".BankCheckingGrid_PreviewRow").hide();
                }
                else {
                    $(".BankCheckingGrid_PreviewRow").show();
                }
                GetSessionStorage("BankCheckingGrid");
            }
        });
        HideLoader();
        }

    function BankCheckingOnGridFocusedRowChanged(s, e)
    {
        if (s.GetFocusedRowIndex() > -1)
        {
            if (!BankCheckingGrid.IsGroupRow(s.GetFocusedRowIndex()))
            {
                if (BankChecking_IsVouchingMode)
                {
                    BankChecking_FAB.SetVisible(true);
                    BankChecking_FAB.SetActionContext("VouchingActionContext", true);
                }
                var BBC_btn = ASPxClientControl.GetControlCollection().GetByName("BBC_btn" + BankChecking_BA_Rec_ID);
                if (BBC_btn && $("#BBC_btn" + BankChecking_BA_Rec_ID).length>0)
                {
                    BBC_btn.SetEnabled(false);
                }
                //s.GetRowValues(s.GetFocusedRowIndex(), 'ID;Edit_Date;Edit_By;Add_Date;Add_By;Action_Date;Action_By;Action_Status;CEN_ID', BankCheckingOnGetRowValues);
                BankCheckingOnGetRowValues(s.GetFocusedRowIndex())
            }
            else
            {
                BankChecking_BA_Rec_ID = null;
                BankChecking_UpdateFooterDetail(BankChecking_BA_Rec_ID, BankChecking_ActionStatus, BankChecking_AddDate, BankChecking_AddBy, BankChecking_ActionDate, BankChecking_ActionBy, BankChecking_EditDate, BankChecking_EditBy);
            }
        }
        else
        {
            BankChecking_BA_Rec_ID = null;
            BankChecking_UpdateFooterDetail(BankChecking_BA_Rec_ID, BankChecking_ActionStatus, BankChecking_AddDate, BankChecking_AddBy, BankChecking_ActionDate, BankChecking_ActionBy, BankChecking_EditDate, BankChecking_EditBy);
        }
    }

    function BankCheckingOnGetRowValues(RowIndex = null)
    {        
        var focusedrow = RowIndex == null ? BankCheckingGrid.GetFocusedRowIndex() : RowIndex;
        var topindex = BankCheckingGrid.GetTopVisibleIndex();
        var Index = focusedrow - topindex;
        var BankCheckingPageData = BankCheckingGrid.cpPagedata;
        if (BankCheckingPageData != null && BankCheckingPageData.length > 0 && Index < BankCheckingPageData.length) {
            BankChecking_BA_Rec_ID = BankCheckingPageData[Index][0];
            BankChecking_EditDate = BankCheckingPageData[Index][1];
            BankChecking_EditBy = BankCheckingPageData[Index][2];
            BankChecking_AddDate = BankCheckingPageData[Index][3];
            BankChecking_AddBy = BankCheckingPageData[Index][4];
            BankChecking_ActionDate = BankCheckingPageData[Index][5];
            BankChecking_ActionBy = BankCheckingPageData[Index][6];
            BankChecking_ActionStatus = BankCheckingPageData[Index][7];
            BankChecking_CEN_ID = BankCheckingPageData[Index][8];
            BankChecking_Balance = BankCheckingPageData[Index][9] == null ? 0 : BankCheckingPageData[Index][9];
            BankChecking_AccountType = BankCheckingPageData[Index][10];
            BankChecking_AccountNo = BankCheckingPageData[Index][11];
            BankChecking_BankFullName = BankCheckingPageData[Index][12];

            var BBC_btn = ASPxClientControl.GetControlCollection().GetByName("BBC_btn" + BankChecking_BA_Rec_ID);
            if (BBC_btn)
            {
                BBC_btn.SetEnabled(true);
            }
            BankChecking_UpdateFooterDetail(BankChecking_BA_Rec_ID, BankChecking_ActionStatus, BankChecking_AddDate, BankChecking_AddBy, BankChecking_ActionDate, BankChecking_ActionBy, BankChecking_EditDate, BankChecking_EditBy);
            var Leftpane = Mainspliter.GetPaneByName('LeftPane');
            if (BankChecking_IsVouchingMode == true)
            {
                if (Leftpane.IsCollapsed() == true)
                {
                    Leftpane.Expand();
                }
                ShowLoader();
                $("#LeftPane_Div_Content").html(null);
                var LoadURL = StandardizeCallURL("@Url.Action("LeftPaneContent", "BankBalanceChecking", new { @area = "Start" })?ID=" + BankChecking_BA_Rec_ID + "&VouchingMode=" + BankChecking_IsVouchingMode + "&CEN_ID=" + BankChecking_CEN_ID);
                $("#LeftPane_Div_Content").load(LoadURL, function () {
                    HideLoader();
                });
            }
        }
        else
        {
            BankChecking_BA_Rec_ID = null;
        }
    }
    function BankChecking_UpdateFooterDetail(BankChecking_BA_Rec_ID, Bank_Action_Status, Bank_Add_Date, Bank_Add_By, Bank_Action_Date, Bank_Action_By, Bank_Edit_Date, Bank_Edit_By) {

    HideLoader();
    var Status = "";
    var Lbl_Status = "";
    var Lbl_StatusBy = "";
    var Pic_Status = "";
    var Lbl_Create = "";
    var Lbl_Modify = "";
    var Lbl_Status_Color = "";
    var Lbl_ActionOn = "";
    var Lbl_ActionBy = "";
    var StatusStr = "";
        if (BankChecking_BA_Rec_ID != null)
    {
        Bank_Add_Date = (moment(Bank_Add_Date).format("DD/MM/YYYY HH:mm:ss"));
        Bank_Edit_Date = (moment(Bank_Edit_Date).format("DD/MM/YYYY HH:mm:ss"));
        Bank_Action_Date = (moment(Bank_Action_Date).format("DD/MM/YYYY HH:mm:ss"));
        Status = Bank_Action_Status;
        StatusStr = Status == "Locked" ? "Locked" : Status == null ? null : "UnLocked";

        if (Status && Status.toUpperCase() == "LOCKED") {
            Lbl_Status = "Completed";
            Lbl_Status_Color = "blue";
            Pic_Status = "fa fa-lock";
        }
        else {
            Pic_Status = "fa fa-unlock";
            Lbl_Status = Status;
            if (Status && Status.toUpperCase() == "COMPLETED") {
                Lbl_Status_Color = "green";
            }
            else {
                Lbl_Status_Color = "red";
            }
        }
        if (Bank_Action_Date) {
            Lbl_ActionOn = StatusStr + " On: " + Bank_Action_Date;
            Lbl_ActionBy = StatusStr + " By: " + Bank_Action_By;
        }

        else {
            Lbl_ActionOn = "";
            Lbl_ActionBy = "";
        }
        if (Bank_Add_Date) {
            Lbl_Create = "Add On: " + Bank_Add_Date + ", By: " + Bank_Add_By;
        }
        else {
            Lbl_Create = "";
        }

        if (Bank_Edit_Date) {
            Lbl_Modify = "Edit On: " + Bank_Edit_Date + ", By: " + Bank_Edit_By;
        }
        else {
            Lbl_Modify = "";
        }
    }
    $('#BankLbl_Status').text(Lbl_Status);
    $('#Bank_Lbl_ActionOn').text(Lbl_ActionOn)
    $('#Bank_Lbl_ActionBy').text(Lbl_ActionBy);
    $('#BankLbl_Create').text(Lbl_Create);
    $('#BankLbl_Modify').text(Lbl_Modify);
    if (Lbl_Status_Color != "") {
        $('#BankLbl_Status').css('color', Lbl_Status_Color);
    }
    if (Pic_Status == "fa fa-lock") {
        $('#Bank_LockICON').addClass(Pic_Status).removeClass("fa-unlock");
    }
    else if (Pic_Status == "fa fa-unlock") {
        $('#Bank_LockICON').addClass(Pic_Status).removeClass("fa-lock");
    }
    else {
        $('#Bank_LockICON').removeClass("fa");
        $('#Bank_LockICON').removeClass("fa-lock");
        $('#Bank_LockICON').removeClass("fa-unlock");
    }
}

    function BankCheckingContextMenuFunction(s, e) {
        if (e.item.name == "Close") {
            closeChecking_Bank();
        }
        else if (e.item.name == 'Profile_Bank_View') {
            BankProfile_OnViewClick();
        }
        else if (e.item.name == 'ListPreview') {
            OnBankCheckingPreviewClick();
        }
        else if (e.item.name == 'Refresh') {
            BankCheckingGrid.Refresh();
        }
    }

    function BankChecking_SaveButton_Click() {

    BankCheckingOnGetRowValues();

    var BankChecking_PassbookBalance_CellName = "BBC_spin" + BankChecking_BA_Rec_ID;
    var BankChecking_AccountStatus_CellName = "BBC_cmb" + BankChecking_BA_Rec_ID;
    var BankChecking_TxnDate_CellName = "BBC_txt" + BankChecking_BA_Rec_ID;

    var BankChecking_PassbookBalance_CellValue = ASPxClientControl.GetControlCollection().GetByName(BankChecking_PassbookBalance_CellName).GetValue();
    var BankChecking_AccountStatus_CellValue = ASPxClientControl.GetControlCollection().GetByName(BankChecking_AccountStatus_CellName).GetValue();
    var BankChecking_TxnDate_CellValue = ASPxClientControl.GetControlCollection().GetByName(BankChecking_TxnDate_CellName).GetValue();

    BankChecking_TxnDate_CellValue = (BankChecking_TxnDate_CellValue == null) ? null : moment(BankChecking_TxnDate_CellValue).format("DD/MM/YYYY");
        BankChecking_PassbookBalance_CellValue == null ? 0 : BankChecking_PassbookBalance_CellValue;
        var SaveBankBalanceDetails = true;

    if (BankChecking_TxnDate_CellValue != null) {

        if (moment(BankChecking_TxnDate_CellValue, "DD/MM/YYYY").toDate() > moment("@Open_FY_Edt", "DD/MM/YYYY").add(90, 'days').toDate()) {

            SaveBankBalanceDetails = false;

            var alertResult = alertResult = DevExpress.ui.dialog.alert("Last Transaction Date Cannot be greater than End Date of open FY by 90 Days.", "Information");
            alertResult.done(function (result) {
                if (result) {
                    ASPxClientControl.GetControlCollection().GetByName(BankChecking_TxnDate_CellName).Focus();
                    return;
                }
            });

        }
        }        
        if (BankChecking_Balance != BankChecking_PassbookBalance_CellValue)
        {
            SaveBankBalanceDetails = false;
            var alertResult = alertResult = DevExpress.ui.dialog.alert("Passbook balance and ConnectOne bank balance does not match", "Information");
            alertResult.done(function (result)
            {
                if (result)
                {
                    ASPxClientControl.GetControlCollection().GetByName(BankChecking_PassbookBalance_CellName).Focus();
                }
            });
            return;
        }
    if (SaveBankBalanceDetails) {
        ShowLoader();
        $.ajax({
            type: 'POST',
            url: "/Start/BankBalanceChecking/SaveBankBalance",
            data:
            {
                passbookbalance: BankChecking_PassbookBalance_CellValue == null ? 0 : BankChecking_PassbookBalance_CellValue,
                accountStatus: BankChecking_AccountStatus_CellValue,
                lastTxnDate: BankChecking_TxnDate_CellValue,
                BA_REC_ID: BankChecking_BA_Rec_ID

            },
            cache: false,
            success: function (data) {
                HideLoader();

                var alertResult = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                alertResult.done(function (result) {
                    if (result) {
                        //BankCheckingGrid.Refresh();
                    }
                });
            }
        });
    }

}
    </script>

    <script>
    function getBankstatement_BankChecking_Onclick()
    {
        if (BankChecking_BA_Rec_ID == null || BankChecking_BA_Rec_ID == "" || BankChecking_BA_Rec_ID == "0") {
            DevExpress.ui.dialog.alert("Please select one row", "Alert");
            return
        }     
        getBankStatement_window(BankChecking_BankFullName, BankChecking_AccountType, BankChecking_AccountNo, BankChecking_BA_Rec_ID,"Start_BankChecking")
    }

</script>
