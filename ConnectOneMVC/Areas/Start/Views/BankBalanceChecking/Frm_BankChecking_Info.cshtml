    <script class="BankChecking_Scripts">

    function BankCheckingGrid_CollapseAllDetailRows()
    {
            if (typeof window !== 'undefined')
            {
                if (typeof window.BankCheckingGrid !== 'undefined')
                {
                    if (typeof window.BankCheckingGrid.CollapseAllDetailRows !== 'undefined')
                    {
                        if (typeof BankCheckingGrid.CollapseAllDetailRows == 'function')
                        {
                            BankCheckingGrid.SetFocusedRowIndex(-1);
                            BankCheckingGrid.CollapseAllDetailRows();
                        }
                        else
                        {
                            alert("CollapseAllDetailRows is not a function");
                        }
                    }
                    else
                    {
                        ShowLoader();
                        setTimeout(function ()
                        {
                            BankCheckingGrid_CollapseAllDetailRows();
                            HideLoader();
                        }, Timeout100);
                    }
                }
                else
                {
                    alert('grid undefined')
                }
            }
            else
            {
                alert('window undefined')
            }
    }

    function BankChecking_VouchingSwitch_ValueChange(e) {
        BankChecking_IsVouchingMode = e.value;
        if (BankCheckingInfo_SetVouchingModeOn == true) {
            BankCheckingInfo_SetVouchingModeOn = false;
        }
        else {
            BankChecking_FAB.SetVisible(false);
        }
        if (BankChecking_IsVouchingMode == true) {
            var Rightpane = Mainspliter.GetPaneByName('RightPane');
            Rightpane.Expand();
            var Leftpane = Mainspliter.GetPaneByName('LeftPane');
            ClearLeftPane();
            if (Leftpane.IsCollapsed() == true) {
                Leftpane.Expand();
            }
        }
        else {
            var Rightpane = Mainspliter.GetPaneByName('RightPane');
            if (Rightpane.IsCollapsed() == false) {
                Rightpane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
            }
            var Leftpane = Mainspliter.GetPaneByName('LeftPane');
            ClearLeftPane();
            if (Leftpane.IsCollapsed() == false) {
                Leftpane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
            }
        }
        BankCheckingGrid_CollapseAllDetailRows();
    }
    function BankChecking_ViewSwitch_ValueChange(e) {
        BankChecking_ViewMode = e.value == false ? "Default" : "Compact";
        if (BankCheckingInfo_SetVouchingModeOn == true) {
            $("#BankVouchingModeSwitch").dxSwitch("instance").option("value", true);
        }
        else {
            BankCheckingGrid.CollapseAllDetailRows();
        }
    }

    function OnBankCheckingPreviewClick()
    {

        OpenPopup("BankChecking_report_modal", "Export Option", "@Url.Action("Frm_Export_Options", "BankBalanceChecking", new { @area = "Start" })", "auto", 125);
    }

    function BankChecking_RefreshGridClick() {
        BankCheckingGrid.Refresh();
    }

    function closeChecking_Bank()
    {
            $(".TabPanalMenu-tabs .active span").click();

    }
    $(".TabPanalMenu-tabs .active span").on("click", function () {
        $.ajax({
            type: 'GET',
            url: "/Start/BankBalanceChecking/SessionClear",
            cache: false
        });
        var pane = Mainspliter.GetPaneByName('RightPane');
        pane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
        var Leftpane = Mainspliter.GetPaneByName('LeftPane');
        ClearLeftPane();
        if (Leftpane.IsCollapsed() == false)
        {
            Leftpane.Collapse(Mainspliter.GetPaneByName('MiddlePane'));
        }
        ClearAllReferences_BankChecking();
    });

    function ClearAllReferences_BankChecking()
    {
        BankCheckingInfo_IsDetailRowExpanded = null;
        BankCheckingInfo_NestedRecord_FocusedRowIndex = null;
        BankCheckingInfo_NestedGrid_AccessID = null;
        BankCheckingInfo_AtachmentID = null;
        BankCheckingInfo_FileName = null;
        BankCheckingInfo_ParamMandatory = null;
        BankCheckingInfo_FromDateLabel = null;
        BankCheckingInfo_ToDateLabel = null;
        BankCheckingInfo_DescriptionLabel = null;
        BankCheckingInfo_Doc_ID = null;
        BankCheckingInfo_Doc_Category = null;
        BankCheckingInfo_MasterRowRecID = null;
        BankCheckingInfo_MasterRowMID = null;
        BankCheckingInfo_NestedRowMapID = null;
        BankCheckingInfo_NestedRowUniqueID = null;
        BankCheckingInfo_reason = null;
        BankCheckingInfo_Attachment_RecStatus = null;
        BankCheckingInfo_SetVouchingModeOn = null;
        BankCheckingInfo_NestedRowReasonID = null;
        BankCheckingInfo_Nested_Doc_Status = null;

        BankChecking_ShowHorizontalBar = null;
        BankCheckingGridLayout = null;
        BankCheckingFocusedRowIndexBeforeRefresh = null;
        BankChecking_BA_Rec_ID = null;
        BankChecking_ActionStatus = null;
        BankChecking_EditDate = null;
        BankChecking_AddBy = null;
        BankChecking_AddDate = null;
        BankChecking_EditBy = null;
        BankChecking_ActionDate = null;
        BankChecking_ActionBy = null;
        BankChecking_IsVouchingMode = null;
        BankChecking_ViewMode = null;
        BankChecking_ColumnToBeShownIndex = null;
        BankChecking_ColumnToBeHidddenIndex = null;
        BankChecking_StatusValue = null;
        BankChecking_AccountType = null;
        BankChecking_AccountNo = null;
        BankChecking_BankFullName = null;

        ClearAllReferences("BankChecking_ClearReferences");

}
