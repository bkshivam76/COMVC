<div class="DocumentChecking_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    @using DevExpress;
    @using DevExpress.Web.Mvc;
    @model IEnumerable<dynamic>
    @{
        Layout = null;
        bool Doc_Delete_Right = (bool)ViewData["Help_Attachment_DeleteRight"];
        bool Doc_Edit_Right = (bool)ViewData["Help_Attachment_UpdateRight"];
    }
    <style>
        .dx-list-item-content {
            white-space: normal;
        }
    </style>

    <div id="DocumentChecking_ParentDiv">
        <div class="full-width-header-bg2">
            <div class="row">
                <div class="col-sm-6">
                    <label class="report_header_label">Document Checking</label>
                </div>
                <div class="col-sm-6  styleActionBtn">
                    @(Html.DevExtreme().Button().ID("DocumentCheckingSelectFilter").Text("Filters").OnClick(@<text>function () {OnFilterDocument(); } </text>).Icon("fas fa-filter checkgreen "))
                    @(Html.DevExtreme().Button().ID("DocumentCheckingApplyFilter").Text("Show").OnClick("DocumentChecking_ApplyFilter").Icon("fas fa-check-circle btn-icons checkgreen"))
                    @(Html.DevExtreme().Button().ID("DocumentCheckingToggleScrollBar").Text("Full Data").Icon("toolbox").OnClick(@<text>function () {DocumentCheckingChangeMode(); } </text>))
                    @(Html.DevExtreme().Button().ID("DocumentCheckingCLOSE").Text("Close").Icon("close").OnClick(@<text> function (){CloseDocumentChecking();} </text>) )
                </div>
            </div>
        </div><!--[Header]-->

        <div id="DC_Grid_DIV" class="parent_table">
            <form id="DocumentCheckingGridPartialView">
                @Html.Partial("DocumentChecking_Grid", Model)
            </form>
        </div>  @* Grid *@
    </div>

    @(Html.DevExtreme().Popup().ID("DC_Filters_popup").OnShowing("PopupOnShowing").Title("Select Options").Height("auto").MaxHeight(350).Width("auto").MaxWidth(300).Shading(false).ContentTemplate( @<text> <div id='popup_dc_filter_result'>
    <div class="row">
        <div class="form-field">
            <div class="container-fluid">
                <div class="row">
                    <div class="col-sm-12 col-md-12 col-lg-12">
                        <label>Document Category:</label>
                    </div>
                    <div class="col-sm-12 col-md-12 col-lg-12">
                        @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("DC_DocumentCategory").Name("DC_DocumentCategory").DataSource(d => d.Mvc().Controller("DocumentChecking").LoadAction("LookUp_GetDocument_Category").Key("ID")).DisplayExpr("Category").ValueExpr("ID").OnValueChanged("DC_Category_ValueChange"))
                    </div>
                    <div class="col-sm-12 col-md-12 col-lg-12">
                        <label>Document Name:</label>
                    </div>
                    <div class="col-sm-12 col-md-12 col-lg-12">
                        @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("DC_DocumentName").Name("DC_DocumentName").DataSource(d => d.Mvc().Controller("DocumentChecking").LoadAction("LookUp_GetDocument_Name").Key("ID").LoadParams(new { CategoryName = new JS("function (){ return DC_Doc_Category;}") })).DisplayExpr("Name").ValueExpr("ID").ReadOnly(true).OnValueChanged("DC_Name_ValueChange"))
                    </div>
                    <div class="col-sm-12 col-md-12 col-lg-12">
                        <label>Status:</label>
                    </div>
                    <div class="col-sm-12 col-md-12 col-lg-12">
                        @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("DC_Status").Name("DC_Status").Items(new[] { "ACCEPTED", "REJECTED", "PENDING", "ALL" }).Value("PENDING").OnValueChanged("DC_Status_ValueChange").ShowClearButton(false))
                    </div>
                </div>
                <div class="row">
                    <div class="col-sm-12 col-md-12 col-lg-12">
                        <label>Audit Status:</label>
                    </div>
                    <div class="col-sm-12 col-md-12 col-lg-12">
                        @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("DC_AuditStatus").Name("DC_AuditStatus").Items(new[] { "Audited", "Unaudited", "All" }).Value("Unaudited").OnValueChanged("DC_AuditStatus_ValueChange").ShowClearButton(false))
                    </div>
                    <div class="col-sm-12 col-md-12 col-lg-12">
                        <label>Checked By:</label>
                    </div>
                    <div class="col-sm-12 col-md-12 col-lg-12">
                        @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("DC_CheckedBy").Name("DC_CheckedBy").DataSource(d => d.Mvc().Controller("DocumentChecking").LoadAction("LookUp_GetCheckedBy").Key("REC_ID")).DisplayExpr("USER_ID").ValueExpr("USER_ID").OnValueChanged("DC_CheckedBy_ValueChange").ShowClearButton(true))
                    </div>
                    <div class="col-sm-12 col-md-12 col-lg-12">
                        <label>Data Scope:</label>
                    </div>
                    <div class="col-sm-12 col-md-12 col-lg-12">
                        @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("DC_DataScope").Name("DC_DataScope").Items(new[] { "All", "Exclusive" }).Value("Exclusive").OnValueChanged("DC_DataScope_ValueChange").ShowClearButton(false))
                    </div>
                    <div class="col-sm-12 col-md-12 col-lg-12 styleActionBtn">
                        @(Html.DevExtreme().Button().ID("DocumentCheckingApplyFilter2").Text("Show").OnClick("DocumentChecking_ApplyFilter"))
                    </div>
                </div>
            </div>
        </div>
    </div><!--[Filters]-->
</div> </text>) )

    @Html.DevExpress().FloatingActionButton(
