    //$('.notification-list').slimScroll({
    //    height: '325px'
    //});
    function pending_task_click() {
        var docWidth = (document.documentElement.clientWidth);
        if (docWidth < 768) { $("#btn_menu_mobile").trigger("click"); } //check why not working
        OpenTabControl('ActionItems_frm_ActionItems_Info', 'Audit Actions', '@Url.Action("Frm_Action_Items_Info","ActionItems",new { @area = "Help" })');
    }
    function doc_click() {
        OpenTabControl('ActionItems_Frm_Attachment_Info','Attachment Box','@Url.Action("Frm_Attachment_Info","Attachment",new { @area = "Help" })');
    }
    function pending_internal_transfer_click() {
        OpenTabControl('Frm_I_Transfer_Reg','Internal Transfer Register','@Url.Action("Frm_I_Transfer_Reg", "InternalTransfer", new { @area = "Account" })');
    }
      function current_month_service_reports()
    {
        OpenTabControl('Frm_Service_Report_Info_Dx','Godly Service Report','@Url.Action("Frm_Service_Report_Info_dx","ServiceReport",new { @area = "Facility" })')
    }
    $(document).ready(function ()
    {
        if ("@GenericLogin" == "True")
        {
            //if(isMenuListVisible($("#Facility_ServiceProject")))
            //{
            //    $("#Facility_ServiceProject").click();
            //}
            //By default on Login it will open Sparc Screen
            if (isMenuListVisible($("#Facility_SparcProject")))
            {
                $("#Facility_SparcProject").click();
            }
        }
        if (sessionStorage.getItem("Window_is_reloaded") == null) {
            AutoOpenScreenIds = @Html.Raw(Json.Encode(AutoOpenScreenIDs));
            if (AutoOpenScreenIds != null && AutoOpenScreenIds.length > 0) {
                ShowLoader();
                for (var i = 0; i < AutoOpenScreenIds.length; i++) {
                    if (AutoOpenScreenIds[i] != null && AutoOpenScreenIds[i].length > 0) {
                        $("#" + AutoOpenScreenIds[i]).click();
                    }
                }
                HideLoader();
            }
        }
        sessionStorage.setItem("Window_is_reloaded", true);
    });
</script>
