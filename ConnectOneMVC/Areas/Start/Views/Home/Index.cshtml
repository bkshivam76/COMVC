    async function getBankStatement_window(bankName, accountType, accountNumber, account_ID,screen, _FromDate = "", _ToDate = "")
    {
        if (accountNumber == null || accountNumber == "" || accountNumber == "0")
        {
            DevExpress.ui.dialog.alert("Invalid Account/FD Number", "Information");
            return
        }
        if (screen == "Profile_BankAccounts" || screen == "Start_BankChecking")
        {
            if (accountType.toLowerCase() == "fd")
            {
                DevExpress.ui.dialog.alert("For checking Account statement of FD, please use Profile -> FD Screen", "Information");
                return
            }
            if (screen == "Start_BankChecking")
            {
                var year = "20" + open_FY.slice(-2)
                _FromDate = "10/03/" + year;
                _ToDate = "10/04/" + year;
                if (bankName.toLowerCase().startsWith("state bank of"))
                {
                    _ToDate = "08/04/" + year;
                }
            }
        }
        if (bankName.toLowerCase() == "bank of baroda")
        {
            var firstFourLettersOfAccnt = accountNumber.slice(0, 4)
            const reloadableAccountsStartingNums = ["1190", "1570", "6082","6083"];
            if (reloadableAccountsStartingNums.includes(firstFourLettersOfAccnt))
            {
                DevExpress.ui.dialog.alert("This facility is not available on Re-loadable cards", "Information");
                return;
            }
        }
        else if (bankName.toLowerCase().startsWith("state bank of"))
        {

        }
        else
        {
            DevExpress.ui.dialog.alert("This functionality is only for Bank of Baroda and State Bank Of India bank accounts", "Information");
            return;
        }
        ShowLoader();
        var genuine = await CheckGenuineAccount(accountNumber)
        if (genuine.jsonParam.result)
        {
            var apiActivated = await CheckApiActivatedAccount(accountNumber)
            if (apiActivated.jsonParam.result) {
                ShowLoader();
                $.ajax({
                    type: 'GET',
                    url: '/Profile/BankAPI/Frm_BankStatement_window_Tabs',
                    cache: false,
                    data:
                    {
                        accountNumber: accountNumber,
                        bankName: bankName,
                        account_ID: account_ID,
                        FromDate: _FromDate,
                        ToDate: _ToDate
                    },
                    success: function (data) {
                        HideLoader();
                        OpenPopup("popup_BankStatement_Window", "Bank Statement", null, "auto", 1080, true, data);
                    }
                });
            }
            else
            {
                HideLoader()
                DevExpress.ui.dialog.alert("This account number is not registered in Bank API Tables. Please contact BK Saurabh bhai in Madhuban", "Information");
            }
        }
        else
        {
            HideLoader()
            DevExpress.ui.dialog.alert("There seems a security issue in this bank account. Please contact BK Saurabh bhai in madhuban", "Information");
        }
    }
    async function CheckGenuineAccount(accountNumber) {
        return $.ajax({
            type: 'POST',
            url: "/Profile/BankAPI/CheckForGenuineAccount",
            data:
            {
                accountNumber: accountNumber
            },
            cache: false
        });
    }
    async function CheckApiActivatedAccount(accountNumber) {
        return $.ajax({
            type: 'POST',
            url: "/Profile/BankAPI/CheckForApiActivated",
            data:
            {
                accountNumber: accountNumber
            },
            cache: false
        });
    }
</script>
<script>
    function Vouchers_New(Voucher_Type, Selection_By_Item = false, Selected_Item_ID = "", Selected_Item_Name = "", _Additionalparam = "", Sel_Led_Name = "", Sel_Led_ID = "")
    {
        var zfrmTag = "_New";
        var zfrmItemID = "";
        var popup_title = "";
        var popup_form_name = "";
        var popup_form_path = "";
        var popup_querystring = "";
        var result = false;
        if (Selection_By_Item)
        {
            zfrmTag = "_New_From_Selection";
            zfrmItemID = Selected_Item_ID;
        }
        if (Voucher_Type == "CASH") {
            result = true;
            popup_title = "New ~ Cash Deposit / Withdrawn";
            popup_form_name = "Frm_Voucher_Win_Cash";
            popup_form_path = "/Account/CashDepositAndWithdrawnVoucher/Frm_Voucher_Win_Cash/";
            popup_querystring = "Tag=" + zfrmTag + "&iSpecific_ItemID=" + zfrmItemID;
        }
        else if (Voucher_Type == "BANK")
        {
           result = true;
           popup_title = "New ~ Bank to Bank Transfer";
           popup_form_name = "Frm_Voucher_Win_B2B";
           popup_form_path = "/Account/BankToBankTransferVoucher/Frm_Voucher_Win_B2B/";
           popup_querystring = "Tag=" + zfrmTag + "&iSpecific_ItemID=" + zfrmItemID;
        }
        else if (Voucher_Type == "DONATION - REGULAR") {
            result = true;
            popup_title = "New ~ Donation";
            popup_form_name = "Frm_Voucher_Win_Donation_R";
            popup_form_path = "/Account/DonationVoucher/Frm_Voucher_Win_Donation_R/";
            popup_querystring = "Tag=" + zfrmTag + "&iSpecific_ItemID=" + zfrmItemID;
        }
        else if (Voucher_Type == "DONATION - FOREIGN") {
           result = true;
           popup_title = "New ~ Foreign Donation";
           popup_form_name = "Frm_Voucher_Win_Donation_F";
           popup_form_path = "/Account/DonationVoucher/Frm_Voucher_Win_Donation_F/";
           popup_querystring = "Tag=" + zfrmTag + "&iSpecific_ItemID=" + zfrmItemID;
        }
        else if (Voucher_Type == "COLLECTION BOX")
        {
            if ("@open_Ins_ID" == "00001" || "@open_Ins_ID" == "00005" || "@open_Ins_ID" == "00009")
            {
                result = true;
                popup_title = "New ~ Collection Box";
                popup_form_name = "Frm_Voucher_Win_C_Box";
                popup_form_path = "/Account/CollectionBoxVoucher/Frm_Voucher_Win_C_Box/";
                popup_querystring = "Tag=" + zfrmTag + "&iSpecific_ItemID=" + zfrmItemID;
            }
            else
            {
                result = false;
                DevExpress.ui.dialog.alert("In " + "@InsName" + "<br><br>Collection Box Entry Not Applicable...!", "CashBook")
            }
        }
        else if (Voucher_Type == "PAYMENT" || Voucher_Type == "PAYMENT - INSTITUTE")
        {
          result = true;
          popup_title = "New ~ Payment";
          popup_form_name = "Frm_Voucher_Win_Gen_Pay";
          popup_form_path = "/Account/PaymentVoucher/Frm_Voucher_Win_Gen_Pay/";
            popup_querystring = "Tag=" + zfrmTag + "&iSpecific_ItemID=" + zfrmItemID;
            if (Sel_Led_Name != null && Sel_Led_Name.length > 0)
            {
                Sel_Led_Name = Sel_Led_Name.toUpperCase();
                if (Sel_Led_Name == "DEBTORS" || Sel_Led_Name == "CREDITORS" || Selected_Item_Name.toUpperCase().startsWith("PAYMENT"))
                {
                    popup_querystring = popup_querystring + "&SelectedPaymentType=" + "Cash";
                }
            }
            if (_Additionalparam != null && _Additionalparam.length > 0)
            {
                zfrmTag = "_New_From_Selection";
                popup_querystring = "Tag=" + zfrmTag + "&iSpecific_ItemID=" + zfrmItemID
                if (_Additionalparam == "BANK") {
                    popup_querystring = popup_querystring + "&SelectedPaymentType=" + "Bank";
                }
                if (_Additionalparam == "CASH") {
                    popup_querystring =popup_querystring + "&SelectedPaymentType=" + "Cash";
                }
                if (_Additionalparam == "JV") {
                   popup_querystring = popup_querystring + "&SelectedPaymentType=" + "Credit";
                }
            }
        }
        else if (Voucher_Type == "RECEIPTS" || Voucher_Type == "RECEIPTS - INSTITUTE")
        {
           result = true;
           popup_title = "New ~ Receipt";
           popup_form_name = "Frm_Voucher_Win_Gen_Rec";
           popup_form_path = "/Account/ReceiptVoucher/Frm_Voucher_Win_Gen_Rec/";
           popup_querystring = "Tag=" + zfrmTag + "&iSpecific_ItemID=" + zfrmItemID;
        }
        else if (Voucher_Type == "DONATION - GIFT") {
           result = true;
           popup_title = "New ~ Donation in Kind";
           popup_form_name = "Frm_Voucher_Win_Gift";
           popup_form_path = "/Account/DonationInKindVoucher/Frm_Voucher_Win_Gift/";
           popup_querystring = "Tag=" + zfrmTag + "&iSpecific_ItemID=" + zfrmItemID;
        }
        else if (Voucher_Type == "INTERNAL TRANSFER") {
           result = true;
           popup_title = "New ~ Internal Transfer";
           popup_form_name = "Frm_Voucher_Win_I_Transfer";
           popup_form_path = "/Account/InternalTransfer/Frm_Voucher_Win_I_Transfer/";
           popup_querystring = "Tag=" + zfrmTag + "&iSpecific_ItemID=" + zfrmItemID;
        }
        else if (Voucher_Type == "FD")
        {
            if (!Selection_By_Item)
            {
               result = true;
               popup_title = "FD Activity";
               popup_form_name = "Frm_Voucher_Win_FD_Type";
               popup_form_path = "/Account/FDVoucher/Frm_Voucher_Win_FD_Type/";
               popup_querystring = "";
            }
            else
            {
                var zfrmiAction = "";
                var zfrmTitleX = "New";
                switch (Selected_Item_ID)
                {
                    case "f6e4da62-821f-4961-9f93-f5177fca2a77":
                        zfrmiAction = "New_FD";
                        zfrmTitleX = "FD Creation";
                        break;
                    case "4eb60d78-ce90-4a9f-891b-7a82d79dc84b":
                        zfrmiAction = "Renew_FD";
                        zfrmTitleX = "FD Renewal";
                        break;
                    case "1ed5cbe4-c8aa-4583-af44-eba3db08e117":
                    case "65730a27-e365-4195-853e-2f59225fe8f4":
                        zfrmiAction = "Close_FD";
                        zfrmTitleX = "FD Closure";
                        zfrmItemID = "65730a27-e365-4195-853e-2f59225fe8f4";
                        break;
                }
                result = true;
                popup_title = "New ~ " + zfrmTitleX;
                popup_form_name = "Frm_Voucher_Win_FD";
                popup_form_path = "/Account/FDVoucher/Frm_Voucher_Win_FD/";
                popup_querystring = "Tag=" + zfrmTag + "&iSpecific_ItemID=" + zfrmItemID + "&iAction=" + zfrmiAction + "&TitleX=" + zfrmTitleX;
            }
        }
        else if (Voucher_Type == "SALE OF ASSET") {
            result = true;
            popup_title = "New ~ Sale of Asset";
            popup_form_name = "Frm_Voucher_Win_Sale_Asset";
            popup_form_path = "/Account/SaleAsset/Frm_Voucher_Win_Sale_Asset/";
            popup_querystring = "Tag=" + zfrmTag + "&iSpecific_ItemID=" + zfrmItemID;
        }
        else if (Voucher_Type == "MEMBERSHIP") {
            result = true;
            popup_title = "New ~ Membership";
            popup_form_name = "Frm_Voucher_Membership";
            popup_form_path = "/Membership/MembershipReceiptRegister/Frm_Voucher_Membership";
            popup_querystring = "Tag=" + zfrmTag + "&iSpecific_ItemID=" + zfrmItemID;
        }
        else if (Voucher_Type == "MEMBERSHIP RENEWAL")
        {
            result = false;
            DevExpress.ui.dialog.alert("NEW Membership Renewal is not allowed", "Error!!")
        }
        else if (Voucher_Type == "JOURNAL")
        {
            result = true;
            popup_title = "New ~ Journal Entry";
            popup_form_name = "Frm_Voucher_Win_Journal";
            popup_form_path = "/Account/JournalVoucher/Frm_Voucher_Win_Journal/";
            popup_querystring = "Tag=" + zfrmTag + "&iSpecific_ItemID=" + zfrmItemID;
        }
        else if (Voucher_Type == "ASSET TRANSFER")
        {
           result = true;
           popup_title = "New ~ Asset Transfer";
           popup_form_name = "Frm_Voucher_Win_Asset_Transfer";
           popup_form_path = "/Account/AssetTransferVoucher/Frm_Voucher_Win_Asset_Transfer/";
           popup_querystring = "Tag=" + zfrmTag + "&iSpecific_ItemID=" + zfrmItemID;
        }
        else if (Voucher_Type == "WIP FINALIZATION")
        {
           result = true;
           popup_title = "New ~ WIP Finalization";
           popup_form_name = "Frm_Voucher_Win_WIP_Finalization";
           popup_form_path = "/Account/WIPFinalization/Frm_Voucher_Win_WIP_Finalization/";
           popup_querystring = "Tag=" + zfrmTag + "&iSpecific_ItemID=" + zfrmItemID;
        }
        if (result) {
            if (popup_form_name == "Frm_Voucher_Win_FD_Type") {
                OpenDynamicPopup(popup_title, popup_form_path + "?" + encodeURI(popup_querystring), "auto", 300, false, false);
            }
            else {
                var width = 1000;
                switch (popup_form_name) {
                    case "Frm_Voucher_Win_Donation_R":
                        width = 750;
                        break;
                    case "Frm_Voucher_Win_Cash":
                        width = 840;
                        break;
                    case "Frm_Voucher_Win_WIP_Finalization":
                        width = 750;
                        break;
                    case "Frm_Voucher_Win_FD":
                        width = 750;
                        break;
                    case "Frm_Voucher_Win_B2B":
                        width = 750;
                        break;
                    case "Frm_Voucher_Win_Gen_Rec":
                        width = 850;
                        break;
                }
                OpenDynamicPopup(popup_title, popup_form_path + "?" + encodeURI(popup_querystring), "auto", width, false, false);
            }
        }
        else
        {
            HideLoader();
        }
    }

    /// <summary>
    /// Voucher Edit call when only Txn Entry Record ID is available on Screen
    /// </summary>
    /// <param name="Txn_Rec_ID"></param>
    /// <param name="Me_Text"></param>
    /// <param name="GridToRefresh"></param>
    /// <param name="Tr_Date"></param>
    /// <param name="MultiUserConfirmationTaken"></param>
    function Vouchers_Edit_TxnEntryID(_Txn_Rec_ID, _Me_Text, _GridToRefresh, _Tr_Date = null, _MultiUserConfirmationTaken = false) {
        ShowLoader();
        $.ajax({
            type: "GET",
            url: "/Account/CommonCalls/Vouchers_Edit1",
            data:
            {
                Txn_Rec_ID: _Txn_Rec_ID,
                Me_Text: _Me_Text,
                GridToRefresh: _GridToRefresh,
                Tr_Date: _Tr_Date,
                MultiUserConfirmationTaken: _MultiUserConfirmationTaken
            },
            cache: false,
            success: function (data) {
                HideLoader();
                if (data.jsonParam.result == false) {
                    if (data.jsonParam.isconfirm == true) {
                        DevExpress.ui.dialog.confirm(data.jsonParam.message, data.jsonParam.title).done(function (result) {
                            if (result == false) {
                                RefreshGridView(_GridToRefresh);
                            }
                            else {
                                Vouchers_Edit_TxnEntryID(_Txn_Rec_ID, _Me_Text, _GridToRefresh, _Tr_Date, true);
                            }
                        })
                    }
                    else {
                        DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                        if (data.jsonParam.refreshgrid == true) {
                            RefreshGridView(_GridToRefresh);
                        }
                    }
                }
                else
                {
                    VoucherEntriesPopupOpen(data.jsonParam.popup_form_name, data.jsonParam.popup_title, data.jsonParam.popup_form_path, data.jsonParam.popup_querystring)                 
                }
            }
        });
    }
