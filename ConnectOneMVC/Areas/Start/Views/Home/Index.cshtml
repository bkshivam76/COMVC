                GridID_MetropolisBlue = null;
                GridID_Aqua = null;
                GridID_dx = null;
            }
            if (evt.target.classList.contains("dx-dialog-button"))// handling shortcuts for dialog boxes
            {
                if (evt.keyCode == 9 || (evt.keyCode >= 37 && evt.keyCode <= 40))//tab and arrow keys
                {
