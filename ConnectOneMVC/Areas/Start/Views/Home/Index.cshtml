            {
                ASPxClientUtils.PreventEventAndBubble(evt);
                var GridID_Aqua = $(".tab-content .tab-pane.active .dxgvControl_Aqua").attr("id");
                var GridID_MetropolisBlue = $(".tab-content .tab-pane.active .dxgvControl_MetropolisBlue").attr("id");
