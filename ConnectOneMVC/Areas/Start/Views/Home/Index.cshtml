        console.log(e.file);
        var message = "";
        if (Attach_uploadErrorDuetohtml == true)
        {
            Attach_uploadErrorDuetohtml = false;
            message = "<b>Html files are not allowed</b><br>";
        }
        else if (Attach_uploadErrorDuetoFilesize == true)
        {
            Attach_uploadErrorDuetoFilesize = false;
            message = "<b>Max File Size Allowed is 20MB</b><br>";
        }
        if (e.error.statusText.length > 0)
        {
            message = message + (e.error.status == void 0 ? "" : e.error.status) + ": " + e.error.statusText + "<br>";
        }
        DevExpress.ui.dialog.alert(message + Attached_FileName + "<br>Did Not Upload<br>Kindly Check The File", 'Upload Error..');
    }
    function Common_fileUploader_valueChanged(e)
    {
        var files = e.value;
        if (files.length > 0)
        {
            var ErrMsg = PreventFileUpload(files[0])
            if (ErrMsg != null && ErrMsg.length > 0)
            {
                DevExpress.ui.dialog.alert(ErrMsg, 'Upload Error..');
                return;
            }
            if (files[0].size > 524288000)
            {
                DevExpress.ui.dialog.alert("You Have Selected <b>" + formatBytes(files[0].size) + "</b> To Upload<br><b>Upto 500 MB Can Be Uploaded At Once<b>", 'Upload Error..');
                return;
            }
            Attached_FileName = files[0].name;
            ShowLoader("Uploading File", false);
            var formdata = new FormData($('#Common_DirectBrowse_Form').get(0));
            formdata.append('Help_Document_FileName', Attached_FileName);
            formdata.append('Help_Document_NameID', Attach_DocName_ID);
            formdata.append('Help_Byte_SessionName', AttachmentByteSessionVariable);
            formdata.append('Help_Post_Area_Name', "Help");
            formdata.append('Help_Post_Controller_Name', "Attachment");
            formdata.append('Help_REF_REC_ID', Attach_RefRecId);
            formdata.append('Help_REF_SCREEN', Attach_RefScreen);
