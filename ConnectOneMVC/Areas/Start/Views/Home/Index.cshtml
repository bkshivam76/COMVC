    async function DataGrid_OnContentReady(e, dropdown_component) {
        if (e.component.option("searchPanel.text") != null && e.component.option("searchPanel.text").length > 0) {
            if (e.component.totalCount() == 1) {
                await e.component.selectRowsByIndexes(0);
            }
        }
    }
    function HideAlert(alert) {
        setTimeout(function () {
            alert.hide();
        }, 2000);
    }
    function getUserLocation(PositionSuccessCallbackFn = null, component = null) {
        if (navigator.geolocation) {
            PositionSuccessCallbackFn = PositionSuccessCallbackFn == null ? showPosition : PositionSuccessCallbackFn;
            var options = {
                enableHighAccuracy: true,
                timeout: 5000,
                maximumAge: 0
            };
            navigator.geolocation.getCurrentPosition(function (position) { PositionSuccessCallbackFn(position, component) }, showPositionError, options);
        }
        else {
            HideLoader();
            DevExpress.ui.dialog.alert("Geolocation is not supported by this browser.", "Information");
        }
    }
    function showPosition(position, component = null) {
        $("#User_Position").val("Latitude: " + position.coords.latitude +
            "<br>Longitude: " + position.coords.longitude);
        console.log($("#User_Position").val())
    }
    function showPositionError(error) {
        var err = "";
        switch (error.code) {
            case error.PERMISSION_DENIED:
                err = "User denied the request for Geolocation."
                break;
            case error.POSITION_UNAVAILABLE:
                err = "Location information is unavailable."
                break;
            case error.TIMEOUT:
                err = "The request to get user location timed out."
                break;
            case error.UNKNOWN_ERROR:
                err = "An unknown error occurred."
                break;
        }
        if (err.length > 0) {
            DevExpress.ui.dialog.alert(err, "Information");
        }
        HideLoader();
    }
</script>
