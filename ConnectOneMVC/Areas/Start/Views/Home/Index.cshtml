    function DxGrid_KeyDown(e) {
        let isEditing = e.component.element().find(".dx-datagrid-rowsview td.dx-editor-cell.dx-focused").length > 0
        if (isEditing == false) {
            var selKey = e.component.getSelectedRowKeys();
            if (selKey != null && selKey.length > 0) {
                var currentKey = selKey[0];
                var index = e.component.getRowIndexByKey(currentKey);
                const rowsCount = e.component.getVisibleRows().length;
                const pageCount = e.component.pageCount();
                const pageIndex = e.component.pageIndex();
                const pageSize = e.component.pageSize();
                if (e.event.keyCode == 38) //up arrow
                {
                    e.handled = true;
                    index--;
                    if (index >= 0)
                    {
                        e.component.selectRowsByIndexes([index]);
                        e.component.getScrollable().scrollToElement(e.component.getRowElement(index))
                    }
                    else if (pageIndex > 0)
                    {
                        e.component.pageIndex(pageIndex - 1).done(function () {
                            e.component.selectRowsByIndexes([pageSize - 1]);
                            setTimeout(function ()
                            {
                                e.component.getScrollable().scrollToElement(e.component.getRowElement(pageSize - 1))
                            })
                        })
                    }
                    Event_PreventDefaultAndStopPropagation(e.event)
                }
                else if (e.event.keyCode == 40) // down arrow
                {
                    e.handled = true;
                    index++;
                    if (index <= rowsCount - 1)
                    {
                        e.component.selectRowsByIndexes([index]);
                        e.component.getScrollable().scrollToElement(e.component.getRowElement(index))
                    }
                    else if (pageIndex < pageCount - 1)
                    {
                        e.component.pageIndex(pageIndex + 1).done(function ()
                        {
                            e.component.selectRowsByIndexes([0]);
                            setTimeout(function () {
                                e.component.getScrollable().scrollToElement(e.component.getRowElement(0))
                            })
                        })
                    }
                    Event_PreventDefaultAndStopPropagation(e.event)
                }
            }
        }
    }
    async function DxGrid_IfRowIsPresent(GridInstance, key, keyField=null)
    {
        var rowPresentInDataSource = false;
        var rowPresentAfterFilter = false;
        var rowPresentInVisiblePage = false;
        var GridName = GridInstance.element()[0].id;
        var CombinedFilter = GridInstance.getCombinedFilter(true);
        var gridData = GetDataSourceItems(GridName, "dxDataGrid")
        if (keyField == null)
        {
            keyField = GetKeyFieldOfDataSource(GridName, "dxDataGrid")
        }
        var ifRowToSelectPresent = gridData.filter(x => x[keyField] == key)
        if (ifRowToSelectPresent != null && ifRowToSelectPresent.length > 0) {
            rowPresentInDataSource = true;
        }
        if (CombinedFilter) {
            var filteredData = await GridInstance
                .getDataSource()
                .store()
                .load({ filter: CombinedFilter })
            var ifRowToSelectPresent = filteredData.filter(x => x[keyField] == key)
            if (ifRowToSelectPresent != null && ifRowToSelectPresent.length > 0) {
                rowPresentAfterFilter = true
            }
            filteredData = null;
        }
        else {
            rowPresentAfterFilter = true
        }
        var visibleRows = GridInstance.getVisibleRows()
        var ifRowToSelectPresent = visibleRows.filter(x => x.rowType == "data" && x.key == key)
        if (ifRowToSelectPresent != null && ifRowToSelectPresent.length > 0) {
            rowPresentInVisiblePage = true;
        }
        if (rowPresentInVisiblePage && rowPresentAfterFilter == false)
        {
            rowPresentAfterFilter = true; // for compact column not able to get filtred data from ds due to unbound column
        }
        gridData = null;
        return [rowPresentInDataSource && rowPresentAfterFilter, rowPresentInVisiblePage]
    }
    async function DxGrid_RowSelectionTobeCheckedAfterAnyAction(e, expandedKey=null,keyToSelect=null, keyField = null)
    {
        var GridInstance = e.component;
        if (keyToSelect)
        {         
            if (expandedKey != null && keyToSelect != expandedKey)
            {
                if (GridInstance.isRowExpanded(expandedKey)) {
                    await GridInstance.collapseRow(expandedKey)
                }
            }
            GridInstance.clearSelection();
            await GridInstance.selectRows(keyToSelect)
        }
        var selectedRowKey = GridInstance.getSelectedRowKeys();
        if (selectedRowKey != null && selectedRowKey.length > 0) {
            var RowPresent = await DxGrid_IfRowIsPresent(GridInstance, selectedRowKey[0], keyField)
            if (RowPresent[0] == false) {
                if (expandedKey != null) {
                    await GridInstance.collapseRow(expandedKey)
                }
                GridInstance.clearSelection();
            }
            else
            {
                let pageIndexChange = GridInstance.option("CustomProp.pageIndexChange");
                let pageSizeChange = GridInstance.option("CustomProp.pageSizeChange");
                let groupRowExpanded = GridInstance.option("CustomProp.groupRowExpanded");
                let groupRowCollapsed = GridInstance.option("CustomProp.groupRowCollapsed");
                let adaptiveDetailRowExpanded = GridInstance.option("CustomProp.adaptiveDetailRowExpanded");
                if (pageIndexChange == true || pageSizeChange == true)
                {
                    if (expandedKey) {
                        if (GridInstance.isRowExpanded(expandedKey)) {
                            await GridInstance.collapseRow(expandedKey)
                            await GridInstance.selectRows(selectedRowKey)  //collapsing the row will shift the selection to collpased row 
                        }
                    }
                    if (pageIndexChange) {
                        //GridInstance.option("CustomProp.pageIndexChange", false);
                        if (RowPresent[1] == false) {
                            GridInstance.clearSelection();
                            ClearLeftPane(); ClearRightPane();
                        }
                        else {
                            await DxGrid_ScrollToView(GridInstance, selectedRowKey[0])
                        }
                    }
                    else if (pageSizeChange)
                    {
                        //GridInstance.option("CustomProp.pageSizeChange", false)
                        if (RowPresent[1] == false) {
                            await GridInstance.navigateToRow(selectedRowKey[0])
                        }
                        else {
                            await DxGrid_ScrollToView(GridInstance, selectedRowKey[0])
                        }
                    }
                }
                else if (groupRowExpanded || groupRowCollapsed || adaptiveDetailRowExpanded)
                {
                    //if (groupRowExpanded) { GridInstance.option("CustomProp.groupRowExpanded", false) }
                   // if (groupRowCollapsed) { GridInstance.option("CustomProp.groupRowCollapsed", false) }
                   // if (adaptiveDetailRowExpanded) { GridInstance.option("CustomProp.adaptiveDetailRowExpanded", false) }
                    if (RowPresent[1] == false)
                    {
                        if (expandedKey)
                        {
                            if (GridInstance.isRowExpanded(expandedKey))
                            {
                                await GridInstance.collapseRow(expandedKey)
                            }
                        }
                        GridInstance.clearSelection();
                    }
                }
                else if (RowPresent[1] == false) {
                    await GridInstance.navigateToRow(selectedRowKey[0])
                }
                else {
                    await DxGrid_ScrollToView(GridInstance, selectedRowKey[0])
                }
            }
        }
       
            GridInstance.option("CustomProp.pageIndexChange",false);
            GridInstance.option("CustomProp.pageSizeChange",false);
            GridInstance.option("CustomProp.groupRowExpanded",false);
            GridInstance.option("CustomProp.groupRowCollapsed",false);
            GridInstance.option("CustomProp.adaptiveDetailRowExpanded",false);
        
    }
    async function DxGrid_GetFilteredAndSortedData(e) {
        const grid = e.component;
        const filterExpr = grid.getCombinedFilter(true);
        const dataSource = grid.getDataSource();
        const loadOptions = dataSource.loadOptions();

       return await dataSource
            .store()
            .load({ filter: filterExpr, sort: loadOptions.sort, group: loadOptions.group })
    }
    function DxGrid_ScrollToView(GridInstance, key)
    {
        if (key == null || key.length == 0) { return; }  
        var contEle = (GridInstance.getScrollable().element())[0]
        var Rowele = GridInstance.getRowElement(GridInstance.getRowIndexByKey(key))
        setTimeout(function ()
        {
            var InView = isElementInView(Rowele[0], contEle)
            if (InView == false)
            {
                //GridInstance.getScrollable().scrollToElement(Rowele)
                Rowele[0].scrollIntoView({
                    behavior: 'auto',
                    block: 'center'
                });
                //GridInstance.navigateToRow(key)
            }
        }, 500)      
    }
    function DxGrid_flattenGroupedData(groups, level = 1)
    {
        const result = [];
        for (const g of groups)
        {
            // Add the key as its own row, with level
            result.push({ key: g.key, level });
            for (const item of g.items)
            {
                if (item.key && item.items)
                {
                    // Recurse deeper with level+1
                    result.push(...DxGrid_flattenGroupedData([item], level + 1));
                }
                else
                {
                    // Leaf item
                    result.push({ ...item});
                }
            }
        }
        return result;
    }
    function DxGrid_isGrouped(data)
    {
        return Array.isArray(data) && data.length > 0 &&
            typeof data[0] === "object" &&
            "items" in data[0] &&
            "key" in data[0];
    }
    function DxGrid_OnCellClick(e)
    {
        if (e.column && e.column.type && e.column.type == "adaptive") {
            if (e.component.isRowSelected(e.key) == false) {
                e.component.selectRows(e.key)
            }
        }
    }
