    async function DxGrid_GetSelectedExpandedRowDetails(e)
    {
        var visibleDataRows = [];
        var selectedRowKey = null;
        var expandedRowKey = null;
        var selectedRowindex = -1;
        var expandedRowindex = -1;   
        var keyField = GetKeyFieldOfDataSource(e.component.element()[0].id, "dxDataGrid")       
        var filteredsortedData = await DxGrid_GetFilteredAndSortedData(e);
        if (DxGrid_isGrouped(filteredsortedData))
        {
            filteredsortedData = DxGrid_flattenGroupedData(filteredsortedData)
        }   
        var visibleRows = e.component.getVisibleRows();
        if (visibleRows != null && visibleRows.length > 0)
        {
            visibleDataRows = visibleRows.filter(x => x.rowType == "data")
        }
        if (visibleDataRows != null && visibleDataRows.length > 0)
        {
            for (var i = 0; i < visibleDataRows.length; i++)
            {
                if (visibleDataRows[i].isExpanded != void 0 && visibleDataRows[i].isExpanded)
                {
                    expandedRowKey = visibleDataRows[i].key    
                    expandedRowindex = filteredsortedData.findIndex(x => x[keyField] == expandedRowKey)                   
                }
                if (visibleDataRows[i].isSelected != void 0 && visibleDataRows[i].isSelected)
                {
                    selectedRowKey = visibleDataRows[i].key   
                    selectedRowindex = filteredsortedData.findIndex(x => x[keyField] == selectedRowKey)
                }
                if (selectedRowindex > -1 && expandedRowindex > -1)
                {
                    break;
                }
            }
        }
        return [selectedRowKey, selectedRowindex, expandedRowKey, expandedRowindex]
    }
