                                        }
                                    }
                                    else
                                    {
                                        var GridInstance = $("div[id = '" + NestedGridOnwhichAttachmentDone + "']").data("dxDataGrid")
                                        if (GridInstance !== void 0) {
                                            GridInstance.clearSelection();
                                        }
                                    }
                                }
                                if (GridOnwhichAttachmentDone == "CashBookListGrid")
                                {
                                    var GridInstance = $("div[id = 'CashBookListGrid']").data("dxDataGrid")
                                    if (GridInstance !== void 0)
                                    {
                                        Grid_Display_CB(null, true);
                                    }
                                    else
                                    {
                                        Grid_Display(null, true);
                                    }
                                }
                                else
                                {
                                    var GridInstance = $('#' + GridOnwhichAttachmentDone).data("dxDataGrid")
                                    if (GridInstance !== void 0) {
                                        GridInstance.refresh().done(function (data) { ActionAfterDataGridRefresh(data, GridInstance) });
                                    }
                                    else {
                                        ASPxClientControl.GetControlCollection().GetByName(GridOnwhichAttachmentDone).Refresh();
                                    }
                                }
                            }
                        });
                    }
                    else
                    {
                        DevExpress.ui.dialog.alert(data.Message, "Error");
                    }
                    $.ajax({
                        type: 'GET',
                        url: "/Help/Attachment/Sessionclear?ByteSessionVariable=" + AttachmentByteSessionVariable,
                        cache: false
                    });
                },
                error: function (jqXHR, textStatus, errorThrown)
                {
                    HideLoader();
