    function ClearRightPane() {
        var Iframe = document.getElementById('RightPane_Iframe');
        var IframeDiv = document.getElementById('RightPane_div_Iframe');
        var ImageDiv = document.getElementById('RightPane_div_Img')
        var ImageTag = document.getElementById('RightPane_Img');
        ImageTag.src = "";
        Iframe.src = "about:blank";
        ImageTag.style.transform = 'rotate(360deg)';
        ImageTag.innerHTML = "";
        Iframe.innerHTML = "";
        IframeDiv.style.display = "none";
        ImageDiv.style.display = "none";
        Iframe = null;
        IframeDiv = null;
        ImageDiv = null;
        ImageTag = null;
    }
    function ClearLeftPane(message = "") {
        ClearAllReferences("LeftPane_Div_ClearReference");
        if (message.length == 0) {
            $("#LeftPane_Div_Content").html("<div class='WaterMarked'><span>Turn On Vouching Mode<br>Select A Grid Row<br>Document And Additional Info Will Be Loaded</span></div>");
        }
        else {
            $("#LeftPane_Div_Content").html("<div style='text-align:center;'><span style='font-size:larger'><b>" + message + "</b></span></div>");
        }
    }
    function CollapsePane(PaneToCollpase, PaneToExpand) {
        PaneToCollpase.Collapse(PaneToExpand);
    }
    function CloseRightPane() {
        if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == false) {
            CollapsePane(Mainspliter.GetPaneByName('RightPane'), Mainspliter.GetPaneByName('MiddlePane'));
        }
    }
    function CloseLeftPane() {
        if (Mainspliter.GetPaneByName('LeftPane').IsCollapsed() == false) {
            CollapsePane(Mainspliter.GetPaneByName('LeftPane'), Mainspliter.GetPaneByName('MiddlePane'));
        }
    }
    function OpenRightPane() {
        if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == true) {
            Mainspliter.GetPaneByName('RightPane').Expand();
        }
    }
    function OpenLeftPane() {
        if (Mainspliter.GetPaneByName('LeftPane').IsCollapsed() == true) {
            Mainspliter.GetPaneByName('LeftPane').Expand();
        }
    }
    function OpenBottomRightPane()
    {
        if (Mainspliter.GetPaneByName('RightPane').IsCollapsed() == true)
        {
            Mainspliter.GetPaneByName('RightPane').Expand();
        }
        if (Mainspliter.GetPaneByName('BottomRightPane').IsCollapsed() == true)
        {
            Mainspliter.GetPaneByName('BottomRightPane').Expand();
        }
    }
    function CloseBottomRightPane()
    {
        if (Mainspliter.GetPaneByName('BottomRightPane').IsCollapsed() == false)
        {
            CollapsePane(Mainspliter.GetPaneByName('BottomRightPane'), Mainspliter.GetPaneByName('TopRightPane'));
        }
    }
    function ClearBottomRightPane() {
        var Iframe = document.getElementById('BottomRightPane_Iframe');
        var IframeDiv = document.getElementById('BottomRightPane_div_Iframe');
        var ImageDiv = document.getElementById('BottomRightPane_div_Img')
        var ImageTag = document.getElementById('BottomRightPane_Img');
        ImageTag.src = "";
        Iframe.src = "about:blank";
        ImageTag.style.transform = 'rotate(360deg)';
        ImageTag.innerHTML = "";
        Iframe.innerHTML = "";
        IframeDiv.style.display = "none";
        ImageDiv.style.display = "none";
        Iframe = null;
        IframeDiv = null;
        ImageDiv = null;
        ImageTag = null;
    }
    function LoadDocumentAndAdditionalInfoInLeftPane(AreaName, ControllerName, FunctionName, RecID, _VouchingMode, _MID = "") {
        ShowLoader("Document Grid");
        ClearLeftPane("Document And Additional Info<br>Grid Is Loading...<br>Please Wait");
        var URL = "/" + AreaName + "/" + ControllerName + "/" + FunctionName;
        $.ajax({
            type: 'GET',
            url: URL,
            cache: false,
            data:
            {
                ID: RecID,
                VouchingMode: _VouchingMode,
                MID: _MID
            },
            success: function (data) {
                $("#LeftPane_Div_Content").html(data);
                HideLoader();
            }
        });
    }

    function CheckIfVoucherAllowed()
    {
        if (AllowedUsersForVouchers.includes(_open_User_ID.toLowerCase()))
        {
            return true;
        }
        if (LoginUserType.toLowerCase() == "superuser")
        {
            return true;
        }
        return false;
    }
    var Voucher_AllowedUser = CheckIfVoucherAllowed();
    var Voucher_CDW_Allow_AEDV = true;
    var Voucher_B2B_Allow_AEDV = true;
    var Voucher_CBox_Allow_AEDV = true;
    var Voucher_FD_Allow_AEDV = true;
    var Voucher_ITrf_Allow_AEDV = true;
    var Voucher_DonR_Allow_AEDV = true;
    var Voucher_DonF_Allow_AEDV = true;
    var Voucher_Payment_Allow_AEDV = true;
    var Voucher_Receipt_Allow_AEDV = true;
    var Voucher_SaleAsset_Allow_AEDV = true;
    var Voucher_AssetTransfer_Allow_AEDV = true;
    var Voucher_WIP_Allow_AEDV = true;
    var Voucher_JV_Allow_AEDV = true;
    var Voucher_DonationKind_Allow_AEDV = true;
    var Voucher_NoteBook_Allow_AEDV = true;
    var Voucher_Membership_Allow_AEDV = true;
    var Voucher_Membership_Renewal_Allow_AEDV = false;
    var Voucher_Membership_Conversion_Allow_AEDV = false;


</script>
@* Pane *@
<script>
    var ImageRotateAngle = 0;
    function ViewDocument(AttachmentID = null, FileName = null, FAB_Name = null, FAB_Context = null, Iframe = null, ImageTag = null, IframeDiv = null, ImageDiv = null, Pane = null, viaPopup = false, ImageDivToolbar = null)
    {
        ShowLoader();
        if (FileName == null || FileName.length == 0)
        {
            DevExpress.ui.dialog.alert("No Document Selected To View..", "Information..");
            return;
        }
        if (Iframe == null)
        {
            Iframe = document.getElementById('RightPane_Iframe');
        }
        if (ImageTag == null)
        {
            ImageTag = document.getElementById('RightPane_Img');
        }
        if (IframeDiv == null)
        {
            IframeDiv = document.getElementById('RightPane_div_Iframe');
        }
        if (ImageDiv == null)
        {
            ImageDiv = document.getElementById('RightPane_div_Img')
        }
        if (Pane == null)
        {
            Pane = Mainspliter.GetPaneByName('RightPane');
        }
        var ImageToolBarDiv = $('#RightPane_div_Img_ToolBar');
        if (ImageDiv.id == "BottomRightPane_div_Img")
        {
            ImageToolBarDiv =$('#BottomRightPane_div_Img_ToolBar');
        }
        var Path = "";
        var MimeType = "";
        var protocol = window.location.protocol;
        var hostname = window.location.host;
        var CustomFileName = "";
        var filename = FileName.split(".");
        HideLoader();
        if (isMobile)
        {
            Path = StandardizeCallURL(protocol + "//" + hostname + "/Help/Attachment/Frm_Attachment_ViewFile?ID=" + AttachmentID);
            window.open(Path);
        }
        else
        {
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Start/DocumentChecking/GetFileMimeType",
                cache: false,
                data:
                {
                    FileName: FileName
                },
                success: function (data)
                {
                    HideLoader();
                    MimeType = data.mimeType
                    for (var i = 0; i < filename.length; i++)
                    {
                        if (i == 0)
                        {
                            CustomFileName = AttachmentID;
                        }
                        if ((i == (filename.length - 1)) && i != 0)
                        {
                            CustomFileName = CustomFileName + "." + filename[i];
                        }
                    }
                    Path = protocol + "//" + hostname + "/Attachments/" + CustomFileName + "?" + performance.now();
                    //Path = "D:/Attachments/"+CustomFileName +  "?"  + performance.now();
                    if (viaPopup == false)
                    {
                        Pane.Expand();
                        if (ImageDiv.id == "BottomRightPane_div_Img")
                        {
                            OpenBottomRightPane();
                        }
                        ImageRotateAngle = 0;
                        ImageTag.src = "";
                        Iframe.src = "about:blank";
                        ImageTag.style.transform = 'rotate(360deg)';
                        IframeDiv.style.display = "none";
                        ImageDiv.style.display = "none";
                        if (MimeType.includes("image"))
                        {
                            ShowLoader("Attachment");
                            var Url = StandardizeCallURL('@Url.Action("ImageToolButtons", "AuditButton", new { @area = "" })?ViaPopup=' + false + "&ImgTag=" + ImageTag.id);
                            $(ImageToolBarDiv).show();
                            $(ImageToolBarDiv).html("");
                            $(ImageToolBarDiv).load(Url);
                            $(ImageToolBarDiv).hide();
                            IframeDiv.style.display = "none";
                            ImageDiv.style.display = "grid";
                            ImageDiv.style.height = "100%";
                            dragElement(ImageTag);
                            ImageTag.src = Path;
                            ImageTag.style.maxWidth = "100%";
                            ImageTag.style.maxHeight = "97vh";
                            ImageTag.style.height = "100%"
                            ImageTag.style.width = "100%"
                            CheckImageload();
                            function CheckImageload()
                            {
                                if (ImageTag.complete)
                                {
                                    HideLoader();
                                }
                                else
                                {
                                    setTimeout(function ()
                                    {
                                        CheckImageload();
                                    }, 100);
                                }
                            }
                            ImageTag.onmousedown = function ()
                            {
                                if (FAB_Name != null)
                                {
                                    if (ASPxClientControl.GetControlCollection().GetByName(FAB_Name) != null)
                                    {
                                        if (typeof ASPxClientControl.GetControlCollection().GetByName(FAB_Name) !== 'undefined')
                                        {
                                            ASPxClientControl.GetControlCollection().GetByName(FAB_Name).SetVisible(true);
                                            ASPxClientControl.GetControlCollection().GetByName(FAB_Name).SetActionContext(FAB_Context, true);
                                            ASPxClientControl.GetControlCollection().GetByName(FAB_Name).ExpandActionGroupItems();
                                        }
                                        else
                                        {
                                            $(ImageToolBarDiv).show();
                                        }
                                    }
                                    else
                                    {
                                        $(ImageToolBarDiv).show();
                                    }
                                }
                                else
                                {
                                    $(ImageToolBarDiv).show();
                                }
                            };
                            ImageTag.onwheel = function (event)
                            {
                                var y = event.deltaY;
                                if (y > 0)
                                {
                                    ImageZoomOut(ImageTag);
                                }
                                else if (y < 0)
                                {
                                    ImageZoomIn(ImageTag);
                                }
                            };
                        }
                        else
                        {
                            IframeDiv.style.display = "block";
                            ImageDiv.style.display = "none";
                            setTimeout(function ()
                            {
                                Iframe.src = Path;
                            }, 100);
                        }
                    }
                    else
                    {
                        $("#AttachmentView_popup").dxPopup("instance").show();
                        Iframe = document.getElementById('AttachmentPopup_Iframe');
                        ImageTag = document.getElementById('AttachmentPopup_Img');
                        IframeDiv = document.getElementById('AttachmentPopup_div_Iframe');
                        ImageDiv = document.getElementById('AttachmentPopup_div_Img');
                        ImageRotateAngle = 0;
                        ImageTag.src = "";
                        Iframe.src = "about:blank";
                        ImageTag.style.transform = 'rotate(360deg)';
                        IframeDiv.style.display = "none";
                        ImageDiv.style.display = "none";
                        $("#AttachmentPopup_div_Img_ToolBar").hide();
                        var Url = StandardizeCallURL('@Url.Action("ImageToolButtons", "AuditButton", new { @area = "" })?ViaPopup=' + true+ "&ImgTag=" + ImageTag.id);
                        $("#AttachmentPopup_div_Img_ToolBar").load(Url);
                        if (MimeType.includes("image"))
                        {
                            ShowLoader("Attachment");
                            IframeDiv.style.display = "none";
                            ImageDiv.style.display = "grid";
                            ImageDiv.style.height = "100%";
                            dragElement(ImageTag);
                            ImageTag.src = Path;
                            ImageTag.style.maxWidth = "100%";
                            ImageTag.style.maxHeight = "97%";
                            ImageTag.style.height = "100%"
                            ImageTag.style.width = "100%"
                            CheckImageload_Popup();
                            function CheckImageload_Popup()
                            {
                                if (ImageTag.complete)
                                {
                                    HideLoader();
                                }
                                else
                                {
                                    setTimeout(function ()
                                    {
                                        CheckImageload_Popup();
                                    }, 100);
                                }
                            }
                            ImageTag.onmousedown = function ()
                            {
                                if (FAB_Name != null)
                                {
                                    if (ASPxClientControl.GetControlCollection().GetByName(FAB_Name) != null)
                                    {
                                        if (typeof ASPxClientControl.GetControlCollection().GetByName(FAB_Name) !== 'undefined')
                                        {
                                            $("#AttachmentPopup_div_Img_ToolBar").hide();
                                            ASPxClientControl.GetControlCollection().GetByName(FAB_Name).SetActionContext(FAB_Context, true);
                                        }
                                        else
                                        {
                                            $("#AttachmentPopup_div_Img_ToolBar").show();
                                        }
                                    }
                                    else
                                    {
                                        $("#AttachmentPopup_div_Img_ToolBar").show();

                                    }
                                }
                                else
                                {
                                    $("#AttachmentPopup_div_Img_ToolBar").show();
                                }
                            };
                            ImageTag.onwheel = function (event)
                            {
                                var y = event.deltaY;
                                if (y > 0)
                                {
                                    ImageZoomOut(ImageTag);
                                }
                                else if (y < 0)
                                {
                                    ImageZoomIn(ImageTag);
                                }
                            };
                        }
                        else
                        {
                            IframeDiv.style.display = "block";
                            ImageDiv.style.display = "none";
                            setTimeout(function ()
                            {

                                Iframe.src = Path;

                            }, 100);
                        }
                    }
                }
            });
        }
    }
    function ImageRotate(ImageTag) {
        if (ImageTag == null) {
            ImageTag = document.getElementById('RightPane_Img');
        }
        ImageRotateAngle += 90;
        ImageTag.style.transform = 'rotate(' + ImageRotateAngle + 'deg)';
    }
    function ImageZoomOut(ImageTag) {
        if (ImageTag == null) {
            ImageTag = document.getElementById('RightPane_Img');
        }
        var currWidth = ImageTag.clientWidth;
        var currHeight = ImageTag.clientHeight;
        ImageTag.style.width = (currWidth - 100) + "px";
        ImageTag.style.height = (currHeight - 100) + "px";
    }
    function ImageZoomIn(ImageTag) {
        if (ImageTag == null) {
            ImageTag = document.getElementById('RightPane_Img');
        }
        var currWidth = ImageTag.clientWidth;
        var currHeight = ImageTag.clientHeight;
        ImageTag.style.maxWidth = "none";
        ImageTag.style.maxHeight = "none";
        ImageTag.style.width = (currWidth + 100) + "px";
        ImageTag.style.height = (currHeight + 100) + "px";
    }
    function ImageFit(ImageTag) {
        if (ImageTag == null) {
            ImageTag = document.getElementById('RightPane_Img');
        }
        ImageTag.style.maxWidth = "100%";
        ImageTag.style.maxHeight = "97vh";
        ImageTag.style.height = "100%"
        ImageTag.style.width = "100%"
    }
    function ImageBack(FAB_Name = null, FAB_Context = null) {
        ASPxClientControl.GetControlCollection().GetByName(FAB_Name).SetActionContext(FAB_Context, true);
    }
    function ImageTools_buttonGroup_Click(e, imgTagID)
    {
        var btn = e.itemData.item;

        if (btn == "ZoomOut") {
            ImageZoomOut(document.getElementById(imgTagID));
        }
        else if (btn == "ZoomIn") {
            ImageZoomIn(document.getElementById(imgTagID));
        }
        else if (btn == "Rotate") {
            ImageRotate(document.getElementById(imgTagID));
        }
        else if (btn == "Fit") {
            ImageFit(document.getElementById(imgTagID));
        }
        else if (btn == "ZoomOut_Popup")
        {
            ImageZoomOut(document.getElementById('AttachmentPopup_Img'));
        }
        else if (btn == "ZoomIn_Popup") {
            ImageZoomIn(document.getElementById('AttachmentPopup_Img'));
        }
        else if (btn == "Rotate_Popup") {
            ImageRotate(document.getElementById('AttachmentPopup_Img'));
        }
        else if (btn == "Fit_Popup") {
            ImageFit(document.getElementById('AttachmentPopup_Img'));
        }
    }

</script>
@* View Documents *@
<script>
    var AttachmentByteSessionVariable = "HelpDocument";
    var GridOnwhichAttachmentDone;
    var NestedGridOnwhichAttachmentDone;
    function AddAttachment(RefRecID, RefScreen, DocumentName, DocumentCategory, ParamMandatory, FromDateLabel, ToDateLabel, DescriptionLabel, ByteSessionVariable = null, PostSuccessFunctionName = null, GridName = null, NestedGridName = null)
    {
        if ("@AttachmentAddRight" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
            return;
        }
        ByteSessionVariable = ByteSessionVariable == null ? "HelpDocument" : ByteSessionVariable;
        AttachmentByteSessionVariable = ByteSessionVariable;
        PostSuccessFunctionName = PostSuccessFunctionName == null ? "AttachmentSuccess" : PostSuccessFunctionName;
        GridOnwhichAttachmentDone = GridName;
        NestedGridOnwhichAttachmentDone = NestedGridName;
        $("#ID_Frm_Help_Document_Attach").remove();
        ShowLoader();
        $.ajax({

            type: 'GET',
            //async: false,
            url: "/Help/Attachment/Frm_Attachment_Window",
            cache: false,
            data:
            {
                AM: "New",
                PostSucessFunctionName: PostSuccessFunctionName,
                Refrecid: RefRecID,
                RefScreen: RefScreen,
                DocumentName: DocumentName,
                DocumentCategory: DocumentCategory,
                ParamMandatory: ParamMandatory,
                FromDate_Label: FromDateLabel,
                ToDate_Label: ToDateLabel,
                Description_Label: DescriptionLabel,
                ByteSessionVariable: ByteSessionVariable
            },
            success: function (data)
            {
                OpenPopup("Dynamic_Content_popup", "Add ~ Attachment", null, "auto", 1000, true, data);
            }
        });
    }
    function EditAttachment(RefRecID, RefScreen, AttachmentID, ParamMandatory, FromDateLabel, ToDateLabel, DescriptionLabel, ByteSessionVariable = null, PostSuccessFunctionName = null, GridName = null, NestedGridName = null)
    {
        if ("@AttachmentUpdateRight" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed", "No Rights");
            return;
        }
