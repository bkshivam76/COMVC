<script>
    function AttachmentAddEditClick(e, UniqueIdentifier, ActionMethod) {
        $("#AttachmentsPopup_" + UniqueIdentifier).dxPopup("show");
        var galleryImagesCount = document.getElementById("galleryContainer_" + UniqueIdentifier).childElementCount;
        if (ActionMethod.includes("New")) {
            if (galleryImagesCount == 0) {
                UploadFiles(UniqueIdentifier);
            }
        }
        if (ActionMethod.includes("Edit")) {
            if (galleryImagesCount == 0 && (window["Saved_Attachment_" + UniqueIdentifier] == null || window["Saved_Attachment_" + UniqueIdentifier].length == 0)) {
                UploadFiles(UniqueIdentifier);
            }
        }
    }
    function AttachmentsPopup_onhiding(e, UniqueIdentifier) {
        UpdateAttachedFileNames(UniqueIdentifier)
    }
    function AttachmentsPopup_DoneClick(e, UniqueIdentifier) {
        $("#AttachmentsPopup_" + UniqueIdentifier).dxPopup("hide");
    }
    function UpdateAttachedFileNames(UniqueIdentifier) {
        var filename = "";
        var gallery = $("#galleryContainer_" + UniqueIdentifier + " a")
        for (var i = 0; i < gallery.length; i++) {
            if (i == 0) {
                filename = $(gallery[i]).data("filename")
            }
            else {
                filename = filename + ", " + $(gallery[i]).data("filename")
            }
        }
        $("#span_FileName_" + UniqueIdentifier).text(filename)
    }
    function AttachmentsOnValueChange(e, UniqueIdentifier, Rec_ID = "", RefScreen = "") {
        var UploadControlID = "#myFile_" + UniqueIdentifier;
        if (window["fromRemovefile_" + UniqueIdentifier] == false) {
            var files = e.value;
            var FilesSelectedCount = files.length;
            if (FilesSelectedCount > 50) {
                DevExpress.ui.dialog.alert("You Have Selected " + FilesSelectedCount + " Files To Upload<br><b>More Than 50 Files Cannot Be Uploaded At Once<b>", 'Upload Error..');
                $(UploadControlID).dxFileUploader("reset");
                return;
            }
            if (files.length > 0) {
                var totalContent = 0;
                var NotAllowedFilePresent = false;
                var filenames = "";
                var err_msg = "";
                for (var i = 0; i < files.length; i++) {
                    var ErrMsg = PreventFileUpload(files[i])
                    if (ErrMsg != null && ErrMsg.length > 0) {
                        NotAllowedFilePresent = true;
                        err_msg = err_msg + ErrMsg;
                        break;
                    }
                    else {
                        totalContent = totalContent + files[i].size
                        filenames = filenames + files[i].name
                    }
                }
                if (totalContent > 524288000) {
                    DevExpress.ui.dialog.alert("You Have In Total Selected <b>" + formatBytes(totalContent) + "</b> To Upload<br><b>Upto 500 MB Can Be Uploaded At Once<b>", 'Upload Error..');
                    totalContent = 0;
                    $(UploadControlID).dxFileUploader("reset");
                    return;
                }
                if (NotAllowedFilePresent == true) {
                    DevExpress.ui.dialog.alert(err_msg, 'Upload Error..');
                    $(UploadControlID).dxFileUploader("reset");
                    return;
                }
            }
            insertImages(e.value, e.previousValue, "", UniqueIdentifier, Rec_ID, RefScreen)
        }
        window["fromRemovefile_" + UniqueIdentifier] = false;
    }
    function insertImages(value = null, prevValue = null, Action = "", UniqueIdentifier = "", Rec_ID = "", RefScreen = "") {
        var NewlyaddedFiles = [];
        var Saved_Attachment_VariableName = "Saved_Attachment_" + UniqueIdentifier;
        var gallery = $("#galleryContainer_" + UniqueIdentifier + " a")
        if (Action == "EditLoad") //Creating Gallery for images coming from db in edit mode
        {
            NewlyaddedFiles = window[Saved_Attachment_VariableName];
            if (NewlyaddedFiles != null) {
                var i = 0
                for (i = 0; i < NewlyaddedFiles.length; i++) {
                    createGallery(NewlyaddedFiles[i].Attachment_Path, NewlyaddedFiles[i].Attachment_FileName, NewlyaddedFiles[i].Attachment_Type, NewlyaddedFiles[i].Attachment_Description, NewlyaddedFiles[i].Attachment_ID, UniqueIdentifier, Rec_ID, RefScreen)
                }
            }
        }
        else {
            if (value == null || value.length == 0) //remove all chosen files keeping those coming from db
            {
                var i = 0;
                if (window[Saved_Attachment_VariableName] != null && window[Saved_Attachment_VariableName].length > 0) {
                    i = window[Saved_Attachment_VariableName].length;
                }
                if (i > 0) {
                    ($(gallery).eq(i - 1)).nextAll().remove();
                }
                else {
                    $(gallery).remove();
                }
            }
            else {
                NewlyaddedFiles = value.filter(function (obj) { return prevValue.indexOf(obj) == -1; });
                var i = 0
                for (i = 0; i < NewlyaddedFiles.length; i++) {
                    createGallery(window.URL.createObjectURL(NewlyaddedFiles[i]), NewlyaddedFiles[i].name, NewlyaddedFiles[i].type, "", "", UniqueIdentifier, Rec_ID, RefScreen)
                }
            }
        }
    }
    function createGallery(fileURL, fname, ftype, fdescription = "", AttachmentID = "", UniqueIdentifier = "", Rec_ID = "", RefScreen = "") {
        //attach display
        var new_a = document.createElement("a")
        window["Attachments_Srno_" + UniqueIdentifier]++;
        new_a.id = "Attach_" + UniqueIdentifier + "_" + window["Attachments_Srno_" + UniqueIdentifier];
        new_a.setAttribute("data-FileName", fname);
        if (AttachmentID != null && AttachmentID.length > 0) {
            new_a.setAttribute("data-AttachmentID", AttachmentID);
        }
        var new_img;
        if (ftype.includes("video") || ftype.includes("mp4")) {
            new_img = document.createElement("video")
            new_img.src = fileURL;
        }
        else if (ftype.includes("pdf")) {
            new_img = document.createElement("img")
            new_img.src = "/Content/Events/images/pdficon.jpg";
        }
        else if (ftype.includes("document")) {
            new_img = document.createElement("img")
            new_img.src = "/Content/Events/images/docxicon.png";
        }
        else if (ftype.includes("image") || ftype.includes("jpeg") || ftype.includes("png")) {
            new_img = document.createElement("img")
            new_img.src = fileURL;
        }
        else {
            new_img = document.createElement("img")
            new_img.src = fileURL;
        }
        new_a.appendChild(new_img)
        //caption
        var new_input = document.createElement("textarea")
        new_input.className = "form-control"
        new_input.classList.add("newcaption");
        new_input.placeholder = "Caption..."
        if (fdescription != null && fdescription.length > 0) {
            new_input.value = fdescription
        }
        if (AttachmentID != null && AttachmentID.length > 0) {
            new_input.readOnly = true;
        }
        new_a.appendChild(new_input)
        //delete button
        var new_i = document.createElement("i")
        new_i.className = "bx bxs-trash"
        new_i.role = "button"
        new_i.setAttribute("onclick", "remove_file('" + new_a.id + "','" + fname + "','" + UniqueIdentifier + "','" + Rec_ID + "','" + RefScreen + "')")
        new_a.appendChild(new_i)
        document.getElementById("galleryContainer_" + UniqueIdentifier).appendChild(new_a)
    }
    function remove_file(Gallery_id, file_name, UniqueIdentifier, Rec_ID, RefScreen) {
        window["fromRemovefile_" + UniqueIdentifier] = true;
        var Gallery_a_element = document.getElementById(Gallery_id);
        var Deletedindex = $("#galleryContainer_" + UniqueIdentifier + " a").index(Gallery_a_element);
        if (Gallery_a_element.hasAttribute('data-AttachmentID')) {
            var AttachmentID = Gallery_a_element.getAttribute('data-AttachmentID')
            remove_filefromdb(AttachmentID, Rec_ID, file_name, RefScreen).done(function (data) {
                if (data.result == true) {
                    Gallery_a_element.remove();
                    window["Saved_Attachment_" + UniqueIdentifier].splice(Deletedindex, 1)
                }
                else {
                    DevExpress.ui.dialog.alert(data.Message, "Information")
                }
                window["fromRemovefile_" + UniqueIdentifier] = false;
            })
        }
        else {
            Gallery_a_element.remove();
            ($("#myFile_" + UniqueIdentifier + " .dx-fileuploader-cancel-button").eq(Deletedindex)).click();
        }
    }
    function remove_filefromdb(_AttachmentID, _RefRecID, _file_name, _RefScreen) {
        return $.ajax({
            url: "/Base/Unlink_OR_Delete_Attachment",
            type: "get",
            data:
            {
                'AttachmentID': _AttachmentID,
                'RefRecID': _RefRecID,
                'file_name': _file_name,
                'RefScreen': _RefScreen
            }
        });
    }
    function UploadFiles(UniqueIdentifier) {
        document.getElementById("myFile_" + UniqueIdentifier).getElementsByClassName('dx-fileuploader-button')[0].click();
    }
</script>
