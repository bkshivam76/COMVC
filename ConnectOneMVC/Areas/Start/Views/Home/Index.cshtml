    // Menu Keyboard arrow keys navigation javascript (by bk pritam)
    $('.dropdown').on('show.bs.dropdown keydown focus', function (e)
    {
        var focusable, currFocused, nextFocusable, focusableParent, navParent, navItem, focusedNavItem, nextNavItem;
        if ($('.dropdown li:visible > a:focus').length == 0) {
            focusableParent = $('li:visible > a:visible').closest('.dropdown-menu');
        } else {
            focusableParent = $('li:visible > a:focus').closest('.dropdown-menu');
        }
        focusable = $('li:visible > a:visible', focusableParent);
        currFocused = $('li > a:focus', focusableParent);

        navParent = $('li:visible > button:visible').closest('.navbar-nav');
        navItem = $('li:visible > button:visible', navParent);
        focusedNavItem = $('li > button:focus', navParent);

        if (e.keyCode == 39)//right arrow functionality for nav main item focus
        {
            if (navItem.is(':focus')) {
                nextNavItem = navItem.eq(navItem.index(focusedNavItem[0]) + 1);
                ShowHideNavBar(focusedNavItem, nextNavItem)
            }
            if (navItem.index(focusedNavItem) == navItem.length - 1) {
                nextNavItem = navItem.eq(0);
                ShowHideNavBar(focusedNavItem, nextNavItem)
            }
        }
        if (e.keyCode == 37)//left arrow functionality for nav main item focus
        {
            if (navItem.is(':focus')) {
                nextNavItem = navItem.eq(navItem.index(focusedNavItem[0]) - 1);
                ShowHideNavBar(focusedNavItem, nextNavItem)
            }
            if (navItem.index(focusedNavItem) == navItem[0]) {
                nextNavItem = navItem.eq(focusable.length - 1);
                ShowHideNavBar(focusedNavItem, nextNavItem)
            }
        }
        if (e.keyCode == 40) //down arrow functionality for menu items navigation
        {
            if (currFocused.length == 0) {
                nextFocusable = focusable.eq(0);
            }
            else if (focusable.index(currFocused) == focusable.length - 1) {
                nextFocusable = focusable.eq(0);
            }
            else {
                nextFocusable = focusable.eq(focusable.index(currFocused[0]) + 1);
            }
            if (nextFocusable.length >= 0) {
                setTimeout(function () {
                    nextFocusable.focus();
                })
            }
        }

        if (e.keyCode == 38) //up arrow functionality for menu items navigation
        {
            if (currFocused.length == 0) {
                nextFocusable = focusable.eq(focusable.length - 1);
            }
            else {
                nextFocusable = focusable.eq(focusable.index(currFocused[0]) - 1);
            }
            if (nextFocusable.length) {
                if (focusable.eq(0).is(':focus') && focusableParent.hasClass('show')) {
                    focusableParent.prev('button').focus()
                }
                else {
                    nextFocusable.focus();
                }
            }
        }
        else if (e.keyCode == 39 || e.keyCode == 37 || e.keyCode == 13) //right left arrow, enter functionality for submenu opening & closing
        {
            if ($(currFocused[0]).hasClass("dropdown-toggle")) {
                if (e.keyCode == 39)//right arrow
                {
                    $(currFocused[0]).parent().addClass("open")
                    setTimeout(function () {
                        $($(currFocused[0]).next().find("a:visible")[0]).focus();
                    })
                }
                if (e.keyCode == 13)//enter
                {
                    setTimeout(function () {
                        $($(currFocused[0]).next().find("a:visible")[0]).focus();
                    })
                }

                if (e.keyCode == 37)//left arrow
                {
                    $(currFocused[0]).closest('.dropdown-submenu').removeClass("open").find("> .dropdown-toggle").focus();
                }
            }

            if ($('.dropdown-submenu').hasClass("open")) {
                if (e.keyCode == 37)//left arrow
                {
                    $(currFocused[0]).closest('.dropdown-submenu').removeClass("open").find("> .dropdown-toggle").focus();
                }
            }
        }

        if (e.keyCode == 33) { //pageup key
            focusable.eq(0).focus();
        }
        if (e.keyCode == 34) { //pagedown key
            focusable.eq(focusable.length - 1).focus();
        }

        if (["Space", "ArrowUp", "ArrowDown", "ArrowLeft", "ArrowRight", "Escape", "PageUp", "PageDown"].indexOf(e.code) > -1) { //this code is to stop the scrolling of the background page on pressing these keys, escape to prevent native bootstrap shortcut of closing and opening menu
            e.preventDefault();
            e.stopPropagation();
        }
    })
    function ShowHideNavBar(CurrentNav, NextNav) {
        NextNav.focus().trigger('click');
        NextNav.parent().addClass('show');
        NextNav.next().addClass('show').show();
        CurrentNav.parent().removeClass('show');
        CurrentNav.next().removeClass('show').hide();
        CurrentNav.blur();
    }
