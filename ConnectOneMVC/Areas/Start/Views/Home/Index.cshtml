<script>
    function DxGrid_AttachmentIcons(ReqAttachCount, CompleteAttachCount, RespondedCount, RejectedCount, OtherCount, AllCount) {
        var htmlString = "";
        var src = "data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7";
        var TotalResponse = CompleteAttachCount + RespondedCount
        if (TotalResponse == 0 && ReqAttachCount > 0) {
            htmlString += "<img class='imagesprite attach_red_2' title='Attachment Status : Pending' src='" + src + "' alt=''>"
        }
        else if (TotalResponse > 0 && TotalResponse < ReqAttachCount) {
            htmlString += "<img class='imagesprite attach_yellow_2' title='Attachment Status : Partial' src='" + src + "' alt=''>"
        }
        else if (TotalResponse >= ReqAttachCount && ReqAttachCount > 0 && RespondedCount == 0) {
            htmlString += "<img class='imagesprite attach_green_2' title='Attachment Status : Complete' src='" + src + "' alt=''>"
        }
        else if (TotalResponse >= ReqAttachCount && ReqAttachCount > 0 && RespondedCount > 0) {
            htmlString += "<img class='imagesprite completed_with_remarks' title='Attachment Status : Complete but With Remarks' src='" + src + "' alt=''>"
        }
        if (RejectedCount > 0) {
            htmlString += "<div><img class='imagesprite rejected_attachment' title='Entry has " + RejectedCount + " Rejected Attachments' src='" + src + "' alt=''></div>"
        }
        if (AllCount > 0) {
            var cssClass = "imagesprite";
            if (OtherCount == 0) {
                cssClass += " attach_normal";
            }
            else {
                cssClass += " attach_other_plus";
            }
            htmlString += "<div><img class='" + cssClass + "' title='Total Attachmnets:" + AllCount + "\r Non-Recommended Attachments:" + OtherCount + "' src='" + src + "' alt=''></div>"
        }
        return htmlString;
    }
    function DxGrid_VouchingAuditIcons(iIcon) {
