                    //        console.log(percentComplete);
                    //    }
                    //}, false);

                    return xhr;
                },
                type: 'POST',
                url: "/Help/Attachment/Frm_Attachment_Window",
                cache: false,
                data: formdata,
                processData: false,
                contentType: false,
                success: function (data)
                {
                    HideLoader();
                    if (data.result)
