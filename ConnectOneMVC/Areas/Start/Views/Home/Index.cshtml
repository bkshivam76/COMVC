    // window keydown capture phase
    ASPxClientUtils.AttachEventToElement(window, "keydown", function (evt)
    {
        console.log(evt.key);
        LastKeyDown = evt.key;
        if (evt.altKey) //prevent default of alt
        {
            ASPxClientUtils.PreventEvent(evt)
        }
        if (Check_keydownEventRepeat(evt) == false) {
            var key = convertUpperCaseToLowerForKeysPressed(evt)
            AllKeysDownStatus[key] = true;
            if (evt.altKey) //adding class to body to detect alt press
            {
                $('body').addClass('alt_active');
                if (AltActiveTimeout) {
                    clearTimeout(AltActiveTimeout)
                }
                AltActiveTimeout=setTimeout(function () {
                    $('body').removeClass('alt_active');
                }, 5000);
            }
            if (evt.keyCode == 27) //escape press
            {
                ASPxClientUtils.PreventEvent(evt)
                if ($('.dropdown').hasClass('show')) // hide menu dropdown on escape press
                {
                    $('.dropdown, .dropdown-menu').removeClass('show');
                    $('.dropdown-menu').hide('fast');
                    $('.dropdown-toggle').blur()
                }
                else if ($(".dx-popup-wrapper").length == 0) { // escape press close active tab
                    $(".TabPanalMenu-tabs .active span").trigger("click")
                }
                if ($(".dx-popup-wrapper").length != 0 && (document.activeElement.type == "text" || (document.activeElement.hasAttribute("role") && document.activeElement.getAttribute("role") == "button"))) {
                    $(".dx-popup").each(function () {
                        if (this.id.length > 0) //removing focus from input element and setting on popup
                        {
                            try {
                                $("#" + this.id).dxPopup("focus")
                            }
                            catch (err) { }
                        }
                    });
                    ASPxClientUtils.PreventEventAndBubble(evt)
                }
            }
            if (evt.ctrlKey && evt.shiftKey && evt.keyCode == 71) {
                $("#" + $(".tab-content .tab-pane.active .dxgvTable_MetropolisBlue").attr("id").split('_')[0]).focus()
                ASPxClientUtils.PreventEventAndBubble(evt);
            }
            if (evt.ctrlKey && evt.keyCode == 9 && $(".dx-popup-wrapper").length == 0) { // CTRL + tab
                ASPxClientUtils.PreventEventAndBubble(evt);
                $(".TabPanalMenu-tabs .active").next().find("a").trigger("click")
            }
            if (evt.ctrlKey && evt.shiftKey && evt.keyCode == 9 && $(".dx-popup-wrapper").length == 0) { // CTRL + Shift +tab
                ASPxClientUtils.PreventEventAndBubble(evt);
                $(".TabPanalMenu-tabs .active").prev().find("a").trigger("click")
            }
