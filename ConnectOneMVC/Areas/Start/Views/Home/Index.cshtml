<script>
    function AddressBook_Window_save_Success(data, ActionMethod_AB, NewFunctionName, DropdownFunction, PartyDGId, InlineEditEvent = null) {       
        HideLoader();
        if (data.jsonParam.result == false) {
            if (data.jsonParam.isconfirm == true) {
                var confirm = DevExpress.ui.dialog.confirm(data.jsonParam.message, data.jsonParam.title);
                confirm.done(function (dialogResult) {
                    if (dialogResult) {
                        if (ActionMethod_AB == "_New") {
                            $("#New_Confirm").val(true);
                            $("#AddressBookForm").submit();
                        }
                        else if (ActionMethod_AB == "_Edit" && InlineEditEvent == null) {
                            $("#Edit_Confirm").val(true);
                            $("#AddressBookForm").submit();
                        }
                        else if (ActionMethod_AB == "_Edit" && InlineEditEvent) {//Perform Operation when Grid wise editing is enabled
                            InlineEditEvent.row.data["Edit_Confirm"] = true;
                            saveRecord_AB(InlineEditEvent);
                        }

                    }
                });
            }
            else {
                var alert = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
                alert.done(function (dialogResult) {
                    if (data.jsonParam.focusid != null) {
                        if (data.jsonParam.focusid == "Txt_Name_AB") {
                            $("#tabPanel_AB").dxTabPanel("instance").option("selectedIndex", 0);
                        }
                        else {
                            $("#tabPanel_AB").dxTabPanel("instance").option("selectedIndex", 2);
                        }
                        if (dialogResult) {
                            var id = "#" + data.jsonParam.focusid;
                            setTimeout(function () {
                                $(id).find('input').focus();
                            }, Timeout100);
                        }
                    }
                });
            }
        }
        else {
            if (InlineEditEvent) {
                DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title)
                AddressListGrid_dx_Refresh();
                return;
            }
            AB_TakepopUpcloseConfirmation = false;
            if (typeof AddressListGrid !== "undefined" && ASPxClientUtils.IsExists(AddressListGrid) && AddressListGrid.GetMainElement()) {
                AB_Select_xid = data.xid;
            }
            var GridInstance = $('#AddressListGrid_dx').data("dxDataGrid")
            if (GridInstance !== void 0) {
                AB_Select_xid_dx = data.xid;
            }
            var result = DevExpress.ui.dialog.alert(data.jsonParam.message, data.jsonParam.title);
            result.done(function () {
                if (ActionMethod_AB == "_New" && DropdownFunction.length == 0 && PartyDGId.length == 0) {
                    var addmoreAddressbookresult = DevExpress.ui.dialog.confirm("Add More Entry...?", "Addressbook");
                    addmoreAddressbookresult.done(function (dialogResult) {
                        if (dialogResult) {
                            var fn = window[NewFunctionName];
                            if (typeof fn == "function") {
                                fn();
                            }
                        }
                    });
                }
                AB_ClosePopUP(data.xid);
            });
        }
    }
