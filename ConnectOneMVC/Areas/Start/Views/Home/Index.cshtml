    function DxGrid_CustomDataGridListing(GridID, AllColumns = 1, instance = null) {
        if (instance == null) {
            instance = $("div[id='" + GridID + "']").data("dxDataGrid");
            instance = instance == void 0 ? null : instance;
        }
        if (instance != null) {
            instance.option("allowColumnReordering", true);
            instance.option("columnAutoWidth", true);
            instance.option("hoverStateEnabled", true);
            instance.option("rowAlternationEnabled", true);
            instance.option("showBorders", true);
            instance.option("showColumnLines", true);
            instance.option("showRowLines", true);
            instance.option("wordWrapEnabled", true);
            instance.option("width", "100%");
            instance.option("renderAsync", true);
            instance.option("selection.mode", "single");
            instance.option("searchPanel.highlightSearchText", true);
            instance.option("searchPanel.searchVisibleColumnsOnly", true);
            instance.option("scrolling.mode", 'standard');
            instance.option("scrolling.useNative", true);
            instance.option("scrolling.showScrollbar", 'always');
            instance.option("paging.pageSize", 25);
            instance.option("pager.showPageSizeSelector", true);
            instance.option("pager.showNavigationButtons", true);
            instance.option("pager.showInfo", true);
            instance.option("pager.allowedPageSizes", [10, 20, 25, 50, 100, 200]);
            instance.option("headerFilter.visible", true);
            instance.option("headerFilter.allowSearch ", true);
            instance.option("filterRow.visible", true);
            instance.option("filterPanel.visible", true);
            instance.option("grouping.contextMenuEnabled", true);
            instance.option("grouping.autoExpandAll", true);
            instance.option("grouping.expandMode", true);
            instance.option("sorting.mode", "multiple");
            // instance.option("onAdaptiveDetailRowPreparing", DxGrid_AdaptiveDetailRowPreparing);
            if (AllColumns == 1) {
                instance.option("columnHidingEnabled", false);
                instance.option("allowColumnResizing", true);
                instance.option("columnResizingMode", 'widget');
            }
            else {
                instance.option("columnHidingEnabled", true);
                instance.option("allowColumnResizing", false);
                instance.option("columnResizingMode", 'nextColumn');
            }
            if (isMobile) {
                instance.option("columnChooser.mode", 'select');
            }
            var isDetailGrid = $("div[id='" + GridID + "']").hasClass("DG_DetailGrid")
            var AttachmentGrid = $("div[id='" + GridID + "']").parent().parent().hasClass("AttachmentGrid")
            if (isDetailGrid && AttachmentGrid == false) {
                var storageKey = GridID + "_DetailGridState";
                instance.option("stateStoring.enabled", true);
                instance.option("stateStoring.type", 'custom');
                instance.option("stateStoring.storageKey", storageKey);
                instance.option("stateStoring.savingTimeout", 1500);
                instance.option("stateStoring.customLoad", function () { return JSON.parse(sessionStorage.getItem(storageKey)); });
                instance.option("stateStoring.customSave", function (state) { sessionStorage.setItem(storageKey, JSON.stringify(state)) });
            }
        }
    }
    function DxGrid_HeaderContextMenu(e) {
        var gridId = e.element[0].id;
        var isDetailGrid = $(e.element).hasClass("DG_DetailGrid")
        var groupFooterPresent = false;
        var footerPresent = false;
        if (isDetailGrid) {
            groupFooterPresent = $("div[id='" + gridId + "'] .dx-datagrid-group-footer:visible").length > 0 ? true : false
            footerPresent = $("div[id='" + gridId + "'] .dx-datagrid-total-footer:visible").length > 0 ? true : false
        }
        else {
            groupFooterPresent = ($("div[id='" + gridId + "'] .dx-datagrid-group-footer:visible").not($("div[id='" + gridId + "'] .DG_DetailGrid .dx-datagrid-group-footer:visible"))).length > 0 ? true : false;
            footerPresent = ($("div[id='" + gridId + "'] .dx-datagrid-total-footer:visible").not($("div[id='" + gridId + "'] .DG_DetailGrid .dx-datagrid-total-footer:visible"))).length > 0 ? true : false;
        }
        var filterRowPresent = e.component.option("filterRow.visible");
        e.items.push(
            {
                text: "Group Panel",
                icon: "fa-solid fa-table-columns",
                onItemClick: function () {
                    var _showGroupPanel = e.component.option("groupPanel.visible");
                    e.component.option({
                        groupPanel:
                        {
                            visible: !_showGroupPanel
                        }
                    });
                }
            },
            {
                text: "Hide Column",
                beginGroup: true,
                visible: e.column == void 0 ? false : (e.column.command == void 0 && (e.column.isBand == void 0 || e.column.isBand == false)),
                onItemClick: function () {
                    e.component.columnOption(e.column.dataField, "visible", false);
                }
            },
            {
                text: "Column Chooser",
                icon: "columnchooser",
                onItemClick: function () {
                    e.component.showColumnChooser()

                }
            },
            {
                text: "Search Panel",
                icon: "find",
                beginGroup: true,
                onItemClick: function () {
                    var _showGroupPanel = e.component.option("searchPanel.visible");
                    e.component.option({
                        searchPanel:
                        {
                            visible: !_showGroupPanel
                        }
                    });
                }
            },
            {
                text: "Filter Builder",
                icon: "filter",
                onItemClick: function () {
                    e.component.option("filterBuilderPopup", { visible: true });
                }
            },
            //Filter Row
            {
                text: "Filter Row",
                icon: filterRowPresent ? "todo" : "",
                onItemClick: function () {
                    e.component.option({
                        filterRow:
                        {
                            visible: !filterRowPresent
                        }
                    });
                }
            },
            {
                text: "Footer",
                icon: footerPresent ? "todo" : "",
                onItemClick: function (es) {
                    if (footerPresent) {
                        if (isDetailGrid) {
                            $("div[id='" + gridId + "'] .dx-datagrid-total-footer").hide();
                        }
                        else {
                            $("div[id='" + gridId + "'] .dx-datagrid-total-footer").not($("div[id='" + gridId + "'] .DG_DetailGrid .dx-datagrid-total-footer")).hide();
                        }
                    }
                    else {
                        var SummaryItems = e.component.option("summary.totalItems")
                        if (SummaryItems == void 0 || SummaryItems == null || SummaryItems.length == 0) {
                            SummaryItems = [];
                            SummaryItems.push({ "column": "SummaryColumn", "displayFormat": "" })
                            e.component.option("summary.totalItems", SummaryItems)
                        }
                        else if (SummaryItems != null && SummaryItems.length > 0) {
                            var columnsWithSummary = SummaryItems.map(a => a.column)
                            if (columnsWithSummary.includes("SummaryColumn") == false) {
                                SummaryItems.push({ "column": "SummaryColumn", "displayFormat": "" })
                                e.component.option("summary.totalItems", SummaryItems)
                            }
                            else {
                                if (isDetailGrid) {
                                    $("div[id='" + gridId + "'] .dx-datagrid-total-footer").show();
                                }
                                else {
                                    $("div[id='" + gridId + "'] .dx-datagrid-total-footer").not($("div[id='" + gridId + "'] .DG_DetailGrid .dx-datagrid-total-footer")).show();
                                }
                            }
                        }
                        else {
                            if (isDetailGrid) {
                                $("div[id='" + gridId + "'] .dx-datagrid-total-footer").show();
                            }
                            else {
                                $("div[id='" + gridId + "'] .dx-datagrid-total-footer").not($("div[id='" + gridId + "'] .DG_DetailGrid .dx-datagrid-total-footer")).show();
                            }
                        }
                        // es.component.option("items[" + es.itemIndex + "].icon", "fa-solid fa-check")
                    }
