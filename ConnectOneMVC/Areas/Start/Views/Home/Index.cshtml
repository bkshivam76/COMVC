    function Entry_AcceptReject(_actionMethod, RecID, CallingScreen, GridName, Attachment_ID, NestedRowReasonID, NestedRowKeyvalue = "") {
        if (RecID == null || RecID.length == 0) {
            DevExpress.ui.dialog.alert("Select A Row..", "Error");
            return;
        }
        if ((IndexAttachmentID == null || IndexAttachmentID.length == 0) && (IndexAttachmentReasonID == null || IndexAttachmentReasonID.length == 0)) {
            DevExpress.ui.dialog.alert("Please select an Attachment/Remarks in Nested Row..", "Error");
            return;
        }
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Account/CashBookAuditor/Frm_CB_Remarks",
            data:
            {
                ActionMethod: _actionMethod,
                RefRecId: RecID,
                MainGridName: GridName,
                TempID: RecID,
                CallingScreen: CallingScreen,
                AttachmentID: Attachment_ID,
                TxnDocRespID: NestedRowReasonID == (null || "") ? NestedRowReasonID : NestedRowReasonID,
                NestedRowKeyvalue: NestedRowKeyvalue
            },
            cache: false,
            success: function (data) {
                HideLoader();
                OpenPopup("VoucherAuditRemarksPopup", "Remarks", null, "auto", 250, true, data);
            }
        });
    }
    function ActionAfterDataGridRefresh(data, GridInstance, SelectRow = true) {
        var selectedRowKeys = GridInstance.getSelectedRowKeys()
        if (selectedRowKeys != null && selectedRowKeys.length > 0) {
            GridInstance.clearSelection()
            GridInstance.selectRows(selectedRowKeys)
        }
    }
    function ActionAfterAuditing(MainGridName, TempID, NestedRowKeyvalue) {
        if (MainGridName.length > 0) {
            if (ASPxClientControl.GetControlCollection().GetByName(MainGridName) != null) {
                if (typeof ASPxClientControl.GetControlCollection().GetByName(MainGridName) !== 'undefined') {
                    switch (MainGridName) {
                        //case "BankListGrid":
                        //case "FDListGrid":
                        case "CashBookListGrid":
                            //case "DonRegisterListGrid":
                            //case "DailyBalancesListGrid":
                            // case "LedgerReportListGrid":
                            // case "PartyLedgerReportListGrid":
                            // case "CashListGrid":
                            RefreshGridIcons_PreviewRow(MainGridName, TempID, NestedRowKeyvalue);
                            break;
                        case "CashBookAuditListGrid":
                            CB_RefreshAfterAction = true;
                            RefreshGridView(MainGridName);
                            break;
                        default:
                            RefreshGridView(MainGridName);
                    }
                }
            }
            else {
                var GridInstance = $('#' + MainGridName).data("dxDataGrid")
                if (GridInstance !== void 0) {
                    if (MainGridName == "CashBookListGrid") {
                        Grid_Display_CB(null, true, false, true)
                    }
                    else {
                        GridInstance.refresh().done(function (data) { ActionAfterDataGridRefresh(data, GridInstance) });
                    }
                }
            }
        }
    }
    function RefreshGridIcons_PreviewRow(MainGridName, _TempID, _NestedRowKeyvalue) {
        ShowLoader();
        var _url = GetUrlToRefreshGridIcon_PreviewRow(MainGridName);
        $.ajax({
            type: 'GET',
            url: _url,
            data:
            {
                TempID: _TempID,
                NestedRowKeyValue: _NestedRowKeyvalue
            },
            success: function (data) {
                _TempID = _TempID.replace(/[^0-9A-Za-z-]/g, "_");
                RefreshMainGridIcon(MainGridName, _TempID, data.Main_iIcon);
                RefreshAttachmentGridIcon(MainGridName, _TempID, data.Attachment_Vouching_During_Audit, data.Attachment_VOUCHING_REMARKS, data.Attachment_VOUCHING_STATUS, _NestedRowKeyvalue);
                RefreshAttachmentPreviewRow(MainGridName, _TempID, data.Attachment_Vouching_During_Audit, data.Attachment_VOUCHING_REMARKS, data.Attachment_VOUCHING_STATUS, data.Vouching_History, _NestedRowKeyvalue, data.VouchingDetails)
                HideLoader();
            }
        });
    }
    function RefreshMainGridIcon(MainGridName, _TempID, _iIcon) {
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/AuditButton/VouchingAuditIcons",
            data:
            {
                iIcon: _iIcon
            },
            success: function (data) {
                $(".Icon_" + MainGridName + _TempID).each(function () { $(this).html(data) });
                HideLoader();
            }
        });
    }
    function RefreshAttachmentGridIcon(MainGridName, _TempID, _Vouching_During_Audit, _VOUCHING_REMARKS, _VOUCHING_STATUS, _NestedRowKeyvalue) {
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/AuditButton/VouchingAuditIcons_Attachment",
            data:
            {
                VOUCHING_STATUS: _VOUCHING_STATUS,
                VOUCHING_REMARKS: _VOUCHING_REMARKS,
                Vouching_During_Audit: _Vouching_During_Audit
            },
            success: function (data) {
                $("#Attachment_Icon_" + MainGridName + _TempID + _NestedRowKeyvalue).html(data);
                HideLoader();
            }
        });
    }
    function RefreshAttachmentPreviewRow(MainGridName, TempID, Vouching_During_Audit, VOUCHING_REMARKS, VOUCHING_STATUS, Vouching_History, NestedRowKeyvalue, VouchingDetails) {
        var PrevRowData = "";
        if (VOUCHING_REMARKS || VouchingDetails) {
            if (VOUCHING_STATUS.toUpperCase() == "REJECTED") {
                PrevRowData = PrevRowData + "<div><span style='color:#FF0000'> <i>" + (Vouching_During_Audit == false ? "Vouching" : "Audit") + (VOUCHING_REMARKS.Length > 0 ? " Rejection Remarks: " : " Rejection Details: ") + VOUCHING_REMARKS + VouchingDetails + "</i></span></div>";
            }
            else if (VOUCHING_STATUS.toUpperCase() == "ACCEPTED") {
                PrevRowData = PrevRowData + "<div><span style='color:#008000'> <i>" + (Vouching_During_Audit == false ? "Vouching" : "Audit") + (VOUCHING_REMARKS.Length > 0 ? " Acceptance Remarks: " : " Acceptance Details: ") + VOUCHING_REMARKS + VouchingDetails + "</i></span></div>";
            }
        }
        if (Vouching_History) {
            PrevRowData = PrevRowData + "<div>" + Vouching_History + "</div>";
        }
        $("#Attachment_PrevRow_AuditInfo_" + MainGridName + TempID + NestedRowKeyvalue).html(PrevRowData);
    }
    function GetUrlToRefreshGridIcon_PreviewRow(MainGridName) {
        var URL = "";
        if (MainGridName == "BankListGrid") {
            URL = "/Profile/Bank/Refresh_GridIcon_PreviewRow";
        }
        else if (MainGridName == "FDListGrid") {
            URL = "/Profile/FD/Refresh_GridIcon_PreviewRow";
        }
        else if (MainGridName == "CashBookListGrid") {
            URL = "/Account/Voucher/Refresh_GridIcon_PreviewRow";
        }
        else if (MainGridName == "DonRegisterListGrid") {
            URL = "/Account/DonationRegister/Refresh_GridIcon_PreviewRow";
        }
        else if (MainGridName == "DailyBalancesListGrid") {
            URL = "/Reports/DailyBalances/Refresh_GridIcon_PreviewRow";
        }
        else if (MainGridName == "LedgerReportListGrid") {
            URL = "/Reports/LedgerReport/Refresh_GridIcon_PreviewRow";
        }
        else if (MainGridName == "PartyLedgerReportListGrid") {
            URL = "/Reports/PartyLedger/Refresh_GridIcon_PreviewRow";
        }
        else if (MainGridName == "CashListGrid") {
            URL = "/Profile/Cash/Refresh_GridIcon_PreviewRow";
        }
        return URL;
    }
</script>
