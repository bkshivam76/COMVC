    function DxGrid_MaintainGroupFooterState(e) {
        var groupFooterPresent = e.component.option("CustomProp.GroupFooter.Visible")
        if (groupFooterPresent != void 0) {
            if (groupFooterPresent == false) {
                var GridName = e.element[0].id;
                var isDetailGrid = $(e.element).hasClass("DG_DetailGrid")
                if (isDetailGrid) {
                    $("div[id='" + GridName + "'] .dx-datagrid-group-footer").hide();
