    var DxGrid_DateTimeEditorOptions = {
        //displayFormat: 'dd-MM-yyyy HH:mm:ss',
        displayFormat:
        {
            formatter(value) {
                return DevExpress.localization.formatDate(value, "dd-MM-yyyy HH:mm");
            },
            parser(value) {
                var date = value.replaceAll("/", "-")
                var MomentDate = moment(date, "DD-MM-YYYY HH:mm:ss");
                if (MomentDate.isValid() == false) {
                    MomentDate = moment(date, "DD-MM-YYYY");
                    if (MomentDate.isValid() == false) {
                        return new Date("")
                    }
                }
                var dateParts = date.split('-');
                var day = dateParts[0];
                var month = dateParts[1] - 1
                var yearParts = dateParts[2].split(' ');
                var year = yearParts[0]
                var timeParts = "";
                if (yearParts.length > 1) {
                    timeParts = yearParts[1].split(":")
                }
                else {
                    return new Date(year, month, day);
                }
                var hr = timeParts[0]
                var min = timeParts[1]
                var sec = "00"
                if (timeParts.length > 2) {
                    sec = timeParts[2]
                }
                return new Date(year, month, day, hr, min, sec)
            },
        },
        //useMaskBehavior: true,
        //showClearButton: true,
        onOpened: function (e) {
            if (e.component._popup.option('toolbarItems').length == 3)
                e.component._popup.option('toolbarItems', e.component._popup.option('toolbarItems').slice(1))
        }

