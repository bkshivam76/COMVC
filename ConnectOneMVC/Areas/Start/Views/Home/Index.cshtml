    function Entry_AcceptwithoutRemarks(RecID, CallingScreen, GridName, Attachment_ID, NestedRowReasonID, NestedRowKeyvalue = "") {
        if (RecID == null || RecID.length == 0) {
            DevExpress.ui.dialog.alert("Select A Row..", "Error");
            return;
        }
        if ((Attachment_ID == null || Attachment_ID.length == 0) && (NestedRowReasonID == null || NestedRowReasonID.length == 0)) {
            DevExpress.ui.dialog.alert("Please select an Attachment/Remarks in Nested Row..", "Error");
            return;
        }
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Account/CashBookAuditor/AcceptRejectVoucher",
            data:
            {
                TempID: RecID,
                ActionMethod: "Accept",
                CallingScreen: CallingScreen,
                AttachmentID: Attachment_ID,
                TxnDocRespID: NestedRowReasonID == (null || "") ? NestedRowReasonID : NestedRowReasonID
            },
            cache: false,
            success: function (data) {
                HideLoader();
                if (data.result == true) {
                    ActionAfterAuditing(GridName, RecID, NestedRowKeyvalue);
