    function DxGrid_DeleteDetailGridState(GridName = "") {
        GridName = GridName ?? "";
        var StateKeys = [];
        for (var i = 0; i < sessionStorage.length; i++) {
            if ((sessionStorage.key(i).startsWith(GridName) || GridName.length == 0) && sessionStorage.key(i).endsWith("_DetailGridState")) {
                StateKeys.push(sessionStorage.key(i))
            }
        }
        for (var i = 0; i < StateKeys.length; i++) {
            sessionStorage.removeItem(StateKeys[i]);
        }
    }
    function DxGrid_FormatNumber(value, Format = "en-IN", maxDecimal = 2) {
        //let formatter = new Intl.NumberFormat(Format, {
        //    maximumFractionDigits: maxDecimal,
        //    minimumFractionDigits: maxDecimal
        //});
        //return new Intl.NumberFormat(formatter).format(value)
        if (typeof value == 'number') {
            return value.toLocaleString("en-IN", {
                minimumFractionDigits: maxDecimal,
                maximumFractionDigits: maxDecimal,
            });
        }
        return "";
    }
    function DxGrid_AdjustSize(GridInstance, ListingBtnsDiv, PopupID = "", resizeEvent = null)
    {
        var _screenWidth = $(window).width();
        var _screenHeight = $(window).height();
        if ((_screenWidth != ScreenWidth || _screenHeight != ScreenHeight) || resizeEvent == null) {
            ScreenWidth = _screenWidth;
            ScreenHeight = _screenHeight;            
            let instances = [];
            if (Array.isArray(GridInstance)) {
                instances = GridInstance;
            }
            else
            {
                instances = [GridInstance];
            }
            for (let i = 0; i < instances.length; i++)
            {
                GridInstance = instances[i];
                var height;
                PopupID = PopupID ?? "";
                if (isDesktop == true) {
                    if (PopupID.length > 0) {
                        var listingBtnDivHeight = 0;
                        if (ListingBtnsDiv.length > 0) {
                            listingBtnDivHeight = parseInt(getComputedStyle(ListingBtnsDiv[0]).height, 10);
                        }
                        height = document.documentElement.clientHeight - listingBtnDivHeight - 80
                    }
                    else {
                        height = ((document.documentElement.clientHeight * 90) / 100) - 110;
                    }
                }
                else {
                    var listingBtnDivHeight = 0;
                    if (ListingBtnsDiv.length > 0) {
                        listingBtnDivHeight = parseInt(getComputedStyle(ListingBtnsDiv[0]).height, 10);
                    }
                    if (window.matchMedia("(orientation: landscape)").matches) {
                        if (PopupID.length > 0) {
                            height = document.documentElement.clientHeight - listingBtnDivHeight - 80;
                        }
                        else {
                            height = document.documentElement.clientHeight - listingBtnDivHeight;
                            if (height < 350) { height = 350; }
                        }
                    }
                    else {
                        height = document.documentElement.clientHeight - listingBtnDivHeight - 150;
                    }
                }
                GridInstance.option("height", height);
                setTimeout(function () {
                    GridInstance.updateDimensions();
                    if (resizeEvent) {
                        DxGrid_SetGridUIinColHiding(GridInstance.option("CustomProp.ID"), GridInstance.option("columnHidingEnabled") ? 0 : 1)
                    }
                })
            }
        }
    }
