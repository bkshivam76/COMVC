    var DxGrid_StringFilterOperations = ["contains", "notcontains", "startswith", "endswith", "=", "<>"]
    var DxGrid_NumericFilterOperations = ["=", "<>", "<", ">", "<=", ">="]
    function DxGrid_DateTimeFilterOperations(filterBuilder = false) {
        if (filterBuilder) {
            return [...new Set([...DxGrid_StringFilterOperations, ...DxGrid_NumericFilterOperations, "isblank", "isnotblank", "anyof", "noneof"])]
        }
        return [...new Set([...DxGrid_StringFilterOperations, ...DxGrid_NumericFilterOperations])]
    }
    function DxGrid_DateTimeColFilterExp(filterValue, selectedFilterOperation, target) {
        if (target == "filterBuilder") {        
            var dataField = this.dataField;
            var format = this.format
            format = format == void 0 ? "" : format;
            var splitter = "/"
            if (format.includes("HH")) {
                var splitTime = format.split("HH:")
                if (splitTime.length > 1) {
                    format = splitTime[0].toUpperCase() + "HH:" + splitTime[1]
                }
            }
            else {
                format = format.toUpperCase()
            }
            if (format.includes("-")) {
                splitter = "-"
            }
            if (Array.isArray(filterValue)) {
                if (filterValue[0] != void 0 && filterValue[0] != null) {
                    filterValue[0] = filterValue[0].replaceAll("/", splitter).replaceAll("-", splitter)
                }
                if (filterValue[1] != void 0 && filterValue[1] != null) {
                    filterValue[1] = filterValue[1].replaceAll("/", splitter).replaceAll("-", splitter)
                }
            }
            else {
                filterValue = filterValue.replaceAll("/", splitter).replaceAll("-", splitter)
            }
            if (DxGrid_NumericFilterOperations.indexOf(selectedFilterOperation) > -1) {
                return [function (data) {
                    return new Date(data[dataField])
                }, selectedFilterOperation, DateStringToJsDate(filterValue, format)]
            }
            else (DxGrid_StringFilterOperations.indexOf(selectedFilterOperation) > -1)
            {
                return [function (data) {
                    return JS_Json_Date_To_ddMMyyyy(data[dataField], format)
                }, selectedFilterOperation, filterValue]
            }
        }
        return this.defaultCalculateFilterExpression.apply(this, arguments);
    }
