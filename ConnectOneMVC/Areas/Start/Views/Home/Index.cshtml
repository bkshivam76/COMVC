    async function ExitProcess() {
        $.ajax({
            type: 'GET',
            url: "/Start/AccountSubmission/Pending_Accounts_Submission",
            cache: false,
            data: {},
            success: function (data) {
                if (data.ReturnMessage.length > 0)
                {
                    CheckSubmissionAccounts(data.ReturnMessage);
                } else {
                    ClearSessionStorage();
                    window.location.assign(window.location.origin + '/Start/Login/Logout/@Request.Url.Query');
                }
            },
            error: function (data) {
                CheckSubmissionAccounts("Account Submission Checking failed !!");
            }
        });


    }
    function CheckSubmissionAccounts(message)
    {
        var checkResultDocument = DevExpress.ui.dialog.confirm("<p style='color:red;font-weight:bold'>"+message+"</p>" + "Sure You Want To Exit ??", "Alert!!");
                    checkResultDocument.done(function (dialogResult) {
                        if (dialogResult)
                        {
                            ClearSessionStorage();
                            window.location.assign(window.location.origin + '/Start/Login/Logout/@Request.Url.Query');
                        }
                    })

    }
