    function DxGrid_FooterContextMenu(e, CompactMode = false) {
        var isGroupFooter = e.target == "footer" ? false : true;
        var SummaryExpression = isGroupFooter ? "summary.groupItems" : "summary.totalItems";
        var SummaryItems = e.component.option(SummaryExpression)
        if (e.column) {
            if (e.column.dataType) {
                var IsNumberColumn = e.column.dataType == "number";
            }
            else return;//Bug #137474
        }
        else {
            return;
        }
        var sumIcon = SumIcon();
        var minIcon = MinIcon();
        var maxIcon = MaxIcon();
        var countIcon = CountIcon();
        var avgIcon = AvgIcon();
        if (SummaryItems !== void 0 && SummaryItems != null && SummaryItems.length > 0) {
            for (var i = 0; i < SummaryItems.length; i++) {
                var _currSummaryName = SummaryItems[i].name;
                if (SummaryItems[i].column === e.column.dataField) {
                    switch (SummaryItems[i].summaryType) {
                        // case "sum": sumIcon = "todo"; break;
                        case "sum": sumIcon = SumIconSelected(); break;
                        case "min": minIcon = MinIconSelected(); break;
                        case "max": maxIcon = MaxIconSelected(); break;
                        case "count": countIcon = CountIconSelected(); break;
                        case "avg": avgIcon = AvgIconSelected(); break;
                        case "custom":
                            if (_currSummaryName.endsWith("_minCalc")) {
                                minIcon = MinIconSelected();
                            }
                            else if (_currSummaryName.endsWith("_maxCalc")) {
                                maxIcon = MaxIconSelected();
                            }
                            break;
                        default: avgIcon = "";
                    }
                }
            }
        }

        e.items.push(
            {
                text: "Sum",
                icon: sumIcon,
                visible: IsNumberColumn,
                onItemClick: function () {
                    DxGrid_AddorRemoveSummary(e, e.column.dataField, "sum", isGroupFooter, IsNumberColumn)
                }
            },
            {
                text: "Min",
                icon: minIcon,
                visible: !CompactMode,
                onItemClick: function () {
                    DxGrid_AddorRemoveSummary(e, e.column.dataField, "min", isGroupFooter, IsNumberColumn)
                }
            },
            {
                text: "Max",
                icon: maxIcon,
                visible: !CompactMode,
                onItemClick: function () {
                    DxGrid_AddorRemoveSummary(e, e.column.dataField, "max", isGroupFooter, IsNumberColumn)
                }
            },
            {
                text: "Count",
                icon: countIcon,
                onItemClick: function () {
                    DxGrid_AddorRemoveSummary(e, e.column.dataField, "count", isGroupFooter, IsNumberColumn)
                }
            },
            {
                text: "Average",
                icon: avgIcon,
                visible: IsNumberColumn,
                onItemClick: function () {
                    DxGrid_AddorRemoveSummary(e, e.column.dataField, "avg", isGroupFooter, IsNumberColumn)
                }
            },
            {
                text: "None",
                beginGroup: true,
                onItemClick: function () {
                    DxGrid_AddorRemoveSummary(e, e.column.dataField, "none", isGroupFooter, IsNumberColumn)
                }
            }
        );
    }
    function DxGrid_AddorRemoveSummary(e, dataField, SummaryType, isGroupFooter, IsNumberColumn) {

        var GridName = e.element[0].id;
        var SummaryExpression = isGroupFooter ? "summary.groupItems" : "summary.totalItems";
        var SummaryItems = e.component.option(SummaryExpression)
        if (e.column.dataType === "date" || e.column.dataType === "datetime")//Bug #137472
            var IsDateColumn = true;
        else
            var IsDateColumn = false;

        var IsStringColumn = e.column.dataType == "string";
        var ToRemoveSummary = false;
        var _SummaryType;
        var SummaryName;
        if (IsStringColumn && (SummaryType == "min" || SummaryType == "max")) {
            _SummaryType = "custom";
        }
        else {
            _SummaryType = SummaryType;
        }
        if (SummaryType == "min" && _SummaryType == "custom") {
            SummaryName = dataField + "_" + dataField + "_minCalc";
        }
        else if (SummaryType == "max" && _SummaryType == "custom") {
            SummaryName = dataField + "_" + dataField + "_maxCalc";
        }
        else {
            SummaryName = dataField + "_" + dataField + "_" + _SummaryType;
        }
        if (SummaryItems == void 0) {
            SummaryItems = [];
        }
        if (SummaryItems != null && SummaryItems.length > 0) {
            if (_SummaryType != "none") {
                const index = SummaryItems.findIndex(obj => { return obj.summaryType === _SummaryType && obj.name === SummaryName })
                if (index > -1) //summary present remove it
                {
                    SummaryItems.splice(index, 1);
                    ToRemoveSummary = true;
                }
            }
            else //none so remove all summary of the column
            {
                var AfterRemovingSummary = SummaryItems.filter(obj => obj.column != dataField);
                SummaryItems = AfterRemovingSummary
            }
        }
        if (SummaryItems == null || SummaryItems.length == 0) //summary not present in summarycolumn adding it to prevent hiding of footer
        {
            if (SummaryItems == null) { SummaryItems = []; }
            if (isGroupFooter) {
                SummaryItems.push({ "column": "SummaryColumn", "showInGroupFooter": true, "displayFormat": "" })
            }
            else {
                SummaryItems.push({ "column": "SummaryColumn", "displayFormat": "" })
            }
        }
        if (_SummaryType != "none" && ToRemoveSummary == false) //summary to be added
        {
            var summary;
            var ValFormat;
            var DisplayFormat = "";
            if (IsNumberColumn) {
                ValFormat = function (value) { return DxGrid_FormatNumber(value) };
            }
            else if (IsDateColumn && _SummaryType != "count") {

                var Cformat = e.column.format;
                ValFormat = function (value) { return DevExpress.localization.formatDate(value, (Cformat !== void 0 ? Cformat : 'dd-MM-yyyy')); }
            }
            else {
                ValFormat = "";
            }
            if (GridName == "BankListGrid_dx" && _SummaryType == "sum" && isGroupFooter && dataField == "OP_AMOUNT")//Redmine Bug #136966 Fix
            /*To maintain the display text of OP_AMOUNT sum text as Grand Total even * if it was removed by none context menu click*/ {
                DisplayFormat = "Total: {0}";
            }
            else if (GridName == "BankListGrid_dx" && _SummaryType == "sum" && dataField == "OP_AMOUNT") {
                DisplayFormat = "Grand Total= {0}";
            }
            else {
                DisplayFormat = SummaryType.toProperCase() + "= {0}";
            }
            if (isGroupFooter) {
                summary =
                {
                    "name": SummaryName, "column": dataField, "showInGroupFooter": true, "summaryType": _SummaryType, "showInColumn": dataField, "skipEmptyValues": !(SummaryType == "min" || SummaryType == "max" || SummaryType == "avg"), "recalculateWhileEditing": true, valueFormat: ValFormat
                    , "displayFormat": DisplayFormat
                    //IsNumberColumn ? function (value) { return DxGrid_FormatNumber(value) } : ""
                }
            }
            else {
                summary =
                {
                    "name": SummaryName, "column": dataField, "summaryType": _SummaryType, "showInColumn": dataField, "skipEmptyValues": !(SummaryType == "min" || SummaryType == "max" || SummaryType == "avg"), "recalculateWhileEditing": true, valueFormat: ValFormat
                    , "displayFormat": DisplayFormat,
                    //IsNumberColumn ? function (value) { return DxGrid_FormatNumber(value) } : "",
                }
            }
            SummaryItems.push(summary)
        }
        else {
            //if (SummaryItems == null || SummaryItems.length == 0) // to keep footer showing when no summary is there
            //{
            //    var summary;
            //    if (isGroupFooter)
            //    {
            //        summary =
            //        {
            //            "column": dataField, "showInGroupFooter": true, "summaryType": "custom", "showInColumn": dataField, "displayFormat": " "
            //        }
            //    }
            //    else
            //    {
            //        summary = { "column": dataField, "summaryType": "custom", "showInColumn": dataField, "displayFormat": " " }
            //    }
            //    SummaryItems.push(summary)
            //}
        }
        e.component.option(SummaryExpression, SummaryItems)
        e.component.option("summary.calculateCustomSummary", DxGrid_CalcCustomSummary)
    }
    const DxGrid_CalcCustomSummary = (options) => {
        if (options.name.endsWith("_maxCalc") || options.name.endsWith("_minCalc")) {
            if (options.summaryProcess) {
                if (options.summaryProcess === "start") {
                    options.totalValue = [];
                }
                else if (options.summaryProcess === "calculate") {
                    options.totalValue.push(options.value == null ? "" : options.value)
                }
                else if (options.summaryProcess === "finalize") {
                    options.totalValue.sort((a, b) => a.toLowerCase().localeCompare(b.toLowerCase()));
                    if (options.name.endsWith("_maxCalc")) {
                        options.totalValue = options.totalValue[options.totalValue.length - 1]
                    }
                    else {
                        options.totalValue = options.totalValue[0]
                    }
                }
            }
        }
    }
