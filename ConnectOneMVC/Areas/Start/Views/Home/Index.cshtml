                ],
            onRowPrepared: function (e) { DxGrid_AttachmentGrid_onRowPrepared(e, vouchingMode) },
            onContentReady: function (e) { DxGrid_AttachmentGrid_onContentReady(e, vouchingMode, AllColumns) },
            //onSelectionChanged: function (e) { WIPListGrid_dx_Detail_onSelectionChanged(e) },
            onContextMenuPreparing: function (e) { DxGrid_AttachmentGrid_onContextMenuPreparing(e) }
        });
        var instance = $("div[id='" + DetailGridID + "']").dxDataGrid("instance");
        DxGrid_CustomDataGridListing(DetailGridID, AllColumns, instance)
        if (vouchingMode == true)
        {
            instance.option("headerFilter.visible", false);
            instance.option("scrolling.showScrollbar", 'never');
            instance.option("showColumnHeaders", false);
        }
        instance.option("filterRow.visible", false);
        instance.option("paging.enabled", false);
        //instance.option("columnAutoWidth", false);
        // instance.option("wordWrapEnabled", false);
        return instance;
    }
    function DxGrid_AttachmentGrid_onRowPrepared(e, VouchingOn)
    {
        if (e.rowType == "data")
        {
            DxGrid_CreatePreviewRow(e, VouchingOn, "Detail")
        }
        else if (e.rowType == "detailAdaptive")
        {
            DxGrid_MovePreviewRowAfterAdaptiveRow(e)
        }
    }
    function DxGrid_AttachmentGrid_onContentReady(e, vouchingOn, AllColumns)
    {
        var rows = e.component.getVisibleRows();
        var count = rows.length;
        var selectedKeys = e.component.getSelectedRowKeys();
        if (selectedKeys == null || selectedKeys.length == 0) {
            for (var i = 0; i < count; i++) {
                if (rows[i].rowType == "data") {
                    var Doc_Status = rows[i].data.Doc_Status;
                    var Doc_Category = rows[i].data.Document_Category;
                    if (vouchingOn == true) {
                        if (i == 0) {
                            e.component.selectRows(rows[i].key);
                            break;
                        }
                    }
                    if (vouchingOn == false) {
                        if ((Doc_Status == null || Doc_Status == "") && Doc_Category.toLowerCase() != "others") {
                            e.component.selectRows(rows[i].key);
                            break;
                        }
                    }
                }
            }
        }
        else
        {
            e.component.clearSelection();
            e.component.selectRows(selectedKeys);
        }
        DxGrid_SetGridUIinColHiding(e.element[0].id, AllColumns, true)
        DxGrid_GetFIlterBuilderDataSource(e)
    }
    function DxGrid_AttachmentGrid_onContextMenuPreparing(e)
    {
        if (!e.items) e.items = [];
        if (e.target == "header")
        {
            DxGrid_HeaderContextMenu(e)
        }
        else if ((e.target == "content" && e.row && e.row.rowType == "groupFooter") || e.target == "footer")
        {
            DxGrid_FooterContextMenu(e);
        }
        else if (e.target == "content" && e.row && e.row.rowType == "data")
        {
            e.items = [{
                text: "Refresh",
                icon: "fa-solid fa-arrow-rotate-right text-success",
                onItemClick: function () {
                    e.component.refresh();
                }
            }]
        }
    }
