    //    //Frm_COD_Selection_Auditor_Grid.Focus();
    //}


    function chKRememberMeAddClass(e) {
        e.element.addClass("checkbox-auditor")
    }

    function Txt_Pass_Eye_showPasswordClick(e) {
        currentMode = $("#Txt_Pass").dxTextBox("instance").option("mode");

        if (currentMode == "password") {
            $("#Txt_Pass").dxTextBox("instance").option("mode", "text")
            $("#Txt_Pass_Eye").dxButton("instance").option("icon", "fa fa-eye-slash")
        }
        else if (currentMode == "text") {
            $("#Txt_Pass").dxTextBox("instance").option("mode", "password")
            $("#Txt_Pass_Eye").dxButton("instance").option("icon", "fa fa-eye")
        }
    }
</script>