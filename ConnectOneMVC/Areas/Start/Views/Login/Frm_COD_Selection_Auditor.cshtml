    function createGuid() {
        return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function (c) {
            var r = Math.random() * 16 | 0, v = c === 'x' ? r : (r & 0x3 | 0x8);
            return v.toString(16);
        });
    }
    function getQueryStringValue(key)
    {
        return decodeURIComponent(window.location.search.replace(new RegExp("^(?:.*[&\\?]" + encodeURIComponent(key).replace(/[\.\+\*]/g, "\\$&") + "(?:\\=([^&]*))?)?.*$", "i"), "$1"));
    }
    function getParameterByName(name, url)
    {
        if (!url) url = window.location.href;
        name = name.replace(/[\[\]]/g, "\\$&");
        var regex = new RegExp("[?&]" + name + "(=([^&#]*)|&|#|$)"),
            results = regex.exec(url);
        if (!results) return null;
        if (!results[2]) return '';
        return decodeURIComponent(results[2].replace(/\+/g, " "));
    }

    function Frm_COD_Selection_Auditor_Grid_init(s, e)
    {
        ASPxClientUtils.AttachEventToElement(s.GetMainElement(), "keydown", function (evt) 
        {
            switch (evt.keyCode) 
            {
                case 13: // enter key
                    evt.stopImmediatePropagation();
                    ASPxClientUtils.PreventEventAndBubble(evt);
                    SlectCenter_okClick();
                    break;
            }
        });
    }
    function Frm_COD_Selection_Auditor_Grid_OnGridFocusedRowChanged(s, e)
    {
        //s.GetRowValues(s.GetFocusedRowIndex(), 'CEN_UID;CEN_PAD_NO;COD_YEAR_ID;COD_YEAR_NAME;COD_YEAR_SDT;COD_YEAR_EDT;REC_ID;CEN_ID_MAIN;CEN_PAD_NO_MAIN;CEN_ZONE_ID;CEN_ZONE_SUB_ID;CEN_ACC_TYPE_ID;IS_VOLUME;CEN_NAME;CEN_ID;AuditStatus', Frm_COD_Selection_Auditor_Grid_Values);
    }
    async function Frm_COD_Selection_Auditor_Grid_Values(values)
    {
         CEN_ID= values[0];
         CEN_NAME = values[1];
        COD_YEAR_ID = values[2];
        COD_YEAR_NAME = values[3];
        COD_YEAR_SDT = values[4];
        COD_YEAR_EDT = values[5];
         CEN_UID = values[6];
         REC_ID= values[7];
         CEN_ID_MAIN= values[8];
         CEN_PAD_NO_MAIN= values[9];
        CEN_PAD_NO= values[10];
        CEN_ZONE_ID= values[11];
         CEN_ZONE_SUB_ID = values[12];
        CEN_ACC_TYPE_ID= values[13];
        IS_VOLUME = values[14];
        AuditStatus = values[15];      
        try { _SessionGUID = SessionGUID; }//If coming from Auditor Login Page
        catch (err) { }
        var IsToContinue = true;
        if (AuditStatus == "Returned") {
            var confirm = DevExpress.ui.dialog.confirm("Center is in 'Returned for Correction' status. Do you want to Resume Audit...?", "Confirm");
            await confirm.done(function (dialogResult) {
                if (dialogResult) {
                    if (CheckResumeAudit() == false) {
                        IsToContinue = false;
                    }
                    else
                    {
                        CEN_NAME = CEN_NAME.replace("(Returned)", "");    //Redmine Bug #133627 fixed
                    }
                }
                else {
                    if ("@OpenUserType" != "SUPERUSER") {
                        DevExpress.ui.dialog.alert("Sorry! Not allowed to Login Center without Resuming Audit....!", "Information..");
                        IsToContinue = false;
                    }
                }
            });
        }
        if (IsToContinue)
        {
            ShowLoader_CC();
            $.ajax({
                type: 'Get',
                url: "/Start/Login/ChangeCenter",
                data:
                {
                    CenID: CEN_ID,
                    CenName: CEN_NAME,
                    YearID: COD_YEAR_ID,
                    YearName: COD_YEAR_NAME,
                    YrStDate: (moment(COD_YEAR_SDT).format("DD/MM/YYYY HH:mm:ss")),
                    YrEndDate: (moment(COD_YEAR_EDT).format("DD/MM/YYYY HH:mm:ss")),
                    UID: CEN_UID,
                    CenRecID: REC_ID,
                    CenIDMain: CEN_ID_MAIN,
                    PadMain: CEN_PAD_NO_MAIN,
                    PADNo: CEN_PAD_NO,
                    ZoneID: CEN_ZONE_ID,
                    SubZoneID: CEN_ZONE_SUB_ID,
                    AccTypeID: CEN_ACC_TYPE_ID,
                    isVolume: IS_VOLUME,
                    XINS_NAME: "@xINS_NAME",
                    XINS_ID: "@xIns_ID",
                    xINS_SHORT: "@xINS_SHORT"
                },
                cache: false,
                success: function (data)
                {
                    //CloseChangeCenter();
                    if (data.result == true) {// Redmine Bug #133683 fixed
                        if (_SessionGUID == 'undefined' || _SessionGUID == undefined || _SessionGUID == '') {
                            _SessionGUID = getQueryStringValue("SessionGUID");
                        }
                        if (getParameterByName('SessionGUID', window.location.href) == _SessionGUID) {
                            window.location.reload();
                            ClearSessionStorage();
                        }
                        else {
                            window.name = createGuid();
                            window.location = "/Start/Home/Index?SessionGUID=" + _SessionGUID;
                        }
                    }
                    else
                    {
                        DevExpress.ui.dialog.alert(data.message, "Information..");
                    }
                    HideLoader_CC();
                }
            });
        }
    }
    function Frm_COD_Selection_Auditor_Grid_BeginCallBack(s, e)
    {
        e.customArgs["command"] = e.command;
        e.customArgs['xIns_ID'] = "@xIns_ID";
        e.customArgs['txtCenter'] = $('#TxtCenter_SelectCenter').dxTextBox('option', 'text');
        e.customArgs['SearchClick'] = CC_SearchClick;
    }
    function Frm_COD_Selection_Auditor_Grid_EndCallBack(s, e)
    {
        if (e.command == "REFRESH")
        {
            if (CC_SearchClick == true)//Redmine Bug #133743 fixed
            {
                if (s.cpTotalRowCount < 1)
                {
                    DevExpress.ui.dialog.alert("Data Not Found...!", "Select Center");
                }
            }
            CC_SearchClick = false;
            s.SetFocusedRowIndex(-1);
            s.SetFocusedRowIndex(0);
            s.Focus();
        }
    }

    function SlectCenter_okClick(e)
    {
        if (COD_Selection_Auditor_Grid.GetVisibleRowsOnPage() <= 0)
        {
            DevExpress.ui.dialog.alert("Select A Center", "Error!!");
            return;
        }
        if (COD_Selection_Auditor_Grid.GetFocusedRowIndex() < 0)
        {
            DevExpress.ui.dialog.alert("Select A Center", "Error!!");
            return;
        }
        COD_Selection_Auditor_Grid.GetRowValues(COD_Selection_Auditor_Grid.GetFocusedRowIndex(), 'CEN_ID;CEN_NAME;COD_YEAR_ID;COD_YEAR_NAME;COD_YEAR_SDT;COD_YEAR_EDT;CEN_UID;REC_ID;CEN_ID_MAIN;CEN_PAD_NO_MAIN;CEN_PAD_NO;CEN_ZONE_ID;CEN_ZONE_SUB_ID;CEN_ACC_TYPE_ID;IS_VOLUME;AuditStatus', Frm_COD_Selection_Auditor_Grid_Values);

    }


    var CC_SearchClick = false;
    function TxtCenter_OnEnterKey(e)
    {
        if (e.event)
        {
            e.event.stopImmediatePropagation();
        }
        CC_SearchClick = true;
        COD_Selection_Auditor_Grid.Refresh();
    }
    function CheckResumeAudit()
    {
        var result;
        $.ajax({
            type: 'Get',
            url: "/Start/Login/CheckResumeAudit",
            data: { CEN_ID: CEN_ID, COD_YEAR_ID: COD_YEAR_ID },
            cache: false,
            async: false,
            success: function (data)
            {
                result = data;
            }
        });
            return result;
    }



