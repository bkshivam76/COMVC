    function transformTypedChar(charStr) {
        if (charStr == "'") {
            charStr = "`";
        }
        else if (charStr == "[") {
            charStr = "(";
        }
        else if (charStr == "]") {
            charStr = ")";
        }
        else if (charStr == "!") {
            charStr = "|";
        }
        return charStr;
    }
