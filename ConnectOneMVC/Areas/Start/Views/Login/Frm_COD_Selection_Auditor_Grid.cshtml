
@using System.Web.UI.WebControls

@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "COD_Selection_Auditor_Grid";
        settings.CallbackRouteValues = new
        {
            Controller = "Login",
            Action = "Frm_COD_Selection_Auditor_Grid",
        };
        settings.Width = Unit.Percentage(100);
        settings.Settings.HorizontalScrollBarMode= ScrollBarMode.Visible;
        settings.Settings.VerticalScrollBarMode = ScrollBarMode.Visible;
        settings.Settings.VerticalScrollableHeight = 200;
        settings.KeyboardSupport = true;
        //settings.AccessKey = "G";
        //settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
        settings.Settings.ShowGroupPanel = false;
        settings.SettingsBehavior.AutoExpandAllGroups = true;
        settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
        settings.Settings.UseFixedTableLayout = true;
        settings.SettingsLoadingPanel.Mode = GridViewLoadingPanelMode.Disabled;
        settings.SettingsBehavior.AllowFocusedRow = true;
        settings.SettingsBehavior.AllowSelectByRowClick = false;
        settings.ClientSideEvents.FocusedRowChanged = "Frm_COD_Selection_Auditor_Grid_OnGridFocusedRowChanged";
        settings.Settings.ShowHeaderFilterButton = true;
        settings.Settings.ShowFilterRow = false;
        settings.Settings.ShowHeaderFilterBlankItems = false;
        settings.Settings.AutoFilterCondition = AutoFilterCondition.Contains;
        settings.SettingsPager.Mode = GridViewPagerMode.EndlessPaging;
        settings.SettingsContextMenu.Enabled = true;
        settings.SettingsContextMenu.EnableRowMenu = DefaultBoolean.False;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;
        settings.ClientSideEvents.BeginCallback = "Frm_COD_Selection_Auditor_Grid_BeginCallBack";
        settings.ClientSideEvents.EndCallback = "Frm_COD_Selection_Auditor_Grid_EndCallBack";
        settings.ClientSideEvents.Init = "Frm_COD_Selection_Auditor_Grid_init";
        settings.CustomJSProperties = (s, e) =>
        {
            MVCxGridView grid = s as MVCxGridView;
            e.Properties["cpTotalRowCount"] = grid.VisibleRowCount;
        };
        settings.DataBound = (s, e) =>
        {
            MVCxGridView grid = s as MVCxGridView;
            grid.KeyFieldName = "CEN_ID";
            grid.DataColumns["CEN_ID"].Visible = false;
            grid.DataColumns["CEN_ACC_TYPE_ID"].Caption = "Acc. Type";
            grid.DataColumns["CEN_ACC_TYPE_ID"].Width = 90;
            grid.DataColumns["COD_YEAR_ID"].Visible = false;
            grid.DataColumns["COD_YEAR_NAME"].Visible = false;
            grid.DataColumns["COD_YEAR_SDT"].Visible = false;
            grid.DataColumns["COD_YEAR_EDT"].Visible = false;
            grid.DataColumns["CEN_ID_MAIN"].Visible = false;
            grid.DataColumns["CEN_PAD_NO_MAIN"].Visible = false;
            grid.DataColumns["CEN_ZONE_ID"].Visible = false;
            grid.DataColumns["CEN_ZONE_SUB_ID"].Visible = false;
            grid.DataColumns["REC_ID"].Visible = false;
            grid.DataColumns["CEN_NAME"].Caption = "Center Name";
            grid.DataColumns["CEN_NAME"].MinWidth = 360;//Redmine Task #135146 & Task #135145 completed
            grid.DataColumns["CEN_UID"].Caption = "Center UID";
            grid.DataColumns["CEN_UID"].MinWidth = 115;
            grid.DataColumns["CEN_PAD_NO"].Caption = "No.";
            grid.DataColumns["CEN_PAD_NO"].MinWidth = 100;
            grid.DataColumns["CEN_PAD_NO"].Visible = false;//Redmine Task #135146 & Task #135145 completed
            grid.DataColumns["CEN_CANCELLATION_DATE"].Caption = "Closure Date";//Redmine Task #135146 & Task #135145 completed
            grid.DataColumns["IS_VOLUME"].Visible = false;//Redmine Task #135146 & Task #135145 completed
            grid.DataColumns["AuditStatus"].Visible = false;//Redmine Task #135146 & Task #135145 completed
        };
        settings.SettingsSearchPanel.ShowApplyButton = true;//Redmine Bug #132041 fixed
        settings.SettingsSearchPanel.ShowClearButton = true;
        MyExtensions.GridViewHelper.CustomGridView(settings);
    }).Bind(Model).GetHtml()
