@*@model List<ConnectOneMVC.Areas.Profile.Models.Center_Ins_List>*@
@model System.Data.DataTable
@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "CenterSelectionListGrid";
        settings.CallbackRouteValues = new
        {
            Controller = "Login",
            Action = "Frm_COD_Selection_Ins_Grid",
            certificate_no = ViewBag.certificate_number.ToString(),
        };
        settings.CustomDataActionRouteValues = new { Controller = "Login", Action = "CODSelectionInsCustomDataAction" };
        settings.Settings.VerticalScrollBarMode = ScrollBarMode.Visible;
        //settings.Settings.VerticalScrollableHeight = 190;
        settings.KeyboardSupport = true;
        //settings.AccessKey = "G";
        settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Auto;
        //settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.HideDataCells;
        //settings.SettingsAdaptivity.AllowHideDataCellsByColumnMinWidth = true;       
        settings.Settings.ShowGroupPanel = false;
        settings.SettingsBehavior.AutoExpandAllGroups = true;
        settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
        settings.Settings.UseFixedTableLayout = true;
        settings.SettingsLoadingPanel.Mode = GridViewLoadingPanelMode.Disabled;
        settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
        //settings.ClientSideEvents.SelectionChanged = "SelectionChanged";

        settings.SettingsBehavior.AllowFocusedRow = true;

        settings.ClientSideEvents.FocusedRowChanged = "OnGridFocusedRowChanged";

        settings.Settings.ShowHeaderFilterButton = true;
        settings.Settings.ShowFilterRow = false;
        settings.Settings.ShowHeaderFilterBlankItems = false;
        settings.Settings.AutoFilterCondition = AutoFilterCondition.Contains;
        settings.SettingsPager.Mode = GridViewPagerMode.ShowAllRecords;
        settings.EnablePagingGestures = AutoBoolean.False;
        settings.SettingsContextMenu.Enabled = true;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;
        // DXCOMMENT: Specify the grid's key field name and define grid columns in accordance with data model fields
        settings.KeyFieldName = "CEN_ID";

        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "CEN_UID",
            Caption = "Center UID",
            MinWidth = 100,
            Width = 100
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "INS_SHORT",
            Caption = "Institute",
            MinWidth = 80,
            Width = 80
        });
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "CEN_NAME_X",
            Caption = "Center Name",
            MinWidth = 300,
            Width = 300
        });//Redmine Task #135146 & Task #135145 completed
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "CEN_PAD_NO",
            Caption = "No.",
            MinWidth = 60,
            Width = 60,
            Visible = false
        });//Redmine Task #135146 & Task #135145 completed  
        settings.Columns.Add(new MVCxGridViewColumn()
        {
            FieldName = "CEN_ACC_TYPE_ID",
            Caption = "Acc. Type",
            MinWidth = 80,
            Width = 80
        });
        settings.Columns.Add(column =>
        {
            column.FieldName = "CEN_CANCELLATION_DATE";
            column.Caption = "Closure Date";
            column.MinWidth = 100;
            column.Width = 100;
            column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
        });//Redmine Task #135146 & Task #135145 completed
        settings.ClientSideEvents.Init = "CenterSelectionListGrid_Init";
        settings.ClientSideEvents.EndCallback = "CenterSelectionListGrid_EndCallBack";
    }).Bind(Model).GetHtml()
