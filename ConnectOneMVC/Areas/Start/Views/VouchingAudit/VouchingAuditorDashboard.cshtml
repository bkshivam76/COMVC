@using DevExtreme.AspNet.Mvc;
@using System.Web.UI.WebControls;
@model  List<Common_Lib.DbOperations.Vouchers.Return_GetVouchingAuditDashboard>

<div class="middle-section clearfix" style="padding-top:25px">
    <div class="container-fluid">
        <div class="main-content-left ol-sm-12 col-md-6">
            <div class="notification">
                <div class="heading">
                    <h2 style="background: url(../../../../Content/image/icon_audit5.jpg) left center no-repeat;padding-left:45px">Vouchers <span>Available for Audit</span> </h2> @*<span class="notification-count"># 12</span>*@
                </div>
                @Html.DevExpress().CardView(settings =>
           {
               settings.Name = "Cards";
               settings.CallbackRouteValues = new { Controller = "Vouching Audit", Action = "VouchingAuditorDashboardCardView" };
               settings.Styles.Card.Width = 300;
               settings.Styles.Card.Border.BorderStyle = BorderStyle.Solid;
               settings.Styles.Card.Border.BorderWidth = Unit.Pixel(1);
               settings.Styles.Card.Border.BorderColor = System.Drawing.Color.LightGray;
               settings.Width = Unit.Percentage(100);
               settings.EnableCardsCache = false;
               settings.SettingsText.EmptyCard = "<div style='height:100px;width:100%;text-align: center;vertical-align:middle'>No Vouchers Available for Audit!!</div>";
               settings.Settings.LayoutMode = DevExpress.Web.Layout.Breakpoints;
               settings.SettingsAdaptivity.BreakpointsLayoutSettings.CardsPerRow = 2;
               settings.SettingsAdaptivity.BreakpointsLayoutSettings.Breakpoints.Add(BreakpointsLayoutDeviceSizes.XLarge, 2);
               settings.SettingsAdaptivity.BreakpointsLayoutSettings.Breakpoints.Add(BreakpointsLayoutDeviceSizes.Large, 2);
               settings.SettingsAdaptivity.BreakpointsLayoutSettings.Breakpoints.Add(BreakpointsLayoutDeviceSizes.Medium, 1);
               settings.SettingsAdaptivity.BreakpointsLayoutSettings.Breakpoints.Add(BreakpointsLayoutDeviceSizes.Small, 1);
               settings.SettingsAdaptivity.BreakpointsLayoutSettings.Breakpoints.Add(450, 1);
               settings.SettingsPager.Mode = GridViewPagerMode.EndlessPaging;
               settings.SettingsPager.EndlessPagingMode = CardViewEndlessPagingMode.OnScroll;
               settings.SettingsPager.SettingsBreakpointsLayout.ItemsPerPage = 18;
               settings.Styles.BreakpointsCard.Height = Unit.Percentage(100);

               settings.KeyFieldName = "ID";
               settings.Columns.Add(c =>
               {
                   c.FieldName = "PhotoUrl";
                   c.ColumnType = MVCxCardViewColumnType.Image;
                   ((ImageEditProperties)c.PropertiesEdit).ImageWidth = 80;
                   c.Caption = "";
               });
               settings.Columns.Add("Category");
               settings.Columns.Add("Instt");
               settings.Columns.Add("Financial_Year");
               settings.Columns.Add("Entries_Available");

               settings.Columns.Add(column =>
               {
                   column.FieldName = "LinkURL";
                   column.Caption = "Details";
                   column.SetDataItemTemplateContent(container =>
                   {
                       Html.DevExpress().HyperLink(hyperlink =>
                       {
                           var visibleIndex = container.VisibleIndex;
                           var keyValue = container.KeyValue;
                           var Category = DataBinder.Eval(container.DataItem, "Category");
                           var Instt = DataBinder.Eval(container.DataItem, "Instt");

                           hyperlink.Name = "hl" + keyValue.ToString();
                           hyperlink.Properties.Text = "Click here to Start Vouching";
                           hyperlink.NavigateUrl = "#";
                           hyperlink.Attributes.Add("onclick", "openVouchingAudit('"+Instt+ "','" + Category + "'); return false;");
                       }).Render();
                   });
               });
               settings.CardLayoutProperties.ColCount = 2;
               settings.CardLayoutProperties.Items.Add(i =>
               {
                   i.ColumnName = "PhotoUrl";
                   i.ShowCaption = DefaultBoolean.False;
                   i.RowSpan = 5;
                   i.VerticalAlign = FormLayoutVerticalAlign.Middle;
               });
               settings.CardLayoutProperties.Items.Add("Category");
               settings.CardLayoutProperties.Items.Add("Instt").Caption = "Institution";
               settings.CardLayoutProperties.Items.Add("Financial_Year").Caption = "Financial Year";
               settings.CardLayoutProperties.Items.Add("Entries_Available").Caption = "Entries";
               settings.CardLayoutProperties.Items.Add("LinkURL").ShowCaption=DefaultBoolean.False;

               //settings.FormatConditions.AddTopBottom("Entries_Available", GridTopBottomRule.BottomItems, GridConditionHighlightFormat.BoldText);
               //settings.FormatConditions.AddTopBottom("Entries_Available", GridTopBottomRule.BottomItems, GridConditionHighlightFormat.GreenText);
               //settings.FormatConditions.AddTopBottom("Price", GridTopBottomRule.TopItems, GridConditionHighlightFormat.BoldText);
               //settings.FormatConditions.AddTopBottom("Price", GridTopBottomRule.TopItems, GridConditionHighlightFormat.RedText);

               //settings.FormatConditions.AddIconSet("Baths", GridConditionIconSetFormat.Arrows3Colored);
               //settings.FormatConditions.AddIconSet("Beds", GridConditionIconSetFormat.Arrows3Colored);

               //settings.FormatConditions.AddTopBottom("HouseSize", GridTopBottomRule.TopItems, GridConditionHighlightFormat.GreenText).Threshold = 5;
               //settings.FormatConditions.AddTopBottom("HouseSize", GridTopBottomRule.BottomItems, GridConditionHighlightFormat.RedText).Threshold = 5;

               settings.Settings.ShowHeaderPanel = false;
               settings.SettingsPager.SettingsTableLayout.ColumnCount = 2;
           }).Bind(Model).GetHtml()
            </div>
        </div>  <!-- main content left end -->

        <div class="col-sm-12 col-md-3 clearfix no-padding">
