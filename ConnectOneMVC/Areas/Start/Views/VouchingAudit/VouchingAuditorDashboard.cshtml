<script>
    function openVouchingAudit(InsttID, Category) {
        var Category_Param = Category.replace(" ", "_");
        OpenTabControl('VouchingScreenName', 'Vouching Screen', '@Url.Action("VouchingScreen", "VouchingAudit")' + "?InsttID=" + InsttID + "&Vouching_Category=" + Category_Param + "");
        //OpenDynamicPopup('Accounts Submission', '/Start/AccountSubmission/Frm_Submit_Accounts', 460, 680);
    }
</script>