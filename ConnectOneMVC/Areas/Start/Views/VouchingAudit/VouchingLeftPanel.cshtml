@using DevExtreme.AspNet.Mvc;
@using System.Web.UI.WebControls;


@Html.DevExpress().DockZone(
       settings => {
           settings.Name = "dockZone1";
           settings.ZoneUID = "leftZone";
           settings.ControlStyle.CssClass = "leftZone";
           settings.Width = Unit.Percentage(100);
           settings.PanelSpacing = 3;
       }
   ).GetHtml()
@Html.DevExpress().DockPanel(
       settings => {
           settings.Name = "mailPanel";
           settings.PanelUID = "Mail";
           settings.OwnerZoneUID = "leftZone";
           settings.HeaderText = "Mail";
           settings.AllowResize = true;
           settings.VisibleIndex = 0;
           settings.Height = Unit.Percentage(100);
           settings.SetContent(() => {
               Html.RenderPartial("MailWidgetPartial");
           });
       }
   ).GetHtml()
@Html.DevExpress().DockPanel(
    settings => {
        settings.Name = "tradingPanel";
        settings.PanelUID = "Trading";
        settings.OwnerZoneUID = "leftZone";
        settings.HeaderText = "Trading";
        //settings.Width = 400;
        settings.AllowResize = true;
        settings.ShowOnPageLoad = false;
        settings.SetContent(() => {
            Html.RenderPartial("TradingWidgetPartial");
        });
    }
).GetHtml()
<script>
    function PopupVoucher() {
        $("#Vouching_Inner_Popup").dxPopup("show");
        $("#Vouching_Inner_Popup").dxPopup("instance").option("title", "View ~Donation")
        ShowLoader();
        $("#Vouching_Inner_Popup").dxPopup("instance").option("width", "80vw");
        $("#Vouching_Inner_Popup").dxPopup("instance").option("height", "80vh");
        $("#result_Vouching_Inner_Popup").load("@Url.Action("Frm_Voucher_Win_Donation_R", "DonationVoucher", new {@area= "Account" })?Tag=_View&xID=" + EntryID, function () {
            HideLoader();
        });
    }
    function CallforVouchingScreenFunction() {
           $("#Productioninnergrid").dxPopup("instance").option("width", "500");
           $("#Productioninnergrid").dxPopup("instance").option("height", "500");
           $("#Productioninnergrid").dxPopup("instance").option("shading", false);
    }
</script>