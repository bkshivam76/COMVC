@using DevExtreme.AspNet.Mvc;
@using System.Web.UI.WebControls;
@model ConnectOneMVC.Areas.Start.Models.VouchingAuditModel
@*@RenderPage("~/Areas/Account/Views/Frm_Donation_Register.cshtml")*@
@Html.Partial("~/Areas/Account/Views/DonationRegister/Frm_Donation_Register_Grid.cshtml", Model.DonationData)
@(Html.DevExtreme().Button().ID("BUT_Start_vouching").Text("Start Audit").Icon("doc").OnClick(@<text>function () {Start_Audit()}</text>))
@(Html.DevExtreme().Button().ID("BUT_Stop_vouching").Text("Stop Audit").Icon("doc").OnClick(@<text>function () {Stop_Audit()}</text>))
<script>
    function Start_Audit() {
        var leftpane = splResizing.GetPaneByName("listBoxContainer");
        var midPane = splResizing.GetPaneByName("midBoxContainer");
        var rightPane = splResizing.GetPaneByName("gridContainer");
        leftpane.Expand(midPane); 
        rightPane.Expand(midPane);
    }
    function Stop_Audit(s,e) {
        var leftpane = splResizing.GetPaneByName("listBoxContainer");
        var midPane = splResizing.GetPaneByName("midBoxContainer");
        var rightPane = splResizing.GetPaneByName("gridContainer");
        leftpane.Collapse(midPane); 
        rightPane.Collapse(midPane);
    }
</script>