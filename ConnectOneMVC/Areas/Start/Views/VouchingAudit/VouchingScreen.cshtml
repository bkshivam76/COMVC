@using DevExtreme.AspNet.Mvc;
@using System.Web.UI.WebControls;
@using ConnectOneMVC.Areas.Start.Controllers;
@model ConnectOneMVC.Areas.Start.Models.VouchingAuditModel


<style>
    /*.dxeImage{height:300px !important;}*/

    @@media only screen and (max-width:768px) {
        #Vouching table > tbody > tr {
            display: flex !important;
            flex-direction: column !important;
        }

        #Vouching #splResizing_0, #splResizing_0_CC {
            width: 90vw !important;
            height: 55vh !important;
        }

        #splResizing_1i0_CC {
            width: 90vw !important;
        }

        #splResizing_1_S {
            display: none;
        }
    }

    @@media only screen and (max-width:480px) {
        #Vouching #splResizing_0, #splResizing_0_CC {
            height: 70vh !important;
        }
    }

    @@media screen and (max-device-width: 560px) and (orientation:landscape) {
        #Vouching #splResizing_0, #splResizing_0_CC {
            height: 90vh !important;
        }
    }
</style>
<script type="text/javascript">
    function ShowWidgetPanel(widgetPanelUID) {
        var panel = dockManager.GetPanelByUID(widgetPanelUID);
        panel.Show();
    }
    function SetWidgetButtonVisible(widgetName, visible) {
        if (!visible)
            $('#widgetButton_' + widgetName).addClass('disabled')
        else
            $('#widgetButton_' + widgetName).removeClass();
    }
</script>

@using (Ajax.BeginForm("VouchingScreen", "VouchingAudit", new AjaxOptions
{
    HttpMethod = "POST",
    UpdateTargetId = "VouchingAuditWindow",
    InsertionMode = InsertionMode.Replace,
    OnSuccess = "VouchingAuditSuceess",
    OnBegin = "AjaxBeginFormPost"
},
            new
            {
                id = "VouchingAuditvalidationForm",
            }))
{
    @Html.HiddenFor(x => x.VF_ENTRY_ID)
    @Html.HiddenFor(x => x.Curr_Attachment_File_Name)
    @Html.HiddenFor(x => x.VF_Vouching_Status)
    @Html.HiddenFor(x => x.VF_Instt_Code)
    @Html.HiddenFor(x => x.VF_Category)

    @Html.DevExpress().Splitter(
                settings =>
                {
                    settings.Name = "splResizing";
                    settings.Height = 1000;
                    settings.Width = Unit.Percentage(100);
                    settings.Styles.Pane.Paddings.Padding = 0;

                    settings.Panes.Add(listBoxPane =>
                    {
                        listBoxPane.Name = "listBoxContainer";
                        listBoxPane.Size = Unit.Percentage(25);
                        listBoxPane.ShowCollapseBackwardButton = DefaultBoolean.True;
                        listBoxPane.ShowCollapseForwardButton = DefaultBoolean.True;
                        listBoxPane.SetContent(() =>
                        {
                            @Html.RenderPartial("VouchingLeftPanel", Model);
                        });
                    });
                    settings.Panes.Add(listBoxPane =>
                    {
                        listBoxPane.Name = "midBoxContainer";
                        listBoxPane.Size = Unit.Percentage(35);
                        listBoxPane.ShowCollapseBackwardButton = DefaultBoolean.True;
                        listBoxPane.ShowCollapseForwardButton = DefaultBoolean.True;
                        listBoxPane.SetContent(() =>
                        {
                            @Html.RenderPartial("VouchingMidPanel", Model);
                        });
                    });
                    settings.Panes.Add(contentPane =>
                    {
                        contentPane.Size = Unit.Percentage(40);
                        contentPane.Name = "gridContainer";
                        contentPane.ShowCollapseBackwardButton = DefaultBoolean.True;
                        contentPane.ShowCollapseForwardButton = DefaultBoolean.True;
                        contentPane.SetContent(() =>
                        {
                            @Html.RenderPartial("VouchingRightPanel", Model);
                        });
                    });

                    settings.ClientSideEvents.PaneResized = "OnSplitterPaneResized";
                    settings.PreRender = (sender, e) =>
                    {
                        if (ASPxWebControl.GlobalTheme.Contains("Metropolis"))
                            ((MVCxSplitter)sender).Styles.Pane.CssClass = "metropolisPane";
                        else if (ASPxWebControl.GlobalTheme.Contains("Youthful"))
                            ((MVCxSplitter)sender).Styles.Pane.CssClass = "youthfulPane";
                        else
                            ((MVCxSplitter)sender).Styles.Pane.CssClass = string.Empty;
                    };
                }).GetHtml()


    @Html.DevExpress().DockManager(
    settings => {
        settings.Name = "dockManager";
        settings.ClientSideEvents.PanelShown = "function(s, e) { SetWidgetButtonVisible(e.panel.panelUID, false) }";
        settings.ClientSideEvents.PanelCloseUp = "function(s, e) { SetWidgetButtonVisible(e.panel.panelUID, true) }";
    }
).GetHtml()
    @Html.DevExpress().DockPanel(
        settings => {
            settings.Name = "dateTimePanel";
            settings.PanelUID = "DateTime";
            settings.HeaderText = "Attachment";
            //settings.Left = 820;
            //settings.Top = 220;
            settings.AllowResize = true;
            settings.OwnerZoneUID = "rightZone";
           // settings.Width = 600;
            settings.SetContent(() => {
                Html.RenderPartial("DateTimeWidgetPartial");
            });
        }
    ).GetHtml()
    @Html.DevExpress().DockPanel(
        settings => {
            settings.Name = "weatherPanel";
            settings.PanelUID = "Weather";
            settings.HeaderText = "Weather";
           // settings.Width = 275;
            settings.OwnerZoneUID = "midZone";
            settings.VisibleIndex = 0;
            settings.AllowResize = true;
            settings.ShowOnPageLoad = false;
            settings.SetContent(() => {
                Html.RenderPartial("WeatherWidgetPartial");
            });
        }
    ).GetHtml()


    <div class="widgetPanel">
        @foreach (string widget in WidgetsDemoHelper.GetWidgets())
        {
            @Html.DevExpress().Image(
                settings => {
                    settings.Name = "widgetButton_" + widget;
                    settings.ImageUrl = Url.Content(string.Format("~/Content/image/back-to-bank.jpg", widget));
                    settings.ControlStyle.Cursor = "pointer";
                    settings.ToolTip = "Show " + widget;
                    settings.Properties.ClientSideEvents.Click = string.Format("function(s, e) {{ ShowWidgetPanel('{0}') }}", widget);
                }
            ).GetHtml()
        }
    </div>


}

