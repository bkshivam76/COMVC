    function Vouching_Accept_click(e) {
        var result = e.validationGroup.validate();
        var form = $("#VouchingAuditvalidationForm");
        if (result.isValid) {
            $("#VF_Vouching_Status").val("Accepted");
            form.submit();
        }
    }
    function Vouching_Reject_click(e) {
        var result = e.validationGroup.validate();
        var form = $("#VouchingAuditvalidationForm");
        if (result.isValid) {
            $("#VF_Vouching_Status").val("Rejected");
            form.submit();
        }
    }
    function Vouching_Skip_click(e) {
        var result = e.validationGroup.validate();
        var form = $("#VouchingAuditvalidationForm");
        if (result.isValid) {
            $("#VF_Vouching_Status").val("Skipped");
            form.submit();
        }
    }
