@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid()
    .ID("Frm_Profile_Win_opening_GLookUp_TelePhonebillList_datagrid")
    .DataSource(new JS(@"component.option(""dataSource"")"))
    .Columns(columns =>
    {

        columns.Add().DataField("TP_NO").Caption("TelePhoneNo").SortOrder(SortOrder.Asc).Width(125);
        columns.Add().DataField("TP_COMPANY").Caption("Company").Width(125);
        columns.Add().DataField("TP_CATEGORY").Caption("Category").Width(125);
        columns.Add().DataField("TP_TYPE").Caption("PlanType").Width(125);
        columns.Add().DataField("TP_ID").Caption("ID").Width(0).Visible(false);
        //columns.Add().DataField("BANK_ACC_NO").Caption("Account No.").Width(50);
        //columns.Add().DataField("REC_EDIT_ON").Caption("REC_EDIT_ON").Width(0).Visible(false);

    })
    .HoverStateEnabled(true)
    .Paging(p => p.PageSize(100))
    .FilterRow(f => f.Visible(true))
    .Scrolling(s => s.Mode(GridScrollingMode.Infinite))
    .Height(300)
    .Selection(s => s.Mode(SelectionMode.Single))
    .OnSelectionChanged(@<text>
        function(selectedItems) {

        var keys = selectedItems.selectedRowKeys;
        component.option("value", keys);
        }
    </text>)
)




