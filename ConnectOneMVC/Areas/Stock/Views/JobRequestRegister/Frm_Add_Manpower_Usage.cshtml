<link href="/content/fontawesome/css/fontawesome-all.css" rel="stylesheet">
<div id="Frm_Job_Actual_Manpower_Usage_Popup" class="col-md-12">
    @using (Ajax.BeginForm("Frm_Add_Manpower_Usage", "JobRequestRegister",
