                        <div class="col-sm-4 col-md-4 col-lg-4 paddLR5">
                            <div class="dx-texteditor dx-widget dx-textbox">
                                <div class="dx-texteditor-container">
                                    @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("Job_ManpowerID").Name("Job_ManpowerID").Value(Model.Job_ManpowerID).ValueExpr("ID").DisplayExpr("Name")
                                                                                                  .DataSource(d => d.Mvc().Controller("JobRequestRegister").LoadAction("LookUp_Get_Person_Names").Key("ID"))
                                                                                                  .Placeholder("Select Name").ReadOnly(IsVisible).Disabled(IsVisible).OnValueChanged("Get_Person_Names_ChangeEvent").OnInitialized("Init_Get_Person_Names_ChangeEvent").ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).ContentTemplate(@<text> @Html.Partial("LookUp_Get_Person_Names") </text>))
                                    @Html.ValidationMessageFor(model => model.Job_PersonName, "", new { @class = "text-danger" })
                                </div>
                            </div>
                        </div><!--[Manpower]-->
                        <div class="col-sm-6 col-md-6 col-lg-6 prm pll">
                            @(Html.DevExtreme().Button()
                                                                                                                                                                                                .ID("Job_Add_Person_Type")
                                                                                                                                                                                                .Text("Add Person")
                                                                                                                                                                                                .Disabled(IsVisible)
                                                                                                                                                                                                .OnClick(@<text>
                                                                                                                                                                                                    function () {
                                                                                                                                                                                                    Job_manpower_addpersonnel()
                                                                                                                                                                                                    }
                                                                                                                                                                                                </text>))
                        </div>
                    </div>
                </div>
            </div> <!--[Manpower]-->
            <div class="row">
                <div class="form-field">
                    <div class="container-fluid pll prm">
                        <div class="row">
                            <div class="col-sm-2 col-md-2 col-lg-2 paddLR5">
                                <label class="control-label text-red" for="Name">Period From:</label>
                            </div>
                            <div class="col-sm-4 col-md-4 col-lg-4 paddLR5">
                                <div class="dx-texteditor dx-widget dx-textbox">
                                    <div class="dx-texteditor-container">
                                        @(Html.DevExtreme().DateBoxFor(model => model.Job_W_PeriodFrom).CustomDateBox().ID("Job_W_PeriodFrom").Name("Job_W_PeriodFrom")
                                                                                                                                              .OnValueChanged("Get_Units_Rate_ChangeEvent").ReadOnly(IsVisible).Disabled(IsVisible).ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).Placeholder("Work Period From") )
                                        @Html.ValidationMessageFor(model => model.Job_W_PeriodFrom, "", new { @class = "text-danger" })
                                    </div>
