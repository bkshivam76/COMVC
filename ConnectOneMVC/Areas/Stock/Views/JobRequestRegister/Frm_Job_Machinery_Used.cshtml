</div>

<script type="text/javascript">


        function OnJob_Machine_NameChanged(e) {
            var dropdown = $("#Job_Machine_NameID").dxDropDownBox("instance");
            dropdown.close();
            if (e.previousValue!=null&&e.previousValue != e.value)
            {
                $("#Job_Machine_Usage_Hours").dxNumberBox("instance").reset();
                $("#Job_Machine_Count").dxNumberBox("instance").option("value", 1);//0000135 bug fixed
            }
            var $dataGrid = $("#JobLookUp_Machine_List_datagrid");
            if ($dataGrid.length) {
                var dataGrid = $dataGrid.dxDataGrid("instance");
                dataGrid.selectRows(dropdown.option("value"), false);
                if (dataGrid.getSelectedRowsData().length > 0) {
                     var item = dataGrid.getSelectedRowsData()[0];
                   var MCode = item.Item_Code;
                   var macname = item.Item_Name;
                    $("#Job_Machine_No").dxTextBox("instance").option("value", MCode);
                    $("#Job_Machine_Name").val(macname)
                    $("#Job_Machine_Curr_Qty").val(item.Curr_Qty);
                }
            }
        }
        function OnInitialized_JobOnMachine_NameChanged(e)
        {
            if ("@Model.Job_Machine_ActionMethod" != "New")
            {
                var machinenameid="@Model.Job_Machine_NameID";
                $("#Job_Machine_NameID").dxDropDownBox("instance").option("value","@Model.Job_Machine_NameID");
                e.component.option("dataSource").store.load().done(function (d) {
                    if (d.length > 0) {
                        var $dataGrid = $("#JobLookUp_Machine_List_datagrid");
                        if ($dataGrid.length) {
                            var dataGrid = $dataGrid.dxDataGrid("instance");
                            dataGrid.selectRows(machinenameid, false);
                        }
                    }
                });
            }
            if ("@Model.Job_Machine_ActionMethod" == "New")
            {
                e.component.option("dataSource").store.load().done(function (d) {
                    if (d.length ==1) {
                        var $dataGrid = $("#JobLookUp_Machine_List_datagrid");
                        if ($dataGrid.length) {
                            var dataGrid = $dataGrid.dxDataGrid("instance");
                            dataGrid.selectRowsByIndexes(0);
                        }
                    }
                });
            }
        }
    function OnFrm_Job_View_Past_Usage_Click() {
        if (!($("#Job_Machine_NameID").dxDropDownBox("instance").option("value")))
        {
            DevExpress.ui.dialog.alert("Select A Machine...!", 'Inform!')
            return;
        }
            DevExpress.ui.dialog.alert("Coming soon...!", 'Inform!');
        }
</script>

<script>
    $(document).ready(function ()
    {
        var form = "ID_Job_Frm_Machine_Window";
        ShowLoader();
        AssignIDtoLabel(form, "jobMachineUsed");
        setTimeout(function ()
        {
            Set_Form_View_Delete_Mode(null, form, "@Model.Job_Machine_ActionMethod");
            Focus_FirstEditable_Field(form, "@Model.Job_Machine_ActionMethod");
            HideLoader();
        }, Timeout500);
    })

</script>