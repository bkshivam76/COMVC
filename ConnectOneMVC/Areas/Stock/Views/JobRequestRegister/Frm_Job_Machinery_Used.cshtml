                                            <div class="dx-texteditor-container">
                                                @(Html.DevExtreme().TextBoxFor(x => x.Job_Machine_No).CustomTextBox().ID("Job_Machine_No").Name("Job_Machine_No").ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).Placeholder("Item Code").ReadOnly(true).Disabled(IsVisible) )
                                            </div>
