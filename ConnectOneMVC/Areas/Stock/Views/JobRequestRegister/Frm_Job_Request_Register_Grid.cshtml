        {
            if (e.MenuType == GridViewContextMenuType.Rows)
            {
                var New = e.CreateItem("New", "New");
                New.Image.IconID = "actions_new_16x16gray";
                if (Job_AddRight) e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), New);

                var Edit = e.CreateItem("Edit", "Edit");
                Edit.Image.IconID = "actions_edit_16x16devav";
                if (Job_UpdateRight) e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Edit);

