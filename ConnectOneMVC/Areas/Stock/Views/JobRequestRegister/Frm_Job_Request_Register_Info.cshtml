        function Job_RegisterAdjustSize() {
            var height = (document.documentElement.clientHeight * 90) / 100;
            JobRequestRegisterListGrid.SetHeight(height);
        }
        function JobRegisterOnInit(s, e)
        {
           Job_RegisterAdjustSize();
            ASPxClientUtils.AttachEventToElement(window, "resize", function (evt)
            {
                Job_RegisterAdjustSize();
            });
            s.SetFocusedRowIndex(-1);
    }
    var JobGridFocusedIndex;
        function JobRegisterGrid_BeginCallBack(s, e)
        {
            e.customArgs["command"] = e.command;
            if (e.command == "REFRESH")
            {
                isJobGridRefresh = true;//1253 bug fix
                JobGridFocusedIndex = s.GetFocusedRowIndex();//1253 bug fix
            }
            e.customArgs["ShowHorizontalBar"] = JobRR_Master_ShowHorizontalBar;
        }
        function JobRegisterGrid_EndCallBack(s, e)
        {
            Job_RegisterAdjustSize();
            if (isJobGridRefresh)//1253 bug fix
            {
                isJobGridRefresh = false;//1253 bug fix
                s.SetFocusedRowIndex(-1);//1253 bug fix
                s.SetFocusedRowIndex(JobGridFocusedIndex);//1253 bug fix
            }
            SendCustomArgs_FilterControl(s, e);
        }
        function JobRegisterGridFocusedRowChanged(s, e)
        {          
            if (s.GetFocusedRowIndex() == -1)
            {
                Job_ID = 0;
                JobRRAddedBy = null;
                JobRRAddedOn = null;
                JobRREditedBy = null;
                JobRREditedOn = null;
                JobStatus = null;
                JobCurrUserRole = null;
            }
            else
            {
                Job_ID = s.GetRowKey(s.GetFocusedRowIndex());
                s.GetValuesOnCustomCallback({ key: Job_ID }, Job_Request_RegisterGetRowValues);
            }
        }
    function Job_Request_RegisterGetRowValues(Data) {
        //mantis #1499
        if (Data != "") { 
            var values = Data.split("![");
            JobRRAddedBy = values[2];
            JobRRAddedOn = values[3];
            JobRREditedBy = values[0];
            JobRREditedOn = values[1];
            JobStatus = values[4];
            if (values[5] != "") //mantis #1499
            {
                JobCurrUserRole = (values[5].split(','));
                for (var i = 0; i < JobCurrUserRole.length; i++) {
                    JobCurrUserRole[i] = JobCurrUserRole[i].trim();
                }
            }
            JobRequestor = values[6];
            JobRegister_UpdateFooterDetail(JobRRAddedOn, JobRRAddedBy, JobRREditedBy, JobRREditedOn);
        }
    }
        function JobRegister_UpdateFooterDetail(Addon, Addby, Editby, Editon)
