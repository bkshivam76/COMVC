                }
                else {
                    Lbl_Create = "Add On: " + "?, Add By: " + Addby;
                }
            if (Editon) {
                    Lbl_Modify = "Edit On: " + Editon + ", Edit By: " + Editby;
                }
                else {
                    Lbl_Modify = "Edit On: " + "?, Edit By: " + Editby;
                }
            $('#JobRRLbl_Create').text(Lbl_Create);
            $('#JobRRLbl_Modify').text(Lbl_Modify);
            }
