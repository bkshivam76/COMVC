<script>
    function LookUp_ViewType_ChangeEvent_JRR(e)
    {
        var SelectBox = $("#JobRRPeriodSelection").dxSelectBox("instance").option("value");
        $("#JobRRChangePeriodMain").dxButton("instance").option("disabled", true);
        if (SelectBox == "Specific Period") {
            $("#JobRRChangePeriodMain").dxButton("instance").option("disabled", false);
            $("#JobRR_View_Period").dxTextBox("instance").option("value", "");
            JobChangePeriodinLayout();
        }
        else {
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Stock/JobRequestRegister/LookUp_ViewType_ChangeEvent_JRR",
                data: { Chaval: $("#JobRRPeriodSelection").dxSelectBox("instance").option("value") },
                cache: false,
                success: function (data)
                {
                    if (data.result == true)
                    {
                        $("#JobRR_View_Period").dxTextBox("instance").option("value", data.Message.JobRR_BE_View_Period);

                        var fromdate = ConvertJsonDateToString(data.Message.JobRR_Fromdate);
                        var todate = ConvertJsonDateToString(data.Message.JobRR_Todate);

                        ShowLoader();
                        JobRequestRegisterListGrid.Refresh();
                        @*$("#JobRRPartialView").load("@Url.Action("Frm_Job_Request_Register_Info", "JobRequestRegister", new { @area = "Stock" })?FromDate=" +fromdate + "&Todate=" + todate + "&ChangeStatus=False", function () {
                            HideLoader();
                        });*@
                        HideLoader();
                    }
                }
            });
            HideLoader();
        }
    }//Period Selection
    function JobChangePeriodinLayout()
    {
   
        ShowLoader();
 
        OpenDynamicPopup("Change Period", "@Url.Action("Frm_Change_Period_Screen_JRR", "JobRequestRegister", new { @area = "Stock" })", "auto", "45%", false, null);
    }

</script>
