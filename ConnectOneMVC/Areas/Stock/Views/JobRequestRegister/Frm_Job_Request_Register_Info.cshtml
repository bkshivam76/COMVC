    function Job_datanavigation(_actionmethod)
    {
        if (!_actionmethod) { _actionmethod = null; }
        var msg;
        var result;
        $.ajax({
            type: 'GET',
            async:false,
            url: "/Stock/JobRequestRegister/DataNavigation",
            data: {
                jobid: Job_ID,
                actionmethod: _actionmethod
            },
            cache: false,
            success: function (data)
            {
                msg = data.Message;
                result = data.result;
            }
        });

        return [msg, result];
    }
    function Job_StatusFlowCheck(Status)
    {        
        var msg;
        var result;
        $.ajax({
            type: 'POST',
            url: "/Stock/JobRequestRegister/JobRequestStatusFlow",
            data: {
                JobId: Job_ID,
                StatusButton: Status,
                CurrUserRole: JobCurrUserRole
            },
            async: false,
            cache: false,
            success: function (data) {
                msg = data.message;
                result = data.result;
            }
        });
        return [msg, result];
    }

