    function JobRequestRegisterPreviewClick() {
        if (!JobRRExportright) {
            DevExpress.ui.dialog.alert("Not Allowed", 'No Rights');
            return;
        }
        $("#JobRequestRegister_report_modal").dxPopup("show");
        $("#JobRequestRegister_report_modal").dxPopup("instance").option("title", "Export Option");
        $("#id_JobRequestRegister_Result").html('');
        ShowLoader();
        $("#id_JobRequestRegister_Result").load("@Url.Action("Frm_Export_Options", "JobRequestRegister", new { @area = "Stock" })", function () {
            HideLoader();
        });
    }//preview click
    
    function JobRegisterContextMenuFunction(s, e)
        {
          if (e.item.name == 'New')
          {
              jRR_NEVD_Click_New();
          }
          else if (e.item.name == 'Close')
          {
              btnCloseActiveTab();
          }
         else if (e.item.name == 'Edit')
         {
              jRR_NEVD_Click_Edit();
         }
         else if (e.item.name == 'Delete')
          {
              jRR_NEVD_Click_Delete();
         }
          else if (e.item.name == 'View')
          {
              jRR_NEVD_Click_View();
          }
         else if (e.item.name == 'ListPreview')
         {
                JobRequestRegisterPreviewClick();
         }
          else if (e.item.name == 'QuickJob') {
              jobrrQuickjob();
          }
          else if (e.item.name == 'MarkComplete')
          {
              UpDateJobStatus("Complete");
          }
          else if (e.item.name == 'Addexp')
          {
              jobrrAddExpenses();
          }
          else  if (e.item.name == 'Addmachine')
          {
              jobrrAddMachine();
          }
          else if (e.item.name == 'Adddocuments')
          {
              jobrrAddDocuments();
          }
          else if (e.item.name == 'Addmanpower')
          {
              Job_Context_Menu_AddManpowerUsage = true;//Mantis bug 0000541 fixed
              jobrrAddManpower();
          }
          else if (e.item.name == 'postmanhr')
          {
              jobrrPostmanhr();
          }
          else if (e.item.name == 'jobcard')
          {
              jobrrJobCard();
          }
          else if (e.item.name == 'jobcost')
          {
              jobrrJobCost();
          }
         else if (e.item.name == 'Refresh')
         {
           JobRequestRegisterListGrid.Refresh();
         }

    }
