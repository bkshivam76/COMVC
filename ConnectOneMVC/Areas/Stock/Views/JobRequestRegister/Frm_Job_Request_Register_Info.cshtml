    function OnJobRequestRegisterAjaxSuccessForm(data) {

        HideLoader();
        dontaskpopupcloseconfirmation = true;
        if (data.result == true) {
            DevExpress.ui.dialog.alert(data.message, "Inform");
            if (JobIsEditPopup == true) {
                JobIsEditPopup = false;
                if (JobStatus == "Changes Recommended") {
                    if (data.isRequestor == true) {
                        var result = DevExpress.ui.dialog.confirm("Do You Want To Re-open The Job", "Change Status");
                        result.done(function (dialogResult) {
                            if (dialogResult) {
                                $.ajax({
                                    type: 'GET',
                                    url: "/Stock/JobRequestRegister/JobStatusToNew",
                                    cache: false,
                                    async: false,
                                    data: {
                                        jobid: Job_ID
                                    },
                                    success: function (check) {
                                        if (check.result == false) {
                                            DevExpress.ui.dialog.alert(check.message, "Error")
                                        }
                                        else {
                                            DevExpress.ui.dialog.alert(check.message, "Inform")
                                        }
                                    }
                                });
                            }
                        }
                        );
                    }
                }
            }
            $("#Dynamic_Content_popup").dxPopup("hide");
            $("#result_Dynamic_Content_popupJRR").html(null);
            $("#popup_frm_quick_JRR").dxPopup("hide");
            $("#jobvalidationForm").remove();
            $("#quickJobvalidationForm").remove();
                    JobRequestRegisterListGrid.Refresh();

                }
                if (data.result == false) {
                    DevExpress.ui.dialog.alert(data.message, "Inform");
                }
            }


