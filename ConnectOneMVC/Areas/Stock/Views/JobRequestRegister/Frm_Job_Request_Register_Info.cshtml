<script>

    function UpDateJobStatus(Status_Button)
    {        

        if (!Job_ID)
        {
            DevExpress.ui.dialog.alert("Please Select A Job...!", 'alert!');
            return;
        }
        else
        {
            var statusflowcheck = Job_StatusFlowCheck(Status_Button);
            if (statusflowcheck[1] == false) {
                DevExpress.ui.dialog.alert(statusflowcheck[0], "Error");
                return;
            }

            var Status_Msg = "";

            switch (Status_Button) {
                case "Estimation_Submission":
                    Status_Msg = "Do You Want To Assign For Estimate Submission ?";
                    break;
                case "Reopen_Job":
                    Status_Msg = "Do You Want To Re-Open The Job ?";
                    break;
                case "Estimate_Approval":
                    Status_Msg = "Do You Want To Submit For Estimate_Approval ?";
                    break;
                case "Changes Recommended":
                    Status_Msg = "Do You Want To Suggest Changes ?";
                    break;
                case "Approve":
                    Status_Msg = "Do You Want To Approve The Job Or Estimate ?";
                    break;
                case "Reject":
                    Status_Msg = "Do You Want To Reject The Job ?";
                    break;
                case "Cancel":
                    Status_Msg = "Do You Want To Cancel The Job?";
                    break;
                case "Complete":
                    Status_Msg = "Do You Want To Mark Job As Completed ?";
                    break;
                default:
                    Status_Msg = "";
                    break;
            }
            if (Status_Msg != "") {
                var result = DevExpress.ui.dialog.confirm(Status_Msg, "Confirm Changes");
                result.done(function (dialogResult) {
                    if (dialogResult) {
                        if (Status_Button != "Approve" && Status_Button != "Estimation_Submission" && Status_Button != "Estimate_Approval" && Status_Button != "Reopen_Job") {
                            $.ajax({
                                type: "POST",
                                url: "/Stock/JobRequestRegister/Job_StatusChange_Check",
                                data: {
                                    JobId: Job_ID,
                                    StatusButton: Status_Button
                                },
                                async: false,
                                success: function (data) {


                                    if (data.result == true) {                                    
                                        ShowLoader();
                                        $.ajax({
                                            type: 'GET',
                                            url: "/Stock/JobRequestRegister/Job_StatusChange_Window",
                                            cache: false,
                                            data:
                                            {
                                                JobId:Job_ID,
                                                StatusButton: Status_Button
                                            },
                                            success: function (data)
                                            {
                                                OpenDynamicPopup("Job ~ " + Status_Button, null, "auto", "40%", true, data);     
                                                HideLoader();
                                            }
                                        });//0000148 Bug fixed
                                        HideLoader();
                                    }
                                    else {
                                        DevExpress.ui.dialog.alert(data.message, 'Error');
                                    }
                                }
                            });
                        }
                        else {
                            ShowLoader();
                            $.ajax({
                                type: "POST",
                                url: "/Stock/JobRequestRegister/Job_StatusChange",
                                data: {
                                    JobId: Job_ID,
                                    StatusButton: Status_Button,
                                    userRole:JobCurrUserRole
                                },
                                success: function (data)
                                {                                    
                                    if (data.result == true)
                                    {
                                        HideLoader();
                                        DevExpress.ui.dialog.alert(data.message, 'Inform!');
                                        JobRequestRegisterListGrid.Refresh();
                                    }
                                    else if (data.result == false)
                                    {
                                        HideLoader();
                                        DevExpress.ui.dialog.alert(data.message, 'Inform!');
                                    }
                                }
                            });
                        }
                    }
                });
            }
        }
    }
</script>
