        function jRR_NEVD_Click_New()
        {
            if (!JobRRNewright)
            {
                DevExpress.ui.dialog.alert("Not Allowed", 'No Rights');
                return;
            }      
            ShowLoader();
            $.ajax({
                type: "Get",
                url: "/Stock/JobRequestRegister/Frm_NEVD_Job_Request",
                data: {
                    ActionMethod: "New"
                },
                success: function (data)
                {                   
                        OpenDynamicPopup("New ~ Job Request", null, "auto", "90%", true, data);
                }
            });
        }
    function jRR_NEVD_Click_Edit() {
        if (!JobRREditright) {
            DevExpress.ui.dialog.alert("Not Allowed", 'No Rights');
            return;
        }
        if (!Job_ID) {
            DevExpress.ui.dialog.alert("Please Select A Row...!!", "Error");
            return;
            }

        if (JobStatus == "Completed") {
            DevExpress.ui.dialog.alert("Completed Job Cannot Be Edited..!!", "Error");
            return;
        }
        var check = Job_datanavigation();
        if (check[1] == false)
        {
            DevExpress.ui.dialog.alert(check[0], "Error");
            return;
        }
            var statusflowcheck = Job_StatusFlowCheck("Edit");
            if (statusflowcheck[1] == false) {
                DevExpress.ui.dialog.alert(statusflowcheck[0], "Error");
                return;
            }
            JobIsEditPopup = true;
 
            ShowLoader();
            $.ajax({
                type: "Get",
                url: "/Stock/JobRequestRegister/Frm_NEVD_Job_Request",
                data: {
                    ActionMethod: "Edit",

                    ID: Job_ID

                },
                success: function (data)
                {                    
                        OpenDynamicPopup("Edit ~ Job Request", null, "auto", "90%", true, data);
                }
            });
    }
