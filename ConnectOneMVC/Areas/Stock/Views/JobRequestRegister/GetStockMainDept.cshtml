@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                .ID("GetStockMainDept_Grid")
            
                .Columns(columns =>
                {

                    columns.Add().DataField("Name").Caption("Name");
                    columns.Add().DataField("InCharge_Name").Caption("InCharge Name");
                    columns.Add().DataField("Center").Caption("Center");
                    columns.Add().DataField("ID").Visible(false);
                    columns.Add().DataField("InCharge_ID").Visible(false);
                })
              
                .Selection(s => s.Mode(SelectionMode.Single))
                
)
