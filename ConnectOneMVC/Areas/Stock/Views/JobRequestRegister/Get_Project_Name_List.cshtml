@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                        .ID("GetProjectName_JRGrid")
                  
                        .Columns(columns =>
                        {

                            columns.Add().DataField("Project_Name").Caption("Project Name");
                            columns.Add().DataField("Project_Type").Caption("Type");
                            columns.Add().DataField("Complex_Name").Caption("Complex Name").Visible(true);
                            columns.Add().DataField("Sanction_no").Caption("Sanction_no").Visible(false);
                            columns.Add().DataField("Sanction_Date").Caption("Sanction Date").Visible(false);
                            columns.Add().DataField("Project_Id").Visible(false);
                            columns.Add().DataField("Complex_Id").Visible(false);
                        })
                     
                        .Selection(s => s.Mode(SelectionMode.Single))
                      
)


