@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                    .ID("GetRequestorNames_Grid")

                    .Columns(columns =>
                    {

                        columns.Add().DataField("Name").Caption("Name");
                        columns.Add().DataField("Skill_Type").Caption("Skill Type");
                        columns.Add().DataField("Main_Dept").Caption("Main Dept");
                        columns.Add().DataField("Sub_Dept").Caption("Sub Dept");

                        columns.Add().DataField("Type").Caption("Type").Visible(false) ;

                        columns.Add().DataField("ID").Visible(false);
                        columns.Add().DataField("Mobile_No").Visible(false);
                        columns.Add().DataField("Main_DeptID").Visible(false);
                        columns.Add().DataField("Sub_DeptID").Visible(false);
                    })

                    .Selection(s => s.Mode(SelectionMode.Single))
//mantis #1366
)


