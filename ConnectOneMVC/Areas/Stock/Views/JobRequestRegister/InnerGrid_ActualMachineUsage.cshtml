@model ConnectOneMVC.Areas.Stock.Models.Model_NEVD_JobRequest
@using DevExtreme.AspNet.Mvc;
@{
    bool IsVisible = (Model != null && Model.ActionMethod == "Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.ActionMethod == "View" || Model.ActionMethod == "Delete") ? true : false;
}
<fieldset id="jobmacusagegrid">
    <div class="row">
        <div class="col-md-12 ">
            @Html.Action("InnerGrid_ActualMachineUsageGrid", "JobRequestRegister", new { ActionMethodName = Model.ActionMethod, JobID = Model.Job_Id })
        </div>
    </div>
    <div class="row">
        <div class="form-field">
            <div class="container-fluid">
                <div class="col-md-12">
                        @(Html.DevExtreme().Button().ID("Job_BUT_MachNew").Text("New").Icon("fas fa-file btn-icons newfile icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Job_Machine_New_Click() } </text>))
                        @(Html.DevExtreme().Button().ID("Job_BUT_MachEdit").Text("Edit").Icon("fas fa-pencil-alt btn-icons editcolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Job_Machine_Edit_Click() } </text>))
                        @(Html.DevExtreme().Button().ID("Job_BUT_MachDelete").Text("Delete").Icon("fas fa-trash btn-icons deletecolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Job_Machine_Delete_Click() } </text>))
                        @(Html.DevExtreme().Button().ID("Job_BUT_MachView").Text("View").Icon("fas fa-eye btn-icons eyeicon icon-rgt-space5").Disabled(IsVisible).OnClick(@<text> function () { OnFrm_Job_Machine_View_Click() } </text>))
                </div>
            </div>
        </div>
    </div>
    </fieldset>
    <script>

    var JobMachineUsage_Sr;
    var JobMachineUsage_ID;
    function OnJobMachineDetailsGridFocusedRowChanged(s,e)
    {
        s.GetRowValues(s.GetFocusedRowIndex(), 'Sr;REC_ID', MachineUsageDetailsGridRowValues);
    }
    function MachineUsageDetailsGridRowValues(value) {
        JobMachineUsage_Sr = value[0];
        JobMachineUsage_ID = value[1];
    }
    $("#Job_Machine_Usage_Window_Grid").keydown(function (evt) {
        switch (evt.keyCode) {
            case 45: // insert key
                OnFrm_Job_Machine_New_Click();
                break;
            case 13: //enter key
                OnFrm_Job_Machine_Edit_Click();
                break;
            case 32: //space bar
                OnFrm_Job_Machine_View_Click();
                break;
            case 46://delete key
                OnFrm_Machine_Job_View_Click();
                break;
        }
        if (evt.ctrlKey && evt.keyCode == 73)//ctrl+i
        {
            OnFrm_Job_Machine_New_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 69)//ctrl+e
        {
            OnFrm_Job_Machine_Edit_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_Machine_Job_View_Click();
        }
    });
    function OnFrm_Job_Machine_New_Click()
    {
        if ("@IsDisabled" == "true") { return; }
        var statusflowcheck = Job_StatusFlowCheck();
        if (statusflowcheck[1] == false) {
            DevExpress.ui.dialog.alert(statusflowcheck[0], "Error");
            return;
        }
        ShowLoader();
        OpenPopup("Jobinnergrid", "New ~ Machine Usage", "@Url.Action("Frm_Job_Machinery_Used", "JobRequestRegister", new {@area= "Stock" })?ActionMethod=New", "auto", 1024, false, null);
    }//new click
    function OnFrm_Job_Machine_Edit_Click()
    {if ("@IsDisabled"=="true") { return; }
        if (!JobMachineUsage_Sr) {DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');return; }
        ShowLoader();
        OpenPopup("Jobinnergrid", "Edit ~ Machine Usage","@Url.Action("Frm_Job_Machinery_Used", "JobRequestRegister", new {@area= "Stock" })?ActionMethod=Edit&SrID=" + encodeURIComponent(JobMachineUsage_Sr), "auto", 1024, false, null);
          }//edit click
    function OnFrm_Job_Machine_Delete_Click()
    {
        if (!JobMachineUsage_Sr) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        var deleteResultPaymentDetail = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
        deleteResultPaymentDetail.done(function (dialogResult) {
            if (dialogResult) {
                $.ajax({
                    type: 'GET',
                    url: "/Stock/JobRequestRegister/Frm_MachineUsageDetail_Window_Delete_Grid_Record",
                    data: { ActionMethod: "Delete", SrID: JobMachineUsage_Sr, Rec_Id: JobMachineUsage_ID },
                    cache: false,
                    success: function (result) {
                        Job_Machine_Usage_Window_Grid.SetFocusedRowIndex(-1);
                        Job_Machine_Usage_Window_Grid.Refresh();
                    }
                });
            }
        });

    }
        function OnFrm_Job_Machine_View_Click()//0000136 bug fixed

        {
        if (!JobMachineUsage_Sr) { DevExpress.ui.dialog.alert('Please Select one row', 'Alert '); return; }

                    ShowLoader();
        OpenPopup("Jobinnergrid", "View ~ Machine Usage","@Url.Action("Frm_Job_Machinery_Used", "JobRequestRegister", new {@area= "Stock" })?ActionMethod=View&SrID=" + encodeURIComponent(JobMachineUsage_Sr), "auto", 1024, false, null);

        }//view click



    </script>
