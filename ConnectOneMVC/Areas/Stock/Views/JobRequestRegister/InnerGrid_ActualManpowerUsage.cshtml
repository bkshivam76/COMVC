@model ConnectOneMVC.Areas.Stock.Models.Model_NEVD_JobRequest
@using DevExtreme.AspNet.Mvc;
@{
    bool IsVisible = (Model != null && Model.ActionMethod == "Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.ActionMethod == "View" || Model.ActionMethod == "Delete") ? true : false;
}
<fieldset id="jobmanusagegrid">
    <div class="row">
        <div class="col-md-12">
            @Html.Action("InnerGrid_ActualManpowerUsageGrid", "JobRequestRegister", new { ActionMethodName = Model.ActionMethod, JobID = Model.Job_Id })
        </div>
    </div>
    <div class="row">
        <div class="form-field">
            <div class="container-fluid">
                <div class="col-md-12">
                        @(Html.DevExtreme().Button().ID("Job_BUT_Actual_ManpowerNew").Text("New").Icon("fas fa-file btn-icons newfile icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Job_Actual_Manpower_New_Click() } </text>))
                        @(Html.DevExtreme().Button().ID("Job_BUT_Actual_ManpowerEdit").Text("Edit").Icon("fas fa-pencil-alt btn-icons editcolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Job_Actual_Manpower_Edit_Click() } </text>))
                        @(Html.DevExtreme().Button().ID("Job_BUT_Actual_ManpowerDelete").Text("Delete").Icon("fas fa-trash btn-icons deletecolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Job_Actual_Manpower_Delete_Click() } </text>))
                        @(Html.DevExtreme().Button().ID("Job_BUT_Actual_ManpowerView").Text("View").Icon("fas fa-eye btn-icons eyeicon icon-rgt-space5").Disabled(IsVisible).OnClick(@<text> function () { OnFrm_Job_Actual_Manpower_View_Click() } </text>))
                </div>
            </div>
        </div>
    </div>
    </fieldset>
    <script>
     var Job_Manpower_Usage_Rec_Id;
    var Job_Manpower_Sr;
        function JobActualManPowerUsageGridFocusedRowChanged(s, e) {
            s.GetRowValues(s.GetFocusedRowIndex(), 'Sr;REC_ID', Manpower_Usage_GridRowValues);
        }
        function Manpower_Usage_GridRowValues(values) {
            Job_Manpower_Usage_Rec_Id = values[1];
            Job_Manpower_Sr = values[0];
    }
    $("#JobActual_ManPower_Usage_Grid").keydown(function (evt) {
        switch (evt.keyCode) {
            case 45: // insert key
                OnFrm_Job_Actual_Manpower_New_Click();
                break;
            case 13: //enter key
                OnFrm_Job_Actual_Manpower_Edit_Click();
                break;
            case 32: //space bar
                OnFrm_Job_Actual_Manpower_View_Click();
                break;
            case 46://delete key
                OnFrm_Job_Actual_Manpower_Delete_Click();
                break;
        }
        if (evt.ctrlKey && evt.keyCode == 73)//ctrl+i
        {
            OnFrm_Job_Actual_Manpower_New_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 69)//ctrl+e
        {
            OnFrm_Job_Actual_Manpower_Edit_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_Job_Actual_Manpower_View_Click();
        }
    });
        function OnFrm_Job_Actual_Manpower_New_Click()
        {
            if ("@IsDisabled" == "true")
            {
                return;
            }
            var statusflowcheck = Job_StatusFlowCheck();
            if (statusflowcheck[1] == false)
            {
                DevExpress.ui.dialog.alert(statusflowcheck[0], "Error");
                return;
            }
            ShowLoader();
            OpenPopup("Jobinnergrid", "New ~ Manpower Usage","@Url.Action("Frm_Add_Manpower_Usage", "JobRequestRegister", new {@area= "Stock" })?ActionMethod=New", "auto", 1024, false, null);
        }//new click
    function OnFrm_Job_Actual_Manpower_Edit_Click() { if ("@IsDisabled"=="true") { return; }
            if (!Job_Manpower_Sr){
                DevExpress.ui.dialog.alert("Please Select Row", "Error");
                return;
            }
                    ShowLoader();
        OpenPopup("Jobinnergrid", "Edit ~ Manpower Usage","@Url.Action("Frm_Add_Manpower_Usage", "JobRequestRegister", new {@area= "Stock" })?ActionMethod=Edit&SR=" + encodeURIComponent(Job_Manpower_Sr), "auto", 1024, false, null);
        }//edit click
        function OnFrm_Job_Actual_Manpower_View_Click() {
            if (!Job_Manpower_Sr){
                DevExpress.ui.dialog.alert("Please Select Row", "Error");
                return;
            }
            ShowLoader();

            OpenPopup("Jobinnergrid", "View ~ Manpower Usage", "@Url.Action("Frm_Add_Manpower_Usage", "JobRequestRegister", new {@area= "Stock" })?ActionMethod=View&SR=" + encodeURIComponent(Job_Manpower_Sr), "auto", 1024, false, null);

        }// view click
    function OnFrm_Job_Actual_Manpower_Delete_Click() { if ("@IsDisabled"=="true") { return; }
        if (!Job_Manpower_Sr) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        var Actual_Manpower_Details = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
        Actual_Manpower_Details.done(function (dialogResult) {
            if (dialogResult) {
                $.ajax({
                    type: 'GET',
                    url: "/Stock/JobRequestRegister/Frm_Manpower_Usage_Window_Delete_Grid_Record",
                    data: { ActionMethod: "Delete", Manpower_Usage_Rec_Id: Job_Manpower_Usage_Rec_Id, SR: Job_Manpower_Sr },
                    cache: false,
                    success: function (result) {

                        JobActual_ManPower_Usage_Grid.SetFocusedRowIndex(-1);
                        JobActual_ManPower_Usage_Grid.Refresh();

                    }
                });
            }
        });
    }

    </script>
