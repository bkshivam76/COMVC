@model ConnectOneMVC.Areas.Stock.Models.Model_NEVD_JobRequest
@using DevExtreme.AspNet.Mvc;
@{
    bool IsVisible = (Model != null && Model.ActionMethod == "Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.ActionMethod == "View" || Model.ActionMethod == "Delete") ? true : false;
}
<div class="row">
    <div class="col-md-12">
        @Html.Action("InnerGrid_DocumentsGrid", "JobRequestRegister", new { ActionMethodName = Model.ActionMethod, JobID = Model.Job_Id })
    </div>
</div>
<div class="row">
    <div class="form-field">
        <div class="container-fluid">
            <div class="col-md-12">
                    @(Html.DevExtreme().Button().ID("Job_BUT_DocNew").Text("New").Icon("fas fa-file btn-icons newfile icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Job_Document_New_Click() } </text>))
                    @(Html.DevExtreme().Button().ID("Job_BUT_DocEdit").Text("Edit").Icon("fas fa-pencil-alt btn-icons editcolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Job_Document_Edit_Click() } </text>))
                    @(Html.DevExtreme().Button().ID("Job_BUT_DocDelete").Text("Delete").Icon("fas fa-trash btn-icons deletecolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Job_Document_Delete_Click() } </text>))
                    @(Html.DevExtreme().Button().ID("Job_BUT_DocView").Text("View").Icon("fas fa-eye btn-icons eyeicon icon-rgt-space5").Disabled(IsVisible).OnClick(@<text> function () { OnFrm_Job_Document_View_Click() } </text>))
            </div>
        </div>
    </div>
</div>
<script>

        var Job_Document_Sr;
        var Job_Document_ID;
    function OnJob_DocumentDetailsGridFocusedRowChanged(s, e)
    {
            s.GetRowValues(s.GetFocusedRowIndex(), 'Sr_No;ID', OnDocumentsDetailsGridRowValues);
    }
    function OnDocumentsDetailsGridRowValues(values)
    {
            Job_Document_Sr = values[0];
            Job_Document_ID = values[1];
    }
    
    $("#JobDocuments_Window_Grid").keydown(function (evt) {
        switch (evt.keyCode) {
            case 45: // insert key
                OnFrm_Job_Document_New_Click();
                break;
            case 13: //enter key
                OnFrm_Job_Document_Edit_Click();
                break;
            case 32: //space bar
                OnFrm_Job_Document_View_Click();
                break;
            case 46://delete key
                OnFrm_Job_Document_Delete_Click();
                break;
        }
        if (evt.ctrlKey && evt.keyCode == 73)//ctrl+i
        {
            OnFrm_Job_Document_New_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 69)//ctrl+e
        {
            OnFrm_Job_Document_Edit_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_Job_Document_View_Click();
        }
    });

    function OnFrm_Job_Document_New_Click()
    {        
        if ("@IsDisabled" == "true") { return; }
        $("#ID_Frm_Help_Document_Attach").remove();
        ShowLoader();                
        $.ajax({
            type: 'GET',
            url: "/Help/Attachment/Frm_Attachment_Window",
            data: {
                AM:"New",
                PostSucessFunctionName:"Frm_Job_Documents_Window_OnSuccess",
                Post_action_Name:"Job_Documents_Attachment",
                Post_Controller_Name:"JobRequestRegister",
                Post_Area_Name: "Stock",
                Document_Grid_PopupName: "Jobinnergrid",
                ByteSessionVariable:"JobDocument"
            },
            cache: false,
            success: function (data)
            {
                OpenPopup("Jobinnergrid", "New ~ Documents", null, "auto", 900, true, data);
            }
        });
     
       // $('.dx-overlay-wrapper').addClass('popupresponsive');
    }//new click//Mantis 0000213 bug fixed
 function OnFrm_Job_Document_Edit_Click()
    {
        if ("@IsDisabled" == "true") { return; }
     if (!Job_Document_Sr) { DevExpress.ui.dialog.alert('Please Select one row', 'Alert '); return; }

        $("#ID_Frm_Help_Document_Attach").remove();
        ShowLoader();

       
          $.ajax({
              type: 'GET',
              url: "/Help/Attachment/Frm_Attachment_Window",
              data: {
                  AM: "Edit",
                  PostSucessFunctionName: "Frm_Job_Documents_Window_OnSuccess",
                  Post_action_Name: "Job_Documents_Attachment",
                  Post_Controller_Name: "JobRequestRegister",
                  Post_Area_Name: "Stock",
                  Document_Grid_Data_SessionName: "Job_Documents_Window_Grid_Data_JobRR",
                  Document_Grid_SrNo: Job_Document_Sr,
                  ID: Job_Document_ID,
                  Document_Grid_PopupName: "Jobinnergrid",
                  ByteSessionVariable: "JobDocument"
              },
              cache: false,
              success: function (data) {
          
                  OpenPopup("Jobinnergrid", "Edit ~ Documents", null, "auto", 900, true, data);
           
              }
          });
         
    }//edit click//Mantis 0000213 bug fixed
    function OnFrm_Job_Document_Delete_Click()
    {
        if ("@IsDisabled"=="true") { return; }
        if (!Job_Document_Sr) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
            if (Job_Document_ID) {
                $.ajax({
                    type: 'GET',
                    url: "/Stock/JobRequestRegister/Job_Documents_Attachment_LinkCheck",
                    data: { DocId: Job_Document_ID, JobId:Job_ID },
                    cache: false,
                    success: function (data) {
                        if (data.result == false) {
                            var deleteResultDocument = DevExpress.ui.dialog.confirm(data.message, "Confirm changes");
                            deleteResultDocument.done(function (dialogResult) {
                                if (dialogResult) {
                                    $.ajax({
                                        type: 'GET',
                                        url: "/Stock/JobRequestRegister/Frm_DocumentsDetail_Window_Delete_Grid_Record",
                                        data: { ActionMethod: "Unlink", SrID: Job_Document_Sr, Doc_ID: Job_Document_ID },
                                        cache: false,
                                        success: function (result) {
                                            JobDocuments_Window_Grid.SetFocusedRowIndex(-1);
                                            JobDocuments_Window_Grid.Refresh();
                                        }
                                    });
                                }
                            });
                        }
                        else {
                            job_deletedocument();
                        }
                    }
                });
            }
            else {
                job_deletedocument();
            }
    } //delete click
         function job_deletedocument()
        {
            if ("@IsDisabled" == "True")
            {
                return;
            }
        var deleteResultPaymentDetail = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
            deleteResultPaymentDetail.done(function (dialogResult)
            {
            if (dialogResult)
            {
                $.ajax({
                    type: 'GET',
                    url: "/Stock/JobRequestRegister/Frm_DocumentsDetail_Window_Delete_Grid_Record",
                    data: { ActionMethod: "Delete", SrID: Job_Document_Sr, Doc_ID: Job_Document_ID },
                    cache: false,
                    success: function (result)
                    {
                        JobDocuments_Window_Grid.SetFocusedRowIndex(-1);
                        JobDocuments_Window_Grid.Refresh();
                    }
                });
            }
        });
    }//delete document
    function OnFrm_Job_Document_View_Click()
    {
        if (!Job_Document_Sr) { DevExpress.ui.dialog.alert('Please Select one row', 'Alert '); return; }
        $("#ID_Frm_Help_Document_Attach").remove();       
        ShowLoader();
      $.ajax({
              type: 'GET',
              url: "/Help/Attachment/Frm_Attachment_Window",
              data: {
                  AM: "View",
                  PostSucessFunctionName: "Frm_Job_Documents_Window_OnSuccess",
                  Post_action_Name: "Job_Documents_Attachment",
                  Post_Controller_Name: "JobRequestRegister",
                  Post_Area_Name: "Stock",
                  Document_Grid_Data_SessionName:"Job_Documents_Window_Grid_Data_JobRR",
                  Document_Grid_SrNo: Job_Document_Sr,
                  ID: Job_Document_ID,
                  Document_Grid_PopupName: "Jobinnergrid",
                  ByteSessionVariable: "JobDocument"
              },
              cache: false,
          success: function (data) {
              ShowLoader();
              OpenPopup("Jobinnergrid", "View ~ Documents", null, "auto", 900, true, data);
          }  
          });
           
    }//Mantis 0000213 bug fixed
    function Frm_Job_Documents_Window_OnSuccess(data)
    {
        HideLoader();
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.message, "Error");
        }
        else {

            $("#Jobinnergrid").dxPopup("hide");
            JobDocuments_Window_Grid.SetFocusedRowIndex(-1);
            JobDocuments_Window_Grid.Refresh();           
        }
    }

</script>