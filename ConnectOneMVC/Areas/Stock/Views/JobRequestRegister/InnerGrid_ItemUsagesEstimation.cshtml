@model ConnectOneMVC.Areas.Stock.Models.Model_NEVD_JobRequest
@using DevExtreme.AspNet.Mvc;
@{
    bool IsVisible = (Model != null && Model.ActionMethod == "Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.ActionMethod == "View" || Model.ActionMethod == "Delete") ? true : false;
}
<fieldset id="jobitemusagegrid">
    <div class="row">
        <div class="col-md-12">
            @Html.Action("InnerGrid_ItemUsagesEstimationGrid", "JobRequestRegister", new { ActionMethodName = Model.ActionMethod, JobID = Model.Job_Id })
        </div>
    </div>
    <div class="row">
        <div class="form-field">
            <div class="container-fluid">
                <div class="col-md-12">
                        @(Html.DevExtreme().Button().ID("Job_BUT_ItemEstiNew").Text("New").Icon("fas fa-file btn-icons newfile icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Job_ItemUsageEstimation_New_Click() } </text>))
                        @(Html.DevExtreme().Button().ID("Job_BUT_ItemEstiEdit").Text("Edit").Icon("fas fa-pencil-alt btn-icons editcolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Job_ItemUsageEstimation_Edit_Click() } </text>))
                        @(Html.DevExtreme().Button().ID("Job_BUT_ItemEstiDelete").Text("Delete").Icon("fas fa-trash btn-icons deletecolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Job_ItemUsageEstimation_Delete_Click() } </text>))
                        @(Html.DevExtreme().Button().ID("Job_BUT_ItemEstiView").Text("View").Icon("fas fa-eye btn-icons eyeicon icon-rgt-space5").Disabled(IsVisible).OnClick(@<text> function () { OnFrm_Job_ItemUsageEstimation_View_Click() } </text>))
                </div>
            </div>
        </div>
    </div>
</fieldset>
<script>
    var Job_ItemUsage_Sr;
    var Job_ItemUsage_RecId;
        function OnItemUsageEstGridFocusedRowChanged (s, e)
        {
            s.GetRowValues(s.GetFocusedRowIndex(), 'Sr;REC_ID;', ItemUsageEstGridRowValues);
        }
        function ItemUsageEstGridRowValues(values)
        {
            Job_ItemUsage_Sr = values[0];
            Job_ItemUsage_RecId = values[1];
    }
    $("#Item_Usage_Est_Window_Grid").keydown(function (evt) {
        switch (evt.keyCode) {
            case 45: // insert key
                OnFrm_Job_ItemUsageEstimation_New_Click();
                break;
            case 13: //enter key
                OnFrm_Job_ItemUsageEstimation_Edit_Click();
                break;
            case 32: //space bar
                OnFrm_Job_ItemUsageEstimation_View_Click();
                break;
            case 46://delete key
                OnFrm_Job_ItemUsageEstimation_Delete_Click();
                break;
        }
        if (evt.ctrlKey && evt.keyCode == 73)//ctrl+i
        {
            OnFrm_Job_ItemUsageEstimation_New_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 69)//ctrl+e
        {
            OnFrm_Job_ItemUsageEstimation_Edit_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_Job_ItemUsageEstimation_View_Click();
        }
    });
        function OnFrm_Job_ItemUsageEstimation_New_Click()
        {if ("@IsDisabled"=="true") { return; }
    
            ShowLoader();
     
            OpenPopup("Jobinnergrid", "New ~ Item Estimation", "@Url.Action("Frm_Job_Request_Add_Item_Estimate", "JobRequestRegister", new {@area= "Stock" })?ActionMethod=New", "auto", 900, false, null);
    }
       function OnFrm_Job_ItemUsageEstimation_Edit_Click() {if ("@IsDisabled"=="true") { return; }
           if (!Job_ItemUsage_Sr) {
               DevExpress.ui.dialog.alert("Please Select A Row...!!", "Error"); return;
           }
                ShowLoader();

           OpenPopup("Jobinnergrid", "Edit ~ Item Estimation", "@Url.Action("Frm_Job_Request_Add_Item_Estimate", "JobRequestRegister", new {@area= "Stock" })?ActionMethod=Edit&SrID=" + encodeURIComponent(Job_ItemUsage_Sr), "auto", 900, false, null);
    }


     
        function OnFrm_Job_ItemUsageEstimation_Delete_Click() {if ("@IsDisabled"=="true") { return; }
            if (!Job_ItemUsage_Sr) {
                DevExpress.ui.dialog.alert("Please Select A Row...!!", "Error"); return;
            }
            var Actual_Manpower_Details = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
            Actual_Manpower_Details.done(function (dialogResult) {

                if (dialogResult) {
                    $.ajax({
                        type: 'GET',
                        url: "/Stock/JobRequestRegister/Frm_ItemEstimation_Window_Delete_Grid_Record",
                        data: { ActionMethod: "Delete", SrID: Job_ItemUsage_Sr, Rec_Id: Job_ItemUsage_RecId },
                        cache: false,
                        success: function (result) {
                       
                            Item_Usage_Est_Window_Grid.SetFocusedRowIndex(-1);
                            Item_Usage_Est_Window_Grid.Refresh();     
                        }
                    });
                }
            });
        }
    function OnFrm_Job_ItemUsageEstimation_View_Click()
    {
        if (!Job_ItemUsage_Sr)
        {
            DevExpress.ui.dialog.alert("Please Select A Row...!!", "Error"); return;
        }
        ShowLoader();
        OpenPopup("Jobinnergrid", "View ~ Item Estimation", "@Url.Action("Frm_Job_Request_Add_Item_Estimate", "JobRequestRegister", new {@area= "Stock" })?ActionMethod=View&SrID=" + encodeURIComponent(Job_ItemUsage_Sr), "auto", 900, false, null);

    }
        
        function OnItemUsageEstimationSuccess(data) {
            HideLoader();
            if (data.result == false) {
                DevExpress.ui.dialog.alert(data.message, "Error");
            }
            else {
               
                $("#Jobinnergrid").dxPopup("hide");
                Item_Usage_Est_Window_Grid.SetFocusedRowIndex(-1);
                Item_Usage_Est_Window_Grid.Refresh();
            }
        }   
     
      
</script>