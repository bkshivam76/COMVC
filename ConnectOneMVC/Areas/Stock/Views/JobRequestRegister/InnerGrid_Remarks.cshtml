@model ConnectOneMVC.Areas.Stock.Models.Model_NEVD_JobRequest
@using DevExtreme.AspNet.Mvc;
@{
    bool IsVisible = (Model != null && Model.ActionMethod == "Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.ActionMethod == "View" || Model.ActionMethod == "Delete") ? true : false;
}
<div class="row">
    <div class="col-md-12">
        @Html.Action("InnerGrid_RemarksGrid", "JobRequestRegister", new { ActionMethodName = Model.ActionMethod, JobID = Model.Job_Id })
    </div>

</div>
<div class="row">
    <div class="form-field">
        <div class="container-fluid">
            <div class="col-md-12">
                <div class="dx-button dx-button-normal dx-widget dx-button-has-text" role="button" aria-label="Price History" tabindex="0">

                    @(Html.DevExtreme().Button().ID("Job_BUT_ExistingRemDelete").Text("Delete").Icon("fas fa-trash btn-icons deletecolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Job_Existing_Remarks_Delete_Click() } </text>))
                </div><!--[button]-->

                <div class="dx-button dx-button-normal dx-widget dx-button-has-text" role="button" aria-label="Price History" tabindex="0">

                    @(Html.DevExtreme().Button().ID("Job_BUT_ExistingRemView").Text("View").Icon("fas fa-eye btn-icons eyeicon icon-rgt-space5").Disabled(IsVisible).OnClick(@<text> function () { OnFrm_Job_Existing_Remarks_View_Click() } </text>))
                </div><!--[button]-->
            </div>
            </div>
        </div>
    </div>
<script>
        var Jobremarkssr;
    var JobExistingRemarks_Id;
    var JobRemarks = "";
    function OnExistingJobRemarksGridFocusedRowChanged(s, e) {
        s.GetRowValues(s.GetFocusedRowIndex(), 'Sr_No;ID;Remarks', OnRemarksJobDetailsGridRowValues);
    };
    function OnRemarksJobDetailsGridRowValues(values) {
        Jobremarkssr = values[0];
        JobExistingRemarks_Id = values[1];
        JobRemarks = values[2];
    };
    $("#JobExistingRemarks_Window_Grid").keydown(function (evt) {
        switch (evt.keyCode) {         
          
            case 32: //space bar
                OnFrm_Job_Existing_Remarks_View_Click();
                break;
            case 46://delete key
                OnFrm_Job_Existing_Remarks_Delete_Click();
                break;
        }       
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_Job_Existing_Remarks_View_Click();
        }
    });
    function OnFrm_Job_Existing_Remarks_Delete_Click() { if ("@IsDisabled"=="true") { return; }
        if (!Jobremarkssr){
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        var deleteResultPaymentDetail = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
        deleteResultPaymentDetail.done(function (dialogResult) {

            if (dialogResult) {
                $.ajax({
                    type: 'GET',
                    url: "/Stock/JobrequestRegister/Frm_ExistingRemarks_Window_Delete_Grid_Record",
                    data: { ActionMethod: "Delete", ID: JobExistingRemarks_Id },
                    cache: false,
                    success: function (Result) {
                        if (Result.result == true) {                           
                            JobExistingRemarks_Window_Grid.Refresh();
                            JobExistingRemarks_Window_Grid.SetFocusedRowIndex(-1);
                        }
                        else {
                            DevExpress.ui.dialog.alert(Result.message, "Error");
                        }
                    }
                });
            }
        });
    }
    function OnFrm_Job_Existing_Remarks_View_Click() {
        if (!Jobremarkssr) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        else {

                    ShowLoader(); 
        OpenPopup("Jobinnergrid", "View Remarks","@Url.Action("Frm_ViewRemarks", "JobRequestRegister", new {@area= "Stock" })?SR=" + encodeURIComponent(Jobremarkssr), "auto", 900, false, null);
        }
    }//view click
</script>