@{ 
    var SessionGUID = Request.QueryString["SessionGUID"];
}
@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "JobActuallExpensesGrid";
        settings.CallbackRouteValues = new
        {
            Controller = "JobRequestRegister",
            Action = "Job_Actual_Estimation_Grid",
            SessionGUID = SessionGUID
        };
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Visible;
        settings.SettingsExport.EnableClientSideExportAPI = true;
        settings.SettingsExport.ExcelExportMode = DevExpress.Export.ExportType.DataAware;
        settings.SettingsExport.TopMargin = 10;
        settings.SettingsExport.LeftMargin = 10;
        settings.SettingsExport.RightMargin = 10;
        settings.SettingsExport.BottomMargin = 10;
        settings.CommandColumn.Visible = true;
        settings.CommandColumn.ShowSelectCheckbox = true;
        settings.Settings.UseFixedTableLayout = true;
        settings.SettingsDataSecurity.AllowReadUnlistedFieldsFromClientApi = DefaultBoolean.True;
        settings.CustomJSProperties = (s, e) =>
        {
            MVCxGridView gridView = (MVCxGridView)s;
            var lastVisibleColumn = gridView.VisibleColumns.LastOrDefault();
            e.Properties["cpLastVisibleColumnIndex"] = lastVisibleColumn != null ? lastVisibleColumn.Index : 0;
            e.Properties["cpHiddenColumnCaptions"] = gridView.AllColumns.Where(c => !c.Visible).ToDictionary(c => c.ToString(), c => c.Index);
        };
        settings.BeforeGetCallbackResult = (s, e) =>
        {
            MVCxGridView gridView = s as MVCxGridView;
            foreach (GridViewDataColumn column in gridView.DataColumns)
            {
                if (column.Visible)
                    column.Settings.SortMode = DevExpress.XtraGrid.ColumnSortMode.Custom;
                else
                    column.Settings.AllowSort = DefaultBoolean.False;
            }
        };

        settings.KeyFieldName = "Txn_ID";

        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "_Date";
                column.Caption = "Date";
                column.Width = 150;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "ItemName";
                column.Caption = "Item Name";
                column.Width = 150;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Head";
                column.Caption = "Head";
                column.Width = 150;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Party";
                column.Caption = "Party";
                column.Width = 150;

            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Amount";
                column.Caption = "Amount";
                column.Width = 150;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Mapped_On";
                column.Caption = "Mapped On";
                column.Width = 130;
                column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Mapped_By";
                column.Caption = "Mapped By";
                column.Visible = false;
                column.Width = 175;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "ID";
                column.Caption = "ID";
                column.Visible = false;
                column.Width = 175;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Txn_ID";
                column.Caption = "Txn_ID";
                column.Visible = false;
                column.Width = 175;
                column.Settings.SortMode = DevExpress.XtraGrid.ColumnSortMode.Custom;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Txn_Sr_No";
                column.Caption = "Txn_Sr_No";
                column.Visible = false;
                column.Width = 175;
            }
        });
        settings.Settings.ShowHeaderFilterBlankItems = false;
        settings.SettingsContextMenu.Enabled = false;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsContextMenu.EnableGroupFooterMenu = DefaultBoolean.True;
        settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;
        settings.Settings.VerticalScrollBarMode = ScrollBarMode.Auto;
        settings.Settings.ShowHeaderFilterButton = true;
        settings.KeyboardSupport = true;
        //settings.AccessKey = "G";
        settings.SettingsResizing.ColumnResizeMode = DevExpress.Web.ColumnResizeMode.Control;
        settings.SettingsResizing.Visualization = DevExpress.Web.ResizingMode.Live;
        settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
        settings.SettingsBehavior.ProcessColumnMoveOnClient = true;
        settings.SettingsBehavior.ColumnMoveMode = GridColumnMoveMode.AmongSiblings;
        settings.Settings.UseFixedTableLayout = true;
        settings.SettingsBehavior.AutoExpandAllGroups = true;
        settings.SettingsBehavior.AllowSelectSingleRowOnly = false;
        settings.SettingsBehavior.AllowSort = true;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsPager.Mode = GridViewPagerMode.ShowAllRecords;
        settings.SettingsSearchPanel.ShowApplyButton = true;
        settings.SettingsSearchPanel.ShowClearButton = true;
        settings.SettingsBehavior.AllowFocusedRow = true;
        settings.ClientSideEvents.Init = "jobonexpensemapgridinit";
        settings.ClientSideEvents.SelectionChanged = "job_expenses_grid_selectionchanged";
        settings.CustomColumnSort += (s, e) =>
        {
            MVCxGridView gv = (MVCxGridView)s;
            bool isRow1Selected = gv.Selection.IsRowSelectedByKey(e.GetRow1Value(gv.KeyFieldName));
            bool isRow2Selected = gv.Selection.IsRowSelectedByKey(e.GetRow2Value(gv.KeyFieldName));
            e.Handled = isRow1Selected != isRow2Selected;
            if (e.Handled)
            {
                e.Result = isRow1Selected ? 1 : -1;
            }
        };

    }).Bind(Model).GetHtml()
