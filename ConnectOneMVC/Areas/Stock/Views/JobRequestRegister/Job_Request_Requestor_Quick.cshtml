            <div class="row">
                <div class="">
                    <div class="col-sm-6 col-md-6 col-lg-6">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label text-red" for="user">Assignee's Main Dept:</label></div>
                                    <div class="col-sm-8 col-md-8 col-lg-8 prm ">
                                        <div class="dx-texteditor  dx-widget dx-textbox">
                                            <div class="dx-texteditor-container">
                                                @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("Quick_Job_AssigneeMainDeptID").Name("Quick_Job_AssigneeMainDeptID").Placeholder("Assignee's Main Department").ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).DataSource(d => d.Mvc().Controller("JobRequestRegister").LoadAction("Get_Stock_Assigns_MainDept_QJ").Key("ID"))
                                                                                              .ValueExpr("ID").DisplayExpr("Name").Value(Model.Quick_Job_AssigneeMainDeptID).OnValueChanged("quick_On_Assigns_MainDept_Value_Changed").DeferRendering(false).OnInitialized("quick_OnInitialized_OnAssignee_Main_Dept").ContentTemplate(@<text> @Html.Partial("Get_Stock_Assigns_MainDept_QJ") </text>).ReadOnly(false))@*//Mantis bug 0000397 fixed*@
                                                @Html.ValidationMessageFor(model => model.Quick_Job_AssigneeMainDeptID, "", new { @class = "text-danger" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div> <!--[Assignee Main Dept]-->
                    <div class="col-sm-6 col-md-6 col-lg-6">
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label" for="user">Assignee's Sub Dept:</label></div>
                                    <div class="col-sm-8 col-md-8 col-lg-8 prm">
                                        <div class="dx-texteditor  dx-widget dx-textbox">
                                            <div class="dx-texteditor-container">
                                                @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("Quick_Job_AssigneeSubDeptID").Name("Quick_Job_AssigneeSubDeptID").Placeholder("Assignee's Sub-Department:").DataSource(d => d.Mvc().Controller("JobRequestRegister").LoadAction("Get_Stock_Assign_SubDept_QJ").Key("ID").LoadParams(new { AssigMainDeptID = new JS("function (){return quick_Job_AssigMainDeptID;}") }))
                                                                                              .Value(Model.Quick_Job_AssigneeSubDeptID).ValueExpr("ID").DisplayExpr("Name").DeferRendering(false).ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).OnInitialized("quick_On_Initialize_Assignee_Sub_Dept").ReadOnly(true).OnValueChanged("quick_On_Assign_Value_Changed").ContentTemplate(@<text> @Html.Partial("Get_Stock_Assign_SubDept_QJ") </text>))@*//Mantis bug 0000592 fixed*@
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div> <!--[Assignee Sub Dept]-->
