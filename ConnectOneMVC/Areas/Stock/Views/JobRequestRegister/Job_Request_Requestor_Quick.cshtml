</div>
<script>
    var quick_Job_AssigMainDeptID;

    $(document).ready(function ()
    {
        var Job_ProjectScreenNewright = "@Job_ProjectScreenNewright" == "True" ? true : false;
        if (Job_ProjectScreenNewright != true)
        {
            $("#Quick_JOB_ADD_PROJECT").hide();
        }

        var form = "quickJobvalidationForm";
        ShowLoader();
        AssignIDtoLabel(form, "jobQuick");
        if ("@Model.Quick_CallingScreen".Length > 0) {
           
            $("#Quick_Job_ProjectId").dxDropDownBox("instance").option('readOnly', true);
            $("#Quick_Job_ComplexId").dxDropDownBox("instance").option('readOnly', true);
            $("#Quick_Job_AssigneeSubDeptID").dxDropDownBox("instance").option('readOnly', true);
            $("#Quick_JOB_ADD_PROJECT").dxButton('instance').option('disabled', true);
            $("#Quick_Id_Add_Complecx").dxButton('instance').option('disabled', true);
            $("#Quick_Job_ProjectId").dxDropDownBox("instance").option("value", parseInt("@Model.Quick_Job_ProjectId"))            
        }
        @*//if ("@Model.Quick_Job_ProjectId".length > 0) $("#Quick_Job_ProjectId").dxDropDownBox("instance").option("value", parseInt("@Model.Quick_Job_ProjectId"));//Mantis bug 0000466 fixed*@

        setTimeout(function ()
        {           
            Focus_FirstEditable_Field(form);
            HideLoader();
        }, Timeout100);
    });
 function quick_OnJobTypeChange(e)
    {
     var Drop_Down = $("#Quick_Job_Type").dxSelectBox("instance");//Mantis bug 0000860 fixed
        if (Drop_Down != undefined && Drop_Down != "undefined")
        {
            Drop_Down.close();
        }
    }
    function quick_OnJobTypeInit(e)
    {
            e.component.option("dataSource").store.load().done(function (d) {
             if (d.length > 0)
             {
                        for (var i = 0; i < d.length; i++)
                        {
                            if (d[i].Job_Type == "New Construction")
                            {
                                e.component.option("value", d[i].Job_Type_ID);
                            }
                        }
                    }
            });
    }   // Job_Type_init

    function quick_On_Project_Initialization(e)
    {

        e.component.option("dataSource").store.load().done(function (d) {
            if (d.length > 0)
            {
                @*e.component.option("value", "@Model.Quick_Job_ProjectId");*@//Mantis bug 0000466 fixed
            }
        });
    }
    function quick_On_Project_Value_Changed(e)
    {
     
        var Drop_Down = $("#Quick_Job_ProjectId").dxDropDownBox("instance");
        Drop_Down.close();
        if (e.previousValue != null && e.previousValue != e.value) {
            $("#Quick_Job_ComplexId").dxDropDownBox("instance").reset();

        }
        var $dataGrid = $("#GetProjectName_JRGrid_QJ");//Mantis bug 0000592 fixed
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(Drop_Down.option("value"), false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                $("#Quick_Job_ComplexId").dxDropDownBox("instance").option("value", item.Complex_Id);
                $("#Quick_Job_ComplexId").dxDropDownBox("instance").option("readOnly", true);

            }
        }
    }
    function quick_On_Initialize_Complex(e)
    {

    }
    function quick_On_Complex_Value_Changed(e) {
        var dropDown = $("#Quick_Job_ComplexId").dxDropDownBox("instance");
        dropDown.close();
    }
    function quick_OnInitialized_OnAssignee_Main_Dept(e)
    {        
        quick_Job_AssigMainDeptID = "@Model.Quick_Job_AssigneeMainDeptID";
        e.component.option("dataSource").store.load().done(function (d) {
            if (d.length > 0)
            {
                for (var i = 0; i < d.length; i++)
                {
                    if (d[i].Name == "Construction")
                    {
                        var $dataGrid = $("#GetStockAssignMainDept_Grid-QJ");
                        if ($dataGrid.length) {
                            var dataGrid = $dataGrid.dxDataGrid("instance");
                            dataGrid.selectRows(d[i].ID, true);
                        }
                        break;
                    }
                }//Mantis bug 0000397 fixed
                @*e.component.option("value", "@Model.Quick_Job_AssigneeMainDeptID");*@
            }
        });
    }
    function quick_On_Assigns_MainDept_Value_Changed(e) {

        var dropDown = $("#Quick_Job_AssigneeMainDeptID").dxDropDownBox("instance");
        dropDown.close();
        if (e.previousValue != null && e.previousValue != e.value) {
            $("#Quick_Job_AssigneeSubDeptID").dxDropDownBox("instance").reset();
        }
        var $dataGrid = $("#GetStockAssignMainDept_Grid-QJ");//Mantis bug 0000397 fixed
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(dropDown.option("value"), false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                quick_Job_AssigMainDeptID = item.ID;

                $("#Quick_Job_AssigneeSubDeptID").dxDropDownBox("instance").option("readOnly", false);
                $("#GetStockAssignSubDept_JRGrid_QJ").dxDataGrid("getDataSource").reload().done(function (d) {
                    if (d.length > 0) {
                        var datagrid = $("#GetStockAssignSubDept_JRGrid_QJ").dxDataGrid("instance");
                            var count = datagrid.totalCount();
                        if (count == 1) {
                                datagrid.selectRowsByIndexes(0);
                        }
                    }
                });//Mantis bug 0000592 fixed
            }
        }
    }
    function quick_On_Initialize_Assignee_Sub_Dept(e)
    {
        e.component.option("dataSource").store.load().done(function (d)
        {            
            if (d.length > 0)
            {
                    e.component.option("value", "@Model.Quick_Job_AssigneeSubDeptID");
            }
        });
    }//Mantis bug 0000397 fixed
    function quick_On_Assign_Value_Changed(e)
    {
        var dropDown = $("#Quick_Job_AssigneeSubDeptID").dxDropDownBox("instance");
        dropDown.close();

        $("#Job_QJ_Assignee_Sub_Dept_ID").val(e.value);//Mantis bug 0000374 fixed

        var $dataGrid = $("#GetStockAssignSubDept_JRGrid_QJ");//Mantis bug 0000592 fixed
        if ($dataGrid.length)
        {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(dropDown.option("value"), false);
            if (e.value == null) {
                dataGrid.clearSelection();
            }
            if (dataGrid.getSelectedRowsData().length > 0)
            {
                var item = dataGrid.getSelectedRowsData()[0];
            }
        }
    }
    function quick_job_add_New_Project() {
        if (!Job_ProjectScreenNewright) { DevExpress.ui.dialog.alert('Not Allowed', 'No Rights'); return; }

        $("#NPR_Content_popup").dxPopup("instance").option("contentTemplate", "<div id='result_Dynamic_Content_popupJPRFromJob'></div>")
        $("#NPR_Content_popup").dxPopup("show");
        $("#NPR_Content_popup").dxPopup("instance").option("title", "New ~ Project Request");
        $("#NPR_Content_popup").dxPopup("instance").option("width", "80%");
        $("#NPR_Content_popup").dxPopup("instance").option("height", "90%");
        ShowLoader();
        $.ajax({
            type: "GET",
            url: "/Stock/ProjectScreen/Frm_Project_NEVD",
            data: {
                ActionMethod: "New",
                rEC_ID: "0",
                projectNae: "",
                ComplexName: "",
                SanctionNo: "",
                PrjType: "",
                RequestDate: "",
                ReqMainDept: "",
                ReqSubDept: "",
                AssigneeMainDept: "",
                assigneeSubDept: "",
                PrjStatus: "",
                EstimatedCost: "",
                ActCost: "",
                EstimationDate: "",
                SanctionDate: "",
                StartDate: "",
                FinishDate: "",
                Project_Engineer: "",
                Project_Estimator: "",
                Project_Summary: "",
                Project_Your_Remarks: "",
                //Existingrecord = Remarks_Id
                 PostSuccessFunction: "Job_AddProject_Success",
                PopUpID: "NPR_Content_popup",
                buttonID: "Quick_JOB_ADD_PROJECT"
            },
            success: function (data) {
                $("#result_Dynamic_Content_popupJPRFromJob").html(data);
                HideLoader();
            },
            error: function (e) {
                HideLoader();
            }
        });
    } //mantis bug 703 fixed
    function Job_AddProject_Success(data) {
        HideLoader();
        if (data.result == true) {
            $("#NPR_Content_popup").dxPopup("hide");
            $("#GetProjectName_JRGrid_QJ").dxDataGrid("instance").refresh();
        }
        else {
            DevExpress.ui.dialog.alert(data.message, "Error");
        }
    }
    function quick_job_add_Complex() {
        DevExpress.ui.dialog.alert("Coming soon...!", 'Inform!');
    }
    function switch_To_Full_Job()
    {
        $("#quickJobvalidationForm").remove();//Mantis bug 0000860 fixed
        var popupid = "#" + "@Model.Quick_popupID";
        $(popupid).dxPopup("hide");
             if ("@Model.Quick_CallingScreen" == "Project")
             {            
                 ShowLoader();
                 $.ajax({
                     type: "GET",
                     url: "/Stock/JobRequestRegister/Frm_NEVD_Job_Request",
                     data:
                     {
                         ActionMethod: "New", PostSuccessFunction: "project_QuickJob_Success", PopupID: "popup_frm_addJob", CallingScreen: "Project", projectID: PR_REC_ID
                     },
                     success: function (data)
                     {
                         OpenPopup("popup_frm_addJob", "New ~ Job Request Register", null, "auto", "90%", true, data);                 
                     }
                 });
             }
             else
             {
                 ShowLoader();       
                 OpenDynamicPopup("New ~ Job Request Register","@Url.Action("Frm_NEVD_Job_Request", "JobRequestRegister", new { @area = "Stock" })?ActionMethod=New", "auto", "90%", false, null);    
             }
