                                                                                              .Value(Model.Quick_Job_ComplexId).ValueExpr("ID").DisplayExpr("Complex_Name").OnValueChanged("quick_On_Complex_Value_Changed").DeferRendering(false).OnInitialized("quick_On_Initialize_Complex").ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } })
                                                                                              .ContentTemplate(@<text> @Html.Partial("Get_Complexes_List - QJ") </text>).ReadOnly(false))@*//Mantis bug 0000592 fixed*@
                                            </div>
                                        </div>
