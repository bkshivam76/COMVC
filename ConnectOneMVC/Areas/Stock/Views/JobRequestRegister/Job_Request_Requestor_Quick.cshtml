                    <div class="col-sm-6">
                        <div>
                            <div class="container-fluid">
                                @(Html.DevExtreme().Button().ID("ID_Swicth_To_Full_Job").Text("Switch to Full Job")
                                                                           .OnClick(@<text>
                                                                            function() { switch_To_Full_Job();}
                                                                        </text>))
                            </div>
                        </div>
                    </div>
                    <div class="btn-align styleActionBtn">
                        @(Html.DevExtreme().Button().CustomSaveButton().ID("ID_SaveQAJ").Text("Save").UseSubmitBehavior(true))
                        @(Html.DevExtreme().Button().CustomCloseButton().ID("Id_CloseQAJ").Text("Close").OnClick(@<text> function(){ close_quickjob(); } </text>))
