                                    <div class="col-sm-3 col-md-3 col-lg-3 prm pll4">
                                        @(Html.DevExtreme().Button().ID("Quick_Id_Add_Complecx").Text("Add Complex").OnClick(@<text> function(){ quick_job_add_Complex();}</text>).Disabled(false))
