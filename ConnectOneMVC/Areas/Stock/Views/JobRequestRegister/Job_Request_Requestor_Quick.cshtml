                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-2 col-md-2 col-lg-2 pll"><label class="control-label text-red" for="user">Job Description:</label></div>
                                <div class="col-sm-10 col-md-10 col-lg-10 prm ">
                                    <div class="dx-texteditor  dx-widget dx-textbox">
                                        <div class="dx-texteditor-container">
                                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("Quick_Job_Description").Name("Quick_Job_Description").MaxLength(8000).Placeholder("Job Description").Value(Model.Quick_Job_Description).ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }))
                                            @Html.ValidationMessageFor(model => model.Quick_Job_Description, "", new { @class = "text-danger" })
                                        </div>
