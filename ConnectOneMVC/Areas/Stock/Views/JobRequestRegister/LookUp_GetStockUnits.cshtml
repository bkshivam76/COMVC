@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
               .ID("LookUp_StockUnit")
             
               .Columns(columns =>
               {                  
                   columns.Add().DataField("Unit").Caption("Unit").Visible(true);                 
                   columns.Add().DataField("Unit_ID").Caption("UnitID").Visible(false);            
               })
             
                .Selection(s => s.Mode(SelectionMode.Single))
               
)