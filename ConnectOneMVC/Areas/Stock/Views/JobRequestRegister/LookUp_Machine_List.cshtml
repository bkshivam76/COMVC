@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
        .ID("JobLookUp_Machine_List_datagrid")
       
        .Columns(columns =>
        {

            columns.Add().DataField("Item_Name").Caption("Name");
            columns.Add().DataField("Item_Code").Caption("Item Code");
            columns.Add().DataField("Location").Caption("Location");
            columns.Add().DataField("ID").Caption("ID");
            columns.Add().DataField("Curr_Qty").Caption("Curr_Qty").Visible(false);
})
       
        .Selection(s => s.Mode(SelectionMode.Single))
       
)




