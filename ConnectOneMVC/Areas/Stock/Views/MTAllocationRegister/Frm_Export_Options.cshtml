@using DevExtreme.AspNet.Mvc;
<div>
    @(Html.DevExtreme().Button()
                .ID("MT_ExportGridDatapdf")
                .Text("Export to PDF")
                .OnClick("ExportPDF")
                .Visible(true)
                .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                .ID("MT_ExportGridDataxls")
                .Text("Export to XLS")
                .OnClick("ExportXLS")
                .Visible(true)
                .Width(120)
    )<br />
    @(Html.DevExtreme().Button()
                .ID("MT_ExportGridDataxlsx")
                .Text("Export to XLSX")
                .OnClick("ExportXLSX")
                .Visible(true)
                .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                .ID("MT_ExportGridDatadocx")
                .Text("Export to DOCX")
                .OnClick("ExportDOCX")
                .Visible(true)
                .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                .ID("Personnel_ExportGridDatartf")
                .Text("Export to RTF")
                .OnClick("ExportRTF")
                .Visible(true)
                .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                .ID("MT_ExportGridDatacsv")
                .Text("Export to CSV")
                .OnClick("ExportCSV")
                .Visible(true)
                .Width(120)
    )
</div>
<script>
    function ExportPDF() {
        MTAllocationRegisterListGrid.ExportTo(ASPxClientGridViewExportFormat.Pdf);
        $("#MTAllocation_report_modal").dxPopup("hide");
    }
    function ExportXLS() {
        MTAllocationRegisterListGrid.ExportTo(ASPxClientGridViewExportFormat.Xls);
        $("#MTAllocation_report_modal").dxPopup("hide");
    }
    function ExportXLSX() {
        MTAllocationRegisterListGrid.ExportTo(ASPxClientGridViewExportFormat.Xlsx);
        $("#MTAllocation_report_modal").dxPopup("hide");
    }
    function ExportCSV() {
        MTAllocationRegisterListGrid.ExportTo(ASPxClientGridViewExportFormat.Csv);
        $("#MTAllocation_report_modal").dxPopup("hide");
    }
    function ExportDOCX() {
        MTAllocationRegisterListGrid.ExportTo(ASPxClientGridViewExportFormat.Docx);
        $("#MTAllocation_report_modal").dxPopup("hide");
    }
    function ExportRTF() {
        MTAllocationRegisterListGrid.ExportTo(ASPxClientGridViewExportFormat.Rtf);
        $("#MTAllocation_report_modal").dxPopup("hide");
    }
</script>

