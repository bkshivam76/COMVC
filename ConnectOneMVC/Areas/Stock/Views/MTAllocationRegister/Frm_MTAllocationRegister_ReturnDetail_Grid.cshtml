@{ 
    var SessionGUID = Request.QueryString["SessionGUID"];
    int MTMainGridID =(int) ViewData["MTMainGridID"];
    int MTNestedGridID = (int) ViewData["MTNestedGridID"];
}
@Html.DevExpress().GridView(settings =>
{
    settings.Name = "MTAllocationRegisterSubItemProduce"+ MTNestedGridID;
    settings.SettingsDetail.MasterGridName = "MTAllocationRegisterItemProduce"+ MTMainGridID;

    settings.CallbackRouteValues = new
    {
        Controller = "MTAllocationRegister",
        Action = "Frm_MTAllocationRegister_ReturnDetail_Grid",
        ITEM_ID = MTNestedGridID,
        SessionGUID = SessionGUID
    };
    settings.CommandColumn.Visible = true;
    settings.CommandColumn.Width = 30;
    settings.CommandColumn.ShowSelectCheckbox = true;

    settings.Width = Unit.Percentage(100);

    settings.AfterPerformCallback = (s, e) =>
    {
        ASPxGridView gridView = s as ASPxGridView;
        gridView.Selection.UnselectAll();
    };

    settings.KeyFieldName = "ID";
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Return_Qty";
            column.Caption = "Return Qty";
            column.PropertiesEdit.DisplayFormatString = "#.##";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Return_Date";
            column.Caption = "Return Date";
            column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Penalty";
            column.Caption = "Penalty";
            column.PropertiesEdit.DisplayFormatString = "#.##";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Remarks";
            column.Caption = "Remarks";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "ID";
            column.Caption = "ID";
            column.Visible = false;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "IssueItemRecID";
            column.Caption = "IssueItemRecID";
            column.Visible = false;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "MachineToolID";
            column.Caption = "MachineToolID";
            column.Visible = false;
        }
    });

    settings.CustomDataActionRouteValues = new { Controller = "MTAllocationRegister", Action = "MTItemProduceSubCustomDataAction" };

    settings.SettingsBehavior.AllowFocusedRow = false;
    settings.SettingsBehavior.AllowSelectByRowClick = true;
    settings.SettingsBehavior.AllowSelectSingleRowOnly = true;

    int MT_ReturnDetail_ShowHorizontalBar = ViewData["MT_ShowHorizontalBar"] == null ? 0 : (int)ViewData["MT_ShowHorizontalBar"];
    if (MT_ReturnDetail_ShowHorizontalBar == 1)
    {
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Visible;
        settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.Off;
        settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.Control;
        settings.SettingsResizing.Visualization = ResizingMode.Postponed;
    }
    else
    {
        settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.HideDataCells;
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Hidden;
        settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.Disabled;
    }

    settings.ClientSideEvents.Init = "MT_ReturnDetailGrid_init";
    settings.ClientSideEvents.SelectionChanged = "MT_ReturnGridRowSelectionChanged";
}).Bind(Model).GetHtml()


