@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool MT_Add_Rights = (bool)ViewData["MT_AddRight"];
    bool MT_Update_Rights = (bool)ViewData["MT_UpdateRight"];
    bool MT_View_Rights = (bool)ViewData["MT_ViewRight"];
    bool MT_Delete_Rights = (bool)ViewData["MT_DeleteRight"];
    bool MT_Export_Rights = (bool)ViewData["MT_ExportRight"];
    int MT_ShowHorizontalBar = ViewData["MT_ShowHorizontalBar"] == null ? 0 : (int)ViewData["MT_ShowHorizontalBar"];
}
@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "MTAllocationRegisterListGrid";
        settings.CallbackRouteValues = new
        {
            Controller = "MTAllocationRegister",
            Action = "Frm_MT_AllocationRegister_Grid",
            SessionGUID = SessionGUID
        };

        settings.SettingsDetail.AllowOnlyOneMasterRowExpanded = false;// set false for simultaneous nested grid
        settings.SettingsDetail.ShowDetailRow = true; //set true for nested grid

        settings.SettingsExport.ExcelExportMode = DevExpress.Export.ExportType.DataAware;
        settings.SettingsExport.EnableClientSideExportAPI = true;
        settings.SettingsExport.ExcelExportMode = DevExpress.Export.ExportType.DataAware;
        settings.SettingsDetail.ExportMode = GridViewDetailExportMode.All;

        settings.SettingsExport.PageHeader.Center = "Machine Tool Allocation";
        settings.SettingsExport.PageHeader.Left = ViewData["MTAExportGridHeaderLeft"] != null ? ViewData["MTAExportGridHeaderLeft"].ToString() : "";
        settings.SettingsExport.PageHeader.Right = ViewData["MTAExportGridHeaderRight"] != null ? ViewData["MTAExportGridHeaderRight"].ToString() : "";
        settings.SettingsExport.PageFooter.Right = ViewData["MTAExportGridFooter"] != null ? ViewData["MTAExportGridFooter"].ToString() : "";
        settings.SettingsExport.PageFooter.Left = "#";
        settings.SettingsExport.PageFooter.Font.Size = 7;
        settings.SettingsExport.PaperKind = System.Drawing.Printing.PaperKind.A4Rotated;
        settings.SettingsExport.TopMargin = 10;
        settings.SettingsExport.LeftMargin = 10;
        settings.SettingsExport.RightMargin = 10;
        settings.SettingsExport.BottomMargin = 10;

        settings.SettingsExport.GetExportDetailGridViews = (s, e) => //export nested grid
        {
            int MT_ID = (int)DataBinder.Eval(e.DataItem, "ID");
            GridViewExtension exportnestedGrid = new GridViewExtension(ConnectOneMVC.Areas.Stock.Controllers.MTAllocationRegisterController.MTAllocationRegister_IssueDetail_Export(MT_ID));
            exportnestedGrid.Bind(ConnectOneMVC.Areas.Stock.Controllers.MTAllocationRegisterController.GetIssueDetail(MT_ID));
            e.DetailGridViews.Add(exportnestedGrid);
        };
        settings.SetDetailRowTemplateContent(c =>
        {
            Html.RenderAction("Frm_MTAllocationRegister_IssueDetail_Grid", new { MT_ID = DataBinder.Eval(c.DataItem, "ID")});
        });

        settings.CustomDataActionRouteValues = new { Controller = "MTAllocationRegister", Action = "MTAllocationRegisterCustomDataAction" };

        settings.CustomJSProperties = (s, e) =>
        {
            MVCxGridView gridView = (MVCxGridView)s;
            var lastVisibleColumn = gridView.VisibleColumns.LastOrDefault();
            e.Properties["cpLastVisibleColumnIndex"] = lastVisibleColumn != null ? lastVisibleColumn.Index : 0;
            e.Properties["cpHiddenColumnCaptions"] = gridView.AllColumns.Where(c => !c.Visible).ToDictionary(c => c.ToString(), c => c.Index);
            e.Properties["cpDetailRowCount"] = gridView.DetailRows.VisibleCount;
        };
        settings.BeforeGetCallbackResult = (s, e) =>
        {
            MVCxGridView gridView = s as MVCxGridView;
            foreach (GridViewDataColumn column in gridView.DataColumns)
            {
                if (column.Visible)
                    column.Settings.AllowSort = DefaultBoolean.True;
                else
                    column.Settings.AllowSort = DefaultBoolean.False;
            }
        };
        settings.FillContextMenuItems = (sender, e) =>
        {
            if (e.MenuType == GridViewContextMenuType.Rows)
            {
                var New = e.CreateItem("Issue Tools", "New");
                New.Image.IconID = "actions_new_16x16gray";
                if (MT_Add_Rights == true)e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), New);

                var Edit = e.CreateItem("Edit", "Edit");
                Edit.Image.IconID = "actions_edit_16x16devav";
                if (MT_Update_Rights == true) e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Edit);

                var Deleteitem = e.CreateItem("Delete", "Delete");
                Deleteitem.Image.IconID = "actions_delete_16x16devav";
                if (MT_Delete_Rights == true)e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Deleteitem);

                var Viewitem = e.CreateItem("View", "View");
                Viewitem.Image.IconID = "actions_show_16x16gray";
                if(MT_View_Rights==true)e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Viewitem);

                var PrintViewitem = e.CreateItem("Export", "ListPreview");
                PrintViewitem.Image.IconID = "actions_export_16x16devav";
                if (MT_Export_Rights == true)e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), PrintViewitem);

                var CloseItem = e.CreateItem("Close", "Close");
                CloseItem.Image.IconID = "actions_close_16x16devav";
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), CloseItem);

                var fullyreturn = e.CreateItem("Mark Full Returned", "MarkFullReturned");
                fullyreturn.Image.Url = "~/Icons/return_purchase-16.png";
                if (MT_Add_Rights == true) e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), fullyreturn);

                var Markreturn = e.CreateItem("Mark As Returned", "MarkRetunred");
                Markreturn.Image.Url = "~/Icons/return16.png";
                if (MT_Add_Rights == true) e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Markreturn);
            }
        };

        settings.KeyFieldName = "ID";

        settings.PreRender = (s, e) =>
        {
            MVCxGridView grid = (MVCxGridView)s;

            grid.FilterExpression = "";
        };

        //Columns
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Sr";
                column.Caption = "Sr.No.";
                column.Visible = true;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Issue_Date";
                column.Caption = "Issue Date";
                column.Visible = true;
                column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Issued_To";
                column.Caption = "Issue To";
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Gender";
                column.Caption = "Gender";
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Contractor";
                column.Caption = "Contractor Name";
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Job";
                column.Caption = "Job Name";
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Complex";
                column.Caption = "Complex Name";
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Allocation_Returned_Status";
                column.Caption = "Status";
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Issued_By";
                column.Caption = "Issued By";
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Allocation_Return_Remarks";
                column.Caption = "Remarks";
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "AddedBy";
                column.Caption = "Add By";
                column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "EditedBy";
                column.Caption = "Edit By";
                column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "AddedOn";
                column.Caption = "Add On";
                column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "EditedOn";
                column.Caption = "Edit On";
                column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "ID";
                column.Caption = "ID";
                column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "CurrUserRole";
                column.Caption = "Curr User Role";
                column.Visible = false;
            }
        });
        settings.SettingsCookies.Enabled = true;
        settings.SettingsCookies.CookiesID = "MTACookie";
        settings.Settings.VerticalScrollBarMode = ScrollBarMode.Visible;
        if (MT_ShowHorizontalBar == 1)
        {
            settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Visible;
            settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.Off;
            settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.Control;
            settings.SettingsResizing.Visualization = ResizingMode.Postponed;
        }
        else
        {
            settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.HideDataCells;
            settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Hidden;
            settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.Disabled;
            //settings.SettingsAdaptivity.HideDataCellsAtWindowInnerWidth = 500;
        }
        settings.Settings.ShowHeaderFilterBlankItems = false;
        settings.SettingsContextMenu.Enabled = true;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsContextMenu.EnableGroupFooterMenu = DefaultBoolean.True;
        settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;
        settings.Settings.ShowHeaderFilterButton = true;
        settings.KeyboardSupport = true;
        //settings.AccessKey = "G";
        settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
        settings.SettingsBehavior.ProcessColumnMoveOnClient = true;
        settings.SettingsBehavior.ColumnMoveMode = GridColumnMoveMode.AmongSiblings;
        settings.Settings.ShowGroupFooter = GridViewGroupFooterMode.VisibleAlways;
        settings.Settings.UseFixedTableLayout = true;
        settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
        settings.SettingsBehavior.AllowSort = true;
        settings.SettingsBehavior.AllowSelectByRowClick = true;
        settings.SettingsBehavior.EnableCustomizationWindow = true;

        settings.SettingsPager.Mode = GridViewPagerMode.ShowPager;
        settings.SettingsPager.PageSize = 25;
        settings.SettingsPager.AlwaysShowPager = true;
        settings.SettingsPager.EnableAdaptivity = true;
        settings.SettingsPager.PageSizeItemSettings.Visible = true;

        settings.SettingsSearchPanel.ShowApplyButton = true;
        settings.SettingsSearchPanel.ShowClearButton = true;
        settings.SettingsBehavior.AllowFocusedRow = true;
        // show filter control
        settings.Settings.ShowFilterBar = GridViewStatusBarMode.Visible;
        settings.Settings.ShowFilterRow = false;
        settings.Settings.AutoFilterCondition = AutoFilterCondition.Contains;
        settings.SettingsFilterControl.ViewMode = true ? FilterControlViewMode.VisualAndText : FilterControlViewMode.Visual;
        settings.SettingsFilterControl.AllowHierarchicalColumns = true;// AllowHierarchicalColumns;
        settings.SettingsFilterControl.ShowAllDataSourceColumns = true;//FilterBuilderDemoHelper.Options.ShowAllDataSourceColumns;
        settings.SettingsFilterControl.MaxHierarchyDepth = 1;
        //settings.Settings.ShowGroupedColumns = ShowGroupedColumns;
        settings.Settings.ShowFooter = false;
        settings.SettingsCustomizationDialog.ShowSortingPage = true;
        settings.SettingsCustomizationDialog.ShowGroupingPage = true;
        settings.SettingsCustomizationDialog.ShowFilteringPage = true;
        settings.SettingsCustomizationDialog.ShowColumnChooserPage = true;

        settings.ClientSideEvents.Init = "MTOnInit";
        settings.ClientSideEvents.BeginCallback = "MTAllocationRegisterGrid_BeginCallBack";
        settings.ClientSideEvents.EndCallback = "MTAllocationRegisterGrid_EndCallBack";
        settings.ClientSideEvents.FocusedRowChanged = "MTAllocationGridFocusedRowChanged";
        settings.ClientSideEvents.ContextMenuItemClick = "MTAllocationContextMenuFunction";
        settings.ClientSideEvents.DetailRowExpanding = "ExpandMTRow";
        settings.ClientSideEvents.DetailRowCollapsing = "CollapseMTRow";
    }).Bind(Model).GetHtml()
