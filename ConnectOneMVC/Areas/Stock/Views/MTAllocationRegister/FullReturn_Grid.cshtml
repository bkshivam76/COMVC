@{
    var SessionGUID = Request.QueryString["SessionGUID"];
}
@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "MTFullReturnGrid";
        settings.CallbackRouteValues = new
        {
            Controller = "MTAllocationRegister",
            Action = "FullReturn_Grid",
            SessionGUID = SessionGUID
        };
        settings.Settings.VerticalScrollBarMode = ScrollBarMode.Visible;
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Visible;
        settings.Settings.VerticalScrollableHeight = 100;
        settings.KeyboardSupport = true;
        //settings.AccessKey = "G";
        settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
        settings.SettingsBehavior.AutoExpandAllGroups = false;
        settings.SettingsBehavior.AllowSelectSingleRowOnly = false;
        settings.SettingsBehavior.AllowSelectByRowClick = false;
        settings.Settings.UseFixedTableLayout = true;
        settings.SettingsBehavior.ColumnMoveMode = GridColumnMoveMode.AmongSiblings;
        settings.SettingsBehavior.AllowSort = true;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.NextColumn;
        settings.SettingsResizing.Visualization = ResizingMode.Live;
        settings.SettingsBehavior.AllowEllipsisInText = true;
        settings.SettingsPager.Mode = GridViewPagerMode.ShowAllRecords;
        settings.SettingsSearchPanel.ShowApplyButton = true;
        settings.SettingsSearchPanel.ShowClearButton = true;
        settings.SettingsBehavior.AllowFocusedRow = false;
        settings.Settings.ShowHeaderFilterBlankItems = false;
        settings.SettingsContextMenu.Enabled = false;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;
        settings.SettingsCustomizationDialog.ShowColumnChooserPage = true;
        settings.PreRender = (sender, e) =>
        {
            ASPxGridView grid = (ASPxGridView)sender;
            grid.FocusedRowIndex = -1;
        };
        settings.KeyFieldName = "Sr";

        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "MachineName";
                column.Caption = "Machine Name";
                column.Visible = true;
                column.Width = System.Web.UI.WebControls.Unit.Percentage(25);
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "IssueDate";
                column.Caption = "Issue Date";
                column.Visible = true;
                column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
                column.Width = System.Web.UI.WebControls.Unit.Percentage(15);
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "QtyIssued";
                column.Caption = "Quantity Issued";
                column.Visible = true;
                column.Width = System.Web.UI.WebControls.Unit.Percentage(15);
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "QtyPending";
                column.Caption = "Quantity Pending";
                column.Visible = true;
                column.Width = System.Web.UI.WebControls.Unit.Percentage(15);
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "QtyReturned";
                column.Caption = "Quantity Returned";
                column.Visible = true;
                column.Width = System.Web.UI.WebControls.Unit.Percentage(15);
                column.SetDataItemTemplateContent(c =>
                {
                    Html.DevExpress().SpinEdit(x =>
                    {
                        x.Name = "txt" + c.KeyValue + c.Column.FieldName;
                        x.Width = System.Web.UI.WebControls.Unit.Percentage(100);
                        x.Properties.SpinButtons.ShowIncrementButtons = false;
                        x.Properties.AllowMouseWheel = false;
                        x.ControlStyle.BackColor = System.Drawing.Color.Aqua;
                        x.ControlStyle.Border.BorderStyle = BorderStyle.None;
                        x.ControlStyle.HorizontalAlign = HorizontalAlign.Right;
                        x.Properties.NumberType = SpinEditNumberType.Integer;
                        x.Properties.AllowNull = false;
                        x.Properties.ClientSideEvents.ValueChanged = String.Format("function (s, e) {{ FullReturn_ValueChanged(s, '{0}', '{1}'); }}", c.Column.FieldName, c.KeyValue);

                    }).Bind(DataBinder.Eval(c.DataItem, c.Column.FieldName)).Render();
                });
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "IssuingStore";
                column.Caption = "Issuing Store";
                column.Visible = true;
                column.Width = System.Web.UI.WebControls.Unit.Percentage(15);
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Sr";
                column.Caption = "Sr no";
                column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "IssueRowID";
                column.Caption = "IssueRowID";
                column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "MachineToolID";
                column.Caption = "MachineToolID";
                column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "ID";
                column.Caption = "ID";
                column.Visible = false;
            }
        });
    }).Bind(Model).GetHtml()

