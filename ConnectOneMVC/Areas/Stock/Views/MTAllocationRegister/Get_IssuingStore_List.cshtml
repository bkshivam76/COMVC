@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                                .ID("GetIssuingStoreDG")                              
                                .Columns(columns =>
                                {
                                    columns.Add().DataField("Store_Name").Caption("Store");
                                    columns.Add().DataField("Sub_Dept_Name").Caption("Sub Dept");
                                    columns.Add().DataField("Dept_Name").Caption("Dept");
                                    columns.Add().DataField("Dept_Incharge_Name").Caption("Incharge");
                                    columns.Add().DataField("StoreID").Visible(false);
                              
                                })                               
                                .Selection(s => s.Mode(SelectionMode.Single))
                       
)




