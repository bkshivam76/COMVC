@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                                                    .ID("GetReturnMachineToolDG")
                                                    .Columns(columns =>
                                                    {
                                                        columns.Add().DataField("Name").Caption("Name");
                                                        columns.Add().DataField("Machine_Code").Caption("Machine Code");
                                                        columns.Add().DataField("Issue_Date").Caption("Date of Issue").DataType(GridColumnDataType.Date).Format("dd/MM/yyyy");
                                                        columns.Add().DataField("Issued_Qty").Caption("Qty Issued");
                                                        columns.Add().DataField("Pending_Qty").Caption("Qty Pending");
                                                        columns.Add().DataField("Issued_To").Caption("Issued To");
                                                        columns.Add().DataField("Usage_Site").Caption("Usage Site");
                                                        columns.Add().DataField("Job").Caption("Job");
                                                        columns.Add().DataField("IssueID").Visible(false); //bug 1171 resolved
                                                        columns.Add().DataField("MachineToolID").Visible(false); //bug 1171 resolved
                                                        columns.Add().DataField("Issuing_Store_ID").Visible(false);
                                                        columns.Add().DataField("Sr").Visible(false);
                                                    })

                                                    .Selection(s => s.Mode(SelectionMode.Single))

)


