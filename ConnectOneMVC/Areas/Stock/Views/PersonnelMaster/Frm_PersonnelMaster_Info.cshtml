        @(Html.DevExtreme().Button().ID("btnpersonnnelExpandAll").Text("Expand All").Icon("preferences").OnClick(@<text> function () { PersonnelMasterExpandAll(); } </text>))
        @(Html.DevExtreme().Button().ID("Personnel_MasterCLOSE").Text("Close").Icon("clear").OnClick(@<text> function (){$(".TabPanalMenu-tabs .active span").click()} </text>))
