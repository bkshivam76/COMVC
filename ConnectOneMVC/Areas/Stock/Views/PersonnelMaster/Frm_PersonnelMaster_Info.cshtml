<div id="content" class="col-md-12 report_header_div_main">
    <div class="col-md-4 report_header_div">
        <label class="report_header_label">Personnel Master</label>
    </div>
    <div class="report_button_div">
        @(Html.DevExtreme().Button().ID("Personnel_MasterNew").Text("New").Icon("add").Visible(true).Disabled(false).OnClick(@<Text> function () { PersonnelMaster_NEW(); } </Text>))
        @(Html.DevExtreme().Button().ID("Personnel_MasterEdit").Text("Edit").Icon("edit").Visible(true).Disabled(false).OnClick(@<text> function () { PersonnelMaster_NEVD("Edit"); } </text>))
        @(Html.DevExtreme().Button().ID("Personnel_MasterDelete").Text("Delete").Icon("trash").Visible(true).Disabled(false).OnClick(@<text> function () { PersonnelMaster_NEVD("Delete"); } </text>))
        @(Html.DevExtreme().Button().ID("Personnel_MasterView").Text("View").Icon(IconID.ViewCustomers16x16devav).Icon("doc").Visible(true).Disabled(false).OnClick(@<text> function () { PersonnelMaster_NEVD("View"); } </text>))
        @(Html.DevExtreme().Button().ID("Personnel_MasterListPreview").Text("List Export").Icon("save")/*.Width(105)*/.OnClick(@<text> function () { Personnel_MasterListPreviewClick(); } </text>))
