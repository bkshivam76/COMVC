@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    var PersonnelID =(int) ViewData["PersonnelID"];
}
@Html.DevExpress().GridView(settings =>
{
    settings.Name = "PersonnelCharges" + PersonnelID;
    settings.SettingsDetail.MasterGridName = "PersonnelChargesListGrid";
    settings.CallbackRouteValues = new { Controller = "PersonnelMaster", Action = "Frm_PersonnelMaster_PersonnelCharges_Grid", PersonnelID = PersonnelID, SessionGUID = SessionGUID };
    settings.Width = Unit.Percentage(100);
    settings.KeyFieldName = "ID";
    settings.Columns.Add("ID").Visible = false;
    settings.Columns.Add("Personnel_ID").Visible = false;
    settings.Columns.Add("Effective_Till").Visible = false;
    settings.Columns.Add("Charges");
    settings.Columns.Add("Unit");
    settings.Columns.Add("Remarks");
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Effective_Date";
            column.Caption = "Effective Date";
            column.ColumnType = MVCxGridViewColumnType.DateEdit;
            ((DateEditProperties)column.PropertiesEdit).DisplayFormatString = "dd/MM/yyyy";
        }
    });//Mantis bug 0001037 fixed
    settings.ClientSideEvents.Init="Personnelnestedgridinit";
    settings.ClientSideEvents.FocusedRowChanged = "OnPersonnel_NestedGridFocusedRowChanged";
    settings.SettingsBehavior.AllowFocusedRow = true;
    settings.SettingsBehavior.AllowSelectByRowClick = true;
    settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
    settings.CustomDataActionRouteValues = new { Controller = "PersonnelMaster", Action = "PersonnelChargesCustomDataAction" };
    settings.PreRender = (sender, e) =>
    {
        ASPxGridView grid = (ASPxGridView)sender;
        grid.FocusedRowIndex = -1;
    };
}).Bind(Model).GetHtml()

