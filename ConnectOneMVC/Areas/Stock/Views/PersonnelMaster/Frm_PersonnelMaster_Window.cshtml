                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                @Html.ValidationMessageFor(model => model.Personnel_OtherDetails, "", new { @class = "text-danger" })
