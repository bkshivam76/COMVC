</div>
<script type="text/javascript">
   
    var form = "PersonnelMastervalidationForm";
    $(document).ready(function ()
    {
        ShowLoader();
        if ($("#Store_Dept_MastervalidationForm").length) {
            $("#Per_AddDept").dxButton("instance").option("visible", false);
        }
        AssignIDtoLabel(form, "Personnel");
        $("#Personnel_right_div_id").height($("#Personnel_left_div_id").height());
        $("#Personnel_SkillTypeID1").dxList("instance").option("height", $("#Personnel_left_div_id").height());
        sessionclearpath = "/Stock/PersonnelMaster/Sessionclear";
        if ("@Model.ActionMethod" != "View")
        {
            dontaskpopupcloseconfirmation = false;
        }    
        if ("@Personnel_AddDeptRights" == "False") { $("#Per_AddDept").hide(); }
        if ("@Model.ActionMethod" == "Edit")
        {
            if (Personnelusagecountcheck == false)
            {
                $("#Personnel_PersonNameID").dxDropDownBox("instance").option("readOnly", true);
                $("#Personnel_DesignationID").dxDropDownBox("instance").option("readOnly", true);
                $("#Personnel_DeptID").dxDropDownBox("instance").option("readOnly", true);
                $("#Personnel_SubDeptID").dxDropDownBox("instance").option("readOnly", true);
                $("#Personnel_Type").dxSelectBox("instance").option("readOnly", true);
                $("#Personnel_PaymentMode").dxSelectBox("instance").option("readOnly", true);

            }
        }

        if (("@Model.ActionMethod" == "Edit" || "@Model.ActionMethod" == "View" || "@Model.ActionMethod" == "Delete") && ("@Model.Personnel_Type" != "Paid")) {
            $("#Personnel_PaymentMode").dxSelectBox("instance").option("readOnly", true);
        }
        else { $("#lbl_payment_mode").addClass("text-red"); }


        setTimeout(function ()
        {
            if ("@Model.ActionMethod" == "View")
            {
                Set_Form_View_Delete_Mode("#000080", form);
            }
            else if ("@Model.ActionMethod" == "Delete")
            {
                Set_Form_View_Delete_Mode("#696969", form);
            }
            else
            {
                Focus_FirstEditable_Field(form);
            }
            HideLoader();
        }, Timeout500);
    });
    var personnellistselectkey = [];
    var personnel_MainDeptId;

    function PaidRequired()
    {
        $("#lbl_payment_mode").addClass("text-red");
        $("#Personnel_PaymentMode").dxSelectBox({})
            .dxValidator({
                validationRules: [{
                    type: 'required',
                    message: "Payment Mode Cannot be blank...!"
                }],
                validationGroup: "Stock_Personnel"
            });
    }//Mantis bug 0000301 fixed
    function LookUp_PersonnelDetails_Gen_Personnel_ChangeEvent(e)
    {
        if (e.previousValue!=null&&e.previousValue != e.value)
        {
            var emptylist = [];
            $("#Personnel_Type").dxSelectBox("instance").reset();
            $("#Personnel_DesignationID").dxDropDownBox("instance").reset();
            $("#Personnel_ContractorID").dxDropDownBox("instance").reset();
            $("#Personnel_DeptID").dxDropDownBox("instance").reset();
            $("#Personnel_LeavingDate").dxDateBox("instance").reset();
            $("#Personnel_JoiningDate").dxDateBox("instance").reset();
            $("#Personnel_PFNO").dxTextBox("instance").reset();
            $("#Personnel_SkillTypeID1").dxList("instance").option("selectedItemKeys", emptylist);
        }
        var dropDownBox = $("#Personnel_PersonNameID").dxDropDownBox("instance");
        dropDownBox.close();
        var $dataGrid = $("#Frm_PersonnelMaster_GetLookUp_PersonnelList_datagrid");
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(dropDownBox.option("value"), false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                $("#Personnel_Name").val(item["Name"]);
                $("#Personnel_Gender").dxTextBox("instance").option("value", item["Gender"]);
                $("#Personnel_PANNo").dxTextBox("instance").option("value", item["Pan_No"]);
                $("#Personnel_DOB").dxTextBox("instance").option("value", item["DoB"]);
                $("#Personnel_AadharNo").dxTextBox("instance").option("value", item["Aadhar_No"]);
                $("#Personnel_ContactNO").dxTextBox("instance").option("value", item["Mobile_No"]);
                $("#Frm_PersonnelMaster_GetContractor_datagrid").dxDataGrid("instance").refresh();
                $("#Frm_PersonnelMaster_GetDesignation_datagrid").dxDataGrid("instance").refresh();
                $("#Frm_PersonnelMaster_Getdepartment_datagrid").dxDataGrid("instance").refresh();
            }
        }
    }
    function PersonnelDetails_Gen_Personnel_init(e)
    {
        if ("@Model.ActionMethod" != "New") {
            $("#Personnel_PersonNameID").dxDropDownBox("instance").option("value","@Model.Personnel_PersonNameID")
                e.component.option("dataSource").store.load().done(function (d) {
                    if (d.length > 0) {
                        var $dataGrid = $("#Frm_PersonnelMaster_GetLookUp_PersonnelList_datagrid");
                        if ($dataGrid.length) {
                            var dataGrid = $dataGrid.dxDataGrid("instance");
                            dataGrid.selectRows("@Model.Personnel_PersonNameID", false);
                        }
                    }
                });
            }
    }// person name init
    function LookUp_PersonnelType_ChangeEvent_Paid(e) {
        debugger;
        if (e.value != "Paid") {
            $("#Personnel_PaymentMode").dxSelectBox("instance").reset();
            $("#Personnel_PaymentMode").dxSelectBox("instance").option("readOnly", true);
            $("#lbl_payment_mode").removeClass("text-red");
            $("#Personnel_PaymentMode").dxSelectBox({})
                .dxValidator({
                    validationRules: [{
                        type: 'custom',
                        validationCallback: function (options) {
                            var result = false;
                            if (options.value != "Paid") {
                                result = true;
                            }
                            return result;
                        },
                        message: ""
                    }],
                    validationGroup: "Stock_Personnel"
                });
        }
         else {
             $("#Personnel_PaymentMode").dxSelectBox("instance").option("readOnly", false);
             PaidRequired();
        }
    }//Mantis bug 0000301 fixed
    function LookUp_PersonnelDetails_Designation_ChangeEvent(e) {
        var dropDownBox = $("#Personnel_DesignationID").dxDropDownBox("instance");
        dropDownBox.close();
        var $dataGrid = $("#Frm_PersonnelMaster_GetDesignation_datagrid");
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(dropDownBox.option("value"), false);

        }
    }
    function LookUp_PersonnelDetails_Contractor_ChangeEvent(e) {
        if (e.fullName == "text") {
        var dropDownBox = $("#Personnel_ContractorID").dxDropDownBox("instance");
        dropDownBox.close();
        var $dataGrid = $("#Frm_PersonnelMaster_GetContractor_datagrid");
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(dropDownBox.option("value"), false);
          }
        }
    }
    function Personnel_DeptIDInitialize(e)
    {
        personnel_MainDeptId = "@Model.Personnel_DeptID";
        e.component.option("dataSource").store.load().done(function (d)
        {
            e.component.option("value", "@Model.Personnel_DeptID");
        });
    }//Mantis bug 0000304 fixed
    function LookUp_GetDepartmentList_ChangeEvent(e) {
        var dropDownBox = $("#Personnel_DeptID").dxDropDownBox("instance");
        dropDownBox.close();
        if (e.previousValue != null && e.previousValue != e.value)
                {
            $("#Personnel_SubDeptID").dxDropDownBox("instance").reset();
        }
        var $dataGrid = $("#Frm_PersonnelMaster_Getdepartment_datagrid");
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(e.value, false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                personnel_MainDeptId = item.ID;
                $("#Frm_PersonnelMaster_GetSubdepartment_datagrid").dxDataGrid("instance").refresh();
            }
        }
    }
    function LookUp_GetSubDepartmentList_ChangeEvent(e) {
        var dropDownBox = $("#Personnel_SubDeptID").dxDropDownBox("instance");
        dropDownBox.close();
    }

    function Listinitialize(e)
    {

        var listBox = $("#Personnel_SkillTypeID1").dxList("instance");
        if ("@Model.ActionMethod"== "Edit" || "@Model.ActionMethod" == "View" || "@Model.ActionMethod" == "Delete")
        {
                personnellistselectkey = "@Model.Personnel_SkillTypeID".split(',');
            listBox.option("selectedItemKeys", personnellistselectkey);
        }
    }// List Initialize
    function OnListSelectionChanged(e) {

        var listBox = $("#Personnel_SkillTypeID1").dxList("instance");
        if ("@Model.ActionMethod" == "Edit")
        {
            var currentselectedkeys = listBox.option("selectedItemKeys");
                for (var i = 0; i < personnellistselectkey.length; i++)
                {
                    var index = currentselectedkeys.indexOf(personnellistselectkey[i]);
                    if (index == -1) {
                        if (Personnelusagecountcheck == false) {
                            DevExpress.ui.dialog.alert('An Already Selected Skill Type Cannot Be De-selected, If Personnel Has Been Used In Some Other Entry..!!', 'Information');
                            currentselectedkeys.push(personnellistselectkey[i]);
                            listBox.option("selectedItemKeys", currentselectedkeys);
                            break;
                        }
                    }
                }
        }
        $("#Personnel_SkillTypeID").val(listBox.option("selectedItemKeys").join(","));
    }// List Selection Changed
    function delete_personnel()
    {
        var result = DevExpress.ui.dialog.confirm("Sure you want to delete?", "Delete ~ Personnel");
        result.done(function (dialogResult) {
            if (dialogResult) {
                $("#PersonnelMastervalidationForm").submit();
            }
        });
    }
    function personnel_Add_Department_Click()
    {
        if ("@Personnel_AddDeptRights" == "False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights")
            return;
        }
        ShowLoader();
        $.ajax({
            type: "GET",
            url: "/Stock/Store_Dept_Master/Frm_Store_Dept_Master_Window",
            data: {
                ActionMethod: "New",
                ID: 0,
                PostSucessFunction: "personnelAddstoredeptSuccess",
                PopupName: "Personnel_Button_popup",
                ButtonID:"Per_AddDept"
            },
            success: function (data)
            {
                ShowLoader();
                OpenPopup("Personnel_Button_popup", "New ~ Dept", null, "auto", "85%", true, data);
                HideLoader();
            }
        });
        HideLoader();

    }
    function personnelAddstoredeptSuccess(data)
    {
        HideLoader();
        if (data.result == true)
        {
            $("#Personnel_Button_popup").dxPopup("hide");
            $("#Frm_PersonnelMaster_Getdepartment_datagrid").dxDataGrid("instance").refresh();
        }
        else
        {
            DevExpress.ui.dialog.alert(data.Message, "Error");
        }
    }
    function Add_Person_Click() {
        DevExpress.ui.dialog.alert("Coming soon...!", 'Inform!');
    }
    function Update_Person_Click() {
        DevExpress.ui.dialog.alert("Coming soon...!", 'Inform!');
    }
    function close_personnel()
    {
        if ("@Model.PopupName" == "Dynamic_Content_popup")
        {
            if ("@Model.ActionMethod" != "View")
            {
                dontaskpopupcloseconfirmation = false;
            }
            sessionclearpath = "/Stock/PersonnelMaster/Sessionclear";
        }
        var popupnameid = "#" + "@Model.PopupName";
        $(popupnameid).dxPopup("hide");
    }
</script>


