
@model ConnectOneMVC.Areas.Stock.Models.Model_PersonnelRates_Window
@using DevExtreme.AspNet.Mvc;
<script src="~/Content/fontawesome/js/fontawesome_v5_all.js"></script>
@{
     ViewBag.Test = Model.ActionMethod;  
    bool IsVisible = Model != null && (Model.ActionMethod.ToString().Trim() == "View" || Model.ActionMethod.ToString().Trim() == "Delete") ? true : false;
}
@{
    Html.EnableClientValidation();
    Html.EnableUnobtrusiveJavaScript();
}

<style>
    .control-label {
        text-align: left !important;
    }
    /*.dx-button-has-text .dx-button-content {
        margin-right: 15px;
        padding: 2px 1px;
        min-width: 40px;
        padding-left: 19px;
    }*/
    .dx-texteditor-container {
        overflow: visible
    }
</style>
<div id="Frm_PersonnelMaster_Charge_Content">
    @using (Ajax.BeginForm("Frm_PersonnelRates_Window", "PersonnelMaster",
                                              new AjaxOptions
                                              {
                                                  HttpMethod = "POST",
                                                  UpdateTargetId = "Frm_PersonnelRates_Window",
                                                  InsertionMode = InsertionMode.InsertAfter,
                                                  OnBegin = "AjaxBeginFormPost",
                                                  OnSuccess = "PersonnelMasterChargeAjaxSuccessForm"
                                              },
                                              new
                                              {
                                                  id = "PersonnelMasterChargevalidationForm",
                                                  @class = "edit_form"
                                              }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.ActionMethod)
        @Html.HiddenFor(x => x.PersonnelCharges_ChargeID)
        @Html.HiddenFor(x => x.PersonnelCharges_PersonnelID)


        var errors = ViewData.ModelState.Where(n => n.Value.Errors.Count > 0).Select(c => c.Value.Errors).ToList();
        using (Html.DevExtreme().ValidationGroup())
        {
            <div class="full-width-header">
                <div class="row">

                    <div class="col-sm-8 pll">
                        <h3 class="popuphead"><i class="far fa-edit"></i>Personnel Rates For @Model.PersonnelCharges_PersonnelName </h3>
                    </div>
                    <div class="col-sm-4 prm">
                        <h5 class="mand-txt-align"><i class="fas fa-info-circle"></i> Red Fields are mandatory</h5>
                    </div>
                    @Html.ValidationSummary(true, "", new { @class = "text-red" })
                </div>
            </div><!--[row]-->

            <div class="row">
                <div class="col-sm-4">
                    <div class="form-field">
                        <div class="container-fluid ">
                            <div class="row">
                                <div class="col-sm-4 pll">
                                    @Html.LabelFor(model => model.PersonnelCharges_EffDate, htmlAttributes: new { @class = "control-label text-red" })
                                </div>
                                <div class="col-sm-8 prm">
                                    <div class="dx-texteditor dx-widget dx-textbox">
                                        <div class="dx-texteditor-container">
                                            @(Html.DevExtreme().DateBoxFor(model => model.PersonnelCharges_EffDate).CustomDateBox().ID("PersonnelCharges_EffDate").Name("PersonnelCharges_EffDate").Placeholder("Enter Date")
                                                         .ReadOnly(IsVisible).ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).Disabled(IsVisible).TabIndex(1) )
                                            @Html.ValidationMessageFor(model => model.PersonnelCharges_EffDate, "", new { @class = "text-red " })
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Effective Date]-->
                <div class="col-sm-4">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-4 pll">
                                    @Html.LabelFor(model => model.PersonnelCharges_Charges, htmlAttributes: new { @class = "control-label text-red" })
                                </div>
                                <div class="col-sm-8 prm">
                                    <div class="dx-texteditor dx-widget dx-textbox">
                                        <div class="dx-texteditor-container">
                                            @(Html.DevExtreme().NumberBoxFor(x => x.PersonnelCharges_Charges).CustomNumberBox().ID("PersonnelCharges_Charges").Name("PersonnelCharges_Charges").Placeholder("Enter Charges")
                                                         .Format("#0.00").ShowClearButton(true).ReadOnly(IsVisible).Disabled(IsVisible).TabIndex(2))
                                            @Html.ValidationMessageFor(model => model.PersonnelCharges_Charges, "", new { @class = "text-red " })
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Charges]-->
                <div class="col-sm-4">
                    <div class="form-field">
                        <div class="container-fluid ">
                            <div class="row">
                                <div class="col-sm-2 pll">
                                    @Html.LabelFor(model => model.PersonnelCharges_UnitID, htmlAttributes: new { @class = "control-label text-red" })
                                </div>
                                <div class="col-sm-10 prm">
                                    <div class="dx-texteditor dx-widget dx-textbox">
                                        <div class="dx-texteditor-container">
                                            @(Html.DevExtreme().DropDownBoxFor(y => y.PersonnelCharges_UnitID).CustomDropDown().ID("PersonnelCharges_UnitID").Name("PersonnelCharges_UnitID").DisplayExpr("Unit").ValueExpr("Unit_ID").DataSource(d => d.Mvc().Controller("PersonnelMaster")
                                                          .LoadAction("LookUp_GetUnitList").Key("Unit_ID")).Placeholder("Select Unit").ReadOnly(IsVisible).Disabled(IsVisible).ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).TabIndex(3).OnValueChanged("LookUp_PersonnelDetails_Unitlist_ChangeEvent").ContentTemplate(@<text> @Html.Partial("LookUp_GetUnitList") </text>) )
                                            @Html.ValidationMessageFor(model => model.PersonnelCharges_UnitID, "", new { @class = "text-red" })

                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Unit]-->
            </div>
            <div class="row">
                <div class="col-sm-12 col-md-12 col-lg-12">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-2 col-md-2 col-lg-2 pll">
                                    @Html.LabelFor(model => model.PersonnelCharges_Remarks, htmlAttributes: new { @class = "control-label text-black" })

                                </div>
                                <div class="col-sm-10 col-md-10 col-lg-10 prm">
                                    <div class="dx-texteditor dx-widget dx-textbox">
                                        <div class="dx-texteditor-container">
                                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("PersonnelCharges_Remarks").Name("PersonnelCharges_Remarks").Placeholder("Enter Remarks..").Disabled(IsVisible).ReadOnly(IsVisible).ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).MaxLength(255).TabIndex(4) )

                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div><!--[Remarks]-->

            <div class="row">
                <div class="col-sm-12 col-md-12 col-lg-12">
                    <div class="styleActionBtn">
                        @if (Model.ActionMethod.ToString().Trim() == "Delete")
                        {
                            @(Html.DevExtreme().Button().CustomSaveButton().ID("PersonnelMasterChargeNew").Text("Delete").FocusStateEnabled(true).TabIndex(5).UseSubmitBehavior(false).OnClick(@<text>function () { delete_personnelrates(); }</text>) )

                        }
                        else
                        {
                            @(Html.DevExtreme().Button().CustomSaveButton().ID("PersonnelMasterChargeNew").Text("Save").FocusStateEnabled(true).TabIndex(5).UseSubmitBehavior(true).Visible(Model.ActionMethod == "View" ? false : true) )
                                                    }
                        @(Html.DevExtreme().Button().CustomCloseButton().ID("PersonnelMasterChargeCancel").Text(Model.ActionMethod == "View" ? "Close" : "Cancel").FocusStateEnabled(true).TabIndex(6).OnClick(@<text> function () { close_personnelrates(); } </text>) )

                    </div>
                </div>
            </div><!--[Buttons]-->

        }
    }
</div>
<script>
    
    $(document).ready(function ()
    {
        var form = "PersonnelMasterChargevalidationForm";
        ShowLoader();
        AssignIDtoLabel(form, "Personnel_Rates");
        sessionclearpath = "/Stock/PersonnelMaster/Sessionclear";   
        dontaskpopupcloseconfirmation = false;

        setTimeout(function ()
        {
            if ("@Model.ActionMethod" == "View")
            {
                Set_Form_View_Delete_Mode("#000080", form);
            }
            else if ("@Model.ActionMethod" == "Delete")
            {
                Set_Form_View_Delete_Mode("#696969", form);
            }
            else
            {
                Focus_FirstEditable_Field(form);
            }
            HideLoader();
        }, Timeout500);
    });
    function LookUp_PersonnelDetails_Unitlist_ChangeEvent() {
        var dropDownBox = $("#PersonnelCharges_UnitID").dxDropDownBox("instance");
        dropDownBox.close();
        var $dataGrid = $("#Frm_PersonnelMaster_Getunit_datagrid");
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(dropDownBox.option("value"), false);
        }
    }
    function delete_personnelrates()
    {
        var result = DevExpress.ui.dialog.confirm("Sure you want to delete?", "Delete ~ Personnel Rate");
        result.done(function (dialogResult) {
            if (dialogResult) {
                $("#PersonnelMasterChargevalidationForm").submit();
            }
        });
    }
    function close_personnelrates()
    {
        sessionclearpath = "/Stock/PersonnelMaster/Sessionclear"; 
        dontaskpopupcloseconfirmation = false;
        $("#Dynamic_Content_popup").dxPopup("hide"); 
    }
</script>
