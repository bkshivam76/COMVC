@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("Frm_PersonnelMaster_GetLookUp_PersonnelList_datagrid")
 
    .Columns(columns =>
    {

        columns.Add().DataField("Name").Caption("Name");
        columns.Add().DataField("Gender").Caption("Gender");
        columns.Add().DataField("DoB").Caption("Date of Birth");
        columns.Add().DataField("Aadhar_No").Caption("Aadhar no");
        columns.Add().DataField("ID").Caption("ID").Visible(false);//Mantis bug 0001030 fixed
        columns.Add().DataField("Pan_No").Caption("Pan_No").Visible(false);
        columns.Add().DataField("Mobile_No").Caption("Mobile_No").Visible(false);     
       
            })            
  
    .Selection(s => s.Mode(SelectionMode.Single))

)

