@model ConnectOneMVC.Areas.Stock.Models.Model_NEVD_Production
@using DevExtreme.AspNet.Mvc;
@{
    bool IsVisible = (Model != null && Model.ActionMethod == "Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.ActionMethod == "View" || Model.ActionMethod == "Delete") ? true : false;
}
<div class="row">
    <div class="col-md-12">
        @Html.Action("ProductionDocumentsGridData", "ProductionRegister", new { ActionMethodName =Model.ActionMethod, Prod_ID =Model.Prod_ID })
    </div>
</div>

<div class="row">
    <div class="form-field">
        <div class="container-fluid">
            <div class="col-md-12 btnsDiv">
                @(Html.DevExtreme().Button().ID("productionBUT_DocNew").Text("New").Icon("fas fa-file btn-icons newfile icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Documents_New_Click() } </text>)) 
                @(Html.DevExtreme().Button().ID("productionBUT_DocEdit").Text("Edit").Icon("fas fa-pencil-alt btn-icons editcolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Document_Edit_Click() } </text>))
                @(Html.DevExtreme().Button().ID("productionBUT_DocDelete").Text("Delete").Icon("fas fa-trash btn-icons deletecolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Document_Delete_Click() } </text>))
                @(Html.DevExtreme().Button().ID("productionBUT_DocView").Text("View").Icon("fas fa-eye btn-icons eyeicon icon-rgt-space5").Disabled(IsVisible).OnClick(@<text> function () { OnFrm_Document_View_Click() } </text>))
            </div>
        </div>
    </div>
</div>
<script>
    var Document_Sr;
    var Document_ID;
    function OnDocumentDetailsGridFocusedRowChanged(s, e) {
        s.GetRowValues(s.GetFocusedRowIndex(), 'Sr_No;ID;', OnDocumentsDetailsGridRowValues);
    }
    function OnDocumentsDetailsGridRowValues(values) {
        Document_Sr = values[0];
        Document_ID = values[1];    
    }
    $("#ProductionDocumentsGrid").keydown(function (evt) {
        switch (evt.keyCode) {
            case 45: // insert key
                OnFrm_Documents_New_Click();
                break;
            case 13: //enter key
                OnFrm_Document_Edit_Click();
                break;
            case 32: //space bar
                OnFrm_Document_View_Click();
                break;
            case 46://delete key
                OnFrm_Document_Delete_Click();
                break;
        }
        if (evt.ctrlKey && evt.keyCode == 73)//ctrl+i
        {
            OnFrm_Documents_New_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 69)//ctrl+e
        {
            OnFrm_Document_Edit_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_Document_View_Click();
        }
    });
    function OnFrm_Documents_New_Click()
    {       
        if ("@IsDisabled" == "true") { return; }
        $("#ID_Frm_Help_Document_Attach").remove();
        ShowLoader();       
        $.ajax({
            type: 'GET',
            url: "/Help/Attachment/Frm_Attachment_Window",
            data: {
                AM:"New",
                PostSucessFunctionName:"Frm_Production_Documents_Window_OnSuccess",
                Post_action_Name:"Production_Documents_Attachment",
                Post_Controller_Name:"ProductionRegister",
                Post_Area_Name: "Stock",                
                Document_Grid_PopupName: "Productioninnergrid",
                ByteSessionVariable:"ProductionDocument"
            },
            cache: false,
            success: function (data)
            {
                OpenPopup("Productioninnergrid", "New ~ Documents", null, "auto", 900, true, data);            
            }
        });         
    }//new click//Mantis 0000213 bug fixed          
    function OnFrm_Document_Edit_Click()
      { if ("@IsDisabled"=="true") { return; }
          if (Document_Sr == 'undefined' || Document_Sr == undefined || Document_Sr == null || Document_Sr =="") {
              DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
              return;
          }
            $("#ID_Frm_Help_Document_Attach").remove();
            ShowLoader();
          $.ajax({
              type: 'GET',
              url: "/Help/Attachment/Frm_Attachment_Window",
              data: {
                  AM: "Edit",
                  PostSucessFunctionName: "Frm_Production_Documents_Window_OnSuccess",
                  Post_action_Name: "Production_Documents_Attachment",
                  Post_Controller_Name: "ProductionRegister",
                  Post_Area_Name: "Stock",                
                  Document_Grid_Data_SessionName: "Production_Documents_Window_Grid_Data_Prod",
                  Document_Grid_SrNo: Document_Sr,
                  ID: Document_ID,
                  Document_Grid_PopupName: "Productioninnergrid",
                  ByteSessionVariable: "ProductionDocument"
              },
              cache: false,
              success: function (data) {
                  OpenPopup("Productioninnergrid", "Edit ~ Documents", null, "auto", 900, true, data);    
              }
          });
                               
    }//edit click//Mantis 0000213 bug fixed
    function OnFrm_Document_Delete_Click() { if ("@IsDisabled"=="true") { return; }
        if (!Document_Sr) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        if (Document_ID) {
            $.ajax({
                type: 'GET',
                url: "/Stock/ProductionRegister/Production_Documents_Attachment_LinkCheck",
                data: { DocId: Document_ID, prodId: Prod_ID },
                cache: false,
                success: function (data) {
                    if (data.result == false) {
                        var deleteResultDocument = DevExpress.ui.dialog.confirm(data.message, "Confirm changes");
                        deleteResultDocument.done(function (dialogResult) {
                            if (dialogResult) {
                                $.ajax({
                                    type: 'GET',
                                    url: "/Stock/ProductionRegister/Frm_DocumentsDetail_Window_Delete_Grid_Record",
                                    data: { ActionMethod: "Unlink", Doc_ID: Document_ID },
                                    cache: false,
                                    success: function (result) {
                                        ProductionDocumentsGrid.SetFocusedRowIndex(-1);
                                        ProductionDocumentsGrid.Refresh();
                                    }
                                });
                            }
                        });
                    }
                    else
                    {
                        production_deletedocument();
                    }
                }
            });
        }
                    else {
            production_deletedocument();
                    }
                } //delete click          
    function production_deletedocument()
    { if ("@IsDisabled"=="true") { return; }
        var deleteResultPaymentDetail = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
        deleteResultPaymentDetail.done(function (dialogResult) {
            if (dialogResult) {
                $.ajax({
                    type: 'GET',
                    url: "/Stock/ProductionRegister/Frm_DocumentsDetail_Window_Delete_Grid_Record",
                    data: { ActionMethod: "Delete", SrID: Document_Sr, Doc_ID: Document_ID },
                    cache: false,
                    success: function (result) {
                        ProductionDocumentsGrid.SetFocusedRowIndex(-1);
                        ProductionDocumentsGrid.Refresh();
                    }
                });
            }
        });
    }    
    function OnFrm_Document_View_Click()
    {
        if (Document_Sr == 'undefined' || Document_Sr == undefined || Document_Sr == null || Document_Sr == "") {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }

        $("#ID_Frm_Help_Document_Attach").remove();
                   ShowLoader();
      $.ajax({
              type: 'GET',
              url: "/Help/Attachment/Frm_Attachment_Window",
              data: {
                  AM: "View",
                  PostSucessFunctionName: "Frm_Production_Documents_Window_OnSuccess",
                  Post_action_Name: "Production_Documents_Attachment",
                  Post_Controller_Name: "ProductionRegister",
                  Post_Area_Name: "Stock",
                  Document_Grid_Data_SessionName:"Production_Documents_Window_Grid_Data_Prod",
                  Document_Grid_SrNo: Document_Sr,
                  ID: Document_ID,
                  Document_Grid_PopupName: "Productioninnergrid",
                  ByteSessionVariable: "ProductionDocument"
              },
              cache: false,
              success: function (data) {
                  OpenPopup("Productioninnergrid", "View ~ Documents", null, "auto", 900, true, data);    
              }
          });
              
    }//Mantis 0000213 bug fixed
    function Frm_Production_Documents_Window_OnSuccess(data) {
        HideLoader();
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.message, "Error");
        }
        else {
            $("#Productioninnergrid").dxPopup("hide");
            ProductionDocumentsGrid.SetFocusedRowIndex(-1);
            ProductionDocumentsGrid.Refresh();
        }
    }



</script>