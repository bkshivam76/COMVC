@using DevExtreme.AspNet.Mvc
<div>
    @(Html.DevExtreme().Button()
                                        .ID("SI_ExportGridDatapdf")
                                        .Text("Export to PDF")
                                        .OnClick("ExportPDF")
                                        .Visible(true)
                                        .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                                        .ID("SI_ExportGridDataxls")
                                        .Text("Export to XLS")
                                        .OnClick("ExportXLS")
                                        .Visible(true)
                                        .Width(120)
    )<br />
    @(Html.DevExtreme().Button()
                                        .ID("SI_ExportGridDataxlsx")
                                        .Text("Export to XLSX")
                                        .OnClick("ExportXLSX")
                                        .Visible(true)
                                        .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                                        .ID("SI_ExportGridDatadocx")
                                        .Text("Export to DOCX")
                                        .OnClick("ExportDOCX")
                                        .Visible(true)
                                        .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                                        .ID("SI_ExportGridDatartf")
                                        .Text("Export to RTF")
                                        .OnClick("ExportRTF")
                                        .Visible(true)
                                        .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                                        .ID("SI_ExportGridDatacsv")
                                        .Text("Export to CSV")
                                        .OnClick("ExportCSV")
                                        .Visible(true)
                                        .Width(120)
    )
</div>
<script>
    function ExportPDF() {
        ProductionRegisterListGrid.ExportTo(ASPxClientGridViewExportFormat.Pdf);
        $("#ProductionRegister_report_modal").dxPopup("hide");
    }
    function ExportXLS() {
        ProductionRegisterListGrid.ExportTo(ASPxClientGridViewExportFormat.Xls);
        $("#ProductionRegister_report_modal").dxPopup("hide");
    }
    function ExportXLSX() {
        ProductionRegisterListGrid.ExportTo(ASPxClientGridViewExportFormat.Xlsx);
        $("#ProductionRegister_report_modal").dxPopup("hide");
    }
    function ExportCSV() {
        ProductionRegisterListGrid.ExportTo(ASPxClientGridViewExportFormat.Csv);
        $("#ProductionRegister_report_modal").dxPopup("hide");
    }
    function ExportDOCX() {
        ProductionRegisterListGrid.ExportTo(ASPxClientGridViewExportFormat.Docx);
        $("#ProductionRegister_report_modal").dxPopup("hide");
    }
    function ExportRTF() {
        ProductionRegisterListGrid.ExportTo(ASPxClientGridViewExportFormat.Rtf);
        $("#ProductionRegister_report_modal").dxPopup("hide");
    }
</script>

