    bool IsVisible = Model != null && (Model.ActionMethod.ToString().Trim() == "View") ? true : false;
    bool Production_AddItemMasterRight = (bool)ViewData["Production_AddItemMasterRight"];
}
@{
    Html.EnableClientValidation();
    Html.EnableUnobtrusiveJavaScript();
    Html.AntiForgeryToken();
}
<style>
    .demo {
        margin-bottom: -99999px !important;
        padding-bottom: 99999px !important;
    }

    #equalheight {
        overflow: hidden;
    }

    .wdfull {
        width: 100%;
    }

    td {
        width: auto;
    }

    .dntnbtn {
        min-width: 68px !important;
        font-size: 12px;
    }

    .fonttwelve {
        font-size: 12px !important;
    }


    .paddLR5 {
        padding-left: 5px !important;
        padding-right: 5px !important;
    }

    .margT4 {
        margin-top: 4px !important;
    }

    .buttonMrgTB {
        margin-bottom: 15px;
        margin-top: 15px;
    }

    #Frm_ScrapCreate_Popup {
        padding-right: 0px !important;
        padding-left: 0px !important;
    }
</style>
<link href="/content/fontawesome/css/fontawesome-all.css" rel="stylesheet">
<div id="Frm_ScrapCreate_Popup" class="col-md-12">
    @using (Ajax.BeginForm("Frm_Add_Scrap_Created", "ProductionRegister",
                       new AjaxOptions
                       {
                           HttpMethod = "POST",
                           UpdateTargetId = "Frm_ScrapCreate_Popup",
                           InsertionMode = InsertionMode.InsertAfter,
                           OnBegin = "AjaxBeginFormPost",
                           OnSuccess = "Frm_ScrapCreate_OnSuccess"
                       },
                       new
                       {
                           id = "ID_Frm_ScrapCreate_Window",
                           @class = "edit_form"
                       }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.ActionMethod)
        @Html.HiddenFor(x => x.sr)
        @Html.HiddenFor(y => y.ID)
        @Html.HiddenFor(y => y.Production_ScrapItem_Name)
        @Html.HiddenFor(y => y.Production_ScrapCode)
        @Html.HiddenFor(y => y.Production_ScrapUnit)
        @Html.HiddenFor(y => y.Production_ScrapUnitID)
        @Html.HiddenFor(y => y.Production_ScrapRate)

        using (Html.DevExtreme().ValidationGroup())
        {

            <!-- <div class="full-width-header-bg3">
                 <div class="row">

                     <div class="col-sm-8 pll">
                         <h3 class="popuphead"><i class="far fa-edit"></i> Scrap Creation</h3>
                     </div>
                     <div class="col-sm-4 prm">
                         <h5 class="mand-txt-align"><i class="fas fa-info-circle"></i> Red Fields are mandatory</h5>
                     </div>
                     @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                 </div>
             </div> [Header]-->
            <div class="row">
                <div class="col-sm-12 col-md-12 col-lg-12">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-2 col-md-2 col-lg-2 pll"><label class="control-label text-red" for="user">Item Name:</label></div>
                                <div class="col-sm-6 col-md-6 col-lg-6 pll2">
                                    <div class="dx-texteditor dx-widget dx-textbox">
                                        <div class="dx-texteditor-container">
                                            @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("Production_ScrapItem_ID").Name("Production_ScrapItem_ID").Value(Model.Production_ScrapItem_ID).ValueExpr("Item_ID").DisplayExpr("Stock_Item_Name").DataSource(d => d.Mvc().Controller("ProductionRegister").LoadAction("LookUp_GetScrap_Created").Key("Item_ID").LoadParams(new { storeid = new JS("function (){ return productionstoreid;}") }))
                                                                                          .Placeholder("Select Scrap Item Name").ReadOnly(IsVisible).Disabled(IsVisible).ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).OnInitialized("OnInitialized_OnScrapcreatedChanged").OnValueChanged("Get_ScrapCreated_ChangeEvent").ContentTemplate(@<text> @Html.Partial("LookUp_Get_ScrapCreated_List") </text>) )
                                            @Html.ValidationMessageFor(model => model.Production_ScrapItem_ID, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                </div>
                                <div class="col-sm-4 col-md-4 col-lg-4 prm pll">
                                    @(Html.DevExtreme().Button().ID("AddScrapItem").Text("Add Scrap Item").Disabled(IsVisible).OnClick(@<text> function () { Add_ScrapItem_Click() } </text>))
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Scrap Item]-->
            </div>
            <div class="row">
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-4 col-md-4col-lg-4 pll"><label class="control-label" for="user">Item Code:</label></div>
                                <div class="col-sm-8 col-md-8 col-lg-8">
                                    <div class="dx-texteditor dx-state-disabled dx-widget dx-textbox">
                                        <div class="dx-texteditor-container">
                                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("Production_ScrapCode1").Name("Production_ScrapCode1").Value(Model.Production_ScrapCode).MaxLength(20).ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).Placeholder("Scrap Code").ReadOnly(true).Disabled(true) )
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Scrap Code]-->
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label text-red" for="user">Qty:</label></div>
                                <div class="col-sm-8 col-md-8 col-lg-8">
                                    <div class="dx-texteditor dx-widget dx-textbox">
                                        <div class="dx-texteditor-container">
                                            @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Production_ScrapQty").Name("Production_ScrapQty").Value(Model.Production_ScrapQty).ShowSpinButtons(true).Format("#0.00").ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).Placeholder("Enter Quantity").ReadOnly(IsVisible).Disabled(IsVisible) )
                                            @Html.ValidationMessageFor(model => Model.Production_ScrapQty, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Qty]-->
            </div><!--[Row 1]-->
            <div class="row">
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label" for="user">Unit:</label></div>
                                <div class="col-sm-8 col-md-8 col-lg-8 ">
                                    <div class="dx-texteditor dx-widget dx-textbox">
                                        <div class="dx-texteditor-container">
                                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("Production_ScrapUnit1").Name("Production_ScrapUnit1").Value(Model.Production_ScrapUnit).MaxLength(20).ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).Placeholder("Unit").ReadOnly(true).Disabled(true) )
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Unit]-->
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label text-red" for="user">Amount:</label></div>
                                <div class="col-sm-8 col-md-8 col-lg-8 prm">
                                    <div class="dx-texteditor dx-widget dx-textbox">
                                        <div class="dx-texteditor-container">
                                            @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Production_ScrapAmount").Name("Production_ScrapAmount").Value(Model.Production_ScrapAmount).ShowSpinButtons(true).Format("#0.00").ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).Placeholder("Enter Amount").OnChange("CalculateRate").ReadOnly(IsVisible).Disabled(IsVisible) )
                                            @Html.ValidationMessageFor(model => Model.Production_ScrapAmount, "", new { @class = "text-danger" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div><!--[Amount]-->
            </div><!--[Row 2]-->
            <div class="row">
                <div class="form-field">
                    <div class="container-fluid">
                        <div class="row">
                            <div class="col-sm-2 col-md-2 col-lg-2 pll"><label class="control-label" for="user">Remarks:</label></div>
                            <div class="col-sm-10 col-md-10 col-lg-10 ">
                                <div class="dx-texteditor dx-widget dx-textbox">
                                    <div class="dx-texteditor-container">
                                        @(Html.DevExtreme().TextBox().CustomTextBox().ID("Production_ScrapRemarks").Name("Production_ScrapRemarks").Value(Model.Production_ScrapRemarks).Placeholder("Enter Remarks...").ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).MaxLength(8000).ReadOnly(IsVisible).Disabled(IsVisible) )
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div><!--[Remarks]-->
            <div class="row">
                <div class="form-field">
                    <div class="container-fluid">
                        <div class="col-sm-12 btn-align prm styleActionBtn">
                            @if (Model.ActionMethod.ToString().Trim() == "View")
                            {
                                @(Html.DevExtreme().Button().CustomCloseButton().Text("Close").ID("productionStockCeate_Cancle").FocusStateEnabled(true).OnClick(@<text> function () { $("#Productioninnergrid").dxPopup("hide"); } </text>) )
                            }
                            @if (Model.ActionMethod.ToString().Trim() == "Edit" || Model.ActionMethod.ToString().Trim() == "New")
                            {
                                @(Html.DevExtreme().Button().CustomSaveButton().Text("Save").ID("productionStockCreate_Save").FocusStateEnabled(true).UseSubmitBehavior(true) )
                                @(Html.DevExtreme().Button().CustomCloseButton().Text("Cancel").ID("StockCreate_Cancled").FocusStateEnabled(true).OnClick(@<text> function () { $("#Productioninnergrid").dxPopup("hide"); } </text>) )
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

<script>

    var scrapcode;
    var scrapunit;
    var scrapunitID;
    var scrapname;
    var scrapqty;
    var scrapamt;
    var scraprate;    

    function Get_ScrapCreated_ChangeEvent(e) {
        if (e.value != e.previousValue && e.previousValue!=null)
        {
            $("#Production_ScrapQty").dxNumberBox("instance").reset();
            $("#Production_ScrapAmount").dxNumberBox("instance").reset();
        }
        var dropdown = $("#Production_ScrapItem_ID").dxDropDownBox("instance");
        dropdown.close();
        var $dataGrid = $("#LookUp_ScrapCreated_datagrid");
        if ($dataGrid.length) {
            LookUp_ScrapCreated_datagrid
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(dropdown.option("value"), false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                scrapname = item.Stock_Item_Name;
                scrapcode = item.Item_Code;
                scrapunit = item.Unit;
                scrapunitID = item.UnitID;
                $("#Production_ScrapItem_Name").val(scrapname);
                $("#Production_ScrapCode").val(scrapcode);
                $("#Production_ScrapUnit").val(scrapunit);
                $("#Production_ScrapUnitID").val(scrapunitID);
                $("#Production_ScrapCode1").dxTextBox("instance").option("value", scrapcode);
                $("#Production_ScrapUnit1").dxTextBox("instance").option("value", scrapunit);
            }
        }
    }
    function OnInitialized_OnScrapcreatedChanged(e)
    {        
        if ("@Model.ActionMethod" != "New")
        {        
            $("#Production_ScrapItem_ID").dxDropDownBox("instance").option("value","@Model.Production_ScrapItem_ID"); 
            e.component.option("dataSource").store.load().done(function (d)
            {
                if (d.length > 0)
                {
                    var $dataGrid = $("#LookUp_ScrapCreated_datagrid");
                    if ($dataGrid.length)
                    {
                        var dataGrid = $dataGrid.dxDataGrid("instance");                
                        dataGrid.selectRows("@Model.Production_ScrapItem_ID", false);
                    }
                }
            });
        }
    }
    function CalculateRate()
    {
        scrapqty = $("#Production_ScrapQty").dxNumberBox("instance").option("value");
        scrapamt = $("#Production_ScrapAmount").dxNumberBox("instance").option("value");
        scraprate = scrapamt / scrapqty;
        $("#Production_ScrapRate").val(scraprate);
    }
    function Add_ScrapItem_Click()
    {
        if (Production_AddItemMasterRight == true)
        {
            ShowLoader();
            $.ajax({
                type: "GET",
                url: "/Stock/StockItemWindow/StockItemWindowNew",
                data:
                {
                    ActionMethod: "_New",
                    ID: 0,
                    PostSucessFunction: "AjaxSuccessForProd_ItemWindow",
                    PopupName: "Prod_frm_StockItem_Window",
                    ButtonID: "AddScrapItem"
                },
                success: function (data)
                {            
                    OpenPopup("Prod_frm_StockItem_Window", "New ~ Stock Item", null, "auto", 1000, true, data);
                }
            });
        }
        else
        {
            ShowLoader();    
            $.ajax({
                type: "GET",
                url: "/Help/RequestBox/Frm_Request_Window",
                data:
                {
                    ActionMethod: "New",                
                    PopUpId: "Prod_RequestBox_Window",
                    AjaxSuccessForm: "Prod_RequestAjaxSuccessForm",
                    CallingFrom:"Production_Scrap"
                },
                success: function (data)
                {
                    OpenPopup("Prod_RequestBox_Window", "New ~ Request Box", null, "auto", "650", true, data);                
                }
            });
        }
    }
    function AjaxSuccessForProd_ItemWindow(data) 
    {
        dontaskpopupcloseconfirmation = true;
        HideLoader();
        if (data.result == false)
        {
            DevExpress.ui.dialog.alert(data.message, 'Error');
        }
        else
        {
            debugger;
            DevExpress.ui.dialog.alert(data.message, 'Success');
            $("#Prod_frm_StockItem_Window").dxPopup("hide");
            $("#LookUp_ScrapCreated_datagrid").dxDataGrid("instance").refresh();
        }
    }
    function Prod_RequestAjaxSuccessForm(data)
    {
        HideLoader();
        if (data.result == false)
        {
            DevExpress.ui.dialog.alert(data.Message, "Error");
        }
        else
        {
            IsRequest_InfoSucessPopup = true;
            var RequestSubmitSuccess = DevExpress.ui.dialog.alert(data.Message, "Request Box");
            $("#Prod_RequestBox_Window").dxPopup("hide");
        }
    }
</script>
<script>
    $(document).ready(function ()
    {
        var form = "ID_Frm_ScrapCreate_Window";
        ShowLoader();
        AssignIDtoLabel(form, "ProductionScrap");        
        Production_AddItemMasterRight = "@Production_AddItemMasterRight" == "True" ? true : false;

        if (Production_AddItemMasterRight == false)
        {
            $("#AddScrapItem").hide();
        }
        
        setTimeout(function ()
        {        
            Set_Form_View_Delete_Mode(null, form, "@Model.ActionMethod");         
            Focus_FirstEditable_Field(form, "@Model.ActionMethod");           
            HideLoader();
        }, Timeout500);
    })
   
</script>

