                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label text-red" for="user">Accepted Qty:</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm">
                        <div class="dx-texteditor dx-widget dx-textbox">
                            <div class="dx-texteditor-container">
                                @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Production_StkPrd_Accepted_Qty").Name("Production_StkPrd_Accepted_Qty").Value(Model.Production_StkPrd_Accepted_Qty).ShowSpinButtons(true).Format("#0.00").ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).OnValueChanged("AcceptedQty_ChangeEvent").Placeholder("Accepted Quantity").ReadOnly(IsVisible).Disabled(IsVisible) )
                                @Html.ValidationMessageFor(model => Model.Production_StkPrd_Accepted_Qty, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>
                </div><!--[Accepted Qty]-->
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label text-red" for="user">Rejected Qty:</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm">
                        <div class="dx-texteditor dx-state-disabled dx-widget dx-textbox">
                            <div class="dx-texteditor-container">
                                @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Production_StkPrd_Rejected_Qty").Name("Production_StkPrd_Rejected_Qty").Value(Model.Production_StkPrd_Rejected_Qty).ShowSpinButtons(true).ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).Format("#0.00").Placeholder("Rejected Quantity").ReadOnly(IsVisible).Disabled(IsVisible) )
                                @Html.ValidationMessageFor(model => Model.Production_StkPrd_Rejected_Qty, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>
                </div><!--[Rejected Quantity]-->
            </div><!--[row4]-->

            <div class="row form-field">
                <div class="col-sm-4 col-md-4 col-lg-4">
                    <div class="col-sm-6 col-md-6 col-lg-6 pll"><label class="control-label" for="user">Market Rate:</label></div>
                    <div class="col-sm-6 col-md-6 col-lg-6 prm pll">
                        <div class="dx-texteditor dx-widget dx-textbox">
                            <div class="dx-texteditor-container">
                                @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Production_StkPrd_MarketRate").Name("Production_StkPrd_MarketRate").Value(Model.Production_StkPrd_MarketRate).ShowSpinButtons(true).ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).Format("#0.00").Placeholder("Enter Rate").OnValueChanged("MarketRate_ChangeEvent").ReadOnly(IsVisible).Disabled(IsVisible) )
                            </div>
                        </div>
                    </div>
                </div><!--[Rate]-->
                <div class="col-sm-4 col-md-4 col-lg-4">
                    <div class="col-sm-6 col-md-6 col-lg-6 pll"><label class="control-label" for="user">Market Price:</label></div>
                    <div class="col-sm-6 col-md-6 col-lg-6prm">
                        <div class="dx-texteditor dx-widget dx-textbox">
                            <div class="dx-texteditor-container">
                                @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Production_StkPrd_MarketPrice").Name("Production_StkPrd_MarketPrice").Value(Model.Production_StkPrd_MarketPrice).ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).ShowSpinButtons(true).Format("#0.00").Placeholder("Market Price").ReadOnly(true).Disabled(IsVisible) )
                            </div>
                        </div>
                    </div>
                </div><!--[price]-->
                <div class="col-sm-4 col-md-4 col-lg-4">
                    <div class="col-sm-6 col-md-6 col-lg-6 pll"><label class="control-label text-red" for="user">% Of Total Value:</label></div>
                    <div class="col-sm-6 col-md-6 col-lg-6 prm">
                        <div class="dx-texteditor dx-widget dx-textbox">
                            <div class="dx-texteditor-container">
                                @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Production_StkPrd_Percentage").Name("Production_StkPrd_Percentage").ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).Value(Model.Production_StkPrd_Percentage).Placeholder("Percentage").ReadOnly(IsVisible).Disabled(IsVisible) )
                            </div>
                        </div>
                    </div>
                </div><!--[percentage]-->
            </div><!--[row5]-->
            <div class="row form-field">
                <div class="col-sm-12 col-md-12 col-lg-12">
                    <div class="col-sm-2 col-md-2 col-lg-2 pll"><label class="control-label" for="user">Remarks:</label></div>
                    <div class="col-sm-10 col-md-10 col-lg-10 prm">
                        <div class="dx-texteditor dx-widget dx-textbox">
                            <div class="dx-texteditor-container">
                                @(Html.DevExtreme().TextBox().CustomTextBox().ID("Production_StkPrd_Remarks").Name("Production_StkPrd_Remarks").Value(Model.Production_StkPrd_Remarks).ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).Placeholder("Enter Remarks...").MaxLength(8000).ReadOnly(IsVisible).Disabled(IsVisible) )
                            </div>
                        </div>
                    </div>
                </div>
            </div><!--[Remarks]-->
            <div class="marginAll8 styleActionBtn">
                @if (Model.ActionMethod.ToString().Trim() == "View")
                {
                    @(Html.DevExtreme().Button().CustomCloseButton()
                                                                       .Text("Close")
                                                                       .ID("productionStockprod_Cancle")                                                                     
                                                                       .FocusStateEnabled(true)
                                                                       .OnClick(@<text> function () { $("#Productioninnergrid").dxPopup("hide"); } </text>) )
                }
                @if (Model.ActionMethod.ToString().Trim() == "New" || Model.ActionMethod.ToString().Trim() == "Edit")
                {
                    @(Html.DevExtreme().Button().CustomSaveButton()
                                                        .Text("Save")
                                                        .ID("productionStockprod_Save")                                                      
                                                        .FocusStateEnabled(true)
                                                        .UseSubmitBehavior(true)
                    )
                    @(Html.DevExtreme().Button().CustomCloseButton()
                                                                    .Text("Cancel")
                                                                    .ID("productionStockprod_Cancled")
                                                                    .FocusStateEnabled(true)                                                                  
                                                                    .OnClick(@<text>
                                                                        function () {
                                                                        $("#Productioninnergrid").dxPopup("hide");
                                                                        }
                                                                    </text>)
                    )}
            </div><!--[Buttons]-->

        }
    }
</div>
<script>
    var stockprodhead;
    var stockprodtype;
    var stockprodcode;
    var stockprodcategory;
    var stockprodunit;
    var stockprodname;
    var stockaccqty;
    var stockmktrate;
    var stockmktprice;
    var stockprdqty;
    var stockrejqty;
    var stockunitid;

    function Get_StockProduced_ChangeEvent(e) {
        var dropdown = $("#Production_StkPrd_Item_ID").dxDropDownBox("instance");
        dropdown.close();
        if (e.previousValue != null&&e.previousValue != e.value)
        {
            $("#Production_StkPrd_Accepted_Qty").dxNumberBox("instance").reset();
            $("#Production_StkPrd_MarketRate").dxNumberBox("instance").reset();
            $("#Production_StkPrd_Produced_Qty").dxNumberBox("instance").reset();
            $("#Production_StkPrd_MarketPrice").dxNumberBox("instance").reset();
            $("#Production_StkPrd_Percentage").dxNumberBox("instance").reset();
        }
        var $dataGrid = $("#LookUp_StockProduced_datagrid");
        if ($dataGrid.length) {            
            LookUp_StockProduced_datagrid
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(dropdown.option("value"), false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                stockprodname = item.Stock_Item_Name;
                stockprodtype = item.Item_Type;
                stockprodcategory = item.Item_Category;
                stockprodcode = item.Item_Code;
                stockprodunit = item.Unit;
                stockunitid=item.UnitID;
                $("#StkPrd_UnitID").val(stockunitid);
                $("#Production_StkPrd_Item_Name").val(stockprodname);
                $("#Production_StkPrd_Type").val(stockprodtype);
                $("#Production_StkPrd_Code").val(stockprodcode);
                $("#Production_StkPrd_Category").val(stockprodcategory);
                $("#Production_StkPrd_Unit").val(stockprodunit);
                $("#Production_StkPrd_Type1").dxTextBox("instance").option("value", stockprodtype);
                $("#Production_StkPrd_Code1").dxTextBox("instance").option("value", stockprodcode);
                $("#Production_StkPrd_Category1").dxTextBox("instance").option("value", stockprodcategory);
                $("#Production_StkPrd_Unit1").dxTextBox("instance").option("value", stockprodunit);

            }
        }
    }
    function OnInitialized_OnStockProducedChanged(e)
    {
        if ("@Model.ActionMethod" != "New") {
            $("#Production_StkPrd_Item_ID").dxDropDownBox("instance").option("value",@Model.Production_StkPrd_Item_ID);
            e.component.option("dataSource").store.load().done(function (d) {
                if (d.length > 0) {
                    var $dataGrid = $("#LookUp_StockProduced_datagrid");
                    if ($dataGrid.length) {
                        var dataGrid = $dataGrid.dxDataGrid("instance");
                        dataGrid.selectRows($("#Production_StkPrd_Item_ID").dxDropDownBox("instance").option("value"), false);
                    }
                }
            });
        }
        }

    function MarketRate_ChangeEvent(e) {
        stockaccqty = $("#Production_StkPrd_Accepted_Qty").dxNumberBox("instance").option("value");
        stockmktrate = $("#Production_StkPrd_MarketRate").dxNumberBox("instance").option("value");
        stockmktprice = stockaccqty * stockmktrate;
        $("#Production_StkPrd_MarketPrice").dxNumberBox("instance").option("value", stockmktprice);
    }
    function AcceptedQty_ChangeEvent(e) {
        stockprdqty = $("#Production_StkPrd_Produced_Qty").dxNumberBox("instance").option("value");
        stockaccqty = $("#Production_StkPrd_Accepted_Qty").dxNumberBox("instance").option("value");
        stockrejqty = stockprdqty - stockaccqty;      
        $("#Production_StkPrd_Rejected_Qty").dxNumberBox("instance").option("value", stockrejqty);
    }
    function ProducedQty_ChangeEvent(e) {
        stockprdqty = $("#Production_StkPrd_Produced_Qty").dxNumberBox("instance").option("value");
        stockaccqty = $("#Production_StkPrd_Accepted_Qty").dxNumberBox("instance").option("value");
        stockrejqty = stockprdqty - stockaccqty;       
        $("#Production_StkPrd_Rejected_Qty").dxNumberBox("instance").option("value", stockrejqty);
    }
    function Add_CheckPriceHistory_Click() {
        DevExpress.ui.dialog.alert("Coming soon...!", 'Inform!');
    }

</script>
<script>
    $(document).ready(function ()
    {
        var form = "ID_Frm_StkProduce_Popup";
        ShowLoader();
        AssignIDtoLabel(form, "ProductionStock");
        setTimeout(function ()
        {
            Set_Form_View_Delete_Mode(null, form, "@Model.ActionMethod");
            Focus_FirstEditable_Field(form, "@Model.ActionMethod");
            HideLoader();
        }, Timeout500);
    })

</script>


