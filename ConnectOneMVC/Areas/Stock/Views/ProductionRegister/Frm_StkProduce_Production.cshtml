                        <div class="dx-texteditor dx-sate-disabled dx-widget dx-textbox">
                            <div class="dx-texteditor-container">
                                @(Html.DevExtreme().TextBox().CustomTextBox().ID("Production_StkPrd_Type1").Name("Production_StkPrd_Type1").Value(Model.Production_StkPrd_Type).MaxLength(20).ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).Placeholder("Item Type").ReadOnly(true).Disabled(true))
                            </div>
                        </div>
                    </div>
                </div><!--[Type]-->
                <div class="col-sm-3 col-md-3 col-lg-3">@*Mantis bug 0000948 fixed*@
                    <div class="col-sm-6 col-md-6 col-lg-6 pll"><label class="control-label" for="user">Item Code:</label></div>
                    <div class="col-sm-6 col-md-6 col-lg-6 prm">
                        <div class="dx-texteditor dx-state-disabled dx-widget dx-textbox">
                            <div class="dx-texteditor-container">
                                @(Html.DevExtreme().TextBox().CustomTextBox().ID("Production_StkPrd_Code1").Name("Production_StkPrd_Code1").Value(Model.Production_StkPrd_Code).MaxLength(20).ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).Placeholder("Item Code").ReadOnly(true).Disabled(true) )
                            </div>
                        </div>
                    </div>
                </div><!--[Code]-->
            </div><!--[row2]-->
            <div class="row form-field">
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll  "><label class="control-label text-red" for="user">Unit:</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm ">
                        <div class="dx-texteditor dx-state-disabled dx-widget dx-textbox">
                            <div class="dx-texteditor-container">
                                @(Html.DevExtreme().TextBox().CustomTextBox().ID("Production_StkPrd_Unit1").Name("Production_StkPrd_Unit1").Value(Model.Production_StkPrd_Unit).MaxLength(20).Placeholder("Unit").ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).ReadOnly(true).Disabled(true) )
                                @Html.ValidationMessageFor(model => Model.Production_StkPrd_Unit, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>
                </div><!--[Unit]-->
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label text-red" for="user">Produced Qty:</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm ">
