                       {
                           id = "ID_Frm_StkProduce_Popup",
                           @class = "edit_form"
                       }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.ActionMethod)
        @Html.HiddenFor(x => x.sr)
        @Html.HiddenFor(y => y.ID)
        @Html.HiddenFor(y => y.StockID)
        @Html.HiddenFor(y => y.Production_StkPrd_Item_Name)
        @Html.HiddenFor(y => y.Production_StkPrd_Unit)
        @Html.HiddenFor(y => y.StkPrd_UnitID)
        @Html.HiddenFor(y => y.Production_StkPrd_Type)
        @Html.HiddenFor(y => y.Production_StkPrd_Category)
        @Html.HiddenFor(y => y.Production_StkPrd_Code)




