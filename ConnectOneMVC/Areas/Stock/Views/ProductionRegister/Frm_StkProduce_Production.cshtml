                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6 col-md-6 col-lg-6">
                    @(Html.DevExtreme().Button().ID("CheckPriceHistory").Text("Check Price History").Disabled(IsVisible).OnClick(@<text> function () { Add_CheckPriceHistory_Click() } </text>))
                </div>
            </div><!--[Stock Produced]-->
            <div class="row form-field">
