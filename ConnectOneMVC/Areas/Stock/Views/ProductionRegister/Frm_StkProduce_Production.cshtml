                            <div class="dx-texteditor-container">
                                @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Production_StkPrd_Produced_Qty").Name("Production_StkPrd_Produced_Qty").Value(Model.Production_StkPrd_Produced_Qty).ShowSpinButtons(true).ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).Format("#0.00").Placeholder("Produced Quantity").ReadOnly(IsVisible).Disabled(IsVisible).OnValueChanged("ProducedQty_ChangeEvent") )
                                @Html.ValidationMessageFor(model => Model.Production_StkPrd_Produced_Qty, "", new { @class = "text-danger" })
                            </div>
                        </div>
                    </div>
                </div><!--[Produced Qty]-->
            </div><!--[row3]-->
