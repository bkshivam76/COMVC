                </div>

            </div> <!--[Header]-->
            <div class="row form-field">
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label text-red" for="user">Item Name:</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm pll1">
                        <div class="dx-texteditor dx-widget dx-textbox">
                            <div class="dx-texteditor-container">
                                @(Html.DevExtreme().DropDownBox().CustomDropDown()
