@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                                .ID("GetProductionLocationDG")
                              
                                .Columns(columns =>
                                {

                                    columns.Add().DataField("Location_Name").Caption("Location Name");
                                    columns.Add().DataField("Matched_Name").Caption("Matched Name").Visible(true);
                                    columns.Add().DataField("Matched_Type").Caption("Matched Type").Visible(true);
                                    columns.Add().DataField("Loc_ID").Caption("ID").Visible(true);


                                })
                        
                                .Selection(s => s.Mode(SelectionMode.Single))
                     )



