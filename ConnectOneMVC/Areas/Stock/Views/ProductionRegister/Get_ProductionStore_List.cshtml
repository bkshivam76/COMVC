@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                            .ID("GetProductionStoreDG")                        
                            .Columns(columns =>
                            {

                                columns.Add().DataField("Store_Name").Caption("Store");
                                columns.Add().DataField("Sub_Dept_Name").Caption("Sub Dept").Visible(true);
                                columns.Add().DataField("Dept_Name").Caption("Dept").Visible(true);
                                columns.Add().DataField("Dept_Incharge_Name").Caption("Incharge").Visible(true);
                                columns.Add().DataField("StoreId").Visible(false);
                               
                            })
                           
                            .Selection(s => s.Mode(SelectionMode.Single))
                          
)



