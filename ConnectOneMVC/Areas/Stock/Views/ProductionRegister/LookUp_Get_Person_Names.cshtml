@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                       .ID("LookUp_Get_Persons_PM")//Mantis bug 0001045 resolved
                   
                       .Columns(columns =>
                       {
                           columns.Add().DataField("Name").Caption("Person Name").Visible(true);
                           columns.Add().DataField("Type").Caption("Type").Visible(false);//Mantis bug 0000950 resolved
                           columns.Add().DataField("Main_Dept").Caption("Main Department").Visible(true);
                           columns.Add().DataField("Sub_Dept").Caption("Sub Department").Visible(true);
                           columns.Add().DataField("ID").Caption("Person Id").Visible(false);
                           columns.Add().DataField("Joining_Date").Caption("Joining_Date").Visible(true).DataType(GridColumnDataType.Date).Format("dd/MM/yyyy");//Mantis bug 0001045 resolved
                           columns.Add().DataField("Leaving_Date").Caption("Leaving_Date").Visible(true).DataType(GridColumnDataType.Date).Format("dd/MM/yyyy");//Mantis bug 0001045 resolved
                       })
                     
                        .Selection(s => s.Mode(SelectionMode.Single))
                        
)