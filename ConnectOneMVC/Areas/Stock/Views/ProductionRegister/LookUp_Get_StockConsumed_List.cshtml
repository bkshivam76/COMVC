@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
        .ID("LookUp_StockConsumed_datagrid")
        .Columns(columns =>
        {

            columns.Add().DataField("Item_Name").Caption("Item Name");
            columns.Add().DataField("Item_Code").Caption("Item Code");
            columns.Add().DataField("Make").Caption("Make");
            columns.Add().DataField("Model").Caption("Model");
            columns.Add().DataField("Item_Category").Caption("Type");
            columns.Add().DataField("Lot_Serial_No").Caption("Serial No");
            columns.Add().DataField("Curr_Qty").Caption("Available Quantity");
            columns.Add().DataField("Curr_Cost").Caption("Current Cost").Visible(false); //Mantis bug 0000953 fixed
            columns.Add().DataField("Location").Caption("Location");
            columns.Add().DataField("PurchaseDate").Caption("Date Of Purchase");
            columns.Add().DataField("Org_Cost").Caption("Total Cost");
            columns.Add().DataField("ID").Caption("ID").Visible(true);
            columns.Add().DataField("Head").Caption("Head").Visible(false);
            columns.Add().DataField("Unit").Caption("Unit").Visible(false);
            columns.Add().DataField("Stock_Unit_ID").Caption("StockID").Visible(false);
        })

        .Selection(s => s.Mode(SelectionMode.Single))

)




