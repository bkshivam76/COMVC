@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
        .ID("LookUp_StockProduced_datagrid")      
        .Columns(columns =>
        {
            columns.Add().DataField("Stock_Item_Name").Caption("Item Name");
            columns.Add().DataField("Item_Type").Caption("Item Type");
            columns.Add().DataField("Item_Code").Caption("Item Code");
            columns.Add().DataField("Item_ID").Caption("ID").Visible(false);
            columns.Add().DataField("Unit").Caption("Unit").Visible(false);
            columns.Add().DataField("UnitID").Caption("UnitID").Visible(false);
            columns.Add().DataField("Item_Category").Caption("Item Category").Visible(true);
        })
       
        .Selection(s => s.Mode(SelectionMode.Single))
        
)




