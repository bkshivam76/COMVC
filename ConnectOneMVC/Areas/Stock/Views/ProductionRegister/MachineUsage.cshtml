@model ConnectOneMVC.Areas.Stock.Models.Model_NEVD_Production
@using DevExtreme.AspNet.Mvc;
@{bool IsVisible = Model != null && ( Model.ActionMethod == "Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.ActionMethod == "View" || Model.ActionMethod == "Delete") ? true : false;
}
<div class="row">
    <div class="col-lg-12 col-xs-12 table-responsive tbnew2" id="result_MachineUsagegridData">
        @Html.Action("ProductionMachineUsageGridData", "ProductionRegister", new { ActionMethodName =Model.ActionMethod, Prod_ID = Model.Prod_ID })
    </div>
</div>
<div class="row">
    <div class="form-field">
        <div class="container-fluid">
            <div class="col-md-12 btnsDiv">
                    @(Html.DevExtreme().Button().ID("ProductionBUT_MachNew").Text("New").Icon("fas fa-file btn-icons newfile icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Machine_New_Click() } </text>))
                    @(Html.DevExtreme().Button().ID("productionBUT_MachEdit").Text("Edit").Icon("fas fa-pencil-alt btn-icons editcolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Machine_Edit_Click() } </text>))
                    @(Html.DevExtreme().Button().ID("productionBUT_MachDelete").Text("Delete").Icon("fas fa-trash btn-icons deletecolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Machine_Delete_Click() } </text>))
                    @(Html.DevExtreme().Button().ID("productionBUT_MachView").Text("View").Icon("fas fa-eye btn-icons eyeicon icon-rgt-space5").Disabled(IsVisible).OnClick(@<text> function () { OnFrm_Machine_View_Click() } </text>))
            </div>
        </div>
    </div>
</div>

<script>
    var MachineUsage_Sr;
    var MachineUsage_ID;
    function OnMachineDetailsGridFocusedRowChanged(s,e)
    {
        s.GetRowValues(s.GetFocusedRowIndex(), 'Sr;REC_ID', MachineUsageDetailsGridRowValues);
    }
    function MachineUsageDetailsGridRowValues(value) {
        MachineUsage_Sr = value[0];
        MachineUsage_ID = value[1];
    }
    $("#Machine_Usage_Window_Grid").keydown(function (evt) {
        switch (evt.keyCode) {
            case 45: // insert key
                OnFrm_Machine_New_Click();
                break;
            case 13: //enter key
                OnFrm_Machine_Edit_Click();
                break;
            case 32: //space bar
                OnFrm_Machine_View_Click();
                break;
            case 46://delete key
                OnFrm_Machine_Delete_Click();
                break;
        }
        if (evt.ctrlKey && evt.keyCode == 73)//ctrl+i
        {
            OnFrm_Machine_New_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 69)//ctrl+e
        {
            OnFrm_Machine_Edit_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_Machine_View_Click();
        }
    });
    function OnFrm_Machine_New_Click()
    { if ("@IsDisabled"=="true") { return; }

        ShowLoader();

        OpenPopup("Productioninnergrid", "New ~ Machine Usage", "@Url.Action("Frm_Stock_Production_Machinery_Used", "ProductionRegister", new {@area= "Stock" })?ActionMethod=New", "auto", 1024, false, null);
    }// new click
    function OnFrm_Machine_Edit_Click()
    { if ("@IsDisabled"=="true") { return; }
        if (MachineUsage_Sr == 'undefined' || MachineUsage_Sr == undefined || MachineUsage_Sr == null || MachineUsage_ID == 'undefined' || MachineUsage_ID == undefined) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        if (MachineUsage_Sr != null && MachineUsage_Sr != undefined && MachineUsage_Sr != "undefined") {

                  ShowLoader();

            OpenPopup("Productioninnergrid", "Edit ~ Machine Usage", "@Url.Action("Frm_Stock_Production_Machinery_Used", "ProductionRegister", new {@area= "Stock" })?ActionMethod=Edit&SrID=" + encodeURIComponent(MachineUsage_Sr), "auto", 1024, false, null);
        }
    }// edit click
    function OnFrm_Machine_Delete_Click()
    { if ("@IsDisabled"=="true") { return; }
        if (MachineUsage_Sr == 'undefined' || MachineUsage_Sr == undefined || MachineUsage_Sr == null || MachineUsage_ID == 'undefined' || MachineUsage_ID == undefined) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        var deleteResultPaymentDetail = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
        deleteResultPaymentDetail.done(function (dialogResult) {

            if (dialogResult) {
                $.ajax({
                    type: 'GET',
                    url: "/Stock/ProductionRegister/Frm_MachineUsageDetail_Window_Delete_Grid_Record",
                    data: { ActionMethod: "Delete", SrID: MachineUsage_Sr, Rec_Id: MachineUsage_ID },
                    cache: false,
                    success: function (result) {
                     
                        Machine_Usage_Window_Grid.SetFocusedRowIndex(-1);
                        Machine_Usage_Window_Grid.Refresh();
                       
                    }
                });
            }
        });
        var total = ProductionStockConsumedGrid.GetVisibleRowsOnPage() + ProductionStockProducedGrid.GetVisibleRowsOnPage() + ProductionScrapCreatedGrid.GetVisibleRowsOnPage() + Actual_ManPower_Usage_Grid.GetVisibleRowsOnPage() + Machine_Usage_Window_Grid.GetVisibleRowsOnPage()-1;
                if (total == 0) {
            $("#ProductionStoreID").dxDropDownBox("instance").option("readOnly", false);
        }

    }
    function OnFrm_Machine_View_Click()
    { 
        if (MachineUsage_Sr == 'undefined' || MachineUsage_Sr == undefined || MachineUsage_Sr == null || MachineUsage_ID == 'undefined' || MachineUsage_ID == undefined) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        if (MachineUsage_Sr != null && MachineUsage_Sr != undefined && MachineUsage_Sr != "undefined")
        {
            ShowLoader();
            OpenPopup("Productioninnergrid", "View ~ Machine Usage", "@Url.Action("Frm_Stock_Production_Machinery_Used", "ProductionRegister", new {@area= "Stock" })?ActionMethod=View&SrID=" + encodeURIComponent(MachineUsage_Sr), "auto", 1024, false, null);
        }
    }//view click    
    function Frm_Machine_Window_OnSuccess(data)
    {
        HideLoader();
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.message, "Error");
        }
        else {
    
            $("#Productioninnergrid").dxPopup("hide");
            Machine_Usage_Window_Grid.SetFocusedRowIndex(-1);
            Machine_Usage_Window_Grid.Refresh();
            $("#ProductionStoreID").dxDropDownBox("instance").option("readOnly", true);
        }
    }
    
    
</script>