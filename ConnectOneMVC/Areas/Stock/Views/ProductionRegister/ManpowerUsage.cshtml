@model ConnectOneMVC.Areas.Stock.Models.Model_NEVD_Production
@using DevExtreme.AspNet.Mvc;
@{
    bool IsVisible = Model != null && (Model.ActionMethod == "Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.ActionMethod == "View" || Model.ActionMethod == "Delete") ? true : false;
    }
<div class="row">
    <div class="col-md-12">
        @Html.Action("ProductionActual_Manpower_Usage_GridData", "ProductionRegister", new { ActionMethodName =Model.ActionMethod, Prod_ID =Model.Prod_ID })
    </div>
</div>
<div class="row">
    <div class="form-field">
        <div class="container-fluid">
            <div class="col-md-12 btnsDiv">
                    @(Html.DevExtreme().Button().ID("productionBUT_Actual_ManpowerNew").Text("New").Icon("fas fa-file btn-icons newfile icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Actual_Manpower_New_Click() } </text>))
                    @(Html.DevExtreme().Button().ID("productionBUT_Actual_ManpowerEdit").Text("Edit").Icon("fas fa-pencil-alt btn-icons editcolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Actual_Manpower_Edit_Click() } </text>))
                    @(Html.DevExtreme().Button()
                                                    .ID("productionBUT_Actual_ManpowerDelete")
                                                    .Text("Delete")
                                                    .Icon("fas fa-trash btn-icons deletecolor icon-rgt-space5")
                                                    .Disabled(IsDisabled)
                                                    .OnClick(@<text>
                                                        function () {
                                                        OnFrm_Actual_Manpower_Delete_Click()
                                                        }
                                                    </text>))
                    @(Html.DevExtreme().Button()
                                                    .ID("productionBUT_Actual_ManpowerView")
                                                    .Text("View")
                                                    .Icon("fas fa-eye btn-icons eyeicon icon-rgt-space5")
                                                    .Disabled(IsVisible)
                                                    .OnClick(@<text>
                                                        function () {
                                                        OnFrm_Actual_Manpower_View_Click()
                                                        }
                                                    </text>))
            </div>
        </div>
    </div>
</div>
<script>
    var Manpower_Usage_Rec_Id;
    var Manpower_Sr
        function ActualManPowerUsageGridFocusedRowChanged(s, e) {
            s.GetRowValues(s.GetFocusedRowIndex(), 'Sr;ID', Manpower_Usage_GridRowValues);
        };
        function Manpower_Usage_GridRowValues(values) {
            Manpower_Usage_Rec_Id = values[1];
            Manpower_Sr = values[0];
    };
    $("#Actual_ManPower_Usage_Grid").keydown(function (evt) {
        switch (evt.keyCode) {
            case 45: // insert key
                OnFrm_Actual_Manpower_New_Click();
                break;
            case 13: //enter key
                OnFrm_Actual_Manpower_Edit_Click();
                break;
            case 32: //space bar
                OnFrm_Actual_Manpower_View_Click();
                break;
            case 46://delete key
                OnFrm_Actual_Manpower_Delete_Click();
                break;
        }
        if (evt.ctrlKey && evt.keyCode == 73)//ctrl+i
        {
            OnFrm_Actual_Manpower_New_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 69)//ctrl+e
        {
            OnFrm_Actual_Manpower_Edit_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_Actual_Manpower_View_Click();
        }
    });
    function OnFrm_Actual_Manpower_New_Click()
    {
        if ("@IsDisabled" == "true") { return; }
        ShowLoader();
        OpenPopup("Productioninnergrid", "New ~ Manpower Usage", "@Url.Action("Frm_Add_Manpower_Usage", "ProductionRegister", new {@area= "Stock" })?ActionMethod=New", "auto", 1024, false, null);

    }//new click
        function OnFrm_Actual_Manpower_Edit_Click() { if ("@IsDisabled"=="true") { return; }
            if (Manpower_Sr == null || Manpower_Sr == undefined || Manpower_Sr == "undefined") {
                DevExpress.ui.dialog.alert("Please Select Row", "Error");
                return;
            }    
            ShowLoader();
            OpenPopup("Productioninnergrid", "Edit ~ Manpower Usage", "@Url.Action("Frm_Add_Manpower_Usage", "ProductionRegister", new {@area= "Stock" })?ActionMethod=Edit&SR=" + encodeURIComponent(Manpower_Sr), "auto", 1024, false, null);
        }//edit click     
        function OnFrm_Actual_Manpower_View_Click() {
            if (Manpower_Sr == null || Manpower_Sr == undefined || Manpower_Sr == "undefined") {
                DevExpress.ui.dialog.alert("Please Select Row", "Error");
                return;
            }            
            ShowLoader();
            OpenPopup("Productioninnergrid", "View ~ Manpower Usage", "@Url.Action("Frm_Add_Manpower_Usage", "ProductionRegister", new {@area= "Stock" })?ActionMethod=View&SR=" + encodeURIComponent(Manpower_Sr), "auto", 1024, false, null);
        }// view click
    function OnFrm_Actual_Manpower_Delete_Click() { if ("@IsDisabled"=="true") { return; }
        if (Manpower_Sr == 'undefined' || Manpower_Sr == undefined || Manpower_Sr == null) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        var Actual_Manpower_Details = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
        Actual_Manpower_Details.done(function (dialogResult) {

            if (dialogResult) {
                $.ajax({
                    type: 'GET',
                    url: "/Stock/ProductionRegister/Frm_Manpower_Usage_Window_Delete_Grid_Record",
                    data: { ActionMethod: "Delete", Manpower_Usage_Rec_Id: Manpower_Usage_Rec_Id, SR: Manpower_Sr },
                    cache: false,
                    success: function (result) {
                   
                        Actual_ManPower_Usage_Grid.SetFocusedRowIndex(-1);
                        Actual_ManPower_Usage_Grid.Refresh();
                        
                    }
                });
            }
        });
        var total = ProductionStockConsumedGrid.GetVisibleRowsOnPage() + ProductionStockProducedGrid.GetVisibleRowsOnPage() + ProductionScrapCreatedGrid.GetVisibleRowsOnPage() + Actual_ManPower_Usage_Grid.GetVisibleRowsOnPage() + Machine_Usage_Window_Grid.GetVisibleRowsOnPage()-1;
       
        if (total == 0) {
            $("#ProductionStoreID").dxDropDownBox("instance").option("readOnly", false);
        }
    }
    function Frm_Manpower_Usage_OnSuccess(data) {
        HideLoader();
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.message, "Error");
        }
        else {

            $("#Productioninnergrid").dxPopup("hide");
            Actual_ManPower_Usage_Grid.SetFocusedRowIndex(-1);
            Actual_ManPower_Usage_Grid.Refresh();
            $("#ProductionStoreID").dxDropDownBox("instance").option("readOnly", true);
        }
    }
</script>