@model ConnectOneMVC.Areas.Stock.Models.Model_NEVD_Production
@using DevExtreme.AspNet.Mvc;
@{
    bool IsVisible = Model != null && (Model.ActionMethod == "Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.ActionMethod == "View" || Model.ActionMethod == "Delete") ? true : false;

}
<div class="row">
    <div class="col-md-12">
        @Html.Action("ProductionScrapCreatedGridData", "ProductionRegister", new { ActionMethodName =Model.ActionMethod, Prod_ID = Model.Prod_ID })
    </div>
</div>

<div class="row">
    <div class="form-field">
        <div class="container-fluid">
            <div class="col-md-12 btnsDiv">
                        @(Html.DevExtreme().Button().ID("productionBUT_ScrapNew").Text("New").Icon("fas fa-file btn-icons newfile icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_ScrapCreate_New_Click() } </text>))
                        @(Html.DevExtreme().Button().ID("productionBUT_ScrapEdit").Text("Edit").Icon("fas fa-pencil-alt btn-icons editcolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_ScrapCreate_Edit_Click() } </text>))
                        @(Html.DevExtreme().Button().ID("productionBUT_ScrapDelete").Text("Delete").Icon("fas fa-trash btn-icons deletecolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_ScrapCreate_Delete_Click() } </text>))
                        @(Html.DevExtreme().Button().ID("BUT_ScrapView").Text("View").Icon("fas fa-eye btn-icons eyeicon icon-rgt-space5").Disabled(IsVisible).OnClick(@<text> function () { OnFrm_ScrapCreate_View_Click() } </text>))
                </div>
        </div>
    </div>
</div>
<script>
    var ScrapCreatesr;
    var ScrapCreateid;
    function OnProductionScrapCreateGridFocusedRowChanged(s, e) {
        s.GetRowValues(s.GetFocusedRowIndex(), 'Sr;ID', ScrapCreate_GridRowValues);
    }
    function ScrapCreate_GridRowValues(values) {
        ScrapCreatesr = values[0];
        ScrapCreateid = values[1];
    }  
    $("#JobDocuments_Window_Grid").keydown(function (evt) {
        switch (evt.keyCode) {
            case 45: // insert key
                OnFrm_ScrapCreate_New_Click();
                break;
            case 13: //enter key
                OnFrm_ScrapCreate_Edit_Click();
                break;
            case 32: //space bar
                OnFrm_ScrapCreate_View_Click();
                break;
            case 46://delete key
                OnFrm_ScrapCreate_Delete_Click();
                break;
        }
        if (evt.ctrlKey && evt.keyCode == 73)//ctrl+i
        {
            OnFrm_ScrapCreate_New_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 69)//ctrl+e
        {
            OnFrm_ScrapCreate_Edit_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_ScrapCreate_View_Click();
        }
    });
    function OnFrm_ScrapCreate_New_Click()
    { if ("@IsDisabled"=="true") { return; }
        ShowLoader();
        OpenPopup("Productioninnergrid", "New ~ Scrap Creation", "@Url.Action("Frm_ScrapCreated_Production", "ProductionRegister", new {@area= "Stock" })?ActionMethod=New", "auto", 1024, false, null);
    }// new click
    function OnFrm_ScrapCreate_Edit_Click()
    { if ("@IsDisabled"=="true") { return; }
        if (ScrapCreatesr == null || ScrapCreatesr == undefined || ScrapCreatesr == "undefined")
        {
            DevExpress.ui.dialog.alert("Please Select Row", "Error");
            return;
        }
        ShowLoader();
        OpenPopup("Productioninnergrid", "Edit ~ Scrap Creation","@Url.Action("Frm_ScrapCreated_Production", "ProductionRegister", new {@area= "Stock" })?ActionMethod=Edit&SR=" + encodeURIComponent(ScrapCreatesr), "auto", 1024, false, null);

    }// edit click
    function OnFrm_ScrapCreate_View_Click()
    {
        if (ScrapCreatesr == null || ScrapCreatesr == undefined || ScrapCreatesr == "undefined")
        {
                DevExpress.ui.dialog.alert("Please Select Row", "Error");
                return;
        } 
        ShowLoader();
        OpenPopup("Productioninnergrid", "View ~ Scrap Creation","@Url.Action("Frm_ScrapCreated_Production", "ProductionRegister", new {@area= "Stock" })?ActionMethod=View&SR=" + encodeURIComponent(ScrapCreatesr), "auto", 1024, false, null);
    }//view click
    function OnFrm_ScrapCreate_Delete_Click()
    {
        if ("@IsDisabled" == "true") { return; }
        if (ScrapCreatesr == 'undefined' || ScrapCreatesr == undefined || ScrapCreatesr == null)
        {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        var Actual_Manpower_Details = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
        Actual_Manpower_Details.done(function (dialogResult)
        {
            if (dialogResult)
            {
                $.ajax({
                    type: 'GET',
                    url: "/Stock/ProductionRegister/Frm_ScrapCreate_Window_Delete_Grid_Record",
                    data: { ActionMethod: "Delete", sr: ScrapCreatesr, id: ScrapCreateid },
                    cache: false,
                    success: function (check) {
                        if (check.result == true) {
                          
                            ProductionScrapCreatedGrid.SetFocusedRowIndex(-1);
                            ProductionScrapCreatedGrid.Refresh();
                           
                        }
                        else {
                            DevExpress.ui.dialog.alert(check.message, "Error");
                        }
                    }
                });
            }
        });
        var total = ProductionStockConsumedGrid.GetVisibleRowsOnPage() + ProductionStockProducedGrid.GetVisibleRowsOnPage() + ProductionScrapCreatedGrid.GetVisibleRowsOnPage() + Actual_ManPower_Usage_Grid.GetVisibleRowsOnPage() + Machine_Usage_Window_Grid.GetVisibleRowsOnPage()-1;
        
        if (total == 0) {
            $("#ProductionStoreID").dxDropDownBox("instance").option("readOnly", false);
        }
    }
    function Frm_ScrapCreate_OnSuccess(data)
    {
        HideLoader();
        if (data.result == false)
        {
            DevExpress.ui.dialog.alert(data.message, "Error");
        }
        else
        {     
            $("#Productioninnergrid").dxPopup("hide");         
            $("#ProductionStoreID").dxDropDownBox("instance").option("readOnly", true);
            ProductionScrapCreatedGrid.SetFocusedRowIndex(-1);
            ProductionScrapCreatedGrid.Refresh();
        }
    }
</script>