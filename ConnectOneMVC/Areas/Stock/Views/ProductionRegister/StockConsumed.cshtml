@model ConnectOneMVC.Areas.Stock.Models.Model_NEVD_Production
@using DevExtreme.AspNet.Mvc;
@{
    bool IsVisible = Model != null && (Model.ActionMethod == "Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.ActionMethod == "View" || Model.ActionMethod == "Delete") ? true : false;

}
<div class="row">
    <div class="col-md-12">
        @Html.Action("ProductionStockConsumedGridData", "ProductionRegister", new { ActionMethodName =Model.ActionMethod, Prod_ID =Model.Prod_ID })
    </div>
</div>

<div class="row">
    <div class="form-field">
        <div class="container-fluid">
            <div class="col-md-12 btnsDiv">
                @(Html.DevExtreme().Button().ID("productionBUT_StockNew").Text("New").Icon("fas fa-file btn-icons newfile icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_StockCon_New_Click() } </text>))
                @(Html.DevExtreme().Button().ID("productionBUT_StockEdit").Text("Edit").Icon("fas fa-pencil-alt btn-icons editcolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_StockCon_Edit_Click() } </text>))
                @(Html.DevExtreme().Button().ID("BUT_StockDelete").Text("Delete").Icon("fas fa-trash btn-icons deletecolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_StockCon_Delete_Click() } </text>))
                @(Html.DevExtreme().Button().ID("productionBUT_StockView").Text("View").Icon("fas fa-eye btn-icons eyeicon icon-rgt-space5").Disabled(IsVisible).OnClick(@<text> function () { OnFrm_StockCon_View_Click() } </text>))
            </div>
        </div>
    </div>
</div>
<script>
    var stockconsr;
    var stockconid;
    function OnProductionStockConsumedGridFocusedRowChanged(s, e) {
        s.GetRowValues(s.GetFocusedRowIndex(), 'Sr;consumptionID', StockCon_GridRowValues);
    }
    function StockCon_GridRowValues(values) {
        stockconsr = values[0];
        stockconid = values[1];
    }
    $("#ProductionStockConsumedGrid").keydown(function (evt) {
        switch (evt.keyCode) {
            case 45: // insert key
                OnFrm_StockCon_New_Click();
                break;
            case 13: //enter key
                OnFrm_StockCon_Edit_Click();
                break;
            case 32: //space bar
                OnFrm_StockCon_View_Click();
                break;
            case 46://delete key
                OnFrm_StockCon_Delete_Click();
                break;
        }
        if (evt.ctrlKey && evt.keyCode == 73)//ctrl+i
        {
            OnFrm_StockCon_New_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 69)//ctrl+e
        {
            OnFrm_StockCon_Edit_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_StockCon_View_Click();
        }
    });
    function OnFrm_StockCon_New_Click() { if ("@IsDisabled"=="true") { return; }
                ShowLoader();
        OpenPopup("Productioninnergrid", "New ~ Item Consumed","@Url.Action("Frm_Stock_Production_Item_Consumed", "ProductionRegister", new {@area= "Stock" })?ActionMethod=New", "auto", 1024, false, null);
    }// new click
    function OnFrm_StockCon_Edit_Click() { if ("@IsDisabled"=="true") { return; }
        if (stockconsr == null || stockconsr == undefined || stockconsr == "undefined") {
                DevExpress.ui.dialog.alert("Please Select Row", "Error");
                return;
            }
                        ShowLoader();
        OpenPopup("Productioninnergrid", "Edit ~ Item Consumed", "@Url.Action("Frm_Stock_Production_Item_Consumed", "ProductionRegister", new {@area= "Stock" })?ActionMethod=Edit&SR=" + encodeURIComponent(stockconsr), "auto", 1024, false, null);
        }//edit click     
    function OnFrm_StockCon_View_Click() {
        if (stockconsr == null || stockconsr == undefined || stockconsr == "undefined") {
                DevExpress.ui.dialog.alert("Please Select Row", "Error");
                return;
        }               
                                ShowLoader();
        OpenPopup("Productioninnergrid", "View ~ Item Consumed", "@Url.Action("Frm_Stock_Production_Item_Consumed", "ProductionRegister", new {@area= "Stock" })?ActionMethod=View&SR=" + encodeURIComponent(stockconsr), "auto", 1024, false, null);
        }//view click
    function OnFrm_StockCon_Delete_Click() {

        if ("@IsDisabled" == "true") {
            return;
        }
        if (stockconsr == 'undefined' || stockconsr == undefined || stockconsr == null) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        var Actual_Manpower_Details = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
        Actual_Manpower_Details.done(function (dialogResult) {

            if (dialogResult) {
                $.ajax({
                    type: 'GET',
                    url: "/Stock/ProductionRegister/Frm_StockCon_Window_Delete_Grid_Record",
                    data: { ActionMethod: "Delete", sr: stockconsr, id: stockconid },
                    cache: false,
                    success: function (result) {                      
                        
                        ProductionStockConsumedGrid.SetFocusedRowIndex(-1);                           
                        ProductionStockConsumedGrid.Refresh();                                      
                      }
                });
            }
        });
        var total = ProductionStockConsumedGrid.GetVisibleRowsOnPage() + ProductionStockProducedGrid.GetVisibleRowsOnPage() + ProductionScrapCreatedGrid.GetVisibleRowsOnPage() + Actual_ManPower_Usage_Grid.GetVisibleRowsOnPage() + Machine_Usage_Window_Grid.GetVisibleRowsOnPage()-1;
        
        if (total == 0) {
            $("#ProductionStoreID").dxDropDownBox("instance").option("readOnly", false);
        }
    }
    function Frm_Prod_Stock_Consumed_OnSuccess(data) {
        
        HideLoader();
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.message, "Error");
        }
        else {
          
            $("#Productioninnergrid").dxPopup("hide");
            ProductionStockConsumedGrid.SetFocusedRowIndex(-1);              
            ProductionStockConsumedGrid.Refresh();
            $("#ProductionStoreID").dxDropDownBox("instance").option("readOnly", true);
        }
    }
</script>