@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    var ProjectExportGridHeaderLeft=ViewData["ProjectExportGridHeaderLeft"] != null ? ViewData["ProjectExportGridHeaderLeft"].ToString() : "";
    var ProjectExportGridHeaderRight = ViewData["ProjectExportGridHeaderRight"] != null ? ViewData["ProjectExportGridHeaderRight"].ToString() : "";
    var ProjectExportGridFooter = ViewData["ProjectExportGridFooter"] != null ? ViewData["ProjectExportGridFooter"].ToString() : "";
}
@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "Estimation_Window_Grid";
        settings.CallbackRouteValues = new
        {
            Controller = "ProjectScreen",
            Action = "EstimationGridData",
            SessionGUID = SessionGUID
        };
        settings.Settings.VerticalScrollBarMode = ScrollBarMode.Visible;
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Visible;
        settings.Settings.VerticalScrollableHeight = 100;
        settings.KeyboardSupport = true;
        //settings.AccessKey = "G";
        settings.SettingsExport.ExcelExportMode = DevExpress.Export.ExportType.DataAware;
        settings.SettingsExport.EnableClientSideExportAPI = true;
        settings.SettingsExport.ExcelExportMode = DevExpress.Export.ExportType.DataAware;
        settings.SettingsDetail.ExportMode = GridViewDetailExportMode.Expanded;
        settings.SettingsExport.PageHeader.Center = "Estimation Report";
        settings.SettingsExport.PageHeader.Left = ProjectExportGridHeaderLeft;
        settings.SettingsExport.PageHeader.Right = ProjectExportGridHeaderRight;
        settings.SettingsExport.PageFooter.Right = ProjectExportGridFooter;
        //settings.SettingsExport.PageFooter.Left = "#";
        settings.SettingsExport.PageFooter.Font.Size = 7;
        settings.SettingsExport.PaperKind = System.Drawing.Printing.PaperKind.A4Rotated;
        settings.SettingsExport.TopMargin = 10;
        settings.SettingsExport.LeftMargin = 10;
        settings.SettingsExport.RightMargin = 10;
        settings.SettingsExport.BottomMargin = 10;
        settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
        if (ViewBag.Estimation_HideColumn == false)
        {
            settings.Settings.ShowFooter = true;
            settings.TotalSummary.Add(DevExpress.Data.SummaryItemType.Sum, "Total_Amount").DisplayFormat = "Total: {0:#,0.00}";
        }
        settings.Settings.ShowGroupFooter = GridViewGroupFooterMode.VisibleAlways;
        settings.SettingsBehavior.AutoExpandAllGroups = true;
        settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
        settings.SettingsBehavior.AllowSelectByRowClick = true;
        settings.Settings.UseFixedTableLayout = true;
        settings.SettingsBehavior.ColumnMoveMode = GridColumnMoveMode.AmongSiblings;
        settings.SettingsBehavior.AllowSort = true;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.Control;
        settings.SettingsResizing.Visualization = ResizingMode.Live;
        settings.SettingsBehavior.AllowEllipsisInText = true;
        settings.SettingsPager.Mode = GridViewPagerMode.ShowAllRecords;
        settings.SettingsSearchPanel.ShowApplyButton = true;
        settings.SettingsSearchPanel.ShowClearButton = true;
        settings.SettingsBehavior.AllowFocusedRow = true;
        settings.ClientSideEvents.FocusedRowChanged = "OnEstimationDetailsGridFocusedRowChanged";
        settings.Settings.ShowHeaderFilterBlankItems = false;
        settings.SettingsContextMenu.Enabled = false;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;
        settings.SettingsCustomizationDialog.ShowColumnChooserPage = true;
        settings.SettingsDataSecurity.AllowReadUnlistedFieldsFromClientApi = DefaultBoolean.True;
        settings.ClientSideEvents.BeginCallback = "OnFrm_Estimation_BeginCallback";
        settings.ClientSideEvents.EndCallback = "OnFrm_Estimation_EndCallback";
        settings.ClientSideEvents.RowDblClick = "OnFrm_Estimation_Edit_Click";
        settings.ClientSideEvents.ContextMenuItemClick = "Frm_Estimation_Detail_Grid_ContextMenuFunction";
        settings.FillContextMenuItems = (sender, e) =>
        {
            if (e.MenuType == GridViewContextMenuType.Rows)
            {
                var Additem = e.CreateItem("New", "New");
                Additem.Image.IconID = "actions_expandcollapse_16x16devav";
                Additem.BeginGroup = true;
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Additem);

                var Edititem = e.CreateItem("Edit", "Edit");
                Edititem.Image.IconID = "actions_edit_16x16devav";
                Edititem.BeginGroup = true;
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Edititem);

                var Deleteitem = e.CreateItem("Delete", "Delete");
                Deleteitem.Image.IconID = "actions_delete_16x16devav";
                Deleteitem.BeginGroup = true;
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Deleteitem);

                var Viewitem = e.CreateItem("View", "View");
                Viewitem.Image.IconID = "print_tasklist_16x16devav";
                Viewitem.BeginGroup = true;
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Viewitem);
            }
        };
        settings.PreRender = (sender, e) =>
        {
            ASPxGridView grid = (ASPxGridView)sender;
            grid.FocusedRowIndex = -1;
        };

        settings.KeyFieldName = "Sr_No";
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Sr_No";
                column.Caption = "Sr No.";
                column.Visible = true;
                column.Width = 150;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Description";
                column.Caption = "Description Of Work";
                column.Visible = true;
                column.Width = 250;
            }
        });
        if (ViewBag.Estimation_HideColumn == false)
        {
            settings.Columns.Add(column =>
            {
                {
                    column.FieldName = "Estimated_Qty";
                    column.Caption = "Estimated Qty.";
                    column.Visible = true;
                    column.Width = 150;
                    column.PropertiesEdit.DisplayFormatString = "#0.00";
                }
            });
            settings.Columns.Add(column =>
            {
                {
                    column.FieldName = "Unit";
                    column.Caption = "Unit";
                    column.Visible = true;
                    column.Width = 200;
                }
            });
            settings.Columns.Add(column =>
            {
                {
                    column.FieldName = "Rate";
                    column.Caption = "Rate Per Unit";
                    column.Visible = true;
                    column.Width = 150;
                    column.PropertiesEdit.DisplayFormatString = "#0.00";
                }
            });
            settings.Columns.Add(column =>
            {
                {
                    column.FieldName = "Total_Amount";
                    column.Caption = "Amount Rs.";
                    column.Visible = true;
                    column.Width = 150;
                    column.PropertiesEdit.DisplayFormatString = "#0.00";
                }
            });
        }
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Added_By";
                column.Caption = "Added_By";
                column.Visible = false;
                column.Width = 5;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Added_On";
                column.Caption = "Added_On";
                column.Visible = false;
                column.Width = 5;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "ID";
                column.Caption = "ID";
                column.Visible = false;
                column.Width = 5;
            }
        });

    }).Bind(Model).GetHtml()

