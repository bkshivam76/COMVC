@using DevExtreme.AspNet.Mvc;
@model ConnectOneMVC.Areas.Stock.Models.ProjectRegister_Period
<style>
    .dx-button-has-icon .dx-button-content {
        padding-right: 8px !important;
    }

    .dx-toolbar-after .dx-button-content {
        padding-right: 0px !important;
    }
</style>

@{
    Html.EnableClientValidation();
    Html.EnableUnobtrusiveJavaScript();
    Html.AntiForgeryToken();
}

<style>
    .demo {
        margin-bottom: -99999px !important;
        padding-bottom: 99999px !important;
    }

    #equalheight {
        overflow: hidden;
    }

    .paddLR5 {
        padding-left: 5px !important;
        padding-right: 5px !important;
    }

    .margT4 {
        margin-top: 4px !important;
    }

    .buttonMrgTB {
        margin-bottom: 15px;
        margin-top: 15px;
    }

    .margTB2 {
        margin-top: 2px !important;
        margin-bottom: 2px !important;
    }
</style>
<link href="/content/fontawesome/css/fontawesome-all.css" rel="stylesheet">
<div>
    @using (Ajax.BeginForm("Frm_Change_Period_Screen_PR", "ProjectScreen",
           new AjaxOptions
           {
               HttpMethod = "POST",
               UpdateTargetId = "Frm_Change_Period_Screen_PR",
               InsertionMode = InsertionMode.InsertAfter,
               OnBegin = "AjaxBeginFormPost",
               OnSuccess = "Frm_Change_Period_Screen_PR_Success"
           },
            new
            {
                id = "id_Frm_Change_Period_Screen_PR",
                @class = "edit_form"
            }))
    {
        using (Html.DevExtreme().ValidationGroup())
        {
            <div class="row">
                <div class="form-field" style="padding-bottom:7px;">
                    <div class="container-fluid mb_height27">
                        <div class="row">
                            <div class="col-sm-3 col-md-3 col-lg-3 pll"><label class="control-label  text-red" for="Name">From:</label></div>
                            <div class="col-sm-9 col-md-9 col-lg-9 prm">
                                <div class="dx-texteditor dx-widget dx-textbox">
                                    <div class="dx-texteditor-container">
                                        @(Html.DevExtreme().DateBox().CustomDateBox().ID("Pr_Fromdate").Name("Pr_Fromdate").Min(Model.Pr_Opendate).Max(Model.Pr_Closedate).Value(Convert.ToDateTime(Model.Pr_Fromdate)).ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }))
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="form-field" style="padding-bottom:7px;">
                    <div class="container-fluid mb_height27">
                        <div class="row">
                            <div class="col-sm-3 col-md-3 col-lg-3 pll"><label class="control-label  text-red" for="Name">To:</label></div>
                            <div class="col-sm-9 col-md-9 col-lg-9 prm">
                                <div class="dx-texteditor dx-widget dx-textbox">
                                    <div class="dx-texteditor-container">
                                        @(Html.DevExtreme().DateBox().CustomDateBox().ID("Pr_Todate").Name("Pr_Todate").Min(Model.Pr_Opendate).Max(Model.Pr_Closedate).Value(Convert.ToDateTime(Model.Pr_Todate)).ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }))
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div><!--[row]-->
            <div class="row">
          
                    <div class="col-lg-12 col-xs-12">
                         <div class="styleActionBtn">
                        @(Html.DevExtreme().Button().ID("pRChangePeriod").CustomSaveButton().Text("Ok").FocusStateEnabled(true).UseSubmitBehavior(true) )
                        @(Html.DevExtreme().Button().ID("PrChangePeriodCancel").CustomCloseButton().Text("Cancel").FocusStateEnabled(true).OnClick(@<text> function () { $("#Dynamic_Content_popup").dxPopup("hide"); } </text>) )
                    </div>
                </div>
            </div><!--[button]-->
        }
    }
</div>
<script>
    $(document).ready(function () {
        setTimeout(function () {
            $("#Pr_Fromdate").dxDateBox("instance").focus();
        }, Timeout100);
    });
    function Frm_Change_Period_Screen_PR_Success(data) {
        HideLoader();
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.Message, 'Error!!');
        }
        else {

            var FromDate = $("#Pr_Fromdate").dxDateBox("instance").option("value");
            var ToDate = $("#Pr_Todate").dxDateBox("instance").option("value");
            var tomonth = ToDate.getMonth() + 1;
            var frommonth = FromDate.getMonth() + 1;
            var Fromdatefordisplay = FromDate.getDate() + "-" + frommonth + "-" + FromDate.getFullYear();
            var Todatefordisplay = ToDate.getDate() + "-" + tomonth + "-" + ToDate.getFullYear();
            FromDate = frommonth + "-" + FromDate.getDate() + "-" + FromDate.getFullYear();
            ToDate = tomonth + "-" + ToDate.getDate() + "-" + ToDate.getFullYear();
            $("#BE_View_PeriodPR").dxTextBox("instance").option("value", "Fr:" + Fromdatefordisplay + " " + "To:" + Todatefordisplay);
            ProjectScreenListGrid.Refresh();
            $("#Dynamic_Content_popup").dxPopup("hide");
        }
    }

</script>