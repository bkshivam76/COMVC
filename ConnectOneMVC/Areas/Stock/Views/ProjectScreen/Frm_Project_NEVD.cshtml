                $("#PR_BUT_estNew").dxButton("instance").option("disabled", true);
                $("#PR_BUT_estEdit").dxButton("instance").option("disabled", true);
                $("#PR_BUT_estDelete").dxButton("instance").option("disabled", true);
                $("#PR_BUT_estView").dxButton("instance").option("disabled", true);
                $("#PR_BUT_estPrint").dxButton("instance").option("disabled", true);
