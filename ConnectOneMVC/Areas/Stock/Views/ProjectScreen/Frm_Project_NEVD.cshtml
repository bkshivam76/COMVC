    function Project_NEVD_SAVE_CLICK(e)
    {
        var result = DevExpress.ui.dialog.confirm("Sure You Want To Save", "Project");
        result.done(function (dialogResult)
        {
            var form = $("#projectvalidationForm");
            if (dialogResult)
            {
                var result = e.validationGroup.validate();
                if (result.isValid)
                {
                    form.submit();
                }
            }
        });
    }
    function Project_NEVD_Delete_CLICK(e)
    {
        var form = $("#projectvalidationForm");
        var result = DevExpress.ui.dialog.confirm("Sure You Want To Delete..?", "Delete~Project");
        result.done(function (dialogResult)
        {
            if (dialogResult)
            {
                $.ajax({
                    type: 'GET',
                    url: "/Stock/ProjectScreen/CheckDocumentsLinked",
                    cache: false,
                    async: false,
                    data: {
                        ProjectID: PR_REC_ID
                    },
                    success: function (check)
                    {
                        if (check.result == false)
                        {
                            form.submit();
                        }
                        else {
                            var docdel = DevExpress.ui.dialog.confirm(check.message, "Unlink-Documents");
                            docdel.done(function (dialogResult)
                            {
                                if (dialogResult)
                                {
                                    form.submit();
                                }
                            });
                        }
                    }
                });
            }
        });
    }
    function OnProjectRequestAjaxSuccessForm(data) {
        dontaskpopupcloseconfirmation = true;
        HideLoader();
        if (data.result == false)
        {
            DevExpress.ui.dialog.alert(data.message, "Error");
        }
        else
        {
            DevExpress.ui.dialog.alert(data.message, "Success");
            $("#Dynamic_Content_popup").dxPopup("hide");
            ProjectScreenListGrid.SetFocusedRowIndex(-1);
            ProjectScreenListGrid.Refresh();
        }
    }
    function ProjectRegister_close(e)
    {

      
        if ("@Model.PR_PopUpID" == "Dynamic_Content_popup")
