            $("#PR_BUT_estEdit").dxButton("instance").option("disabled", false);
            $("#PR_BUT_estDelete").dxButton("instance").option("disabled", false);
            $("#PR_BUT_estView").dxButton("instance").option("disabled", false);
            $("#PR_BUT_estPrint").dxButton("instance").option("disabled", false);
            $("#BUT_Estimate").dxButton("instance").option("visible", true);
        }
        else
        {
            $("#Project_Name").dxTextBox("instance").option("readOnly", false);
            $("#Project_Request_Date").dxDateBox("instance").option("readOnly", false);
            $("#Project_Type_ID").dxDropDownBox("instance").option("readOnly", false);
            $("#Project_Complex_ID").dxDropDownBox("instance").option("readOnly", false);
            $("#Project_Summary").dxTextBox("instance").option("readOnly", false);
