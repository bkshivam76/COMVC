    function PR_Add_Dept_Click()
    {
        if (ProjectRequest_AddDeptright != "True")
        {
            DevExpress.ui.dialog.alert('Not Allowed', 'No Rights');
            return;
        }
        $("#PR_Content_popup").dxPopup("instance").option("contentTemplate", "<div id='result_projectdept'></div>")
        $("#PR_Content_popup").dxPopup("show");
        $("#PR_Content_popup").dxPopup("instance").option("title", "New ~Dept");
        $("#PR_Content_popup").dxPopup("instance").option("width", "80%");
        $("#PR_Content_popup").dxPopup("instance").option("height", "71%");
        $("#result_jobdept").html(null);
        ShowLoader();
        $.ajax({
            type: "GET",
            url: "/Stock/Store_Dept_Master/Frm_Store_Dept_Master_Window",
            data: {
                ActionMethod: "New",
                ID: 0,
                PostSucessFunction: "ProjectAddstoredeptSuccess",
                PopupName: "PR_Content_popup",
                ButtonID:"Pr_Add_Dept"
            },
            success: function (data) {
                HideLoader();
                $("#result_projectdept").html(data);
                HideLoader();
            }
        });
        HideLoader();

    }
    function ProjectAddstoredeptSuccess(data)
    {
        HideLoader();
        if (data.result == true) {
            $("#PR_Content_popup").dxPopup("hide");
            $("#LookUp_ReqMainDept_List_datagrid").dxDataGrid("instance").refresh();
        }
        else {
            DevExpress.ui.dialog.alert(data.Message, "Error");
        }
    }
