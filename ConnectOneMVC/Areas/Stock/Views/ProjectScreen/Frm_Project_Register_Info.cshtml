    function ProjectAddDocuments()
    {
        if (!PR_REC_ID) {
            DevExpress.ui.dialog.alert("Please Select A Row...!!", "Error");
            return;
        }
        var statusFlowCheck = project_StatusFlowCheck("Document");
        if (statusFlowCheck[0] == false) { DevExpress.ui.dialog.alert(statusFlowCheck[1], 'Error!!'); return; }
        var DataNavigationCheck = project_dataNavigation("Document");
        if (DataNavigationCheck[0] == false) { DevExpress.ui.dialog.alert(DataNavigationCheck[1], 'Error!!'); return; }
        $("#ID_Frm_Help_Document_Attach").remove();
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Help/Attachment/Frm_Attachment_Window",
            data: {
                AM: "New",
                PostSucessFunctionName: "Frm_InnerGrid_DirectAdd_OnSuccess_Prj",
                Post_action_Name: "Frm_Project_Document",
                Post_Controller_Name: "ProjectScreen",
                Post_Area_Name: "Stock",
                Document_Grid_PopupName: "PRinnergrid",
                ByteSessionVariable: "PRDocument",
                Refrecid: PR_REC_ID.toString()
            },
            cache: false,
            success: function (data) {
                ShowLoader();
                OpenPopup("PRinnergrid", "New ~ Documents", null, "auto", 900, true, data);   
             
           
            }
        });
        HideLoader();
    }//Mantis 0000213 bug fixed
    function Frm_InnerGrid_DirectAdd_OnSuccess_Prj(data)
    {
        if (data.result == true)
        {
            $("#PRinnergrid").dxPopup("hide");
            DevExpress.ui.dialog.alert(data.message, "Inform");
            ProjectScreenListGrid.SetFocusedRowIndex(-1);
            ProjectScreenListGrid.Refresh();
            HideLoader();
        }
        if (data.result == false)
        {
            DevExpress.ui.dialog.alert(data.message, "Inform");
            HideLoader();
        }
    }
    function project_printEstimationReport()
    {
        if (!PR_REC_ID) {
            DevExpress.ui.dialog.alert('Select A Row', 'Alert'); return;
        }
        if (PR_CurrUserRole.includes("Estimator") || PR_CurrUserRole.includes("Approver"))
        {
            $("#ProjectRegister_report_modal").dxPopup("show");
            $("#ProjectRegister_report_modal").dxPopup("instance").option("title", "Export Option");
            $("#ProjectRegister_report_modal").html('');
            ShowLoader();
            $("#ProjectRegister_report_modal_result").load("@Url.Action("Frm_Export_Options_Estimation", "ProjectScreen", new { @area = "Stock" })", function () {
                HideLoader();
            });
        }
        else { DevExpress.ui.dialog.alert('Not Allowed', 'No Rights'); return; }
    }

