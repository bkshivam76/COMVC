<script>
     function ChangePeriodinLayout()
    {  
         OpenDynamicPopup("Change Period", "@Url.Action("Frm_Change_Period_Screen", "ProjectScreen", new { @area = "Stock" })", "auto", "45%");
    }

    function LookUp_ViewType_ChangeEvent(e)
    {
        var SelectBox = $("#PeriodSelection_PS").dxSelectBox("instance").option("value");
        $("#ChangePeriodPR").dxButton("instance").option("disabled", true);
        if (SelectBox == "Specific Period")
        {
            $("#ChangePeriodPR").dxButton("instance").option("disabled", false);
            $("#BE_View_PeriodPR").dxTextBox("instance").option("value", "");
            ChangePeriodinLayout();
        }
        else
        {
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Stock/ProjectScreen/LookUp_ViewType_ChangeEvent",
                data: { Chaval: $("#PeriodSelection_PS").dxSelectBox("instance").option("value")  },
                cache: false,
                success: function (data)
                {
                    if (data.result == true)
                    {
                        $("#BE_View_PeriodPR").dxTextBox("instance").option("value", data.Message.Pr_BE_View_Period);
                                                ShowLoader();
                        ProjectScreenListGrid.Refresh();

                        HideLoader();
                    }
                }
            });
            HideLoader();
        }
    }//Period Selection
</script>
