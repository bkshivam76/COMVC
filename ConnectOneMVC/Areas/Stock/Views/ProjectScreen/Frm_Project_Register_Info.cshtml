            @(Html.DevExtreme().Button().ID("ADD_QuickJob").Text("Add Quick Job").Visible(true).Disabled(false).OnClick(@<text> function () { Qad_Aes_Sea_Cr_Appr_Rej_Cp_Mc("QuickJob"); } </text>))
