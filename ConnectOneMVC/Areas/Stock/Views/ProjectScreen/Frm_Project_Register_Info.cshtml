            @(Html.DevExtreme().Button().ID("Submitted_for_Estimate_Approval").Text("Submit for Estimation Approval").OnClick(@<text> function () { Qad_Aes_Sea_Cr_Appr_Rej_Cp_Mc("Estimate Approval"); } </text>))
