@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                    .ID("GetStockAssignSubDept_PRGrid")
                  
                    .Columns(columns =>
                    {

                        columns.Add().DataField("Name").Caption("Name Type");
