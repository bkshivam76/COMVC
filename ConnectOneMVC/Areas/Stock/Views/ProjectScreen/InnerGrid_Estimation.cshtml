@model ConnectOneMVC.Areas.Stock.Models.Model_Project_NEVD
@using DevExtreme.AspNet.Mvc;
@{
    bool IsVisible = (Model != null && Model.TempActionMethod == "_Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.TempActionMethod == "_View" || Model.TempActionMethod == "_Delete") ? true : false;
}
<div class="row">
    <div class="col-md-12">
        @Html.Action("EstimationGridData", "ProjectScreen", new { ActionMethodName = Model.ActionMethod , ProjectID = Model.ProjectID, EstimatorID = Model.Project_Estimator_ID })
    </div>
</div>
<div class="row">
    <div class="form-field">
        <div class="container-fluid">
            <div class="col-md-12">
                @(Html.DevExtreme().Button().ID("PR_BUT_estNew").Text("New").Icon("fas fa-file btn-icons newfile icon-rgt-space5").Disabled(true).OnClick(@<text> function () { OnFrm_Estimation_New_Click() } </text>))
                @(Html.DevExtreme().Button().ID("PR_BUT_estEdit").Text("Edit").Icon("fas fa-pencil-alt btn-icons editcolor icon-rgt-space5").Disabled(true).OnClick(@<text> function () { OnFrm_Estimation_Edit_Click() } </text>))
                @(Html.DevExtreme().Button().ID("PR_BUT_estDelete").Text("Delete").Icon("fas fa-trash btn-icons deletecolor icon-rgt-space5").Disabled(true).OnClick(@<text> function () {     OnFrm_Estimation_Delete_Click() } </text>))
                @(Html.DevExtreme().Button().ID("PR_BUT_estView").Text("View").Icon("fas fa-eye btn-icons eyeicon icon-rgt-space5").Disabled(true).OnClick(@<text> function () {OnFrm_Estimation_View_Click() } </text>))
                @(Html.DevExtreme().Button().ID("PR_BUT_estPrint").Text("Print Report").Icon("fas fa-eye btn-icons eyeicon icon-rgt-space5").Disabled(true).OnClick(@<text> function () {DevExpress.ui.dialog.alert("Coming Soon!!", "Error"); } </text>)) @*OnFrm_Estimation_PrintReport_Click()*@

            </div>
        </div>
    </div>
</div>
<script>
    var Estimation_Sr;
    var Est_ID;
    var Is_Estimation_Refresh = false;
    var Is_InsertNewEstRow = false;
    var EstimatorID = 0;
    EstimatorID = "@Model.Project_Estimator_ID";
    function OnEstimationDetailsGridFocusedRowChanged(s, e)
    {
        debugger
        if (s.GetFocusedRowIndex() > -1) {
            s.GetRowValues(s.GetFocusedRowIndex(), 'Sr_No;ID', OnEstimationDetailsGridRowValues);
        }
        else { Estimation_Sr = 0; }
    }//Mantis bug 0000214 fixed

    function OnEstimationDetailsGridRowValues(values)
    {        
        Estimation_Sr = values[0];
        Est_ID = values[1];
    }
    function OnFrm_Estimation_BeginCallback(s,e)
    {
        debugger
        e.customArgs["EstimatorID"] = EstimatorID;
  


        //"function(s, e) { e.customArgs['command'] =e.command;   e.customArgs['TO_CEN_ID'] = TO_CEN_ID; e.customArgs['TO_CEN_NAME'] = To_CEN_Name;}";
        //    @*//"@Model.Project_Estimator_ID";*@
            //$('#Project_Estimator_ID').dxDropDownBo
    
        if (e.command == "REFRESH")
        {
            Is_Estimation_Refresh = true;
        }
    }
    function OnFrm_Estimation_EndCallback(s, e)
    {
        if (Is_Estimation_Refresh)
        {
            if (Is_InsertNewEstRow == true)
            {
                Is_InsertNewEstRow = false;
                if (s.GetVisibleRowsOnPage() == 1)
                {
                    $("#Project_Estimation_Date").dxDateBox("instance").option("value", new Date().toLocaleDateString());
                }
            }
        }
    }
    function Frm_Estimation_Detail_Grid_ContextMenuFunction(s, e)
    {
        if (e.item.name == "New")
        {
            OnFrm_Estimation_New_Click();
        }
        if (e.item.name == "Edit")
        {
            OnFrm_Estimation_Edit_Click();
        }
        if (e.item.name == "Delete")
        {
            OnFrm_Estimation_Delete_Click();
        }
        if (e.item.name == "View")
        {
            OnFrm_Estimation_View_Click();
        }
    }

    $("#Estimation_Window_Grid").keydown(function (evt) {
        switch (evt.keyCode) {
            case 45: // insert key
                OnFrm_Estimation_New_Click();
                break;
            case 13: //enter key
                OnFrm_Estimation_Edit_Click();
                break;
            case 32: //space bar
                OnFrm_Estimation_View_Click();
                break;
            case 46://delete key
                OnFrm_Estimation_Delete_Click();
                break;
        }
        if (evt.ctrlKey && evt.keyCode == 73)//ctrl+i
        {
            OnFrm_Estimation_New_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 69)//ctrl+e
        {
            OnFrm_Estimation_Edit_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_Estimation_View_Click();
        }
    });


    function OnFrm_Estimation_New_Click()
    {
        if ("@IsDisabled" == "True") { return; }
        if ($("#PR_BUT_estNew").dxButton("instance").option("disabled")) { return;}
        Is_InsertNewEstRow = true; 
        ShowLoader();      
        OpenPopup("PRinnergrid", "New ~ Estimation", "@Url.Action("Frm_Project_Request_Add_Estimate", "ProjectScreen", new {@area= "Stock" })?ActionMethod=_New", "auto", 1000, false, null);
           
    }
    function OnFrm_Estimation_Edit_Click()
    {
    
        if ("@IsDisabled" == "True") { return; }
        if ($("#PR_BUT_estEdit").dxButton("instance").option("disabled")) { return; }
        if (Estimation_Sr == null || Estimation_Sr == undefined || Estimation_Sr == "undefined")       
        {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');  return;
        }//Mantis bug 0000214 fixed
        else
        { 
            ShowLoader();
            OpenPopup("PRinnergrid", "Edit ~ Estimation", "@Url.Action("Frm_Project_Request_Add_Estimate", "ProjectScreen", new {@area= "Stock" })?ActionMethod=_Edit&SrID=" + encodeURIComponent(Estimation_Sr), "auto", 1000, false, null);
      
        }
    }
    function OnFrm_Estimation_View_Click()
    {
        if ($("#PR_BUT_estView").dxButton("instance").option("disabled")) { return; }
        if (Estimation_Sr == null || Estimation_Sr == undefined || Estimation_Sr == "undefined" || Estimation_Sr == 0) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert '); return;
        }//Mantis bug 0000214 fixed
        else
        {          
            ShowLoader();
            OpenPopup("PRinnergrid", "Edit ~ Estimation", "@Url.Action("Frm_Project_Request_Add_Estimate", "ProjectScreen", new {@area= "Stock" })?ActionMethod=_View&SrID=" + encodeURIComponent(Estimation_Sr), "auto", 1000, false, null);
          
        }
    }
    function OnFrm_Estimation_Delete_Click()
    {
        if ("@IsDisabled" == "True") { return; }
        if ($("#PR_BUT_estDelete").dxButton("instance").option("disabled")) { return; }
        if (Estimation_Sr == null || Estimation_Sr == undefined || Estimation_Sr == "undefined" || Estimation_Sr == 0) {        
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }//Mantis bug 0000214 fixed
        var deleteResultPaymentDetail = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
        deleteResultPaymentDetail.done(function(dialogResult) {

            if (dialogResult)
            {
                      $.ajax({
                type: 'GET',
                          url: "/Stock/ProjectScreen/Frm_EstimationDetail_Window_Delete_Grid_Record",
                          data: { ActionMethod: "Delete", SrID: Estimation_Sr },
                          cache: false,
                          success: function (result) {
                              if (result.result == true) {
                                  Estimation_Window_Grid.SetFocusedRowIndex(-1);
                                  Estimation_Window_Grid.Refresh();                                  
                              }
                          }
                });
            }
        });
    }
    function Frm_Estimation_Window_OnSuccess(data)
    {
        HideLoader();
        if (data.result == false)
        {
            DevExpress.ui.dialog.alert(data.message, "Error");
        }
        else
        {
            $("#PRinnergrid").dxPopup("hide");
            Estimation_Window_Grid.SetFocusedRowIndex(-1);
            Estimation_Window_Grid.Refresh();
           //mantis bug #1311
            
        }
    }
    function OnFrm_Estimation_PrintReport_Click()
    {
        if ("@IsDisabled" == "True") { return; }
        if ($("#PR_BUT_estPrint").dxButton("instance").option("disabled")) { return; }
        $("#ProjectRegister_report_modal").dxPopup("show");
        $("#ProjectRegister_report_modal").dxPopup("instance").option("title", "Export Option");
        $("#ProjectRegister_report_modal").html('');
        ShowLoader();
        $("#ProjectRegister_report_modal_result").load("@Url.Action("Frm_Export_Options_Estimation", "ProjectScreen", new { @area = "Stock" })", function () {
            HideLoader();
        });
    }

    //End Estimation Script
</script>