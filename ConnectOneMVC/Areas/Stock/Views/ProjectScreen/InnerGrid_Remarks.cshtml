@model ConnectOneMVC.Areas.Stock.Models.Model_Project_NEVD
@using DevExtreme.AspNet.Mvc;
@{
    bool IsVisible = (Model != null && Model.TempActionMethod == "_Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.TempActionMethod == "_View" || Model.TempActionMethod == "_Delete") ? true : false;
}
<div class="row">
    <div class="col-md-12">
        @Html.Action("ExistingRemarksGridData", "ProjectScreen", new { ActionMethodName = Model.TempActionMethod, ProjectID = Model.ProjectID })
    </div>
</div>
<div class="row">
    <div class="form-field">
        <div class="container-fluid">
            <div class="col-md-12">
                @(Html.DevExtreme().Button().ID("PR_BUT_remDelete").Text("Delete").Icon("fas fa-trash btn-icons deletecolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () {      OnFrm_Existing_Remarks_Delete_Click() } </text>))
                @(Html.DevExtreme().Button().ID("PR_BUT_remView").Text("View").Icon("fas fa-eye btn-icons eyeicon icon-rgt-space5").Disabled(IsVisible).OnClick(@<text> function () {        OnFrm_Existing_Remarks_View_Click() } </text>))
            </div>
        </div>
    </div>
</div>
<script>
    var ExistingRemarks_Id;
    var ExistingRemarks_sr;
    $("#ExistingRemarks_Window_Grid").keydown(function (evt) {
        switch (evt.keyCode) {      
            case 32: //space bar
                OnFrm_Existing_Remarks_View_Click();
                break;
            case 46://delete key
                OnFrm_Existing_Remarks_Delete_Click();
                break;
        }    
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_Existing_Remarks_View_Click();
        }
    });
    function OnExistingRemarksGridFocusedRowChanged(s, e)
    {
        s.GetRowValues(s.GetFocusedRowIndex(), 'Sr_No;ID', OnRemarksDetailsGridRowValues);
    }
    function OnRemarksDetailsGridRowValues(values)
    {
  
        ExistingRemarks_sr = values[0];
        ExistingRemarks_Id = values[1];
        Remarks = values[2];
    }
    function Frm_Remarks_Grid_ContextMenuFunction(s, e)
    {    
        if (e.item.name == "Delete")
        {
            OnFrm_Existing_Remarks_Delete_Click();
        }
        if (e.item.name == "View")
        {
            OnFrm_Existing_Remarks_View_Click();
        }
    }
    function OnFrm_Existing_Remarks_Delete_Click()
    {if ("@IsDisabled"=="True") { return; }
        if (ExistingRemarks_Id == 'undefined' || ExistingRemarks_Id == undefined || ExistingRemarks_Id == null) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        var deleteResultPaymentDetail = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
        deleteResultPaymentDetail.done(function (dialogResult) {

            if (dialogResult) {
                $.ajax({
                    type: 'GET',
                    url: "/Stock/ProjectScreen/Frm_ExistingRemarks_Window_Delete_Grid_Record",
                    data: { ActionMethod: "Delete", SrID: ExistingRemarks_Id },
                    cache: false,
                    success: function (result)
                    {
                        if (result.result == false) {
                            DevExpress.ui.dialog.alert(result.message, 'Alert ');
                        }
                        else {
                            ExistingRemarks_Window_Grid.Refresh();
                            ExistingRemarks_Window_Grid.SetFocusedRowIndex(-1);
                        }
                    }//Mantis bug 0000218 fixed
                });
            }
        });
    }
    function OnFrm_Existing_Remarks_View_Click()
    {
        if (ExistingRemarks_sr == 'undefined' || ExistingRemarks_sr == undefined || ExistingRemarks_sr == null)
        {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        else
        {  
            ShowLoader();
            OpenPopup("PRinnergrid", "View ~ Remarks","@Url.Action("Frm_ViewRemarks", "ProjectScreen", new {@area= "Stock" })?SR=" + encodeURIComponent(ExistingRemarks_sr), "auto", 900, false, null);
            HideLoader();  
        }

    }
    </script>
