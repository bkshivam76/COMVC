@model ConnectOneMVC.Areas.Stock.Models.Model_NEVD_Purchase
@using DevExtreme.AspNet.Mvc;
@{
    bool IsVisible = (Model != null && Model.ActionMethod == "Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.ActionMethod == "View" || Model.ActionMethod == "Delete") ? true : false;
}
<div class="row">
    <div class="col-md-12">
        @Html.Action("PurchaseDocumentsGridData", "PurchaseRegister", new { ActionMethodName = Model.ActionMethod, PO_ID = Model.PO_ID })
    </div>
</div>

<div class="row">
    <div class="form-field">
        <div class="container-fluid">
            <div class="col-md-12 btnsDiv">
                    @(Html.DevExtreme().Button().ID("purchaseBUT_DocNew").Text("New").Icon("fas fa-file btn-icons newfile icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Documents_New_Click() } </text>))
                    @(Html.DevExtreme().Button().ID("purchaseBUT_DocEdit").Text("Edit").Icon("fas fa-pencil-alt btn-icons editcolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Document_Edit_Click() } </text>))
                    @(Html.DevExtreme().Button().ID("purchaseBUT_DocDelete").Text("Delete").Icon("fas fa-trash btn-icons deletecolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_Document_Delete_Click() } </text>))
                    @(Html.DevExtreme().Button().ID("purchaseBUT_DocView").Text("View").Icon("fas fa-eye btn-icons eyeicon icon-rgt-space5").Disabled(IsVisible).OnClick(@<text> function () { OnFrm_Document_View_Click() } </text>))
            </div>
        </div>
    </div>
</div>
<script>
    var Document_Sr;
    var Document_ID;
    function OnDocumentDetailsGridFocusedRowChanged(s, e) {
        s.GetRowValues(s.GetFocusedRowIndex(), 'Sr_No;ID;', OnDocumentsDetailsGridRowValues);
    }
    function OnDocumentsDetailsGridRowValues(values) {
        Document_Sr = values[0];
        Document_ID = values[1];
    }
    $("#PurchaseDocumentsGrid").keydown(function (evt) {
        switch (evt.keyCode) {
            case 45: // insert key
                OnFrm_Documents_New_Click();
                break;
            case 13: //enter key
                OnFrm_Document_Edit_Click();
                break;
            case 32: //space bar
                OnFrm_Document_View_Click();
                break;
            case 46://delete key
                OnFrm_Document_Delete_Click();
                break;
        }
        if (evt.ctrlKey && evt.keyCode == 73)//ctrl+i
        {
            OnFrm_Documents_New_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 69)//ctrl+e
        {
            OnFrm_Document_Edit_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_Document_View_Click();
        }
    });
    function OnFrm_Documents_New_Click()
    {

        if ("@IsDisabled" == "true") { return; }

        var menucheck = PO_StatusFlowCheck("Documents");
        if (menucheck[1] == false) {
            DevExpress.ui.dialog.alert(menucheck[0], "Error");
            return;
        }

        $("#ID_Frm_Help_Document_Attach").remove();
        ShowLoader(); 
        $.ajax({
            type: 'GET',
            url: "/Help/Attachment/Frm_Attachment_Window",
            data: {
                AM:"New",
                PostSucessFunctionName:"Frm_Purchase_Documents_Window_OnSuccess",
                Post_action_Name:"Purchase_Documents_Attachment",
                Post_Controller_Name:"PurchaseRegister",
                Post_Area_Name: "Stock",
                Document_Grid_PopupName: "Purchaseinnergrid",
                ByteSessionVariable:"PurchaseDocument"
            },
            cache: false,
            success: function (data)
            {
                OpenPopup("Purchaseinnergrid", "New ~ Documents", null, "auto", 1024, true, data);             
            }
        });
  
    }//new click//Mantis 0000213 bug fixed
    function OnFrm_Document_Edit_Click()
    {
        if ("@IsDisabled" == "true") { return; }
        if (Document_Sr == 'undefined' || Document_Sr == undefined || Document_Sr == null || Document_Sr == "")
        {
              DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
              return;
        }
            $("#ID_Frm_Help_Document_Attach").remove();
            ShowLoader();  
          $.ajax({
              type: 'GET',
              url: "/Help/Attachment/Frm_Attachment_Window",
              data: {
                  AM: "Edit",
                  PostSucessFunctionName: "Frm_Purchase_Documents_Window_OnSuccess",
                  Post_action_Name: "Purchase_Documents_Attachment",
                  Post_Controller_Name: "PurchaseRegister",
                  Post_Area_Name: "Stock",
                  Document_Grid_Data_SessionName: "Purchase_Documents_Window_Grid_Data_PO",
                  Document_Grid_SrNo: Document_Sr,
                  ID: Document_ID,
                  Document_Grid_PopupName: "Purchaseinnergrid",
                  ByteSessionVariable: "PurchaseDocument"
              },
              cache: false,
              success: function (data) {
                  OpenPopup("Purchaseinnergrid", "Edit ~ Documents", null, "auto", 1024, true, data);  
              }
          });
               
    }//edit click//Mantis 0000213 bug fixed
    function OnFrm_Document_Delete_Click() { if ("@IsDisabled"=="true") { return; }
        if (!Document_Sr) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        if (Document_ID) {
            $.ajax({
                type: 'GET',
                url: "/Stock/PurchaseRegister/Purchase_Documents_Attachment_LinkCheck",
                data: { DocId: Document_ID, POId: PO_ID },
                cache: false,
                success: function (data) {
                    if (data.result == false) {
                        var deleteResultDocument = DevExpress.ui.dialog.confirm(data.message, "Confirm changes");
                        deleteResultDocument.done(function (dialogResult) {
                            if (dialogResult) {
                                $.ajax({
                                    type: 'GET',
                                    url: "/Stock/PurchaseRegister/Frm_DocumentsDetail_Window_Delete_Grid_Record",
                                    data: { ActionMethod: "Unlink", Doc_ID: Document_ID },
                                    cache: false,
                                    success: function (result) {
                                        PurchaseDocumentsGrid.SetFocusedRowIndex(-1);
                                        PurchaseDocumentsGrid.Refresh();
                                    }
                                });
                            }
                        });
                    }
                    else
                    {
                        purchase_deletedocument();
                    }
                }
            });
        }
                    else {
            purchase_deletedocument();
                    }
                } //delete click
    function purchase_deletedocument()
    { if ("@IsDisabled"=="true") { return; }
        var deleteResultPaymentDetail = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
        deleteResultPaymentDetail.done(function (dialogResult) {
            if (dialogResult) {
                $.ajax({
                    type: 'GET',
                    url: "/Stock/PurchaseRegister/Frm_DocumentsDetail_Window_Delete_Grid_Record",
                    data: { ActionMethod: "Delete", SrID: Document_Sr, Doc_ID: Document_ID },
                    cache: false,
                    success: function (result) {
                        PurchaseDocumentsGrid.SetFocusedRowIndex(-1);
                        PurchaseDocumentsGrid.Refresh();
                    }
                });
            }
        });
    }
    function OnFrm_Document_View_Click()
    {
        if (Document_Sr == 'undefined' || Document_Sr == undefined || Document_Sr == null || Document_Sr == "") {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        $("#ID_Frm_Help_Document_Attach").remove();
        ShowLoader();
      $.ajax({
              type: 'GET',
              url: "/Help/Attachment/Frm_Attachment_Window",
              data: {
                  AM: "View",
                  PostSucessFunctionName: "Frm_Purchase_Documents_Window_OnSuccess",
                  Post_action_Name: "Purchase_Documents_Attachment",
                  Post_Controller_Name: "PurchaseRegister",
                  Post_Area_Name: "Stock",
                  Document_Grid_Data_SessionName: "Purchase_Documents_Window_Grid_Data_PO",
                  Document_Grid_SrNo: Document_Sr,
                  ID: Document_ID,
                  Document_Grid_PopupName: "Purchaseinnergrid",
                  ByteSessionVariable: "PurchaseDocument"
              },
              cache: false,
          success: function (data)
          {
                  OpenPopup("Purchaseinnergrid", "View ~ Documents", null, "auto", 1024, true, data);  
          }

      });
     
    }//Mantis 0000213 bug fixed
    function Frm_Purchase_Documents_Window_OnSuccess(data) {
        HideLoader();
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.message, "Error");
        }
        else {
            $("#Purchaseinnergrid").dxPopup("hide");
            PurchaseDocumentsGrid.SetFocusedRowIndex(-1);
            PurchaseDocumentsGrid.Refresh();
        }
    }

    function PO_StatusFlowCheck(Status) {
        var msg;
        var result;
        $.ajax({
            type: 'POST',
            url: "/Stock/PurchaseRegister/PurchaseOrderStatusFlow",
            data: {
                ID: PO_ID,
                StatusButton: Status,
                CurrUserRole: POCurrUserRole
            },
            async: false,
            cache: false,
            success: function (data) {
                msg = data.message;
                result = data.result;
            }
        });
        return [msg, result];
    }

</script>
