@using DevExtreme.AspNet.Mvc;
@model ConnectOneMVC.Areas.Stock.Models.PurchaseRegister_Period
<style>
    .dx-button-has-icon .dx-button-content {
        padding-right: 8px !important;
    }

    .dx-toolbar-after .dx-button-content {
        padding-right: 0px !important;
    }
</style>
@{
    Html.EnableClientValidation();
    Html.EnableUnobtrusiveJavaScript();
    Html.AntiForgeryToken();
}
<style>
    .demo {
        margin-bottom: -99999px !important;
        padding-bottom: 99999px !important;
    }
    #equalheight {
        overflow: hidden;
    }
    .paddLR5 {
        padding-left: 5px !important;
        padding-right: 5px !important;
    }
    .margT4 {
        margin-top: 4px !important;
    }
    .buttonMrgTB {
        margin-bottom: 15px;
        margin-top: 15px;
    }
    .margTB2 {
        margin-top: 2px !important;
        margin-bottom: 2px !important;
    }
</style>
<link href="/content/fontawesome/css/fontawesome-all.css" rel="stylesheet">
<div>
    @using (Ajax.BeginForm("Frm_Change_Period_Screen_Purchase", "ProjectScreen",
           new AjaxOptions
           {
               HttpMethod = "POST",
               UpdateTargetId = "Frm_Change_Period_Screen_Purchase",
               InsertionMode = InsertionMode.InsertAfter,
               OnBegin = "AjaxBeginFormPost",
               OnSuccess = "Frm_Change_Period_Screen_Purchase_Success"
           },
            new
            {
                id = "id_Frm_Change_Period_Screen_PR",
                @class = "edit_form"
            }))
    {
        using (Html.DevExtreme().ValidationGroup())
        {

                <!--<div class="full-width-header-bg3">
                    <div class="row">
                        <div class="col-sm-12 pll">
                            <h3 class="popuphead"><i class="far fa-edit"></i> Change Period</h3>
                        </div>
                    </div>
                </div>[row]-->
                <div class="row">
                    <div class="col-sm-6 col-md-6 col-lg-6">
                        <div class="form-field" style="padding-bottom:7px;">
                            <div class="container-fluid mb_height27">
                                <div class="row">
                                    <div class="col-sm-3 col-md-3 col-lg-3 pll"><label class="control-label  text-red" for="Name">From:</label></div>
                                    <div class="col-sm-9 col-md-9 col-lg-9 prm">
                                        @(Html.DevExtreme().DateBox().CustomDateBox().ID("PO_Fromdate").Name("PO_Fromdate").Min(Model.PO_Opendate).Max(Model.PO_Closedate).Value(Convert.ToDateTime(Model.PO_Fromdate)).ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).InvalidDateMessage("Value must be a Date!!"))
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div><!--[2]-->
                    <div class="col-sm-6 col-md-6 col-lg-6">
                        <div class="form-field" style="padding-bottom:7px;">
                            <div class="container-fluid mb_height27">
                                <div class="row">
                                    <div class="col-sm-3 col-md-3 col-lg-3 pll"><label class="control-label  text-red" for="Name">To:</label></div>
                                    <div class="col-sm-9 col-md-9 col-lg-9 prm">
                                        @(Html.DevExtreme().DateBox().CustomDateBox().ID("PO_Todate").Name("PO_Todate").Min(Model.PO_Opendate).Max(Model.PO_Closedate).Value(Convert.ToDateTime(Model.PO_Todate)).ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).InvalidDateMessage("Value must be a Date!!"))
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div><!--[3]-->
                    <span id="lblerror" style="font-size:11px" class="text-red"></span>
                </div><!--[row]-->

                <div class="row">
                    <div class="form-field wbg brd-bot-none">
                        <div class="col-lg-6 col-xs-12"></div>
                        <div class="col-lg-6 col-xs-12">
                            <div class="action-btn-wrap">
                                @(Html.DevExtreme().Button().CustomCloseButton().ID("PurchaseChangePeriodCancel").Text("Cancel").ElementAttr("style", "float:right;margin-left:5px;margin-right:0px;margin-top:0px").FocusStateEnabled(true).OnClick(@<text>function () {$("#Dynamic_Content_popup").dxPopup("hide");}</text>))
                            </div>
                            <div class="action-btn-sec-wrap">
                                @(Html.DevExtreme().Button().CustomSaveButton().ID("PurchaseChangePeriodOK").Text("Ok").ElementAttr("style", "float:right;margin-top:0px").FocusStateEnabled(true).UseSubmitBehavior(true))
                            </div>
                        </div>
                    </div>
                </div>
        }
    }
</div>
<script>
    function Frm_Change_Period_Screen_Purchase_Success(data) {
        debugger;
        HideLoader();
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.Message, 'Error!!');
        }
        else {
            var FromDate = $("#PO_Fromdate").dxDateBox("instance").option("value");
            var ToDate = $("#PO_Todate").dxDateBox("instance").option("value");
            var tomonth = ToDate.getMonth() + 1;
            var frommonth = FromDate.getMonth() + 1;
            var Fromdatefordisplay = FromDate.getDate() + "-" + frommonth + "-" + FromDate.getFullYear();
            var Todatefordisplay = ToDate.getDate() + "-" + tomonth + "-" + ToDate.getFullYear();
            FromDate = frommonth + "-" + FromDate.getDate() + "-" + FromDate.getFullYear();
            ToDate = tomonth + "-" + ToDate.getDate() + "-" + ToDate.getFullYear();
            $("#Purchase_View_Period").dxTextBox("instance").option("value", "Fr:" + Fromdatefordisplay + " " + "To:" + Todatefordisplay);
            PurchaseRegisterGrid.Refresh();
            $("#Dynamic_Content_popup").dxPopup("hide");
        }
    }
    $(document).ready(function ()
    {
        setTimeout(function ()
        {
            $("#PO_Fromdate").dxDateBox("instance").focus();
        })
    });
</script>
            
