    function OnInitialized_OnGREShipmentChanged(e) {
        if ("@Model.ActionMethod" != "New") {
            $("#Purchase_GRE_ShipmentModeID").dxDropDownBox("instance").option("value","@Model.Purchase_GRE_ShipmentModeID");
            e.component.option("dataSource").store.load().done(function (d) {
                if (d.length > 0) {
                    var $dataGrid = $("#StockPurchaseretshipmentDG");
                    if ($dataGrid.length) {
                        var dataGrid = $dataGrid.dxDataGrid("instance");
                        dataGrid.selectRows($("#Purchase_GRE_ShipmentModeID").dxDropDownBox("instance").option("value"), false);
                    }
                }
            });
        }
    }




