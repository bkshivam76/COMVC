<script>
    $(document).ready(async function ()
    {
        var form = "ID_Frm_GoodsRet_Window";
        ShowLoader();
        AssignIDtoLabel(form, "PO_GoodsRet");
           if ("@Model.Purchase_GRE_ItemID".length > 0)
        {
               var PurchaseGoodsItemRetDG = $("#PurchaseGREItemDG").dxDataGrid("instance");
             await PurchaseGoodsItemRetDG.selectRows(parseInt("@Model.Purchase_GRE_ItemID"), false);
            }
        setTimeout(function ()
        {
            Set_Form_View_Delete_Mode(null, form, "@Model.ActionMethod");
            Focus_FirstEditable_Field(form, "@Model.ActionMethod");
            HideLoader();

        }, Timeout500);

    });

  </script>
           
 <script>
    var GREname;
    var GREcode;
    var GREmake;
    var GREmodel;
    var GREunit;
    var GRErecqty;
    var GREdate;
    var GRElot;
    var GREPriority;
    var GREmob;
    var GREbillno;
    var subitemid;
    var GREItem_Rec_ID;
     var GREChallan;
     var GRE_PendingQuantity;
     var stockID;

     function OnInitialized_OnGREItemChanged(e) {
         Ret_ID = "@Model.ID";
         if ("@Model.ActionMethod" != "New") {
            @*$("#Purchase_GRE_ItemID").dxDropDownBox("instance").option("value","@Model.Purchase_GRE_ItemID");*@
             e.component.option("dataSource").store.load().done(function (d) {
                 //if (d.length > 0) {
                 //var $dataGrid = $("#PurchaseGREItemDG");
                 //if ($dataGrid.length) {
                 //    var dataGrid = $dataGrid.dxDataGrid("instance");
                 //    dataGrid.selectRows($("#Purchase_GRE_ItemID").dxDropDownBox("instance").option("value"), false);
                 //}
                    @*e.component.option("value", @Model.Purchase_GRE_ItemID);
                }*@
                 Get_GREItem_ChangeEvent(@Model.Purchase_GRE_ItemID);
             });
         }
     }


     function Get_GREItem_ChangeEvent(e) {
         POid = "@Model.POid";
         srno = "@Model.Sr";
         recid = "@Model.ID";
         if ("@Model.ActionMethod" == "New") {

             var dropdown = $("#Purchase_GRE_ItemID").dxDropDownBox("instance");
             dropdown.close();
             var $dataGrid = $("#PurchaseGREItemDG");
             if ($dataGrid.length) {
                 PurchaseGREItemDG
                 var dataGrid = $dataGrid.dxDataGrid("instance");
                 dataGrid.selectRows(dropdown.option("value"), false);
                 if (dataGrid.getSelectedRowsData().length > 0) {
                     var item = dataGrid.getSelectedRowsData()[0];
                     GREname = item.ItemName;
                     GREcode = item.ItemCode;
                     GREmake = item.Make;
                     GREmodel = item.Model;
                     GREunit = item.Unit;
                     GRErecqty = item.ReceivedQty;
                     GREdate = item.ReceivedDate;
                     GRElot = item.LotNo;
                     GREChallan = item.ChallanNo;
                     GREPriority = item.POI_Priority;
                     subitemid = item.ItemID;
                     GREbillno = item.BillNo;
                     GREItem_Rec_ID = item.ID;
                     GRE_PendingQuantity = item.PendingToReturn;
                     stockID = item.CreatedStockID;
                     $.ajax({
                         type: 'GET',
                         url: "/Stock/PurchaseRegister/Return_Item_Entry_Already_in_Same_Grid",
                         data: { ReturnID: GREItem_Rec_ID, POid: POid, srno: srno },
                         cache: false,
                         success: function (res) {

                             if (res.result == true)//  no edited row exists
                             {
                                 $.ajax({
                                     type: 'GET',
                                     url: "/Stock/PurchaseRegister/Return_Item_Entry_in_Received_Grid",
                                     data: { RetItemID: GREItem_Rec_ID },
                                     cache: false,
                                     success: function (res) {

                                         if (res.result == true)// no added/edited row exists in returrecd
                                         {

                                             $("#Purchase_GRE_ItemName").val(GREname);
                                             //  $("#Purchase_GR_ItemCode").val(GREcode);
                                             $("#Purchase_GRE_ItemCode").dxTextBox("instance").option("value", GREcode);
                                             $("#Purchase_GR_RecdQuantity").dxTextBox("instance").option("value", GRErecqty);
                                             $("#Purchase_GRE_Make").dxTextBox("instance").option("value", GREmake);
                                             $("#Purchase_GRE_Model").dxTextBox("instance").option("value", GREmodel);
