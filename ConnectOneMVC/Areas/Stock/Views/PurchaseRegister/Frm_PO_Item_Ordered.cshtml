<script>
    $(document).ready(async function ()
    {
        var form = "ID_Frm_ItemOrd_Window";
        ShowLoader();
        AssignIDtoLabel(form, "PO_itemOrd");
           if ("@Model.Purchase_IO_ItemID".length > 0)
        {
               var StockPurchaseItemDG = $("#StockPurchaseItemDG").dxDataGrid("instance");
               await StockPurchaseItemDG.selectRows(parseInt("@Model.Purchase_IO_ItemID"), false);
            }
        setTimeout(function ()
        {
            Set_Form_View_Delete_Mode(null, form, "@Model.ActionMethod");
            Focus_FirstEditable_Field(form, "@Model.ActionMethod");
            HideLoader();

        }, Timeout500);

    });

</script>
