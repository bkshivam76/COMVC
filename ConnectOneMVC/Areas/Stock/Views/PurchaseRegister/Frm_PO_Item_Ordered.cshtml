    function CalculateTaxes() {
        var Rate = $("#Purchase_IO_Rate").dxNumberBox("instance").option("value");
        var RateAfterDiscount = $("#Purchase_IO_Rate_After_Discount").dxNumberBox("instance").option("value");

        stockorderedqty = $("#Purchase_IO_OrderedQty").dxNumberBox("instance").option("value");

        if (stockorderedqty == null || stockorderedqty == 0) {
            DevExpress.ui.dialog.alert('Please enter Quantity in Item screen', 'Error..');
            return;
        }
        // var Discount = ((Qty * Rate) * Discount_percent) / 100;
        //var TaxAmt = (((Qty * Rate) -Discount) * Tax) / 100;

        $.ajax({
            type: 'GET',
            url: "/Stock/PurchaseRegister/CalculateTaxes",
            data: {
                Quantity: stockorderedqty,
                Rate: Rate,
                RateAfterDiscount: RateAfterDiscount
            },
            success: function (data) {
                $("#Purchase_IO_Taxes").dxNumberBox("instance").option("value", data.Amount);




            },

        });
        //    $("#Requisition_RequestedItem_Taxes").dxNumberBox("instance").option("value", (Qty * Rate) - Discount + Tax);
    }

    function CalculateRateAfterDiscount() {
        var Rate = $("#Purchase_IO_Rate").dxNumberBox("instance").option("value");
        var Discount_percent = $("#Purchase_IO_Discount").dxNumberBox("instance").option("value");
        var Amount = $("#Purchase_IO_Amount").dxNumberBox("instance").option("value");
        var OrderedQty = $("#Purchase_IO_OrderedQty").dxNumberBox("instance").option("value");


        if (Rate == null) {

            Rate = Amount / OrderedQty;
        }

        DiscountAmount = (Rate * Discount_percent) / 100;

        $("#Purchase_IO_Rate_After_Discount").dxNumberBox("instance").option("value", Rate - DiscountAmount);




    }

