    function CalculateAmount() {

        stockorderedqty = $("#Purchase_IO_OrderedQty").dxNumberBox("instance").option("value");
        IORate = $("#Purchase_IO_Rate").dxNumberBox("instance").option("value");
        IODiscount = $("#Purchase_IO_Discount").dxNumberBox("instance").option("value");
        IOTaxes = $("#Purchase_IO_Taxes").dxNumberBox("instance").option("value");
        var RateAfterDiscount = $("#Purchase_IO_Rate_After_Discount").dxNumberBox("instance").option("value");


        var Discount = ((stockorderedqty * IORate) * IODiscount) / 100;
      //  var TaxAmt = (((stockorderedqty * IORate) - Discount) * IOTaxes) / 100;
        $("#Purchase_IO_Amount").dxNumberBox("instance").option("value", (stockorderedqty * RateAfterDiscount) + IOTaxes);
    }

