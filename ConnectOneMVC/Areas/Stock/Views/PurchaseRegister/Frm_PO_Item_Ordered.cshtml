    function Get_StockItem_ChangeEvent(e) {
        recid = "@Model.ID";
        ItemID = e.value;
        subitem = ItemID;
        var dropdown = $("#Purchase_IO_ItemID").dxDropDownBox("instance");
        dropdown.close();
        var $dataGrid = $("#StockPurchaseItemDG");
        if ($dataGrid.length) {
            //StockPurchaseItemDG
            var dataGrid = $dataGrid.dxDataGrid("instance");
        }
        if (e.value == null && e.previousValue != null) {
            dataGrid.clearSelection();
            return;
        }
        if ("@Model.ActionMethod" == "New") {


            // dataGrid.selectRows(dropdown.option("value"), false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];

                IOname = item.Name;
                IOcode = item.Item_Code;
                IOhead = item.Head;
                IOtype = item.Item_Type;
                IOcat = item.Item_Category;
                IOunit = item.UnitID;

                $("#Purchase_IO_ItemName").val(IOname);
                $("#Purchase_IO_ItemType").dxTextBox("instance").option("value", IOtype);
                $("#Purchase_IO_Head").dxTextBox("instance").option("value", IOhead);
                $("#Purchase_IO_ItemCode").dxTextBox("instance").option("value", IOcode);
                $("#Purchase_IO_Item_Category").dxTextBox("instance").option("value", IOcat);
                $("#Purchase_IO_UnitID").dxDropDownBox("instance").option("value", IOunit);

            }

        }
        else {

            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                IOname = item.Name;
                IOcode = item.Item_Code;
                IOhead = item.Head;
                IOtype = item.Item_Type;
                IOcat = item.Item_Category;
                IOunit = item.UnitID;

                $.ajax({
                    type: 'GET',
                    url: "/Stock/PurchaseRegister/Check_Unsaved_Item_Entry_in_Received_Grid",
                    data: { ID_Item: recid },
                    cache: false,
                    success: function (res) {
                        if (res.result == true)// no added row exists in delivery
                        {
                            $("#Purchase_IO_ItemName").val(IOname);
                            $("#Purchase_IO_ItemType").dxTextBox("instance").option("value", IOtype);
                            $("#Purchase_IO_Head").dxTextBox("instance").option("value", IOhead);
                            $("#Purchase_IO_ItemCode").dxTextBox("instance").option("value", IOcode);
                            $("#Purchase_IO_Item_Category").dxTextBox("instance").option("value", IOcat);
                            $("#Purchase_IO_UnitID").dxDropDownBox("instance").option("value", IOunit);
                        }
                        else if (res.result == false) {
                            DevExpress.ui.dialog.alert(res.message, 'Alert');
                            $("#Purchase_IO_ItemType").dxTextBox("instance").reset();
                            $("#Purchase_IO_Head").dxTextBox("instance").reset();
                            $("#Purchase_IO_ItemCode").dxTextBox("instance").reset();
                            $("#Purchase_IO_Item_Category").dxTextBox("instance").reset();
                            $("#Purchase_IO_RequestedQty").dxNumberBox("instance").reset();
                            $("#Purchase_IO_UnitID").dxDropDownBox("instance").reset();



                        }

                    }
                });
            }
        }


    }






