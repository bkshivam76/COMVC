                        //resCountryCode = result.R_CO_CODE;
                        //resCountryId = result.R_CO_REC_ID;
                        //$("#Res_StateID").dxDropDownBox("instance").repaint();
                        //$("#Res_StateID").dxDropDownBox("instance").reset("",result.R_CO_CODE);
                        MainCategoryValue = "@Model.UO_CA_Item_Category";
                        //$("#Res_DisttID").dxDropDownBox("instance").repaint();
                        //$("#Res_cityID").dxDropDownBox("instance").repaint();
                    }
                })
            }
        }
    }*@
  


    async function LookUp_Supplier_ChangeEvent(e) {
        try {
            e.component.close();
            if (e.value == null && e.previousValue != null) {
                PO_PH_Supplier_DG.clearSelection();
                return;
            }
            if (PO_PH_Supplier_DG.getSelectedRowsData().length > 0) {
                var item = PO_PH_Supplier_DG.getSelectedRowsData()[0];
                SupplierID = item.ID;
                await PO_PH_Item_DG.refresh();

            }
        }
        catch (e) {
            console.log(e);
        }
    }

   


    async function Refresh_PO_PH_Item_DG() {
        try {
            var $PO_PH_Item_DG = $("#LookUp_PriceHistoryItems_datagrid");
            if ($PO_PH_Item_DG.length) {
                PO_PH_Item_DG = $PO_PH_Item_DG.dxDataGrid("instance");
                await PO_PH_Item_DG.refresh();
            }
        }
        catch (e) {
            console.log(e);
        }
    }
       async function Refresh_PO_PH_Supplier_DG() {
           try {
               var $PO_PH_Supplier_DG = $("#GetSupplierPriceHistoryDG");
               if ($PO_PH_Supplier_DG.length) {
                   PO_PH_Supplier_DG = $PO_PH_Supplier_DG.dxDataGrid("instance");
                   await PO_PH_Supplier_DG.refresh();
               }
           }
           catch (e) {
               console.log(e);
           }
        }

     

    function PurchasePriceHistorySuccessForm(data) {
     

        HideLoader();
        if (data.result == true || data.result == "true") {
            DevExpress.ui.dialog.alert(data.Message, "Inform");
            //var StackSubmitSuccess = DevExpress.ui.dialog.alert(data.Message, "Inform..");
            $("#popup_frm_price_history").dxPopup("hide");
            PriceHistoryListGrid.SetFocusedRowIndex(-1);
            PriceHistoryListGrid.Refresh();
        }
        else {

            DevExpress.ui.dialog.alert(data.Message, "Error");
        }
    }


    
    function closePriceHistory() {
        $.ajax({
            url: "/Stock/PurchaseRegister/POHistorySessionclear",
            type: "GET",
            cache: false
        });

        $("#popup_frm_price_history").dxPopup("hide");
   
    }
   
</script>
