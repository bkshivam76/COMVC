    function PO_datanavigation(_actionmethod) {
        if (!_actionmethod) { _actionmethod = null; }
        var msg;
        var result;
        var uosr_info;
        $.ajax({
            type: 'GET',
            async: false,
            url: "/Stock/PurchaseRegister/DataNavigation",
            data: {
                ActionMethod: _actionmethod,
                ID: PO_ID,
                PODate: PODate
            },
            cache: false,
            success: function (data) {
                msg = data.Message;
                result = data.result;
                if (data.UOSR != 0) {
                    uosr_info = data.UOSR;
                }
           
            }
        });

        return [msg, result, uosr_info];
    }
    function PO_StatusFlowCheck(Status) {
        var msg;
        var result;
        $.ajax({
            type: 'POST',
            url: "/Stock/PurchaseRegister/PurchaseOrderStatusFlow",
            data: {
                ID: PO_ID,
                StatusButton: Status,
                CurrUserRole: POCurrUserRole
            },
            async: false,
            cache: false,
            success: function (data) {
                msg = data.message;
                result = data.result;
            }
        });
        return [msg, result];
    }
</script>

<script>

    function UpDatePurchaseOrderStatus(Status_Button) {

        if (!PO_ID) {
            DevExpress.ui.dialog.alert("Please Select A Row...!", 'alert!');
            return;
        }

        var statusflowcheck = PO_StatusFlowCheck(Status_Button);
        if (statusflowcheck[1] == false) {
            DevExpress.ui.dialog.alert(statusflowcheck[0], "Error");
            return;
        }

        var Status_Msg = "";

        switch (Status_Button) {

            case "Complete":
                Status_Msg = "Do You Want To Mark selected Purchase Order As Completed ?";
                break;
            case "Cancel":
                Status_Msg = "Do You Want To Cancel the selected Purchase Order ?";
                break;
            case "Approve":
                Status_Msg = "Do You Want To Approve the Purchase Order?";
                break;
            case "Re_Requisition":
                Status_Msg = "Do You Want To Submit Purchase Order for Re-Requisition?";
                break;
            case "Reject":
                Status_Msg = "Do You Want To Reject the Purchase Order ?";
                break;
            case "Reopen":
                Status_Msg = "Do You Want To Re-open selected PO?";
                break;
            default:
                Status_Msg = "";
                break;
        }
        if (Status_Msg != "") {
            var result = DevExpress.ui.dialog.confirm(Status_Msg, "Confirm Changes");
            result.done(function (dialogResult) {
                if (dialogResult) {
                    if (Status_Button == "Complete" || Status_Button == "Reopen") {
                        $.ajax({
                            type: "POST",
                            url: "/Stock/PurchaseRegister/PO_StatusChange_Check",
                            data: {
                                ID: PO_ID,
                                StatusButton: Status_Button
                            },
                            success: function (data) {
                                if (data.result == true) {
                                    @*$("#Dynamic_Content_popup").dxPopup("instance").option("contentTemplate", "<div id='result_Dynamic_Content_popupPO'></div>");
                                    $("#Dynamic_Content_popup").dxPopup("show");
                                    $("#Dynamic_Content_popup").dxPopup("instance").option("title", "PO ~ " + Status_Button);
                                    $("#Dynamic_Content_popup").dxPopup("instance").option("width", "40%");
                                    $("#Dynamic_Content_popup").dxPopup("instance").option("height", "30%");
                                    ShowLoader();
                                    $("#result_Dynamic_Content_popupPO").load("@Url.Action("PO_StatusChange_Window", "PurchaseRegister", new { @area = "Stock" })?ID=" + PO_ID + "&StatusButton=" + Status_Button, function () {
                                        HideLoader();
                                    });*@
                                    HideLoader();

                                }
                                else {
                                    DevExpress.ui.dialog.alert(data.message, 'Error');
                                }
                            }
                        });
                    }

                    ShowLoader();
                    $.ajax({
                        type: "POST",
                        url: "/Stock/PurchaseRegister/PO_StatusChange",
                        data: {
                            ID: PO_ID,
                            StatusButton: Status_Button,
                            userRole: POCurrUserRole
                        },
                        success: function (data) {
                            if (data.result == true) {
                                HideLoader();
                                DevExpress.ui.dialog.alert(data.message, 'Inform!');
                                PurchaseRegisterGrid.Refresh();
                            }
                            else if (data.result == false) {
                                HideLoader();
                                DevExpress.ui.dialog.alert(data.message, 'Inform!');
                            }
                        }
                    });
                }

            });
        }
    }


    function PO_StatusChangeAjaxSuccessForm(data) {
        HideLoader();
        dontaskpopupcloseconfirmation = true;
        if (data.result == true) {
            DevExpress.ui.dialog.alert(data.message, 'Inform!');
            $("#Dynamic_Content_popup").dxPopup("hide");
            PurchaseRegisterGrid.Refresh();
        }
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.message, 'Inform!');
            $("#Dynamic_Content_popup").dxPopup("hide");
        }
    }

</script>