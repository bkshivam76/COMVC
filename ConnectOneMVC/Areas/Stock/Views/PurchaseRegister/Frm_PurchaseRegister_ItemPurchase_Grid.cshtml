@{ 
    var SessionGUID = Request.QueryString["SessionGUID"];
}
@Html.DevExpress().GridView(settings =>
{
    settings.Name = "PurchaseRegister" + Model[0].PO_ID;
    settings.SettingsDetail.MasterGridName = "PurchaseRegisterGrid";
    settings.CallbackRouteValues = new
    {
        Controller = "PurchaseRegister",
        Action = "Frm_PurchaseRegister_ItemPurchase_Grid",
        PO_ID = +Model[0].PO_ID,
        //FromDate = ViewData["FromDate"],
        //ToDate = ViewData["ToDate"],
        SessionGUID = SessionGUID
    };
    settings.Width = Unit.Percentage(100);
    settings.KeyFieldName = "ID";
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "PO_ID";
            column.Caption = "PO_ID";
            //column.Width = 200;
            //column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
        }
        {
            column.FieldName = "ItemName";
            column.Caption = "Item";
            //column.Width = 200;
            //column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Ordered_Qty";
            column.Caption = "Quantity Ordered";
            // column.Width = 100;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Received_Qty";
            column.Caption = "Quantity Received";
            // column.Width = 80;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Unit";
            column.Caption = "Unit";
            //column.Width = 110;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Rate";
            column.Caption = "Rate";
            // column.Width = 175;
            // column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Amount";
            column.Caption = "Amount";
            // column.Width = 175;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Item_Del_Status";
            column.Caption = "Item Delivery Status";
            // column.Width = 175;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Req_Del_Date";
            column.Caption = "Required Delivery Date";
            column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";  //mantis bug  1048
            // column.Width = 130;
            //  column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Added_On";
            column.Caption = "Add On";
            column.Visible = false;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Added_By";
            column.Caption = "Add By";
            column.Visible = false;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Edited_On";
            column.Caption = "Edit date";
            column.Visible = false;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Edited_By";
            column.Caption = "Edit By";
            column.Visible = false;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "SubitemID";
            column.Caption = "SubitemID";
            column.Visible = false;
        }
    });
    settings.KeyboardSupport = true;
    //settings.AccessKey = "G";
    settings.CustomDataActionRouteValues = new { Controller = "PurchaseRegister", Action = "ItemPurchaseCustomDataAction" };
    settings.ClientSideEvents.FocusedRowChanged = "OnItemPurchaseFocusedRowChange";
    settings.ClientSideEvents.Init = "OnItemPurchaseInit";
    settings.SettingsBehavior.AllowFocusedRow = true;
    settings.SettingsBehavior.AllowSelectByRowClick = true;
    settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
    //  settings.ClientSideEvents.RowDblClick = "OnEditButtonClick";
    settings.SettingsResizing.ColumnResizeMode = DevExpress.Web.ColumnResizeMode.Control;
    settings.SettingsResizing.Visualization = DevExpress.Web.ResizingMode.Live;
    settings.SettingsCustomizationDialog.ShowColumnChooserPage = true;
    settings.ClientSideEvents.BeginCallback = "ItemPurchaseGrid_BeginCallBack";
    settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
    settings.SettingsBehavior.ProcessColumnMoveOnClient = true;
    settings.SettingsBehavior.ColumnMoveMode = GridColumnMoveMode.AmongSiblings;
}).Bind(Model).GetHtml()

