@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
        .ID("StockPurchaseItemDG")       
        .Columns(columns =>
        {
            columns.Add().DataField("Name").Caption("Name").SortOrder(SortOrder.Asc);
            columns.Add().DataField("Item_Type").Caption("Item Type");
            columns.Add().DataField("Item_Code").Caption("Item Code");
            columns.Add().DataField("Item_Category").Caption("Item Category");
            columns.Add().DataField("Unit").Caption("Unit");
            columns.Add().DataField("Head").Caption("Head");
            columns.Add().DataField("ItemID").Caption("ID").Visible(false);
            columns.Add().DataField("UnitID").Caption("UnitID").Visible(false);

        })
 
        .Selection(s => s.Mode(SelectionMode.Single))

)
