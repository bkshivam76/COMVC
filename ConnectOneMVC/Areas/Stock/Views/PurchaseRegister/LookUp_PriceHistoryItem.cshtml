@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
        .ID("LookUp_PriceHistoryItems_datagrid")

        .Columns(columns =>
        {

            columns.Add().DataField("ItemName").Caption("Item Name").SortOrder(SortOrder.Asc);
            columns.Add().DataField("ItemType").Caption("Item Type");
            columns.Add().DataField("Item_Code").Caption("Item Code");
            columns.Add().DataField("ID").Caption("Item Id").Visible(false);

        })
         .Paging(paging => paging.PageSize(10))
        .Pager(pager =>
        {
            pager.ShowPageSizeSelector(true);
            pager.AllowedPageSizes(new[] { 5, 10, 20 });
            pager.ShowInfo(true);
        })
        .Selection(s => s.Mode(SelectionMode.Single))

)





