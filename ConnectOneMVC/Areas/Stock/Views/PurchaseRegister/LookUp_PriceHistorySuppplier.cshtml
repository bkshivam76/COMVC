@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                                    .ID("GetSupplierPriceHistoryDG")

                                    .Columns(columns =>
                                    {

                                        columns.Add().DataField("SuppName").Caption("Supplier Name");
                                        columns.Add().DataField("CompanyCode").Caption("Company Code");
                                        columns.Add().DataField("ContactNo").Caption("Contact No.");
                                        columns.Add().DataField("ID").Visible(false);

                                    })

                                    .Selection(s => s.Mode(SelectionMode.Single))

)





