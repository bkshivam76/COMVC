@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                .ID("PurchaseGREItemDG")
                .Columns(columns =>
                {
                    columns.Add().DataField("ItemName").Caption("Item Name");
                    columns.Add().DataField("ItemCode").Caption("Item Code");
                    columns.Add().DataField("Make").Caption("Make");
                    columns.Add().DataField("Model").Caption("Model");
                    columns.Add().DataField("ReceivedQty").Caption("Received Quantity");
                    columns.Add().DataField("ReceivedDate").Caption("Received Date").Visible(false);
                    columns.Add().DataField("PendingToReturn").Caption("Pending Quantity").Width(150);//mantis #822
                    columns.Add().DataField("LotNo").Caption("Lot No.");

                    columns.Add().DataField("ItemID").Caption("ItemID").Visible(false);
                    columns.Add().DataField("Unit").Caption("Unit").Visible(false);
                    columns.Add().DataField("BillNo").Caption("Bill No").Visible(false);
                    columns.Add().DataField("POI_Priority").Caption("Priority").Visible(false);
                    columns.Add().DataField("ChallanNo").Caption("Challan No.").Visible(false);//Mantis bug 936 fixed
                    columns.Add().DataField("CreatedStockID").Caption("CreatedStockID").Visible(false);//Mantis bug 1267 fixed


                    columns.Add().DataField("ID").Caption("ID").Visible(false);

                })

                .Selection(s => s.Mode(SelectionMode.Single))

)


