@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
            .ID("PurchaseGRItemDG")        
            .Columns(columns =>
            {
                columns.Add().DataField("ItemName").Caption("Item Name");
                columns.Add().DataField("ItemCode").Caption("Item Code");
                columns.Add().DataField("Make").Caption("Make");
                columns.Add().DataField("Model").Caption("Model");
                columns.Add().DataField("PendingQty").Caption("Pending Quantity");
                
                columns.Add().DataField("Unit").Caption("Default Unit").Visible(false);
                columns.Add().DataField("Head").Caption("Head").Visible(false);

                columns.Add().DataField("POI_Priority").Caption("Priority").Visible(false);

                columns.Add().DataField("Reqd_Del_Date").Caption("Reqd_Del_Date").Visible(true);
                columns.Add().DataField("ID").Caption("PO Item ID").Visible(false);


                columns.Add().DataField("ItemID").Caption("ItemID").Visible(false);
                columns.Add().DataField("UnitID").Caption("Unit ID").Visible(false);
                columns.Add().DataField("Stock_Project_ID").Caption("Stock_Project_ID").Visible(false);
                columns.Add().DataField("Rate").Caption("Item Rate").Visible(true);




            })
    
            .Selection(s => s.Mode(SelectionMode.Single))
         
)

