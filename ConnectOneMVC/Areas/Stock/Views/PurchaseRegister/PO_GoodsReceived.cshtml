@model ConnectOneMVC.Areas.Stock.Models.Model_NEVD_Purchase
@using DevExtreme.AspNet.Mvc;
@{
    bool IsVisible = Model != null && (Model.ActionMethod == "Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.ActionMethod == "View" || Model.ActionMethod == "Delete") ? true : false;
    

}
<div class="row">
    <div class="col-md-12">
        @Html.Action("PO_GoodsReceivedGridData", "PurchaseRegister", new { ActionMethodName = Model.ActionMethod, PO_ID = Model.PO_ID })
    </div>
</div>
<div class="row">
    <div class="form-field">
        <div class="container-fluid">
            <div class="col-md-12 btnsDiv">
                        @(Html.DevExtreme().Button().ID("purchaseBUT_GReNew").Text("New").Icon("fas fa-file btn-icons newfile icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_PO_GoodsRecd_New_Click() } </text>))
                        @(Html.DevExtreme().Button().ID("purchaseBUT_GReEdit").Text("Edit").Icon("fas fa-pencil-alt btn-icons editcolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_PO_GoodsRecd_Edit_Click() } </text>))
                        @(Html.DevExtreme().Button().ID("purchaseBUT_GReDelete").Text("Delete").Icon("fas fa-trash btn-icons deletecolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_PO_GoodsRecd_Delete_Click() } </text>))
                        @(Html.DevExtreme().Button().ID("purchaseBUT_GReView").Text("View").Icon("fas fa-eye btn-icons eyeicon icon-rgt-space5").Disabled(IsVisible).OnClick(@<text> function () { OnFrm_PO_GoodsRecd_View_Click() } </text>))
                        @(Html.DevExtreme().Button().ID("purchaseBUT_GReAllRec").Text("All Received").Icon("fas fa-trash btn-icons deletecolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_PO_GoodsRecd_AllRecd_Click() } </text>))
                        @(Html.DevExtreme().Button().ID("purchaseBUT_GRePrintRec").Text("Print Receipt").Icon("fas fa-eye btn-icons eyeicon icon-rgt-space5").Disabled(IsVisible).OnClick(@<text> function () { OnFrm_PO_GoodsRecd_PrintRec_Click() } </text>))
            </div>
        </div>
    </div>
</div>
<script>
    var goodsrecdsr;
    var goodsrecdid;
    function OnPurchaseGoodsReceivedGridFocusedRowChanged(s, e) {
        s.GetRowValues(s.GetFocusedRowIndex(), 'Sr;ID', PO_GoodsRecd_GridRowValues);
    }
    function PO_GoodsRecd_GridRowValues(values) {
        goodsrecdsr = values[0];
        goodsrecdid = values[1];
    }
    $("#PO_GoodsReceivedGrid").keydown(function (evt) {
        switch (evt.keyCode) {
            case 45: // insert key
                OnFrm_PO_GoodsRecd_New_Click();
                break;
            case 13: //enter key
                OnFrm_PO_GoodsRecd_Edit_Click();
                break;
            case 32: //space bar
                OnFrm_PO_GoodsRecd_View_Click();
                break;
            case 46://delete key
                OnFrm_PO_GoodsRecd_Delete_Click();
                break;
        }
        if (evt.ctrlKey && evt.keyCode == 73)//ctrl+i
        {
            OnFrm_PO_GoodsRecd_New_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 69)//ctrl+e
        {
            OnFrm_PO_GoodsRecd_Edit_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_PO_GoodsRecd_View_Click();
        }
    });
    function OnFrm_PO_GoodsRecd_New_Click() {
        if ("@IsDisabled" == "true") { return; }

        var menucheck = PO_StatusFlowCheck("POSTING DELIVERY RECEIVED");
        if (menucheck[1] == false) {
            DevExpress.ui.dialog.alert(menucheck[0], "Error");
            return;
        }
            ShowLoader();

        OpenPopup("Purchaseinnergrid", "New ~ Received Goods Detail", "@Url.Action("Frm_PO_Goods_Received", "PurchaseRegister", new {@area= "Stock" })?ActionMethod=New", "auto", 900, false, null);
    }// new click
    function OnFrm_PO_GoodsRecd_Edit_Click() {
        if ("@IsDisabled" == "true") { return; }
        if (goodsrecdsr == null || goodsrecdsr == undefined || goodsrecdsr == "undefined") {
                DevExpress.ui.dialog.alert("Please Select Row", "Error");
                return;
            }
        //var menucheck = PO_StatusFlowCheck("UPDATE-GOODS-RECEIVED");
        //if (menucheck[1] == false) {
        //    DevExpress.ui.dialog.alert(menucheck[0], "Error");
        //    return;
        //}
        var check = PO_Received_datanavigation("Edit");
        if (check[1] == false) {
            DevExpress.ui.dialog.alert(check[0], "Error");
            return;
        }
            ShowLoader();
    
                OpenPopup("Purchaseinnergrid", "Edit ~ Received Goods Detail", "@Url.Action("Frm_PO_Goods_Received", "PurchaseRegister", new {@area= "Stock" })?ActionMethod=Edit&SR=" + encodeURIComponent(goodsrecdsr), "auto", 900, false, null);
    }//edit click
    function OnFrm_PO_GoodsRecd_View_Click() {
        if (goodsrecdsr == null || goodsrecdsr == undefined || goodsrecdsr == "undefined") {
                DevExpress.ui.dialog.alert("Please Select Row", "Error");
                return;
        } 
                    ShowLoader();
 
                        OpenPopup("Purchaseinnergrid", "View ~ Received Goods Detail", "@Url.Action("Frm_PO_Goods_Received", "PurchaseRegister", new {@area= "Stock" })?ActionMethod=View&SR=" + encodeURIComponent(goodsrecdsr), "auto", 900, false, null);
        }//view click
    function OnFrm_PO_GoodsRecd_Delete_Click() {

        if ("@IsDisabled" == "true") {
            return;
        }
        if (goodsrecdsr == 'undefined' || goodsrecdsr == undefined || goodsrecdsr == null) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        var check = PO_Received_datanavigation("Delete");
        if (check[1] == false) {
            DevExpress.ui.dialog.alert(check[0], "Error");
            return;
        }
        var GR_result = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
        GR_result.done(function (dialogResult) {

            if (dialogResult) {
                $.ajax({
                    type: 'GET',
                    url: "/Stock/PurchaseRegister/Received_Item_Entry_in_Returned_Grid",
                    data: { recid: goodsrecdid },
                    cache: false,
                    success: function (res) {
                        if (res.result == true)// no added row exists in ret
                        {

                            $.ajax({
                                type: 'GET',
                                url: "/Stock/PurchaseRegister/Frm_PO_GoodsRecd_Window_Delete_Grid_Record",
                                data: { ActionMethod: "Delete", sr: goodsrecdsr, id: goodsrecdid },
                                cache: false,
                                success: function (data) {
                                    if (data.result == false) {
                                        DevExpress.ui.dialog.alert(data.message, "Error");
                                    }
                                    else if (data.result == true) {
                                        DevExpress.ui.dialog.alert("Record Deleted Successfully", "Inform..");
                                        PO_GoodsReceivedGrid.SetFocusedRowIndex(-1);
                                        PO_GoodsReceivedGrid.Refresh();
                                    }
                                }
                            });
                        }
                        else if (res.result == false) {
                            DevExpress.ui.dialog.alert(res.message, 'Alert');
                        }
                    }
                });
            }
        });
        //var total = ProductionStockConsumedGrid.GetVisibleRowsOnPage() + ProductionStockProducedGrid.GetVisibleRowsOnPage() + ProductionScrapCreatedGrid.GetVisibleRowsOnPage() + Actual_ManPower_Usage_Grid.GetVisibleRowsOnPage() + Machine_Usage_Window_Grid.GetVisibleRowsOnPage()-1;

        //if (total == 0) {
        //    $("#ProductionStoreID").dxDropDownBox("instance").option("readOnly", false);
        //}
    }

    function OnFrm_PO_GoodsRecd_AllRecd_Click()
    {
        DevExpress.ui.dialog.alert("Coming soon...!", 'Inform!');
    }


    function OnFrm_PO_GoodsRecd_PrintRec_Click()
    {
        DevExpress.ui.dialog.alert("Coming soon...!", 'Inform!');
    }

    //function PO_StatusFlowCheck(Status) {
    //    var msg;
    //    var result;
    //    $.ajax({
    //        type: 'POST',
    //        url: "/Stock/PurchaseRegister/PurchaseOrderStatusFlow",
    //        data: {
    //            ID: PO_ID,
    //            StatusButton: Status,
    //            CurrUserRole: POCurrUserRole
    //        },
    //        async: false,
    //        cache: false,
    //        success: function (data) {
    //            msg = data.message;
    //            result = data.result;
    //        }
    //    });
    //    return [msg, result];
    //}
    function PO_Received_datanavigation(_actionmethod) {
        if (!_actionmethod) { _actionmethod = null; }

        var msg;
        var result;
        $.ajax({
            type: 'GET',
            async: false,
            url: "/Stock/PurchaseRegister/DataNavigationReceived",
            data: {
                ActionMethod: _actionmethod,
                ID: goodsrecdid,
            },
            cache: false,
            success: function (data) {
                msg = data.message;
                result = data.result;
            }
        });

        return [msg, result];
    }
</script>



