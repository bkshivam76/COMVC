    function PO_ItemOrdered_datanavigation(_actionmethod) {
        if (!_actionmethod) { _actionmethod = null; }

        var msg;
        var result;
        $.ajax({
            type: 'GET',
            async: false,
            url: "/Stock/PurchaseRegister/DataNavigationItemOrdered",
            data: {
                ActionMethod: _actionmethod,
                ID: itemordid,
            },
            cache: false,
            success: function (data) {
                msg = data.message;
                result = data.result;
            }
        });

        return [msg, result];
    }
</script>
    
