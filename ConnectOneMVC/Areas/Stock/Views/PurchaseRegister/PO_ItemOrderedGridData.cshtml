        settings.SettingsExport.GetExportDetailGridViews = (s, e) => //bind nested grid
        {
            int PO_Item_ID = (int)DataBinder.Eval(e.DataItem, "ID");
            int MainSr = (int)DataBinder.Eval(e.DataItem, "Sr");

            if (PO_Item_ID == 0)
            {

                GridViewExtension griditemTax = new GridViewExtension(ConnectOneMVC.Areas.Stock.Controllers.PurchaseRegisterController.PurchaseRegisterItemTaxNestedGridSettings(MainSr));
                griditemTax.Bind(ConnectOneMVC.Areas.Stock.Controllers.PurchaseRegisterController.GetItemOrderedTax(MainSr));
                e.DetailGridViews.Add(griditemTax);
            }
            else
            {
                GridViewExtension griditemTax = new GridViewExtension(ConnectOneMVC.Areas.Stock.Controllers.PurchaseRegisterController.PurchaseRegisterItemTaxNestedGridSettings(PO_Item_ID));
                griditemTax.Bind(ConnectOneMVC.Areas.Stock.Controllers.PurchaseRegisterController.GetItemOrderedTax(PO_Item_ID));
                e.DetailGridViews.Add(griditemTax);
            }

        };

