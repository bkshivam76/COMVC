@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    int PO_Item_ID = (int)ViewData["PO_Item_ID"];
    int MainSr = (int)ViewData["MainSr"];
}
@Html.DevExpress().GridView(settings =>
{
    settings.Name = "POItemRequestedTax" + PO_Item_ID + MainSr;
    settings.SettingsDetail.MasterGridName = "PO_ItemOrderedGrid";
    settings.CallbackRouteValues = new
    {
        Controller = "PurchaseRegister",
        Action = "PO_ItemOrderedNestedGridData",
        PO_Item_ID = PO_Item_ID,
        MainSr = MainSr,
        SessionGUID = SessionGUID
    };
    settings.Width = Unit.Percentage(100);
    settings.KeyFieldName = "ID";
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Sr";
            column.Caption = "Sr. No.";
            column.Visible = false;
            //  column.Width = 175;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Tax_Type";
            column.Caption = "Tax Type";
            column.Width = 100;
            //column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "TaxPercent";
            column.Caption = "Tax Percent";
            column.Width = 100;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Tax_Amount";
            column.Caption = "Tax_Amount";
            column.Width = 100;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "TaxRemarks";
            column.Caption = "Tax Remarks";
            column.Width = 80;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "PO_Item_ID";
            column.Caption = "PO_Item_ID";
            column.Visible = false;
            //  column.Width = 130;
            //  column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Tax_TypeID";
            column.Caption = "Tax_TypeID";
            column.Visible = false;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "ID";
            column.Caption = "ID";
            // column.Width = 130;
            column.Visible = false;
        }
    });



    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "MainSr";
            column.Caption = "MainSr";
            column.Visible = false;
            //    column.Width = 175;
        }
    });
    //settings.CustomDataActionRouteValues = new { Controller = "ProductionRegister", Action = "ItemProduceCustomDataAction" };
    //settings.ClientSideEvents.FocusedRowChanged = "OnItemProduceFocusedRowChange";
    settings.SettingsBehavior.AllowFocusedRow = true;
    settings.SettingsBehavior.AllowSelectByRowClick = true;
    settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
    settings.SettingsResizing.ColumnResizeMode = DevExpress.Web.ColumnResizeMode.Control;
    settings.SettingsResizing.Visualization = DevExpress.Web.ResizingMode.Live;
    //  settings.ClientSideEvents.RowDblClick = "OnEditButtonClick";
    settings.SettingsCustomizationDialog.ShowColumnChooserPage = true;
    //settings.ClientSideEvents.BeginCallback = "ItemProduceGrid_BeginCallBack";

}).Bind(Model).GetHtml()

