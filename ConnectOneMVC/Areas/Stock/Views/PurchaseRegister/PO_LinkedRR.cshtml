@model ConnectOneMVC.Areas.Stock.Models.Model_NEVD_Purchase
@using DevExtreme.AspNet.Mvc;
@{
    bool IsVisible = Model != null && (Model.ActionMethod == "Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.ActionMethod == "View" || Model.ActionMethod == "Delete") ? true : false;

    bool PO_ViewRRRight = (bool)ViewData["PO_ViewRRRight"];
}
<div class="row">
    <div class="col-md-12">
        @Html.Action("PO_LinkedRRMainGridData", "PurchaseRegister", new { ActionMethodName = Model.ActionMethod, PO_ID = Model.PO_ID })
    </div>
</div>
<div class="row">
    <div class="form-field">
        <div class="container-fluid">
            <div class="col-md-12 btnsDiv">
                        @(Html.DevExtreme().Button().ID("purchaseBUT_RRRView").Text("View RR").Icon("fas fa-eye btn-icons eyeicon icon-rgt-space5").Disabled(IsVisible).OnClick(@<text> function () { OnFrm_PO_RR_View_Click(); } </text>))
                      
            </div>
        </div>
    </div>  
</div>
<script>
    debugger
    var rrsr;
    var rrid;
    function OnPurchaseLinkedRRMainGridFocusedRowChanged(s, e) {
        s.GetRowValues(s.GetFocusedRowIndex(), 'Sr;ID;', RR_GridRowValues);
    }
    function RR_GridRowValues(values) {
        rrsr = values[0];
        rrid = values[1];
    }
    $(document).ready(function ()
    {
        if ("@PO_ViewRRRight" == "False")
        {
            $("#purchaseBUT_RRRView").hide();
        }
    });
    $("#PO_LinkedRRMainGrid").keydown(function (evt) {
        switch (evt.keyCode) {

            case 32: //space bar
                OnFrm_PO_RR_View_Click();
                break;

        }

        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_PO_RR_View_Click();
        }
    });

    function OnFrm_PO_RR_View_Click() {
        if ("@PO_ViewRRRight" == "False")
        {
            DevExpress.ui.dialog.alert('Not Allowed', 'No Rights');
            return;
        }
        if (rrsr == null || rrsr == undefined || rrsr == "undefined")
        {
                DevExpress.ui.dialog.alert("Please Select Row", "Error");
                return;
        }

        ShowLoader();
        @*$("#result_Purchaseinnergrid").load("@Url.Action("Frm_PO_Payment", "PurchaseRegister", new {@area= "Stock" })?ActionMethod=View&SR=" + encodeURIComponent(paysr), function () {
                    HideLoader();
            });*@
        $.ajax({
            type: 'GET',
            url: "/Stock/RequestRegister/Frm_NEVD_Requisition",
            data: {
                ActionMethod: "View",
                PostSuccessFunction: "Frm_Purchase_RR_OnSuccess",
                //Post_action_Name: "Purchase_RR_Save",
                //Post_Controller_Name: "PurchaseRegister",
                //Post_Area_Name: "Stock",
               // RR_Grid_Data_SessionName: "Purchase_LinkRRMainData",
               // RR_Grid_SrNo: rrsr,
                ID: rrid,
                PopupName: "Purchaseinnergrid",
               // ByteSessionVariable: "PurchaseRR"
              
            },
            cache: false,
            success: function (data)
            {
                OpenPopup("Purchaseinnergrid", "View ~ Linked RR Detail",null, "auto", 1150, true, data);
               
            }
        });
        

    }//view click

   
    function Frm_Purchase_RR_OnSuccess(data) {

        HideLoader();
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.message, "Error");
        }
        else {

            $("#Purchaseinnergrid").dxPopup("hide");
            PO_LinkedRRMainGrid.SetFocusedRowIndex(-1);
            PO_LinkedRRMainGrid.Refresh();
            //$("#ProductionStoreID").dxDropDownBox("instance").option("readOnly", true);
        }
    }

</script>



