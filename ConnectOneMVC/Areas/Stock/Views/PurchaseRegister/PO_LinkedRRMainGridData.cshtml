@{
    var SessionGUID = Request.QueryString["SessionGUID"];
}
@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "PO_LinkedRRMainGrid";
        settings.CallbackRouteValues = new
        {
            Controller = "PurchaseRegister",
            Action = "PO_LinkedRRMainGridData",
            ActionMethodName = "View",
            SessionGUID = SessionGUID
        };
        settings.SettingsDetail.AllowOnlyOneMasterRowExpanded = false;// set false for simultaneous nested grid
        settings.SettingsDetail.ShowDetailRow = true; //set true for nested grid
        settings.Settings.VerticalScrollBarMode = ScrollBarMode.Visible;
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Visible;
        settings.Settings.VerticalScrollableHeight = 100;
        settings.KeyboardSupport = true;
        //settings.AccessKey = "G";
        settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
        settings.Settings.ShowGroupFooter = GridViewGroupFooterMode.VisibleAlways;
        settings.SettingsBehavior.AutoExpandAllGroups = true;
        settings.Settings.UseFixedTableLayout = true;
        settings.SettingsBehavior.ColumnMoveMode = GridColumnMoveMode.AmongSiblings;
        settings.SettingsBehavior.AllowSort = true;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.NextColumn;
        settings.SettingsResizing.Visualization = ResizingMode.Live;
        settings.SettingsBehavior.AllowEllipsisInText = true;
        settings.SettingsPager.Mode = GridViewPagerMode.ShowAllRecords;
        settings.SettingsSearchPanel.ShowApplyButton = true;
        settings.SettingsSearchPanel.ShowClearButton = true;
        settings.SettingsBehavior.AllowFocusedRow = true;
        settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
        settings.SettingsBehavior.AllowSelectByRowClick = true;
        settings.ClientSideEvents.FocusedRowChanged = "OnPurchaseLinkedRRMainGridFocusedRowChanged";
        settings.Settings.ShowHeaderFilterBlankItems = false;
        settings.SettingsContextMenu.Enabled = false;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;
        // settings.ClientSideEvents.RowDblClick = "OnFrm_PO_Linked_RR_Main_Edit_Click";

        settings.SettingsExport.GetExportDetailGridViews = (s, e) => //bind nested grid
        {
            int RRID = (int)DataBinder.Eval(e.DataItem, "ID");
            GridViewExtension griditemrr = new GridViewExtension(ConnectOneMVC.Areas.Stock.Controllers.PurchaseRegisterController.PurchaseRegisterRRNestedGridSettings(RRID));
            griditemrr.Bind(ConnectOneMVC.Areas.Stock.Controllers.PurchaseRegisterController.GetItemRR(RRID));
            e.DetailGridViews.Add(griditemrr);
        };
        settings.SetDetailRowTemplateContent(c =>
        {
            Html.RenderAction("PO_LinkedRRNestedGridData", new { RRID = DataBinder.Eval(c.DataItem, "ID") , PO_ID = ViewData["PO_ID"] });
        });
        settings.PreRender = (sender, e) =>
        {
            ASPxGridView grid = (ASPxGridView)sender;
            grid.FocusedRowIndex = -1;
        };

        settings.KeyFieldName = "ID";

        settings.Columns.Add(column =>
        {
            column.FieldName = "Sr";
            column.Caption = "Sr. No";
            column.Visible = true;
            // column.Width = 210;
        });
        settings.Columns.Add(column =>
        {
            column.FieldName = "RR_ID";
            column.Caption = "RRID";
            column.Visible = true;
            // column.Width = 210;
        });
        settings.Columns.Add(column =>
        {
            column.FieldName = "RR_Date";
            column.Caption = "RR Date";
            column.Visible = true;
            // column.Width = 210;
        });
        settings.Columns.Add(column =>
        {
            column.FieldName = "Requestor";
            column.Caption = "Requestor Name";
            column.Visible = true;
            // column.Width = 210;
        });
        settings.Columns.Add(column =>
        {
            column.FieldName = "Req_Dept";
            column.Caption = "Requestor Dept";
            column.Visible = true;
            // column.Width = 210;
        });
        settings.Columns.Add(column =>
        {
            column.FieldName = "Req_Sub_Dept";
            column.Caption = "Requestor Sub Dept";
            column.Visible = true;
            //column.Width = 210;
        });
        settings.Columns.Add(column =>
        {
            column.FieldName = "Project";
            column.Caption = "Project";
            column.Visible = true;
            // column.Width = 210;
        });
        settings.Columns.Add(column =>
        {
            column.FieldName = "Sanction_No";
            column.Caption = "Sanction No";
            column.Visible = true;
            // column.Width = 210;
        });
        settings.Columns.Add(column =>
        {
            column.FieldName = "Complex";
            column.Caption = "Complex";
            column.Visible = true;
            // column.Width = 210;
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Job";
                column.Caption = "Job";
                column.Visible = true;
                // column.Width = 210;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Job_No";
                column.Caption = "Job No";
                column.Visible = true;
            }
        });
        settings.Columns.Add(column =>
        {
            column.FieldName = "Job_Type";
            column.Caption = "Job Type";
            column.Visible = true;
            // column.Width = 210;
        });
        settings.Columns.Add(column =>
        {
            column.FieldName = "RR_Amt";
            column.Caption = "Req. Amount";
            column.Visible = true;
            // column.Width = 210;
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "RR_Status";
                column.Caption = "Status";
                column.Visible = true;
                // column.Width = 210;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "ID";
                column.Caption = "ID";
                column.Visible = false;
            }
        });

    }).Bind(Model).GetHtml()

