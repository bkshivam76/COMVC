@model ConnectOneMVC.Areas.Stock.Models.Model_NEVD_Purchase
@using DevExtreme.AspNet.Mvc;
@{
    bool IsVisible = Model != null && (Model.ActionMethod == "Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.ActionMethod == "View" || Model.ActionMethod == "Delete") ? true : false;

}
<div class="row">
    <div class="col-md-12">
        @Html.Action("PO_PaymentGridData", "PurchaseRegister", new { ActionMethodName = Model.ActionMethod, PO_ID = Model.PO_ID })
    </div>
</div>
<div class="row">
    <div class="form-field">
        <div class="container-fluid">
            <div class="col-md-12 btnsDiv">
                        @(Html.DevExtreme().Button().ID("purchaseBUT_PayNew").Text("New").Icon("fas fa-file btn-icons newfile icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_PO_Payment_New_Click() } </text>))
                        @(Html.DevExtreme().Button().ID("purchaseBUT_PayDelete").Text("Delete").Icon("fas fa-trash btn-icons deletecolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_PO_Payment_Delete_Click() } </text>))
                        @(Html.DevExtreme().Button().ID("purchaseBUT_PayViewSL").Text("View Supplier Ledger").Icon("fas fa-eye btn-icons eyeicon icon-rgt-space5").Disabled(IsVisible).OnClick(@<text> function () { OnFrm_PO_Payment_ViewSL_Click() } </text>))
            </div>
        </div>
    </div>
</div>
<script>
    var paysr;
    var payid;
    function OnPurchasePaymentGridFocusedRowChanged(s, e) {
        s.GetRowValues(s.GetFocusedRowIndex(), 'Sr;ID', Payment_GridRowValues);
    }
    function Payment_GridRowValues(values) {
        paysr = values[0];
        payid = values[1];
    }
    $("#PO_PaymentGrid").keydown(function (evt) {
        switch (evt.keyCode) {
            case 45: // insert key
                OnFrm_PO_Payment_New_Click();
                break;

            case 32: //space bar
                OnFrm_PO_Payment_ViewSL_Click();
                break;
            case 46://delete key
                OnFrm_PO_Payment_Delete_Click();
                break;
        }
        if (evt.ctrlKey && evt.keyCode == 73)//ctrl+i
        {
            OnFrm_PO_Payment_New_Click();
        }
        //if (evt.ctrlKey && evt.keyCode == 69)//ctrl+e
        //{
        //    OnFrm_PO_Payment_Edit_Click();
        //}
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_PO_Payment_View_Click();
        }
    });
