    function OnFrm_PO_Payment_Delete_Click() {

        if ("@IsDisabled" == "true") {
            return;
        }
        if (paysr == 'undefined' || paysr == undefined || paysr == null) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        var pay_result = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
        pay_result.done(function (dialogResult) {

            if (dialogResult) {
                $.ajax({
                    type: 'GET',
                    url: "/Stock/PurchaseRegister/PaymentDelete",
                    data: { ActionMethod: "Delete", sr: paysr, id: payid },
                    cache: false,
                    success: function (result) {

                        PO_PaymentGrid.SetFocusedRowIndex(-1);
                        PO_PaymentGrid.Refresh();
                      }
                });
            }
        });
