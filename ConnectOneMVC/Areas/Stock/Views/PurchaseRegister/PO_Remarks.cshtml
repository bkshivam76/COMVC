@model ConnectOneMVC.Areas.Stock.Models.Model_NEVD_Purchase
@using DevExtreme.AspNet.Mvc;
@{
    bool IsVisible = (Model != null && Model.ActionMethod == "Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.ActionMethod == "View" || Model.ActionMethod == "Delete") ? true : false;
}
<div class="row">
    <div class="col-md-12">
        @Html.Action("POExistingRemarksGridData", "PurchaseRegister", new { ActionMethodName = Model.ActionMethod, PO_ID = Model.PO_ID })
    </div>

</div>
<div class="row">
    <div class="form-field">
        <div class="container-fluid">
            <div class="col-md-12 btnsDiv">
                    @(Html.DevExtreme().Button().ID("PO_BUT_ExistingRemDelete").Text("Delete").Icon("fas fa-trash btn-icons deletecolor icon-rgt-space5").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_PO_Existing_Remarks_Delete_Click() } </text>))
                    @(Html.DevExtreme().Button().ID("PO_BUT_ExistingRemView").Text("View").Icon("fas fa-eye btn-icons eyeicon icon-rgt-space5").Disabled(IsVisible).OnClick(@<text> function () { OnFrm_PO_Existing_Remarks_View_Click() } </text>))
            </div>
        </div>
    </div>
</div>
<script>
        var POremarkssr;
    var POExistingRemarks_Id;
    var PORemarks = "";
    function OnExistingPORemarksGridFocusedRowChanged(s, e) {
        s.GetRowValues(s.GetFocusedRowIndex(), 'Sr_No;ID;Remarks', OnRemarksPODetailsGridRowValues);
    };
    function OnRemarksPODetailsGridRowValues(values) {
        POremarkssr = values[0];
        POExistingRemarks_Id = values[1];
        PORemarks = values[2];
    };
    $("#POExistingRemarks_Window_Grid").keydown(function (evt) {
        switch (evt.keyCode) {

            case 32: //space bar
                OnFrm_PO_Existing_Remarks_View_Click();
                break;
            case 46://delete key
                OnFrm_PO_Existing_Remarks_Delete_Click();
                break;
        }
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_PO_Existing_Remarks_View_Click();
        }
    });
    function OnFrm_PO_Existing_Remarks_Delete_Click() { if ("@IsDisabled"=="true") { return; }
        if (!POremarkssr){
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        var deleteResultPaymentDetail = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
        deleteResultPaymentDetail.done(function (dialogResult) {

            if (dialogResult) {
                $.ajax({
                    type: 'GET',
                    url: "/Stock/PurchaseRegister/Frm_ExistingRemarks_Window_Delete_Grid_Record",
                    data: { ActionMethod: "Delete", ID: POExistingRemarks_Id },
                    cache: false,
                    success: function (Result) {
                        if (Result.result == true) {
                            POExistingRemarks_Window_Grid.Refresh();
                            POExistingRemarks_Window_Grid.SetFocusedRowIndex(-1);
                        }
                        else {
                            DevExpress.ui.dialog.alert(Result.message, "Error");
                        }
                    }
                });
            }
        });
    }
    function OnFrm_PO_Existing_Remarks_View_Click() {
        if (!POremarkssr) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        else {
    
            ShowLoader();
 
            OpenPopup("Purchaseinnergrid", "View Remarks", "@Url.Action("PO_Frm_ViewRemarks", "PurchaseRegister", new {@area= "Stock" })?SR=" + encodeURIComponent(POremarkssr), "auto", 900, false, null);
        }
    }//view click
</script>
