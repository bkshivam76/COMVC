@using DevExtreme.AspNet.Mvc;
@model ConnectOneMVC.Areas.Stock.Models.RequestRegister_Period
<style>
    .dx-button-has-icon .dx-button-content {
        padding-right: 8px !important;
    }

    .dx-toolbar-after .dx-button-content {
        padding-right: 0px !important;
    }
</style>
@{
    /**/

    Html.EnableClientValidation();
    Html.EnableUnobtrusiveJavaScript();
    Html.AntiForgeryToken();
}
<link href="/content/fontawesome/css/fontawesome-all.css" rel="stylesheet">
<div>
    @using (Ajax.BeginForm("Frm_Change_Period_Screen_RR", "RequestRegister",
           new AjaxOptions
           {
               HttpMethod = "POST",
               UpdateTargetId = "Frm_Change_Period_Screen_RR",
               InsertionMode = InsertionMode.InsertAfter,
               OnBegin = "AjaxBeginFormPost",
               OnSuccess = "Frm_Change_Period_Screen_RR_Success"
           },
            new
            {
                id = "id_Frm_Change_Period_Screen_RR",
                @class = "edit_form"
            }))
    {
        using (Html.DevExtreme().ValidationGroup())
        {
            <div class="row">
                <div class="form-field" style="padding-bottom:7px;">
                    <div class="container-fluid mb_height27">
                        <div class="row">
                            <div class="col-sm-3 col-md-3 col-lg-3 pll"><label class="control-label  text-red" for="Name">From:</label></div>
                            <div class="col-sm-9 col-md-9 col-lg-9 prm">
                                <div class="dx-texteditor dx-widget dx-textbox">
                                    <div class="dx-texteditor-container">
                                        @(Html.DevExtreme().DateBox().CustomDateBox().ID("RR_Fromdate").Name("RR_Fromdate").Min(Model.RR_Opendate).Max(Model.RR_Closedate).Value(Model.RR_Fromdate))
                        </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="form-field" style="padding-bottom:7px;">
                    <div class="container-fluid mb_height27">
                        <div class="row">
                            <div class="col-sm-3 col-md-3 col-lg-3 pll"><label class="control-label  text-red" for="Name">To:</label></div>
                            <div class="col-sm-9 col-md-9 col-lg-9 prm">
                                <div class="dx-texteditor dx-widget dx-textbox">
                                    <div class="dx-texteditor-container">
                                        @(Html.DevExtreme().DateBox().CustomDateBox().ID("RR_Todate").Name("RR_Todate").Min(Model.RR_Opendate).Max(Model.RR_Closedate).Value(Model.RR_Todate))
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div><!--[row]-->
            <div class="row">
                <div class="form-field wbg brd-bot-none">
                    <div class="col-lg-6 "></div>
                    <div class="col-lg-6 styleActionBtn">
                        @(Html.DevExtreme().Button().ID("RequestChangePeriodOK").CustomSaveButton().Text("Ok").FocusStateEnabled(true).TabIndex(6).UseSubmitBehavior(true) )
                        @(Html.DevExtreme().Button().ID("RequestChangePeriodCancel").CustomCloseButton().Text("Cancel").FocusStateEnabled(true).TabIndex(7).OnClick(@<text> function () { $("#Dynamic_Content_popup").dxPopup("hide"); } </text>) )
                    </div>
                </div>
            </div><!--[button]-->
        }
    }
</div>
<script>

    function Frm_Change_Period_Screen_RR_Success(data) {
        HideLoader();
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.Message, 'Error!!');
        }
        else {

            var FromDate = $("#RR_Fromdate").dxDateBox("instance").option("value");
            var ToDate = $("#RR_Todate").dxDateBox("instance").option("value");
            var tomonth = ToDate.getMonth() + 1;
            var frommonth = FromDate.getMonth() + 1;
            var Fromdatefordisplay = FromDate.getDate() + "-" + frommonth + "-" + FromDate.getFullYear();
            var Todatefordisplay = ToDate.getDate() + "-" + tomonth + "-" + ToDate.getFullYear();
            FromDate = frommonth + "-" + FromDate.getDate() + "-" + FromDate.getFullYear();
            ToDate = tomonth + "-" + ToDate.getDate() + "-" + ToDate.getFullYear();
            $("#Request_View_Period").dxTextBox("instance").option("value", "Fr:" + Fromdatefordisplay + " " + "To:" + Todatefordisplay);
            RequestRegisterListGrid.Refresh();
            $("#Dynamic_Content_popup").dxPopup("hide");
        }
    }
    $(document).ready(function ()
    {
        setTimeout(function ()
        {
            $("#RR_Fromdate").dxDateBox("instance").focus();
        }, Timeout100)
    });
</script>