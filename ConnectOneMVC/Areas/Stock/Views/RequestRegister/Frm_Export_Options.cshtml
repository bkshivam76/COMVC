@using DevExtreme.AspNet.Mvc
<div>
    @(Html.DevExtreme().Button()
                                                .ID("RR_ExportGridDatapdf")
                                                .Text("Export to PDF")
                                                .OnClick("ExportPDF")
                                                .Visible(true)
                                                .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                                                .ID("RR_ExportGridDataxls")
                                                .Text("Export to XLS")
                                                .OnClick("ExportXLS")
                                                .Visible(true)
                                                .Width(120)
    )<br />
    @(Html.DevExtreme().Button()
                                                .ID("RR_ExportGridDataxlsx")
                                                .Text("Export to XLSX")
                                                .OnClick("ExportXLSX")
                                                .Visible(true)
                                                .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                                                .ID("RR_ExportGridDatadocx")
                                                .Text("Export to DOCX")
                                                .OnClick("ExportDOCX")
                                                .Visible(true)
                                                .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                                                .ID("RR_ExportGridDatartf")
                                                .Text("Export to RTF")
                                                .OnClick("ExportRTF")
                                                .Visible(true)
                                                .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                                                .ID("RR_ExportGridDatacsv")
                                                .Text("Export to CSV")
                                                .OnClick("ExportCSV")
                                                .Visible(true)
                                                .Width(120)
    )
</div>
<script>
    function ExportPDF() {
        RequestRegisterListGrid.ExportTo(ASPxClientGridViewExportFormat.Pdf);
        $("#RequestRegister_report_modal").dxPopup("hide");
    }
    function ExportXLS() {
        RequestRegisterListGrid.ExportTo(ASPxClientGridViewExportFormat.Xls);
        $("#RequestRegister_report_modal").dxPopup("hide");
    }
    function ExportXLSX() {
        RequestRegisterListGrid.ExportTo(ASPxClientGridViewExportFormat.Xlsx);
        $("#RequestRegister_report_modal").dxPopup("hide");
    }
    function ExportCSV() {
        RequestRegisterListGrid.ExportTo(ASPxClientGridViewExportFormat.Csv);
        $("#RequestRegister_report_modal").dxPopup("hide");
    }
    function ExportDOCX() {
        RequestRegisterListGrid.ExportTo(ASPxClientGridViewExportFormat.Docx);
        $("#RequestRegister_report_modal").dxPopup("hide");
    }
    function ExportRTF() {
        RequestRegisterListGrid.ExportTo(ASPxClientGridViewExportFormat.Rtf);
        $("#RequestRegister_report_modal").dxPopup("hide");
    }
</script>

