@{ 
    var SessionGUID = Request.QueryString["SessionGUID"];
}
@Html.DevExpress().GridView(settings =>
{
    settings.Name = "RequestRegister" + ViewData["RequestID"];
    settings.SettingsDetail.MasterGridName = "RequestRegisterListGrid";
    settings.CallbackRouteValues = new
    {
        Controller = "RequestRegister",
        Action = "Frm_RequestRegister_ItemRequest_Grid",
        RequestID = ViewData["RequestID"],
       FromDate = ViewData["FromDate"],
        ToDate = ViewData["ToDate"],
        SessionGUID = SessionGUID
    };
    settings.Width = Unit.Percentage(100);
    settings.KeyFieldName = "ID";
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Item_Name";
            column.Caption = "Item Name";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Destination_Location";
            column.Caption = "Destination Location";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Requested_Quantity";
            column.Caption = "Requested Quantity";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Approved_Quantity";
            column.Caption = "Approved Quantity";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Unit";
            column.Caption = "Unit";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Rate";
            column.Caption = "Rate";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Discount_Promised";
            column.Caption = "Discount Promised";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Amount";
            column.Caption = "Amount";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Supplier_Dept";
            column.Caption = "Supplier / dept";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "RR_Priority";
            column.Caption = "Priority";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Req_Delivery_Date";
            column.Caption = "Required Delivery Date";
            column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
        }
    });
    settings.Columns.Add(new MVCxGridViewColumn()
    {
        FieldName = "Added_On",
        Caption = " Add On",
        Visible = false
    });
    settings.Columns.Add(new MVCxGridViewColumn()
    {
        FieldName = "Added_By",
        Caption = "Add By",
        Visible = false
    });
    settings.Columns.Add(new MVCxGridViewColumn()
    {
        FieldName = "Edited_By",
        Caption = "Edit By",
        Visible = false
    });
    settings.Columns.Add(new MVCxGridViewColumn()
    {
        FieldName = "Edited_On",
        Caption = "Edit date",
        Visible = false
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "ID";
            column.Caption = "RequestedItemID";
            column.Visible = false;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "RR_ID";
            column.Caption = "RR ID";
            column.Visible = false;
        }
    });

    settings.CustomDataActionRouteValues = new { Controller = "RequestRegister", Action = "ItemRequestCustomDataAction" };
    settings.ClientSideEvents.FocusedRowChanged = "OnItemRequestFocusedRowChange";
    settings.SettingsBehavior.AllowFocusedRow = true;
    settings.SettingsBehavior.AllowSelectByRowClick = true;
    settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
    //  settings.ClientSideEvents.RowDblClick = "OnEditButtonClick";
    settings.SettingsCustomizationDialog.ShowColumnChooserPage = true;
    settings.ClientSideEvents.BeginCallback = "ItemRequestGrid_BeginCallBack";
    settings.ClientSideEvents.Init = "ItemRequestGrid_Init";

    var ShowHorizontalBar = (int)ViewBag.RRItemGrid_ShowHorizontalBar;
    settings.SettingsCookies.Enabled = true;
    if (ShowHorizontalBar == 1)
    {
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Visible;
        settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.Off;
        settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.Control;
        settings.SettingsResizing.Visualization = ResizingMode.Postponed;
    }
    else
    {
        settings.SettingsAdaptivity.AdaptivityMode = GridViewAdaptivityMode.HideDataCells;
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Hidden;
        settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.Disabled;
        //settings.SettingsAdaptivity.HideDataCellsAtWindowInnerWidth = 500;
    }

}).Bind(Model).GetHtml()
