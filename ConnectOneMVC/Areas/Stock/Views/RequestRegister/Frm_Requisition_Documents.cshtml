        padding-left: 19px;
    }*/

    #file-uploader {
        margin: -16px;
        margin-top: -1px;
    }

    .dx-fileuploader-input-wrapper {
        margin-top: -19px;
        margin-left: -3px;
        /* padding: 7px 0 7px; */
        border: 3px dashed transparent;
    }

    #Frm_Documents_Popup {
        padding-right: 0px !important;
        padding-left: 0px !important;
