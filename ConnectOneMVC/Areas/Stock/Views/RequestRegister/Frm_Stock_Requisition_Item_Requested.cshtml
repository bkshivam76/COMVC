    function CalculateTaxes() {
        var Rate = $("#Requisition_RequestedItem_Rate").dxNumberBox("instance").option("value");
        var RateAfterDiscount = $("#Requisition_RequestedItem_Rate_After_Discount").dxNumberBox("instance").option("value");
        var ApprovedQty = $("#Requisition_RequestedItem_Approved_Qty").dxNumberBox("instance").option("value");
        var RequestedQty = $("#Requisition_RequestedItem_Requested_Qty").dxNumberBox("instance").option("value");
     //   var Tax = $("#Requisition_RequestedItem_Taxes").dxNumberBox("instance").option("value");
        var Qty = RequestedQty;
        if (ApprovedQty > 0)
        { Qty = ApprovedQty; }

        if (Qty == null || Qty == 0) {
            DevExpress.ui.dialog.alert('Please enter Quantity in Item screen', 'Error..');
            return;
        }
       // var Discount = ((Qty * Rate) * Discount_percent) / 100;
        //var TaxAmt = (((Qty * Rate) -Discount) * Tax) / 100;

        $.ajax({
            type: 'GET',
            url: "/Stock/RequestRegister/CalculateTaxes",
            data: {
                Quantity: Qty,
                Rate: Rate,
                RateAfterDiscount: RateAfterDiscount
            },
            success: function (data) {
                $("#Requisition_RequestedItem_Taxes").dxNumberBox("instance").option("value", data.Amount);
                var taxper =  data.TaxPercent;
                $("#Requisition_RequestedItem_Tax_Percent").val(taxper);



            },

        });
    //    $("#Requisition_RequestedItem_Taxes").dxNumberBox("instance").option("value", (Qty * Rate) - Discount + Tax);
    }
    function CalculateAmount()
    {
        var Rate = $("#Requisition_RequestedItem_Rate").dxNumberBox("instance").option("value");
        var RateAfterDiscount = $("#Requisition_RequestedItem_Rate_After_Discount").dxNumberBox("instance").option("value");
        var ApprovedQty = $("#Requisition_RequestedItem_Approved_Qty").dxNumberBox("instance").option("value");
        var RequestedQty = $("#Requisition_RequestedItem_Requested_Qty").dxNumberBox("instance").option("value");
        var Discount_percent = $("#Requisition_RequestedItem_Discount").dxNumberBox("instance").option("value");
        var Tax = $("#Requisition_RequestedItem_Taxes").dxNumberBox("instance").option("value");
        var Qty = RequestedQty;
        if (ApprovedQty > 0) { Qty = ApprovedQty; }
      //  var Discount = ((Qty * Rate) * Discount_percent) / 100;
        //var TaxAmt = (((Qty * Rate) -Discount) * Tax) / 100;

     
            $("#Requisition_RequestedItem_Amount").dxNumberBox("instance").option("value", (Qty * RateAfterDiscount) + Tax);
       

      
       
    }

    function CalculateRateAfterDiscount()
    {
        var Rate = $("#Requisition_RequestedItem_Rate").dxNumberBox("instance").option("value");
        var Discount_percent = $("#Requisition_RequestedItem_Discount").dxNumberBox("instance").option("value");
        var Amount = $("#Requisition_RequestedItem_Amount").dxNumberBox("instance").option("value");
        var ApprovedQty = $("#Requisition_RequestedItem_Approved_Qty").dxNumberBox("instance").option("value");
        var RequestedQty = $("#Requisition_RequestedItem_Requested_Qty").dxNumberBox("instance").option("value");
        var Qty = RequestedQty;
        if (ApprovedQty > 0) { Qty = ApprovedQty; }

        if (Rate == null) {

            Rate = Amount / Qty;
        }
     
        DiscountAmount = (Rate * Discount_percent)/100;
     
        $("#Requisition_RequestedItem_Rate_After_Discount").dxNumberBox("instance").option("value", Rate - DiscountAmount);
       

      
       
    }
