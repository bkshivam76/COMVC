        if ("@Supplier_AddRight" == "False")
        {
	        $("#RR_SupplierMasterNew").hide();
        }
        var form = "ID_Frm_Stock_Requisition_Item_Requested_Window";
        ShowLoader();
        AssignIDtoLabel(form, "RR_ItemReq");
        var ReqType = $("#RequisitionType").dxSelectBox('instance').option('value');
        RR_Item_DD();
        RR_Delivery_DD();
        if (ReqType == "Purchase Request")
        {
            RR_Supplier_DD();
        }
        if (ItemRequested_Sr == null || ItemRequested_Sr == undefined || ItemRequested_Sr == "undefined")
        {
            _StoreID_UO_DeptID = ReqStoreDeptid;
        }
        else
        {
            _StoreID_UO_DeptID = ReqStoreDeptid + ',' + $("#UODeptID").val() + ',' + $("#UOSubDeptID").val();
        }
        $("#Requisition_RequestedItem_Item_ID").dxDropDownBox("instance").focus();  
              
        if (ReqType == "Transfer Request")
        {
            document.getElementById("RR_Supplier_Row").style.display = "none";
            $("#Requisition_RequestedItem_Supplier_ID").dxDropDownBox("instance").option("disabled", true);
        }

        if ("@IsApprover"=="True")
        {
            $("#Requisition_RequestedItem_Approved_Qty").dxNumberBox("instance").option("readOnly", false);
            $("#lblApprovedQty").removeClass("disabletxt");
        }
        else
        {
            $("#Requisition_RequestedItem_Approved_Qty").dxNumberBox("instance").option("readOnly", true);
            $("#lblApprovedQty").addClass("disabletxt");
        }
        if ("@Model.ActionMethod" == "_Edit" || "@Model.ActionMethod" == "_View" || "@Model.ActionMethod" == "_Delete")
        {
            RR_Item_DG.selectRows("@Model.Requisition_RequestedItem_Item_ID", false);
            RR_Delivery_DG.selectRows("@Model.Requisition_RequestedItem_Delivery_Location_ID", false);
            if (ReqType == "Purchase Request")
            {
                RR_Supplier_DG.selectRows("@Model.Requisition_RequestedItem_Supplier_ID",false);
            }
        }
            setTimeout(function ()
    {
        Set_Form_View_Delete_Mode(null, form, "@Model.ActionMethod");
        Focus_FirstEditable_Field(form, "@Model.ActionMethod");
        HideLoader();
            }, Timeout500);
    });

</script>