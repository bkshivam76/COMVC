<script>
    var OpenFromRR;
 
    function RR_Add_Supplier_Click()
    {
        if ("@IsVisible" == "True") { return;}
        if ("@Supplier_AddRight"=="False")
        {
            DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights")
            return;
        } 
        OpenFromRR = true;
        ShowLoader();
        $.ajax({
            type: "GET",
            url: "/Stock/SupplierMaster/Frm_SupplierMaster_Window",
            data: {
                ActionMethod: "New",
                ID: 0,
                PostSucessFunction: "RRAddSupplierSuccess",
                PopupName: "RequestRegister_Button_popup"
            },
            success: function (data)
            {
                OpenPopup("RequestRegister_Button_popup", "New ~ Supplier", null, "auto", "1000", true, data);             
            }
        });   
    }
    function RRAddSupplierSuccess(data)
    {
        HideLoader();
        if (data.result == true)
        {
            $("#RequestRegister_Button_popup").dxPopup("hide");
            $("#LookUp_Requisition_SupplierRequestedItem_Item_datagrid").dxDataGrid("instance").refresh();
        }
        else
        {
            DevExpress.ui.dialog.alert(data.Message, "Error");
        }
    }
    function AddTax_Click()
    {
    
        if ("@IsVisible" == "True") { return; }
        var itemID = $("#Requisition_RequestedItem_Item_ID").dxDropDownBox("instance").option("value");
        if (itemID == null || itemID.length == 0)
        {
            DevExpress.ui.dialog.alert('Select An Item..', 'Error..');         
            return;
        }
        var Qty = $("#Requisition_RequestedItem_Requested_Qty").dxNumberBox("instance").option("value");
        if (Qty == null || Qty == 0) {
            DevExpress.ui.dialog.alert('Select Req. Qty..', 'Error..');
            return;
        }
        var Rate = $("#Requisition_RequestedItem_Rate").dxNumberBox("instance").option("value");

        var Rate_After_Discount = $("#Requisition_RequestedItem_Rate_After_Discount").dxNumberBox("instance").option("value");
        //if (Rate == null || Rate == 0) {
        //    DevExpress.ui.dialog.alert('Select Rate..', 'Error..');
        //    return;
        //}
        ShowLoader();
      
        OpenPopup("RequestRegister_Button_popup", "Add Taxes", "@Url.Action("Frm_Requisition_Request_Add_Taxes", "RequestRegister", new {@area= "Stock" })?ActionMethod=_NewAddTax", "auto", 1024, false, null);                       
      
    }
    function ManageTaxClick()
    {
     
        if ("@IsVisible" == "True") { return; }
        var itemID = $("#Requisition_RequestedItem_Item_ID").dxDropDownBox("instance").option("value");
        if (itemID == null || itemID.length == 0)
        {
