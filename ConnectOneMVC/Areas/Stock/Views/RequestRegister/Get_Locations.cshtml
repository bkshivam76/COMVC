@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                    .ID("LookUp_Requisition_LocationRequestedItem_Item_datagrid")
                
                    .Columns(columns =>
                    {
                        columns.Add().DataField("Location_Name").Caption("Location");
                        columns.Add().DataField("Matched_Name").Caption("Place");
                        columns.Add().DataField("Matched_Type").Caption("Type");
                        columns.Add().DataField("Matched_Instt").Caption("Instt");
                        columns.Add().DataField("Loc_Id").Caption("Loc_Id").Visible(false);
                    })
               
                    .Selection(s => s.Mode(SelectionMode.Single))
            
)
