@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
            .ID("LookUp_GetRequestorStoreDeptRequisition_datagrid")

            .Columns(columns =>
            {
                columns.Add().DataField("Name").Caption("Name");
                columns.Add().DataField("Center").Caption("Center").Visible(false);
                columns.Add().DataField("InCharge_Name").Caption("Incharge");
                columns.Add().DataField("MAIN_DEPT_ID").Caption("MAIN_DEPT_ID").Visible(false);
                columns.Add().DataField("MAIN_DEPT_Name").Caption("MAIN_DEPT_Name");
                columns.Add().DataField("ID").Caption("StoreID").Visible(false);
            })

            .Selection(s => s.Mode(SelectionMode.Single))

)




