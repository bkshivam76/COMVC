@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("LookUp_Requisition_SupplierRequestedItem_Item_datagrid")
       
                .Columns(columns =>
                {
                    columns.Add().DataField("Supplier").Caption("Supplier");
                    columns.Add().DataField("CompanyCode").Caption("Code");
                    columns.Add().DataField("Contact_No").Caption("Contact_No");
                    columns.Add().DataField("ID").Caption("ID").Visible(false);
                })
              
                .Selection(s => s.Mode(SelectionMode.Single))
          
)
