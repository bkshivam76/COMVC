@model ConnectOneMVC.Areas.Stock.Models.Model_NEVD_Requisition
@using DevExtreme.AspNet.Mvc;
@{
    bool IsVisible = Model != null && (Model.ActionMethod == (Common_Lib.Common.Navigation_Mode)Enum.Parse(typeof(Common_Lib.Common.Navigation_Mode), "_View") || (Model.ActionMethod == (Common_Lib.Common.Navigation_Mode)Enum.Parse(typeof(Common_Lib.Common.Navigation_Mode), "_Delete")) ? true : false);
    bool IsDisabled = Model != null && (Model.ActionMethod == (Common_Lib.Common.Navigation_Mode)Enum.Parse(typeof(Common_Lib.Common.Navigation_Mode), "_View") || (Model.ActionMethod == (Common_Lib.Common.Navigation_Mode)Enum.Parse(typeof(Common_Lib.Common.Navigation_Mode), "_Delete")) ? true : false);

}
<div class="row">
    <div class="col-md-12">
        @Html.Action("RequisitionLinkedUserOrderGridData", "RequestRegister", new { ActionMethodName = ViewData["RRActionMethod"], RR_ID = ViewData["RR_ID"] })
    </div>
</div>

<div class="row btnsDiv marginAll8">
    @(Html.DevExtreme().Button().ID("BUT_RequisitionLinkedUserOrderOpen").Text("Open User Order").Disabled(IsDisabled).OnClick(@<text>function () {OnFrm_RequisitionLinkedUserOrder_Open_Click()}</text>))
    @(Html.DevExtreme().Button().ID("BUT_RequisitionLinkedUserOrderPostDelivery").Text("Post Delivery").Disabled(IsDisabled).OnClick(@<text>function () {OnFrm_RequisitionLinkedUserOrder_Delivery_Click()}</text>))
</div>
@(Html.DevExtreme().Popup().CustomPopup().ID("RR_ViewUo").CloseOnOutsideClick(false).ShowCloseButton(true).ShowTitle(true).ContentTemplate(@<text><div id="result_ViewUO"></div></text>))
<script>
    var LinkUO_Sr;
    var LinkUO_ID;
    var LinkUO_UONumber;
    function OnRequisitionLinkedUserOrderFocusedRowChanged(s, e)
    {
        if (s.GetFocusedRowIndex() > -1)
        {
            s.GetRowValues(s.GetFocusedRowIndex(), 'Sr;ID;UO_number', LinkUO_GridRowValues);
        }
        else
        {
            LinkUO_Sr = 0;
        }
    }
    function LinkUO_GridRowValues(values)
    {
        LinkUO_Sr = values[0];
        LinkUO_ID = values[1];
        LinkUO_UONumber = values[2];
    }
    function OnFrm_RequisitionLinkedUserOrder_Open_Click()
    {
        if (LinkUO_Sr < 1)
        {
            DevExpress.ui.dialog.alert("Select A Row..!!", "Information");
            return;
        }
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Stock/UserOrder/Frm_NEVD_User_Order",
            data: {
                PopUpID: "RR_ViewUo",
                ActionMethod: "View",
                ID: LinkUO_ID
            },
            cache: false,
            success: function (data)
            {
                OpenPopup("RR_ViewUo", "View ~ User Order", null, "auto", 1000, true, data);        
             
            }
        });
    }
    function OnFrm_RequisitionLinkedUserOrder_Delivery_Click()
    {
        if ("@Model.RequisitionStatus" == "Cancelled" || "@Model.RequisitionStatus" == "Rejected" || "@Model.RequisitionStatus" == "Completed")
        {
            DevExpress.ui.dialog.alert("Posting Delivery not allowed if RR status is " + "@Model.RequisitionStatus", "Error");
            return;
        }
        DevExpress.ui.dialog.alert("Coming Soon", "Information");
    }

</script>
