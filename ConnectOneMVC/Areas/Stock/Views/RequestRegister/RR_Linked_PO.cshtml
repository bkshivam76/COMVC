@{ 
    var SessionGUID = Request.QueryString["SessionGUID"];
}
@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "LinkedPOGrid";
        settings.CallbackRouteValues = new
        {
            Controller = "RequestRegister",
            Action = "RR_Linked_PO",
            SessionGUID = SessionGUID
        };
        settings.SettingsDetail.AllowOnlyOneMasterRowExpanded = false;// set false for simultaneous nested grid
        settings.SettingsDetail.ShowDetailRow = true; //set true for nested grid
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Visible;
        settings.SettingsResizing.ColumnResizeMode = DevExpress.Web.ColumnResizeMode.Control;
        settings.SettingsResizing.Visualization = DevExpress.Web.ResizingMode.Live;

        settings.SettingsExport.EnableClientSideExportAPI = true;

        settings.SetDetailRowTemplateContent(c =>
        {
            Html.RenderAction("RR_Linked_PO_ItemPurchase_Grid", new { PO_ID = DataBinder.Eval(c.DataItem, "ID") });
        });
        settings.CustomJSProperties = (s, e) =>
        {
            MVCxGridView gridView = (MVCxGridView)s;
            var lastVisibleColumn = gridView.VisibleColumns.LastOrDefault();
            e.Properties["cpLastVisibleColumnIndex"] = lastVisibleColumn != null ? lastVisibleColumn.Index : 0;
            e.Properties["cpHiddenColumnCaptions"] = gridView.AllColumns.Where(c => !c.Visible).ToDictionary(c => c.ToString(), c => c.Index);
        };
        settings.BeforeGetCallbackResult = (s, e) =>
        {
            MVCxGridView gridView = s as MVCxGridView;
            foreach (GridViewDataColumn column in gridView.DataColumns)
            {
                if (column.Visible)
                    column.Settings.AllowSort = DefaultBoolean.True;
                else
                    column.Settings.AllowSort = DefaultBoolean.False;
            }
        };

        //settings.ClientSideEvents.ContextMenuItemClick = "ContextMenuFunction";
        settings.KeyFieldName = "ID";

        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "PO_No";
                column.Caption = "Purchase  Order No.";
                //column.Width = 75;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "PO_Date";
                column.Caption = "PO Date";
                //column.Width = 75;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "RequisitionID";
                column.Caption = "Requisition ID";
                //column.Width = 100;
                // column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "PO_Status";
                column.Caption = "PO Status";
                //column.Width = 80;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "DeliveryStatus";
                column.Caption = "Delivery Status";
                //column.Width = 110;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "PaymentStatus";
                column.Caption = "Payment Status";
                //column.Width = 100;

            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Req_Dest_Location";
                column.Caption = "Requisition Destination";
                //column.Width = 105;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "TotalAmount";
                column.Caption = "Total Amount";
                //column.Width = 125;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Supplier";
                column.Caption = "Supplier";
                //column.Width = 125;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Project";
                column.Caption = "Project Name";
                //column.Width = 175;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Job";
                column.Caption = "Job Name";
                //column.Width = 125;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Requestor_Dept";
                column.Caption = "Requestor Department Name";
                //column.Width = 175;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Requestor";
                column.Caption = "Requestor’s Name";
                //column.Width = 175;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "AddedOn";
                column.Caption = "Rec.Add On";
                //column.Width = 175;
                column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "AddedBy";
                column.Caption = "Rec.Add by";
                //column.Width = 175;
                column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "EditedOn";
                column.Caption = "Rec.Edit On";
                column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "EditedBy";
                column.Caption = "Rec.Edit By";
                column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "ID";
                column.Caption = "ID";
                column.Visible = false;
                //column.Width = 175;
            }
        });
