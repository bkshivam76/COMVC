        function SP_Add_Location_Click(e)
        {

            if ("@Stock_Profile_Core_AddRights"=="False") { DevExpress.ui.dialog.alert('Not Allowed', 'No Rights'); return; }

            @*IsCoreLocationViewPopup = false;
            $("#popup_frm_CoreLocation_Window").dxPopup("show");
            $("#popup_frm_CoreLocation_Window").dxPopup("instance").option("title", "New ~ CoreLocation");
            $("#CoreLocationresult").html('');
            ShowLoader();
            $("#CoreLocationresult").load("@Url.Action("frm_CoreLocation_window", "CoreLocation", new { @area = "Profile" })?ActionMethod=New", function () {
                HideLoader();

            });
        }*@

            $.ajax({
                type: 'GET',
                url: "/Account/ProfilePaymentVoucher/AddLocations_Check",
                data: { ActionMethod: "New" },
                cache: false,
                async: false,
                success: function (data) {
                    if (data.result) {
                        $.ajax({
                            type: 'GET',
                            url: "/Account/ProfilePaymentVoucher/Frm_Location_Window",
                            data: {
                                ActionMethod: "New",
                                PopupID: "StockAddLocation",
                               // CallingScreen: "UO",
                                Dropdown_DataGrid: "LookUp_GetLocations_datagrid",
                                //PopupID: "StockAddLocation",
                                DropdownRefreshFunction: "Refresh_location_grid"
                        },
                            cache: false,
                            async: false,
                            success: function (data) {
                                ShowLoader();
                                $("#StockAddLocation").dxPopup('show');
                                $("#StockAddLocation").dxPopup("instance").option("title", "New~Location");
                                $("#result_StockAddLocation").html(null);
                                $("#result_StockAddLocation").html(data);
                                HideLoader();

                            }
                        });
                    }
                    else {
                        DevExpress.ui.dialog.alert(data.message, "Error");
                    }
                }
            });
        }
</script>