        }//Mantis bug 0001186 fixed
      

    async function Refresh_location_grid()//Mantis bug 0000470 fixed
    {
        var $LookUp_GetLocations_datagrid_DG = $("#LookUp_GetLocations_datagrid");
        if ($LookUp_GetLocations_datagrid_DG.length) {
            LookUp_GetLocations_datagrid_DG = $LookUp_GetLocations_datagrid_DG.dxDataGrid("instance");
