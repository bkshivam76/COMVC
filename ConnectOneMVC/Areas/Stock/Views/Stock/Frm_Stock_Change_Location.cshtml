@(Html.DevExtreme().Popup().CustomPopup().ID("StockAddLocation").CloseOnOutsideClick(false).ShowTitle(true).Height("auto").Width("auto").DragEnabled(true).Title("New ~ Location").ContentTemplate(@<text> <div id="result_StockAddLocation"> </div> </text>) )

<script>
