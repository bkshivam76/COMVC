function StockprofileOnInit(s, e) {
    StockprofileAdjustSize();
    ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
        StockprofileAdjustSize();
    });
}
    function StockprofileGrid_BeginCallBack(s, e) {
        e.customArgs["command"] = e.command;
        if (e.command == "REFRESH") {
            isStockGridRefresh = true;
        }

        e.customArgs["ShowHorizontalBar"] = StockProfile_ShowHorizontalBar;
    }
    


function StockprofileAdjustSize() {
    var height = (document.documentElement.clientHeight * 90) / 100;
    StockProfileListGrid.SetHeight(height);
    StockProfileListGrid.SetHeight(height);
}
function StockProfilechangeMode() {
    ShowLoader();
    if (StockProfile_ShowHorizontalBar == 0) {
        StockProfile_ShowHorizontalBar = 1;
        $("#StockProfileToggleScrollBar").find("span").text("Default Data");
        // $("#StockProfileToggleScrollBar").width(110);
    }
    else {
        StockProfile_ShowHorizontalBar = 0;
        $("#StockProfileToggleScrollBar").find("span").text("Full Data");
        // $("#StockProfileToggleScrollBar").width(80);
    }
    $.ajax({        
        url: '@Url.Action("Frm_Stock_Info_Grid", "Stock")',    
        type: "GET",
        data: { ShowHorizontalBar: StockProfile_ShowHorizontalBar },
        success: function (res) {
        $("#StockProfilereloadPartialView").html(res);
        }
    });
    HideLoader();
}


