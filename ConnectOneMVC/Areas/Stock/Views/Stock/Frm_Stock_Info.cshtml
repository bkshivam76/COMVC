@using DevExtreme.AspNet.Mvc;
@model IEnumerable<dynamic>
@{
    ViewBag.Title = "Index";
    Layout = null;
    bool Stock_ListRights = (bool)ViewData["Stock_ListRight"];
    bool Stock_Add_Rights = (bool)ViewData["Stock_AddRight"];
    bool Stock_Update_Rights = (bool)ViewData["Stock_UpdateRight"];
    bool Stock_View_Rights = (bool)ViewData["Stock_ViewRight"];
    bool Stock_Delete_Rights = (bool)ViewData["Stock_DeleteRight"];
    bool Stock_Export_Rights = (bool)ViewData["Stock_ExportRight"];
    bool Stock_Report_Rights = (bool)ViewData["Stock_ReportRight"];
    bool Stock_Profile_Core_AddRights = (bool)ViewData["Stock_Profile_Core_AddRight"];
    bool IsSuperuserAuditor = (bool)ViewBag.IsSuperUserOrAuditor;
}
<div id="content" class="col-md-12 report_header_div_main">
    <div class="col-md-4 report_header_div">
        <label class="report_header_label">Stock Profile</label>
    </div>
    @*Buttons*@
    <div class="report_button_div">
        @(Html.DevExtreme().Button()
                                                .ID("StockProfileUnlock")
                                                .Text("Unlock")
                                                .Icon("add")
                                                .Visible(IsSuperuserAuditor)
                                                .Disabled(true)
                                                .OnClick(@<text>
                                                        function () {
                                                        StockProfileUnlockClick();
                                                        }
                                                    </text>)
        )

        @(Html.DevExtreme().Button()
                                                .ID("StockProfileLock")
                                                .Text("Lock")
                                                .Icon("add")
                                                .Visible(IsSuperuserAuditor)
                                                .Disabled(true)
                                                .OnClick(@<text>
                                                        function () {
                                                        StockProfileLockClick();
                                                        }
                                                    </text>)
        )
        @(Html.DevExtreme().Button()
                                                .ID("StockProfileNew")
                                                .Text("New")
                                                .Icon("add")
                                                .Visible(true)
                                                .Disabled(false)
                                                .OnClick(@<text>
                                                        function () {
                                                        StockProfileNewClick();
                                                        }
                                                    </text>)
        )
        @(Html.DevExtreme().Button()
                                                .ID("StockProfileEdit")
                                                .Text("Edit")
                                                .Icon("edit")
                                                .Visible(true)
                                                .Disabled(false)
                                                .OnClick(@<text>
                                                        function () {
                                                        StockProfileOBEditClick();
                                                        }
                                                    </text>)
        )
        @(Html.DevExtreme().Button()
                                                .ID("StockProfileDelete")
                                                .Text("Delete")
                                                .Icon("trash")
                                                .Visible(true)
                                                .Disabled(false)
                                                .OnClick(@<text>
                                                        function () {
                                                        StockProfileDeleteClick();
                                                        }
                                                    </text>)
        )

        @(Html.DevExtreme().Button()
                                                .ID("StockProfileView")
                                                .Text("View")
                                                .Icon(IconID.ViewCustomers16x16devav)
                                                .Icon("doc")
                                                .Visible(true)
                                                .Disabled(false)
                                                .OnClick(@<text>
                                                        function () {
                                                        StockProfileViewClick();
                                                        }
                                                    </text>)
        )
        @(Html.DevExtreme().Button()
                                                                            .ID("StockProfileToggleScrollBar")
                                                                            .Text("Full Data")
                                                                            //.Width(90)
                                                                            .Icon("toolbox")
                                                                            .OnClick(@<text>
                                                                                    function () {
                                                                                    StockProfilechangeMode();
                                                                                    }
                                                                                </text>)
        )
        @(Html.DevExtreme().Button()
                                                                            .ID("StockProfileListPreview")
                                                                            .Text("List Export")
                                                                            .Icon("save")
                                                                            //.Width(75)
                                                                            .OnClick(@<text>
                                                                                    function () {
                                                                                    StockProfileListPreviewClick();
                                                                                    }
                                                                                </text>)
        )

        @(Html.DevExtreme().Button()
                                                                            .ID("StockProfileCLOSE")
                                                                            .Text("Close")
                                                                            .Icon("clear")
                                                                            .OnClick(@<text>
                                                                                    function (){$(".TabPanalMenu-tabs .active span").click()}
                                                                                </text>)

        )
    </div>
</div>
