function StockprofileContextMenuFunction(s, e) {
if (e.item.name == 'New') {
    StockProfileNewClick();
}
if (e.item.name == 'Close') {
    btnCloseActiveTab();
}
else if (e.item.name == 'Edit') {
    StockProfileOBEditClick();
}
else if (e.item.name == 'ChangeLocation') {
    OnChangeLocation();
}
else if (e.item.name == 'Delete') {
    StockProfileDeleteClick();
}
else if (e.item.name == 'View') {
    StockProfileViewClick();
}
else if (e.item.name == 'ListPreview') {
    StockProfileListPreviewClick();
}
else if (e.item.name == 'Lock') {
    OnLockClick();
}
else if (e.item.name == 'UnLock') {
    StockProfileUnlockClick();
}
else if (e.item.name == 'Refresh') {
    StockProfileListGrid.Refresh();
}
}
