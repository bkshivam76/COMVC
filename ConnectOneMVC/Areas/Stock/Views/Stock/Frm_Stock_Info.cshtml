function StockOnGridFocusedRowChanged(s, e) {
    var key = s.GetRowKey(s.GetFocusedRowIndex());
    StockProfileListGrid.GetValuesOnCustomCallback({ key: key }, StockOnGetRowValues);
}

    function StockOnGetRowValues(FDData) {     
        FullData = FDData;    
    var values = FDData.split("![");
    REC_ID = values[0];
    Store_Name = values[1];
    Item_Name = values[2];
    Serial_Lot_No = values[3];
    Item_Type = values[4];
    Item_Code = values[5];
    Make = values[6];
    Model = values[7];
    Warranty = values[8];
    Unit = values[9];
    Opening_Qty = values[10];
    Opening_Value = values[11];
    Date_of_Purchase = values[12];
    Location = values[13];
    Current_Qty = values[14];
    Current_Value = values[15];
    Remarks = values[16];
    REC_ADD_ON = values[17];
    REC_ADD_BY = values[18];
    REC_EDIT_ON = values[19];
    REC_EDIT_BY = values[20];
    REC_STATUS = values[21];
    REC_STATUS_ON = values[22];
    REC_STATUS_BY = values[23];
    Stock_TR_ID = values[25];
    recYearID = values[26];
     Store_ID = values[27];
    StockProfileUpdateFooterDetail(REC_ID, REC_ADD_ON, REC_ADD_BY, REC_EDIT_ON,
        REC_EDIT_BY, REC_STATUS, REC_STATUS_ON, REC_STATUS_BY);
}

function StockProfileUpdateFooterDetail(REC_ID, REC_ADD_ON, REC_ADD_BY, REC_EDIT_ON, REC_EDIT_BY, REC_STATUS, REC_STATUS_ON, REC_STATUS_BY) {

    var Status = "";
    var Lbl_Status = "";
    var Lbl_StatusBy = "";
    var Pic_Status = "";
    var Lbl_Create = "";
    var Lbl_Modify = "";
    var Lbl_Status_Color = "";
    var Add_Date = "";
    var Add_By = "";
    var Status_On = "";
    var Status_By = "";
    var StatusStr = "Completed";
    var Lbl_StatusOn = "";
    var Lbl_StatusBy = "";

    Status = REC_STATUS;

    Add_Date = REC_ADD_ON;
    Add_By = REC_ADD_BY;
    Status_On = REC_STATUS_ON;
    Status_By = REC_STATUS_BY;

    if (Status_On) {
        Lbl_StatusOn = StatusStr + " On: " + Status_On;
        Lbl_StatusBy = StatusStr + " By: " + Status_By;
    }
    else {
        Lbl_StatusOn = StatusStr + " On: " + "?";
        Lbl_StatusBy = StatusStr + " By: " + Status_By;
    }

    if (Add_Date) {
        Lbl_Create = "Add On: " + Add_Date + ", By: " + Add_By;
    }
    else {
        Lbl_Create = "Add On: " + "?, By: " + Add_By;
    }

    var Edit_Date = "";
    var Edit_By = "";

    Edit_Date = REC_EDIT_ON;
    Edit_By = REC_EDIT_BY;

    if (Edit_Date) {
        Lbl_Modify = "Edit On: " + Edit_Date + ", By: " + Edit_By;
    }
    else {
        Lbl_Modify = "Edit On: " + "?, By: " + Edit_By;
    }
    $('#ST_Lbl_ActionOn').text(Lbl_StatusOn)
    $('#ST_Lbl_ActionBy').text(Lbl_StatusBy);
    $('#STLbl_Create').text(Lbl_Create);
    $('#STLbl_Modify').text(Lbl_Modify);
    if (Lbl_Status_Color != "") {
        $('#STLbl_Status').css('color', Lbl_Status_Color);
    }
    if (Pic_Status != "") {
        $('#ST_LockICON').css('class', Pic_Status);
    }
}

//New Click function Start

function StockProfileNewClick() {
    IsSFNewPopup = true;
    IsViewPopup = false;
    
    if (!StockNewright) { DevExpress.ui.dialog.alert('Not Allowed', 'No Rights'); return; }

    $.ajax({
        type: 'GET',
        url: "/Stock/Stock/IsFinalAuditCompleted",
        data: {},
        cache: false,
        success: function (StockResult) {
            if (StockResult.result == "true" || StockResult.result == true) {
                DevExpress.ui.dialog.alert(StockResult.Message, 'alert!');
            }
            else
            {
                ShowLoader();              
                OpenPopup("popup_frm_StockProfile_Window", "New ~ Stock Item", "@Url.Action("Frm_Stock_Window", "Stock", new { @area = "Stock" })?ActionMethod=New", "auto", 1150, false, null);
                HideLoader();
            }
        }
    });
}
//New Click function End

//Edit Click function Start
    function StockProfileOBEditClick() {
        if (!StockEditright) { DevExpress.ui.dialog.alert('Not Allowed', 'No Rights'); return; }

        IsSFNewPopup = false;
        IsViewPopup = false;
        if (!REC_ID) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Stock/Stock/DataNavigation",
            data: { ActionMethod: "Edit", REC_ID: REC_ID, REC_STATUS: REC_STATUS, Stock_TR_ID: Stock_TR_ID, recYearID: recYearID },
            cache: false,
            success: function (OB_Edit_ButtonClick_result) {
                if (OB_Edit_ButtonClick_result.result == "true" || OB_Edit_ButtonClick_result.result == true)
                {
                    ShowLoader();
                    OpenPopup("popup_frm_StockProfile_Window", "Edit ~ Stock Item","@Url.Action("Frm_Stock_Window", "Stock", new { @area = "Stock" })?ActionMethod=Edit&recId=" + REC_ID, "auto", 1150, false, null);
                    HideLoader();
                }
                else {
                    DevExpress.ui.dialog.alert(OB_Edit_ButtonClick_result.Message, 'Warning!');
                    StockProfileListGrid.Refresh();
                }
            }
        });
    }
