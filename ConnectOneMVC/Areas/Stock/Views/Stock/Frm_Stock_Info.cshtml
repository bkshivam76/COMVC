function StockAjaxSuccessForm(data) {
    HideLoader();
    if (data.result == false) {
        DevExpress.ui.dialog.alert(data.Message, "Error");
    }
    else {
        IsSucessPopup = true;
        var StackSubmitSuccess = DevExpress.ui.dialog.alert(data.Message, "Stock");
        $("#popup_frm_StockProfile_Window").dxPopup("hide");
        StockProfileListGrid.Refresh();
        IsSucessPopup = false;
        StackSubmitSuccess.done(function (alertResult) {
            if (alertResult) {
                if (IsSFNewPopup == true) {
                    var addmoreOBresult = DevExpress.ui.dialog.confirm("Add More Entry...?", "Stock New");
                    addmoreOBresult.done(function (dialogResult) {
                        if (dialogResult) {
                            StockProfileNewClick();
                        }
                    });
                }
            }
        });
    }
}
//Drop down change events
    function OnChangeLocation()
    {
        if (!StockEditright)
        {
            DevExpress.ui.dialog.alert('Not Allowed', 'No Rights'); return;
        }
        $("#popup_frm_Stock_Change_Location").dxPopup("show")
        $("#popup_frm_Stock_Change_Location").dxPopup("instance").option("title", "Change ~ Location");
        $("#popup_frm_Stock_Change_Location").dxPopup("instance").option("height", "auto");
        ShowLoader();
        $("#popup_frm_Stock_Change_Location_result").html('');
        $("#popup_frm_Stock_Change_Location_result").load("@Url.Action("Frm_Stock_Change_Location", "Stock", new { @area = "Stock" })?ActionMethod=New" + "&FData=" + encodeURIComponent(FullData), function () {       
            HideLoader();
        });       
    }
    function Frm_Stock_Change_Location_Success(result)
    {
    HideLoader();
    if (result.result == false) {
        DevExpress.ui.dialog.alert(result.Message, "Error");
    }
    else {
        //IsStockSuccesspopup = true;
        var lbSubmitSuccess = DevExpress.ui.dialog.alert(result.Message, "Success");
        $("#popup_frm_Stock_Change_Location").dxPopup("hide");
    }
}
