@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("LookUp_GetProjects_datagrid")   
    .Columns(columns =>
    {

        columns.Add().DataField("ProjectName").Caption("Project Name");
        columns.Add().DataField("Sanctionno").Caption("Sanctionno");
        columns.Add().DataField("ComplexName").Caption("Complex Name");
        columns.Add().DataField("ProjectId").Caption("Project Id").Visible(false);

    })
   
    .Selection(s => s.Mode(SelectionMode.Single))
    
)




