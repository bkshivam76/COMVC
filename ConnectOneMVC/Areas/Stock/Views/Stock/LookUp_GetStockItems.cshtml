@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("LookUp_GetStockItems_datagrid")
   
    .Columns(columns =>
    {

        columns.Add().DataField("ItemName").Caption("Item Name");
        columns.Add().DataField("ItemCategory").Caption("Item Category");
        columns.Add().DataField("ItemType").Caption("Item Type");
        columns.Add().DataField("ItemCode").Caption("Item Code");
        columns.Add().DataField("Unit").Caption("Unit");
        columns.Add().DataField("UnitID").Caption("UnitID").Visible(false);
        columns.Add().DataField("ItemId").Caption("Item Id").Visible(false);

    })
  
    .Selection(s => s.Mode(SelectionMode.Single))
   
)




