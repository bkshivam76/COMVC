@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("LookUp_GetStoreList_datagrid")
    .Columns(columns =>
    {
        columns.Add().DataField("StoreName").Caption("Store Name");
        columns.Add().DataField("DeptName").Caption("Dept Name");
        columns.Add().DataField("SubDeptName").Caption("Sub Dept Name");
        columns.Add().DataField("DeptInchargeName").Caption("Dept Incharge Name");
        columns.Add().DataField("StoreInchargeName").Caption("Store Incharge Name");
        columns.Add().DataField("StoreId").Caption("Store Id").Visible(false);
    })

    .Selection(s => s.Mode(SelectionMode.Single))
   
)




