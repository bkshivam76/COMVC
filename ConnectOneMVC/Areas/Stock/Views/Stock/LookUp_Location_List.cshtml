@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
        .ID("LookUp_Location_List_datagrid")
        .DataSource(new JS(@"component.option(""dataSource"")"))
        .Columns(columns =>
        {
            columns.Add().DataField("LocationName").Caption("Location Name");
            columns.Add().DataField("MatchedName").Caption("Matched name ");
            columns.Add().DataField("MatchedType").Caption("Matched Type");
            columns.Add().DataField("LocId").Caption("ID").Visible(false);
        })

        .Selection(s => s.Mode(SelectionMode.Single))

)




