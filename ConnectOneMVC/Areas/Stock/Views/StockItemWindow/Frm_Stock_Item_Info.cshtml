        function OnMapItemStore()
        { 
            if ("@Item_Update_Rights" == "False") {
                DevExpress.ui.dialog.alert('Not Allowed..!!', 'No Rights');
                return;
            }

            IsSFNewPopup = false;
            IsViewPopup = false;
            if (!REC_ID) {
                DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
                return;
            }
               
            
            var StoreID = $("#Store_Name").dxDropDownBox("instance").option("value");

            if (StoreID != null && StoreID != 0) {
                Store_ID = StoreID;
            }
            else {
                Store_ID = null;
            }
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Stock/StockItemWindow/DataNavigation",
                data: { ActionMethod: "MapItemStore", ID: REC_ID, Closed_On: Closed_On },
