<script type="text/javascript">
    //var StockProfile_ShowHorizontalBar = 0;
    var FullData;
    var IsSFNewPopup = false;
    var IsSucessPopup = false;
    var IsViewPopup = false;
    var REC_ID;
    var REC_ADD_ON;
    var REC_ADD_BY;
    var REC_EDIT_ON;
    var REC_EDIT_BY;
    var REC_STATUS;
    var REC_STATUS_ON;
    var REC_STATUS_BY;
    var Closed_On;
    var Item_Name;
    var SI_ShowHorizontalBar = 0;
    var StockItem_Consumption_Type;
    var Item_Code;
    var Conversion_Rate;
    var SubCategory;
    var Store_ID;
    var Primary_Unit;
    var MainCategoryValue = "";//Mantis bug 0000347 fixed
    var isStockItemGridRefresh = false;
    $(document).ready(function () {
        $("#StockItemListGrid").hover(function () {
            StockItemListGrid.Focus()
        })
      
        if ("@Item_Add_Rights" != "True")
        {
            $("#StockItemNew").hide();
        }
        if ("@Item_Update_Rights" != "True")
        {
            $("#StockCloseItem").hide();
            $("#StockItemEdit").hide();            
        }
        if ("@Item_View_Rights" != "True")
        {
            $("#StockItemView").hide();
        }
        if ("@Item_Delete_Rights" != "True")
        {
            $("#StockItemDelete").hide();
        }
        if ("@Item_Export_Rights" != "True")
        {
            $("#StockItemListPreview").hide();
        }
    });
    $(".TabPanalMenu-tabs .active span").on("click", function () {
        $.ajax({
            type: 'GET',
            url: "/Stock/StockItemWindow/ItemMasterSessionclear",
            cache: false
        });
        DeleteCookie("StItemCookie");
        $.ajax({
            type: 'GET',
            url: "/Stock/StockItemWindow/InfoSessionclear",
            cache: false
        });
    });
    function StockItemOnInit(s, e) {
        StockItemAdjustSize();
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
            StockItemAdjustSize();
        });
    }
    function StockItemGrid_BeginCallBack(s, e) {
     
        e.customArgs["command"] = e.command;       
        if (e.command == "REFRESH") {
            isStockItemGridRefresh = true;
        }
        e.customArgs["ShowHorizontalBar"] = SI_ShowHorizontalBar;
        
        e.customArgs["Store_ID"] = $("#Store_Name").dxDropDownBox("instance").option("value");
    }

    function StockItemAdjustSize() {
        var height = (document.documentElement.clientHeight * 90) / 100;
        StockItemListGrid.SetHeight(height);
        StockItemListGrid.SetHeight(height);
    }

    function StockItemContextMenuFunction(s, e) {
        if (e.item.name == 'New') {
            StockItemNewClick();
        }
        if (e.item.name == 'Close') {
            btnCloseActiveTab();
        }
        else if (e.item.name == 'Edit') {
            StockItemOnEditClick();
        }
        else if (e.item.name == 'ListPreview') {
            StockItemListPreviewClick();
        }
        else if (e.item.name == 'Refresh') {
            StockItemListGrid.Refresh();
        }
        else if (e.item.name == 'CloseItem') {
            OnStockCloseItem();
        }
        else if (e.item.name == 'Delete') {
            StockItemDeleteClick();
        }
        else if (e.item.name == 'View') {
            StockItemViewClick();
        }
        else if (e.item.name == 'MapItemStore') {
            OnMapItemStore();
        }
        else if (e.item.name == 'ReOpenItem') {
            OnStockReOpenItem();
        }
        else if (e.item.name == 'MapItemSupplier') {
            OnMapItemSupplierClick();
        }
        else if (e.item.name == 'AddItemTaxRate') {
            OnAddItemTaxRateClick();
        }
        else if (e.item.name == 'AddItemPenaltyRates') {
            OnAddItemPenaltyRatesClick();
        }
        else if (e.item.name == 'AddItemProperty') {
            OnAddItemPropertyClick();
        }
        else if (e.item.name == 'AddUnitConversion') {
            OnAddItemUnitClick();
        }
        else if (e.item.name == 'ViewItemImage') {
            OnAddItemImageClick();
        }
        else if (e.item.name == 'AddChangeApprovalCriteria') {
            AddChangeApprovalCriteriaClick();
        }

    }
        function AddChangeApprovalCriteriaClick()
        {

            if ("@Item_Update_Rights" == "False")
        {
            DevExpress.ui.dialog.alert('Not Allowed..!!', 'No Rights');
            return;
        }
            if (!REC_ID) {
                DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
                return;
            }

            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Stock/StockItemWindow/DataNavigation",
                data: {
                    ActionMethod: "CloseCheck",
                    ID: REC_ID,

                },
                cache: false,
                success: function (data_Edit) {
                    HideLoader();
                    if (data_Edit.result == "true" || data_Edit.result == true) {
                        DevExpress.ui.dialog.alert("Coming Soon..!", "Inform..");
                    }
                    else if (data_Edit.result == "false" || data_Edit.result == false) {
                        DevExpress.ui.dialog.alert('Approval Criteria can not be added to Closed Item', 'Error');
                    }

                }
            });
        }

    function OnAddItemImageClick() {                  
        if (!REC_ID) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        $.ajax({
            type: 'GET',
            url: "/Stock/StockItemWindow/ViewStockImage",
            data: {             
                ID: REC_ID
            },
            cache: false,
            success: function (data)
            {
                if (data.result == false)
                {
                    DevExpress.ui.dialog.alert(data.message, 'Inform');
                }
                else
                {
                           ShowLoader();   
        OpenPopup("popup_frm_StockItem_Window", "View Image",null, "auto", "60%",true,data);
        HideLoader();
                }
            }
        });
 
    }
                
          

        function OnAddItemUnitClick()
        {      
            if (!REC_ID) {
                DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
                return;
            }

            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Stock/StockItemWindow/DataNavigation",
                data: {
                    ActionMethod: "CloseCheck",
                    ID: REC_ID,

                },
                cache: false,
                success: function (data_Edit) {

                    if (data_Edit.result == "true" || data_Edit.result == true) {

                        $.ajax({
                            type: 'GET',
                            url: "/Stock/StockItemWindow/frm_Item_Window_Add_Unit_conversion",
                            data: {
                                ActionMethod: "_New",
                                subitemid: REC_ID,
                                Itemname: Item_Name,
                            },
                            cache: false,
                            success: function (data) {
                                ShowLoader();
                                OpenPopup("StockIteminnergrid", "New ~ Add Conversion Unit", null, "auto", 900, true, data);
                               
                                HideLoader();
                            }
                        });
                    }
                    else if(data_Edit.result == "false" || data_Edit.result == false)
                    {
                        DevExpress.ui.dialog.alert('Unit Conversion can not be added to closed item', 'Error');
                    }

                }
            });
        }

    function OnAddItemPropertyClick() {

        if (!REC_ID) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }

        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Stock/StockItemWindow/DataNavigation",
            data: {
                ActionMethod: "CloseCheck",
                ID: REC_ID,

            },
            cache: false,
            success: function (data_Edit) {

                if (data_Edit.result == "true" || data_Edit.result == true) {

      
                    $.ajax({
                        type: 'GET',
                        url: "/Stock/StockItemWindow/frm_Item_Window_Add_Property",
                        data: {
                            ActionMethod: "_New",
                            subitemid: REC_ID,
                            Itemname: Item_Name,
                        },
                        cache: false,
                        success: function (data) {                     
                            ShowLoader();
                            OpenPopup("StockIteminnergrid", "New ~ Add Property", null, "auto", 900, true, data);

                            HideLoader();
                        }
                    });
                }
                else if(data_Edit.result == "false" || data_Edit.result == false)
                {
                    DevExpress.ui.dialog.alert('Property cannot be added to closed Item', 'Error');
                }

            }
        });
    }
