        function OnMapItemSupplierClick()
        {
                    if ("@Item_Update_Rights" == "False")
        {
            DevExpress.ui.dialog.alert('Not Allowed..!!', 'No Rights');
            return;
        }
             IsSFNewPopup = false;
            IsViewPopup = false;
            if (REC_ID == 'undefined' || REC_ID == undefined) {
                DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
                return;
            }
            ShowLoader();
            $.ajax({
                type: 'GET',
                url: "/Stock/StockItemWindow/DataNavigation",
                data: { ActionMethod: "MapItemSupplier", ID: REC_ID, Closed_On: Closed_On },
                cache: false,
                success: function (MapItem_result) {
                   
                    if (MapItem_result.result == true || MapItem_result.result == "true") {
               
                        $.ajax({
                            type: 'Get',
                            url: "/Stock/SupplierMaster/Frm_Item_Supplier_Add_Mapping_Window",
                            data: { PopUpId: "StockIteminnergrid", ActionMethod: "New", itemid: REC_ID, PostSuccessFunction: "Frm_Supplier_SI_OnSuccess",  },
                            cache: false,
                            success: function (resultsuccess) {
                            
                                ShowLoader();
                                OpenPopup("StockIteminnergrid", "New ~ Add Supplier Mapping", null, "auto", 900, true, resultsuccess);

                                HideLoader();
                            }
                        });
                    }
                    else {
                        DevExpress.ui.dialog.alert(MapItem_result.Message, 'Inform..!');
                        HideLoader();
                    }
                }
            });
    }
    function Frm_Supplier_SI_OnSuccess(data) {
      
        HideLoader();
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.message, "Error");
        }
        else {
            DevExpress.ui.dialog.alert(data.Message, "Item Supplier Mapping");
            $("#StockIteminnergrid").dxPopup("hide");
            StockItemListGrid.SetFocusedRowIndex(-1);
            StockItemListGrid.Refresh();
            //$("#ProductionStoreID").dxDropDownBox("instance").option("readOnly", true);
        }
    }
