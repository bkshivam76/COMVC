    function StockItemOnGridFocusedRowChanged(s, e)
    {       
        if (s.GetFocusedRowIndex() > -1) {
            var key = s.GetRowKey(s.GetFocusedRowIndex());   
            REC_ID = key;
            s.GetValuesOnCustomCallback({ key: key }, StockItemOnGetRowValues);
        }
        else { REC_ID = 0; }
    }//Mantis bug 0000347 fixed

    function StockItemOnGetRowValues(FDData) {
      
        FullData = FDData;
        var values = FDData.split("![");
        REC_ID = values[0];
        REC_ADD_ON = values[1];
        REC_ADD_BY = values[2];
        REC_EDIT_ON = values[3];
        REC_EDIT_BY = values[4];
        Closed_On = values[5];
        StockItem_Consumption_Type = values[6];
        Item_Name  = values[8];
        Item_Code = values[10];
        Conversion_Rate = values[7];
        SubCategory = values[11];
        Primary_Unit = values[12];
        MainCategoryValue = values[13];
        StockItemUpdateFooterDetail(REC_ID, REC_ADD_ON, REC_ADD_BY, REC_EDIT_ON, REC_EDIT_BY);
    }//Mantis bug 0000347 fixed

    function StockItemUpdateFooterDetail(REC_ID, REC_ADD_ON, REC_ADD_BY, REC_EDIT_ON, REC_EDIT_BY) {

        var Status = "";
        var Lbl_Status = "";
        var Lbl_StatusBy = "";
        var Pic_Status = "";
        var Lbl_Create = "";
        var Lbl_Modify = "";
        var Lbl_Status_Color = "";
        var Add_Date = "";
        var Add_By = "";
        var Status_On = "";
        var Status_By = "";
        var StatusStr = "Completed";
        var Lbl_StatusOn = "";
        var Lbl_StatusBy = "";

        Status = REC_STATUS;

        Add_Date = REC_ADD_ON;
        Add_By = REC_ADD_BY;
        Status_On = REC_STATUS_ON;
        Status_By = REC_STATUS_BY;

        if (Status_On) {
            Lbl_StatusOn = StatusStr + " On: " + Status_On;
            Lbl_StatusBy = StatusStr + " By: " + Status_By;
        }
        else {
            Lbl_StatusOn = StatusStr + " On: " + "?";
            Lbl_StatusBy = StatusStr + " By: " + Status_By;
        }

        if (Add_Date) {
            Lbl_Create = "Add On: " + Add_Date + ", By: " + Add_By;
        }
        else {
            Lbl_Create = "Add On: " + "?, By: " + Add_By;
        }

        var Edit_Date = "";
        var Edit_By = "";

        Edit_Date = REC_EDIT_ON;
        Edit_By = REC_EDIT_BY;

        if (Edit_Date) {
            Lbl_Modify = "Edit On: " + Edit_Date + ", By: " + Edit_By;
        }
        else {
            Lbl_Modify = "Edit On: " + "?, By: " + Edit_By;
        }
        //$('#ST_Lbl_ActionOn').text(Lbl_StatusOn)
        //$('#ST_Lbl_ActionBy').text(Lbl_StatusBy);
        $('#STLbl_Create').text(Lbl_Create);
        $('#STLbl_Modify').text(Lbl_Modify);
        if (Lbl_Status_Color != "") {
            $('#STLbl_Status').css('color', Lbl_Status_Color);
        }
        if (Pic_Status != "") {
            $('#ST_LockICON').css('class', Pic_Status);
        }
    }

