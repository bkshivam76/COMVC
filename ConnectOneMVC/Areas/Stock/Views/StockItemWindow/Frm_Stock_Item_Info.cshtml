<div id="content" class="col-md-12 report_header_div_main">
    @*<div class="row margin0">*@
    <div class="col-md-4 report_header_div">
        <label class="report_header_label">Stock Item Register</label>
    </div>
    <div class="report_button_div">
        @(Html.DevExtreme().Button()
                                                                                                    .ID("StockCloseItem")
                                                                                                    .Text("Close Item")
                                                                                                    .Visible(true)
                                                                                                    .Disabled(false)
                                                                                                    .OnClick(@<text>
                                                                                                        function () {
                                                                                                        OnStockCloseItem();
                                                                                                        }
                                                                                                    </text>)
        )


        @(Html.DevExtreme().Button()
                                                                                            .ID("StockItemNew")
                                                                                            .Text("New")
                                                                                            .Icon("add")
                                                                                            .Visible(true)
                                                                                            .Disabled(false)
                                                                                            .OnClick(@<text>
                                                                                                function () {
                                                                                                StockItemNewClick();
                                                                                                }
                                                                                            </text>)
        )
        @(Html.DevExtreme().Button()
                                                                                          .ID("StockItemEdit")
                                                                                          .Text("Edit")
                                                                                          .Icon("edit")
                                                                                          .Visible(true)
                                                                                          .Disabled(false)
                                                                                          .OnClick(@<text>
                                                                                            function () {
                                                                                            StockItemOnEditClick();
                                                                                            }
                                                                                        </text>)
        )
        @(Html.DevExtreme().Button()
                                                                                     .ID("StockItemDelete")
                                                                                     .Text("Delete")
                                                                                     .Icon("trash")
                                                                                     .Visible(true)
                                                                                     .Disabled(false)
                                                                                     .OnClick(@<text>
                                                                                        function () {
                                                                                        StockItemDeleteClick();
                                                                                        }
                                                                                    </text>)
        )

        @(Html.DevExtreme().Button()
                                                                                    .ID("StockItemView")
                                                                                    .Text("View")
                                                                                    .Icon(IconID.ViewCustomers16x16devav)
                                                                                    .Icon("doc")
                                                                                    .Visible(true)
                                                                                    .Disabled(false)
                                                                                    .OnClick(@<text>
                                                                                        function () {
                                                                                        StockItemViewClick();
                                                                                        }
                                                                                    </text>)
        )

        @(Html.DevExtreme().Button()
                                                                                   .ID("StockItemListPreview")
                                                                                   .Text("List Export")
                                                                                   .Icon("save")
                                                                                   //.Width(75)
                                                                                   .OnClick(@<text>
                                                                                    function () {
                                                                                    StockItemListPreviewClick();
                                                                                    }
                                                                                </text>)
        )

        @(Html.DevExtreme().Button()
                                                                                   .ID("StockItemToggleButton")
                                                                                   .Text("Full Data")
                                                                                   .Icon("toolbox")
                                                                                   //.Width(75)
                                                                                   .OnClick(@<text>
                                                                                    function () {
                                                                                    StockItemListChangeMode();
                                                                                    }
                                                                                </text>)
        )

        @(Html.DevExtreme().Button()
                                                                                  .ID("StockItemCLOSE")
                                                                                  .Text("Close")
                                                                                  .Icon("clear")
                                                                                  .OnClick(@<text>
                                                                                    function (){$(".TabPanalMenu-tabs .active span").click()}
                                                                                </text>)

        )
    </div>
    @*</div>*@
    <div class="col-sm-4 col-md-4 col-lg-3 Select_Store_Name">
        @(Html.DevExtreme().DropDownBox().CustomDropDown()
                    .ID("Store_Name")
                    .Name("Store_Name")
                    .Placeholder("Select Store/All")
                    .ValueExpr("StoreID")
                    .DisplayExpr("Store_Name")
                    .DataSource(d => d.Mvc().Controller("StockItemWindow").LoadAction("LookUp_GetStoreList").Key("StoreID"))                    
                  
                    .OnValueChanged("SelectStoreItem")
                   
                    .ContentTemplate(@<text>
                        @Html.Partial("LookUp_GetStoreList")
                    </text>)
        )
    </div>
</div>
