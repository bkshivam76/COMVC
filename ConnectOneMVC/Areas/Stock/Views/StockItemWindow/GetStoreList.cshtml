@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                   .ID("Frm_GetStoreList")
              
                   .Columns(columns =>
                   {
                       columns.Add().DataField("Store_Name").Caption("Store_Name").Visible(true);
                       columns.Add().DataField("Dept_Name").Caption("Dept_Name").Visible(false);
                       columns.Add().DataField("Sub_Dept_Name").Caption("Sub_Dept_Name").Visible(false);
                       columns.Add().DataField("Dept_Incharge_Name").Caption("Dept_Incharge_Name").Visible(false);
                       columns.Add().DataField("Store_Incharge_Name").Caption("Store_Incharge_Name").Visible(false);
                       columns.Add().DataField("StoreID").Caption("StoreID").Visible(false);
                   })
               
                    .Selection(s => s.Mode(SelectionMode.Single))
                   
)