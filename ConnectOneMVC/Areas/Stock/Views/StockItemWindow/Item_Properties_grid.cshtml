        function StockItemPropertyListPreviewClick() {
         debugger
         $("#StockPItem_report_modal").dxPopup("show");
         $("#StockPItem_report_modal").dxPopup("instance").option("title", "Export Option");

            $("#StockPItem_report_modal_Result").html(null);
        ShowLoader();
         $("#StockPItem_report_modal_Result").load("@Url.Action("Frm_Export_Options_Property", "StockItemWindow", new { @area = "Stock" })", function () {
            HideLoader();
        });
    }
    function to_Edit_New_Delete_ViewData(actionMethod) {
        debugger;

        if (actionMethod == "_New") {
            if ("@IsDisabled" == "true") { return; }

     
            ShowLoader();            
                 OpenPopup("StockIteminnergrid", "Add New Property", "@Url.Action("frm_Item_Window_Add_Property", "StockItemWindow", new {@area= "Stock" })?ActionMethod=_New", "auto", 1000, false, null);
            HideLoader();
        }
        if (actionMethod == "_Edit") {

            if (!prop_SrNo) {
                DevExpress.ui.dialog.alert("Please select one row", "Error");
                return;
            }//Mantis bug 0000349 fixed
             ShowLoader();            
            OpenPopup("StockIteminnergrid", " Property Screen", "@Url.Action("frm_Item_Window_Add_Property", "StockItemWindow", new {@area= "Stock" })?ActionMethod=_Edit&SrNo=" + encodeURIComponent(prop_SrNo), "auto", 1000, false, null);
            HideLoader();
        }
        if (actionMethod == "_View") {
            if (!prop_SrNo) {
                DevExpress.ui.dialog.alert("Please select one row", "Error");
                return;
            }//Mantis bug 0000349 fixed            
                  ShowLoader();            
            OpenPopup("StockIteminnergrid", " Property Screen", "@Url.Action("frm_Item_Window_Add_Property", "StockItemWindow", new {@area= "Stock" })?ActionMethod=_View&SrNo=" + encodeURIComponent(prop_SrNo), "auto", 1000, false, null);
            HideLoader();
        }

        if (actionMethod == "_Delete") {
            if ("@IsDisabled" == "True") { return; }
            if (!prop_SrNo) {
                DevExpress.ui.dialog.alert("Please select one row", "Error");
                return;
            }
            var deleteResultPaymentDetail = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
            deleteResultPaymentDetail.done(function (dialogResult) {

                if (dialogResult) {
                    $.ajax({
                        type: 'GET',
                        url: "/Stock/StockItemWindow/Frm_Property_Grid_Delete_Record",
                        data: { ActionMethod: "_Delete", SrNo: prop_SrNo },
                        cache: false,
                        success: function (result) {
                            if (result.result == true) {
                                Item_Properties_grid_Data.SetFocusedRowIndex(-1);
                                Item_Properties_grid_Data.Refresh();
                            }
                        }
                    });
                }
            });
        }
