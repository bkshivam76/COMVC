@model ConnectOneMVC.Areas.Stock.Models.StockItemWindow
@using DevExtreme.AspNet.Mvc;

@{
    bool IsVisible = Model != null &&  Model.ItemMaster_ActionMethod.ToString().Trim() == "_Delete" ? true : false;
    bool IsDisabled = Model != null && (Model.ItemMaster_ActionMethod == "_View" || Model.ItemMaster_ActionMethod == "_Delete") ? true : false;
}

<div class="tab-content responsive">
    <div id="ItemProperties" class="tab-pane fade in active">
        <div class="row">
            <div class="col-lg-12 col-xs-12 table-responsive overflow-scroll scrollbar">
                <div class="tabtbl width1200px">
                    @Html.Action("Item_Properties_grid_Data", "StockItemWindow", new { ActionMethodName = Model.ItemMaster_ActionMethod, SubItemID = Model.SubItemID })
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="form-field">
                    @(Html.DevExtreme().Button().ID("IDIPVDNew").Text("New").Disabled(IsDisabled).OnClick(@<text> function(){ to_Edit_New_Delete_ViewData("_New");} </text>))

                    @(Html.DevExtreme().Button().ID("IDItemEdit").Text("Edit").Disabled(IsDisabled).OnClick(@<text> function(){to_Edit_New_Delete_ViewData("_Edit")} </text>))

                    @(Html.DevExtreme().Button().ID("IDItemDelete").Text("Delete").Disabled(IsDisabled).OnClick(@<text> function(){to_Edit_New_Delete_ViewData("_Delete")} </text>))

                    @(Html.DevExtreme().Button().ID("IDItemView").Text("View").Disabled(IsDisabled).OnClick(@<text> function(){to_Edit_New_Delete_ViewData("_View")} </text>))

                    @(Html.DevExtreme().Button().ID("IDItemListExport").Text("List Export").Disabled(IsDisabled).OnClick(@<text> function(){StockItemPropertyListPreviewClick()} </text>))

                </div>
            </div>
        </div>
    </div>
</div>@*//Mantis bug 0000347 fixed*@

