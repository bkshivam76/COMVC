@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("LookUp_StoreList_datagrid")   
    .Columns(columns =>
    {
        columns.Add().DataField("Store_Name").Caption("Store Name");
        columns.Add().DataField("Dept_Name").Caption("Dept Name");
        columns.Add().DataField("Sub_Dept_Name").Caption("Sub Dept Name");
        columns.Add().DataField("Dept_Incharge_Name").Caption("Dept Incharge Name");
        columns.Add().DataField("Store_Incharge_Name").Caption("Store Incharge Name");
        columns.Add().DataField("StoreID").Caption("Store Id").Visible(false);
    })
   
    .Selection(s => s.Mode(SelectionMode.Single))
  
)




