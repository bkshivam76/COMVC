
@Html.DevExpress().BinaryImage(
    settings =>
    {
        settings.Name = "SI_binaryImage_show";
        settings.ClientEnabled = true;
        settings.ClientVisible = true;
        settings.Properties.ClientInstanceName = "SI_binaryImage_show";
        settings.Properties.EnableClientSideAPI = true;
        settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
        settings.Height= System.Web.UI.WebControls.Unit.Percentage(100);
        settings.ContentBytes = (byte[])ViewData["SI_Image"];
        settings.Properties.ImageSizeMode = ImageSizeMode.FitProportional;
        
        settings.Properties.ClientSideEvents.Init = String.Format("function (s, e) {{ItemImageEndcallback(s,e);}}");

    }).GetHtml()