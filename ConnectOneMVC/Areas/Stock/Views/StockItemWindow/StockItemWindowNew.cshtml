                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="form-field">
                            <div class="container-fluid">
                                <div class="row">
                                    <div class="col-sm-4 pll">
                                        <label class="control-label text-red Accountingwidth margB0" for="iten">Accounting Item:</label>
                                    </div>
                                    <div class="col-sm-8 prm pll2">
                                        @(Html.DevExtreme().SelectBox().CustomSelectBox().ID("Sub_Item_Accounting_Item").Name("Sub_Item_Accounting_Item").HoverStateEnabled(true)
                                                                                                                        .Value(Model.Sub_Item_Accounting_Item).ValueExpr("ID").DisplayExpr("Head").Placeholder("Please select...")
                                                                                                                        .DataSource(new object[] { new { Head = "Miscellaneous Construction Expenses (C)", ID = "c75de479-bdb6-48ba-9ebc-c3d495ae68f3" } }).ReadOnly(IsVisible).Disabled(IsDisabled))
                                        @Html.ValidationMessageFor(model => model.Sub_Item_Accounting_Item, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="form-field">
                            <div class="container-fluid paddTB2">
                                <div class="row">
                                    <div class="col-sm-4 pll">
                                        <label class="control-label text-red margB0" for="iten">Main Category:</label>
                                    </div>
                                    <div class="col-sm-8 prm pll2">
                                        @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("Sub_Item_Main_Category").Name("Sub_Item_Main_Category").DataSource(d => d.Mvc().Controller("StockItemWindow").LoadAction("GetMainCategories").Key("Main_Category"))
