    function OnValueChanged_Sub_Item_Unit_Id(e)
    {
       
        var dropDownBox = $("#Sub_Item_Unit_Id").dxDropDownBox("instance");
        dropDownBox.close();
        var $dataGrid = $("#Frm_GetStockUnits");//Mantis bug 0000347 fixed
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(e.value, false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                var unitName = item.Unit;
                $("#Sub_Item_Unit_Name").val(unitName);
                //SP_ID = item["SP_ID"]
            }
        }
    }

    function Sub_Item_MainCategoryValueChange(e) {
     
        MainCategoryValue = e.value;
        var dropdown = $("#Sub_Item_Main_Category").dxDropDownBox("instance");
        dropdown.close();

        $("#Sub_Item_Sub_Category").dxDropDownBox("instance").reset();
        var $dataGrid1 = $("#Frm_Sub_Category_GridDDL");
        if ($dataGrid1.length) {
            var dataGrid1 = $dataGrid1.dxDataGrid("instance");
            dataGrid1.clearSelection();
            dataGrid1.refresh();
        }//Mantis bug 0000334 fixed

        var $dataGrid = $("#Frm_GetMainCategories");
        if ($dataGrid.length)
        {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(e.value, false);
            if (e.value == null) {
                dataGrid.clearSelection();
            }
            if (dataGrid.getSelectedRowsData().length > 0)
            {
                var item = dataGrid.getSelectedRowsData()[0];
                //MainCategoryValue = Main_Category;
                //resCountryId = item.R_CO_REC_ID;
                $("#Frm_Sub_Category_GridDDL").dxDataGrid("instance");
            }
        }
    };

