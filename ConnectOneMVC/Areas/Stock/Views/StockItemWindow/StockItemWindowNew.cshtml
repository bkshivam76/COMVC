        });
        var key = e.component.option("value");
        if(key!=null)
        {
            if (e.component.getDataSource()!=null) {
                e.component.getDataSource().store().byKey(key).done(function (result) {
                    if (result != null && result != undefined && result != "undefined") {

                        //MainCategoryValue = result.R_CO_CODE;
                        //resCountryId = result.R_CO_REC_ID;
                        MainCategoryValue = e.value;
