@using DevExtreme.AspNet.Mvc
@using Common_Lib;
@model ConnectOneMVC.Areas.Stock.Models.StockItemWindow

@{
    ViewBag.Title = "Index";
    Layout = null;
    var SessionGUID = Request.QueryString["SessionGUID"];
}

@{
    bool IsVisible = Model != null && (Model.ItemMaster_ActionMethod.ToString().Trim() == "_View" || Model.ItemMaster_ActionMethod.ToString().Trim() == "_Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.ItemMaster_ActionMethod == "_View" || Model.ItemMaster_ActionMethod == "_Delete") ? true : false;
}
<script src="~/Content/fontawesome/js/fontawesome_v5_all.js"></script>
