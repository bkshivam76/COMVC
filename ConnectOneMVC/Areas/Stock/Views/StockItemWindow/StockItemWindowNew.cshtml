        OnSuccess = String.Format("{0}", Model.PostSuccessFunction)
    },
    new { id = "stockitemvalidatationForm", @class = "edit_form" }
    ))
    {
        @Html.HiddenFor(x => x.ItemMaster_ActionMethod)
        @Html.HiddenFor(x => x.select_mapped_store_list)
        @Html.HiddenFor(x => x.SubItemID)
