    function SI_FileUpload_Value_Change(e)
    {
        var filename = e.value[0].name;
        var fileExt = (filename.split('.'))[1];
        if (fileExt.Length <= 1)
        {
            DevExpress.ui.dialog.alert('<div class="SIErrorIconInformation">File Without Extension Is Not Allowed...</div>', 'Error!!');
            return;
        }
        var AllowedExtension = ["jpg", "jpeg", "png"];
        if (AllowedExtension.indexOf(fileExt) == -1)
        {
            DevExpress.ui.dialog.alert('<div class="SIErrorIconInformation">Only Files With jpg,jpeg,png Extension Is Allowed..</div>', 'Error!!');
            return;
        }
    }

    function SI_FileUploaded(e)
    {
        $("#si_fileview").load("@Url.Action("SI_PreviewImageControl", "StockItemWindow", new { @area = "Stock" })", function () { });
       // $("#si_fileRemove").show();
        $("#SI_image_CANCEL").dxButton("instance").option("visible", true);
    }

    function OnInitializedMainCategory(e) {
        MainCategoryValue = e.value;
        e.component.option("dataSource").store.load().done(function (d) {
            if (d.length == 1) {
                //e.component.option("value", d[0].R_CO_NAME);
