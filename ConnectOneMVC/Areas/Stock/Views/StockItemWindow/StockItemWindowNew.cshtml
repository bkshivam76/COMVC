                                                                                                                                                                                       .ContentTemplate(@<text> @Html.Partial("GetMainCategories") </text>))
                                        @Html.ValidationMessageFor(model => model.Sub_Item_Main_Category, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="form-field">
                            <div class="container-fluid paddTB2">
                                <div class="row">
                                    <div class="col-sm-4 pll">
                                        <label class="control-label margB0" for="iten">Sub-Category:</label>
                                    </div>
                                    <div class="col-sm-8 prm pll2">
                                        @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("Sub_Item_Sub_Category").Name("Sub_Item_Sub_Category")
