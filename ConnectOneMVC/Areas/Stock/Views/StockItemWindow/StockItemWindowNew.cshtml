    function SI_NEVD_SAVE_CLICK(e) {
   
        var result = DevExpress.ui.dialog.confirm("Sure You Want To Save", "Stock Item");
        result.done(function (dialogResult) {
            var form = $("#stockitemvalidatationForm");
            if (dialogResult) {
                var result = e.validationGroup.validate();
                if (result.isValid) {
                    form.submit();
                }
            }
        });
    }
    function SI_NEVD_Delete_CLICK(e) {
        var form = $("#stockitemvalidatationForm");
        var result = DevExpress.ui.dialog.confirm("Sure You Want To Delete..?", "Delete~Stock ");
        result.done(function (dialogResult) {
            if (dialogResult) {

                form.submit();
            }
            
        });
    }
    function ItemImageEndcallback(s, e)
    {      
        s.SetHeight(($("#itemwindow-left").height())*0.6);
        $("#itemwindow-right").height($("#itemwindow-left").height());
    }

    function Frm_SI_Properties_OnSuccess(data) {

        HideLoader();
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.message, "Error");
        }
        else if (data.result == true) {

            $("#StockIteminnergrid").dxPopup("hide");
            Item_Properties_grid_Data.SetFocusedRowIndex(-1);
            Item_Properties_grid_Data.Refresh();
            //$("#ProductionStoreID").dxDropDownBox("instance").option("readOnly", true);
        }
        else {
            $("#StockIteminnergrid").dxPopup("hide");
            DevExpress.ui.dialog.alert(data.message, "Inform");
            StockItemListGrid.SetFocusedRowIndex(-1);
            StockItemListGrid.Refresh();

            HideLoader();
        }
    }


