<div id="ContentOfItemWindow" class="edit_form">
    @using (Ajax.BeginForm("SaveItemWindow", "StockItemWindow", new AjaxOptions
    {
        HttpMethod = "POST",
        UpdateTargetId = "ContentOfItemWindow",
        InsertionMode = InsertionMode.InsertAfter,
