                                        </div>
                                        <div class="col-sm-3 col-md-3 col-lg-3 ">
                                            <div id="si_fileRemove" align="left">
                                                @(Html.DevExtreme().Button().ID("SI_image_CANCEL").Text("Delete Image").OnClick("SIImageDelete").Visible(!IsVisible))
                                            </div>
                                        </div>
                                            <div class="col-sm-3 col-md-3 col-lg-3 ">
                                            </div>
                                        </div>

</fieldset>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-sm-12">
                    <div class="form-field">
                        <div class="container-fluid multipleSelection">
                            <div class="row">
                                <div class="col-sm-2 pll">
                                    <label class="control-label RegistLabel" for="iten">Mapped Store(s)</label>
                                </div>
                                <div class="col-sm-10 pll">
                                    <div class="form-field">
                                        @(Html.DevExtreme().List().CustomList().ID("Mapped_Store_List").DataSource(d => d.Mvc().Controller("StockItemWindow").LoadAction("GetMappedStoreList").Key("StoreID")).Height(400).SelectionMode(DevExtreme.AspNet.Mvc.ListSelectionMode.All).ShowSelectionControls(true)
                                              .ItemTemplate(@<div><%- Store_Name %></div>).OnSelectionChanged("ListSelection").Disabled(IsDisabled).OnInitialized("Mapped_Store_List_Initialise").SearchEnabled(true).SearchExpr(new[] { "Store_Name" }))
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>              
            </div>
        </div><!--[Row]-->
            <div class="row">
                <div class="form-field">
                    <div class="container-fluid">
                        <div class="col-sm-2 pll">
                            <label class="control-label margB0" for="user">Item Remarks:</label>
                        </div>
                        <div class="col-sm-10 pll">
                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("Sub_Item_Remarks").Name("Sub_Item_Remarks").Value(Model.Sub_Item_Remarks).Disabled(IsDisabled))
                        </div>
                    </div>
                </div>
            </div>
            <div class="row stockItemWindow">
                <div class="form-field">
                    @(Html.DevExtreme().TabPanel().ID("tabpanel").ShowNavButtons(true).ScrollingEnabled(true).SwipeEnabled(false).Items(items =>
                                                                    {
                                                                        items.Add().Title("Item Properties").Template(@<text> @ItemPropertyView() </text>);
                                                                        items.Add().Title("Unit Conversions").Template(@<text> @UnitConversionView() </text>);
                                                                    }).DeferRendering(false))
                    @helper ItemPropertyView()
                    {
                        @Html.Partial("Item_Properties_grid", Model);//Mantis bug 0000347 fixed
                    }
                    @helper UnitConversionView()
                    {
                        @Html.Partial("UnitConversionList_SubItem_Grid", Model);
                    }
                </div><!--[1]-->
            </div>


            <div class="row">
                <div class="col-sm-12 col-md-12 col-lg-12">
                    <div class="styleActionBtn">
                        @if (Model.ItemMaster_ActionMethod == "_Delete")
                        {
                            @(Html.DevExtreme().Button().CustomSaveButton().ID("IDSaveItemWindowNew").Text("Delete").FocusStateEnabled(true).OnClick("SI_NEVD_Delete_CLICK"))
                        }
                        else
                        {
                            @(Html.DevExtreme().Button().CustomSaveButton().ID("IDSaveItemWindowNew").Text("Save").FocusStateEnabled(true).Visible(Model.ItemMaster_ActionMethod == "_View" ? false : true).OnClick("SI_NEVD_SAVE_CLICK"))
                        }
                        @(Html.DevExtreme().Button().CustomCloseButton().ID("StockItemWindow_Cancel").Text(Model.ItemMaster_ActionMethod == "_View" ? "Close" : "Cancel").FocusStateEnabled(true).OnClick("close_StockItemWindow"))
                    </div>
                </div>
            </div><!--[Buttons]-->


    
        }
    }
</div>


