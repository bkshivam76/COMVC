    function Mapped_Store_List_Initialise(e)
    {
    
        var listBox = $("#Mapped_Store_List").dxList("instance");
        if ("@Model.ItemMaster_ActionMethod" == "_Edit" || "@Model.ItemMaster_ActionMethod" == "_View" || "@Model.ItemMaster_ActionMethod" == "_Delete")
