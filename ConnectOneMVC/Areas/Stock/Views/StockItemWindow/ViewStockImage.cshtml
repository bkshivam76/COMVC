    function SI_FileUploaded(e)
    {
        $("#si_fileview").load("@Url.Action("SI_PreviewImageControl", "StockItemWindow", new { @area = "Stock" })", function () { });
        $("#si_fileRemove").show();
    }

    function ItemImageEndcallback(s, e) {
        s.SetHeight((document.documentElement.clientHeight* 0.6));
