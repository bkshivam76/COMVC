@using DevExtreme.AspNet.Mvc
@model ConnectOneMVC.Areas.Stock.Models.GetUnitConversionList_SubItem

@{
    bool IsVisible = Model != null && (Model.ConvertedUnit_ActionMethod.ToString().Trim() == "_View" || Model.ConvertedUnit_ActionMethod.ToString().Trim() == "_Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.ConvertedUnit_ActionMethod == "_View" || Model.ConvertedUnit_ActionMethod == "_Delete") ? true : false;
}
@*//Mantis bug 0000334 fixed*@
<script src="~/Content/fontawesome/js/fontawesome_v5_all.js"></script>
@{
    Html.EnableClientValidation();
    Html.EnableUnobtrusiveJavaScript();
    Html.AntiForgeryToken();
}
<style>
    .pll2 {
        padding-left: 2px !important;
    }

    .margR4 {
        margin-right: 4px;
    }

    #IDUNSaveUnitConversion > div,
    #IDUNClose > div {
        margin-right: 4px !important;
    }
</style>
<div id="Frm_SubItem_Unit_PopUp" class="edit_form">
    @using (Ajax.BeginForm("SaveUnitClick", "StockItemWindow",
                          new AjaxOptions
                          {
                              HttpMethod = "POST",
                              UpdateTargetId = "frm_Item_Window_Add_Unit_PopUp",
                              InsertionMode = InsertionMode.InsertAfter,
                              OnBegin = "AjaxBeginFormPost",
                              OnSuccess = "Frm_SI_Unit_OnSuccess"

                          },
                          new
                          {
                              id = "ID_frm_Item_Window_Add_Unit",
                              @class = "edit_form"
                          }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.ConvertedUnit_ActionMethod)
        @Html.HiddenFor(x => x.ConvertedUnit_SrNo)
        @Html.HiddenFor(x => x.Converted_Unit)
        @Html.HiddenFor(x => x.subitemid)


        var errors = ViewData.ModelState.Where(n => n.Value.Errors.Count > 0).Select(c => c.Value.Errors).ToList();

        using (Html.DevExtreme().ValidationGroup())
        {
            <div class="full-width-header-bg">
                <div class="row">

                    <div class="col-sm-8">
                        <h3 class="popuphead"><i class="far fa-edit"></i> Item Units</h3>
                    </div>
                    <div class="col-sm-4 prm">
                        <h5 class="mand-txt-align"><i class="fas fa-info-circle"></i> Red Fields are mandatory</h5>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="form-field">
                    <div class="container-fluid">
                        <div class="col-sm-3 pll">
                            <label class="control-label" for="user">Item Name:</label>
                        </div>
                        <div class="col-sm-9 prm pll1">
                            @*<div class="dx-texteditor dx-state-readonly dx-widget dx-textbox">
                                    <div class="dx-texteditor-container">
                                        <input class="dx-texteditor-input" type="text" Placeholder="">
                                    </div>
                                </div>*@
                            @(Html.DevExtreme().TextBox().CustomTextBox().ID("Conversion_Item_Name").Name("Conversion_Item_Name").Placeholder("").Value(Model.Conversion_Item_Name).ReadOnly(true).Disabled(IsDisabled))
                        </div>
                    </div>
                </div>
            </div><!--[Row]-->
            <div class="row">
                <div class="form-field">
                    <div class="container-fluid">
                        <div class="col-sm-3 pll">
                            <label class="control-label text-red" for="user">Unit:</label>
                        </div>
                        <div class="col-sm-9 prm pll1">
                            @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("Converted_UnitID").Name("Converted_UnitID").DataSource(d => d.Mvc().Controller("StockItemWindow").LoadAction("GetStockUnits_UnitConversion").Key("Unit_ID"))
                                                                            .OnInitialized("Initialized_Converted_Unit")
                                                                            .OnValueChanged("Primary_Unit_DDL_OnChange1")
                                                                            .Placeholder("Select Unit Here")
                                                                            .Value(Model.Converted_UnitID)
                                                                            .DisplayExpr("Unit")
                                                                            .ValueExpr("Unit_ID")
                                                                            .Disabled(IsDisabled)
                                                                            .ContentTemplate(@<text> @Html.Partial("GetStockUnits_UnitConversion")</text>))@*//Mantis bug 0000347 fixed*@
                                                                            @Html.ValidationMessageFor(model => model.Converted_UnitID, "", new { @class = "text-danger" })
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div><!--[Row]-->
                                                            <div class="row">
                                                                <div class="form-field">
                                                                    <div class="container-fluid">
                                                                        <div class="col-sm-3 pll">
                                                                            <label class="control-label text-red" for="user">Conversion Rate:</label>
                                                                        </div>
                                                                        <div class="col-sm-9 prm pll1">
                                                                            @(Html.DevExtreme().NumberBox().CustomNumberBox().ID("Rate_Of_Conversion").Name("Rate_Of_Conversion").Placeholder("Conversion Rate").Placeholder("Enter Value Here")
.Disabled(IsDisabled).Value(Convert.ToDouble(Model.Rate_Of_Conversion)))
                                                                            @Html.ValidationMessageFor(model => model.Rate_Of_Conversion, "", new { @class = "text-danger" })
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div><!--[Row]-->
                                                            <div class="row">
                                                                <div class="form-field">
                                                                    <div class="container-fluid">
                                                                        <div class="col-sm-3 pll">
                                                                            <label class="control-label text-red" for="user">Effective Date:</label>
                                                                        </div>
                                                                        <div class="col-sm-9 prm pll1">
                                                                            @(Html.DevExtreme().DateBox().CustomDateBox().ID("Effective_Date").Name("Effective_Date").Disabled(IsDisabled)
                                                                                                    .Value(Model.Effective_Date))
                                                                            @Html.ValidationMessageFor(model => model.Effective_Date, "", new { @class = "text-danger" })
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div><!--[Row]-->

                                                            <div class="row">
                                                                <div class="col-sm-12 col-md-12 col-lg-12">
                                                                    <div class="styleActionBtn">
                                                                        @(Html.DevExtreme().Button().CustomSaveButton().ID("IDUNSaveUnitConversion").Text(Model.ConvertedUnit_ActionMethod == "_Delete" ? "Delete" : "Save").FocusStateEnabled(true).UseSubmitBehavior(true).Visible(Model.ConvertedUnit_ActionMethod == "_View" ? false : true))
                                                                        @(Html.DevExtreme().Button().CustomCloseButton().ID("IDUNClose").Text(Model.ConvertedUnit_ActionMethod == "_View" ? "Close" : "Cancel").FocusStateEnabled(true).OnClick(@<text> function () { toCloseUnitConversionPOP() ;  } </text>))
                                                                    </div>
                                                                </div>
                                                            </div><!--[Buttons]-->


                                                          
                                                        }
                                                    }
</div>
    
<script>
    function Primary_Unit_DDL_OnChange1(e) {
        debugger;
        var dropDownBox = $("#Converted_UnitID").dxDropDownBox("instance");
        dropDownBox.close();
        var $dataGrid = $("#Frm_GetStockUnits_UnitConversion");//Mantis bug 0000347 fixed
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(e.value, false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                var unitName = item.Unit;
                $("#Converted_Unit").val(unitName);
                //SP_ID = item["SP_ID"]
            }
        }
    }
    function Initialized_Converted_Unit(e)
    {
        if ("@Model.ConvertedUnit_ActionMethod" != "_New") {
            e.component.option("dataSource").store.load().done(function (d) {
                e.component.option("value", "@Model.Converted_UnitID");
            });
        }
    }//Mantis bug 0000334 fixed

    
    function toCloseUnitConversionPOP()
    {
        //dontaskpopupcloseconfirmation = false;
        $("#StockIteminnergrid").dxPopup("hide");
    }//Mantis bug 0000346 fixed


    var form = "ID_frm_Item_Window_Add_Unit";
    $(document).ready(function () {
        ShowLoader();

        AssignIDtoLabel(form, "ItemUnitConversion");

        if ($("#Sub_Item_Name").dxTextBox("instance")) {

            var Item_Code = $("#Sub_Item_Name").dxTextBox("instance").option("value");

            $("#Conversion_Item_Name").dxTextBox("instance").option("value", Item_Code);
        }

        setTimeout(function ()
            {
            if ("@Model.ConvertedUnit_ActionMethod" == "_View")
            {
                Set_Form_View_Delete_Mode("#000080", form);
            }
            else if ("@Model.ConvertedUnit_ActionMethod" == "_Delete")
            {
                Set_Form_View_Delete_Mode("#696969", form);
            }
            else
            {
                Focus_FirstEditable_Field(form);
            }
            HideLoader();
        }, Timeout500);
    });//Mantis bug 0000347 fixed
    </script>
