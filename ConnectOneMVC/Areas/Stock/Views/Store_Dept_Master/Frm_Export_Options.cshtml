@using DevExtreme.AspNet.Mvc;
<div>
    @(Html.DevExtreme().Button()
                        .ID("sto_ExportGridDatapdf")
                        .Text("Export to PDF")
                        //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                        //.AccessKey("x")
                        .OnClick("ExportPDF")
                        .Visible(true)
                        .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                        .ID("sto_ExportGridDataxls")
                        .Text("Export to XLS")
                        //.Icon("fa-file-excel-o")
                        //.AccessKey("X")
                        .OnClick("ExportXLS")
                        .Visible(true)
                        .Width(120)
    )<br />
    @(Html.DevExtreme().Button()
                        .ID("sto_ExportGridDataxlsx")
                        .Text("Export to XLSX")
                        //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                        //.AccessKey("L")
                        .OnClick("ExportXLSX")
                        .Visible(true)
                        .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                        .ID("sto_ExportGridDatadocx")
                        .Text("Export to DOCX")
                        //.Icon("export_exporttodocx_16x16office2013")
                        //.AccessKey("D")
                        .OnClick("ExportDOCX")
                        .Visible(true)
                        .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                        .ID("sto_ExportGridDatartf")
                        .Text("Export to RTF")
                        //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                        //.AccessKey("R")
                        .OnClick("ExportRTF")
                        .Visible(true)
                        .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                        .ID("sto_ExportGridDatacsv")
                        .Text("Export to CSV")
                        //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                        //.AccessKey("C")
                        .OnClick("ExportCSV")
                        .Visible(true)
                        .Width(120)
    )
</div>
<script>
    function ExportPDF() {
        Store_Dept_MasterListGrid.ExportTo(ASPxClientGridViewExportFormat.Pdf);
        $("#Store_Dept_Master_report_modal").dxPopup("hide");
    }
    function ExportXLS() {
        Store_Dept_MasterListGrid.ExportTo(ASPxClientGridViewExportFormat.Xls);
        $("#Store_Dept_Master_report_modal").dxPopup("hide");
    }
    function ExportXLSX() {
        Store_Dept_MasterListGrid.ExportTo(ASPxClientGridViewExportFormat.Xlsx);
        $("#Store_Dept_Master_report_modal").dxPopup("hide");
    }
    function ExportCSV() {
        Store_Dept_MasterListGrid.ExportTo(ASPxClientGridViewExportFormat.Csv);
        $("#Store_Dept_Master_report_modal").dxPopup("hide");
    }
    function ExportDOCX() {
        Store_Dept_MasterListGrid.ExportTo(ASPxClientGridViewExportFormat.Docx);
        $("#Store_Dept_Master_report_modal").dxPopup("hide");
    }
    function ExportRTF() {
        Store_Dept_MasterListGrid.ExportTo(ASPxClientGridViewExportFormat.Rtf);
        $("#Store_Dept_Master_report_modal").dxPopup("hide");
    }
</script>

