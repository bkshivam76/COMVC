@model ConnectOneMVC.Areas.Stock.Models.Store_Dept_Master_Closure
@using DevExtreme.AspNet.Mvc;
<script src="~/Content/fontawesome/js/fontawesome_v5_all.js"></script>
@{
    Html.EnableClientValidation();
    Html.EnableUnobtrusiveJavaScript();
    Html.AntiForgeryToken();
}

<style>
    .control-label {
        text-align: left !important;
    }
</style>
<div id="Frm_Store_Dept_Master_Closure_Content">
    @using (Ajax.BeginForm("Frm_Store_Dept_Master_Closure_Window", "Store_Dept_Master",
                      new AjaxOptions
                      {
                          HttpMethod = "POST",
                          UpdateTargetId = "Frm_Store_Dept_Master_Closure_Content",
                          InsertionMode = InsertionMode.InsertAfter,
                          OnBegin = "AjaxBeginFormPost",
                          OnSuccess = "Store_Dept_MasterAjaxSuccessForm"
                      },
                      new
                      {
                          id = "Store_Dept_Master_ClosurevalidationForm",
                          @class = "edit_form"
                      }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.SD_ID)
        var errors = ViewData.ModelState.Where(n => n.Value.Errors.Count > 0).Select(c => c.Value.Errors).ToList();
        using (Html.DevExtreme().ValidationGroup())
        {
            <div class="full-width-header">
                <div class="row">

                    <div class="col-sm-8 pll">
                        <h3 class="popuphead"><i class="far fa-edit"></i>Store/Dept. Closure Details </h3>
                    </div>
                    <div class="col-sm-4 prm">
                        <h5 class="mand-txt-align"><i class="fas fa-info-circle"></i> Red Fields are mandatory</h5>
                    </div>
                    @Html.ValidationSummary(true, "", new { @class = "text-red" })
                </div>
            </div><!--[row]-->
            <div class="row">
                <div class="">
                    <div class="col-sm-6 col-md-6 col-lg-6">
                        <div class="form-field">
                            <div class="container-fluid ">
                                <div class="row">
                                    <div class="col-sm-4 col-md-4 col-lg-4 pll">
                                        @Html.LabelFor(model => model.Store_Dept_Name, htmlAttributes: new { @class = "control-label" })@*Mantis bug 0001118 fixed*@
                                    </div>

                                    <div class="col-sm-8 col-md-8 col-lg-8 prm ">

                                        @(Html.DevExtreme().TextBoxFor(x => x.Store_Dept_Name).CustomTextBox().ID("Store_Dept_Name").Name("Store_Dept_Name").MaxLength(255).Value(Model.Store_Dept_Name).ReadOnly(true).Disabled(false) )

                                        @Html.ValidationMessageFor(model => model.SD_ID, "", new { @class = "text-red" })

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div><!--[Store]-->
                    <div class="col-sm-6">
                        <div class="form-field">
                            <div class="container-fluid ">
                                <div class="row">
                                    <div class="col-sm-4 pll">
                                        @Html.LabelFor(model => model.SD_Close_Date, htmlAttributes: new { @class = "control-label text-red" })
                                    </div>
                                    <div class="col-sm-8 prm">
                                        <div class="dx-texteditor dx-widget dx-textbox">
                                            <div class="dx-texteditor-container">
                                                @(Html.DevExtreme().DateBoxFor(model => model.SD_Close_Date).CustomDateBox().ID("SD_Close_Date").Name("SD_Close_Date").Placeholder("Enter Date").InputAttr("class", "dx-texteditor-input").ReadOnly(false).Disabled(false) )
                                                @Html.ValidationMessageFor(model => model.SD_Close_Date, "", new { @class = "text-red " })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div><!--[Date]-->
                </div>
            </div>
            <div class="row">
                <div class="col-sm-12">
                    <div class="form-field">
                        <div class="container-fluid">
                            <div class="row">
                                <div class="col-sm-2 pll">
                                    @Html.LabelFor(model => model.SD_Close_Remarks, htmlAttributes: new { @class = "control-label " })
                                </div>

                                <div class="col-sm-10 prm">

                                    @(Html.DevExtreme().TextBoxFor(x => x.SD_Close_Remarks).CustomTextBox().ID("SD_Close_Remarks").Name("SD_Close_Remarks").Placeholder("Type Reason...").MaxLength(8000).Value(Model.SD_Close_Remarks).ReadOnly(false).Disabled(false) )

                                    @Html.ValidationMessageFor(model => model.SD_Close_Remarks, "", new { @class = "text-red" })

                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div><!--[Remarks]-->

            <div class="row">
                <div class="col-sm-12 col-md-12 col-lg-12">
                    <div class="styleActionBtn">
                        @(Html.DevExtreme().Button().CustomSaveButton().ID("Store_Dept_Master_ClosureNew").Text("Save").FocusStateEnabled(true).UseSubmitBehavior(true) )
                        @(Html.DevExtreme().Button().CustomCloseButton().ID("Store_Dept_Master_ClosureCancel").Text("Cancel").FocusStateEnabled(true).OnClick(@<text> function () { close_storeclose(); } </text>) )
                    </div>
                </div>
            </div><!--[Buttons]-->

     
        }
    }
</div>
<script>
    var form = "Store_Dept_Master_ClosurevalidationForm";
    $(document).ready(function ()
    {
        ShowLoader();
        AssignIDtoLabel(form, "Store_Close");
        setTimeout(function ()
        {     
            Focus_FirstEditable_Field(form);           
            HideLoader();
        }, Timeout500);
    });
    function close_storeclose()
    {
        dontaskpopupcloseconfirmation = false;
        $("#Dynamic_Content_popup").dxPopup("hide");
    }
</script>
