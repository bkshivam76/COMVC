@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool Dept_Store_Add_Rights = (bool)ViewData["Dept_Store_AddRight"];
    bool Dept_Store_Update_Rights = (bool)ViewData["Dept_Store_UpdateRight"];
    bool Dept_Store_View_Rights = (bool)ViewData["Dept_Store_ViewRight"];
    bool Dept_Store_Delete_Rights = (bool)ViewData["Dept_Store_DeleteRight"];
    bool Dept_Store_Export_Rights = (bool)ViewData["Dept_Store_ExportRight"];
    bool Dept_Store_Report_Rights = (bool)ViewData["Dept_Store_ReportRight"];
}
@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "Store_Dept_MasterListGrid";
        settings.CallbackRouteValues = new
        {
            Controller = "Store_Dept_Master",
            Action = "Frm_Store_Dept_Master_Info_Grid",
            SessionGUID = SessionGUID
        };

        settings.SettingsExport.EnableClientSideExportAPI = true;
        settings.SettingsExport.ExcelExportMode = DevExpress.Export.ExportType.DataAware;
        settings.SettingsExport.PageHeader.Center = "Store/Dept. Master Listing";
        settings.SettingsExport.PageHeader.Left = ViewData["StoreMasterExportGridHeaderLeft"].ToString();
        settings.SettingsExport.PageHeader.Right = ViewData["StoreMasterExportGridHeaderRight"].ToString();
        settings.SettingsExport.PageFooter.Right = ViewData["StoreMasterExportGridFooter"].ToString();
        settings.SettingsExport.PaperKind = System.Drawing.Printing.PaperKind.A4Rotated;
        settings.SettingsExport.TopMargin = 10;
        settings.SettingsExport.LeftMargin = 10;
        settings.SettingsExport.RightMargin = 10;
        settings.SettingsExport.BottomMargin = 10;
        settings.CustomDataActionRouteValues = new { Controller = "Store_Dept_Master", Action = "Store_Dept_MasterCustomDataAction" };

        settings.CustomJSProperties = (s, e) =>
        {
            MVCxGridView gridView = (MVCxGridView)s;
            var lastVisibleColumn = gridView.VisibleColumns.LastOrDefault();
            e.Properties["cpLastVisibleColumnIndex"] = lastVisibleColumn != null ? lastVisibleColumn.Index : 0;
            e.Properties["cpHiddenColumnCaptions"] = gridView.AllColumns.Where(c => !c.Visible).ToDictionary(c => c.ToString(), c => c.Index);
        };
        settings.BeforeGetCallbackResult = (s, e) =>
        {
            MVCxGridView gridView = s as MVCxGridView;
            foreach (GridViewDataColumn column in gridView.DataColumns)
            {
                if (column.Visible)
                    column.Settings.AllowSort = DefaultBoolean.True;
                else
                    column.Settings.AllowSort = DefaultBoolean.False;
            }
        };
        settings.PreRender = (s, e) =>
        {
            MVCxGridView grid = (MVCxGridView)s;
            grid.FilterExpression = "";
        };
        settings.FillContextMenuItems = (sender, e) =>
        {
            if (e.MenuType == GridViewContextMenuType.Rows)
            {
                var Additem = e.CreateItem("New", "New");
                if (Dept_Store_Add_Rights) { e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Additem); }
                Additem.Image.IconID = "actions_new_16x16gray";

                var Edititem = e.CreateItem("Edit", "Edit");
                if (Dept_Store_Update_Rights)  { e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Edititem); }
                Edititem.Image.IconID = "actions_edit_16x16devav";

                var Deleteitem = e.CreateItem("Delete", "Delete");
                if (Dept_Store_Delete_Rights)  { e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Deleteitem); }
                Deleteitem.Image.IconID = "actions_delete_16x16devav";

                var Viewitem = e.CreateItem("View", "View");
                if (Dept_Store_View_Rights) { e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Viewitem); }
                Viewitem.Image.IconID = "actions_show_16x16gray";

                var PrintViewitem = e.CreateItem("Export", "ListPreview");
                PrintViewitem.Image.IconID = "actions_export_16x16devav";
                if (Dept_Store_Export_Rights) {e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), PrintViewitem);}

                var CloseItem = e.CreateItem("Close", "Close");
                CloseItem.Image.IconID = "actions_close_16x16devav";
                e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), CloseItem);

                var Closureitem = e.CreateItem("Close Store/Dept.", "CloseStoreDept");
                if (Dept_Store_Update_Rights) e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Closureitem);
                Closureitem.Image.IconID = "actions_delete_16x16gray";

                var Reopenitem = e.CreateItem("Reopen Store/Dept.", "ReopenStoreDept");
                if (Dept_Store_Update_Rights) e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), Reopenitem);
                Reopenitem.Image.IconID = "actions_opendoc_16x16devav";

                var AddInchargeLoc = e.CreateItem("Change Incharge/Location", "AddInchargeLoc");
                if (Dept_Store_Update_Rights) e.Items.Insert(e.Items.IndexOfCommand(GridViewContextMenuCommand.Refresh), AddInchargeLoc);
                // Closureitem.Image.IconID = "actions_delete_16x16gray";


            }
        };
