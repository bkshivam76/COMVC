@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid()
                            .ID("LookUp_Getpremises_List_datagrid").CustomDataGrid()
                         
                            .Columns(columns =>
                            {
                                columns.Add().DataField("Name").Caption("Name");
                                columns.Add().DataField("Premises_Type").Caption("Type");
                                columns.Add().DataField("Premises_Owner").Caption("Owner");
                                columns.Add().DataField("Pre_UID").Caption("UID");
                                columns.Add().DataField("Pre_Address").Caption("Address");
                                columns.Add().DataField("Pre_City").Caption("City");
                                columns.Add().DataField("Pre_State").Caption("State");
                                columns.Add().DataField("ID").Caption("ID").Visible(false);
                            })
                        
                       
                            .Selection(s => s.Mode(SelectionMode.Single))
                     
                           )

