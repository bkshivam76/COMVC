@using DevExtreme.AspNet.Mvc;
<div>
    @(Html.DevExtreme().Button()
                                        .ID("SuppMasBank_ExportGridDatapdf")
                                        .Text("Export to PDF")
                                        //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                                        //.AccessKey("x")
                                        .OnClick("ExportPDF")
                                        .Visible(true)
                                        .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                                        .ID("SuppMasBank_ExportGridDataxls")
                                        .Text("Export to XLS")
                                        //.Icon("fa-file-excel-o")
                                        //.AccessKey("X")
                                        .OnClick("ExportXLS")
                                        .Visible(true)
                                        .Width(120)
    )<br />
    @(Html.DevExtreme().Button()
                                        .ID("SuppMasBank_ExportGridDataxlsx")
                                        .Text("Export to XLSX")
                                        //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                                        //.AccessKey("L")
                                        .OnClick("ExportXLSX")
                                        .Visible(true)
                                        .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                                        .ID("SuppMasBank_ExportGridDatadocx")
                                        .Text("Export to DOCX")
                                        //.Icon("export_exporttodocx_16x16office2013")
                                        //.AccessKey("D")
                                        .OnClick("ExportDOCX")
                                        .Visible(true)
                                        .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                                        .ID("SuppMasBank_ExportGridDatartf")
                                        .Text("Export to RTF")
                                        //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                                        //.AccessKey("R")
                                        .OnClick("ExportRTF")
                                        .Visible(true)
                                        .Width(120)
    )<br />

    @(Html.DevExtreme().Button()
                                        .ID("SuppMasBank_ExportGridDatacsv")
                                        .Text("Export to CSV")
                                        //.Icon(DevExpress.Web.ASPxThemes.IconID.ActionsAdd32x32)
                                        //.AccessKey("C")
                                        .OnClick("ExportCSV")
                                        .Visible(true)
                                        .Width(120)
    )
</div>
<script>
    function ExportPDF() {
        SupplierBankAcccountGrid.ExportTo(ASPxClientGridViewExportFormat.Pdf);
        $("#SupplierBank_report_modal").dxPopup("hide");
    }
    function ExportXLS() {
        SupplierBankAcccountGrid.ExportTo(ASPxClientGridViewExportFormat.Xls);
        $("#SupplierBank_report_modal").dxPopup("hide");
    }
    function ExportXLSX() {
        SupplierBankAcccountGrid.ExportTo(ASPxClientGridViewExportFormat.Xlsx);
        $("#SupplierBank_report_modal").dxPopup("hide");
    }
    function ExportCSV() {
        SupplierBankAcccountGrid.ExportTo(ASPxClientGridViewExportFormat.Csv);
        $("#SupplierBank_report_modal").dxPopup("hide");
    }
    function ExportDOCX() {
        SupplierBankAcccountGrid.ExportTo(ASPxClientGridViewExportFormat.Docx);
        $("#SupplierBank_report_modal").dxPopup("hide");
    }
    function ExportRTF() {
        SupplierBankAcccountGrid.ExportTo(ASPxClientGridViewExportFormat.Rtf);
        $("#SupplierBank_report_modal").dxPopup("hide");
    }
</script>



