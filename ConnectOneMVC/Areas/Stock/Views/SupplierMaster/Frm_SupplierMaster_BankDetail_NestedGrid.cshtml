@{ 
    var SessionGUID = Request.QueryString["SessionGUID"];
    int SupplierID = (int)ViewData["SupplierID"];
}
@Html.DevExpress().GridView(settings =>
{
    settings.Name = "SupplierMaster" + SupplierID ;
    settings.SettingsDetail.MasterGridName = "SupplierMasterListGrid";
    settings.CallbackRouteValues = new
    {
        Controller = "SupplierMaster",
        Action = "Frm_SupplierMaster_BankDetail_NestedGrid",
        SupplierID = SupplierID,
        SessionGUID = SessionGUID
    };//Mantis bug 0001204 fixed
    settings.Width = Unit.Percentage(100);
    settings.KeyFieldName = "ID";
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Bank";
            column.Caption = "Bank";
            //column.Width = 200;
            //column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Branch";
            column.Caption = "Branch";
            // column.Width = 100;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "Account_No";
            column.Caption = "Account_No";
            // column.Width = 80;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "IFSC";
            column.Caption = "IFSC";
            //column.Width = 110;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "ID";
            column.Caption = "ID";
            //column.Width = 110;
            column.Visible = false;
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "AddedBy";
            column.Caption = "Added By";
            column.Visible = false;
            // column.Width = 130;
            //  column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "AddedOn";
            column.Caption = "Add On";
            // column.Width = 130;
            column.Visible = false;
            column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "EditedBy";
            column.Caption = "Edit By";
            // column.Width = 130;
            column.Visible = false;
            //  column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
        }
    });
    settings.Columns.Add(column =>
    {
        {
            column.FieldName = "EditedOn";
            column.Caption = "Edit On";
            // column.Width = 130;
            column.Visible = false;
            column.PropertiesEdit.DisplayFormatString = "dd/MM/yyyy";
        }
    });

    settings.CustomDataActionRouteValues = new { Controller = "SupplierMaster", Action = "BankDetailsCustomDataAction" };
    settings.ClientSideEvents.FocusedRowChanged = "OnBankDetailFocusedRowChange";
    settings.ClientSideEvents.Init = "OnBankDetailInit";
    settings.SettingsBehavior.AllowFocusedRow = true;
    settings.SettingsBehavior.AllowSelectByRowClick = true;
    settings.SettingsBehavior.AllowSelectSingleRowOnly = true;
    settings.SettingsResizing.ColumnResizeMode = DevExpress.Web.ColumnResizeMode.Control;
    settings.SettingsResizing.Visualization = DevExpress.Web.ResizingMode.Live;
    //  settings.ClientSideEvents.RowDblClick = "OnEditButtonClick";
    settings.SettingsCustomizationDialog.ShowColumnChooserPage = true;
    settings.ClientSideEvents.BeginCallback = "BankDetailGrid_BeginCallBack";

}).Bind(Model).GetHtml()


