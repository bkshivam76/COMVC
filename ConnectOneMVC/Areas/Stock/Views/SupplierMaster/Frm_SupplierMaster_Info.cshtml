@using DevExtreme.AspNet.Mvc;
@model IEnumerable<dynamic>
@{    
    bool Supplier_Add_Rights = (bool)ViewData["Supplier_AddRight"];
    bool Supplier_Update_Rights = (bool)ViewData["Supplier_UpdateRight"];
    bool Supplier_View_Rights = (bool)ViewData["Supplier_ViewRight"];
    bool Supplier_Delete_Rights = (bool)ViewData["Supplier_DeleteRight"];
    bool Supplier_Export_Rights = (bool)ViewData["Supplier_ExportRight"];
    bool Supplier_Report_Rights = (bool)ViewData["Supplier_ReportRight"];
    bool Supplier_MappingRight = (bool)ViewData["Supplier_MappingRight"];
 }

<style>


    .dx-toolbar-after .dx-button-content {
        padding-right: 0px !important;
    }

    .padd {
        padding-left: 10px !important;
    }

    .padd85 {
        padding-left: 85px !important;
    }

    /*gp */ 
