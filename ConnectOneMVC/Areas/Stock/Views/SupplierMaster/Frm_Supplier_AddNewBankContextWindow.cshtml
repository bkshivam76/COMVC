    //    var drop_Down = $("#Supplier_Bank_Name").dxDropDownBox("instance");
    //    var $dataGrid = $("#GetBankListDG");
    //    if ($dataGrid.length) {
    //        var dataGrid = $dataGrid.dxDataGrid("instance");
    //        dataGrid.selectRows(drop_Down.option("value"), false);
    //    }
    //}

    function Supplier_RequestBank_Click()
    {
        DevExpress.ui.dialog.alert("Coming Soon..!", "Inform..");

    }

</script>

