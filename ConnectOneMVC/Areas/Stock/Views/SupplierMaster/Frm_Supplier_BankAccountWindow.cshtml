                                                                                <div class="container-fluid AccountH">
                                                                                    <div class="row">
                                                                                        <div class="col-sm-2 pll">
                                                                                            @*<label class="control-label text-red" for="iten">Account Number:</label>*@
                                                                                            @Html.LabelFor(model => model.Supplier_Account_No, htmlAttributes: new { @class = "control-label text-red" })

                                                                                        </div>
                                                                                        <div class="col-sm-10 prm pll2">
                                                                                            <div class="dx-texteditor dx-state-readonly dx-widget dx-textbox">
                                                                                                <div class="dx-texteditor-container">
                                                                                                    @*<input class="dx-texteditor-input" type="text" Placeholder="Enter Account Number">*@
                                                                                                    @(Html.DevExtreme().TextBox().CustomTextBox().ID("Supplier_Account_No").Name("Supplier_Account_No").Value(Model.Supplier_Account_No).Placeholder("Enter Account Number").MaxLength(255).Disabled(IsVisible))
                                                                                                    @Html.ValidationMessageFor(model => model.Supplier_Account_No, "", new { @class = "text-danger" })
                                                                                                </div>
                                                                                            </div>
                                                                                        </div><!--[Priority]-->
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                        <div class="row">
                                                                            <div class="form-field">
                                                                                <div class="container-fluid AccountH">
                                                                                    <div class="row">
                                                                                        <div class="col-sm-2 pll">
                                                                                            @*<label class="control-label" for="iten">IFSC Code:</label>*@
                                                                                            @Html.LabelFor(model => model.Supplier_IFSC_Code, htmlAttributes: new { @class = "control-label" })

                                                                                        </div>
                                                                                        <div class="col-sm-10 prm">
                                                                                            <div class="dx-texteditor dx-state-readonly dx-widget dx-textbox">
                                                                                                <div class="dx-texteditor-container">
                                                                                                    @*<input class="dx-texteditor-input" type="text" Placeholder="Enter IFSC  Code">*@
                                                                                                    @(Html.DevExtreme().TextBox().CustomTextBox().ID("Supplier_IFSC_Code").Name("Supplier_IFSC_Code").Value(Model.Supplier_IFSC_Code).Placeholder("Enter IFSC Code").MaxLength(11).Disabled(IsVisible))

                                                                                                </div>
                                                                                            </div>
                                                                                        </div><!--[Required Delivery Date]-->
                                                                                    </div>
                                                                                </div>
                                                                            </div>
                                                                        </div><!--[Row]-->

                                                                        <div class="row">
                                                                            <div class="col-sm-12 col-md-12 col-lg-12">
                                                                                <div class="styleActionBtn">
                                                                                    @(Html.DevExtreme().Button().CustomSaveButton().ID("SupplierBankDetails_Save").Text(Model.ActionMethod == "Delete" ? "Delete" : "Save").FocusStateEnabled(true).UseSubmitBehavior(true).Visible(Model.ActionMethod == "View" ? false : true))
                                                                                    @(Html.DevExtreme().Button().CustomCloseButton().ID("SupplierBankDetails_Cancled").Text(Model.ActionMethod == "View" ? "Close" : "Cancel").FocusStateEnabled(true).OnClick(@<text> function () { $("#Frm_SupplierBank_Popup").dxPopup("hide"); } </text>))
                                                                                </div>
                                                                            </div>
                                                                        </div><!--[Buttons]-->


                      
                                                                    }
                                                                }
</div>

<script>
    var form = "ID_BankDetails_Window";
    $(document).ready(function ()
    {
        ShowLoader();
        AssignIDtoLabel(form, "SupplierBank");

        setTimeout(function ()
        {
            if ("@Model.ActionMethod" == "View")
            {
                Set_Form_View_Delete_Mode("#000080", form);
            }
            else if ("@Model.ActionMethod" == "Delete")
            {
                Set_Form_View_Delete_Mode("#696969", form);
            }
            else
            {
                Focus_FirstEditable_Field(form);
            }
            HideLoader();
        }, Timeout500);
    });
            function OnInitialized_OnBankNameChanged(e) {        
        if ("@Model.ActionMethod" != "New") {
            $("#Supplier_Bank_Name_ID").dxDropDownBox("instance").option("value", "@Model.Supplier_Bank_Name_ID");//Mantis bug 0000986 fixed
        }              
    }
    function On_BankNameList_Changed(e) {        
        var drop_Down = $("#Supplier_Bank_Name_ID").dxDropDownBox("instance");//Mantis bug 0000986 fixed
       if (drop_Down != undefined && drop_Down != "undefined") {
            drop_Down.close();
        }
        var $dataGrid = $("#GetBankListDG");
    if ($dataGrid.length) {
       
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(drop_Down.option("value"), false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                bankid = item.ID;
                bankname = item.Bank;
                $("#SM_BankName").val(bankname);
                //alert("SM_BankName:- "+$("#SM_BankName").val());
            }
        }
    }
