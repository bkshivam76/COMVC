@using DevExtreme.AspNet.Mvc;
@model ConnectOneMVC.Areas.Stock.Models.SupplierBankAccountDetails
@{
    ViewBag.Test = Model.ActionMethod;
    bool IsVisible = Model != null && (Model.ActionMethod.ToString().Trim() == "View") ? true : false;
}
@{
    Html.EnableClientValidation();
    Html.EnableUnobtrusiveJavaScript();
    Html.AntiForgeryToken();
}
<script src="~/Content/fontawesome/js/fontawesome_v5_all.js"></script>
<style>
    .pll2 {
        padding-left: 2px !important;
    }

    .margR4 {
        margin-right: 4px;
    }

    #SupplierBankDetails_Cancled {
        float: right;
    }

    #Frm_Supplier_BankAccountWindow_Content {
        padding: 0 !important;
    }
</style>
@*<form action="" class="edit_form">*@
<div id="Frm_Supplier_BankAccountWindow_Content" class="col-md-12">
