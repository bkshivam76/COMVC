                                                                                                    </select>*@
                                                                                                @(Html.DevExtreme().TextBox().CustomTextBox().ID("Supplier_Branch_Name").Name("Supplier_Branch_Name").Value(Model.Supplier_Branch_Name).Placeholder("Enter Branch Name").MaxLength(255).Disabled(IsVisible))
