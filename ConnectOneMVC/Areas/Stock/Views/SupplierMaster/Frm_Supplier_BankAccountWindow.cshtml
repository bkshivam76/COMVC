                                            <option value="0">Select Bank Name</option>
                                        </select>*@
                                    @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("Supplier_Bank_Name_ID")
                                                                                                .Name("Supplier_Bank_Name_ID")
