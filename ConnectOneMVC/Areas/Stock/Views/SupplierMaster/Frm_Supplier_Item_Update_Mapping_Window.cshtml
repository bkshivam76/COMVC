@using DevExtreme.AspNet.Mvc;
@using Common_Lib;
@model ConnectOneMVC.Areas.Stock.Models.UpdateItemSupplierMapping
@{
    bool IsVisible = Model != null && ((Model.ActionMethod == "View") || (Model.ActionMethod == "Delete")) ? true : false;
    bool IsDisabled = Model != null && ((Model.ActionMethod == "View") || (Model.ActionMethod == "Delete")) ? true : false;
    bool isvisible = (Model.ActionMethod == "New") ? true : false;
}

@{
    Html.EnableClientValidation();
    Html.EnableUnobtrusiveJavaScript();
    Html.AntiForgeryToken();
}
<script src="~/Content/fontawesome/js/fontawesome_v5_all.js"></script>
<style>
    .pll2 {
        padding-left: 2px !important;
    }

    .margR4 {
        margin-right: 4px;
    }
</style>
<div id="Frm_Item_Supplier_Add_Mapping_Window_Content" class="edit_form">
    @using (Ajax.BeginForm("Frm_Supplier_Item_Update_Mapping_Window", "SupplierMaster",
                    new AjaxOptions
                    {
                        HttpMethod = "POST",
                        UpdateTargetId = "Frm_Item_Supplier_Update_Mapping_Window_Content",
                        InsertionMode = InsertionMode.InsertAfter,
                        OnBegin = "AjaxBeginFormPost",
                        OnSuccess = "OnUpdateItemSupplierMappingAjaxSuccessForm"
                    },
             new
             {
                 id = "SupplierItemMapForm",
                 @class = "edit_form"
             }))
    {

        @Html.HiddenFor(y => y.ActionMethod)
     //   @Html.HiddenFor(x => x.Sr)
        @Html.HiddenFor(x => x.MappingID)
        //    @Html.HiddenFor(model => model.IS_Mapping_Supplier_ID)
        var errors = ViewData.ModelState.Where(n => n.Value.Errors.Count > 0).Select(c => c.Value.Errors).ToList();
        using (Html.DevExtreme().ValidationGroup())
        {

            <div class="full-width-header-bg">
                <div class="row">
                    <div class="col-sm-8">
                        <h3 class="popuphead"><i class="far fa-edit"></i> Supplier Details</h3>
                    </div>
                    <div class="col-sm-4 prm">
                        <h5 class="mand-txt-align"><i class="fas fa-info-circle"></i> Red Fields Are Mandatory</h5>
                    </div>
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                </div>
            </div><!--[Header]-->
            <div class="row">
                <div class="form-field">
                    <div class="container-fluid">
                        <div class="col-sm-2 pll">
                            @Html.LabelFor(model => model.UIS_Mapping_Item_ID, htmlAttributes: new { @class = "control-label text-red" })
                        </div>
                        <div class="col-sm-8 prm">
                            <div class="dx-texteditor  dx-widget dx-textbox">
                                <div class="dx-texteditor-container">
                                    @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("UIS_Mapping_Item_ID").Name("UIS_Mapping_Item_ID").Placeholder("Select Item").DataSource(d => d.Mvc().Controller("SupplierMaster").LoadAction("Get_Update_Supp_Map_ItemName").Key("Item_ID"))
                                                                                          .ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).ValueExpr("Item_ID").Value(Model.UIS_Mapping_Item_ID).DisplayExpr("Stock_Item_Name").OnValueChanged("Lookup_Get_SupplierMapping_ItemName")
                                                                                       .Disabled(IsVisible).ReadOnly(IsVisible).ContentTemplate(@<text> @Html.Partial("Get_Update_Supp_Map_ItemName") </text>))@*Mantis bug 0000990 fixed*@
                                                                                    @Html.ValidationMessageFor(model => model.UIS_Mapping_Item_ID, "", new { @class = "text-danger" })
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                        <div class="col-sm-2 prm ">

                                                                            @(Html.DevExtreme().Button().Text("Add Item").Disabled(IsVisible).OnClick(@<text>function() { addItem_ItemSupplierMapping(); }</text>))

                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div><!--[Stock Item]-->
                                                            <div class="row">
                                                                <div class="form-field">
                                                                    <div class="container-fluid">
                                                                        <div class="col-sm-2 pll">
                                                                            @Html.LabelFor(model => model.USI_Mapping_Supplier_ID, htmlAttributes: new { @class = "control-label text-red" })
                                                                        </div>
                                                                        <div class="col-sm-8 prm">
                                                                            <div class="dx-texteditor  dx-widget dx-textbox">
                                                                                <div class="dx-texteditor-container">
                                                                                    @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("USI_Mapping_Supplier_ID").Name("USI_Mapping_Supplier_ID").Placeholder("Select Suppliers here").DataSource(d => d.Mvc().Controller("SupplierMaster").LoadAction("Get_Update_SI_Supplier").Key("ID"))
                                                                                                                                          .ValueExpr("ID").DisplayExpr("Supplier").OnValueChanged("MappedSupplierList_Changed").Value(Model.USI_Mapping_Supplier_ID).ContentTemplate(@<text> @Html.Partial("Get_Update_SI_Supplier") </text>)
.ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }).Disabled(IsVisible).ReadOnly(IsVisible))
                                                                                    @Html.ValidationMessageFor(model => model.USI_Mapping_Supplier_ID, "", new { @class = "text-danger" })

                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                        <div class="col-sm-2 prm ">

                                                                            @(Html.DevExtreme().Button().Text("Add Supplier").Disabled(IsVisible).OnClick(@<text>function() { addSupplier_ItemSupplierMapping(); }</text>))

                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div><!--[Mapped Supplier]-->
                                                            <div class="row">
                                                                <div class="form-field">
                                                                    <div class="container-fluid">
                                                                        <div class="col-sm-2 pll">
                                                                            @Html.LabelFor(model => model.UIS_Mapping_Remarks, htmlAttributes: new { @class = "control-label" })

                                                                        </div>
                                                                        <div class="col-sm-10 prm pll1">
                                                                            <div class="dx-texteditor dx-widget dx-textbox">
                                                                                <div class="dx-texteditor-container">
                                                                                    @(Html.DevExtreme().TextBox().CustomTextBox().ID("UIS_Mapping_Remarks").Name("UIS_Mapping_Remarks").Value(Model.UIS_Mapping_Remarks).Disabled(IsVisible).ReadOnly(IsVisible).MaxLength(8000).Placeholder("Type Remarks").Value("").ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } }))

                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div><!--[Remarks]-->

                                                            <div class="row">
                                                                <div class="col-sm-12 col-md-12 col-lg-12">
                                                                    <div class="styleActionBtn">
                                                                        @(Html.DevExtreme().Button().CustomSaveButton().ID("SupplierItemMappingID_Save").Text(Model.ActionMethod == "Delete" ? "Delete" : "Save").FocusStateEnabled(true).UseSubmitBehavior(true).Visible(Model.ActionMethod == "View" ? false : true))
                                                                        @(Html.DevExtreme().Button().CustomCloseButton().ID("SupplierItemMappingViewCancel").Text(Model.ActionMethod == "View" ? "Close" : "Cancel").FocusStateEnabled(true).OnClick(@<text> function () { $("#Dynamic_Content_popup").dxPopup("hide"); } </text>))
                                                                    </div>
                                                                </div>
                                                            </div><!--[Buttons]-->
            
                                                       }
                                                    }
</div>

<script>
    var form = "SupplierItemMapForm";
        $(document).ready(function ()
        {
            ShowLoader();
            AssignIDtoLabel(form, "ItemMapping");
            setTimeout(function ()
            {
                if ("@Model.ActionMethod" == "View")
                {
                    Set_Form_View_Delete_Mode("#000080", form);
                }
                else if ("@Model.ActionMethod" == "Delete")
                {
                    Set_Form_View_Delete_Mode("#696969", form);
                }
                else
                {
                    Focus_FirstEditable_Field(form);
                }
                HideLoader();
            }, Timeout500);
        });
    function Lookup_Get_SupplierMapping_ItemName(e) {
        var drop_Down = $("#UIS_Mapping_Item_ID").dxDropDownBox("instance");
        drop_Down.close();
        if (e.previousValue != null && e.previousValue != e.value) {
            $("#USI_Mapping_Supplier_ID").dxDropDownBox("instance").reset();
        }
        var $dataGrid = $("#GetUpdateItemNameDG")
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            // dataGrid.selectRows(drop_Down.option("value"), false);
            dataGrid.selectRows(e.value, false);
        }
    }
    function On_MappedSupplierList_Init(e) {
    }
    function MappedSupplierList_Changed(e) {
        var drop_Down = $("#USI_Mapping_Supplier_ID").dxDropDownBox("instance");
        drop_Down.close();
        
        var $dataGrid = $("#GetUpdateSupplierMapDG");
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(drop_Down.option("value"), false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                item = dataGrid.getSelectedRowsData()[0];
                
            }
        }
    }
    
    function close_SupplierItemMappingNEVD() {
        $("#Dynamic_Content_popup").dxPopup("hide");

    }
    function addItem_ItemSupplierMapping() {
        DevExpress.ui.dialog.alert("Coming soon...!", 'Inform!');
    }
    function addSupplier_ItemSupplierMapping() {
        DevExpress.ui.dialog.alert("Coming soon...!", 'Inform!');
    }
</script>

