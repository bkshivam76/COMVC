@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                                .ID("GetPersonNameDG")
                              
                                .Columns(columns =>
                                {

                                    columns.Add().DataField("Name").Caption("Name");
                                    columns.Add().DataField("Address").Caption("Address").Visible(false);
                                    columns.Add().DataField("City").Caption("City").Visible(true);
                                    columns.Add().DataField("State").Caption("State").Visible(false);
                                    columns.Add().DataField("Country").Caption("Country").Visible(false);
                                    columns.Add().DataField("Pan_No").Caption("Pan No.").Visible(true);
                                    columns.Add().DataField("ContactNo").Caption("Contact No.").Visible(true);
                                    columns.Add().DataField("Email").Caption("Email ID").Visible(false);
                                    columns.Add().DataField("ID").Visible(false);

                                })
                              
                                .Selection(s => s.Mode(SelectionMode.Single))                              
                        
)




