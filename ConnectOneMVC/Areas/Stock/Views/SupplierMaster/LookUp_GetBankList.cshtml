@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                                    .ID("GetBankListDG")
                                 
                                    .Columns(columns =>
                                    {                                          

                                        columns.Add().DataField("Bank").Caption("Bank");
                                        columns.Add().DataField("ShortName").Caption("ShortName");
                                        columns.Add().DataField("ID").Caption("ID");                                       

                                    })
                                 
                                    .Selection(s => s.Mode(SelectionMode.Single))
                            
)





