@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                                                .ID("GetAddSupplierItemNameDG")

                                                .Columns(columns =>
                                                {

                                                    columns.Add().DataField("Stock_Item_Name").Caption("Stock Item Name");
                                                    // columns.Add().DataField("Item_Type").Caption("Item Type").Width(100);
                                                    columns.Add().DataField("Item_Category").Caption("Item Category");
                                                    columns.Add().DataField("Item_Code").Caption("Item Code");
                                                    columns.Add().DataField("Item_ID").Caption("Item_ID").Visible(false);

                                                })

                                                   .HoverStateEnabled(true)
                                                   .Paging(p => p.PageSize(10))
                                                   .Height(345)
                                                   .FilterRow(f => f.Visible(true))
                                                   .Selection(s => s.Mode(SelectionMode.Multiple))
                                                   .SelectedRowKeys(new JS(@"component.option(""value"")"))
                                                   .Scrolling(s => s.Mode(GridScrollingMode.Infinite))
                                                   .OnSelectionChanged(@<text>
                                                            function(selectedItems) {
                                                            var keys = selectedItems.selectedRowKeys;
                                                            component.option("value", keys);
                                                            }
                                                        </text>)

)







