@using DevExtreme.AspNet.Mvc
@model ConnectOneMVC.Areas.Stock.Models.UOOrderItemDetails
<style>
    .dx-button-has-icon .dx-button-content {
        padding-right: 8px !important;
    }

    .dx-toolbar-after .dx-button-content {
        padding-right: 0px !important;
    }
</style>
@{
    Html.EnableClientValidation();
    Html.EnableUnobtrusiveJavaScript();
    Html.AntiForgeryToken();
}
<link href="/content/fontawesome/css/fontawesome-all.css" rel="stylesheet">
<div id="id_UOstatus" class="edit_form">
    @using (Ajax.BeginForm("ApproveItemsPartially", "UserOrder",
              new AjaxOptions
              {
                  HttpMethod = "POST",
                  UpdateTargetId = "UO_ApproveItemPartially_Window",
                  InsertionMode = InsertionMode.InsertAfter,
                  OnBegin = "AjaxBeginFormPost",
                 // OnSuccess = "UO_ApprovedQtyAjaxSuccessForm"
              },
               new
               {
                   id = "uoapvalidationForm",
                   @class = "edit_form"
               }))
    {

        @Html.HiddenFor(x => x.UOid)
        @Html.HiddenFor(x => x.UO_Schedule_Item_ID)
        using (Html.DevExtreme().ValidationGroup())
        {
            <div class="full-width-header-bg2">
                <div class="row">

                    <div class="col-sm-8">
                        <h3 class="popuphead"><i class="far fa-edit"></i> UO Status Change</h3>
                    </div>
                    <div class="col-sm-4 prm">
                        <h5 class="mand-txt-align">
                            <i class="fas fa-info-circle"></i> Red Fields are mandatory
                        </h5>
                    </div>
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                </div>
            </div><!--[Header]-->

            <div class="row formRow">


                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label" for="user">Approved Quantity</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm pll2">
                        @(Html.DevExtreme().NumberBox().CustomNumberBox()
                                                                                    .ID("OT_Approved_Qty")
                                                                                    .Name("OT_Approved_Qty")
                                                                                    .Value(Model.OT_Approved_Qty)
                                                                                    .Format("##0")
                        )
                        @Html.ValidationMessageFor(model => model.OT_Approved_Qty, "", new { @class = "text-danger" })

                    </div>
                </div><!--[2]-->

            </div><!--[row5]-->


            <div class="row">
                <div class="form-field wbg brd-bot-none">
                    <div class="col-lg-6 col-xs-12"></div>
                    <div class="col-lg-6 col-xs-12">
                        <div class="action-btn-wrap">
                            @(Html.DevExtreme().Button().CustomCloseButton().ID("IDas_CancelUO_Cancel").Text("Cancel").ElementAttr("style", "float:right;margin-left:5px;margin-right:0px;margin-top:0px").FocusStateEnabled(true).OnClick(@<text> function () { $("#UserOrderinnergrid").dxPopup("hide"); } </text>) )
                        </div>
                        <div class="action-btn-sec-wrap">
                            @(Html.DevExtreme().Button().CustomSaveButton().ID("IDas_CancelUO_Save").Text("Ok").ElementAttr("style", "float:right;margin-top:0px").FocusStateEnabled(true).OnClick(@<text>
                                    function () {
                                    UO_AppovePartially_SAVE_CLICK()
                                    }
                            </text>))
                        </div>
                    </div>
                    <div class="clear"></div>
                </div>
            </div>


        }
    }

</div>
<script>
    var AppVal;
    $(document).ready(function () {
        setTimeout(function () {
            $("#OT_Approved_Qty").dxNumberBox("instance").focus();
        }, Timeout500);
    });
    

    function UO_AppovePartially_SAVE_CLICK(e) {
        debugger

        var form = $("#uoapvalidationForm");
        UOScheduleItemID = "@Model.UO_Schedule_Item_ID";

        scheduleFinalID = (UOScheduleItemID.split(','));
        for (var i = 0; i < scheduleFinalID.length; i++) {
            scheduleFinalID[i] = scheduleFinalID[i].trim();
        }

        AppVal = $("#OT_Approved_Qty").dxNumberBox("instance").option("value");
        alert(AppVal);
        debugger
        $.ajax({
            type: 'POST',
            url: "/Stock/UserOrder/ApproveItemsPartially_Save",
            data: {
                ApprovedValue: AppVal, UO_Item_ID: scheduleFinalID,

            },
            success: function (data) {
                if (data.result == false) {
                    DevExpress.ui.dialog.alert(data.message, "Error");
                }
                else if (data.result == true) {
                    $("#UserOrderinnergrid").dxPopup("hide");
                    DevExpress.ui.dialog.alert(data.message, "Inform");
                    Order_Item_Grid.SetFocusedRowIndex(-1);
                    Order_Item_Grid.Refresh();
                }
                

            },

        });


    }
  
    //function UO_ApprovedQtyAjaxSuccessForm(data) {
    //    debugger
    //    if (data.result == true) {
    //        value = data.value;
           

    //    }

        //else {
        //    DevExpress.ui.dialog.alert("Approved Qty added Successfully", 'Success..');
        //    $("#UserOrderinnergrid").dxPopup("hide");
        //    Order_Item_Grid.Refresh();
        //}
    
  
</script>


