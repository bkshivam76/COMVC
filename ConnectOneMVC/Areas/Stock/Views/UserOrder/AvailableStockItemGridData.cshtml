@{
    var SessionGUID = Request.QueryString["SessionGUID"];
    bool DBData = ViewBag.DBData == null ? true : ViewBag.DBData;
}
@Html.DevExpress().GridView(
    settings =>
    {
        settings.Name = "StockAvlItemListGrid";
        settings.CallbackRouteValues = new
        {
            Controller = "UserOrder",
            Action = "AvailableStockItemGridData",
            SessionGUID = SessionGUID
        };
        settings.CustomActionRouteValues = new { Controller = "UserOrder", Action = "CA_Item_Grid_Custom_Data" };
        settings.Settings.VerticalScrollBarMode = ScrollBarMode.Auto;
        settings.Settings.HorizontalScrollBarMode = ScrollBarMode.Visible;
        settings.Settings.VerticalScrollableHeight = 100;
        settings.KeyboardSupport = true;
        //settings.AccessKey = "G";
        settings.Width = System.Web.UI.WebControls.Unit.Percentage(100);
        settings.Settings.ShowGroupFooter = GridViewGroupFooterMode.VisibleAlways;
        settings.SettingsBehavior.AutoExpandAllGroups = false;
        settings.Settings.UseFixedTableLayout = true;
        settings.SettingsBehavior.ColumnMoveMode = GridColumnMoveMode.AmongSiblings;
        settings.SettingsBehavior.AllowSort = true;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsResizing.ColumnResizeMode = ColumnResizeMode.NextColumn;
        settings.SettingsResizing.Visualization = ResizingMode.Live;
        settings.SettingsBehavior.AllowEllipsisInText = true;
        settings.SettingsPager.Mode = GridViewPagerMode.ShowAllRecords;
        settings.SettingsSearchPanel.ShowApplyButton = true;
        settings.SettingsSearchPanel.ShowClearButton = true;
        settings.SettingsBehavior.AllowFocusedRow = true;
        settings.SettingsBehavior.AllowSelectSingleRowOnly = false;
        settings.Settings.ShowHeaderFilterButton = true;
        settings.SettingsBehavior.AllowSelectByRowClick = true;
        settings.Settings.ShowFilterRow = false;
        settings.ClientSideEvents.FocusedRowChanged = "AvailableStockFocusedRowChanged";
        settings.Settings.ShowHeaderFilterBlankItems = false;
        settings.SettingsContextMenu.Enabled = false;
        settings.SettingsBehavior.EnableCustomizationWindow = true;
        settings.SettingsContextMenu.RowMenuItemVisibility.DeleteRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.EditRow = false;
        settings.SettingsContextMenu.RowMenuItemVisibility.NewRow = false;
        settings.SettingsCustomizationDialog.ShowColumnChooserPage = true;
        settings.CommandColumn.Visible = false;
        settings.CommandColumn.ShowSelectCheckbox = false;

        settings.BeforeGetCallbackResult = (s, e) =>
        {
            MVCxGridView gridView = s as MVCxGridView;
            foreach (GridViewDataColumn column in gridView.DataColumns)
            {
                if (column.Visible)
                    //column.Settings.SortMode = DevExpress.XtraGrid.ColumnSortMode.Custom;
                    column.Settings.AllowSort = DefaultBoolean.True;
                else
                    column.Settings.AllowSort = DefaultBoolean.False;
            }
        };
        settings.PreRender = (sender, e) =>
        {
            ASPxGridView grid = (ASPxGridView)sender;
            grid.FocusedRowIndex = -1;
        };

        settings.KeyFieldName = "StockID";

        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Stock_Item_Name";
                column.Caption = "Item Name";
                column.Width = 130;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Item_Code";
                column.Caption = "Item Code";
                column.Width = 110;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Make";
                column.Caption = "Make";
                column.Width = 100;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Model";
                column.Caption = "Model";
                column.Width = 100;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "CenterName";
                column.Caption = "CenterName";
                column.Width = 100;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "StoreName";
                column.Caption = "StoreName";
                column.Width = 100;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "Dept";
                column.Caption = "Dept";
                column.Width = 100;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "AvlbQty";
                column.Caption = "AvlbQty";
                column.Width = 100;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "LocationName";
                column.Caption = "LocationName";
                column.Width = 100;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "ItemID";
                column.Caption = "ItemID";
                column.Width = 100;
            }
        });
        settings.Columns.Add(column =>
        {
            {
                column.FieldName = "StoreID";
                column.Caption = "StoreID";
                column.Visible = false;
            }
        });
        settings.Columns.Add(column =>
        {
            column.FieldName = "StockID";
            column.Caption = "StockID";
            column.Width = 150;
        });

        // settings.ClientSideEvents.SelectionChanged = "function(s,e){ s.GetSelectedFieldValues('ItemID;UnitID;StoreIDs_Mapped;Stock_Item_Name;Item_Category', OnGetValues); }";
        settings.ClientSideEvents.BeginCallback = "CA_UserOrderGrid_BeginCallBack";
        settings.ClientSideEvents.Init = "CheckAvlOnInit";
    }).Bind(Model).GetHtml()
