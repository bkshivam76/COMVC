ce").focus();                                }                            });                        }                        else {                            $("#UO_StatusButtonClick").val("Cancel");                            form.submit();                        }                    }                }            })    }    function UO_Add_Requestor_Click()    {        if ("@UO_AddPersonnelRight" != "True") {                DevExpress.ui.dialog.alert('Not Allowed', 'No Rights');                return;        }        ShowLoader();        $.ajax({            type: "GET",            url: "/Stock/PersonnelMaster/Frm_PersonnelMaster_Window",            data: {                ActionMethod: "New",                ID: 0,                PostSucessFunction: "StockMaster_Personnel_NEVD_Window_OnSuccess",                PopupName: "Stockpersonnel_NEVD"            },            success: function (data) {                OpenPopup("Stockpersonnel_NEVD", "New ~ Personnel", null, "auto", "85%", true, data);            }        });    }    async function StockMaster_Personnel_NEVD_Window_OnSuccess(data) {        try {            HideLoader();            if (data.result == true) {                $("#Stockpersonnel_NEVD").dxPopup("hide");                await Refresh_Requestors_Name_DG();            }            else {                DevExpress.ui.dialog.alert(data.Message, "Error");            }        }        catch (e) {            console.log(e);        }    }    function UO_Add_Job_Click()    {        if ("@UO_AddJobRight" != "True") {                DevExpress.ui.dialog.alert('Not Allowed', 'No Rights');                return;            }            ShowLoader();            $.ajax({                type: "GET",                url: "/Stock/JobRequestRegister/Frm_NEVD_Job_Request",                data: {                    ActionMethod: "New",                    ID: 0,                    CallingScreen: "UserOrder",