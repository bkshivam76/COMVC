rid.getSelectedRowsData().length > 0) {                    var item = dataGrid.getSelectedRowsData()[0];                    var storename = item.Store_Name;                    Requestee_Store_ID = item.StoreID;                    StoreInchargeName = item.Store_Incharge_ID;                    StoreID = item.StoreID;                }            }            $.ajax({                type: 'GET',                url: "/Stock/UserOrder/NewRequesteeStoreItemCheck",                data: {                    NewStoreID: StoreID,                },                cache: false,                success: function (res) {                    if (res.result == true) {                        $("#UORequest_Store").val(storename);                        $("#UOStoreIncharge_Name_Id").val(StoreInchargeName);                    }                    else if (res.result == false) {                        DevExpress.ui.dialog.alert("New Requestee Store Not contain all items ", 'Alert');                        $("#UORequest_Store_Id").dxDropDownBox("instance").reset();                    }                }            });            Checkuostorekeeper();        }        else if (e.previousValue == null || e.previousValue == e.value) {            var dropDownBox = $("#UORequest_Store_Id").dxDropDownBox("instance");            dropDownBox.close();            var $dataGrid = $("#LookUp_GetStoreNames_datagrid");            if ($dataGrid.length) {                var dataGrid = $dataGrid.dxDataGrid("instance");                dataGrid.selectRows(dropDownBox.option("value"), false);                if (dataGrid.getSelectedRowsData().length > 0) {                    var item = dataGrid.getSelectedRowsData()[0];                    var storename = item.Store_Name;                    $("#UORequest_Store").val(storename);                    Requestee_Store_ID = item.StoreID;                    StoreInchargeName = item.Store_Incharge_ID;                   