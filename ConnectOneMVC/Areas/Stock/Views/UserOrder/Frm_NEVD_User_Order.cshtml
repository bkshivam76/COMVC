            {            @(Html.DevExtreme().Button().ID("UOId_createrr").Text("Create Requisition Request").OnClick("UO_Create_RR").Visible(false))            @(Html.DevExtreme().Button().ID("UOId_Approve").Text("Approve").OnClick("UO_Approve_click").Visible(false))            @(Html.DevExtreme().Button().ID("UOIDReject").Text("Reject").OnClick("UO_Reject_click").Visible(false) )            @(Html.DevExtreme().Button().ID("UOIDCancel").Text("Cancel").OnClick("UO_Cancel_click").Visible(false))            @(Html.DevExtreme().Button().ID("UOIDComplete").Text("Mark As Complete").OnClick("UO_Completed_click").Visible(false))            @(Html.DevExtreme().Button().ID("UOId_changesrec").Text("Changes Recommended").OnClick("UO_ChangesRec_click").Visible(false))            @(Html.DevExtreme().Button().ID("UOId_Reopen").Text("Reopen").OnClick("UO_Reopen_click").Visible(false))            }            @if (Model.UO_ActionMethod.Trim() == "New" || Model.UO_ActionMethod.Trim() == "Edit")            {            @(Html.DevExtreme().Button().CustomSaveButton().Text("Save").ID("UO_Save").FocusStateEnabled(true).UseSubmitBehavior(false).OnClick("UO_NEVD_SAVE_CLICK"))            @(Html.DevExtreme().Button().CustomCloseButton().Text("Cancel").ID("SaveUO_Cancle").FocusStateEnabled(true).OnClick("close_UONEVD"))            }            @if (Model.UO_ActionMethod.Trim() == "Delete")            {            @(Html.DevExtreme().Button().CustomSaveButton().Text("Delete").ID("UO_Delete").FocusStateEnabled(true).UseSubmitBehavior(false).OnClick("delete_UONEVD"))            @(Html.DevExtreme().Button().CustomCloseButton().Text("Cancel").ID("DeleteUO_Cancle").FocusStateEnabled(true).OnClick("close_UONEVD"))            }            @if (Model.UO_ActionMethod.Trim() == "View")            {            @(Html.DevExtreme().Button().CustomCloseButton().Text("Close").ID("ViewUO_Cancle").FocusStateEnabled(true).OnClick("close_UONEVD"))            }        </div