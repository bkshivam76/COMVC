r").val(true); is_Store_Keeper = true;            }            if ("@Model.is_Store_Keeper" != "True") {                $("#is_Store_Keeper").val(false); is_Store_Keeper = false;            }            if ("@Model.is_Store_KeeperIncharge" == "True") {                $("#is_Store_KeeperIncharge").val(true); is_Store_KeeperIncharge = true;            }            if ("@Model.is_Store_KeeperIncharge" != "True") {                $("#is_Store_KeeperIncharge").val(false); is_Store_KeeperIncharge = false;            }            UOSetControlStateAsperRole();        }    }    function UOSetControlStateAsperRole() {        if ("@Model.UO_ActionMethod" == "Edit") {            if (is_Requestor) {                var tabPanel = $("#UserOrdertabpanel").dxTabPanel("instance");                tabPanel.option("items[2].disabled", false);                tabPanel.option("items[3].disabled", false);                tabPanel.option("selectedIndex", 1);                $('#UOIDCancel').dxButton("instance").option('visible', true);                $('#UOIDComplete').dxButton("instance").option('visible', true);                $('#UOId_Reopen').dxButton("instance").option('visible', true);                //for item                $('#But_UO_Item_Rec_All').dxButton("instance").option('visible', true);                $('#But_UO_Item_Rec').dxButton("instance").option('visible', true);            }            if (is_RequestorIncharge) {                var tabPanel = $("#UserOrdertabpanel").dxTabPanel("instance");                tabPanel.option("items[2].disabled", false);                tabPanel.option("items[3].disabled", false);                tabPanel.option("selectedIndex", 1);                $('#UOIDReject').dxButton("instance").option('visible', true);                $('#UOIDComplete').dxButton("instance").option('visible', true);                $('#UOId_changesrec').dxButton("instance").option('visible', true);                $('#UOId_Approve').dxButton("instance").option('visible', true);                $('#UOId_Reopen').dxButton("instance").option('visible', true);                //for item                $('#But_UO_Item_Rec_All').dxButton("instance").option('visible', true);                $('#But_UO_Item_Rec').dxButton("instance").option('visible', true);            }            if (!(is_Requestor)) {                hideButton('#UOIDCancel');                if (!(is_RequestorIncharge)) {                    hideButton('#But_UO_Item_Rec_All');                    hideButton('#But_UO_Item_Rec');                    var tabPanel = $("#UserOrdertabpanel").dxTabPanel("instance");                    tabPanel.option("items[2].disabled", true);                    tabPanel.option("items[3].disabled", true);                }            }            if (!(is_RequestorIncharge)) {                if (!(is_Store_Keeper)) {                    if (!(is_Store_KeeperIncharge)) {                        $('#UOIDReject').dxButton("instance").option('visible', false);                        $('#UOId_changesrec').dxButton("instance").option('visible', false);                        $('#UOId_Approve').dxButton("instance").option('visible', false);                    }                }            }            if ((is_Store_Keeper) || (is_Store_KeeperIncharge)) {                var tabPanel = $("#UserOrdertabpanel").dxTabPanel("instance");                tabPanel.option("items[4].disabled", false);                tabPanel.option("items[5].disabled", false);                tabPanel.option("items[6].disabled", false);                tabPanel.option("selectedIndex", 1);                $('#UOIDReject').dxButton("instance").option('visible', true);                $('#UOId_Reopen').dxButton("instance").option('visible', true);                $('#UOId_changesrec').dxButton("instance").option('visible', true);                $('#UOId_createrr').dxButton("instance").option('visible', true);                $('#UOId_Approve').dxButton("instance").option('visible', true);                $('#UOIDComplete').dxButton("instance").option('visible', true);                //for item                $('#But_UO_Item_Deli_All').dxButton("instance").option('visible', true);                $('#But_UO_Item_Deliver').dxButton("instance").option('visible', true);                $('#But_UO_Item_Crea_RR_sel').dxButton("instance").option('visible', true);                $('#But_UO_Item_Merge_Sel_RR').dxButton("instance").option('visible', true);                $('#But_UO_Item_Unmap_Sel_RR').dxButton("instance").option('visible', true);                $('#But_UO_Item_Approve_All').dxButton("instance").option('visible', true);                $('#But_UO_Item_Approve').dxButton("instance").option('visible', true);                $('#But_UO_Item_Approve_Partially').dxButton("instance").option('visible', true);                $('#But_UO_Item_Rej_All').dxButton("instance").option('visible', true);                $('#But_UO_Item_Reject').dxButton("instance").option('visible', true);                $('#But_UO_Item_Schedule_Delivery').dxButton("instance").option('visible', true);                if ((!is_Requestor) && (!is_RequestorIncharge)) {                    $('#UORequest_Store_Id').dxDropDownBox("instance").option("readOnly", true); // requestee store                }            }            if (!(is_Store_Keeper)) {                if (!(is_Store_KeeperIncharge)) {                    var tabPanel = $("#UserOrdertabpanel").dxTabPanel("instance");                    tabPanel.option("items[4].disabled", true);                    tabPanel.option("items[5].disabled", true);                    tabPanel.option("items[6].disabled", true);                    tabPanel.option("selectedIndex", 1);                    hideButton('#UOId_createrr');                    $('#UORequest_Store_Id').dxDropDownBox("instance").option("readOnly", false); // requestee store                    //for item                    hideButton('#But_UO_Item_Deli_All');                    hideButton('#But_UO_Item_Deliver');                    hideButton('#But_UO_Item_Crea_RR_sel');                    hideButton('#But_UO_Item_Merge_Sel_RR');                    hideButton('#But_UO_Item_Unmap_Sel_RR');                    hideButton('#But_UO_Item_Approve_All');                    hideButton('#But_UO_Item_Approve');                    hideButton('#But_UO_Item_Approve_Partially');                    hideButton('#But_UO_Item_Rej_All');                    hideButton('#But_UO_Item_Reject');                    hideButton('#But_UO_Item_Schedule_Delivery');                }            }        }    }    function Checkuorequestor() {        if ("@Model.UO_ActionMethod" == "Edit") {            if ("@Model.UO_Curr_User_Personnel_ID" == RequestorID) {                $("#is_Requestor").val(true); is_Requestor = true;            }            if ("@Model.UO_Curr_User_Personnel_ID" != RequestorID) {                $("#is_Requestor").val(false); is_Requestor = false;            }            UOSetControlStateAsperRole();        }    }    function Checkuorequestorincharge() {        if ("@Model.UO_ActionMethod" == "Edit") {            if ("@Model.UO_Curr_User_Personnel_ID" == MainDeptInchargeID) {                $("#is_RequestorIncharge").val(true); is_RequestorIncharge = true;            }            if ("@Model.UO_Curr_User_Personnel_ID" != MainDeptInchargeID) {                $("#is_RequestorIncharge").val(false); is_RequestorIncharge = false;            }            UOSetControlStateAsperRole();        }    }    function Checkuostorekeeper() {        if ("@Model.UO_ActionMethod" == "Edit") {            if (Requestee_Store_ID == "@Model.UO_Curr_User_Store_ID"  || Requestee_Store_ID == "@Model.UO_Curr_User_Dept_ID"  ) {                $("#is_Store_Keeper").val