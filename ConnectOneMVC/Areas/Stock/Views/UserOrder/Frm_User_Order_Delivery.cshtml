    function UO_DL_Add_Personnel_Click()
    {
        if ("@UO_AddPersonnelRight" != "True")
        {
                DevExpress.ui.dialog.alert('Not Allowed', 'No Rights');
                return;
        }
        ShowLoader();
        $.ajax({
            type: "GET",
            url: "/Stock/PersonnelMaster/Frm_PersonnelMaster_Window",
            data: {
                ActionMethod: "New",
                ID: 0,
                PostSucessFunction: "StockMaster_Personnel_DeliveryWindow_OnSuccess",
                PopupName: "Stockmasterpersonnel_delivery"
            },
            success: function (data) {
                OpenPopup("Stockmasterpersonnel_delivery", "New ~ Personnel", null, "auto", "85%", true, data);
            }
        });
    }

    function StockMaster_Personnel_DeliveryWindow_OnSuccess(data) {

        HideLoader();
        if (data.result == true) {
            $("#Stockmasterpersonnel_delivery").dxPopup("hide");

            $("#LookUp_Delivered_By_Dl_datagrid").dxDataGrid("instance").refresh();

            $("#LookUp_Delivered_By_datagrid").dxDataGrid("instance").refresh();
        }
        else {
            DevExpress.ui.dialog.alert(data.Message, "Error");
        }


    }

