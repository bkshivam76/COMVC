    function Delivery_Mode_DL_ChangeEvent(e) {
        debugger
        var dropDownBox = $("#UO_DL_Delivery_ModeId").dxDropDownBox("instance");
        dropDownBox.close();
        if (e.value == null && e.previousValue != null) {
            UO_DeliveryMode_DG.clearSelection();
            return;
        }

        UO_DeliveryMode_DG.selectRows(dropDownBox.option("value"), false);
        if (UO_DeliveryMode_DG.getSelectedRowsData().length > 0) {
            var item = UO_DeliveryMode_DG.getSelectedRowsData()[0];
            var ReceivedMode = item.Mode;
            $("#UO_DL_Delivery_Mode").val(ReceivedMode);
        }
    }



