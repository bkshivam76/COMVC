<script>

    $(document).ready(function ()
    {
        if ("@UO_AddPersonnelRight" == "False")
        {
            $("#UO_DLA_AddPersonnel").hide();
        }

        var form = "ID_Frm_Delivered_WindowAll";
        ShowLoader();
        AssignIDtoLabel(form, "UO_DeliveredAll");
        setTimeout(function ()
        {
            Set_Form_View_Delete_Mode(null, form, "@Model.UO_DLA_ActionMethod");
            Focus_FirstEditable_Field(form, "@Model.UO_DLA_ActionMethod");
            HideLoader();

        }, Timeout500);

    });
</script>
<script>


    function Delivery_Mode_DLA_ChangeEvent(e) {

        var dropDownBox = $("#UO_DLA_Delivery_ModeId").dxDropDownBox("instance");
        dropDownBox.close();
        var $dataGrid = $("#LookUp_DL_Delivery_Mode_datagrid");
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(dropDownBox.option("value"), false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                var ReceivedMode = item.Mode;
                $("UO_DLA_Delivery_Mode").val(ReceivedMode);
            }
        }
    }
    function Shipment_Location_DLA_ChangeEvent(e) {

        var dropDownBox = $("#UO_DLA_Shipment_To_LocationId").dxDropDownBox("instance");
        dropDownBox.close();
        var $dataGrid = $("#LookUp_Ship_To_Location_DL_datagrid");
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(dropDownBox.option("value"), false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                var LocationName = item.Location_Name;
                $("#UO_DLA_Shipment_To_Location").val(LocationName);
            }
        }
    }
    function Delivered_By_DLA_ChangeEvent(e) {

        var dropDownBox = $("#UO_DLA_Delivered_By_Id").dxDropDownBox("instance");
        dropDownBox.close();
        var $dataGrid = $("#LookUp_Delivered_By_Dl_datagrid");
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(dropDownBox.option("value"), false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                var DeliveredByName = item.Name;
                $("#UO_DLA_Delivered_By").val(DeliveredByName);
                $("#UO_DLA_MobileNo").dxTextBox("instance").option("value", item["Mobile_No"]);
            }
        }
    }

    function Driver_DLA_ChangeEvent(e) {

        var dropDownBox = $("#UO_DLA_DriverID").dxDropDownBox("instance");
        dropDownBox.close();
        var $dataGrid = $("#LookUp_Delivered_By_datagrid");
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(dropDownBox.option("value"), false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                var DriverName = item.Name;
                $("#UO_DLA_Driver").val(DriverName);

            }
        }
    }

    function UO_DLA_Add_Personnel_Click()
    {
         if ("@UO_AddPersonnelRight" != "True")
        {
                DevExpress.ui.dialog.alert('Not Allowed', 'No Rights');
                return;
        }
        ShowLoader();
        $.ajax({
            type: "GET",
            url: "/Stock/PersonnelMaster/Frm_PersonnelMaster_Window",
            data: {
                ActionMethod: "New",
                ID: 0,
                PostSucessFunction: "StockMaster_Personnel_DeliveryAllWindow_OnSuccess",
                PopupName: "Stockmasterpersonnel_deliveryall"
            },
            success: function (data) {
                OpenPopup("Stockmasterpersonnel_deliveryall", "New ~ Personnel", null, "auto", "85%", true, data);
            }
        });
    }

    function StockMaster_Personnel_DeliveryAllWindow_OnSuccess(data) {

        HideLoader();
        if (data.result == true) {
            $("#Stockmasterpersonnel_deliveryall").dxPopup("hide");

            $("#LookUp_Delivered_By_Dl_datagrid").dxDataGrid("instance").refresh();

            $("#LookUp_Delivered_By_datagrid").dxDataGrid("instance").refresh();
        }
        else {
            DevExpress.ui.dialog.alert(data.Message, "Error");
        }


    }

    $('#UO_DLA_Carrier').keypress(function (e) {
        var regex = new RegExp("^[a-zA-Z0-9]+$");
        var str = String.fromCharCode(!e.charCode ? e.which : e.charCode);
        if (regex.test(str)) {
            return true;
        }
        e.preventDefault();
        return false;
    });


</script>
