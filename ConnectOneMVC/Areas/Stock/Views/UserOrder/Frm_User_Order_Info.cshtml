            DevExpress.ui.dialog.alert(menucheck[0], "Error");
            return;
        }

        var check = UO_datanavigation();
        if (check[1] == false) {
            DevExpress.ui.dialog.alert(check[0], "Error");
            return;
        }
        $.ajax({
            type: 'POST',
            url: "/Stock/UserOrder/ReturnedReceived_grid_oldest_returned",
            data: {
                UO_ItemID: UOItemID,
                UOid: UOID,
            },
            success: function (data) {
                if (data.result == false) {
                    DevExpress.ui.dialog.alert(data.message, "Error");
                }
                if (data.result == true) {
                    ShowLoader();
                    $.ajax({
                        type: 'GET',
                        url: "/Stock/UserOrder/Frm_User_Order_Return_Received",
                        data: {
                            ActionMethod: "New",
                            UOid: UOID,
                            Item_Rec_Id: data.selID,
                            MainDeptID: MainDeptID,
                            Requestee_Store_ID: Requestee_Store_ID,
                            //  ItemID: UOItemID,
                            PostSucessFunctionName: "Frm_User_Order_ReturnedReceived_OnSuccess",
                        },
                        cache: false,
                        success: function (data) {

                            OpenPopup("UserOrderinnergrid", "New ~ Items Returned Received", null, "auto", 900, true, data);

                        }
                    });

                }
            }

        });


    }




    function UO_datanavigation(_actionmethod) {
        if (!_actionmethod) { _actionmethod = null; }

        var msg;
        var result;
        $.ajax({
            type: 'GET',
            async: false,
            url: "/Stock/UserOrder/DataNavigation",
            data: {
                ActionMethod: _actionmethod,
                ID: UOID,
                UO_Date: UO_Date
            },
            cache: false,
            success: function (data) {
                msg = data.Message;
                result = data.result;
            }
        });

        return [msg, result];
    }
    function UO_StatusFlowCheck(Status) {
        var msg;
        var result;
        $.ajax({
            type: 'POST',
            url: "/Stock/UserOrder/UserOrderStatusFlow",
            data: {
                ID: UOID,
                StatusButton: Status,
                CurrUserRole: UOCurrUserRole
            },
            async: false,
            cache: false,
            success: function (data) {
                msg = data.message;
                result = data.result;
            }
        });
        return [msg, result];
    }




    function UpDateUserOrderStatus(Status_Button) {
     
        if (!UOID) {
            DevExpress.ui.dialog.alert("Please select A User Order...!", 'alert!');
            return;
        }


        var statusflowcheck = UO_StatusFlowCheck(Status_Button);
        if (statusflowcheck[1] == false) {
            DevExpress.ui.dialog.alert(statusflowcheck[0], "Error");
            return;
        }

        var check = UO_datanavigation(Status_Button);
        if (check[1] == false) {
            DevExpress.ui.dialog.alert(check[0], "Error");
            return;
        }
        var StatusType = "";

        switch (Status_Button) {
            case "Reject":
                StatusType = "Do you want reject the User Order ?";
                break;
            case "Changes Recommended":
                StatusType = "Do you want to change User Order ?";
                break;
            case "Approve":
                StatusType = "Do you want to approve the User Order ?";
                break;
            case "Reopen":
                StatusType = "Do you want to re open the User Order ?";
                break;
            case "Complete":
                StatusType = "Do you want to Mark the User Order as completed?";
                break;
            case "Cancel":
                StatusType = "Please confirm to Cancel User Order...";
                break;
            default:
                StatusType = "";
                break;
        }
        if (StatusType != "") {

            var result = DevExpress.ui.dialog.confirm(StatusType, "Confirm changes");
            result.done(function (dialogResult) {

                if (dialogResult) {

                    switch (Status_Button) {


                        case "Reject":
                        case "Cancel":
                        case "Changes Recommended":

                            ShowLoader();
                            $.ajax({
                                type: "GET",
                                async: false,
                                url: "/Stock/UserOrder/UO_StatusChange_Window",
                                data: {
                                    ID: UOID,
                                    StatusButton: Status_Button
                                },
                                success: function (data)
                                {
                                    OpenDynamicPopup("User Order ~ " + Status_Button, null, "auto", "60%", true, data);
                                }
                            });
                            break;

                        case "Complete":
                        case "Approve":
                        case "Reopen":
                            $.ajax({
                                type: "GET",
                                url: "/Stock/UserOrder/User_StatusChange",
                                data: {
                                    ID: UOID,
                                    StatusButton: Status_Button
                                },
                                success: function (data) {
                                    if (data.result == false) { DevExpress.ui.dialog.alert(data.message, 'Error..!!'); }
                                    else {
                                        DevExpress.ui.dialog.alert(data.message, 'Success..!!');
                                        UserOrderListGrid.Refresh();
                                    }
                                }
                            });
                            break;
                    }
                }
            });
        }

    }

