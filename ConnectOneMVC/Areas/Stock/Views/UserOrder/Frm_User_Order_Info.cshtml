                        var fromdate = ConvertJsonDateToString(data.Message.UO_Fromdate);
                        var todate = ConvertJsonDateToString(data.Message.UO_Todate);
                    
                        UserOrderListGrid.Refresh();
                    @*$("#UserOrderPartialView").load("@Url.Action("Frm_User_Order_Info", "UserOrder", new { @area = "Stock" })?FromDate=" + fromdate + "&Todate=" + todate + "&ChangeStatus=False", function () {

                        HideLoader();
                    });*@
                        HideLoader();
                    }

                }
            });
        }
    }  //Period Selection
    function ChangePeriodinLayout() {

        ShowLoader();

        OpenDynamicPopup("Change Period", "@Url.Action("Frm_Change_Period_Screen_UO", "UserOrder", new { @area = "Stock" })", "auto", "55%", false, null);
    }// Change Period Button Click


    //function menuItem_click(data) {
    //    var item = data.itemData;
    //    console.log(item);
    //}
</script>

<div id="content" class="col-md-12 report_header_div_main">
