        <label class="report_header_label">User Order Register</label>
    </div>
    <div class="report_button_div">
        @(Html.DevExtreme().Button().ID("URNew").Text("New").Icon("add").Visible(true).Disabled(false).OnClick(@<text>function () {UserOrder_NewClick(); }</text>))
        @(Html.DevExtreme().Button().ID("UREdit").Text("Edit").Icon("edit").Visible(true).Disabled(false).OnClick(@<text>function () {UserOrder_EditClick(); }</text>))
