<script>

    function LookUp_ViewType_ChangeEvent_UO(e) {

        var SelectBox = $("#UserOrderPeriodSelection").dxSelectBox("instance").option("value");
        $("#UOChangePeriodMain").dxButton("instance").option("disabled", true);

        if (SelectBox == "Specific Period") {
            $("#UOChangePeriodMain").dxButton("instance").option("disabled", false);
            $("#UO_BE_View_Period").dxTextBox("instance").option("value", "");
