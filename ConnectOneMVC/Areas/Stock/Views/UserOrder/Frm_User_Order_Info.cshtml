    function UserOrderAdjustSize()
    {
        var height = (document.documentElement.clientHeight * 90) / 100;
        UserOrderListGrid.SetHeight(height);
    }

    function UserOrderOnInit(s,e) {
        UserOrderAdjustSize();
        ASPxClientUtils.AttachEventToElement(window, "resize", function (evt) {
         UserOrderAdjustSize();
        });
        s.SetFocusedRowIndex(-1);
    }
    function UserOrderListGrid_BeginCallBack(s,e) {
        e.customArgs["command"] = e.command;
        if (e.command == "REFRESH") {
            isUOGridRefresh = true;
        }
        e.customArgs["ShowHorizontalBar"] = UserOrder_ShowHorizontalBar;
   }
    function UserOrderListGrid_EndCallBack(s,e) {
        UserOrderAdjustSize();
        SendCustomArgs_FilterControl(s, e);
    }

    function ItemUserOrderGrid_BeginCallBack(s,e) {
        e.customArgs["command"] = e.command;
        if (e.command == "REFRESH") {
            isUONestedRefresh = true;
        }
    }
    function OnItemUserOrderInit(s) {
        s.SetFocusedRowIndex(-1);
    }
function UserOrderListGridFocusedRowChanged(s) {
        if (s.GetFocusedRowIndex() == -1) {
            UOID = 0;
        }
        else {
            UserOrdergrid = "UserOrder";
            UOID = s.GetRowKey(s.GetFocusedRowIndex());
            s.GetValuesOnCustomCallback({ key: UOID }, UserOrderGetRowValues);
            s.CollapseAllDetailRows();
        }
    }

    function UserOrderGetRowValues(data) {

        var values = data.split("![");
        UO_number = values[0];

        UOID = values[1];
        UO_Date = values[2];
        UO_Status = values[3];
        Delivery_Status = values[4];
        Edit_Date = values[5];
        Edit_By = values[6];
        Add_Date = values[7];
        Add_By = values[8];
      
        Approval_Required = values[10];
        Requestee_Store = values[11];
        Complex = values[12];
        Job = values[13];
        Project = values[14];
        Initiation_Mode = values[15];
        Requestor_Name = values[16];
        MainDeptID = values[17];
        Requestee_Store_ID = values[18];
        JOBID = values[19];
        UO_RR_mapped = values[20];
        projectid = values[21];
        subdeptid = values[22];

        UOCurrUserRole = (values[9].split(','));
        for (var i = 0; i < UOCurrUserRole.length; i++) {
           UOCurrUserRole[i] = UOCurrUserRole[i].trim();
        }

        UserOrder_UpdateFooterDetail(UOID, Add_Date, Add_By, Edit_Date, Edit_By);

    }

    function UserOrder_UpdateFooterDetail(ID, Add_Date, Add_By, Edit_Date, Edit_By)
        {
        var Lbl_Create = "";
        var Lbl_Modify = "";


        if (Add_Date) {
            Lbl_Create = "Add On: " + Add_Date + ", By: " + Add_By;
        }
        else {
            Lbl_Create = "Add On: " + "?, By: " + Add_By;
        }



        if (Edit_Date) {
            Lbl_Modify = "Edit On: " + Edit_Date + ", By: " + Edit_By;
        }
        else {
            Lbl_Modify = "Edit On: " + "?, By: " + Edit_By;
        }

        $('#UserorderLbl_Create').text(Lbl_Create);
        $('#UserorderLbl_Modify').text(Lbl_Modify);

    }

    function OnItemUserOrderFocusedRowChange(s, e) {
        if (s.GetFocusedRowIndex() == -1) {
            UOItemID = 0;
        }
        else {
            UserOrderListGrid.SetFocusedRowIndex(-1);
            UserOrdergrid = "Item";
            UOItemID = s.GetRowKey(s.GetFocusedRowIndex());
            s.GetValuesOnCustomCallback({ key: UOItemID }, ItemUserOrderGetData);
        }
    }

    function ItemUserOrderGetData(Data) {
  
        var values = Data.split("![");
        UOID = values[16];//uoid
        UOItemID = values[15];
        UserOrderEditedBy = values[13];
        UserOrderEditedOn = values[14];
        UserOrderAddedBy = values[11];
        UserOrderAddedOn = values[12];
        subitemid = values[17];

        UserOrder_UpdateFooterDetail(UOItemID, UserOrderAddedOn, UserOrderAddedBy, UserOrderEditedOn, UserOrderEditedBy);
    }


    function CollapseUserOrderRow(s, e) {
        s.SetFocusedRowIndex(index);
    }
    function ExpandUserOrderRow(s, e) {
        index = e.visibleIndex;
        s.SetFocusedRowIndex(-1);
    }
    function UserOrderExpandAll() {
        if (!UserOrderIsAllDetailExpanded)
        {
            UserOrderListGrid.ExpandAllDetailRows();
            UserOrderIsAllDetailExpanded = true;
            $("#btnUserOrderExpandAll").find("span").text("Collapse All");
        }
        else
        {
            UserOrderListGrid.CollapseAllDetailRows();
            UserOrderIsAllDetailExpanded = false;
            $("#btnUserOrderExpandAll").find("span").text("Expand All");
        }
    }


    function User_OrderchangeMode() {
        ShowLoader();
        if (UserOrder_ShowHorizontalBar == 0) {
            UserOrder_ShowHorizontalBar = 1;
            $("#UR_MasterToggleScrollBar").find("span").text("Default Data");

        }
        else {
            UserOrder_ShowHorizontalBar = 0;
            $("#UR_MasterToggleScrollBar").find("span").text("Full Data");

        }
        $.ajax({
            url: '@Url.Action("Frm_User_Order_Main_Grid", "UserOrder")',
            type: "GET",
            async: false,
            data: { ShowHorizontalBar: UserOrder_ShowHorizontalBar },
            success: function (res) {
                $("#UserOrderPartialView").html(res);
            }
        });
        HideLoader();
    }//full data button click


    $("#UserOrderListGrid").keydown(function (evt) {

        switch (evt.keyCode) {

            case 45: // insert key
                UserOrder_NewClick();
                break;
            case 13: //enter key
                UserOrder_EditClick();
                break;
            case 32: //space bar
              //  UserOrder_ViewClick(); mantis #1398
                break;
            case 46://delete key
                UserOrder_DeleteClick();
                break;
        }
        if (evt.ctrlKey && evt.keyCode == 73)//ctrl+i
        {
            UserOrder_NewClick();
        }
        if (evt.ctrlKey && evt.keyCode == 69)//ctrl+e
        {
            UserOrder_EditClick();
        }
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
           // UserOrder_ViewClick(); mantis #1398
        }
    });

    function UserOrder_NewClick()
    {
        if ("@UO_Add_Rights" == "False")
        {
            DevExpress.ui.dialog.alert('Not Allowed..!!', 'No Rights');
            return;
        }

        ShowLoader();
        OpenDynamicPopup("New ~ User Order", "@Url.Action("Frm_NEVD_User_Order", "UserOrder", new {@area= "Stock" })?ActionMethod=New", "auto", 1000, false, null);
    }


    function UserOrder_EditClick() {

        if (UserOrdergrid == "Item") {
            DevExpress.ui.dialog.alert('Please Select A Master Grid Row..!!', 'Alert');
            return;
        }


        if ("@UO_UpdateRight"=="False") {

            DevExpress.ui.dialog.alert('Not Allowed..!!', 'No Rights');
            return;
        }

        if (!UOID) {
            DevExpress.ui.dialog.alert('Please Select One Row', 'Alert');
            return;
        }

        if (UO_Status == "Completed") {
            DevExpress.ui.dialog.alert("Completed UO Cannot Be Edited..!!", "Error");
            return;
        }

        var statusflowcheck = UO_StatusFlowCheck("Edit");
        if (statusflowcheck[1] == false) {
            DevExpress.ui.dialog.alert(statusflowcheck[0], "Error");
            return;
        }
        var check = UO_datanavigation("Edit");
        if (check[1] == false) {
            DevExpress.ui.dialog.alert(check[0], "Error");
            return;
        }


        UOIsEditPopup = true;
        ShowLoader();
        OpenDynamicPopup("Edit ~ User Order", "@Url.Action("Frm_NEVD_User_Order", "UserOrder", new {@area= "Stock" })?ActionMethod=Edit&ID=" + UOID, "auto", 1000, false, null);
    }


    function UserOrder_ViewClick()
   {
        if (UserOrdergrid == "Item") {
           DevExpress.ui.dialog.alert('Please Select A Master Grid Row..!!', 'Alert');
           return;
       }

        if ("UO_ViewRight" == "False") {
        DevExpress.ui.dialog.alert('Not Allowed..!!', 'No Rights');
        return;
    }
       if (!UOID) {
           DevExpress.ui.dialog.alert('Please Select One Row', 'Alert');
           return;
       }


        ShowLoader();
        OpenDynamicPopup("View ~ User Order", "@Url.Action("Frm_NEVD_User_Order", "UserOrder", new {@area= "Stock" })?ActionMethod=View&ID=" + UOID, "auto", 1000, false, null);
    }

    function UserOrder_DeleteClick() {
        if (UserOrdergrid == "Item") {
            DevExpress.ui.dialog.alert('Please Select A Master Grid Row..!!', 'Alert');
            return;
        }
        if ("@UO_DeleteRight" == "False") {
            DevExpress.ui.dialog.alert('Not Allowed..!!', 'No Rights');
            return;
        }
        if (!UOID) {
            DevExpress.ui.dialog.alert('Please Select One Row', 'Alert');
            return;
        }
        if (UO_Status == "Completed") {
            DevExpress.ui.dialog.alert("Completed UO Cannot Be Deleted..!!", "Error");
            return;
        }

        var statusflowcheck = UO_StatusFlowCheck("Delete");
        if (statusflowcheck[1] == false) {
            DevExpress.ui.dialog.alert(statusflowcheck[0], "Error");
            return;
        }
        var check = UO_datanavigation("Delete");
        if (check[1] == false) {
            DevExpress.ui.dialog.alert(check[0], "Error");
            return;
        }

        ShowLoader();
        OpenDynamicPopup("Delete ~ User Order", "@Url.Action("Frm_NEVD_User_Order", "UserOrder", new {@area= "Stock" })?ActionMethod=Delete&ID=" + UOID, "auto", 1000, false, null);

    }

    function UserOrderPreviewClick()
    {
        if ("@UO_ExportRight" == "False")
        {
                DevExpress.ui.dialog.alert('Not Allowed..!!', 'No Rights');
                return;
        }

       ShowLoader();

        OpenPopup("UserOrderRegister_report_modal", "Export Option", "@Url.Action("Frm_Export_Options", "UserOrder", new { @area = "Stock" })", "auto", "30%", false, null);
   }//list preview





    function UserOrderContextMenuFunction(s, e) {
        if (e.item.name == 'New') {
            UserOrder_NewClick();
        }
        if (e.item.name == 'Close') {
            Close_UO();
        }
        else if (e.item.name == 'Edit') {
            UserOrder_EditClick();
        }
        else if (e.item.name == 'Delete') {
            UserOrder_DeleteClick();
        }
        else if (e.item.name == 'View') {
            UserOrder_ViewClick();
        }
        else if (e.item.name == 'ListPreview') {
            UserOrderPreviewClick();
        }
        else if (e.item.name == 'CreateRR') {
            CreateRequisitionRequest();
        }
        else if (e.item.name == 'Merge_UO_in_Existing_RR') {
            OnMergeExistingRRClick();
        }
        else if (e.item.name == 'UnmapUO_RR') {
            OnUnmapUOClick();
        }
        else if (e.item.name == 'Mark_fullydeli') {
            OnMarkFullyDeliveredClick();
        }
        else if (e.item.name == 'Mark_fullyrecd') {
            OnMarkFullyReceivedClick();
        }
        else if (e.item.name == 'PrintRecoverySlip') {
            OnPrintRecoverySlipClick();
        }
        else if (e.item.name == 'Print_Gatepass') {
            OnPrintGatePassClick();
        }
        else if (e.item.name == 'Jobdetails_UO') {
            OnUOJobDetailsClick();
        }
        else if (e.item.name == 'Schedule_Deli') {
            OnUOScheduleDeliveryClick();
        }
        else if (e.item.name == 'CheckBudgetStatus') {
            UserOrderCheckBudgetClick();
        }
        else if (e.item.name == 'AddItems_UO') {
            UserOrderItemClick();
        }
        else if (e.item.name == 'AddDocument_uo') {
            OnAddDocumentClick();
        }
    }
    function UserOrderNestedContextMenuFunction(s, e) {
        //innergrid contextmenu items
       if (e.item.name == 'PostUo_Scrap') {
            UOPostScrap();
        }
        else if (e.item.name == 'CheckAvail_Item') {
            UOCheckAvail();
        }
        else if (e.item.name == 'AddGoodsDeli_UO') {
            UOGoodsDeli();
