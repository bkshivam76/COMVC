    function CreateRequisitionRequest()
    {
        
        $("#RRvalidationForm").remove();
        if ("@UO_AddRRRight" != "True") {
                DevExpress.ui.dialog.alert('Not Allowed', 'No Rights');
                return;
            }
        if (UserOrdergrid == "Item") {
            DevExpress.ui.dialog.alert('Please Select A Master Grid Row..!!', 'Alert');
            return;
        }

        if (!UOID) {
            DevExpress.ui.dialog.alert('Please Select One Row', 'Alert');
            return;
        }
        if (!(UOCurrUserRole.includes("Store Keeper") || UOCurrUserRole.includes("Store Keeper in-charge"))) {
            DevExpress.ui.dialog.alert("Only 'Store Keeper'Can Create Requisition Request", "Error");
            return;
        }
        if (UO_Status != "Approved" ) {
            DevExpress.ui.dialog.alert("New RR can be created only against “Approved” Status UO", "Error");
            return;
        }
       
        $.ajax({
            type: 'POST',
            url: "/Stock/UserOrder/Check_Approved_Item_Status",
            data: {
                UOID: UOID,
            },
            success: function (res) {
            
                if (res.result == false) {
                    DevExpress.ui.dialog.alert(res.message, "Error");
                    return;
                }
                else {

                    $.ajax({
                        type: 'POST',
                        url: "/Stock/UserOrder/Check_Unmapped_UO_Items_for_CreatingRR",
                        data: {
                            UO_ID: UOID,
                        },
                        success: function (res) {
                            if (res.result == false) {
                                DevExpress.ui.dialog.alert(res.message, "Error");
                                return;
                            }
                            else {
                                $.ajax({
                                    type: 'GET',
                                    url: "/Stock/RequestRegister/Frm_NEVD_Requisition",
                                    data:
                                    {
                                        ActionMethod: "New",
                                        ID: 0,
                                        //CurUserRole: UOCurrUserRole,
                                        PostSuccessFunction: "Frm_UO_RR_OnSuccess_NEVD",
                                        PopupName: "UserOrderinnergrid",
                                        UO_ID: UOID,
                                        Jobid: JOBID,
                                        projectid: projectid
                                    },
                                    cache: false,
                                    success: function (data) {
                                        OpenPopup("UserOrderinnergrid", "New ~ Create RR", null, "auto", 900, true, data);
                                        //UserOrderListGrid.SetFocusedRowIndex(-1);
                                        //UserOrderListGrid.Refresh();
                                    }
                                });
                               

                            }
                        }
                    });
                }
            }
        });       
     }
