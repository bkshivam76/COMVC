@using DevExtreme.AspNet.Mvc;
@model ConnectOneMVC.Areas.Stock.Models.UOOrderItemDetails
@{
    ViewBag.Test = Model.UO_OT_ActionMethod;
    bool IsVisible = Model != null && (Model.UO_OT_ActionMethod.ToString().Trim() == "View") ? true : false;
}
@{
    Html.EnableClientValidation();
    Html.EnableUnobtrusiveJavaScript();
    Html.AntiForgeryToken();

    bool UO_AddStockItemRight = (bool)ViewData["UO_AddStockItemRight"];
    bool UO_AddHelpRequestRight = (bool)ViewData["UO_AddHelpRequestRight"];
}
