                                                                                                                                .ID("OT_Item_Type")
                                                                                                                                .Name("OT_Item_Type")
                                                                                                                                .Value(Model.OT_Item_Type)
                                                                                                                                .ReadOnly(true)
                                                                                                                                .Disabled(IsVisible)
                        )
                    </div>
                </div><!--[2]-->
                <div class="col-sm-12 col-md-4 col-lg-4 padTop4">
                    <div class="col-sm-2 col-md-6 col-lg-6 pll"><label class="control-label" for="user">Item Code</label></div>
                    <div class="col-sm-10 col-md-6 col-lg-6 prm">
                        @(Html.DevExtreme().TextBox().CustomTextBox()
                                                                                                                            .ID("OT_Item_Code")
