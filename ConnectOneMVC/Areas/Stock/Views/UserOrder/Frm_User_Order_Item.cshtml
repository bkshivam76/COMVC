                    @(Html.DevExtreme().TextBox().CustomTextBox()
                                                                .ID("OT_Remarks")
                                                                .Name("OT_Remarks")
                                                                .Value(Model.OT_Remarks)
                                                                .Placeholder("Enter Remarks...")
                                                                .MaxLength(8000)
                                                                .ReadOnly(IsVisible)
                                                                .Disabled(IsVisible)
                    )
                </div>
            </div><!--[row7]-->
            <div class="row styleActionBtn marginAll8">
                @if (Model.UO_OT_ActionMethod.ToString().Trim() == "View")
                {
                    @(Html.DevExtreme().Button().CustomCloseButton().Text("Close").ID("UserOrder_item_Cancle").FocusStateEnabled(true).OnClick(@<text> function () { close_UO_Item();} </text>) )
                }
                @if (Model.UO_OT_ActionMethod.ToString().Trim() == "New" || Model.UO_OT_ActionMethod.ToString().Trim() == "Edit")
                {
                    @(Html.DevExtreme().Button().CustomSaveButton().Text("OK").ID("UserOrder_item_Save").FocusStateEnabled(true).UseSubmitBehavior(true) )
                    @(Html.DevExtreme().Button().CustomCloseButton().Text("Cancel").ID("UserOrder_item_Cancled").FocusStateEnabled(true).OnClick(@<text> function () { close_UO_Item();} </text>) )
                }
            </div>
        }
    }
</div>

@(Html.DevExtreme().Popup().CustomPopup().ID("ItemOrderedGrid").CloseOnOutsideClick(false).ShowTitle(true).Title("New ~ ").ContentTemplate(@<text> <div id="result_ItemOrderedGrid">  </div> </text>))

<script>
    var store;
    var subitem;
    var subdeptid;
    var UO_IO_Item_DG;
    $(document).ready(async function () {
        debugger
        @*if ("@UO_AddStockItemRight" == "False")
        {
            $("#AddRequestItem").hide();
        }*@
    
        var form = "ID_Frm_User_Order_Item_Popup";
        ShowLoader();
        if ("@Model.UOid" != "0") {

            subdeptid = "@Model.UOItemSubDept";
        }
        else {
            subdeptid = $("#UORequestor_Sub_Department_Name_Id").dxDropDownBox("instance").option("value");
        }

        AssignIDtoLabel(form, "UO_orderItem");

        Refresh_UO_ItemGrid_Item_DG();
        if ("@Model.OT_Item_ID".length > 0)
        {
            await UO_IO_Item_DG.selectRows(parseInt("@Model.OT_Item_ID"), false);
            
        }

        if ("@Model.UOid" != 0) {
            $.ajax({
                type: 'GET',
                url: "/Stock/UserOrder/CurrentUserRoleGrids",
                data: {
                    ID: "@Model.UOid",
                },
                cache: false,
                success: function (result) {

                    if (result.Req || result.ReqI) {

                        $('#OT_Requested_Qty').dxNumberBox("instance").option("readOnly", false);
                        $('#OT_Item_ID').dxDropDownBox("instance").option("readOnly", false);
                        $('#OT_Req_Deliver_Date').dxDateBox("instance").option("readOnly", false);
                        $('#OT_Delivery_Allowed').dxRadioGroup("instance").option("readOnly", false);
                        $('#OT_Approved_Qty').dxNumberBox("instance").option("readOnly", true);
                        $('#OT_Sch_Deliver_Date').dxDateBox("instance").option("readOnly", true);
                    }
                    if (result.Sk || result.SkI) {


                        $('#OT_Requested_Qty').dxNumberBox("instance").option("readOnly", false);
                        $('#OT_Item_ID').dxDropDownBox("instance").option("readOnly", false);
                        $('#OT_Req_Deliver_Date').dxDateBox("instance").option("readOnly", false);
                        $('#OT_Delivery_Allowed').dxRadioGroup("instance").option("readOnly", false);
                        $('#OT_Approved_Qty').dxNumberBox("instance").option("readOnly", false);
                        $('#OT_Sch_Deliver_Date').dxDateBox("instance").option("readOnly", false);
                    }
                }
            });
        }
        else
        {
            if (is_Requestor || is_RequestorIncharge) {

                $('#OT_Requested_Qty').dxNumberBox("instance").option("readOnly", false);
                $('#OT_Item_ID').dxDropDownBox("instance").option("readOnly", false);
                $('#OT_Req_Deliver_Date').dxDateBox("instance").option("readOnly", false);
                $('#OT_Delivery_Allowed').dxRadioGroup("instance").option("readOnly", false);
                $('#OT_Approved_Qty').dxNumberBox("instance").option("readOnly", true);
                $('#OT_Sch_Deliver_Date').dxDateBox("instance").option("readOnly", true);

            }

            if (is_Store_Keeper || is_Store_KeeperIncharge) {


                $('#OT_Requested_Qty').dxNumberBox("instance").option("readOnly", false);
                $('#OT_Item_ID').dxDropDownBox("instance").option("readOnly", false);
                $('#OT_Req_Deliver_Date').dxDateBox("instance").option("readOnly", false);
                $('#OT_Delivery_Allowed').dxRadioGroup("instance").option("readOnly", false);
                $('#OT_Approved_Qty').dxNumberBox("instance").option("readOnly", false);
                $('#OT_Sch_Deliver_Date').dxDateBox("instance").option("readOnly", false);
            }

        }
                          setTimeout(function ()

                    {
            Set_Form_View_Delete_Mode(null, form, "@Model.UO_OT_ActionMethod");
            Focus_FirstEditable_Field(form, "@Model.UO_OT_ActionMethod");
            HideLoader();

                          }, Timeout500);

    });

    function OnInitialized_OT_Item_Name_Changed(e) {
        Itemid = "@Model.UO_OT_ID";
        if ("@Model.UO_OT_ActionMethod" != "New") {
            e.component.option("dataSource").store.load().done(function (d) {
                @*if (d.length > 0) {
                    e.component.option("value", @Model.OT_Item_ID);
                }*@
                OnOT_Item_Name_Changed( @Model.OT_Item_ID);
            });

        }
        if ("@Model.UO_OT_ActionMethod" == "New") {
            if (Itemid != 0) {
                e.component.option("dataSource").store.load().done(function (d) {
                @*if (d.length > 0) {
                    e.component.option("value", @Model.OT_Item_ID);
                }*@
                    OnOT_Item_Name_Changed( @Model.OT_Item_ID);
                });
            }

        }


    }
  
    async function Refresh_UO_ItemGrid_Item_DG() {
        try {
            var $UO_IO_Item_DG = $("#LookUp_GetStoreItems_datagrid");
            if ($UO_IO_Item_DG.length) {
                UO_IO_Item_DG = $UO_IO_Item_DG.dxDataGrid("instance");
                await UO_IO_Item_DG.refresh();
            }
        }
        catch (e) {
            console.log(e);
        }
    }

    async function OnOT_Item_Name_Changed(e) {    
        debugger
        try {
            e.component.close();
            if (e.value == null && e.previousValue != null) {
                UO_IO_Item_DG.clearSelection();
                return;
            }

            recid = "@Model.UO_OT_ID";
            var itemid = e.value;
            subitem = itemid;


            if ("@Model.UO_OT_ActionMethod" == "New") {


                //dataGrid.selectRows(e.value, false);
                if (UO_IO_Item_DG.getSelectedRowsData().length > 0) {
                    var item = UO_IO_Item_DG.getSelectedRowsData()[0];

                    $("#OT_Head").dxTextBox("instance").option("value", item["Head"]);
                    $("#OT_Item_Type").dxTextBox("instance").option("value", item["Item_Type"]);
                    $("#OT_Item_Code").dxTextBox("instance").option("value", item["Item_Code"]);
                    $("#OT_Item_Name").val(item["Name"]);
                    $("#OT_UnitID").dxDropDownBox("instance").option("value", item["UnitID"]);
                    $("#OT_UnitName").val(item["Unit"]);


                }

            }
            else if ("@Model.UO_OT_ActionMethod" == "Edit" || "@Model.UO_OT_ActionMethod" == "View") {



                //dataGrid.selectRows(e.value, false);
                if (UO_IO_Item_DG.getSelectedRowsData().length > 0) {
                    var item = UO_IO_Item_DG.getSelectedRowsData()[0];

                    $.ajax({
                        type: 'GET',
                        url: "/Stock/UserOrder/Check_Unsaved_Item_Entry_in_Delivery_Grid_Item_Grid",
                        data: { ID_Item: recid },
                        cache: false,
                        success: function (res) {
                            if (res.result == true)// no added row exists in delivery
                            {
                                $("#OT_Head").dxTextBox("instance").option("value", item["Head"]);
                                $("#OT_Item_Type").dxTextBox("instance").option("value", item["Item_Type"]);
                                $("#OT_Item_Code").dxTextBox("instance").option("value", item["Item_Code"]);
                                $("#OT_Item_Name").val(item["Name"]);
                                $("#OT_UnitID").dxDropDownBox("instance").option("value", item["UnitID"]);
                                $("#OT_UnitName").val(item["Unit"]);
                            }
                            else if (res.result == false) {
                                DevExpress.ui.dialog.alert(res.message, 'Alert');
                                $("#OT_Head").dxTextBox("instance").reset();
                                $("#OT_Item_Type").dxTextBox("instance").reset();
                                $("#OT_Item_Code").dxTextBox("instance").reset();
                                $("#OT_UnitID").dxDropDownBox("instance").reset();
                                $("#OT_DeliveryLocID").dxDropDownBox("instance").reset();
                                $("#OT_Requested_Qty").dxNumberBox("instance").reset();
                                $("#OT_Approved_Qty").dxNumberBox("instance").reset();
                                $("#OT_Req_Deliver_Date").dxDateBox("instance").reset();


                            }

                        }
                    });

                }
            }
        }
        catch (e) {
            console.log(e);
        }
    }

