<div id="Frm_User_Order_Item_Popup">
    @using (Ajax.BeginForm("Frm_User_Order_Item_Popup", "UserOrder",
                                           new AjaxOptions
                                           {
                                               HttpMethod = "POST",
                                               UpdateTargetId = "Frm_User_Order_Item_Popup",
                                               InsertionMode = InsertionMode.InsertAfter,
                                               OnBegin = "AjaxBeginFormPost",
                                               OnSuccess = String.Format("{0}", Model.UOItemPostSuccessFunction)
                                           },
                                           new
                                           {
                                               id = "ID_Frm_User_Order_Item_Popup",
                                               @class = "edit_form"
                                           }))
    {
        @Html.HiddenFor(x => x.UO_OT_ActionMethod)
        //  @Html.HiddenFor(x => x.OT_Item_ID)
        @Html.HiddenFor(x => x.OT_Item_Name)
        @Html.HiddenFor(x => x.OT_UnitName)
        @Html.HiddenFor(x => x.OT_Delivery_Location)
        @Html.HiddenFor(y => y.UO_OT_AddedOn)
        @Html.HiddenFor(y => y.UO_OT_AddedBy)
        @Html.HiddenFor(x => x.Sr)
        @Html.HiddenFor(x => x.UOid)
        @Html.HiddenFor(x => x.UO_OT_ID)
        @Html.HiddenFor(x => x.UOItemPopupName)
        @Html.HiddenFor(x => x.UOItemSubDept)

  @Html.HiddenFor(x => x.UOItemPostSuccessFunction)


        using (Html.DevExtreme().ValidationGroup())
        {
            <div class="row formRow">
                <div class="col-sm-2 col-md-2 col-lg-2 pll">
                    <label class="control-label text-red" for="user">Item Name</label>
                </div>
                <div class="col-sm-4 col-md-4 col-lg-4 prm pll4">
                    @(Html.DevExtreme().DropDownBox().CustomDropDown()
                                                                .ID("OT_Item_ID")
