    function CheckAvailability_Click() {
        if (subitem == null || subitem == 0 || subitem == "undefined") {
            DevExpress.ui.dialog.alert("Please Select Item", "Error");
            return;
        }
        store = Requestee_Store_ID;
     
        ShowLoader();
        $.ajax({
            type: 'POST',
            url: "/Stock/UserOrder/Frm_User_Order_Check_Availability",
            data: {
                ItemID: subitem,
                Requestee_Store_ID: store,
                Screenname: "UO",
                 UOid: "@Model.UOid",
                 

            },
            cache: false,
            success: function (data) {
                OpenPopup("Check_Avl_Popup", "Search ~ Stock Availability", null, "auto", 1150, true, data);
            }
        });

    }

    function AddRequestItem_Click() {
      
        if ("@UO_AddStockItemRight"=="True") {
        
            ShowLoader();
            $.ajax({
                type: "GET",
                url: "/Stock/StockItemWindow/StockItemWindowNew",
                data: {
                    ActionMethod: "_New",
                    ID: 0,
                    PostSucessFunction: "StockItem_Add_ItemWindow_OnSuccess",
                    PopupName: "ItemOrderedGrid",
                    ButtonID: "AddRequestItem"

                },
                success: function (data) {
                    OpenPopup("ItemOrderedGrid", "Request ~ Add UO Item", null, "auto", 1150, true, data);
                }
            });
         
        }
        else if ("@UO_AddHelpRequestRight"=="True")
        {
            ShowLoader();

             $.ajax({
                type: 'Get',
                url: "/Help/RequestBox/Frm_Request_Window",
                 data: { PopUpId: "ItemOrderedGrid", ActionMethod: "New", _Send_From: "UO -Item Ordered Screen" },
                cache: false,
                 success: function (resultsuccess)
                 {
                     OpenPopup("ItemOrderedGrid", "Request ~ Add New Stock Item", null, "auto", "50%", true, resultsuccess);
                 }
             });
        }
    }

