    function StockItem_Add_ItemWindow_OnSuccess(data) {
        HideLoader();
        if (data.result == true) {
            $("#ItemOrderedGrid").dxPopup("hide");
            $("#LookUp_GetStoreItems_datagrid").dxDataGrid("instance").refresh();
        }
        else {
            DevExpress.ui.dialog.alert(data.Message, "Error");
        }
    }

    function Frm_User_Order_Item_InsideCheckAvl_Popup_OnSuccess(data) {
        HideLoader();
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.message, "Error");
        }
        else if (data.result == true) {
            // var lbSubmitSuccess = DevExpress.ui.dialog.alert(data.message, "Success"); //Mantis #1021 fixed
            $("#checkavlinnerpopup").dxPopup("hide");
            Order_Item_Grid.SetFocusedRowIndex(-1);
            Order_Item_Grid.Refresh();
        }
        else {
            $("#checkavlinnerpopup").dxPopup("hide");
            DevExpress.ui.dialog.alert(data.message, "Inform");
            UserOrderListGrid.Refresh();

        }
    }
