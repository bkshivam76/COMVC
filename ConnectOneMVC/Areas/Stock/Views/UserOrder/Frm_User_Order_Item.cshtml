                </div>
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label text-red" for="user">Unit</label></div>
                    <div class="col-sm-5 col-md-5 col-lg-5 prm">
                        @(Html.DevExtreme().DropDownBox().CustomDropDown()
                                                                    .ID("OT_UnitID")
                                                                    .Name("OT_UnitID")
                                                                    .Value(Model.OT_UnitID)
                                                                    .Placeholder("Select Unit")
                                                                    .ValueExpr("Unit_ID")
                                                                    .DisplayExpr("Unit")
                                                                    .DataSource(d => d.Mvc().Controller("UserOrder").LoadAction("LookUp_Units_List").Key("Unit_ID"))

                                                                    .ReadOnly(IsVisible)
                                                                    .Disabled(IsVisible)
                                                                    .OnValueChanged("OT_Unit_ChangeEvent")

                                                                    .OnInitialized("onInitialized_LookUp_OT_Unit")
                                                                    .ContentTemplate(@<text>
                                                                        @Html.Partial("LookUp_Units_List")
                                                                    </text>)
                        )
                        @Html.ValidationMessageFor(model => model.OT_UnitID, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-sm-3 col-md-3 col-lg-3 prm ">
                        @(Html.DevExtreme().Button()
                                                                    .ID("UORequestUnit")
                                                                    .Text("Request Unit")
                                                                    .Disabled(IsVisible)
                                                                    .OnClick(@<text>
                                                                        function () {
                                                                        UORequestUnit_Click()
                                                                        }
                                                                    </text>))

                    </div>
                </div>
            </div><!--[row3 a]-->
            <div class="row formRow">
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label text-red" for="user">Requested Quantity</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm pll2">
                        @(Html.DevExtreme().NumberBox().CustomNumberBox()
                                                                    .ID("OT_Requested_Qty")
                                                                    .Name("OT_Requested_Qty")
                                                                    .Value(Model.OT_Requested_Qty)
                                                                    .Format("##0")
                                                                    .ReadOnly(true)
                                                                    .Disabled(IsVisible)
                        )
                        @Html.ValidationMessageFor(model => model.OT_Requested_Qty, "", new { @class = "text-danger" })
                    </div>
                </div><!--[1]-->
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label" for="user">Approved Quantity</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm pll2">
                        @(Html.DevExtreme().NumberBox().CustomNumberBox()
                                                                    .ID("OT_Approved_Qty")
                                                                    .Name("OT_Approved_Qty")
                                                                    .Value(Model.OT_Approved_Qty)
                                                                    .Format("##0")
                                                                    .ReadOnly(true)
                                                                    .Disabled(IsVisible)
                        )

                    </div>
                </div><!--[2]-->
            </div><!--[row4]-->
            <div class="row formRow">
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-6 col-md-6 col-lg-6 pll"><label class="control-label text-red" for="user">Required Delivery Date</label></div>
                    <div class="col-sm-6 col-md-6 col-lg-6 prm pll2">
                        @(Html.DevExtreme().DateBoxFor(m => m.OT_Req_Deliver_Date).CustomDateBox()
                                                                            .ID("OT_Req_Deliver_Date")
                                                                            .Name("OT_Req_Deliver_Date")
                                                                            .Placeholder("Choose Date..")

                                                                            .ReadOnly(true)
                                                                            .Disabled(IsVisible)
                                                                            .ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } })
                        )
                        @Html.ValidationMessageFor(model => model.OT_Req_Deliver_Date, "", new { @class = "text-danger" })
                    </div>
                </div><!--[1]-->
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-6 col-md-6 col-lg-6 pll"><label class="control-label" for="user">Scheduled Delivery Date</label></div>
                    <div class="col-sm-6 col-md-6 col-lg-6 prm">
                        @(Html.DevExtreme().DateBoxFor(m => m.OT_Sch_Deliver_Date).CustomDateBox()
                                                                    .ID("OT_Sch_Deliver_Date")
                                                                    .Name("OT_Sch_Deliver_Date")

                                                                    .ReadOnly(true)
                                                                    .Disabled(IsVisible)
                        )
                    </div>
                </div><!--[2]-->
            </div><!--[row5]-->
            <div class="row formRow">
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label" for="user">Priority</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm pll2">
                        @(Html.DevExtreme().SelectBox().CustomSelectBox()
                                                                    .ID("OT_Priority")
                                                                    .Name("OT_Priority")
                                                                    .Placeholder("Select Priority...")
                                                                    .ReadOnly(IsVisible)
                                                                    .Disabled(IsVisible)
                                                                    .DataSource(new[] { "High", "Normal", "Low" })
                                                                    .Value(Model.OT_Priority)
                                                                    .OnValueChanged("Priority_SelectedIndexChanged")
                        )
                    </div>
                </div><!--[1]-->
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label" for="user">Part Delivery Allowed?</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm">
                        @(Html.DevExtreme().RadioGroup()
                                                                    .ID("OT_Delivery_Allowed")
                                                                    .Name("OT_Delivery_Allowed")
                                                                    .DisplayExpr("text")
                                                                    .ValueExpr("value")
                                                                    .Value(Model.OT_Delivery_Allowed)
                                                                    .ActiveStateEnabled(true)
