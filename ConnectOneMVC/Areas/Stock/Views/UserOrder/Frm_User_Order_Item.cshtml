    function Delivery_Location_ChangeEvent(e)
    {
        var dropDownBox = $("#OT_DeliveryLocID").dxDropDownBox("instance");
        dropDownBox.close();
        var $dataGrid = $("#LookUp_Delivery_Location_datagrid");
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(dropDownBox.option("value"), false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                var LocationName = item.Location_Name;
                $("#OT_Delivery_Location").val(LocationName);
            }
        }
    }



    function onInitialized_LookUp_Delivery_Location(e) {
        if (e.component.option("dataSource") != null) {
            e.component.option("dataSource").store.load().done(function (d) {

                if (d.length == 1)
                    e.component.option("value", d[0].Loc_Id); //mantis bug #1371
            });
        }
    }

    function OT_Unit_ChangeEvent(e) {
        var dropDownBox = $("#OT_UnitID").dxDropDownBox("instance");
        dropDownBox.close();
        var $dataGrid = $("#LookUp_Units_datagrid");
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(e.value, false);
