                                                                                                                                                            .ReadOnly(IsVisible)
                                                                                                                                                            .Disabled(IsVisible)
                                                                                                                                                        .OnValueChanged("Get_Item_Received_ChangeEvent")
                                                                                                                                                        .OnInitialized("OnInitialized_Get_Item_Received_ChangeEvent")
                                                                                                                                                       
                                                                                                                                                            .ContentTemplate(@<text>
                                                                                                                                                                @Html.Partial("LookUp_Get_Item_Received")
                                                                                                                                                            </text>)
                        )
                        @Html.ValidationMessageFor(model => model.UO_GR_Item_ReceivedId, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>
            <div class="row formRow">
