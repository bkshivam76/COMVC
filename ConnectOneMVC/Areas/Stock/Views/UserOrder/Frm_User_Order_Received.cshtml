<link href="/content/fontawesome/css/fontawesome-all.css" rel="stylesheet">
<div id="Frm_User_Order_Received_PopUp" class="edit_form">
    @using (Ajax.BeginForm("Frm_User_Order_Received", "UserOrder",
                          new AjaxOptions
                          {
                              HttpMethod = "POST",
                              UpdateTargetId = "Frm_User_Order_Received_PopUp",
                              InsertionMode = InsertionMode.InsertAfter,
                              OnBegin = "AjaxBeginFormPost",
                              OnSuccess = String.Format("{0}", Model.GR_PostSuccessFunction)

                          },
                          new
                          {
                              id = "ID_Frm_Received_Window",
                              @class = "edit_form"
                          }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.UO_GR_ActionMethod)
        @Html.HiddenFor(x => x.UO_GR_Item_Name)
        @Html.HiddenFor(x => x.UO_GR_Received_Mode)
        @Html.HiddenFor(x => x.UO_GR_Delivery_Location)
        @Html.HiddenFor(x => x.UO_GR_Received_By)
        @Html.HiddenFor(x => x.UO_GR_Sr)
        @Html.HiddenFor(x => x.UO_GR_ID)
        @Html.HiddenFor(x => x.UO_GR_UDS_ID)
        @Html.HiddenFor(x => x.UO_GR_DeliveryEntry_ID)
        @Html.HiddenFor(x => x.UO_GR_ReturnedEntry_ID)
        @Html.HiddenFor(x => x.UOid)
        @Html.HiddenFor(x => x.GR_PopUPId)
        @Html.HiddenFor(x => x.GR_PostSuccessFunction)


