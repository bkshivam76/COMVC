<link href="/content/fontawesome/css/fontawesome-all.css" rel="stylesheet">
<div id="Frm_User_Order_Received_PopUp" class="edit_form">
    @using (Ajax.BeginForm("Frm_User_Order_Received_All", "UserOrder",
                          new AjaxOptions
                          {
                              HttpMethod = "POST",
                              UpdateTargetId = "Frm_User_Order_Received_All_PopUp",
                              InsertionMode = InsertionMode.InsertAfter,
                              OnBegin = "AjaxBeginFormPost",
                              OnSuccess = "Frm_User_Order_All_Received_OnSuccess"
                          },
                          new
                          {
                              id = "ID_Frm_Received_Window_All",
                              @class = "edit_form"
                          }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.UO_GRA_ActionMethod)
        @Html.HiddenFor(x => x.UO_Selected_Item_ID)
        @Html.HiddenFor(x => x.UO_GRA_Received_Mode)
        @Html.HiddenFor(x => x.UO_GRA_Delivery_Location)
        @Html.HiddenFor(x => x.UO_GRA_Received_By)
        @Html.HiddenFor(x => x.UO_GRA_Sr)
        @Html.HiddenFor(x => x.UO_GRA_ID)
        @Html.HiddenFor(x => x.UOid)



        using (Html.DevExtreme().ValidationGroup())
        {
            <div class="full-width-header-bg3">
                <div class="row">

                    <div class="col-sm-8">
                        <h3 class="popuphead"><i class="far fa-edit"></i> Receipt Detail</h3>
                    </div>
                    <div class="col-sm-4 prm">
                        <h5 class="mand-txt-align"><i class="fas fa-info-circle"></i> Red Fields are mandatory</h5>
                    </div>
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                </div>

            </div>


            <div class="row formRow">
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label text-red" for="user">Received Date:</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm pll2">
                        @(Html.DevExtreme().DateBoxFor(model => model.UO_GRA_Received_Date).CustomDateBox()
                                                                                    .ID("UO_GRA_Received_Date")
                                                                                    .Name("UO_GRA_Received_Date")
                                                                                    .ReadOnly(IsVisible)
                                                                                    .Disabled(IsVisible)
                        )
                        @Html.ValidationMessageFor(model => model.UO_GRA_Received_Date, "", new { @class = "text-danger" })
                    </div>
                </div><!--[1]-->
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label text-red" for="user">Received Mode:</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm ">
                        @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("UO_GRA_Received_ModeId")
                                                                                                .Name("UO_GRA_Received_ModeId")
                                                                                                .Value(Model.UO_GRA_Received_ModeId)
                                                                                                .ValueExpr("ModeID")
                                                                                                .DisplayExpr("Mode")
                                                                                                .DataSource(d => d.Mvc().Controller("UserOrder").LoadAction("LookUp_Get_Received_Mode").Key("ModeID"))
                                                                                                //.Placeholder("DropDown::Courier, Registry, Transport, Railways, By Hand, Ship, Air")

                                                                                                .ReadOnly(IsVisible)
                                                                                                .Disabled(IsVisible)
                                                                                                .OnValueChanged("Received_Mode_ChangeEventAll")
                                                                                                .ContentTemplate(@<text>
                                                                                                    @Html.Partial("LookUp_Get_Received_Mode")
                                                                                                </text>)
                        )
                        @Html.ValidationMessageFor(model => model.UO_GRA_Received_ModeId, "", new { @class = "text-danger" })
                    </div>
                </div><!--[2]-->
            </div><!--[row6]-->
            <div class="row formRow">
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label" for="user">Carrier:</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm pll2">
                        @(Html.DevExtreme().TextBox().CustomTextBox().ID("UO_GRA_Carrier")
                                                                                                        .Name("UO_GRA_Carrier")
                                                                                                        .Value(Model.UO_GRA_Carrier)
                                                                                                        .MaxLength(100)
                                                                                                        .ReadOnly(IsVisible)
                                                                                                        .Disabled(IsVisible))
                    </div>
                </div><!--[1]-->
                <div class="col-sm-2 col-md-2 col-lg-2 pll"><label class="control-label text-red" for="user">Received Location:</label></div>
                <div class="col-sm-4 col-md-4 col-lg-4 prm">
                    @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("UO_GRA_Delivery_LocationId").Name("UO_GRA_Delivery_LocationId")
                                                                                        .Value(Model.UO_GRA_Delivery_LocationId)
                                                                                        .ValueExpr("Loc_Id")
                                                                                        .DisplayExpr("Location_Name")
                                                                                        .DataSource(d => d.Mvc().Controller("UserOrder").LoadAction("LookUp_Get_Received_Location").Key("Loc_Id").LoadParams(new { UOGRReqMainDeptID = new JS("function (){ return MainDeptID;}"), UOReqSubDeptID = new JS("function (){ return subdeptid;}") }))
                                                                                        //.Placeholder("DropDown(Will show location mentioned in item entry as default)")

                                                                                        .ReadOnly(IsVisible)
                                                                                        .Disabled(IsVisible)
                                                                                        .OnValueChanged("Received_Location_ChangeEventAll")

                                                                                        .ContentTemplate(@<text>
                                                                                            @Html.Partial("LookUp_Get_Received_Location")
                                                                                        </text>)
                    )
                    @Html.ValidationMessageFor(model => model.UO_GRA_Delivery_LocationId, "", new { @class = "text-danger" })
                </div>
                <div class="col-sm-6 col-md-6 col-lg-6 prm">
                    @(Html.DevExtreme().Button()
                                                                        .ID("UO_GR_AddLocationAll")
                                                                        .Text("Add Location")
                                                                        .Disabled(IsVisible)
                                                                        .OnClick(@<text>
                                                                            function () {
                                                                            UO_GR_Add_LocationAll_Click()
                                                                            }
                                                                        </text>))
                </div>
            </div><!--[row7]-->

            <div class="row formRow">
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label" for="user">Bill No.:</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm pll2">
                        @(Html.DevExtreme().TextBox().CustomTextBox().ID("UO_GRA_BillNo").Name("UO_GRA_BillNo").Value(Model.UO_GRA_BillNo).MaxLength(50).ReadOnly(IsVisible).Disabled(IsVisible))
                    </div>
                </div><!--[1]-->
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label" for="user">Challan No.:</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm">
                        @(Html.DevExtreme().TextBox().CustomTextBox().ID("UO_GRA_ChallanNo").Name("UO_GRA_ChallanNo").Value(Model.UO_GRA_ChallanNo).MaxLength(50).ReadOnly(IsVisible).Disabled(IsVisible))
                    </div>
                </div><!--[2]-->
            </div><!--[row9]-->
            <div class="row formRow">
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label" for="user">Received By:</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm pll2">
                        @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("UO_GRA_Received_By_Id").Name("UO_GRA_Received_By_Id").Value(Model.UO_GRA_Received_By_Id).ValueExpr("ID").DisplayExpr("Name").DataSource(d => d.Mvc().Controller("UserOrder").LoadAction("LookUp_Get_Received_By").Key("ID").LoadParams(new { UOGRRecReqMainDeptID = new JS("function (){ return MainDeptID;}"), UOGRRecReqSubDeptID = new JS("function (){ return subdeptid;}") }))
                                                                                                                                                                                               .Placeholder("Pre-filled as Logged in user)")
                                                                                                                                                                                               .ReadOnly(IsVisible)
                                                                                                                                                                                               .Disabled(IsVisible)
                                                                                                                                                                                               .OnValueChanged("Received_By_ChangeEventAll")
                                                                                                                                                                                               .OnInitialized("OnInitialized_Received_By_ChangeEventAll")
                                                                                                                                                                                               .ContentTemplate(@<text>
                                                                                                                                                                                                @Html.Partial("LookUp_Get_Received_By")
                                                                                                                                                                                            </text>)
                        )
                    </div>
                </div><!--[1]-->
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label" for="user">Mobile/CUG No.:</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm">
                        @(Html.DevExtreme().TextBox().CustomTextBox()
                                                                            .ID("UO_GRA_MobileNo")
                                                                            .Name("UO_GRA_MobileNo")
                                                                            .Value(Model.UO_GRA_MobileNo)
                                                                            .ReadOnly(true)
                                                                            .Disabled(IsVisible)
                        )
                    </div>
                </div><!--[2]-->
            </div>
            <div class="row formRow">
                <div class="col-sm-2 col-md-2 col-lg-2 pll"><label class="control-label " for="user">Receiver Remarks:</label></div>
                <div class="col-sm-10 col-md-10 col-lg-10 prm ">
                    @(Html.DevExtreme().TextBox().CustomTextBox().ID("UO_GRA_Remarks").Name("UO_GRA_Remarks").Value(Model.UO_GRA_Remarks).Placeholder("Enter Remark").MaxLength(8000).ReadOnly(IsVisible)
                                                                                                                            .Disabled(IsVisible))
                </div>
            </div><!--[row10]-->
            <div class="row styleActionBtn marginAll8">
                @(Html.DevExtreme().Button().ID("Id_Print_ReceiptAll").Text("Print Receipt").Disabled(IsVisible).OnClick(@<text> function(){ UO_RecdAll_Print_Receipt(); } </text>))
                @if (Model.UO_GRA_ActionMethod.ToString().Trim() == "View")
                {
                    @(Html.DevExtreme().Button().CustomCloseButton()
                                                                                        .Text("Close")
                                                                                        .ID("UOReceived_CancleAll")

                                                                                        .FocusStateEnabled(true)
                                                                                        .OnClick(@<text>
                                                                                            function () {
                                                                                            $("#UserOrderinnergrid").dxPopup("hide");
                                                                                            }
                                                                                        </text>)
                    )
                }
                @if (Model.UO_GRA_ActionMethod.ToString().Trim() == "New")
                {
                    @(Html.DevExtreme().Button().CustomSaveButton()
                                                                                        .Text("OK")
                                                                                        .ID("UOReceived_SaveAll")

                                                                                        .FocusStateEnabled(true)
                                                                                        .UseSubmitBehavior(true)
                    )
                    @(Html.DevExtreme().Button().CustomCloseButton()
                                                                            .Text("Cancel")
                                                                            .ID("UOSaveReceivedAll_Cancle")

                                                                            .FocusStateEnabled(true)
                                                                            .OnClick(@<text>
                                                                                function () {
                                                                                $("#UserOrderinnergrid").dxPopup("hide");
                                                                                }
                                                                            </text>)
                    )

                }

            </div>
        }
    }

</div>
@(Html.DevExtreme().Popup().CustomPopup().ID("RecdPaymentAddLocation").CloseOnOutsideClick(false).ShowTitle(true).Height("auto").Width("auto").DragEnabled(true).Title("New ~ Location").ContentTemplate(@<text> <div id="result_RecdPaymentAddLocation"> </div> </text>) )

<script>


    function Received_Mode_ChangeEventAll(e) {

        var dropDownBox = $("#UO_GRA_Received_ModeId").dxDropDownBox("instance");
        dropDownBox.close();
        var $dataGrid = $("#LookUp_Received_Mode_datagrid");
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(dropDownBox.option("value"), false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                var ReceivedMode = item.Mode;
                $("#UO_GRA_Received_Mode").val(ReceivedMode);
            }
        }
    }
    function Received_Location_ChangeEventAll(e) {

        var dropDownBox = $("#UO_GRA_Delivery_LocationId").dxDropDownBox("instance");
        dropDownBox.close();
        var $dataGrid = $("#LookUp_Received_Location_datagrid");
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(dropDownBox.option("value"), false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                var LocationName = item.Location_Name;
                $("#UO_GRA_Delivery_Location").val(LocationName);
            }
        }
    }
    function Received_By_ChangeEventAll(e) {

        var dropDownBox = $("#UO_GRA_Received_By_Id").dxDropDownBox("instance");
        dropDownBox.close();
        var $dataGrid = $("#LookUp_Received_By_datagrid");
        if ($dataGrid.length) {
            var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(dropDownBox.option("value"), false);
            if (dataGrid.getSelectedRowsData().length > 0) {
                var item = dataGrid.getSelectedRowsData()[0];
                var ReceiveName = item.Name;
                $("#UO_GRA_Received_By").val(ReceiveName);
                $("#UO_GRA_MobileNo").dxTextBox("instance").option("value", item["Mobile_No"]);
            }
        }
    }
    function OnInitialized_Received_By_ChangeEventAll(e) {

      e.component.option("dataSource").store.load().done(function (d) {
                if (d.length > 0) {
                    e.component.option("value", "@Model.UO_GRA_Received_By_Id");
                }
            });
        }

    

    function UO_RecdAll_Print_Receipt() {
        DevExpress.ui.dialog.alert("Coming soon...!", 'Inform!');
    }

    function UO_GR_Add_LocationAll_Click() {
        if ("@UO_ProfileCore__AddRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        $.ajax({
            type: 'GET',
            url: "/Account/ProfilePaymentVoucher/AddLocations_Check",
            data: { ActionMethod: "New" },
            cache: false,
            async: false,
            success: function (data) {
                if (data.result) {
                    $.ajax({
                        type: 'GET',
                        url: "/Account/ProfilePaymentVoucher/Frm_Location_Window",
                        data: {
                            ActionMethod: "New",
                            PopupID: "RecdPaymentAddLocation",
                            CallingScreen: "UO",
                            Dropdown_DataGrid: "LookUp_Received_Location_datagrid"
                        },//Mantis bug 0000505 fixed
                        cache: false,
                        async: false,
                        success: function (data) {
                            ShowLoader();
                            $("#RecdPaymentAddLocation").dxPopup('show');
                            $("#RecdPaymentAddLocation").dxPopup("instance").option("title", "New~Location");
                            $("#result_RecdPaymentAddLocation").html(null);
                            $("#result_RecdPaymentAddLocation").html(data);
                            HideLoader();
                        }
                    });
                }
                else {
                    DevExpress.ui.dialog.alert(data.message, "Error");
                }
            }
        });
    }

    $('#UO_GR_Carrier').keypress(function (e) {
        var regex = new RegExp("^[a-zA-Z0-9]+$");
        var str = String.fromCharCode(!e.charCode ? e.which : e.charCode);
        if (regex.test(str)) {
            return true;
        }
        e.preventDefault();
        return false;
    });

    $('#UO_GR_BillNo').keypress(function (e) {
        var regex = new RegExp("^[a-z0-9-]+$");
        var str = String.fromCharCode(!e.charCode ? e.which : e.charCode);
        if (regex.test(str)) {
            return true;
        }
        e.preventDefault();
        return false;
    });
    $('#UO_GR_ChallanNo').keypress(function (e) {
        var regex = new RegExp("^[a-z0-9-]+$");
        var str = String.fromCharCode(!e.charCode ? e.which : e.charCode);
        if (regex.test(str)) {
            return true;
        }
        e.preventDefault();
        return false;
    });
</script>
<script>

    $(document).ready(function ()
    {
        if ("@UO_ProfileCore__AddRight" == "False")
        {
	        $("#UO_GR_AddLocationAll").hide();	
        }
        var form = "ID_Frm_Received_Window_All";
        ShowLoader();
        AssignIDtoLabel(form, "UO_ReceiveAll");
        setTimeout(function ()
        {
            Set_Form_View_Delete_Mode(null, form, "@Model.UO_GRA_ActionMethod");
            Focus_FirstEditable_Field(form, "@Model.UO_GRA_ActionMethod");
            HideLoader();

        }, Timeout500);

    });
</script>