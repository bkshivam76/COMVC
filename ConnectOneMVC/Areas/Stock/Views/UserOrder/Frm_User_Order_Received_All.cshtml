@using DevExtreme.AspNet.Mvc;
@model ConnectOneMVC.Areas.Stock.Models.UserOrder_Received_All
@{
    ViewBag.Test = Model.UO_GRA_ActionMethod;
    bool IsVisible = Model != null && (Model.UO_GRA_ActionMethod.ToString().Trim() == "View") ? true : false;
    bool UO_ProfileCore__AddRight = (bool)ViewData["UO_ProfileCore__AddRight"];
}
@{
    Html.EnableClientValidation();
    Html.EnableUnobtrusiveJavaScript();
    Html.AntiForgeryToken();
}
