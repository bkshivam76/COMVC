            }//Mantis bug 0000532 fixed

        setTimeout(function ()
        {
            Set_Form_View_Delete_Mode(null, form, "@Model.UO_GRetRec_ActionMethod");
            Focus_FirstEditable_Field(form, "@Model.UO_GRetRec_ActionMethod");
            HideLoader();

        }, Timeout500);
    });

