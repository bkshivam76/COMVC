            e.component.option("dataSource").store.load().done(function (d) {
                @*if (d.length > 0) {
                    e.component.option("value", @Model.UO_GRetRec_Item_Return_ReceiveId);
                }*@
                Get_Item_ReturnReceived_ChangeEvent( @Model.UO_GRetRec_Item_Return_ReceiveId);
            });

        }
        else if ("@Model.UO_GRetRec_ActionMethod" == "New" && "@Model.UO_GRetRec_Item_Return_ReceiveId" != 0) {

            e.component.option("dataSource").store.load().done(function (d) {
                @*if (d.length > 0) {
                    e.component.option("value", @Model.UO_GRetRec_Item_Return_ReceiveId);
                }*@
                Get_Item_ReturnReceived_ChangeEvent( @Model.UO_GRetRec_Item_Return_ReceiveId);
            });

        }
    }
