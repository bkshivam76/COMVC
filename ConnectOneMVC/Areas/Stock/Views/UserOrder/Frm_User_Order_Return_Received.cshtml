    function UO_GRetRec_Add_Location_Click() {
        if ("@UO_ProfileCore__AddRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
        $.ajax({
            type: 'GET',
            url: "/Account/ProfilePaymentVoucher/AddLocations_Check",
            data: { ActionMethod: "New" },
            cache: false,
            async: false,
            success: function (data) {
                if (data.result) {
                    $.ajax({
                        type: 'GET',
                        url: "/Account/ProfilePaymentVoucher/Frm_Location_Window",
                        data: { ActionMethod: "New" },
                        cache: false,
                        async: false,
                        success: function (data) {
                            ShowLoader();
                            $("#RecdPaymentAddLocation").dxPopup('show');
                            $("#RecdPaymentAddLocation").dxPopup("instance").option("title", "New~Location");
                            $("#result_RecdPaymentAddLocation").html(null);
                            $("#result_RecdPaymentAddLocation").html(data);
                            HideLoader();
                        }
                    });
                }
                else {
                    DevExpress.ui.dialog.alert(data.message, "Error");
                }
            }
        });
    }

        $("#UO_GRetRec_Return_Received_Qty").keypress(function (e) {
            e = e || window.event;
            key = e.keyCode || e.which;
            var value = e.target.value;
            if (key == 8 || key == 127 || key == 9)
                return true
            var txt = String.fromCharCode(key);
            var reg = /[0-9.]/;
            if (value.indexOf('.') > -1) {
                var splitdot = value.split('.');
                if (splitdot[1].length >= 2)
                    e.preventDefault();
            }
            if (reg.test(txt))
                return true;

            e.preventDefault();
            return false;

        });
            $('#UO_GRetRec_Carrier').keypress(function (e) {
            var regex = new RegExp("^[a-zA-Z0-9]+$");
            var str = String.fromCharCode(!e.charCode ? e.which : e.charCode);
            if (regex.test(str)) {
                return true;
            }
            e.preventDefault();
            return false;
        });


