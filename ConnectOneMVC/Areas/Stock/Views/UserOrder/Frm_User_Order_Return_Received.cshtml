	    $("#UO_GRetRec_AddLocation").hide();	
    }
        var form = "ID_Frm_ReturnedReceived_Window";
        ShowLoader();
        AssignIDtoLabel(form, "UO_Return_Rec");
    
        if ("@Model.UO_GRetRec_Item_Return_ReceiveId".length > 0)
        {
                
                var UO_RetRecd_Item_DG = $("#LookUp_Item_ReturnReceivedDG").dxDataGrid("instance")
