    $("#UO_GRet_Returned_Qty").keypress(function (e) {
            e = e || window.event;
        key = e.keyCode || e.which;
        var value = e.target.value;
        if (key == 8 || key == 127 || key == 9)
            return true
        var txt = String.fromCharCode(key);
        var reg = /[0-9.]/;
        if (value.indexOf('.') > -1) {
            var splitdot = value.split('.');
        if (splitdot[1].length >= 2)
            e.preventDefault();
    }
    if (reg.test(txt))
        return true;

    e.preventDefault();
    return false;

});
    $('#UO_GRet_RnCarrier').keypress(function (e) {
        var regex = new RegExp("^[a-zA-Z0-9]+$");
        var str = String.fromCharCode(!e.charCode ? e.which : e.charCode);
        if (regex.test(str)) {
            return true;
    }
    e.preventDefault();
    return false;
});


