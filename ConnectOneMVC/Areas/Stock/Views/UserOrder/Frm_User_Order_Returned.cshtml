    {
        if ("@UO_ProfileCore__AddRight" == "False")
        {
	        $("#UORetRnAddLocation").hide();	
        }
        var form = "ID_Frm_Returned_Window";
        ShowLoader();
        AssignIDtoLabel(form, "UO_Return");
       
