<link href="/content/fontawesome/css/fontawesome-all.css" rel="stylesheet">
<div id="Frm_User_Order_Returned_PopUp" class="edit_form">
    @using (Ajax.BeginForm("Frm_User_Order_Returned_All", "UserOrder",
                          new AjaxOptions
                          {
                              HttpMethod = "POST",
                              UpdateTargetId = "Frm_User_Order_Returned_PopUpAll",
                              InsertionMode = InsertionMode.InsertAfter,
                              OnBegin = "AjaxBeginFormPost",
                              OnSuccess = "Frm_User_Order_Returned_All_OnSuccess"
                          },
                          new
                          {
                              id = "ID_Frm_Returned_WindowAll",
                              @class = "edit_form"
                          }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.UO_GRetA_ActionMethod)
        @Html.HiddenFor(x => x.UO_GRetA_Returned_Mode)
        @Html.HiddenFor(x => x.UO_GRetA_Returned_Location)
        @Html.HiddenFor(x => x.UO_GRetA_Returned_By)
        @Html.HiddenFor(x => x.UO_GRetA_Sr)
        @Html.HiddenFor(x => x.UO_GRetA_ID)
        @Html.HiddenFor(x => x.UOid)
        using (Html.DevExtreme().ValidationGroup())
        {
            @*<div class="full-width-header-bg3">
                    <div class="row">

                        <div class="col-sm-8">
                            <h3 class="popuphead"><i class="far fa-edit"></i> Item Details</h3>
                        </div>
                        <div class="col-sm-4 prm">
                            <h5 class="mand-txt-align"><i class="fas fa-info-circle"></i> Red Fields are mandatory</h5>
                        </div>
