                </div>*@





            <div class="row formRow">

                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label text-red" for="user">Return Date</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm pll2">
                        @(Html.DevExtreme().DateBoxFor(model => model.UO_GRetA_Returned_Date).CustomDateBox()
                                                                                                                         .ID("UO_GRetA_Returned_Date")
                                                                                                                         .Name("UO_GRetA_Returned_Date")
                                                                                                                         .ReadOnly(IsVisible)
                                                                                                                         .Disabled(IsVisible)
                        )
                        @Html.ValidationMessageFor(model => model.UO_GRetA_Returned_Date, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div><!--[row6]-->

            <div class="row formRow">
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label text-red" for="user">Return Mode</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm pll2">
                        @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("UO_GRetA_Returned_ModeId").Name("UO_GRetA_Returned_ModeId")
                                                                                                      .Value(Model.UO_GRetA_Returned_ModeId)
                                                                                                      .ValueExpr("ModeID")
                                                                                                      .DisplayExpr("Mode")
                                                                                                      .DataSource(d => d.Mvc().Controller("UserOrder").LoadAction("LookUp_Get_Returned_Mode").Key("ModeID"))
                                                                                                      //.Placeholder("DropDown::Courier, Registry, Transport, Railways, By Hand, Ship, Air")

                                                                                                      .ReadOnly(IsVisible)
                                                                                                      .Disabled(IsVisible)
                                                                                                      .OnValueChanged("Returned_Mode_ChangeEventAll")

                                                                                                      .ContentTemplate(@<text>
                                                                                                        @Html.Partial("LookUp_Get_Returned_Mode")
                                                                                                    </text>)
                        )
                        @Html.ValidationMessageFor(model => model.UO_GRetA_Returned_ModeId, "", new { @class = "text-danger" })
                    </div>
                </div><!--[1]-->
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label" for="user">Lot No.</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm">
                        @(Html.DevExtreme().TextBox().CustomTextBox()
                                                                                                                                        .ID("UO_GRetA_RnLot_No")
                                                                                                                                        .Name("UO_GRetA_RnLot_No")
                                                                                                                                        .Value(Model.UO_GRetA_RnLot_No)
                                                                                                                                        .ReadOnly(true)
                                                                                                                                        .Disabled(IsVisible)
                        )
                    </div>
                </div><!--[2]-->
            </div>

            <div class="row formRow">
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label" for="user">Carrier:</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm pll2">
                        @(Html.DevExtreme().TextBox().CustomTextBox().ID("UO_GRetA_RnCarrier").Name("UO_GRetA_RnCarrier").Value(Model.UO_GRetA_RnCarrier).MaxLength(100).ReadOnly(IsVisible)
                                                                                                                      .Disabled(IsVisible))
                    </div>
                </div><!--[1]-->
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label text-red" for="user">Return Location:</label></div>
                    <div class="col-sm-4 col-md-4 col-lg-4 prm">
                        @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("UO_GRetA_Returned_LocationId").Name("UO_GRetA_Returned_LocationId")
                                                                                                                                   .Value(Model.UO_GRetA_Returned_LocationId)
                                                                                                                                   .ValueExpr("Loc_Id")
                                                                                                                                   .DisplayExpr("Location_Name")
                                                                                                                                   .DataSource(d => d.Mvc().Controller("UserOrder").LoadAction("LookUp_Get_Returned_Location").Key("Loc_Id").LoadParams(new { retuoStoreID = new JS("function (){ return Requestee_Store_ID;}") }))
                                                                                                                                   //.Placeholder("DropDown(Will show location mentioned in item entry as default)")

                                                                                                                                   .ReadOnly(IsVisible)
                                                                                                                                   .Disabled(IsVisible)
                                                                                                                                   .OnValueChanged("Returned_Location_ChangeEventAll")

                                                                                                                                   .ContentTemplate(@<text>
                                                                                                                                    @Html.Partial("LookUp_Get_Returned_Location")
                                                                                                                                </text>)
                        )
                        @Html.ValidationMessageFor(model => model.UO_GRetA_Returned_LocationId, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-sm-4 col-md-4 col-lg-4 prm">
                        @(Html.DevExtreme().Button()
                                                                                                                           .ID("UORetRnAddLocationAll")
                                                                                                                           .Text("Add Location")
                                                                                                                           .Disabled(IsVisible)
                                                                                                                           .OnClick(@<text>
                                                                                                                            function () {
                                                                                                                            UO_Ret_Add_Location_All_Click()
                                                                                                                            }
                                                                                                                        </text>))
                    </div>
                </div><!--[2]-->
            </div><!--[row8]-->

            <div class="row formRow">
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label" for="user">Returned By:</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm pll2">
                        @(Html.DevExtreme().DropDownBox().CustomDropDown().ID("UO_GRetA_Returned_By_Id").Name("UO_GRetA_Returned_By_Id")
                                                                                                                                            .Value(Model.UO_GRetA_Returned_By_Id)
                                                                                                                                            .ValueExpr("ID")
                                                                                                                                            .DisplayExpr("Name")
                                                                                                                                            .DataSource(d => d.Mvc().Controller("UserOrder").LoadAction("LookUp_Get_Returned_By").Key("ID").LoadParams(new { UOretMainDeptID = new JS("function (){ return MainDeptID;}"), UOretSubDeptID = new JS("function (){ return subdeptid;}") }))
                                                                                                                                            .Placeholder("Pre-filled as Logged in user)")

                                                                                                                                            .ReadOnly(IsVisible)
                                                                                                                                            .Disabled(IsVisible)
                                                                                                                                            .OnValueChanged("Returned_By_ChangeEventAll")

                                                                                                                                            .ContentTemplate(@<text>
                                                                                                                                                @Html.Partial("LookUp_Get_Returned_By")
                                                                                                                                            </text>)
                        )
                    </div>
                </div><!--[1]-->
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label" for="user">Mobile/CUG No.:</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm">
                        @(Html.DevExtreme().TextBox().CustomTextBox()
                                                                                                                        .ID("UO_GRetA_RnMobileNo")
                                                                                                                        .Name("UO_GRetA_RnMobileNo")
                                                                                                                        .Value(Model.UO_GRetA_RnMobileNo)
                                                                                                                        .ReadOnly(true)
                                                                                                                        .Disabled(IsVisible)
                        )
                    </div>
                </div><!--[2]-->
            </div>
            <div class="row formRow">
                <div class="col-sm-2 col-md-2 col-lg-2 pll"><label class="control-label " for="user">Returned Remarks:</label></div>
                <div class="col-sm-10 col-md-10 col-lg-10 prm ">
                    @(Html.DevExtreme().TextBox().ID("UO_GRetA_RnRemarks").CustomTextBox().Name("UO_GRetA_RnRemarks").Value(Model.UO_GRetA_RnRemarks).Placeholder("Enter Remark").MaxLength(8000).ReadOnly(IsVisible)
                                                                                                                          .Disabled(IsVisible))
                </div>
            </div><!--[row10]-->

            <div class="row styleActionBtn marginAll8">
                @if (Model.UO_GRetA_ActionMethod.ToString().Trim() == "View")
                {
                    @(Html.DevExtreme().Button().CustomCloseButton()
                                                                                                        .Text("Close")
                                                                                                        .ID("UOReturned_CancleAll")
                                                                                                        .FocusStateEnabled(true)
                                                                                                        .OnClick(@<text>
                                                                                                            function () {
                                                                                                            $("#UserOrderinnergrid").dxPopup("hide");
                                                                                                            }
                                                                                                        </text>)
                    )
                }
                @if (Model.UO_GRetA_ActionMethod.ToString().Trim() == "New" || Model.UO_GRetA_ActionMethod.ToString().Trim() == "Edit")
                {
                    @(Html.DevExtreme().Button().CustomSaveButton()
                                                                                                              .Text("OK")
                                                                                                              .ID("UOReturned_SaveAll")
                                                                                                              .FocusStateEnabled(true)
                                                                                                              .UseSubmitBehavior(true)
                    )
                    @(Html.DevExtreme().Button().CustomCloseButton()
                                                                                                          .Text("Cancel")
                                                                                                          .ID("UOSaveReturned_CancleAll")
                                                                                                          .FocusStateEnabled(true)
                                                                                                          .OnClick(@<text>
                                                                                                            function () {
                                                                                                            $("#UserOrderinnergrid").dxPopup("hide");
                                                                                                            }
                                                                                                        </text>)
                    )

                }
                @if (Model.UO_GRetA_ActionMethod.ToString().Trim() == "Delete")
                {
                    @(Html.DevExtreme().Button().CustomSaveButton()
                                                                                                              .Text("Delete")
                                                                                                              .ID("UOReturned_DeleteAll")

                                                                                                              .FocusStateEnabled(true)
                                                                                                              .UseSubmitBehavior(true)
                    )
                    @(Html.DevExtreme().Button().CustomCloseButton()
                                                                                                            .Text("Cancel")
                                                                                                            .ID("UODeleteReturned_CancleAll")

                                                                                                            .FocusStateEnabled(true)
                                                                                                            .OnClick(@<text>
                                                                                                                function () {
                                                                                                                $("#UserOrderinnergrid").dxPopup("hide");
                                                                                                                }
                                                                                                            </text>)
                    )
                }
            </div>
        }
    }

</div>
<script>
                                                                                                                              
    $(document).ready(function ()
    {
        if ("@UO_ProfileCore__AddRight" == "False")
        {
	        $("#UORetRnAddLocationAll").hide();	
        }
        var form = "ID_Frm_Returned_WindowAll";
        ShowLoader();
        AssignIDtoLabel(form, "UO_returnAll");
        setTimeout(function ()
        {
            Set_Form_View_Delete_Mode(null, form, "@Model.UO_GRetA_ActionMethod");
            Focus_FirstEditable_Field(form, "@Model.UO_GRetA_ActionMethod");
            HideLoader();

        }, Timeout500);

    });
</script>
<script>


        function Returned_Mode_ChangeEventAll(e) {

            var dropDownBox = $("#UO_GRetA_Returned_ModeId").dxDropDownBox("instance");
            dropDownBox.close();
            var $dataGrid = $("#LookUp_Returned_Mode_datagrid");
            if ($dataGrid.length) {
                var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(dropDownBox.option("value"), false);
                if (dataGrid.getSelectedRowsData().length > 0) {
                    var item = dataGrid.getSelectedRowsData()[0];
            var ReturnedMode = item.Mode;
            $("#UO_GRetA_Returned_Mode").val(ReturnedMode);
        }
}
}
        function Returned_Location_ChangeEventAll(e) {

            var dropDownBox = $("#UO_GRetA_Returned_LocationId").dxDropDownBox("instance");
            dropDownBox.close();
            var $dataGrid = $("#LookUp_Returned_Location_datagrid");
            if ($dataGrid.length) {
                var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(dropDownBox.option("value"), false);
                if (dataGrid.getSelectedRowsData().length > 0) {
                    var item = dataGrid.getSelectedRowsData()[0];
            var LocationName = item.Location_Name;
            $("#UO_GRetA_Returned_Location").val(LocationName);
        }
}
}
        function Returned_By_ChangeEventAll(e) {

            var dropDownBox = $("#UO_GRetA_Returned_By_Id").dxDropDownBox("instance");
            dropDownBox.close();
            var $dataGrid = $("#LookUp_Returned_By_datagrid");
            if ($dataGrid.length) {
                var dataGrid = $dataGrid.dxDataGrid("instance");
            dataGrid.selectRows(dropDownBox.option("value"), false);
                if (dataGrid.getSelectedRowsData().length > 0) {
                    var item = dataGrid.getSelectedRowsData()[0];
            var ReturnedName = item.Name;
            $("#UO_GRetA_Returned_By").val(ReturnedName);
            $("#UO_GRetA_RnMobileNo").dxTextBox("instance").option("value", item["Mobile_No"]);
        }
}
}



    function UO_Ret_Add_Location_All_Click() {
        if ("@UO_ProfileCore__AddRight" == "False")
        {
	        DevExpress.ui.dialog.alert("Not Allowed!!", "No Rights");
	        return;
        }
                $.ajax({
                    type: 'GET',
                    url: "/Account/ProfilePaymentVoucher/AddLocations_Check",
                    data: { ActionMethod: "New" },
                    cache: false,
                    async: false,
                    success: function (data) {
                        if (data.result) {
                            $.ajax({
                                type: 'GET',
                                url: "/Account/ProfilePaymentVoucher/Frm_Location_Window",
                                data: {
                                    ActionMethod: "New",
                                    PopupID: "RecdPaymentAddLocation",
                                    CallingScreen: "UO",
                                    Dropdown_DataGrid: "LookUp_Returned_Location_datagrid"
                                },//Mantis bug 0000505 fixed
                                cache: false,
                                async: false,
                                success: function (data) {
                                    ShowLoader();
                                    $("#RecdPaymentAddLocation").dxPopup('show');
                                    $("#RecdPaymentAddLocation").dxPopup("instance").option("title", "New~Location");
                                    $("#result_RecdPaymentAddLocation").html(null);
                                    $("#result_RecdPaymentAddLocation").html(data);
                                    HideLoader();
                                }
                            });
                        }
                        else {
                            DevExpress.ui.dialog.alert(data.message, "Error");
                        }
                    }
                });
            }


        $('#UO_GRet_RnCarrier').keypress(function (e) {
            var regex = new RegExp("^[a-zA-Z0-9]+$");
            var str = String.fromCharCode(!e.charCode ? e.which : e.charCode);
            if (regex.test(str)) {
                return true;
        }
        e.preventDefault();
        return false;
});
</script>
