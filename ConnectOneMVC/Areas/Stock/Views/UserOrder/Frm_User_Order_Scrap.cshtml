<link href="/content/fontawesome/css/fontawesome-all.css" rel="stylesheet">
<div id="User_Order_Scrap">
    @using (Ajax.BeginForm("User_Order_Scrap", "UserOrder",
                                          new AjaxOptions
                                          {
                                              HttpMethod = "POST",
                                              UpdateTargetId = "User_Order_Scrap",
                                              InsertionMode = InsertionMode.InsertAfter,
                                              OnBegin = "AjaxBeginFormPost",
                                              OnSuccess = "Frm_User_Order_Scrap_Window_OnSuccess"
                                          },
                                          new
                                          {
                                              id = "ID_Frm_UserOrder_Scrap",
                                              @class = "edit_form"
                                          }))
    {
        @Html.HiddenFor(x => x.UOScrap_Sr)
        @Html.HiddenFor(x => x.UOScrapActionMethod)
        @Html.HiddenFor(x => x.UOScrapID)
        @Html.HiddenFor(x => x.UOScrapItemName)
        @Html.HiddenFor(x => x.UOScrapUnitID)
        @Html.HiddenFor(x => x.UOScrap_Rate)
        @Html.HiddenFor(x => x.UOScrap_Location)
        @Html.HiddenFor(x => x.UORequestee_Store_Id)
        @Html.HiddenFor(x => x.UOid)

        using (Html.DevExtreme().ValidationGroup())
        {
            @*<div class="full-width-header-bg3">
                    <div class="row">

                        <div class="col-sm-8 pll">
                            <h3 class="popuphead"><i class="far fa-edit"></i>Scrap Creation</h3>
                        </div>
                        <div class="col-sm-4 prm">
                            <h5 class="mand-txt-align"><i class="fas fa-info-circle"></i> Red Fields are mandatory</h5>
                        </div>
                    </div>

                </div>*@

            <div class="row formRow">
                <div class="col-sm-2 col-md-2 col-lg-2 pll"><label class="control-label text-red" for="user">Item Name:</label></div>
                <div class="col-sm-4 col-md-4 col-lg-4 prm pll2">
                    @(Html.DevExtreme().DropDownBox().CustomDropDown()
                                            .ID("UOScrap_ItemId")
                                            .Name("UOScrap_ItemId")                                            
                                            .Value(Model.UOScrap_ItemId)
                                            .Placeholder("Select Scrap Item Name")
                                            .ValueExpr("Item_ID")
                                            .DisplayExpr("Stock_Item_Name")
                                            .DataSource(d => d.Mvc().Controller("UserOrder").LoadAction("Scrap_Item_Name_List").Key("Item_ID"))                                      
                                            .OnValueChanged("OnScrap_ItemName_Changed")                                          
                                            .ReadOnly(IsVisible)
                                            .Disabled(IsVisible)
                                            .ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } })
                                            .OnInitialized("OnInitialized_OnScrap_ItemName_Changed")
                                            .ContentTemplate(@<text>
                                                @Html.Partial("Scrap_Item_Name_List")
                                            </text>))
                    @Html.ValidationMessageFor(model => model.UOScrap_ItemId, "", new { @class = "text-danger" })
                </div>
                <div class="col-sm-6 col-md-6 col-lg-6 prm pll2">
                    @(Html.DevExtreme().Button().ID("UOAddScrapItem").Text("Add Scrap Item").Disabled(IsVisible).OnClick(@<text> function () { UOAdd_ScrapItem_Click() } </text>))
                </div>
            </div>
            <div class="row formRow">
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label " for="user">Item code:</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm">
                        @(Html.DevExtreme().TextBox().CustomTextBox()
                                                                .ID("UOScrap_Itemcode")
                                                                .Name("UOScrap_Itemcode")
                                                                .Value(Model.UOScrap_Itemcode)
                                                                .MaxLength(20)
                                                                .Placeholder("Item Code for Select Item")
                                                                .ReadOnly(true)
                                                                .Disabled(IsVisible)
                        )
                    </div>
                </div>
                <div class="col-sm-6 col-md-6 col-lg-6">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label text-red" for="user">Location:</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm">
                        @(Html.DevExtreme().DropDownBox().CustomDropDown()
                                                                                            .ID("UOScrap_LocationID")
                                                                                            .Name("UOScrap_LocationID")
                                                                                            .Value(Model.UOScrap_LocationID)
                                                                                            .Placeholder("Select Location")
                                                                                            .ValueExpr("Loc_Id")
                                                                                            .DisplayExpr("Location_Name")
                                                                                            .DataSource(d => d.Mvc().Controller("UserOrder").LoadAction("LookUp_Scrap_Location_List").Key("Loc_Id").LoadParams(new { uoscrapStoreID = new JS("function (){ return Requestee_Store_ID;}") }))                                                                                     
                                                                                            .ReadOnly(IsVisible)
                                                                                            .Disabled(IsVisible)
                                                                                            .OnValueChanged("Scrap_GetLocation_ChangeEvent")                                                                                           
                                                                                            .OnInitialized("onInitialized_LookUp_ScrapGetLocation")
                                                                                            .ContentTemplate(@<text>
                                                                                                @Html.Partial("LookUp_Scrap_Location_List")
                                                                                            </text>)
                        )
                        @Html.ValidationMessageFor(model => model.UOScrap_LocationID, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div><!--[2]-->
            <div class="row formRow">
                <div class="col-sm-4 col-md-4 col-lg-4">
                    <div class="col-sm-6 col-md-6 col-lg-6 pll"><label class="control-label text-red" for="user">Qty.:</label></div>
                    <div class="col-sm-6 col-md-6 col-lg-6 prm">
                        @(Html.DevExtreme().NumberBox().CustomNumberBox()
                                                                                        .ID("UOScrap_Qty")
                                                                                        .Name("UOScrap_Qty")
                                                                                        .Value(Model.UOScrap_Qty)
                                                                                        .Placeholder("Enter Quantity")
                                                                                       .OnChange("UOScrapCalculateRate")
                                                                                        .ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } })
                                                                                          .Format("#0.00")
                                                                                        .ReadOnly(IsVisible)
                                                                                    .Disabled(IsVisible)
                        )
                        @Html.ValidationMessageFor(model => Model.UOScrap_Qty, "", new { @class = "text-danger" })
                    </div>
                </div><!--[3]-->
                <div class="col-sm-4 col-md-4 col-lg-4">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label text-red" for="user">Unit:</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm">
                        @(Html.DevExtreme().TextBox().CustomTextBox()
                                                                                                    .ID("UOScrap_Unit")
                                                                                                    .Name("UOScrap_Unit")
                                                                                                    .Value(Model.UOScrap_Unit)
                                                                                                    .MaxLength(20)
                                                                                                    .Placeholder("Unit")
                                                                                                    .ElementAttr(new Dictionary<string, object>() { { "class", "dx-texteditor-input appear" } })
                                                                                                    .Placeholder("Unit for select Item")
                                                                                                    .ReadOnly(true)
                                                                                                    .Disabled(IsVisible)
                        )
                    </div>
                </div><!--[1]-->
                <div class="col-sm-4 col-md-4 col-lg-4">
                    <div class="col-sm-4 col-md-4 col-lg-4 pll"><label class="control-label text-red" for="user">Amount:</label></div>
                    <div class="col-sm-8 col-md-8 col-lg-8 prm">
                        @(Html.DevExtreme().NumberBox().CustomNumberBox()
                                                                                        .ID("UOScrap_Amount")
                                                                                        .Name("UOScrap_Amount")
                                                                                        .Value(Model.UOScrap_Amount)
                                                                                        .Placeholder("Enter Amount")
                                                                                        .OnChange("UOScrapCalculateRate")
                                                                                        .Format("##0.00")
                                                                                        .ReadOnly(IsVisible)
                                                                                        .Disabled(IsVisible)
                        )
                        @Html.ValidationMessageFor(model => Model.UOScrap_Amount, "", new { @class = "text-danger" })
                    </div>
                </div><!--[2]-->
            </div>

            <div class="row formRow">
                <div class="col-sm-2 col-md-2 col-lg-2 pll"><label class="control-label" for="user">Remarks:</label></div>
                <div class="col-sm-10 col-md-10 col-lg-10 prm">
                    @(Html.DevExtreme().TextBox().CustomTextBox()
                                                                                        .ID("UOScrap_Remarks")
                                                                                        .Name("UOScrap_Remarks")
                                                                                        .Value(Model.UOScrap_Remarks)
                                                                                        .Placeholder("Type Remarks....")
                                                                                        .ReadOnly(IsVisible)
                                                                                        .Disabled(IsVisible)
                    )
                </div>
            </div><!--[row3]-->
            <div class="row styleActionBtn marginAll8">
                @if (Model.UOScrapActionMethod.ToString().Trim() == "View")
                {
                    @(Html.DevExtreme().Button().CustomCloseButton()
                                                                                                .Text("Close")
                                                                                                .ID("UserOder_Scrap_Cancle")
                                                                                              
                                                                                                .FocusStateEnabled(true)
                                                                                                .OnClick(@<text>
                                                                                                    function () {
                                                                                                    $("#UserOrderinnergrid").dxPopup("hide");
                                                                                                    }
                                                                                                </text>)
                    )
                }
                @if (Model.UOScrapActionMethod.ToString().Trim() == "New" || Model.UOScrapActionMethod.ToString().Trim() == "Edit")
                {
                    @(Html.DevExtreme().Button().CustomSaveButton()
                                                                                               .Text("OK")
                                                                                               .ID("UserOrder_Scrap_Save")
                                                                                             
                                                                                               .UseSubmitBehavior(true))
                    @(Html.DevExtreme().Button().CustomCloseButton()
                                                                                                .Text("Cancel")
                                                                                                .ID("UserOrder_Scrap_Cancle")
                                                                                            
                                                                                                .FocusStateEnabled(true)
                                                                                                .OnClick(@<text>
                                                                                                    function () {
                                                                                                    $("#UserOrderinnergrid").dxPopup("hide");
                                                                                                    }
                                                                                                </text>)
                    )
                }
            </div>
        }
    }
</div>

@(Html.DevExtreme().Popup().CustomPopup().ID("Stockitemscrap").CloseOnOutsideClick(false).ShowTitle(true).Title("New ~ ").ContentTemplate(@<text> <div id="result_Stockitemscrap">  </div> </text>))
     
<script>                                                                                                                            
    $(document).ready(function ()
    {
        var form = "ID_Frm_UserOrder_Scrap";
        ShowLoader();
        AssignIDtoLabel(form, "UO_Scrap");
        setTimeout(function ()
        {
            Set_Form_View_Delete_Mode(null, form, "@Model.UOScrapActionMethod");
            Focus_FirstEditable_Field(form, "@Model.UOScrapActionMethod");
            HideLoader();

        }, Timeout500);

    });
</script>
                                                                                                                                 
 <script>



                function OnScrap_ItemName_Changed(e) {
                    if (e.value != e.previousValue && e.previousValue != null) {
                        $("#UOScrap_Qty").dxNumberBox("instance").reset();
                        $("#UOScrap_Amount").dxNumberBox("instance").reset();
                    }
                    var dropDownBox = $("#UOScrap_ItemId").dxDropDownBox("instance");
                    dropDownBox.close();
                    var $dataGrid = $("#LookUp_GetScrapItems_datagrid");
                    if ($dataGrid.length) {
                        var dataGrid = $dataGrid.dxDataGrid("instance");
                        dataGrid.selectRows(e.value, false);
                        if (dataGrid.getSelectedRowsData().length > 0) {
                            var item = dataGrid.getSelectedRowsData()[0];
                            $("#UOScrap_Itemcode").dxTextBox("instance").option("value", item["Item_Code"]);
                            $("#UOScrap_Unit").dxTextBox("instance").option("value", item["Unit"]);
                            //Hidden values Through model binding
                            $("#UOScrapItemName").val(item["Stock_Item_Name"]);

                            $("#UOScrapUnitID").val(item["UnitID"]);
                        }
                    }
                }
                function OnInitialized_OnScrap_ItemName_Changed(e) {
                    if ("@Model.UOScrapActionMethod" != "New") {
                        $("#UOScrap_ItemId").dxDropDownBox("instance").option("value","@Model.UOScrap_ItemId");
            e.component.option("dataSource").store.load().done(function (d) {
                if (d.length > 0) {
                    var $dataGrid = $("#LookUp_GetScrapItems_datagrid");
                    if ($dataGrid.length) {
                        var dataGrid = $dataGrid.dxDataGrid("instance");
                        dataGrid.selectRows("@Model.UOScrap_ItemId", false);
                    }
                }
            });
        }
                }
                function Scrap_GetLocation_ChangeEvent(e) {
                    var dropDownBox = $("#UOScrap_LocationID").dxDropDownBox("instance");
                    dropDownBox.close();
                    var $dataGrid = $("#LookUp_Scrap_Location_datagrid");
                    if ($dataGrid.length) {
                        var dataGrid = $dataGrid.dxDataGrid("instance");
                        dataGrid.selectRows(e.value, false);
                        if (dataGrid.getSelectedRowsData().length > 0) {
                            var item = dataGrid.getSelectedRowsData()[0];

                            $("#UOScrap_Location").val(item["Location_Name"]);
                        }
                    }
                }
                function onInitialized_LookUp_ScrapGetLocation(e) {
                    if (e.component.option("dataSource") != null) {
                        e.component.option("dataSource").store.load().done(function (d) {

                            if (d.length == 1)
                                e.component.option("value", d[0].LocationName);

                        });
                    }
                }


                function UOScrapCalculateRate() {
                    uoscrapqty = $("#UOScrap_Qty").dxNumberBox("instance").option("value");
                    uoscrapamt = $("#UOScrap_Amount").dxNumberBox("instance").option("value");
                    uoscraprate = uoscrapamt / uoscrapqty;
                    $("#UOScrap_Rate").val(uoscraprate);
                }
    function UOAdd_ScrapItem_Click() {
   
        if ("@UO_AddStockItemRight"=="True") {
        
            ShowLoader();
            $.ajax({
                type: "GET",
                url: "/Stock/StockItemWindow/StockItemWindowNew",
                data: {
                    ActionMethod: "_New",
                    ID: 0,
                    PostSucessFunction: "StockItem_AddScrap_Success",
                    PopupName: "StockItemScrap",
                    ButtonID: "UOAddScrapItem"

                },
                success: function (data) {
                    OpenPopup("Stockitemscrap", "Request ~ Add UO Scrap Item", null, "auto", 1150, true, data);
                }
            });
         
        }
        else if ("@UO_AddHelpRequestRight"=="True")
        {
            ShowLoader();

             $.ajax({
                type: 'Get',
                url: "/Help/RequestBox/Frm_Request_Window",
                data: { PopUpId: "Stockitemscrap", ActionMethod: "New", _Send_From: "UO -Scrap Screen" },
                cache: false,
                 success: function (resultsuccess)
                 {
                     OpenPopup("Stockitemscrap", "Request ~ Add UO Scrap Item", null, "auto", "50%", true, resultsuccess);
                 }
             });
        }

    }
                function StockItem_AddScrap_Success(data) {
                    HideLoader();
                    if (data.result == true) {
                        $("#Stockitemscrap").dxPopup("hide");
                        $("#LookUp_GetScrapItems_datagrid").dxDataGrid("instance").refresh();
                    }
                    else {
                        DevExpress.ui.dialog.alert(data.Message, "Error");
                    }
                }
 </script>
