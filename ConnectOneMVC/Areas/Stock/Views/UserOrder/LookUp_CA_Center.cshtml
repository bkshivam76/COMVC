@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                .ID("LookUp_GetCenterDet_datagrid")             
                .Columns(columns =>
                {

                    columns.Add().DataField("CenterName").Caption("Center Name").Width(120);
                    columns.Add().DataField("Center_UID").Caption("Center UID").Width(120).SortOrder(SortOrder.Asc);
                    columns.Add().DataField("CENID").Caption("CEN ID").Width(0).Visible(false);


                })
                .HoverStateEnabled(true)
                .Paging(p => p.PageSize(100))
                .FilterRow(f => f.Visible(true))
                .Scrolling(s => s.Mode(GridScrollingMode.Infinite))
                .Height(300)
                .Selection(s => s.Mode(SelectionMode.Single))
           
)






