@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
        .ID("LookUp_CA_GetStoreItems_datagrid")   
        .Columns(columns =>
        {

            columns.Add().DataField("Name").Caption("Item Name").Width(120).SortOrder(SortOrder.Asc);
            columns.Add().DataField("Item_Type").Caption("Item Type").Width(160);
            columns.Add().DataField("Item_Code").Caption("Item Code").Width(90);
            columns.Add().DataField("ItemID").Caption("ItemID").Width(100).Visible(true);
         
        })
  
        .Selection(s => s.Mode(SelectionMode.Single))
    
)




