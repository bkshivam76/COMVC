@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
            .ID("LookUp_GetLocation_datagrid")         
            .Columns(columns =>
            {
                columns.Add().DataField("LocationName").Caption("Location Name").Width(200).SortOrder(SortOrder.Asc);
                columns.Add().DataField("MatchedType").Caption("Matched Type").Width(200);
                columns.Add().DataField("MatchedName").Caption("Matched Name").Width(200);
                columns.Add().DataField("LocID").Caption("LocID").Visible(false); 

            })
       
            .Selection(s => s.Mode(SelectionMode.Single))
        
)






