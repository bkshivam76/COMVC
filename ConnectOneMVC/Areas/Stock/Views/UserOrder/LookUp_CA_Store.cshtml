@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
        .ID("LookUp_GetStoreDetails_datagrid")    
        .Columns(columns =>
        {
            columns.Add().DataField("Store_Name").Caption("Store Name").Width(200).SortOrder(SortOrder.Asc);
            columns.Add().DataField("Dept_Name").Caption("Dept Name").Width(200);
            //columns.Add().DataField("Sub_Dept_Name").Caption("Sub Dept Name").Width(200);
            //columns.Add().DataField("Dept_Incharge_Name").Caption("Dept Incharge Name").Width(0).Visible(false);
            columns.Add().DataField("Store_Incharge_Name").Caption("Store Incharge Name");
            columns.Add().DataField("StoreID").Caption("StoreID").Width(0).Visible(false);
            columns.Add().DataField("Store_Incharge_ID").Caption("StoreIncID").Width(0).Visible(false);
        })
      
        .Selection(s => s.Mode(SelectionMode.Single))
    
)





