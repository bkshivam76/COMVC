@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                       .ID("LookUp_Item_DL_RequestedDG")
                       .Columns(columns =>
                       {
                           columns.Add().DataField("Item_Name").Caption("Item Name").Visible(true);
                           columns.Add().DataField("Item_Code").Caption("Item Code").Visible(true);
                           columns.Add().DataField("Make").Caption("Make").Visible(true);
                           columns.Add().DataField("Model").Caption("Model").Visible(true);
                           columns.Add().DataField("Approved_Qty").Caption("Approved Qty").Visible(true);
                           columns.Add().DataField("Pending_Qty").Caption("Pending Qty").Visible(true);
                           columns.Add().DataField("Already_Delivered_Qty").Caption("Already_Delivered_Qty").Visible(true);
                           columns.Add().DataField("SubItemID").Caption("SubItemID").Visible(true);

                           columns.Add().DataField("ID").Caption("ID").Visible(false);

                           columns.Add().DataField("Unit").Caption("Unit").Visible(false);
                           columns.Add().DataField("Head").Caption("Head").Visible(false);
                           columns.Add().DataField("Item_Type").Caption("Item Type").Visible(false);

                           columns.Add().DataField("Delivery_Location_ID").Caption("DeliveryLocationID").Visible(false);
                           columns.Add().DataField("UOI_Priority").Caption("Priority").Visible(false);
                           columns.Add().DataField("Required_Delivery_Date").Caption("Required Delivery Date").Visible(false);
                           columns.Add().DataField("Scheduled_Delivery_Date").Caption("Scheduled Delivery Date").Visible(false);
                           columns.Add().DataField("Partial_Delivery_Allowed").Caption("Partial_Delivery_Allowed").Visible(false);

                       })

                        .Selection(s => s.Mode(SelectionMode.Single))

)
