@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
                   .ID("LookUp_Item_Received")
                   .Columns(columns =>
                   {
                       columns.Add().DataField("Item_Name").Caption("Item Name").Visible(true);
                       columns.Add().DataField("UDS_ID").Caption("UDS_ID").Visible(false);
                       columns.Add().DataField("Unreceived_Delivered_Qty").Caption("Pending Delivered Qty").Visible(true);
                       columns.Add().DataField("Item_Code").Caption("Item Code").Visible(true);
                       columns.Add().DataField("Make").Caption("Make").Visible(true);
                       columns.Add().DataField("Model").Caption("Model").Visible(true);
                       columns.Add().DataField("Delivered_Qty").Caption("Total Delivered Qty").Visible(true);
                       columns.Add().DataField("Delivery_Date").Caption("Delivery_Return_Date").Visible(true);
                       columns.Add().DataField("ItemEntrySource").Caption("Item Source Screen").Visible(true);
                       //columns.Add().DataField("Unit").Caption("Unit").Visible(false).Width(300);
                       columns.Add().DataField("Head").Caption("Head").Visible(false);
                       columns.Add().DataField("Item_Type").Caption("Item Type").Visible(false);
                       columns.Add().DataField("DeliveryLocationId").Caption("DeliveryLocationId").Visible(false);

                       columns.Add().DataField("ID").Caption("ID").Visible(false);
                       //  columns.Add().DataField("Carrier").Caption("Carrier").Visible(false).Width(300);
                       // columns.Add().DataField("Lot_No").Caption("Lot_No").Visible(false).Width(300);
                       columns.Add().DataField("Del_ID").Caption("DeliveredRecID").Visible(false);
                       columns.Add().DataField("Ret_ID").Caption("ReturnedRecID").Visible(false);
                       columns.Add().DataField("ModeID").Caption("ModeID").Visible(false);
                       columns.Add().DataField("Carrier").Caption("Carrier").Visible(false);
                       columns.Add().DataField("Lot_No").Caption("Lot_No").Visible(false);




                   })

                    .Selection(s => s.Mode(SelectionMode.Single))

)