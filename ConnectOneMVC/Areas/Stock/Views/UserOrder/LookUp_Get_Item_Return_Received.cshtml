@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("LookUp_Item_ReturnReceivedDG")
                     
                       .Columns(columns =>
                       {
                           columns.Add().DataField("Item_Name").Caption("Item Name").Visible(true);
                           columns.Add().DataField("Item_Code").Caption("Item Code").Visible(true);
                           columns.Add().DataField("Make").Caption("Make").Visible(true);
                           columns.Add().DataField("Model").Caption("Model").Visible(true);
                           columns.Add().DataField("Returned_Qty").Caption("Returned Qty").Visible(true);
                           columns.Add().DataField("PendingToReturn").Caption("Pending Ret-Recd Qty").Visible(true);
                           columns.Add().DataField("Return_Date").Caption("Return_Date").Visible(true);
                           columns.Add().DataField("Lot_No").Caption("Lot_No").Visible(true);                           
                           columns.Add().DataField("ItemEntrySource").Caption("Item Source Screen").Visible(true);
                           columns.Add().DataField("ID").Caption("ID").Visible(false);
                           columns.Add().DataField("Unit").Caption("Unit").Visible(false);
                           columns.Add().DataField("Head").Caption("Head").Visible(false);
                           columns.Add().DataField("Item_Type").Caption("Item Type").Visible(false);

                           columns.Add().DataField("ReturnLocationId").Caption("ReturnLocationId").Visible(false);

                           columns.Add().DataField("Del_ID").Caption("Del_ID").Visible(true);
                           columns.Add().DataField("Ret_ID").Caption("Ret_ID").Visible(true);
                           columns.Add().DataField("UDS_ID").Caption("UDS_ID").Visible(true);

                       })
                     
                        .Selection(s => s.Mode(SelectionMode.Single))
                       
)
