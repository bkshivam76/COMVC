@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("LookUp_GetJobNames_datagrid")
    .Columns(columns =>
    {
        columns.Add().DataField("Job_Name").Caption("Job Name");
        columns.Add().DataField("Job_No").Caption("Job No");
        columns.Add().DataField("Job_Type").Caption("Job Type");
        columns.Add().DataField("Proj_Name").Caption("Proj Name");
        columns.Add().DataField("Complex").Caption("Complex");
        columns.Add().DataField("Sanction_No").Caption("Sanction No"); 
        columns.Add().DataField("ID").Caption("ID").Visible(false);
    })
   
    .Selection(s => s.Mode(SelectionMode.Single))
  
)




