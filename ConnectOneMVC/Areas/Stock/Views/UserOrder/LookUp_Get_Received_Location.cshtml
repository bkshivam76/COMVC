@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid()
    .ID("LookUp_Received_Location_datagrid")
    .DataSource(new JS(@"component.option(""dataSource"")"))
    .Columns(columns =>
    {
        columns.Add().DataField("Location_Name").Caption("Location Name").SortOrder(SortOrder.Asc);
        columns.Add().DataField("Loc_Id").Caption("ID").Visible(false);
        columns.Add().DataField("Matched_Instt").Caption("Matched Instt");
        columns.Add().DataField("Matched_Name").Caption("Matched name");
        columns.Add().DataField("Matched_Type").Caption("Matched Type");
       
        
    })
    .HoverStateEnabled(true)
    .Paging(p => p.PageSize(100))
    .FilterRow(f => f.Visible(true))
    .Scrolling(s => s.Mode(GridScrollingMode.Infinite))
    .Height(300)
    .Selection(s => s.Mode(SelectionMode.Single))
    .OnSelectionChanged(@<text>
        function(selectedItems) {

        var keys = selectedItems.selectedRowKeys;
        component.option("value", keys);
        }
    </text>)
)




