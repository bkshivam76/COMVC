@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("LookUp_Received_Mode_datagrid")  
    .Columns(columns =>
    {
        columns.Add().DataField("Mode").Caption("Mode").SortOrder(SortOrder.Asc);
        columns.Add().DataField("ModeID").Caption("Mode ID").Visible(false);
    })
  
    .Selection(s => s.Mode(SelectionMode.Single))
  
)




