@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("LookUp_GetRequestNames_datagrid")
    .Columns(columns =>
    {
        columns.Add().DataField("Name").Caption("Name");
        columns.Add().DataField("Type").Caption("Personnel Type").Visible(false);
        columns.Add().DataField("Skill_Type").Caption("Skill Type");
        columns.Add().DataField("Designation").Caption("Designation").Visible(false);
        columns.Add().DataField("Main_Dept").Caption("Main Department Name");
        columns.Add().DataField("Sub_Dept").Caption("Sub Dept");
        columns.Add().DataField("Contractor").Caption("Contractor").Visible(false);
        columns.Add().DataField("Main_DeptID").Caption("Main Dept. ID").Visible(false);
        columns.Add().DataField("Sub_DeptID").Caption("Sub Dept. ID").Visible(false);
        columns.Add().DataField("ID").Caption("ID").Visible(false);
        columns.Add().DataField("Mobile_No").Caption("Mobile No").Visible(false);
    })

    .Selection(s => s.Mode(SelectionMode.Single))
