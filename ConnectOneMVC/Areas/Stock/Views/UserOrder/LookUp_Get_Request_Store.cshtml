@using DevExtreme.AspNet.Mvc;
@(Html.DevExtreme().DataGrid().CustomDataGrid()
    .ID("LookUp_GetStoreNames_datagrid") 
    .Columns(columns =>
    {
        columns.Add().DataField("Store_Name").Caption("Store Name");
        columns.Add().DataField("StoreID").Caption("Store ID").Visible(true);
        columns.Add().DataField("Store_Incharge_Name").Caption("Store_Incharge_Name").Visible(false);
        columns.Add().DataField("Store_Incharge_ID").Caption("Store_Incharge_ID").Visible(true);

    })
   
    .Selection(s => s.Mode(SelectionMode.Single))

)




