@using DevExtreme.AspNet.Mvc;
@model ConnectOneMVC.Areas.Stock.Models.NEVD_UserOrder
@{
    ViewBag.Test = Model.UO_ActionMethod;
    bool IsVisible = (Model != null && Model.UO_ActionMethod == "Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.UO_ActionMethod == "View" || Model.UO_ActionMethod == "Delete") ? true : false;
}
<div id="document" class="tab-pane fade in active">
    <div class="row">
        <div class="col-lg-12 col-xs-12 table-responsive overflow-scroll scrollbar">
            @Html.Action("UO_DocumentsGridData", "UserOrder", new { ActionMethodName = Model.UO_ActionMethod, UOID = Model.UOID })
        </div>
    </div>
    <div class="row btnsDiv formRow">
                        @(Html.DevExtreme().Button()
                                                  .ID("BUT_UDocNew")
                                                  .Text("New")
                                                  //.Icon("fas fa-file btn-icons newfile icon-rgt-space5")
                                                  .Disabled(IsDisabled)
                                                  .OnClick(@<text>
                                                    function () {
                                                    OnFrm_UserDoc_New_Click()
                                                    }
                                                </text>))
                        @(Html.DevExtreme().Button()
                                                  .ID("BUT_UDocEdit")
                                                  .Text("Edit")
                                                  //.Icon("fas fa-file btn-icons newfile icon-rgt-space5")
                                                  .Disabled(IsDisabled)
                                                  .OnClick(@<text>
                                                    function () {
                                                    OnFrm_UserDoc_Edit_Click()
                                                    }
                                                </text>))
                        @(Html.DevExtreme().Button()
                                                  .ID("BUT_UDocDelete")
                                                  .Text("Delete")
                                                  //.Icon("fas fa-file btn-icons newfile icon-rgt-space5")
                                                  .Disabled(IsDisabled)
                                                  .OnClick(@<text>
                                                    function () {
                                                    OnFrm_UserDoc_Delete_Click()
                                                    }
                                                </text>))
                        @(Html.DevExtreme().Button()
                                                  .ID("BUT_UDocView")
                                                  .Text("View")
                                                  //.Icon("fas fa-file btn-icons newfile icon-rgt-space5")
                                                  .Disabled(IsVisible)
                                                  .OnClick(@<text>
                                                    function () {
                                                    OnFrm_UserDoc_View_Click()
                                                    }
                                                </text>))
    </div>
</div><!--[1]-->

<script>
    var Document_Sr;
    var Document_ID;
    function OnDocumentDetailGridFocusedRowChanged(s, e)
    {
        s.GetRowValues(s.GetFocusedRowIndex(), 'Sr_No;ID', OnDocumentsDetailsGridRowValues);
    }
    function OnDocumentsDetailsGridRowValues(values)
    {
        Document_Sr = values[0];
        Document_ID = values[1];
    }

    $("#UserOrderDocumentsGrid").keydown(function (evt) {
        switch (evt.keyCode) {
            case 45: // insert key
                OnFrm_UserDoc_New_Click();
                break;
            case 13: //enter key
                OnFrm_UserDoc_Edit_Click();
                break;
            case 32: //space bar
                OnFrm_UserDoc_View_Click();
                break;
            case 46://delete key
                OnFrm_UserDoc_Delete_Click();
                break;
        }
        if (evt.ctrlKey && evt.keyCode == 73)//ctrl+i
        {
            OnFrm_UserDoc_New_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 69)//ctrl+e
        {
            OnFrm_UserDoc_Edit_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_UserDoc_View_Click();
        }
    });
    function Frm_Document_Detail_Grid_ContextMenuFunction(s, e) {
        if (e.item.name == "New") {
            OnFrm_UserDoc_New_Click();
        }
        if (e.item.name == "Edit") {
            OnFrm_UserDoc_Edit_Click();
        }
        if (e.item.name == "Delete") {
            OnFrm_UserDoc_Delete_Click();
        }
        if (e.item.name == "View") {
            OnFrm_UserDoc_View_Click();
        }
    }
    function OnFrm_UserDoc_New_Click()
    {
        debugger

         if ("@IsDisabled" == "true") { return; }

        var menucheck = UO_StatusFlowCheck("Documents");
        if (menucheck[1] == false) {
            DevExpress.ui.dialog.alert(menucheck[0], "Error");
            return;
        }
        $("#ID_Frm_Help_Document_Attach").remove();
        ShowLoader();

        $("#result_UserOrderinnergrid").html(null);
        $.ajax({
            type: 'GET',
            url: "/Help/Attachment/Frm_Attachment_Window",
            data: {
                AM: "New",
                PostSucessFunctionName: "Frm_UserOrder_Documents_Window_OnSuccess",
                Post_action_Name: "UserOrder_Documents_Attachment",
                Post_Controller_Name: "UserOrder",
                Post_Area_Name: "Stock",
                Document_Grid_PopupName: "UserOrderinnergrid",
                ByteSessionVariable: "UserOrderDocument"
            },
            cache: false,
            success: function (data) {
                OpenPopup("UserOrderinnergrid", "New ~ Documents", null, "auto", 1000, true, data);
            }
        });
   
    }//new click//Mantis 0000213 bug fixed

  
    function OnFrm_UserDoc_Edit_Click()
    {
          if ("@IsDisabled"=="true") { return; }

          if (!Document_Sr) {
              DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
              return;
          }
        $("#ID_Frm_Help_Document_Attach").remove();

        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Help/Attachment/Frm_Attachment_Window",
            data: {
                AM: "Edit",
                PostSucessFunctionName: "Frm_UserOrder_Documents_Window_OnSuccess",
                Post_action_Name: "UserOrder_Documents_Attachment",
                Post_Controller_Name: "UserOrder",
                Post_Area_Name: "Stock",
                Document_Grid_Data_SessionName: "UserOrder_Documents_Window_Grid_Data_UO",
                Document_Grid_SrNo: Document_Sr,
                ID: Document_ID,
                Document_Grid_PopupName: "UserOrderinnergrid",
                ByteSessionVariable: "UserOrderDocument"
            },
            cache: false,
            success: function (data) {
                OpenPopup("UserOrderinnergrid", "Edit ~ Documents", null, "auto", 1000, true, data);
            }
        });    
    }//edit click//Mantis 0000213 bug fixed
       
 
    function OnFrm_UserDoc_Delete_Click()
    {
         if ("@IsDisabled"=="true") { return; }
        
        if (!Document_Sr) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        if (Document_ID) {
            $.ajax({
                type: 'GET',
                url: "/Stock/UserOrder/UserOrder_Documents_Attachment_LinkCheck",
                data: { DocId: Document_ID, UOId: UOID },
                cache: false,
                success: function (data) {
                    if (data.result == false) {
                        var deleteResultDocument = DevExpress.ui.dialog.confirm(data.message, "Confirm changes");
                        deleteResultDocument.done(function (dialogResult) {
                            if (dialogResult) {
                                $.ajax({
                                    type: 'GET',
                                    url: "/Stock/UserOrder/Frm_DocumentsDetail_Window_Delete_Grid_Record",
                                    data: { ActionMethod: "Unlink", SrID: Document_Sr, Doc_ID: Document_ID },
                                    cache: false,
                                    success: function (result) {
                                        UserOrderDocumentsGrid.SetFocusedRowIndex(-1);
                                        UserOrderDocumentsGrid.Refresh();
                                    }
                                });
                            }
                        });
                    }
                    else {
                        userorder_deletedocument();
                    }
                }
            });
        }
        else {
            userorder_deletedocument();
        }
    } //delete click

    function userorder_deletedocument()
    {
     if ("@IsDisabled"=="True") { return; }

        var deleteResultPaymentDetail = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
        deleteResultPaymentDetail.done(function (dialogResult) {
            if (dialogResult) {
                $.ajax({
                    type: 'GET',
                    url: "/Stock/UserOrder/Frm_DocumentsDetail_Window_Delete_Grid_Record",
                    data: { ActionMethod: "Delete", SrID: Document_Sr, Doc_ID: Document_ID },
                    cache: false,
                    success: function (result) {
                        UserOrderDocumentsGrid.SetFocusedRowIndex(-1);
                        UserOrderDocumentsGrid.Refresh();
                    }
                });
            }
        });
    }

    function OnFrm_UserDoc_View_Click()
    {
        debugger;    
        if (Document_Sr == 'undefined' || Document_Sr == undefined || Document_Sr == null || Document_Sr == "") {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        $("#ID_Frm_Help_Document_Attach").remove();
        ShowLoader();

          
      $.ajax({
              type: 'GET',
              url: "/Help/Attachment/Frm_Attachment_Window",
              data: {
                  AM: "View",
                  PostSucessFunctionName: "Frm_UserOrder_Documents_Window_OnSuccess",
                  Post_action_Name: "UserOrder_Documents_Attachment",
                  Post_Controller_Name: "UserOrder",
                  Post_Area_Name: "Stock",
                  Document_Grid_Data_SessionName: "UserOrder_Documents_Window_Grid_Data_UO",
                  Document_Grid_SrNo: Document_Sr,
                  ID: Document_ID,
                  Document_Grid_PopupName: "UserOrderinnergrid",
                  ByteSessionVariable: "UserOrderDocument"
              },
              cache: false,
              success: function (data) {
                  OpenPopup("UserOrderinnergrid", "View ~ Documents", null, "auto", 1000, true, data);
              }
          });
         
    }
    

    
    function Frm_UserOrder_Documents_Window_OnSuccess(data)
    {
        HideLoader();
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.message, "Error");
        }
        else {
           
            $("#UserOrderinnergrid").dxPopup("hide");
            UserOrderDocumentsGrid.SetFocusedRowIndex(-1);
            UserOrderDocumentsGrid.Refresh();
        }
    }

</script>