@using DevExtreme.AspNet.Mvc;
@*@model IEnumerable<dynamic>*@
@model ConnectOneMVC.Areas.Stock.Models.NEVD_UserOrder
@{
    ViewBag.Test = Model.UO_ActionMethod;
    bool IsVisible = (Model != null && Model.UO_ActionMethod == "Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.UO_ActionMethod == "View" || Model.UO_ActionMethod == "Delete") ? true : false;
}
<div id="gudrcvd" class="tab-pane fade in">
    <div class="row">
        <div class="col-lg-12 col-xs-12 table-responsive overflow-scroll scrollbar">
            @Html.Action("UO_GoodsReceivedGridData", "UserOrder", new { ActionMethodName = Model.UO_ActionMethod, UOID = Model.UOID })
        </div>
    </div>
  
    <div class="row btnsDiv formRow">
        @(Html.DevExtreme().Button()
                                                                            .ID("UOBUT_GRNew")
                                                                            .Text("New")
                                                                            //.Icon("fas fa-file btn-icons newfile icon-rgt-space5")
                                                                            .Disabled(IsDisabled)
                                                                            .OnClick(@<text>
                                                                                function () {
                                                                                OnFrm_UORecd_New_Click()
                                                                                }
                                                                            </text>))
        @(Html.DevExtreme().Button()
                                                                          .ID("UOBUT_GREdit")
                                                                          .Text("Edit")
                                                                          //.Icon("fas fa-file btn-icons newfile icon-rgt-space5")
                                                                          .Disabled(IsDisabled)
                                                                          .OnClick(@<text>
                                                                            function () {
                                                                            OnFrm_UORecd_Edit_Click()
                                                                            }
                                                                        </text>))
        @(Html.DevExtreme().Button()
                                                                          .ID("UOBUT_GRDelete")
                                                                          .Text("Delete")
                                                                          //.Icon("fas fa-file btn-icons newfile icon-rgt-space5")
                                                                          .Disabled(IsDisabled)
                                                                          .OnClick(@<text>
                                                                            function () {
                                                                            OnFrm_UORecd_Delete_Click()
                                                                            }
                                                                        </text>))
        @(Html.DevExtreme().Button()
                                                                         .ID("UOBUT_GRView")
                                                                         .Text("View")
                                                                         //.Icon("fas fa-file btn-icons newfile icon-rgt-space5")
                                                                         .Disabled(IsVisible)
                                                                         .OnClick(@<text>
                                                                            function () {
                                                                            OnFrm_UORecd_View_Click()
                                                                            }
                                                                        </text>))
        @(Html.DevExtreme().Button().ID("UOBUT_GRReturn").Text("Return").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_UO_GR_Return_Click() } </text>))
        @(Html.DevExtreme().Button().ID("UOBUT_GRReturned_All").Text("Returned All").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_UO_GR_Returned_All_Click() } </text>))
        @(Html.DevExtreme().Button().ID("UOBUT_GRPrintReceipt").Text("Print Receipt For Selected").Disabled(IsDisabled).OnClick(@<text> function () { OnFrm_UO_GR_PrintReceipt_Click() } </text>))
    </div>
</div><!--[3]-->


<script>


    var Received_Rec_Id;//sr
    var UO_Recd_Id;//id

    function UOReceivedGridFocusedRowChanged(s, e) {

        s.GetRowValues(s.GetFocusedRowIndex(), 'Sr;ID', Recd_GridRowValues);
    }
    function Recd_GridRowValues(values) {

        Received_Rec_Id = values[0];
        UO_Recd_Id = values[1];
    }

    $("#UO_Goods_Received_Grid").keydown(function (evt)
    {
        switch (evt.keyCode) {
            case 45: // insert key
                OnFrm_UORecd_New_Click();
                break;
            case 13: //enter key
                OnFrm_UORecd_Edit_Click();
                break;

        }
        if (evt.ctrlKey && evt.keyCode == 73)//ctrl+i
        {
            OnFrm_UORecd_New_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 69)//ctrl+e
        {
            OnFrm_UORecd_Edit_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_UORecd_View_Click();
        }
    });

    function OnFrm_UORecd_New_Click()    
    {
        debugger
            if ("@IsDisabled" == "true") { return; }
          var menucheck = UO_StatusFlowCheck("ADD-GOODS-RECEIVED");
            if (menucheck[1] == false) {
                DevExpress.ui.dialog.alert(menucheck[0], "Error");
                return;
            }  

        ShowLoader();
          
        OpenPopup("UserOrderinnergrid", "New ~ Goods Received","@Url.Action("Frm_User_Order_Received", "UserOrder", new {@area= "Stock" })?ActionMethod=New", "auto", 1000, false, null);
    }

    function OnFrm_UORecd_Edit_Click()
    {
        debugger
        if ("@IsDisabled" == "true") { return; }
           if (!Received_Rec_Id) {
               DevExpress.ui.dialog.alert("Please Select Row", "Error");
               return;
           }
           var menucheck = UO_StatusFlowCheck("UPDATE-GOODS-RECEIVED");
           if (menucheck[1] == false) {
               DevExpress.ui.dialog.alert(menucheck[0], "Error");
               return;
           }
        var check = UO_Received_datanavigation("Edit");
        if (check[1] == false) {
            DevExpress.ui.dialog.alert(check[0], "Error");
            return;
        }
        ShowLoader();          
        OpenPopup("UserOrderinnergrid", "Edit ~ Goods Received","@Url.Action("Frm_User_Order_Received", "UserOrder", new {@area= "Stock" })?ActionMethod=Edit&SR=" + encodeURIComponent(Received_Rec_Id), "auto", 1000, false, null);
    }

    function OnFrm_UORecd_View_Click()
    {
        if (!Received_Rec_Id) {
            DevExpress.ui.dialog.alert("Please Select Row", "Error");
            return;
        }
        ShowLoader();          
        OpenPopup("UserOrderinnergrid", "View ~ Goods Received","@Url.Action("Frm_User_Order_Received", "UserOrder", new {@area= "Stock" })?ActionMethod=View&SR=" + encodeURIComponent(Received_Rec_Id), "auto", 1000, false, null);
    }
          

    function OnFrm_UORecd_Delete_Click()
    {
        debugger
         if ("@IsDisabled" == "true") {
            return;
        }
        if (Received_Rec_Id == 'undefined' || Received_Rec_Id == undefined || Received_Rec_Id == null || UO_Recd_Id == 'undefined' || UO_Recd_Id == undefined) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }
        var menucheck = UO_StatusFlowCheck("DELETE-GOODS-RECEIVED");
        if (menucheck[1] == false) {
            DevExpress.ui.dialog.alert(menucheck[0], "Error");
            return;
        }
        var check = UO_Received_datanavigation("Delete");
        if (check[1] == false) {
            DevExpress.ui.dialog.alert(check[0], "Error");
            return;
        }
        var Actual_Manpower_Details = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
        Actual_Manpower_Details.done(function (dialogResult) {
            if (dialogResult) {
                $.ajax({
                    type: 'GET',
                    url: "/Stock/UserOrder/Check_Unsaved_Item_Entry_in_Returned_Grid", 
                    data: { RecID: UO_Recd_Id },
                    cache: false,
                    success: function (res) {
                        if (res.result == true)// no added row exists in ret
                        {

                            $.ajax({
                                type: 'GET',
                                url: "/Stock/UserOrder/Check_Unsaved_Item_Entry_in_ReturnedReceived_Grid",
                                data: { UDSid: UO_Recd_Id },
                                cache: false,
                                success: function (res) {
                                    if (res.result == true)// no added row exists in ret
                                    {



                                        $.ajax({
                                            type: 'GET',
                                            url: "/Stock/UserOrder/Frm_GoodsRecd_DetailWin_Delete_Grid_Record",
                                            data: { ActionMethod: "Delete", SrID: Received_Rec_Id, Goods_Rec_Id: UO_Recd_Id },
                                            cache: false,
                                            success: function (data) {
                                                if (data.result == false) {
                                                    DevExpress.ui.dialog.alert(data.message, "Error");
                                                }
                                                else if (data.result == true) {
                                                    DevExpress.ui.dialog.alert("Record Deleted Successfully", "Inform..");

                                                    UO_Goods_Received_Grid.SetFocusedRowIndex(-1);
                                                    UO_Goods_Received_Grid.Refresh();
                                                }
                                            }
                                        });
                                    }
                                    else if (res.result == false) {
                                        DevExpress.ui.dialog.alert(res.message, 'Alert');
                                    }
                                }
                            });
                        }
                        else if (res.result == false) {
                            DevExpress.ui.dialog.alert(res.message, 'Alert');
                        }
                    }
                });

            }
        });
    }
   
    function UO_Received_datanavigation(_actionmethod) {
        debugger
        if (!_actionmethod) { _actionmethod = null; }

        var msg;
        var result;
        $.ajax({
            type: 'GET',
            async: false,
            url: "/Stock/UserOrder/DataNavigationReceived",
            data: {
                ActionMethod: _actionmethod,
                ID: UO_Recd_Id,
            },
            cache: false,
            success: function (data) {
                msg = data.message;
                result = data.result;
            }
        });

        return [msg, result];
    }

    function OnFrm_UO_GR_PrintReceipt_Click() {
        DevExpress.ui.dialog.alert("Coming soon...!", 'Inform!');
    }

    function OnFrm_UO_GR_Returned_All_Click()
    {
        var menucheck = UO_StatusFlowCheck("ADD-GOODS-RETURNED");
        if (menucheck[1] == false) {
            DevExpress.ui.dialog.alert(menucheck[0], "Error");
            return;
        }

        var check = UO_datanavigation();
        if (check[1] == false) {
            DevExpress.ui.dialog.alert(check[0], "Error");
            return;
        }

        ShowLoader();
        OpenPopup("UserOrderinnergrid", "New ~ Goods Returned All","@Url.Action("Frm_User_Order_Returned_All", "UserOrder", new {@area= "Stock" })?ActionMethod=New", "auto", 900, false, null);

    
    }

    function OnFrm_UO_GR_Return_Click() {
        debugger
        if ("@IsDisabled" == "true") { return; }
        if (!Received_Rec_Id) {
            DevExpress.ui.dialog.alert("Please Select Row", "Error");
            return;
        }
        var menucheck = UO_StatusFlowCheck("ADD-GOODS-RETURNED");
        if (menucheck[1] == false) {
            DevExpress.ui.dialog.alert(menucheck[0], "Error");
            return;
        }
        var check = UO_Received_datanavigation();
        if (check[1] == false) {
            DevExpress.ui.dialog.alert(check[0], "Error");
            return;
        }

        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Stock/UserOrder/Frm_User_Order_Returned",
            data: {
                ActionMethod: "New",
                Item_Rec_Id: UO_Recd_Id,
            },
            cache: false,
            success: function (data) {
                OpenPopup("UserOrderinnergrid", "New ~ Items Returned", null, "auto", 900, true, data);
            }
        });

    }
           


  


</script>
