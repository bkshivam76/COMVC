                }
                if (data.result == false) {
                    DevExpress.ui.dialog.alert(data.message, "Error");
                }
            },
            error: function (e) {

            }
        });

    }

    function OnFrm_OT_Approve_Click() {

        UO_selectedrowsarray = Order_Item_Grid.GetSelectedKeysOnPage();
        var UO_arrlen = UO_selectedrowsarray.length;
        if (UO_arrlen == 0) {

            DevExpress.ui.dialog.alert("Please select atleast one Item to Approve ...!", "Error");
            return;
        }
        else {
            $.ajax({
                type: 'POST',
                url: "/Stock/UserOrder/ApproveItems",
                data: {
