        function OrderItemFocusedRowChanged(s,e) {
            s.GetRowValues(s.GetFocusedRowIndex(), 'Sr;ID;Added_By;SubItemID', OnUOitemdetailGridRowValues);
        }
        function OnUOitemdetailGridRowValues(values) {
            UO_Item_Sr = values[0];
            UO_Item_ID = values[1];
            UO_Item_AddedBy = values[2];
            SubitemID = values[3];
        }

    $("#Order_Item_Grid").keydown(function (evt) {
        switch (evt.keyCode) {
            case 45: // insert key
                OnFrm_OT_Order_Item_New_Click();
                break;
            case 13: //enter key
                OnFrm_OT_Order_Item_Edit_Click();
                break;

        }
        if (evt.ctrlKey && evt.keyCode == 73)//ctrl+i
        {
            OnFrm_OT_Order_Item_New_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 69)//ctrl+e
        {
            OnFrm_OT_Order_Item_Edit_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_OT_Order_Item_View_Click();
        }
    });

    function OnFrm_OT_Order_Item_New_Click()
    {
        if ("@IsDisabled" == "true") { return; }

        if ("@Model.UO_ActionMethod" == "Edit") {
            var menucheck = UO_StatusFlowCheck("ADD-ITEMS");
            if (menucheck[1] == false) {
                DevExpress.ui.dialog.alert(menucheck[0], "Error");
                return;
            }
        }

        var ReqStoreDept = $("#UORequest_Store_Id").dxDropDownBox('instance').option('value');
        if (ReqStoreDept == null) { DevExpress.ui.dialog.alert("Please Select Requestee Store First!!", "Error"); return; }

            ShowLoader();

        OpenPopup("UserOrderinnergrid", "New ~ Item Detail","@Url.Action("Frm_User_Order_Item", "UserOrder", new {@area= "Stock" })?ActionMethod=New", "auto", 1000, false, null);



    }

    function OnFrm_OT_Order_Item_Edit_Click() {
        var flag = 1;
        if ("@IsDisabled" == "true") { return; }
        if (UO_Item_Sr == null || UO_Item_Sr == undefined || UO_Item_Sr == "undefined") {
            DevExpress.ui.dialog.alert("Please Select Row", "Error");
            return;
        }

        var menucheck = UO_StatusFlowCheck("UPDATE-ITEMS");
        if (menucheck[1] == false) {
            DevExpress.ui.dialog.alert(menucheck[0], "Error");
            return;
        }
        if ("@Model.UO_ActionMethod" == "Edit") {
            if ("@Model.is_Store_Keeper" == "True" || "@Model.is_Store_KeeperIncharge" == "True") {

                if ("@Model.is_Requestor" == "False" && "@Model.is_RequestorIncharge" == "False") {

                    if ("@Model.UO_openuserID" != UO_Item_AddedBy) {

                        DevExpress.ui.dialog.alert("You are allowed to edit item posted by you", "Error");
                        flag = 0;
                        return;
                    }
                    else {
                        flag = 1;
                    }
                }
            }
        }

        if (flag == 1) {

            var ReqStoreDept = $("#UORequest_Store_Id").dxDropDownBox('instance').option('value');
            if (ReqStoreDept == null) { DevExpress.ui.dialog.alert("Please Select Requestee Store First!!", "Error"); return; }

                        ShowLoader();

            OpenPopup("UserOrderinnergrid", "Edit ~ Item Detail", "@Url.Action("Frm_User_Order_Item", "UserOrder", new {@area= "Stock" })?ActionMethod=Edit&SR=" + encodeURIComponent(UO_Item_Sr), "auto", 1000, false, null);

        }



    }


    function OnFrm_OT_Order_Item_Delete_Click() {
        if ("@IsDisabled" == "true") {
            return;
        }
        if (UO_Item_Sr == 'undefined' || UO_Item_Sr == undefined || UO_Item_Sr == null || UO_Item_ID == 'undefined' || UO_Item_ID == undefined) {
            DevExpress.ui.dialog.alert('Please Select one row', 'Alert ');
            return;
        }


        var menucheck = UO_StatusFlowCheck("DELETE-ITEMS");
        if (menucheck[1] == false) {
            DevExpress.ui.dialog.alert(menucheck[0], "Error");
            return;
        }

        if ("@Model.UO_openuserID" == UO_Item_AddedBy)
        {
            var Actual_Manpower_Details = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
            Actual_Manpower_Details.done(function (dialogResult) {

                if (dialogResult) {
                 $.ajax({
                        type: 'GET',
                        url: "/Stock/UserOrder/Check_Unsaved_Item_Entry_in_Delivery_Grid_Item_Grid", //mantis bug #929
                        data: { ID_Item: UO_Item_ID },
                        cache: false,
                        success: function (res) {
                            if (res.result == true)// no added row exists in delivery
                            {


                    $.ajax({
                        type: 'GET',
                        url: "/Stock/UserOrder/Frm_Item_DetailWin_Delete_Grid_Record",
                        data: { ActionMethod: "Delete", SrID: UO_Item_Sr, Item_Rec_Id: UO_Item_ID },
                        cache: false,

                        success: function (data) {
                            if (data.result == false) {
                                DevExpress.ui.dialog.alert(data.message, "Error");
                            }
                            else if (data.result == true) {
                                DevExpress.ui.dialog.alert("Record Deleted Successfully", "Inform..");
                                Order_Item_Grid.SetFocusedRowIndex(-1);
                                Order_Item_Grid.Refresh();
                            }
                        }

                    });
    }
     else if (res.result == false) {
                                DevExpress.ui.dialog.alert(res.message, 'Alert');
    }
    }
    });

                }
            });
        }
        else {
            DevExpress.ui.dialog.alert("You are allowed to delete item posted by you", "Error");
            return;
        }
    }
    function OnFrm_OT_Order_Item_View_Click() {
        if (UO_Item_Sr == null || UO_Item_Sr == undefined || UO_Item_Sr == "undefined") {
            DevExpress.ui.dialog.alert("Please Select Row", "Error");
            return;
        }
        ShowLoader();
         OpenPopup("UserOrderinnergrid", "View ~ Item Detail","@Url.Action("Frm_User_Order_Item", "UserOrder", new {@area= "Stock" })?ActionMethod=View&SR=" + encodeURIComponent(UO_Item_Sr), "auto", 1000, false, null);

        }


    function OnFrm_OT_Check_Availability_Click() {
        debugger
        if (UO_Item_Sr == null || UO_Item_Sr == undefined || UO_Item_Sr == "undefined") {
            DevExpress.ui.dialog.alert("Please Select Row", "Error");
            return;
        }
       
            var _ReqStoreDept = $("#UORequest_Store_Id").dxDropDownBox('instance').option('value');
        if (_ReqStoreDept != null) {
          ReqStoreDepartment = _ReqStoreDept[0];
        }
        if (SubitemID == null || SubitemID == 0) {
            DevExpress.ui.dialog.alert("Selected row not have item ID", "Error");
            return;
        }
        
        ShowLoader();
        $.ajax({
            type: 'GET',
            url: "/Stock/UserOrder/Frm_User_Order_Check_Availability",
            data: {
                ItemID: SubitemID,
                Requestee_Store_ID: ReqStoreDepartment,
                Screenname: "UO"

            },
            cache: false,
            success: function (data) {
                OpenPopup("Check_Avl_Popup", "Search ~ Stock Availability", null, "auto", 1150, true, data);
            }
        });
        Order_Item_Grid.SetFocusedRowIndex(-1);
        Order_Item_Grid.Refresh();
    }



    function OnFrm_OT_Deliver_All_Click() {

        var menucheck = UO_StatusFlowCheck("ADD-GOODS-DELIVERY");
        if (menucheck[1] == false) {
            DevExpress.ui.dialog.alert(menucheck[0], "Error");
            return;
        }

        var check = UO_datanavigation();
        if (check[1] == false) {
            DevExpress.ui.dialog.alert(check[0], "Error");
            return;
        }

           ShowLoader();

        OpenPopup("UserOrderinnergrid", "New ~ Goods Delivered All","@Url.Action("Frm_User_Order_Delivery_All", "UserOrder", new {@area= "Stock" })?ActionMethod=New", "auto", 900, false, null);



    }

    function OnFrm_OT_Deliver_Click() {
        UO_selectedrowsarray = Order_Item_Grid.GetSelectedKeysOnPage();
        var UO_arrlen = UO_selectedrowsarray.length;
        if (UO_arrlen == 0) {

            DevExpress.ui.dialog.alert("Please select atleast one Item to Deliver...!", "Error");
            return;
        }
        var menucheck = UO_StatusFlowCheck("ADD-GOODS-DELIVERY");
        if (menucheck[1] == false) {
            DevExpress.ui.dialog.alert(menucheck[0], "Error");
            return;
        }
        var check = UO_datanavigation();
        if (check[1] == false) {
            DevExpress.ui.dialog.alert(check[0], "Error");
            return;
        }
        if (UO_arrlen == 1) {
            $.ajax({
                type: 'POST',
                url: "/Stock/UserOrder/Delivery_grid_oldest_item",
                data: {
                    UO_ItemID: UO_selectedrowsarray
                },
                success: function (data) {
                    if (data.result == false) {
                        DevExpress.ui.dialog.alert(data.message, "Error");
                    }
                    if (data.result == true) {
                        //DevExpress.ui.dialog.alert(data.message, "Inform");


                        ShowLoader();
                        $.ajax({
                            type: 'GET',
                            url: "/Stock/UserOrder/Frm_User_Order_Delivery",
                            data: {
                                ActionMethod: "New",
                                Item_Rec_Id: data.selID,
                            },
                            cache: false,
                            success: function (data) {
                                OpenPopup("UserOrderinnergrid", "New ~ Goods Delivered", null, "auto", 1000, true, data);

                            }
                        });


                    }

                }

            });
        }
        if (UO_arrlen > 1) {
            ShowLoader();
            OpenPopup("UserOrderinnergrid", "New ~ Items Delivered All", "@Url.Action("Frm_User_Order_Delivery_All", "UserOrder", new {@area= "Stock" })?ActionMethod=New&UO_ItemID=" + encodeURIComponent(UO_selectedrowsarray), "auto", 900, false, null);

        }
    }








    function OnFrm_OT_Create_RR_Click() {
        
        var uoitemid = null;
        UO_selectedrowsarray = Order_Item_Grid.GetSelectedKeysOnPage();
      
        UO_Selected = UO_selectedrowsarray;
        var UO_arrlen = UO_selectedrowsarray.length;
        if (UO_arrlen == 0) {

            DevExpress.ui.dialog.alert("Please select atleast one Item to Create RR ...!", "Error");
            return;
        }

        if ("@Model.Uo_Status" != "Approved") 
        {
            DevExpress.ui.dialog.alert("New RR can be created only against “Approved” Status UO", "Error");
            return;
        }
      
        var UOID = "@Model.UOID";

        $.ajax({
            type: 'POST',
            url: "/Stock/UserOrder/Check_Approved_Item_Status",
            data: {
                UOID: UOID,
                UO_ItemID: UO_selectedrowsarray,
            },
            success: function (res) {
           
                if (res.result == false) {
                    DevExpress.ui.dialog.alert(res.message, "Error");
                    return;
                }
                else {

        $.ajax({
            type: 'POST',
            url: "/Stock/UserOrder/Findsubitemidforitem",
            data: {
                UO_ItemID: UO_selectedrowsarray,

            },
            success: function (res) {
                if (res.result == false) {
                    DevExpress.ui.dialog.alert(res.message, "Error");
                    return;
                }
                else {

                    uoitemid = res.data;
                    itemrecid = res.itemid;
                    $.ajax({
                        type: 'GET',
                        url: "/Stock/RequestRegister/Frm_NEVD_Requisition",
                        data:
                        {
                            ActionMethod: "New",
                            ID: 0,
                            PostSuccessFunction: "Frm_UO_RR_OnSuccess_Itemgrid",
                            PopupName: "UserOrderinnergrid",
                            UO_SubItem_ID: uoitemid,
                            UO_ItemRecID: itemrecid,
                            UO_ID: UOID,
                        },
                        cache: false,
                        success: function (data) {
                            OpenPopup("UserOrderinnergrid", "New ~ Create RR", null, "auto", 900, true, data);
                        }
                    });

                    Order_Item_Grid.SetFocusedRowIndex(-1);
                    Order_Item_Grid.Refresh();
                }
            }
        });
                }
            }
        });
    }
        
    function Frm_UO_RR_OnSuccess_Itemgrid(data) {

        HideLoader();
        if (data.result == false) {
            DevExpress.ui.dialog.alert(data.Message, "Error");
            HideLoader();
        }
        else {
            dontaskpopupcloseconfirmation = true;
            $("#UserOrderinnergrid").dxPopup("hide");
            DevExpress.ui.dialog.alert(data.Message, "Inform");
            Order_Item_Grid.SetFocusedRowIndex(-1);
            Order_Item_Grid.Refresh();
            if (typeof RequestRegisterListGrid !== 'undefined') {
                RequestRegisterListGrid.SetFocusedRowIndex(-1);
                RequestRegisterListGrid.Refresh();

            }
            HideLoader();

        }
    }
    function OnFrm_OT_Merge_Sel_RR_Click() {
