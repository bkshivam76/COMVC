<script>

    var UO_Item_Sr;
    var UO_Item_ID;
    var UO_Item_AddedBy;
    var Approved_Qty;
    var UOID = "@Model.UOID";
    var UO_Selected;
    var Requestee_Store_Id;
    var SubitemID;
    var UO_SubItem_ID;
    var ReqStoreDepartment;
   // Request_Store_Id = "@Model.UORequest_Store_Id";

    @*$(document).ready(function () {

        if ("@Model.is_Requestor" == "True") {



            $('#OT_Requested_Qty').dxNumberBox("instance").option("readOnly", false);
            $('#OT_Item_ID').dxDropDownBox("instance").option("readOnly", false);
            $('#OT_Req_Deliver_Date').dxDateBox("instance").option("readOnly", false);
            $('#OT_Delivery_Allowed').dxRadioGroup("instance").option("readOnly", false);
            //$('#OT_Approved_Qty').dxNumberBox("instance").option("readOnly", true);
