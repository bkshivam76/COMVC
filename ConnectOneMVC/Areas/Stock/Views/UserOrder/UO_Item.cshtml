    function OnFrm_OT_Received_Click() {
        UO_selectedrowsarray = Order_Item_Grid.GetSelectedKeysOnPage();
        var UO_arrlen = UO_selectedrowsarray.length;
        if (UO_arrlen == 0) {

            DevExpress.ui.dialog.alert("Please select atleast one Item to Receive ...!", "Error");
            return;
        }
        var menucheck = UO_StatusFlowCheck("ADD-GOODS-RECEIVED");
        if (menucheck[1] == false) {
            DevExpress.ui.dialog.alert(menucheck[0], "Error");
            return;
        }

        var check = UO_datanavigation();
        if (check[1] == false) {
            DevExpress.ui.dialog.alert(check[0], "Error");
            return;
        }
        if (UO_arrlen == 1) {
            $.ajax({
                type: 'POST',
                url: "/Stock/UserOrder/Received_grid_oldest_delivery",
                data: {
                    UO_ItemID: UO_selectedrowsarray,
                },
                success: function (data) {
                    if (data.result == false) {
                        DevExpress.ui.dialog.alert(data.message, "Error");
                    }
                    if (data.result == true)
                    {
                        //DevExpress.ui.dialog.alert(data.message, "Inform");


                        ShowLoader();
                        $.ajax({
                            type: 'GET',
                            url: "/Stock/UserOrder/Frm_User_Order_Received",
                            data: {
                                ActionMethod: "New",
                                Item_Rec_Id: data.selID,

                            },
                            cache: false,
                            success: function (data)
                            {
                                OpenPopup("UserOrderinnergrid", "New ~ Goods Received", null, "auto", 1000, true, data);
                            }
                        });


                    }

                }

            });
        }
        if (UO_arrlen > 1) {

            ShowLoader();
            OpenPopup("UserOrderinnergrid", "New ~ Items Received All", "@Url.Action("Frm_User_Order_Received_All", "UserOrder", new {@area= "Stock" })?ActionMethod=New&UO_ItemID=" + encodeURIComponent(UO_selectedrowsarray), "auto", 900, false, null);


        }

    }

