        }

        $.ajax({
            type: 'POST',
            url: "/Stock/UserOrder/CheckForsameRRIDS",
            data: {
                UO_ItemID: UO_selectedrowsarray,

            },
            success: function (res) {
                if (res.result == false) {
                    DevExpress.ui.dialog.alert(res.message, "Error");
                    return;
                }
                else {


        ShowLoader();
        OpenPopup("UserOrderinnergrid", "New ~ Map Screen","@Url.Action("UO_MapExistingRR", "UserOrder", new { @area = "Stock" })?UO_Items_ID=" + UO_Selected + "&UO_ID=" + UOID, "auto", 900, false, null);

                 Order_Item_Grid.SetFocusedRowIndex(-1);
                   Order_Item_Grid.Refresh();
                }
            }
        });

    }


    function OnFrm_OT_Unmap_Sel_RR_Click() {
        UO_selectedrowsarray = Order_Item_Grid.GetSelectedKeysOnPage();
        var UO_arrlen = UO_selectedrowsarray.length;
        if (UO_arrlen == 0) {

            DevExpress.ui.dialog.alert("Please select atleast one Item to Un Map ...!", "Error");
            return;
        }
          var menucheck = UO_StatusFlowCheck("MAP-UNMAP");
        if (menucheck[1] == false) {
            DevExpress.ui.dialog.alert(menucheck[0], "Error");
            return;
        }
        var check = UO_datanavigation("UnmapUO");
        if (check[1] == false) {
            DevExpress.ui.dialog.alert(check[0], "Error");
            return;
        }

        $.ajax({
            type: "POST",
            async: false,
            url: "/Stock/UserOrder/UnmapUORRItemGrid",
            data: {
                UO_ID: UOID,
                UO_Item_ID: UO_selectedrowsarray,
            },
            success: function (data) {
                if (data.result == true) {
                    DevExpress.ui.dialog.alert(data.message, "Success");
                    Order_Item_Grid.SetFocusedRowIndex(-1);
                    Order_Item_Grid.Refresh();


                }
                else {
                    DevExpress.ui.dialog.alert(data.message, "Error");
                }
            }
        });
        }

    function OnFrm_OT_Approve_All_Click() {
        $.ajax({
            type: 'GET',
            url: "/Stock/UserOrder/ApproveAllItems",
            data: {

            },
            cache: false,
            success: function (data) {
                if (data.result == true) {
                    DevExpress.ui.dialog.alert("All Items are Successfully Approved", 'Inform');
                    Order_Item_Grid.SetFocusedRowIndex(-1);
