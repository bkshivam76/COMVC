    //        DevExpress.ui.dialog.alert("Schedule Date updated in selected Items", 'Success..');
    //        $("#Dynamic_Content_popup").dxPopup("hide");
    //        Order_Item_Grid.SetFocusedRowIndex(-1);
    //        Order_Item_Grid.Refresh();
    //    }
    //}
   
</script>

