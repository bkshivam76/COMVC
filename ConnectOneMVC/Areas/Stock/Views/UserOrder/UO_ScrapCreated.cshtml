@using DevExtreme.AspNet.Mvc;
@model ConnectOneMVC.Areas.Stock.Models.NEVD_UserOrder
@{
    ViewBag.Test = Model.UO_ActionMethod;
    bool IsVisible = (Model != null && Model.UO_ActionMethod == "Delete") ? true : false;
    bool IsDisabled = Model != null && (Model.UO_ActionMethod == "View" || Model.UO_ActionMethod == "Delete") ? true : false;
}

<div id="scrap" class="tab-pane fade in ">
    <div class="row">
        <div class="col-lg-12 col-xs-12 table-responsive overflow-scroll scrollbar">
            @Html.Action("UO_ScrapCreatedGridData", "UserOrder", new { ActionMethodName = Model.UO_ActionMethod, UOID = Model.UOID })
        </div>
    </div>
    <div class="row btnsDiv formRow">
                        @(Html.DevExtreme().Button()
                                                    .ID("BUT_UOScrapNew")
                                                    .Text("New")
                                                    //.Icon("fas fa-file btn-icons newfile icon-rgt-space5")
                                                    .Disabled(IsDisabled)
                                                    .OnClick(@<text>
                                                    function () {
                                                    OnFrm_UOScrap_New_Click()
                                                    }
                                                </text>))
                        @(Html.DevExtreme().Button()
                                                  .ID("BUT_UOScrapEdit")
                                                  .Text("Edit")
                                                  //.Icon("fas fa-file btn-icons newfile icon-rgt-space5")
                                                  .Disabled(IsDisabled)
                                                  .OnClick(@<text>
                                                    function () {
                                                    OnFrm_UOScrap_Edit_Click()
                                                    }
                                                </text>))
                        @(Html.DevExtreme().Button()
                                                  .ID("BUT_UOScrapDelete")
                                                  .Text("Delete")
                                                  //.Icon("fas fa-file btn-icons newfile icon-rgt-space5")
                                                  .Disabled(IsDisabled)
                                                  .OnClick(@<text>
                                                    function () {
                                                    OnFrm_UOScrap_Delete_Click()
                                                    }
                                                </text>))
                        @(Html.DevExtreme().Button()
                                                 .ID("BUT_UOScrapView")
                                                 .Text("View")
                                                 //.Icon("fas fa-file btn-icons newfile icon-rgt-space5")
                                                 .Disabled(IsVisible)
                                                 .OnClick(@<text>
                                                    function () {
                                                    OnFrm_UOScrap_View_Click()
                                                    }
                                                </text>))
    </div>
</div><!--[3]-->

<script>
    var Scrap_Sr;
    var Scrap_RecId;

    function OnUOScrapCreatedGridFocusedRowChanged(s,e)
    {
        s.GetRowValues(s.GetFocusedRowIndex(), 'Sr;ID', OnScrapGridRowValues);
    }
   

    function OnScrapGridRowValues(values)
    {
        Scrap_Sr = values[0];
        Scrap_RecId = values[1];
    }

    $("#UOScrapCreated_Window_Grid").keydown(function (evt) {
        switch (evt.keyCode) {
            case 45: // insert key
                OnFrm_UOScrap_New_Click();
                break;
            case 13: //enter key
                OnFrm_UOScrap_Edit_Click();
                break;

        }
        if (evt.ctrlKey && evt.keyCode == 73)//ctrl+i
        {
            OnFrm_UOScrap_New_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 69)//ctrl+e
        {
            OnFrm_UOScrap_Edit_Click();
        }
        if (evt.ctrlKey && evt.keyCode == 86)//ctrl+v
        {
            OnFrm_UOScrap_View_Click();
        }
    }); 
    function OnFrm_UOScrap_New_Click()    
        {
            if ("@IsDisabled" == "true") { return; }
        var menucheck = UO_StatusFlowCheck("POST SCRAP CREATED");
            if (menucheck[1] == false) {
                DevExpress.ui.dialog.alert(menucheck[0], "Error");
                return;
            }
            ShowLoader();  
        OpenPopup("UserOrderinnergrid", "New ~ Scrap Created", "@Url.Action("Frm_User_Order_Scrap", "UserOrder", new {@area= "Stock" })?ActionMethod=New", "auto", 1000, false, null);
        }
  
    function OnFrm_UOScrap_Edit_Click()
    {
        if ("@IsDisabled" == "true") { return; }
        if (!Scrap_Sr) {
            DevExpress.ui.dialog.alert("Please Select Row", "Error");
            return;
        }

            ShowLoader();

                OpenPopup("UserOrderinnergrid", "Edit ~ Scrap Created","@Url.Action("Frm_User_Order_Scrap", "UserOrder", new {@area= "Stock" })?ActionMethod=Edit&SR=" + encodeURIComponent(Scrap_Sr), "auto", 1000, false, null);
    }

    function OnFrm_UOScrap_View_Click()
    {
        if (!Scrap_Sr) {
            DevExpress.ui.dialog.alert("Please Select Row", "Error");
            return;
        }

                ShowLoader();
        
                OpenPopup("UserOrderinnergrid", "View ~ Scrap Created","@Url.Action("Frm_User_Order_Scrap", "UserOrder", new {@area= "Stock" })?ActionMethod=View&SR=" + encodeURIComponent(Scrap_Sr), "auto", 1000, false, null);
    }
          

    function OnFrm_UOScrap_Delete_Click()
    {debugger
         if ("@IsDisabled" == "true") {
            return;
        }
        
        if (!Scrap_Sr) {
            DevExpress.ui.dialog.alert("Please Select Row", "Error");
            return;
        }
        var Actual_Manpower_Details = DevExpress.ui.dialog.confirm("Sure you want to Delete this Entry...?", "Confirm changes");
        Actual_Manpower_Details.done(function (dialogResult) {

            if (dialogResult) {
                $.ajax({
                    type: 'GET',
                    url: "/Stock/UserOrder/Frm_Scrap_Window_Delete_Grid_Record",
                    data: { ActionMethod: "Delete", SrID: Scrap_Sr, Scrap_ID: Scrap_RecId },
                    cache: false,
                    success: function (data) {
                        if (data.result == false) {
                            DevExpress.ui.dialog.alert(data.message, "Error");
                        }
                        else if (data.result == true) {
                            DevExpress.ui.dialog.alert("Record Deleted Successfully", "Inform..");
                            UOScrapCreated_Window_Grid.SetFocusedRowIndex(-1);
                            UOScrapCreated_Window_Grid.Refresh();
                           
                        }
                    }
                });
            }
        });
    }


</script>