@{
    var Doc_Status = ViewBag.Doc_Status;
    var Doc_Checking_Status = ViewBag.Doc_Checking_Status;
    var ItemName = ViewBag.ItemName;
    var ATTACH_FILE_NAME = ViewBag.ATTACH_FILE_NAME;
    var Rejection_Reason = ViewBag.Rejection_Reason;

    if (Doc_Status == "YES")
    {
        if (Doc_Checking_Status == "PENDING")
        {
            Html.DevExpress().Image(ImageSettings =>
            {
                ImageSettings.Properties.EmptyImage.IconID = IconID.ContentCheckboxSvg16x16;
                ImageSettings.Properties.EmptyImage.ToolTip = ATTACH_FILE_NAME;
            }).Render();
        }
        if (Doc_Checking_Status == "REJECTED")
        {
            Html.DevExpress().Image(ImageSettings =>
            {
                ImageSettings.Properties.EmptyImage.SpriteProperties.CssClass = "imagesprite rejected_attachment";
                ImageSettings.Properties.EmptyImage.ToolTip = "This Document has been rejected by Madhuban. Reason :" + Rejection_Reason;
            }).Render();
        }
        if (Doc_Checking_Status == "ACCEPTED")
        {
            Html.DevExpress().Image(ImageSettings =>
            {
                ImageSettings.Properties.EmptyImage.SpriteProperties.CssClass = "imagesprite document_accepted";
                ImageSettings.Properties.EmptyImage.ToolTip = "This Document has been Accepted by Madhuban";
            }).Render();
        }
    }
    else if (Doc_Status == "NO")
    {
        Html.DevExpress().Image(ImageSettings =>
        {
            ImageSettings.Properties.EmptyImage.IconID = IconID.CommentsDeletecommentSvg16x16;
        }).Render();
    }
    else
    {
        if (ItemName != "OTHERS")
        {
            Html.DevExpress().Image(ImageSettings =>
            {
                ImageSettings.Properties.EmptyImage.SpriteProperties.CssClass = "imagesprite attach_red_2";
                ImageSettings.Properties.EmptyImage.ToolTip = "Attachment Status : Pending";
            }).Render();
        }
    }

}