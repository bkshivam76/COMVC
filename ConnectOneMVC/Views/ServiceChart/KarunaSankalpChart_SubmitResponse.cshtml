        }

        @@media (max-width: 620px) {
            body {
                width: 100%;
                display: table-row-group;
            }

            table {
                font-size: 35px;
                line-height: 50px;
                padding: 20px;
                display: block;
                text-align: center
            }

            .pld-head h2, .pld-head h3 {
