            }

            .pld-img {
                width: 50%;
                display: inline-block;
                padding: 20px
            }

            .pld-head {
                margin-top: 50px;
                display: block;
                width: 166%;
            }

            .stackhead td:empty {
                display: none
            }

            .pld-icn img {
                width: 300px
            }
        }
    </style>
</head>
