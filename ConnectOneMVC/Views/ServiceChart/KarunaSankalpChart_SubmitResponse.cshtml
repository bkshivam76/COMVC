    <title>Spiritual Empowerment for Kindness and Compassion</title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;700&amp;display=swap" rel="stylesheet">
    <!-- CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/Content/css/pledge.css" rel="stylesheet">
    <script src="~/Scripts/jquery-3.6.0.js"></script>
    <style>
        .ck-button {
            margin-top:10px;
            background-color:#EFEFEF;
            border-radius:4px;
            border:1px solid #D0D0D0;
            overflow:auto;
            width: max-content;
        }

        .ck-button:hover {
            background:#ddd;
        }
        .pld-grid {font-size: 14px}
        .pld-grid label{margin: 0 15px 5px 0}

        .pld-grid .ck-button label {
            float:left;
            width:4.0em;
            margin: 0;
            cursor: pointer;
            position: relative;
            transition: .4s all
        }

        .ck-button label b {
            text-align:center;
            padding:6px 0px 3px;
            display:block;
        }

        .ck-button label input {
            position:absolute;
            top:-20px;
        }

        .ck-button input:checked + b {
            color:#fff;
            padding: 6px 3px 3px 20px;
            transition: .3s all
        }
        .ck-button input[value="yes"]:checked + b{background-color:#0a7a4c;}
        .ck-button input[value="no"]:checked + b{background-color:#cb3204;}
        .ck-button input[value="yes"]:checked + b:before{
            content: "✓";
            position:absolute;
            left: 10px;
        }
        .ck-button input[value="no"]:checked + b:before{
            content: "✗";
            position:absolute;
            left: 10px;
        }
        .btn-submit{min-width: 300px; margin: 0 auto 30px; font-size: 20px; font-weight: bold; float: none; display: inherit; padding: 12px;}
        footer { padding: 12px 10px 5px; line-height: 23px; font-size: 13px; }

        @*@media (max-width: 768px){
            .pld-grid img {margin: -10px 0 10px; width: 100px; height: 100px}
            .ck-button{margin: 5px auto 0}
            .btn-submit{margin: 10px auto 10px;}*@
        }
    </style>
    <style>
        .pld-head h2, .pld-head h3 {
            font-size: 22px
        }

        .pld-img {
            padding: 10px
        }

        .pld-head {
            display: block;
            margin-top: -100px;
        }

        .pld-icn img {
