@{
    string[] ModelParts = Model.Split(',');
    var FabName = ModelParts[0];
    var FabContainerElement = ModelParts[1];
    var ScreenType = ModelParts[2];
    var ActionItem = ModelParts[3];
    var UserType = ModelParts.Count() == 5 ? ModelParts[4] : "CLIENTROLE";
}

@Html.DevExpress().FloatingActionButton(
settings =>
{
    settings.Name = FabName;
    settings.ControlStyle.CssClass = "DevexpressComponents";
    settings.ContainerElementID = FabContainerElement;
    if (ScreenType == "Type3")
    {
        settings.InitialActionContext = "ViewAttachmentContext";
    }

    settings.HorizontalPosition = FloatingActionButtonHorizontalPosition.Right;
    settings.VerticalPosition = FloatingActionButtonVerticalPosition.Bottom;

    if (ScreenType == "Type3")
    {
        FABAction view = new FABAction();
        view.ContextName = "ViewAttachmentContext";
        view.ActionName = "InitialViewDocumentClick";
        view.Text = "View Document";
        view.Image.SpriteProperties.CssClass = "imagesprite eye";
        settings.Items.Add(view);
    }
    else
    {
        settings.Items.Add(new FABAction("AddAttachmentContext", "InitialAddDocumentClick", "Attach Document?"));
    }

    if (ScreenType == "Type1"|| ScreenType == "Type4")
    {
        FABActionGroup AutoItemGroup = new FABActionGroup() { ContextName = "AutoItemContext", Text = "Attach Document?" };
        AutoItemGroup.ExpandImage.SpriteProperties.CssClass = "imagesprite pin";
        AutoItemGroup.CollapseImage.SpriteProperties.CssClass = "imagesprite collapse_image_2";
        AutoItemGroup.CollapseImage.AlternateText = "Do You Have This Document?";

        FABActionItem add_attach = new FABActionItem();
        add_attach.ActionName = "add_attach";
        add_attach.Image.SpriteProperties.CssClass = "imagesprite tick";
        add_attach.Text = "Yes";
        AutoItemGroup.Items.Add(add_attach);

        FABActionItem Link_Attach = new FABActionItem();
        Link_Attach.ActionName = "Link_Attach";
        Link_Attach.Image.SpriteProperties.CssClass = "imagesprite linkattachment";
        Link_Attach.Text = "Link";
        AutoItemGroup.Items.Add(Link_Attach);

        FABActionItem Add_Reason = new FABActionItem();
        Add_Reason.ActionName = "Add_Reason";
        Add_Reason.Image.SpriteProperties.CssClass = "imagesprite cross";
        Add_Reason.Text = "No";
        AutoItemGroup.Items.Add(Add_Reason);

        if (UserType.ToUpper() == "AUDITOR" || UserType.ToUpper() == "SUPERUSER")
        {
            FABActionItem AuditAction = new FABActionItem();
            AuditAction.ActionName = "AuditAction";
            AuditAction.Image.SpriteProperties.CssClass = "imagesprite auditaction32";
            AuditAction.Text = "Audit Buttons";
            AutoItemGroup.Items.Add(AuditAction);
        }
        settings.Items.Add(AutoItemGroup);

        FABActionGroup editItemGroup = new FABActionGroup() { ContextName = "EditItemContext" };

        FABActionItem add_attach_edit = new FABActionItem();
        add_attach_edit.ActionName = "add_attach";
        add_attach_edit.Image.SpriteProperties.CssClass = "imagesprite pin";
        add_attach_edit.Text = "Add Attachment";
        editItemGroup.Items.Add(add_attach_edit);

        FABActionItem Link_Attach_edit = new FABActionItem();
        Link_Attach_edit.ActionName = "Link_Attach";
        Link_Attach_edit.Image.SpriteProperties.CssClass = "imagesprite linkattachment";
        Link_Attach_edit.Text = "Link Attachment";
        editItemGroup.Items.Add(Link_Attach_edit);

        FABActionItem Delete_Reason = new FABActionItem();
        Delete_Reason.ActionName = "Delete_Reason";
        Delete_Reason.Image.SpriteProperties.CssClass = "imagesprite cross";
        Delete_Reason.Text = "Delete Reason";
        editItemGroup.Items.Add(Delete_Reason);

        FABActionItem Edit_Reason = new FABActionItem();
        Edit_Reason.ActionName = "Edit_Reason";
        Edit_Reason.Image.SpriteProperties.CssClass = "imagesprite edit";
        Edit_Reason.Text = "Edit Reason";
        editItemGroup.Items.Add(Edit_Reason);

        if (UserType.ToUpper() == "AUDITOR" || UserType.ToUpper() == "SUPERUSER")
        {
            FABActionItem AuditAction = new FABActionItem();
            AuditAction.ActionName = "AuditAction";
            AuditAction.Image.SpriteProperties.CssClass = "imagesprite auditaction32";
            AuditAction.Text = "Audit Buttons";
            editItemGroup.Items.Add(AuditAction);
        }
        settings.Items.Add(editItemGroup);
    }
    if (ScreenType != "Type3")
    {
        FABActionGroup actionItemGroup = new FABActionGroup() { ContextName = "actionItemContext" };
        actionItemGroup.ExpandImage.SpriteProperties.CssClass = "imagesprite commentitemcontext";

        FABActionItem add_attach_edit = new FABActionItem();
        add_attach_edit.ActionName = "add_attach";
        add_attach_edit.Image.SpriteProperties.CssClass = "imagesprite pin";
        add_attach_edit.Text = "Add More";
        actionItemGroup.Items.Add(add_attach_edit);

        FABActionItem Link_Attach_edit = new FABActionItem();
        Link_Attach_edit.ActionName = "Link_Attach";
        Link_Attach_edit.Image.SpriteProperties.CssClass = "imagesprite linkattachment";
        Link_Attach_edit.Text = "Link Attachment";
        actionItemGroup.Items.Add(Link_Attach_edit);

        FABActionItem edit_attach = new FABActionItem();
        edit_attach.ActionName = "edit_attach";
        edit_attach.Image.SpriteProperties.CssClass = "imagesprite edit";
        edit_attach.Text = "Edit Attachment";
        actionItemGroup.Items.Add(edit_attach);

        FABActionItem delete_attach = new FABActionItem();
        delete_attach.ActionName = "delete_attach";
        delete_attach.Image.SpriteProperties.CssClass = "imagesprite cross";
        delete_attach.Text = "Delete Attachment";
        actionItemGroup.Items.Add(delete_attach);

        FABActionItem view_attach = new FABActionItem();
        view_attach.ActionName = "view_attach";
        view_attach.Image.SpriteProperties.CssClass = "imagesprite view";
        view_attach.Text = "View Attachment";
        actionItemGroup.Items.Add(view_attach);

        if (UserType.ToUpper() == "AUDITOR" || UserType.ToUpper() == "SUPERUSER")
        {
            FABActionItem AuditAction = new FABActionItem();
            AuditAction.ActionName = "AuditAction";
            AuditAction.Image.SpriteProperties.CssClass = "imagesprite auditaction32";
            AuditAction.Text = "Audit Buttons";
            actionItemGroup.Items.Add(AuditAction);
        }
        settings.Items.Add(actionItemGroup);
    }
    FABActionGroup ShivbabaItemGroup = new FABActionGroup() { ContextName = "ShivbabaItemContext" };
    FABActionItem Shivbaba = new FABActionItem();
    Shivbaba.ActionName = "Shivbaba";
    Shivbaba.Image.SpriteProperties.CssClass = "imagesprite bk_icon";
    Shivbaba.Text = "Shivbaba Yaad Hai!!";
    ShivbabaItemGroup.Items.Add(Shivbaba);
    settings.Items.Add(ShivbabaItemGroup);


    FABActionGroup ImageItemGroup = new FABActionGroup() { ContextName = "ImageToolBarContext" };
    FABActionItem ZoomIn = new FABActionItem();
    ZoomIn.ActionName = "ZoomIn";
    ZoomIn.Image.SpriteProperties.CssClass = "imagesprite zoomin";
    ZoomIn.Text = "Zoom In";
    ImageItemGroup.Items.Add(ZoomIn);

    FABActionItem ZoomOut = new FABActionItem();
    ZoomOut.ActionName = "ZoomOut";
    ZoomOut.Image.SpriteProperties.CssClass = "imagesprite zoomout";
    ZoomOut.Text = "Zoom Out";
    ImageItemGroup.Items.Add(ZoomOut);

    FABActionItem Rotate = new FABActionItem();
    Rotate.ActionName = "Rotate";
    Rotate.Image.SpriteProperties.CssClass = "imagesprite rotateclock";
    Rotate.Text = "Rotate";
    ImageItemGroup.Items.Add(Rotate);

    FABActionItem Fit = new FABActionItem();
    Fit.ActionName = "Fit";
    Fit.Image.SpriteProperties.CssClass = "imagesprite fittoscreen";
    Fit.Text = "Fit";
    ImageItemGroup.Items.Add(Fit);

    if (ScreenType != "Type3")
    {
        FABActionItem Back = new FABActionItem();
        Back.ActionName = "Back";
        Back.Image.SpriteProperties.CssClass = "imagesprite back";
        Back.Text = "Back";
        ImageItemGroup.Items.Add(Back);
    }
    settings.Items.Add(ImageItemGroup);

    FABActionGroup AuditActionGroup = new FABActionGroup() { ContextName = "AuditActionContext" };
    FABActionItem Reject = new FABActionItem();
    Reject.ActionName = "Reject";
    Reject.Image.SpriteProperties.CssClass = "imagesprite rejectrednew";
    Reject.Text = "Reject";
    AuditActionGroup.Items.Add(Reject);

    FABActionItem AcceptWithRemarks = new FABActionItem();
    AcceptWithRemarks.ActionName = "AcceptWithRemarks";
    AcceptWithRemarks.Image.SpriteProperties.CssClass = "imagesprite acceptwithremark";
    AcceptWithRemarks.Text = "Accept With Remarks";
    AuditActionGroup.Items.Add(AcceptWithRemarks);

    FABActionItem Accept = new FABActionItem();
    Accept.ActionName = "Accept";
    Accept.Image.SpriteProperties.CssClass = "imagesprite accept_new";
    Accept.Text = "Accept";
    AuditActionGroup.Items.Add(Accept);

    FABActionItem BackAudit = new FABActionItem();
    BackAudit.ActionName = "BackAudit";
    BackAudit.Image.SpriteProperties.CssClass = "imagesprite back";
    BackAudit.Text = "Back";
    AuditActionGroup.Items.Add(BackAudit);
    settings.Items.Add(AuditActionGroup);


    FABActionGroup VouchingActionGroup = new FABActionGroup() { ContextName = "VouchingActionContext" };
    FABActionItem Reject_vouching = new FABActionItem();
    Reject_vouching.ActionName = "Reject";
    Reject_vouching.Image.SpriteProperties.CssClass = "imagesprite rejectrednew";
    Reject_vouching.Text = "Reject";

    FABActionItem AcceptWithRemarks_vouching = new FABActionItem();
    AcceptWithRemarks_vouching.ActionName = "AcceptWithRemarks";
    AcceptWithRemarks_vouching.Image.SpriteProperties.CssClass = "imagesprite acceptwithremark";
    AcceptWithRemarks_vouching.Text = "Accept With Remarks";

    FABActionItem Accept_vouching = new FABActionItem();
    Accept_vouching.ActionName = "Accept";
    Accept_vouching.Image.SpriteProperties.CssClass = "imagesprite accept_new";
    Accept_vouching.Text = "Accept";

    VouchingActionGroup.Items.Add(Reject_vouching);
    VouchingActionGroup.Items.Add(AcceptWithRemarks_vouching);
    VouchingActionGroup.Items.Add(Accept_vouching);

    settings.Items.Add(VouchingActionGroup);

    //settings.ClientSideEvents.ActionCollapsing = "OnActionItemCollapsing";
    if (ScreenType == "Type4")
    {
        FABActionGroup EditItemGroup = new FABActionGroup() { ContextName = "EditContext" };
        FABActionItem Edit = new FABActionItem();
        Edit.ActionName = "Edit_GridRow";
        Edit.Image.SpriteProperties.CssClass = "imagesprite edit";
        Edit.Text = "Edit";
        EditItemGroup.Items.Add(Edit);

        settings.Items.Add(EditItemGroup);

        FABActionGroup SaveCancelItemGroup = new FABActionGroup() { ContextName = "SaveCancelContext" };
        FABActionItem Save = new FABActionItem();
        Save.ActionName = "Save_GridRow";
        Save.Image.SpriteProperties.CssClass = "imagesprite attach_green_2";
        Save.Text = "Save";
        SaveCancelItemGroup.Items.Add(Save);

        FABActionItem Cancel = new FABActionItem();
        Cancel.ActionName = "Cancel_GridRow";
        Cancel.Image.SpriteProperties.CssClass = "imagesprite cross";
        Cancel.Text = "Cancel";
        SaveCancelItemGroup.Items.Add(Cancel);

        settings.Items.Add(SaveCancelItemGroup);
    }

    settings.ClientSideEvents.Init = "OnFABInit";
    settings.ClientSideEvents.ActionItemClick = "On_" + ActionItem + "_FABActionItemClick";

}).GetHtml()

