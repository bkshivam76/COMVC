<div class="Common_Export_ClearReferences">
    @using DevExtreme.AspNet.Mvc;
    @{
        string GridName = ViewBag.GridName;
        string FileName = (ViewBag.Filename == null ? GridName : ViewBag.Filename);
    }
    <div>
        @(Html.DevExtreme().Button()
                .ID("Common_ExportGridDataxlsx")
                .Text("Export to XLSX")              
                .OnClick("ExportXLSX")
                .Visible(true)
                .Width(120)
    )


    </div>
    <script>
        function ExportXLSX(e)
        {
            const workbook = new ExcelJS.Workbook();
            const worksheet = workbook.addWorksheet('Sheet');

            DevExpress.excelExporter.exportDataGrid({
                worksheet: worksheet,
                component: $("#" + "@GridName").dxDataGrid("instance"),
                autoFilterEnabled: true,
                customizeCell({ excelCell, gridCell }) {
                }
            }).then(function (exportRange) {
                workbook.xlsx.writeBuffer().then(function (buffer) {
                    saveAs(new Blob([buffer], { type: 'application/octet-stream' }), "@FileName" + ".xlsx");
                });
            });
            $("#report_export_modal").dxPopup("hide");
        }
    </script>

</div>