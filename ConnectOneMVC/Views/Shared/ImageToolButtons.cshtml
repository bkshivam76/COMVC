@using DevExtreme.AspNet.Mvc;
@{
    var modelSplit = Model.Split('|');
    var InPopup = modelSplit[0];
    var imgTag = modelSplit[1];
    string iD = "ItemToolBar_Action_BG_" + imgTag;
}
@(Html.DevExtreme().ButtonGroup()

                                                                                .ID(iD)
                                                                                    .KeyExpr("item")
                                                                                    .StylingMode(ButtonStylingMode.Text)
                                                                                    .SelectionMode(ButtonGroupSelectionMode.Single)
                                                                                    .Items(items =>
                                                                                    {
                                                                                        if (InPopup == "0")
                                                                                        {
                                                                                            items.Add().Icon(Url.Content("~/Content/FloatingActionButton/Images/zoomin.png")).Hint("Zoom In").Option("item", "ZoomIn");
                                                                                            items.Add().Icon(Url.Content("~/Content/FloatingActionButton/Images/zoomout.png")).Hint("Zoom Out").Option("item", "ZoomOut");
                                                                                            items.Add().Icon(Url.Content("~/Content/FloatingActionButton/Images/rotateclock.png")).Hint("Rotate").Option("item", "Rotate");
                                                                                            items.Add().Icon(Url.Content("~/Content/FloatingActionButton/Images/fittoscreen.png")).Hint("Fit").Option("item", "Fit");
                                                                                        }
                                                                                        else if(InPopup == "1")
                                                                                        {
                                                                                            items.Add().Icon(Url.Content("~/Content/FloatingActionButton/Images/zoomin.png")).Hint("Zoom In").Option("item", "ZoomIn_Popup");
                                                                                            items.Add().Icon(Url.Content("~/Content/FloatingActionButton/Images/zoomout.png")).Hint("Zoom Out").Option("item", "ZoomOut_Popup");
                                                                                            items.Add().Icon(Url.Content("~/Content/FloatingActionButton/Images/rotateclock.png")).Hint("Rotate").Option("item", "Rotate_Popup");
                                                                                            items.Add().Icon(Url.Content("~/Content/FloatingActionButton/Images/fittoscreen.png")).Hint("Fit").Option("item", "Fit_Popup");
                                                                                        }
                                                                                    })
                                                                                    .OnItemClick(String.Format("function (e) {{ ImageTools_buttonGroup_Click(e,'{0}'); }}", imgTag))
)