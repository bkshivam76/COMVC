    function OpenDynamicPopup(PopupTitle, LoadURL, maxHeight = "100%", maxWidth = "100%") {
        $("#Dynamic_Content_popup").dxPopup("instance").option("contentTemplate", "<div id='result_Dynamic_Content_popup'></div>")
        $("#Dynamic_Content_popup").dxPopup("instance").option("title", PopupTitle)

        //added height & width as few popups were getting very short dimensions
        $("#Dynamic_Content_popup").dxPopup("instance").option("height", "65%")
        $("#Dynamic_Content_popup").dxPopup("instance").option("width", "65%")

        //$("#Dynamic_Content_popup").dxPopup("instance").option("maxHeight", maxHeight)
        //$("#Dynamic_Content_popup").dxPopup("instance").option("maxWidth", maxWidth)
        $("#Dynamic_Content_popup").dxPopup("instance").option("fullScreen", false)
        $("#result_Dynamic_Content_popup").html(null);
        $("#Dynamic_Content_popup").dxPopup("show");
        ShowLoader();

        $("#result_Dynamic_Content_popup").load(LoadURL, function () {
            HideLoader();
        });
    }

    function OpenAssetTrasferPopup(PopupTitle, LoadURL, maxHeight = "100%", maxWidth = "100%") {
        $.ajax({
            type: 'GET',
            url: "/Account/AssetTransferVoucher/Pending_List",
            data: { Tag: "_New", Selected_Item_ID: "" },
            cache: false,
            success: function (data) {

                $("#Dynamic_Content_popup").dxPopup("instance").option("contentTemplate", "<div id='result_Dynamic_Content_popup'></div>")
                if (data.result == true) {
                    $("#Dynamic_Content_popup").dxPopup("show");
                    $("#Dynamic_Content_popup").dxPopup("instance").option("title", PopupTitle);
                    $("#Dynamic_Content_popup").dxPopup("instance").option("maxHeight", maxHeight)
                    $("#Dynamic_Content_popup").dxPopup("instance").option("maxWidth", maxWidth)
                    $("#result_Dynamic_Content_popup").load(data.PopupFormPath, function () {
                        HideLoader();
                    });
                    $("#Dynamic_Content_popup").dxPopup("instance").option(
                        "onHidden", function (e) {
                            $("#Dynamic_Content_popup").dxPopup("instance").option(
                                "onHidden", function (e) {// removed hiding propertof popup.
                                });
                            $("#Dynamic_Content_popup").dxPopup("show");
                            $("#Dynamic_Content_popup").dxPopup("instance").option("title", "Match ~ Asset Transfer Entries");
                            debugger;
                            var customUrl = LoadURL + "&Date=" + encodeURIComponent(_Date) + "&Item_ID=" + _ITEM_ID + "&CEN_ID=" + _CEN_ID + "&Asset_Type=" + _Asset_Type + "&ASSET_REF_ID=" + _ASSET_REF_ID + "&ASSET_QTY=" + _ASSET_QTY + "&ASSET_SALE_AMT=" + _ASSET_SALE_AMT + "&Amount=" + _Amount + "&PUR_ID=" + _PUR_ID + "&ID=" + _ID + "&M_ID=" + _M_ID + "&EDIT_DATE=" + encodeURIComponent(_Date);
                            $("#result_Dynamic_Content_popup").load(customUrl, function () {
                                HideLoader();
                            });
                        });
                }
                else {
                    $("#Dynamic_Content_popup").dxPopup("show");
                    $("#Dynamic_Content_popup").dxPopup("instance").option("title", PopupTitle);
                    $("#Dynamic_Content_popup").dxPopup("instance").option("maxHeight", maxHeight)
                    $("#Dynamic_Content_popup").dxPopup("instance").option("maxWidth", maxWidth)
                    $("#result_Dynamic_Content_popup").load(LoadURL, function () {
                        HideLoader();
                    });
                }
            }
        });
    }
