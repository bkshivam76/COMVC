<script>
    var sessionclearpath = "";
    var dontaskpopupcloseconfirmation = true;
    function Dynamic_Content_popup_hiding(e) {
        HideLoader();
        if (dontaskpopupcloseconfirmation == false) {
            var result = DevExpress.ui.dialog.confirm("Are You Sure You want To Close...?", "Confirm");
            result.done(function (dialogResult) {
                if (dialogResult) {
                    $("#Dynamic_Content_popup").dxPopup("hide");
                    //$('body').css('overflow', 'visible');
                    if (sessionclearpath != "") {
                        $.ajax({
                            type: 'GET',
                            url: sessionclearpath,
                            cache: false,
                            async: false
                        });
                        sessionclearpath = "";

                    }
                    dontaskpopupcloseconfirmation = true;
                }
                else {
                    $("#Dynamic_Content_popup").dxPopup("show");
                    dontaskpopupcloseconfirmation = false;
                }
            });
        }
        else {
            if (sessionclearpath != "") {
                $.ajax({
                    type: 'GET',
                    url: sessionclearpath,
                    cache: false,
                    async: false
                });
                sessionclearpath = "";
            }
            dontaskpopupcloseconfirmation = true;
        }
    }

