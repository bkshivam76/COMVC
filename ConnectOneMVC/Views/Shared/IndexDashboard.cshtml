    $(".TabPanalMenu-tabs").on("click", "li", function (event) {
        var calling_id = event.target.toString();
        if (calling_id.indexOf('#') != -1) {//should happen only for Navigation tabs
            $(".TabPanalMenu-tabs li").removeClass("active");
            $(this).addClass("active");
        }
    });


    $(".TabPanalMenu-tabs").on("click", "span", function () {
        $(".TabPanalMenu-tabs li.active").prev().addClass("active");
        $(".TabPanalMenu-tabs li.active").prev().find("a").trigger("click");
        var anchor = $(this).siblings('a');
        $(anchor.attr('href')).remove();
        $(this).parent().remove();
        $(".TabPanalMenu li").children('a').first().click();
        AllOpenControlTabs.splice($.inArray(anchor.attr('href').split('#')[1], AllOpenControlTabs), 1);

    });

