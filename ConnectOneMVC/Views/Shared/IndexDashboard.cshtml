    function BracketKeyPressEvent(e) {
        if (e.key == "[") {
            $(this).val($(this).val() + "(");
            e.preventDefault();
        }
        if (e.key == "]") {
            $(this).val($(this).val() + ")");
            e.preventDefault();
        }
        if (e.key == "'") {
            $(this).val($(this).val() + "`");
            e.preventDefault();
        }
    }

