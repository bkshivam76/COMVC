    function TxtboxAllowAlphaNumeric(evt) {
        var e = evt.htmlEvent || window.event;
        if (!((e.keyCode >= 48 && e.keyCode <= 57) ||
            (e.keyCode >= 65 && e.keyCode <= 90) ||
            (e.keyCode >= 96 && e.keyCode <= 105) ||
            (e.keyCode == 8 || e.keyCode == 46 || e.keyCode == 37 ||
