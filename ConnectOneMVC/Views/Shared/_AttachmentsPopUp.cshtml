@using DevExtreme.AspNet.Mvc;

<style>
    /*Attach modal*/
    #attachMdl .modal-dialog, #showAllAttachments .modal-dialog { max-width: 720px; width: 100% }
    #showAllAttachments .modal-dialog { max-width: 1182px; max-height: 100px }
    #attachMdl_sr .modal-dialog { max-width: 1182px; margin-top: -1px; width: 100%; }
    #attachMdl_sr .modal-body { max-height: 83vh; overflow: auto; }
    #galleryContainer_sr .modal-dialog .up-box > a:nth-child(3n) { margin-right: 15px }
    .up-box img, .up-box video { width: 215px; position: relative; height: 140px; object-fit: contain; border-radius: 6px 6px 0 0; background: url(/Content/events/images/concrete.jpg); }
    .up-box > a video + textarea.form-control { position: relative; top: -5px; }
    .up-box > a { float: left; position: relative; width: 215px; margin: 15px 15px 0 0; height: 230px; text-decoration: none }
    #attachMdl .up-box > a:nth-child(3n), #showAllAttachments .up-box > a:nth-child(5n) { margin-right: 0; }
    .up-box > a .form-control { height: 63px; font-size: 11px; margin-top: -1px; border-radius: 0 0 6px 6px; padding: 5px; text-decoration: none }
    .up-box .bxs-trash { position: absolute; right: -8px; top: -7px; border-radius: 100%; color: var(--gray); padding: 2px; background: #f7f7f7; border: 1px solid #e5e5e5; cursor: pointer; font-size: 14px; opacity: 0; transition: .3s all; }
    .up-box > a:hover .bxs-trash { opacity: 1 }
    .up-box .bxs-trash:hover { color: var(--black); }
    #attachMdl .dx-button-has-text .dx-button-content, #attachMdl_sr .dx-button-has-text .dx-button-content { padding: 8px }
    #attachMdl .dx-fileuploader-wrapper, #attachMdl_sr .dx-fileuploader-wrapper { padding: 0 }
    #attachMdl .close, #attachMdl_sr .close { font-size: 20px; margin-top: -20px }
    #attachMdl .badge.badge-primary, #attachMdl .badge.badge-primary { display: inline-block; padding: 8px; min-height: auto; cursor: pointer; margin-top: 5px; border-radius: 5px; }
    #attachMdl .badge.badge-primary:hover, #attachMdl .badge.badge-primary:hover { color: #323232 }
    #attachMdl .btn.btn-default, #attachMdl .btn.btn-default { position: relative; top: 3px; margin-right: 5px; }
    .svg-inline--fa.fa-w-18 { width: 22px !important; height: 22px; margin-top: 5px; margin-right: 3px; color: #ddd }
    #scrollView_AttachmentsPopup_Attach_GSM .badge.badge-danger { float: right; background-color: #ad1f1f; font-size: 14px; color: #fff; padding: 12px 15px; border-radius: 5px; margin: 0; margin-top: -15px; position: relative; top: 7px; }
    
    @@media only screen and (max-device-width:767px) {
        .up-box img, .up-box > a, #scrollView_AttachmentWindow, #scrollView_AttachmentWindow label { width: 100% }
        #scrollView_AttachmentsPopup_Attach_GSM .badge.badge-danger { float: left; margin: 0 0 3px; }
        .up-box .bxs-trash {opacity: 1}
    }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/boxicons@latest/css/boxicons.min.css">
@{
    string[] ModelParts = Model.Split(',');
    string UniqueIdentifier = ModelParts[0];
    string ActionMethod = ModelParts[1];
    string Rec_ID = ModelParts[2];
    string RefScreen = ModelParts[3];
    string PopupID = string.Concat("AttachmentsPopup_", UniqueIdentifier);

}
@(
        Html.DevExtreme().Popup().CustomPopup().ID(PopupID).Width(1250).Height("90%").MinHeight(500).ShowTitle(true)
        .Title("Upload").DragEnabled(false).CloseOnOutsideClick(false).OnHiding(string.Format("function (e) {{AttachmentsPopup_onhiding(e,'{0}')}}",UniqueIdentifier))
        .ToolbarItems(barItems =>
        {
        barItems.Add().Toolbar(Toolbar.Bottom).Location(ToolbarItemLocation.After).Widget(widget => widget.Button().Text("Done").OnClick(string.Format("function(e){{AttachmentsPopup_DoneClick(e,'{0}')}}",UniqueIdentifier)));
        })
        .ShowCloseButton(true).ContentTemplate(@<text> @Html.Partial("_AttachmentsWindow",(string)Model) </text>)
)
