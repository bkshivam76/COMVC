    <script>
        var isCollapsed = false;
        function OnFABInit(s, e) {
            $('.dx-fab-text').hide();
            $('.dx-fab-action').hover(function () { $(this).find('.dx-fab-text').show(); }, function () { $(this).find('.dx-fab-text').hide(); });
            dragElement(document.getElementById(s.uniqueID));
            //$(".dx-fab-container").draggable();
        }
        function On_UniversalDoc_FABActionItemClick(s, e) {
            s.ExpandActionGroupItems();
            var img = document.getElementById('BottomRightPane_Img');
            if (e.actionName === "Rotate") {
                ImageRotate(img);
            }
            else if (e.actionName === "ZoomOut") {
                ImageZoomOut(img);
            }
            else if (e.actionName === "ZoomIn") {
                ImageZoomIn(img);
            }
            else if (e.actionName == "Fit") {
                ImageFit(img);
            }
            else if (e.actionName == "Back") {
                s.CollapseActionGroupItems();
                s.SetVisible(false);
                //ImageBack(s.uniqueID, "actionItemContext");
            }
        }
        function OnSplitterPaneResized(s, e)
        {       
            var name = e.pane.name;
            if (name == "MiddlePane")
            {                
                //$("#TabMainDivID").height(e.pane.GetClientHeight());
                //$("#TabMainDivID").width(e.pane.GetClientWidth()); //these 2 lines are commented because middle pane was not resizing if right pane was resized and then collapsed.
            }
            else if (name == "RightPane") {
                // $("#TabMainDivID").height(e.pane.GetClientHeight());
                // $("#TabMainDivID").width(e.pane.GetClientWidth());
            }
            setTimeout(function ()
            {
                adjustDxGridsOnSplitterResize()
            })
        }
        function OnSplitterPaneInit(s, e) {

        }
        function OnSplitterPaneExpanded(s, e) {
            ASPxClientControl.AdjustControls(document.getElementById("TabPanalMenu-content_DivID"));
            setTimeout(function ()
            {
                adjustDxGridsOnSplitterResize()
            })
        }
        function OnSplitterPaneCollpased(s, e) {
            ASPxClientControl.AdjustControls(document.getElementById("TabPanalMenu-content_DivID"));
            var name = e.pane.name;
            var Iframe = document.getElementById('RightPane_Iframe');
            var IframeDiv = document.getElementById('RightPane_div_Iframe');
            var ImageDiv = document.getElementById('RightPane_div_Img')
            var ImageTag = document.getElementById('RightPane_Img');
            if (name == "RightPane") {
                //ImageTag.src = "";
                //Iframe.src = "about:blank";
                //ImageTag.style.transform = 'rotate(360deg)';
                //IframeDiv.style.display = "none";
                //ImageDiv.style.display = "none";
            }
            setTimeout(function () {
                adjustDxGridsOnSplitterResize()
            })
        }
        function adjustDxGridsOnSplitterResize()
        {
            var DXgrids = $("#TabPanalMenu-content_DivID .tab-pane.active .DataGridListing")
            if (DXgrids.length > 0) {
                for (var i = 0; i < DXgrids.length; i++) {
                    var gridInstance = $(DXgrids[i]).data("dxDataGrid")
                    if (gridInstance != void 0) {
                        gridInstance.updateDimensions();
                    }

                }
            }
            var DXgrids = $("#LeftPane_Div_Content .DataGridListing")
            if (DXgrids.length > 0) {
                for (var i = 0; i < DXgrids.length; i++) {
                    var gridInstance = $(DXgrids[i]).data("dxDataGrid")
                    if (gridInstance != void 0) {
                        gridInstance.updateDimensions();
                    }

                }
            }
        }
        function OnSplitterPaneCollapsing(s, e) {
            var name = e.pane.name;
            if (name == 'headerpane') {
                e.cancel = true;
                isCollapsed = !isCollapsed;
                e.pane.SetSize(GetCollapseSize(s, isCollapsed));
                ChangeCollapseImage(isCollapsed);
            }
        }
        function GetCollapseSize(splitter, isCollapsed) {
            alert(isCollapsed ? 50 : 130);
            return isCollapsed ? 50 : 130;
        }

        function ChangeCollapseImage(isCollapsed) {
            var arrows = $('.dxsplS tr');
            arrows.hide();
            $(arrows[GetActiveImageIndex(isCollapsed)]).show()
        }

        function GetActiveImageIndex(isCollapsed) {
            return isCollapsed ? 0 : 1;
        }
        function CollpasePane(s, e, CollpasePane, ExpandPane) {
            var PaneToCollpase = s.GetPaneByName(CollpasePane);
            var PaneToExpand = s.GetPaneByName(ExpandPane);
            PaneToCollpase.Collapse(PaneToExpand);
        }

    </script>
