        function Independent_Attachment_Window_OnSuccess(data) {
            if (data.result == true) {

                DevExpress.ui.dialog.alert(data.Message, "Inform");
                var gridInstance = $("div[id = '" + Refresh_Grid_on_Attachment_Add_ID + "']").data("dxDataGrid")
                if (gridInstance !== void 0)
                {
                    gridInstance.refresh().done(function()
                    {
                        var selectedRowKeys = gridInstance.getSelectedRowKeys()
                        if (selectedRowKeys != null && selectedRowKeys.length > 0) {
                            gridInstance.clearSelection()
                            gridInstance.selectRows(selectedRowKeys)
                        }
                    })
                }
                else
                {
                    var gridInstance = ASPxClientControl.GetControlCollection().GetByName(Refresh_Grid_on_Attachment_Add_ID);
                    gridInstance.Refresh();
                }
                HideLoader_L();
            }
            if (data.result == false) {
                DevExpress.ui.dialog.alert(data.Message, "Inform");
                HideLoader_L();
            }
            $("#Dynamic_Content_popup").dxPopup("hide");
        }
