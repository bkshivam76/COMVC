        .dxrd-menu-export-popover .dx-popup-content::-webkit-scrollbar-thumb { border-radius: 10px; -webkit-box-shadow: inset 0 0 6px rgba(0,0,0,0.5); }

        .dxpc-header { height: 30px; background: linear-gradient(to bottom, #7bcdff 0%,#1e8bed 100%); }

        .dxpc-closeBtn { padding: 0px !important; background-color: white; }

        .dxpc-headerText { font-size: 15px; color: white; }

