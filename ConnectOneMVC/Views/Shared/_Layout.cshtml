                {
                    $(".TabPanalMenu-tabs").append('<li class="w3-bar-item w3-button testbtn active" id="contact_' + frmName + '"><a onclick="TabOnClick()" class="customlia" data-toggle="tab" data-target="#' + frmName + '" href="#' + frmName + '">' + Pagetitle + '</a><span class="closeTab">x</span></li>');//redmine bug #132965 fixed
