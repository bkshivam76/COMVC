<body>
    <script type="text/javascript">
        $(document).ajaxStart(function () {

        }).ajaxSend(function () {
            //ShowLoader_ajax();
        }).ajaxStop(function () {

        }).ajaxComplete(function (event, xhr, settings) {
            //if (xhr.status == 403) {
            //    $("#Login_popup").dxPopup("show");
            //}
            if (xhr.status == 500) {
            }
            //HideLoader_ajax();
        });
        $.ajaxSetup({
            //All ajax request will be pass parameter center GUIID
            beforeSend: function (jqXHR, settings) {
                (jqXHR, settings)
                settings.url = updateQueryStringParameter(settings.url, 'SessionGUID', getParameterByName('SessionGUID', window.location.href));
            }
        });
        $(document).ready(function () {
            $("#loadPanel,#loadPanel_ready,#loadPanel_gridView,#loadPanel_clearReference").dxLoadPanel({
                message: 'Loading...',
                closeOnOutsideClick: false,
                showPane: false,
                shading: true,
                height: "100%",
                width: "100%",
                shadingColor: "",
                deferRendering: false,
                visible: false
            });
            $("#loadPanel_ajax").dxLoadPanel({
                message: 'Please Wait...',
                closeOnOutsideClick: false,
                showPane: false,
                shading: true,
                height: "100%",
                width: "100%",
                shadingColor: "",
                deferRendering: false,
                visible: false
            });
        })

    </script>

    <div class="container-fluid">
        @RenderBody()
        @*Loading Panel*@
        <div id="Layout_Loader">
            <div id="loadPanel"></div>
            <div id="loadPanel_ready"></div>
            <div id="loadPanel_gridView"></div>
            <div id="loadPanel_ajax"></div>
            <div id="loadPanel_clearReference"></div>
        </div>
        <div id="Global_popup">
            @*Loading Panel*@
        </div>
        </div>

</body>
