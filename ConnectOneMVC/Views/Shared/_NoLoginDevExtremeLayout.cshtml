<!DOCTYPE html>
<html>
<head>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=0">
    <title>Form Response</title>
    <link rel="icon" href="~/Content/image/logo_small.png">
    @System.Web.Optimization.Styles.Render("~/Content/QuillBundle")
    @System.Web.Optimization.Scripts.Render("~/Scripts/QuillBundle")
    @*Start StyleSheets*@
    <link href="@Url.Content("~/Content/dx.common.css")" rel="Stylesheet" />
    <link href="@Url.Content("~/Content/dx.light.css")" rel="Stylesheet" />
    <link href="@Url.Content("~/DX.ashx?cssfile=~/Content/css/bootstrap.min.css")" rel="Stylesheet" />
    <link href="@Url.Content("~/DX.ashx?cssfile=~/Content/css/base.css")" rel="Stylesheet" />
    <link href="@Url.Content("~/DX.ashx?cssfile=~/Content/site.css")" rel="Stylesheet" />
    <link href="@Url.Content("~/DX.ashx?cssfile=~/Content/css/responsive-tablet-big.css")" rel="Stylesheet" />
    <link href="@Url.Content("~/DX.ashx?cssfile=~/Content/css/responsive.css")" rel="Stylesheet" />
    <link href="@Url.Content("~/DX.ashx?cssfile=~/Content/css/font-awesome.css")" rel="Stylesheet" />
    <link href="@Url.Content("~/DX.ashx?cssfile=~/Content/css/dx.icons.css")" rel="Stylesheet" />
    <link href="@Url.Content("~/DX.ashx?cssfile=~/Content/css/custom.css")" rel="Stylesheet" />
    <link href="@Url.Content("~/DX.ashx?cssfile=~/Content/CustomeDevextream.css")" rel="stylesheet">
    <link href="@Url.Content("~/DX.ashx?cssfile=~/Content/Min Css/googleapis.min.css")" rel="stylesheet">
    <link href="@Url.Content("~/DX.ashx?cssfile=~/Content/Min Css/ImageSprite.sprite.min.css")" rel="stylesheet">
    <link href="@Url.Content("~/Content/css/index.css")" rel="Stylesheet" />

    <script src="@Url.Content("~/Scripts/jquery-3.6.0.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/dx.all.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/aspnet/dx.aspnet.data.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/aspnet/dx.aspnet.mvc.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/DX.ashx?jsfileset=~/Content/js/jquery.slimscroll.min.js;~/Content/fontawesome/js/fontawesome_v5_all.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/DX.ashx?jsfile=~/Scripts/moment.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/bootstrap.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/CommonFn.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/exceljs.min.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/FileSaver.min.js")" type="text/javascript"></script>
</head>
<body>  
    <script type="text/javascript">     
        $(document).ajaxStart(function () {

        }).ajaxSend(function () {
            //ShowLoader_ajax();
        }).ajaxStop(function () {

        }).ajaxComplete(function (event, xhr, settings) {
            //if (xhr.status == 403) {
            //    $("#Login_popup").dxPopup("show");
            //}
            if (xhr.status == 500) {
            }
            //HideLoader_ajax();
        });
        $.ajaxSetup({
            //All ajax request will be pass parameter center GUIID
            beforeSend: function (jqXHR, settings) {
                (jqXHR, settings)
                settings.url = updateQueryStringParameter(settings.url, 'SessionGUID', getParameterByName('SessionGUID', window.location.href));
            }
        });     
        $(document).ready(function () {
            $("#loadPanel,#loadPanel_ready,#loadPanel_gridView,#loadPanel_clearReference").dxLoadPanel({
                message: 'Loading...',
                closeOnOutsideClick: false,
                showPane: false,
                shading: true,
                height: "100%",
                width: "100%",
                shadingColor: "",
                deferRendering: false,
                visible: false
            });
            $("#loadPanel_ajax").dxLoadPanel({
                message: 'Please Wait...',
                closeOnOutsideClick: false,
                showPane: false,
                shading: true,
                height: "100%",
                width: "100%",
                shadingColor: "",
                deferRendering: false,
                visible: false
            });
        })
    </script>

    <div class="container-fluid">
        @RenderBody()
        @*Loading Panel*@
        <div id="Layout_Loader">
            <div id="loadPanel"></div>
            <div id="loadPanel_ready"></div>
            <div id="loadPanel_gridView"></div>
            <div id="loadPanel_ajax"></div>
        </div>
        @*Loading Panel*@
    </div>

</body>
</html>
