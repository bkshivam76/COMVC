        body {
            background: url(/Content/Images/india-bg.jpg);
            background-size: cover;
            background-position: center;
            font-family: 'Helvetica Neue','Segoe UI',Helvetica,Verdana,sans-serif !important;
            line-height: 1.35715 !important;
            font-weight:400;
            padding:0px !important;
        }
        .MainScreen_WOLogin {
            max-width: 1300px;
            margin: 0 auto;
            padding: 15px;
            background: rgba(240,240,240,.6);
            border-radius: 6px;
        }
        .ServiceReportWindowFacility_ClearReferences {
            overflow-y: scroll;
            max-height: 100vh;
        }
        .fa-rotate-270 {
            -webkit-transform: rotate(270deg);
            -moz-transform: rotate(270deg);
            -ms-transform: rotate(270deg);
            -o-transform: rotate(270deg);
            transform: rotate(270deg);
        }

        .popupresponsive .dx-button-submit-input {
            display: none;
        }

