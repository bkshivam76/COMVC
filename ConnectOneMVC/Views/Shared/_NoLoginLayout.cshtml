            color: #0072C6 !important;
        }

        .dx-button-has-icon .dx-icon {
            height: 12px;
        }

        .dxrd-menu-export-popover .dxrd-menu-export-item {
            color: black !important;
        }

        .dxrd-menu-export-popover .dx-popup-content::-webkit-scrollbar {
            width: 16px;
        }

        .dxrd-menu-export-popover .dx-popup-content::-webkit-scrollbar-track {
            -webkit-box-shadow: inset 0 0 6px rgba(0,0,0,0.3);
            border-radius: 10px;
        }

        .dxrd-menu-export-popover .dx-popup-content::-webkit-scrollbar-thumb {
            border-radius: 10px;
            -webkit-box-shadow: inset 0 0 6px rgba(0,0,0,0.5);
        }

        .dxpc-header {
            height: 30px;
            background: linear-gradient(to bottom, #7bcdff 0%,#1e8bed 100%);
        }

        .dxpc-closeBtn {
            padding: 0px !important;
            background-color: white;
        }

        .dxpc-headerText {
            font-size: 15px;
            color: white;
        }

        .dxmodalSys {
            padding-top: 90px;
        }
        /*.dxpclW{
            z-index: 0 !important;
        }*/

    </style>
    <script>
        document.onmouseover = function () {
            //User's mouse is inside the page.
            window.innerDocClick = true;
        }

        document.onmouseleave = function () {
            //User's mouse has left the page.
            window.innerDocClick = false;
        }
