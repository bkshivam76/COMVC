                if (ActionMethod.includes("Delete")) {
                    colourcode = "#000000";
                    //colourcode = "#505256";
                }
            }
            var element = $("#" + formId).find('label,input:not(".dx-button-submit-input"),div.dx-checkbox,div.dx-radiogroup,div.dx-textarea').filter(':visible');
            if (element.length > 0) {
