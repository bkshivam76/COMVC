    function TransformText(text)
    {
        if (text == null)
        {
            return text
        }
        text = text.replace(/&quot;|&amp;|&lt;|&gt;|&#172;/gi, function (x)
        {
            return TransformCharacters(x);
        });
        return text;
    }
    function TransformCharacters(charStr)
    {
        if (charStr == "&quot;") {
            return "\"";
        }
        else if (charStr == "&amp;") {
            return "&";
        }
        else if (charStr == "&lt;") {
            return "<";
        }
        else if (charStr == "&gt;") {
            return ">";
        }
        else if (charStr == "&#172;")
        {
            return "¬";
        }
    }
    function BracketKeyPressEvent(e) {
