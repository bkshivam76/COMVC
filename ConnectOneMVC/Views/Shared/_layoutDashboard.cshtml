    <script type="text/javascript">
        var OpenTabName;
        $(window).on('beforeunload', function () {
            return 'Are You sure you want to Leave Connectone...';
        });
        $(document).ready(function () {

            var viewportWidth = $(window).width();
            if (viewportWidth > 767) {
                $(".user-setting-set").removeClass("user-info-togle-div");
            }

            $(".user-info-togle-click").click(function () {
                $(".user-info-togle-div").toggle(200);
            });

            $(".navbar-brand").click(function () {
                $(".toogle-menu").toggle(200);
            });
            $('ul.dropdown-menu [data-toggle=dropdown]').on('click', function (event) {
                event.preventDefault();
                event.stopPropagation();
                $(this).parent().siblings().removeClass('open');
                $(this).parent().toggleClass('open');
            });

            $("#loadPanel").dxLoadPanel({
                message: 'Loading...',
                visible: false
            });

            setInterval(function () { myTimer() }, 1000);
            //currDate();
            OpenTabControl("MY_home_Index", "Home", "@Url.Action("Home","Home",new { area="start"})")

            SetHeightGrid(OpenTabName);
        });

        function myTimer() {
            var d = new Date();
            var t = d.toLocaleTimeString();
            var dt = '@DateTime.Now.ToString("dddd, dd MMMM, yyyy")';
            document.getElementById("date-time").innerHTML = t + " " + dt;
        }

        @*function currDate() {
            var d = new Date();
            d.getDay + d.get
            document.getElementById("curr-date").innerHTML = '@DateTime.Now.ToString("dddd, dd MMMM, yyyy")';
        }*@

