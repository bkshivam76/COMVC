            var tab_navHeight = $(".TabPanalMenu-tabs").outerHeight();
            var bottom_height1 = $("#" + frmName).find(".footer-MainBoxdiv").outerHeight();
            var page_height = header_height + tab_navHeight + bottom_height1;
            var page_newHeight = win_height - page_height - 200;
