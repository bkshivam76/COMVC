        $(window).resize(function (e) {
            SetHeightGrid(OpenTabName);
        });

        var AllOpenControlTabs = ["MY_home_Index"]

        function OpenTabControl(frmName, Pagetitle, PageURL) {

            OpenTabName = frmName;
            if ($.inArray(frmName, AllOpenControlTabs) <= 0) {
                $(".TabPanalMenu-tabs li").removeClass("active");
                var id = $(".TabPanalMenu-tabs").children().length; //think about it ;)
                if (frmName == "MY_home_Index") {
                    $(".TabPanalMenu-tabs").append('<li class="w3-bar-item w3-button testbtn active" id="contact_' + frmName + '"><a class="customlia" data-toggle="tab" data-target="#' + frmName + '" href="#' + frmName + '">' + Pagetitle + '</a></li>');
                }
                else {
                    $(".TabPanalMenu-tabs").append('<li class="w3-bar-item w3-button testbtn active" id="contact_' + frmName + '"><a class="customlia" data-toggle="tab" data-target="#' + frmName + '" href="#' + frmName + '">' + Pagetitle + '</a><span class="closeTab">x</span></li>');
                    AllOpenControlTabs.push(frmName);
                }
                $('.TabPanalMenu-content').append('<div class="tab-pane" id="' + frmName + '"></div>');
                ShowLoader();
                $("#" + frmName).load(PageURL, function () {
                    HideLoader(), SetHeightGrid(frmName);
                });
            }
            if (window.innerWidth <= 800)
                $(".navbar-toggle ").trigger("click")
            $(".TabPanalMenu-tabs #contact_" + frmName + " a").tab('show'); //$(".nav-tabs #" + frmName).tab("show");
            SetHeightGrid(frmName);
        }

        function getParameterByName(name, url) {
            if (!url) url = window.location.href;
            name = name.replace(/[\[\]]/g, "\\$&");
            var regex = new RegExp("[?&]" + name + "(=([^&#]*)|&|#|$)"),
                results = regex.exec(url);
            if (!results) return null;
            if (!results[2]) return '';
            return decodeURIComponent(results[2].replace(/\+/g, " "));
        }

        $(document).ajaxStart(function () {
            //ShowLoader();
        }).ajaxStop(function () {
            //HideLoader();
        }).ajaxComplete(function (event, xhr, settings) {
            if (xhr.status == 403) {
                $("#Login_popup").dxPopup("show");
            }
            if (xhr.status == 500) {
            }
            SetHeightGrid(OpenTabName);
        });

        //If session timed out and ajax request is not getting called then blank screen appears
        function CheckAjaxUrl() {
            $.ajax({
                type: 'GET',
                url: "/Start/Home/Index",
                cache: false,
                success: function (x) {
                }
            });
        }

        var CenterGuid = "";
        function AjaxBeginFormPost(jqXHR, settings) {
            ShowLoader();
            settings.url = updateQueryStringParameter(settings.url, 'SessionGUID', getParameterByName('SessionGUID', window.location.href));
        }

        $.ajaxSetup({
            //All ajax request will be pass parameter center GUIID
            beforeSend: function (jqXHR, settings) {
                (jqXHR, settings)
                settings.url = updateQueryStringParameter(settings.url, 'SessionGUID', getParameterByName('SessionGUID', window.location.href));
            }
        });

        function updateQueryStringParameter(uri, key, value) {
            var re = new RegExp("([?&])" + key + "=.*?(&|$)", "i");
            var separator = uri.indexOf('?') !== -1 ? "&" : "?";
            if (uri.match(re)) {
                return uri.replace(re, '$1' + key + "=" + value + '$2');
            }
            else {
                return uri + separator + key + "=" + value;
            }
        }

        function ShowLoader() {
            $("#loadPanel").dxLoadPanel("instance").option("visible", true);
        }

        function HideLoader() {
            $("#loadPanel").dxLoadPanel("instance").option("visible", false);
        }

        function Open_Attachment_Window() {
            $("#ID_Frm_Help_Document_Attach").remove();            
            ShowLoader();
            OpenDynamicPopup('Add Attachment', '/Help/Attachment/Frm_Attachment_Window', 345, 800);
            HideLoader();
        }//Mantis 0000213 bug fixed
    </script>
    <div class="container-fluid">
